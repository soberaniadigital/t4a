msgid ""
"Usage: %s [OPTION]... {script-only-if-no-other-script} [input-file]...\n"
"\n"
msgstr ""
"Utilização: %s [OPTION]... {script_somente_se_não_houver_outro_script} "
"[ficheiro_de_entrada] ...\n"

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"supprimor a escrita automatica do buffer de trabalho sem gerar saída."

msgid ""
"      --debug\n"
"                 annotate program execution\n"
msgstr ""
"      --debug\n"
"                 anotar a execução do programa\n"

msgid ""
"  -e script, --expression=script\n"
"                 add the script to the commands to be executed\n"
msgstr ""
"  -e script, --expression=script\n"
"                 adicionar o script às comandas a serem executadas."

msgid ""
"  -f script-file, --file=script-file\n"
"                 add the contents of script-file to the commands to be executed\n"
msgstr ""
"  -f fichier-script, --file=fichier-script\n"
"                 adicionar o conteúdo do arquivo de script para as comandas a serem executadas."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguir links simbólicos durante o processamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 editar os arquivos no local (faz uma cópia de segurança se o SUFFIXE for especificado) \n"

msgid ""
"  -b, --binary\n"
"                 open files in binary mode (CR+LFs are not processed specially)\n"
msgstr ""
"  -b, --binary\n"
"                 abrir os arquivos no modo binário (CR+LF não são processados de forma especial) \n"

msgid ""
"  -l N, --line-length=N\n"
"                 specify the desired line-wrap length for the `l' command\n"
msgstr ""
"  -l N, --line-length=N\n"
"                 especificar a extensão desejada da linha para o comando \"l\"."

msgid ""
"  --posix\n"
"                 disable all GNU extensions.\n"
msgstr ""
"--posix\n"
"                 desativa todas as extensões GNU."

msgid ""
"  -E, -r, --regexp-extended\n"
"                 use extended regular expressions in the script\n"
"                 (for portability use POSIX -E).\n"
msgstr ""
" -E, --regexp-extended\n"
"                 utilizar a sintaxe das expressões regulares estendidas no script. (utilize o -E para compatibilidade)\n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de um único fluxo contínuo. "
"Para obter mais informações sobre esta opção, digite 'vi --help'."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 executa no modo sandbox (desativa as comandas e/r/w).\n"

msgid ""
"  -u, --unbuffered\n"
"                 load minimal amounts of data from the input files and flush\n"
"                 the output buffers more often\n"
msgstr ""
" -u, --unbuffered\n"
"                 carregar apenas as quantidades mínimas de dados dos arquivos de entrada e escrever os buffers de saída com mais frequência no disco."

msgid ""
"  -z, --null-data\n"
"                 separate lines by NUL characters\n"
msgstr ""
"  -z, --null-data\n"
"                 separar linhas com caractere NUL"

msgid "      --help     display this help and exit\n"
msgstr "      --help     mostra esta ajuda e sai\n"

msgid "      --version  output version information and exit\n"
msgstr "      --version  exibe as informações de versão do software e sai."

msgid ""
"\n"
"If no -e, --expression, -f, or --file option is given, then the first\n"
"non-option argument is taken as the sed script to interpret.  All\n"
"remaining arguments are names of input files; if no input files are\n"
"specified, then the standard input is read.\n"
"\n"
msgstr ""
"Se nenhuma das opções -e, --expression, -f ou --file forem especificadas, o "
"primeiro argumento que não é uma opção será considerado como o script sed a "
"ser interpretado. Todos os outros argumentos são tratados como nomes de "
"arquivos de entrada; caso nenhum seja especificado, a entrada padrão é "
"utilizada. Para obter mais informações sobre as expressões disponísas para "
"uso com este programa, use o comando 'sed --help'."

msgid "failed to set binary mode on STDIN"
msgstr "não foi possível definir o modo binário na entrada padrão (STDIN)"

