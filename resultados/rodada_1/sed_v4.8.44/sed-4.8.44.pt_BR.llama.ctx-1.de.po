msgid "Report bugs to: %s\n"
msgstr "Rapportez as anomalias para: %s\n"

msgid "Report %s bugs to: %s\n"
msgstr ""
"Rapportez os bugs %s ao fórum de suporte ou envie para o desenvolvedor "
"responsável. Para obter mais informações, tente `%s --help'."

