msgstr "Página inicial de %s: <%s>"

msgid "General help using GNU software: <%s>\n"
msgstr "Ajuda geral para o uso de software GNU: <%s>."

msgid "multiple `!'s"
msgstr "Múltiplas instâncias de '!'"

msgid "unexpected `,'"
msgstr "Ocorrência não esperada"

msgid "invalid usage of +N or ~N as first address"
msgstr "utilização inválida de +N ou ~N como primeira endereço"

msgid "unmatched `{'"
msgstr "{ não aparece sem parático }"

msgid "unexpected `}'"
msgstr "Ocultação não intencionada"

msgid "extra characters after command"
msgstr "caracteres desnecessários após a instrução"

msgid "expected \\ after `a', `c' or `i'"
msgstr "Após \textit{a}, \textit{c} ou \textit{i}, é esperado."

msgid "`}' doesn't want any addresses"
msgstr "não há necessidade de nenhuma endereço"

msgid ": doesn't want any addresses"
msgstr ": nenhuma adresse é necessária."

msgid "comments don't accept any addresses"
msgstr "Os comentários não aceitam endereços"

msgid "missing command"
msgstr "comando ausente"

msgid "command only uses one address"
msgstr "a comando não utiliza mais do que uma endereço"

msgid "unterminated address regex"
msgstr "expressão regular não concluída para endereço"

msgid "unterminated `s' command"
msgstr "comando não concluído"

msgid "unterminated `y' command"
msgstr "comando não concluído de 'y'"

msgid "unknown option to `s'"
msgstr "opção desconhecida para 's'"

msgid "multiple `p' options to `s' command"
msgstr "Mais de umas opções 'p' para o comando 's'"

msgid "multiple `g' options to `s' command"
msgstr "Mais de várias opções 'g' ao comando 's'"

msgid "multiple number options to `s' command"
msgstr "mais de várias opções numéricas ao comando 's'"

msgid "number option to `s' command may not be zero"
msgstr "A opção numérica da comando 's' não pode ser nula"

msgid "strings for `y' command are different lengths"
msgstr "As cadeias destinadas ao comando 'y' possuem comprimentos diferentes."

msgid "delimiter character is not a single-byte character"
msgstr "O caractere delimitador não é um único byte de caracteres"

msgid "expected newer version of sed"
msgstr "é esperada uma versão mais recente do sed."

msgid "invalid usage of line address 0"
msgstr "utilização inválida da linha de endereço %s"

msgid "unknown command: `%c'"
msgstr "comando desconhecido: »%c«"

msgid "incomplete command"
msgstr "comando inválido ou incompleto"

msgid "\":\" lacks a label"
msgstr "uma etiqueta está faltando para ':'"

msgid "recursive escaping after \\c not allowed"
msgstr "um escapamento recursivo após \\\"não é permitido\""

msgid "e/r/w commands disabled in sandbox mode"
msgstr "As operações de leitura/escrita (e/r/w) estão desativadas na sandbox."

msgid "%s: file %s line %lu: %s\n"
msgstr "%s: ficheiro %s linha %lu: %s\n"

msgid "%s: -e expression #%lu, char %lu: %s\n"
msgstr "%s: -e expressão n°%lu, caractere %lu: %s\n"

msgid "can't find label for jump to `%s'"
msgstr "impossível encontrar a etiqueta para saltar em \"%s\""

msgid "case conversion produced an invalid character"
msgstr "a conversão de caixa gerou um caractere inválido"

msgid "%s: can't read %s: %s\n"
msgstr "%s: é impossível ler %s: %s"

msgid "couldn't edit %s: is a terminal"
msgstr "impossível editar %s: é um terminal"

msgid "couldn't edit %s: not a regular file"
msgstr "impossível editar %s: não é um arquivo regular"

msgid "%s: warning: failed to set default file creation context to %s: %s"
msgstr ""
"%s: aviso: não foi possível alterar o contexto de criação do arquivo padrão "
"para %s: %s"

msgid "%s: warning: failed to get security context of %s: %s"
msgstr ""
"%s: aviso de segurança: não foi possível determinar o contexto de segurança "
"do %s, pois falta informações suficientes. Por favor, verifique se as "
"permissões estão corretamente configuradas."

msgid "couldn't open temporary file %s: %s"
msgstr "impossível abrir a pasta temporária %s: %s"

msgid "error in subprocess"
msgstr "erro no subprocesso"

msgid "option `e' not supported"
msgstr "A opção 'e' não é suportada."

msgid "`e' command not supported"
msgstr "Comando 'e' não é suportado."

msgid "no input files"
msgstr "não há arquivos de entrada disponíveis"

msgid "no previous regular expression"
msgstr "não há nenhum expressão regular anterior"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\\%d inválida no membro de direita da comando \"s\""

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"A tamanho do buffer de entrada da expressão regular é maior que INT_MAX"

