msgid ""
"GNU sed home page: <https://www.gnu.org/software/sed/>.\n"
"General help using GNU software: <https://www.gnu.org/gethelp/>.\n"
msgstr ""
"Página inicial do GNU sed: <https://www.gnu.org/software/sed/>.\n"
"Ajuda geral sobre o uso dos programas GNU-sed e outros software da comunidade GNU: <https://www.gnu.org/help/gethelp.pt.html>."

msgid "E-mail bug reports to: <%s>.\n"
msgstr "Envie os relatórios de anomalias por e-mail para: <%s>."

msgid "This sed program was built with SELinux support."
msgstr "Este programa foi compilado para suportar SELinux."

msgid "SELinux is enabled on this system."
msgstr "SELinux está ativado neste sistema."

msgid "SELinux is disabled on this system."
msgstr "SELinux está desativado neste sistema."

msgid "This sed program was built without SELinux support."
msgstr "Este programa foi compilado sem suporte para SELinux."

msgid ""
"Usage: %s [OPTION]... {script-only-if-no-other-script} [input-file]...\n"
"\n"
msgstr ""
"Utilização: %s [OPÇÃO] … {Script somente se não houver outro script} "
"[Arquivo de entrada]…\n"

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
"--quiet, --silent\n"
"                 suprimir a escrita automática no buffer de trabalho."

msgid ""
"      --debug\n"
"                 annotate program execution\n"
msgstr ""
"      --debug\n"
"                 comentar a execução do programa"

msgid ""
"  -e script, --expression=script\n"
"                 add the script to the commands to be executed\n"
msgstr ""
"  -e script, --expression=script\n"
"                 adicionar o script às comandos a serem executadas."

msgid ""
"  -f script-file, --file=script-file\n"
"                 add the contents of script-file to the commands to be executed\n"
msgstr ""
" -f fichier-script, --file=fichier-script\n"
"                 adicionar o conteúdo da fichier-script às comandas a serem executadas."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 siga os links simbólicos durante o processamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 editar os arquivos no local (gerará uma cópia de segurança se o SUFFIXE for especificado) \n"

msgid ""
"  -b, --binary\n"
"                 open files in binary mode (CR+LFs are not processed specially)\n"
msgstr ""
"  -b, --binary\n"
"                 abrir os arquivos em modo binário (CR+LF não são processados especialmente).\n"

msgid ""
"  -l N, --line-length=N\n"
"                 specify the desired line-wrap length for the `l' command\n"
msgstr ""
" -l N, --line-length=N\n"
"                 especifica a extensão desejada da quebra de linha para o comando 'l'."

msgid ""
"  --posix\n"
"                 disable all GNU extensions.\n"
msgstr ""
"--posix\n"
"de ativa todas as extensões GNU. \n"

msgid ""
"  -E, -r, --regexp-extended\n"
"                 use extended regular expressions in the script\n"
"                 (for portability use POSIX -E).\n"
msgstr ""
"utilize a sintaxe de expressões regulares estendidas no script.\n"
"(use -E para garantir portabilidade).\n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de uma única fonte contínua "
"longa. Para mais informações, tente `--help`."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 trabalha no modo sandbox (as comandas de entrada/saída e escrita estão desabilitadas).\n"

msgid ""
"  -u, --unbuffered\n"
"                 load minimal amounts of data from the input files and flush\n"
"                 the output buffers more often\n"
msgstr ""
" -u, --unbuffered\n"
"                 carrega apenas as quantidades mínimas de dados dos arquivos de entrada e escreve os buffers de saída com mais frequência no disco."

msgid ""
"  -z, --null-data\n"
"                 separate lines by NUL characters\n"
msgstr ""
"  -z, --null-data\n"
"                 separar linhas por caractere NUL"

msgid "      --help     display this help and exit\n"
msgstr "Tente `%s --help' para mais informações.\n"

msgid "      --version  output version information and exit\n"
msgstr ""
"      --version mostra as informações de versão do software e termina o "
"programa."

msgid ""
"\n"
"If no -e, --expression, -f, or --file option is given, then the first\n"
"non-option argument is taken as the sed script to interpret.  All\n"
"remaining arguments are names of input files; if no input files are\n"
"specified, then the standard input is read.\n"
"\n"
msgstr ""
"Se nenhuma das opções -e, --expression, -f ou --file forem especificadas, o "
"primeiro argumento que não é uma opção será considerado como um script sed "
"para interpretar. Todos os outros argumentos são tratados como nomes de "
"arquivos de entrada; caso nenhum seja especificado, a entrada padrão é lida."

msgid "failed to set binary mode on STDIN"
msgstr "não foi possível definir o modo binário para entrada padrão (STDIN)"

msgid "failed to set binary mode on STDOUT"
msgstr "não foi possível definir o modo binário para a saída padrão (STDOUT)"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "couldn't attach to %s: %s"
msgstr "não é possível anexar ao %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "não foi possível definir o modo binário para \"%s\""

msgid "read error on %s: %s"
msgstr "erro de leitura em %s: %s"

msgid "couldn't readlink %s: %s"
msgstr "impossível executar readlink %s: %s"

msgid "couldn't follow symlink %s: %s"
msgstr "impossível seguir o símbolico link %s: %s"

msgid "cannot rename %s: %s"
msgstr "não é possível renomear %s: %s"
