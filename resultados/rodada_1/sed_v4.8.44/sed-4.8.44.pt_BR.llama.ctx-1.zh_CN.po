msgstr "Envie os relatórios de anomalias por e-mail para: <%s>."

msgid "This sed program was built with SELinux support."
msgstr "Este programa foi compilado com suporte para SELinux."

msgid "SELinux is enabled on this system."
msgstr "SELinux está ativado neste sistema."

msgid "SELinux is disabled on this system."
msgstr "SELinux está desativado neste sistema."

msgid "This sed program was built without SELinux support."
msgstr "O programa foi compilado sem suporte ao SELinux."

msgid ""
"Usage: %s [OPTION]... {script-only-if-no-other-script} [input-file]...\n"
"\n"
msgstr ""
"Utilização: %s [Opções]... {Script (se não houver outro script)} [Arquivo de"
" entrada]...\n"

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"supomover o modo de impressão automática do espaço dos padrões."

msgid ""
"      --debug\n"
"                 annotate program execution\n"
msgstr ""
"      --debug\n"
"                 anotar a execução do programa"

msgid ""
"  -e script, --expression=script\n"
"                 add the script to the commands to be executed\n"
msgstr ""
"  -e script, --expression=script\n"
"                 adicionar o script à lista de comandos para executar."

msgid ""
"  -f script-file, --file=script-file\n"
"                 add the contents of script-file to the commands to be executed\n"
msgstr ""
"  -f fichier-script, --file=fichier-script\n"
"                 adicionar o conteúdo do arquivo de script ao conjunto de comandos para execução."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 Seguir sinais simbólicos durante o processamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 editar os arquivos em seu lugar (faz uma cópia de segurança se o SUFFIXE for especificado)"

msgid ""
"  -b, --binary\n"
"                 open files in binary mode (CR+LFs are not processed specially)\n"
msgstr ""
"  -b, --binary\n"
"                 abrir os arquivos em modo binário (CR+LF não são processados especialmente)"

msgid ""
"  -l N, --line-length=N\n"
"                 specify the desired line-wrap length for the `l' command\n"
msgstr ""
"  -l N, --line-length=N\n"
"                    especificar a extensão desejada da linha para o comando 'l'"

msgid ""
"  --posix\n"
"                 disable all GNU extensions.\n"
msgstr ""
"--posix\n"
"                 Desabilitar todas as extensões GNU."

msgid ""
"  -E, -r, --regexp-extended\n"
"                 use extended regular expressions in the script\n"
"                 (for portability use POSIX -E).\n"
msgstr ""
"-E, -r --extensao-regexp\n"
"                 Utilize a sintaxe das expressões regulares estendidas no script. (Use E para garantir portabilidade).\n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de um único fluxo contínuo.\n"
"    -s ou --separate\n"

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 Operar no modo sandbox (desabilitar comandos e/r/w).\n"

msgid ""
"  -u, --unbuffered\n"
"                 load minimal amounts of data from the input files and flush\n"
"                 the output buffers more often\n"
msgstr ""
" -u, --unbuffered\n"
"                    ler as quantidades mínimas de dados dos arquivos de entrada e escrever os blocos de saída com mais frequência no disco."

msgid ""
"  -z, --null-data\n"
"                 separate lines by NUL characters\n"
msgstr ""
" -z, --null-data\n"
"                 separar linhas com caractere NUL"

msgid "      --help     display this help and exit\n"
msgstr "Tente `%s --help' para mais informações.\n"

msgid "      --version  output version information and exit\n"
msgstr "      --version   exibir as informações de versão do software e sair\n"

msgid ""
"\n"
"If no -e, --expression, -f, or --file option is given, then the first\n"
"non-option argument is taken as the sed script to interpret.  All\n"
"remaining arguments are names of input files; if no input files are\n"
"specified, then the standard input is read.\n"
"\n"
msgstr ""
"Se nenhuma das opções -e, --expression, -f ou --file fora especificada, o "
"primeiro argumento que não é uma opção será considerado como o script sed a "
"ser interpretado. Todos os outros argumentos restantes são nomes de arquivos"
" de entrada; caso nenhum desses seja indicado, a entrada padrão será lida."

msgid "failed to set binary mode on STDIN"
msgstr "impossível de passar em modo binário sobre entrada padrão (STDIN)"

msgid "failed to set binary mode on STDOUT"
msgstr "não é possível configurar o modo binário para a saída padrão (STDOUT)"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "couldn't attach to %s: %s"
msgstr "não é possível ligar ao %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "não é possível definir o modo binário em “%s”"

msgid "read error on %s: %s"
msgstr "erro de leitura no %s: %s"

msgid "couldn't readlink %s: %s"
msgstr "não foi possível executar readlink %s: %s"

msgid "couldn't follow symlink %s: %s"
msgstr "não foi possível seguir o símbolo de ligação %s: %s"

msgid "cannot rename %s: %s"
msgstr "não foi possível renomear %s: %s"
