msgstr "Envie os relatórios de anomalias por e-mail para: <%s>."

msgid "This sed program was built with SELinux support."
msgstr "Este programa foi compilado para suportar SELinux."

msgid "SELinux is enabled on this system."
msgstr "SELinux está ativado neste sistema."

msgid "SELinux is disabled on this system."
msgstr "SELinux está desativado neste sistema."

msgid "This sed program was built without SELinux support."
msgstr "O programa foi compilado sem suporte de SELinux."

msgid ""
"Usage: %s [OPTION]... {script-only-if-no-other-script} [input-file]...\n"
"\n"
msgstr ""
"Utilização: %s [OPÇÃO]... {script apenas se não houver outro script} "
"[ficheiro de entrada...] ..."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"suprirar a escrita automática do espaço de motivos."

msgid ""
"      --debug\n"
"                 annotate program execution\n"
msgstr ""
"      --debug\n"
"                 anota a execução do programa"

msgid ""
"  -e script, --expression=script\n"
"                 add the script to the commands to be executed\n"
msgstr ""
"  -e script, --expression=script\n"
"                 adicionar o script às comandas para serem executadas."

msgid ""
"  -f script-file, --file=script-file\n"
"                 add the contents of script-file to the commands to be executed\n"
msgstr ""
" -f fichier-script, --file=fichier-script\n"
"                 adicionar o conteúdo do fichier-script às comandas a serem executadas."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguir links simbólicos durante o processamento"

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 editar os arquivos no local (faz backup se o SUFFIXE fornecido) \n"

msgid ""
"  -b, --binary\n"
"                 open files in binary mode (CR+LFs are not processed specially)\n"
msgstr ""
"  -b, --binary\n"
"                 abrir os arquivos no modo binário (CR+LF não são processados especialmente)\n"

msgid ""
"  -l N, --line-length=N\n"
"                 specify the desired line-wrap length for the `l' command\n"
msgstr ""
"  -l N, --line-length=N\n"
"                especificar a extensão da quebra de linha desejada para o comando 'l'\n"

msgid ""
"  --posix\n"
"                 disable all GNU extensions.\n"
msgstr "desabilitar todas as extensões posix do GNU."

msgid ""
"  -E, -r, --regexp-extended\n"
"                 use extended regular expressions in the script\n"
"                 (for portability use POSIX -E).\n"
msgstr ""
" -E, -r, --regexp-extended\n"
"utilize a sintaxe das expressões regulares estendidas no script.\n"
"(use -E para portabilidade).\n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 opera em modo sandbox (desabilita as comandas e/r/w).\n"

msgid ""
"  -u, --unbuffered\n"
"                 load minimal amounts of data from the input files and flush\n"
"                 the output buffers more often\n"
msgstr ""
" -u, --unbuffered\n"
"                 carregar quantidades mínimas de dados dos arquivos de entrada e esvaziar os buffers de saída mais frequentemente no disco."

msgid ""
"  -z, --null-data\n"
"                 separate lines by NUL characters\n"
msgstr ""
"--null-data\n"
"                 separar linhas com caractere NUL"

msgid "      --help     display this help and exit\n"
msgstr "      --help     exibir esta ajuda e sair\n"

msgid "      --version  output version information and exit\n"
msgstr "      --version  exibir as informações de versão do software e sair\n"

msgid ""
"\n"
"If no -e, --expression, -f, or --file option is given, then the first\n"
"non-option argument is taken as the sed script to interpret.  All\n"
"remaining arguments are names of input files; if no input files are\n"
"specified, then the standard input is read.\n"
"\n"
msgstr ""
"Se nenhuma das opções -e, --expression, -f ou --file forneceram argumentos, "
"o primeiro que não é uma opção será considerado como sendo um script sed "
"para interpretar. Todos os argumentos restantes são nomes de arquivos de "
"entrada; se nenhum deles foi especificado explicitamente, a entrada padrão "
"será lida."

msgid "failed to set binary mode on STDIN"
msgstr "impossível passar em modo binário sobre entrada padrão (STDIN)"

msgid "failed to set binary mode on STDOUT"
msgstr "impossível passar em modo binário sobre STDOUT"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "couldn't attach to %s: %s"
msgstr "impossível de anexar ao %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "impossível de passar em modo binário sobre \"%s\""

msgid "read error on %s: %s"
msgstr "erro de leitura no arquivo %s: %s"

msgid "couldn't readlink %s: %s"
msgstr "impossível executar readlink %s : %s"

msgid "couldn't follow symlink %s: %s"
msgstr "impossível de seguir o link simbólico %s: %s"

msgid "cannot rename %s: %s"
msgstr "impossível de renomear %s: %s"
