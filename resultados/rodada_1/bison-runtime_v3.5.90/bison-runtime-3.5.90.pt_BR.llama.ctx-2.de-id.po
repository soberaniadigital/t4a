msgid "syntax error: cannot back up"
msgstr "Erro de sintaxe: não é possível salvar a estação de proteção"

msgid "syntax is ambiguous"
msgstr ""
"a sintaxe não é clara o suficiente para determinar se há ambiguidade ou erro"
" de identificação."

msgid "syntax error"
msgstr "erro de sintaxe lỗi cú pháp"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s inválidos"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s incomum, esperava %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "lỗi cú pháp, gặp %s bất thường, cần %s hoặc %s."

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr "erro de sintaxe, %s incomum, esperava %s ou %s ou %s ou %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de sintaxe, %s inválido(a) ou inesperado(a), esperava-se que fosse um "
"ID (%d) ou uma opção (opção) ou outra coisa como resultado"

msgid "memory exhausted"
msgstr "memória esgotada"
