msgid "syntax error: cannot back up"
msgstr "Erro de sintaxe: não é possível armazenar a estação de segurança"

msgid "syntax is ambiguous"
msgstr "a sintaxe não é clara"

msgid "syntax error"
msgstr "erro de sintaxe"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s anônima"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s extraordinário, necessita %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "erro de sintaxe, %s anônimo ou inválido, necessita de %s ou %s."

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr "erro de sintaxe, %s anônimo ou inválido, necessário %s ou %s ou %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de sintaxe, %s anônimo ou inválido, necessita de %s para corrigir o "
"erro (ou) %s para exibir mais informações."

msgid "memory exhausted"
msgstr "memória esgotada"
