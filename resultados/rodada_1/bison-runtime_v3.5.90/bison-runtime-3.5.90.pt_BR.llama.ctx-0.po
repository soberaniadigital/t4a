msgid "syntax error: cannot back up"
msgstr ""
"erro de codificação penal: não é possível armazenar a delegacia fiscalmente"

msgid "syntax is ambiguous"
msgstr ""
"sem indicação clara do código de conduta legalmente aceito para a situação "
"em questão."

msgid "syntax error"
msgstr "erro de código legal"

msgid "syntax error, unexpected %s"
msgstr "erro de código, encontrou %s excepcional"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de codificação, encontrei %s incomum, preciso %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr ""
"erro de código, encontramos %s exceção padrão, precisamos executar %s ou %s "
"para solucioná-lo."

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr ""
"erro de codificação, encontramos %s exceção padrão, precisa executar %s ou "
"%s para corrigir o problema, caso contrário %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de código, encontramos %s excepcional, precisamos %s ou %s ou %s ou %s?"

msgid "memory exhausted"
msgstr "o cache está cheio"
