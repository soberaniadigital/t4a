msgid "syntax error: cannot back up"
msgstr "erro de cúpacão : não é possível armazenar a estação em segurança"

msgid "syntax is ambiguous"
msgstr "a sintaxe não está clara"

msgid "syntax error"
msgstr "erro de sintaxe"

msgid "syntax error, unexpected %s"
msgstr "erro de cú páp, %s não previsto"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de cú páp, %s anômalo, espera %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "erro de cú páp, %s não previsto, espera por %s ou %s."

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr "erro de cú páp, %s sintático inesperado, espera por %s ou %s ou %s."

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de cú páp, %s anômia sintática, espera-se que ocorra um erro ou falha "
"em execução ou uma exceção ao invés do normal."

msgid "memory exhausted"
msgstr "memória esgotada"
