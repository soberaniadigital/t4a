msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr ""
"Aceitação do comando 'iconv': '-c' para continuar após erros, '-s' para "
"ignorar falhas e opções de conversão entre codificações. Opcionalmente "
"especifique a codificação de entrada (-f) e saída (-t). Exemplo: iconv -f "
"AUSGANGS-KODIERUNG -t ZIEL-KODIERUNG [DATEI …]"

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente ‘%s --help’ para obter mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr "Aufruf: %s [OPTION...] [-f ENCODING] [-t ENCODING] [EINBABEDATEI …]\n"

msgid "or:    %s -l\n"
msgstr "ou:   %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converta o texto de uma codificação para outra."

msgid "Options controlling the input and output format:\n"
msgstr "Opções para formatos de entrada e saída: 'DE'"

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                               a codificação da entrada"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                               a codificação de saída"

msgid "Options controlling conversion problems:\n"
msgstr "控制字符转换的选项:\n"

msgid "  -c                          discard unconvertible characters\n"
msgstr ""
" -c                           Ignorar caracteres que não podem ser "
"convertidos \n"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"DE --unicode-subst=FORMATSTRING Substitui caracteres Unicode que não podem "
"ser convertidos."

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=FORMATSTRING    Substituição para bytes que não podem ser "
"convertidos"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=FORMATSTRING\n"
"                              Substitui caracteres de largura mínima que não podem ser convertidos."

msgid "Options controlling error output:\n"
msgstr ""
"Opções para a saída de erros do controle: \n"
" \"%s\": %d, \"verbose\" : false, \"log_file\" : \"/var/log/%c.log\", \"max_retries\" : <PRIuMAX>}"

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
"  -s, --silent                Não são exibidas mensagens relacionadas a "
"erros de conversão\n"

msgid "Informative output:\n"
msgstr "Informativa de saída:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr ""
"  -l, --list                   lista das codificações suportadas mostrar\n"

msgid "  --help                      display this help and exit\n"
msgstr "Tente `%s --help' para mais informações.\n"

msgid "  --version                   output version information and exit\n"
msgstr "--versão                    Mostrar informações da versão e sair\n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+, que é a GNU GPL abaixo da versão 3 <%s> \n"
"Este programa é software livre: você pode modificá-lo e distribuí-lo. Nenhuma garantia legal existe além do permitido pela lei."

msgid "Written by %s.\n"
msgstr "Geschrieben von %s."

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr ""
"%s Argumento: Uma instrução de formatagem com largura variável não é "
"permitida aqui."

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr ""
"%s Argumento: Uma instrução de formatagem com precisão variável não é "
"permitida aqui."

msgid "%s argument: A format directive with a size is not allowed here."
msgstr ""
"%s Argumento: Uma instrução de formatagem com especificação de tamanho não é"
" permitida aqui."

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s argumento: a cadeia de caracteres termina no meio da instrução."

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr "%s argumento: as letras '\\%c' não representam uma conversão válida."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"%s Argumento: Os caracteres no final da instrução de formatagem não "
"representam uma conversão válida."

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não é possível converter o byte desejado para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"Não foi possível converter os caracteres Unicode para a codificação alvo: %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr ""
"não foi possível converter os bytes para uma cadeia ancha de caracteres: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"não é possível converter o caractere de largura expandida para a codificação"
" alvo: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr "não foi possível converter os bytes para a codificação alvo: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%d:%d: Converter não é possível."

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: sequência de caracteres inválida ou incompleta\n"

msgid "%s:%u:%u"
msgstr "%s:%d:%d"

msgid "%s: I/O error"
msgstr "%s: Erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "a conversão a partir de %s não é suportada."

msgid "conversion to %s unsupported"
msgstr "a conversão para %s não é suportada."

msgid "conversion from %s to %s unsupported"
msgstr "A conversão de %s para %s não é suportada."

msgid "try '%s -l' to get the list of supported encodings"
msgstr ""
"Tente usar '\\%s -l' para obter uma lista de todas as codificações "
"suportadas."

msgid "(stdin)"
msgstr "(Entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "Erro de entrada/saída"
