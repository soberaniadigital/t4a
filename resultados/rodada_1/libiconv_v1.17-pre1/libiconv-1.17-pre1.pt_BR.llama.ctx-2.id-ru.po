msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr ""
"Utilização do iconv: -c, --convert all characters; -s, --skip errors; -f "
"вх_кодировка, --from input code; -t вых_кодировка, --to output code [arquivo"
" ...]"

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente ‘%s --help’ para obter mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr ""
"Utilização: %s [OPÇÕES...] [-f ENCODA] [-t ENCODE] "
"[ARQUIVOS_DE_ENTRADA...]\n"

msgid "or:    %s -l\n"
msgstr "ou:    %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converte o texto de uma codificação para outra."

msgid "Options controlling the input and output format:\n"
msgstr "Opções de controle para formatos de entrada e saída: \n"

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                               Entrada em codificação"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              codificação de saída"

msgid "Options controlling conversion problems:\n"
msgstr ""
"Opções de controle para a conversão do caractere: \n"
"\t'RU': Opção RU, que gerencia problemas relacionados à transformação dos caracteres. Para obter mais informações sobre essa opção e como utilizá-la corretamente em um ambiente Linux com CLI, consulte o manual de utilitários do sistema (man) ou a documentação específica para esse software."

msgid "  -c                          discard unconvertible characters\n"
msgstr ""
" -c                          ignorar caracteres que não podem ser "
"convertidos"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"--unicode-subst=FORMATSTRING\n"
"                              Substituição para caracteres Unicode que não podem ser convertidos."

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=FORMATSTRING   substitui bytes não convertíveis para uma string"
" formatada"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=FORMATSTRING\n"
"                              Substituição para caracteres de largura não alterável."

msgid "Options controlling error output:\n"
msgstr ""
"Opções de controle para erros do sistema: \n"
"\t'--control_error': Imprime mensagens relacionadas a falhas no sistema. Usado quando um evento indesejável ocorre, como uma exceção ou violação de restrição.\n"
"\t'--debug-errors': Mostra detalhes dos erros para fins de depuração e solução do problema."

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
" -s, --silent                 não exibir mensagens relacionadas a erros de "
"conversão"

msgid "Informative output:\n"
msgstr "Informações de saída:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   lista de codificações suportadas"

msgid "  --help                      display this help and exit\n"
msgstr "--help                       Mostrar este comando e sair\n"

msgid "  --version                   output version information and exit\n"
msgstr "--versao                    Mostrar informações sobre a versão e sair\n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior <%s> Este software é de código"
" aberto: você pode modificá-lo e distribuí-lo. Nenhum acordo legal será "
"feito além do que a lei permite atualmente."

msgid "Written by %s.\n"
msgstr "Autores: %s. Ditulis oleh %s."

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr ""
"%s argumento: Diretrizes de uso não permitem a utilização de formatos "
"variáveis em largura."

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr ""
"%s argumento: Diretrizes não permitem a utilização de um formato com "
"variáveis que podem ter precisão variável."

msgid "%s argument: A format directive with a size is not allowed here."
msgstr "%s argumento: Não é permitido o uso de diretivas com tamanho."

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s argumento: String termina no meio da diretiva."

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr "%s argumento: Caracter '%c' não é um especificador de escape válido."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"%s argumento: Caracter que termina a diretiva de formatação, não é um "
"caractere válido especificador de conversão."

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não é possível converter os bytes para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"não é possível converter a substituição Unicode para codificação alvo: %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr "não é possível converter os bytes para uma string aninhada: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"não é possível converter substituições de caracteres amplos para a "
"codificação alvo: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr ""
"não é possível converter os bytes substituídos para a codificação alvo: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%d:%d: não é possível converter"

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: sequência de caracteres ou substituição incompleta"

msgid "%s:%u:%u"
msgstr "%s:%u:%u"

msgid "%s: I/O error"
msgstr "%s: erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "conversão de %s não é suportada"

msgid "conversion to %s unsupported"
msgstr "a conversão para %s não é suportada"

msgid "conversion from %s to %s unsupported"
msgstr "conversão de %s para %s não é suportada"

msgid "try '%s -l' to get the list of supported encodings"
msgstr "Tente usar ‘%s -l’ para obter a lista de codificações suportadas."

msgid "(stdin)"
msgstr "(entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "erro de entrada/saída"
