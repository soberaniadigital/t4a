msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr ""
"Usagem: iconv [-c] [-s] [-f codificação_entrada] [-t codificação_saída] "
"[arquivo ...]"

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente '%s --help' para mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr ""
"Usagem: %s [OPÇÃO...] [-f ENCODING] [-t ENCODING] [ARQUIVO_DESTINADO...]"

msgid "or:    %s -l\n"
msgstr "ou:    %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converter o texto de um código para outro código."

msgid "Options controlling the input and output format:\n"
msgstr "Opções de controle do formato de entrada e saída:"

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                               codificação de entrada"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to_code=ENCODING\n"
"                              codificação de saída"

msgid "Options controlling conversion problems:\n"
msgstr "Opções de conversão de caracteres: ZH_CN, FR"

msgid "  -c                          discard unconvertible characters\n"
msgstr " -c                           ignorar caracteres não convertíveis"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"--unicode-subst=FORMATSTRING\n"
"                              Substitua caracteres Unicode não convertíveis"

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=FORMATSTRING    Substituir bytes não convertíveis em uma string"
" formatada"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=FORMATSTRING\n"
"                              Substitui caracteres largos não convertíveis."

msgid "Options controlling error output:\n"
msgstr "Opções para exibição de erros do sistema operacional:"

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
" -s, --silent                 não exibir mensagens relacionadas aos erros de"
" conversão"

msgid "Informative output:\n"
msgstr "Informações de saída:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   lista de codificações suportadas"

msgid "  --help                      display this help and exit\n"
msgstr " --help                       Mostra este ajuda e sai\n"

msgid "  --version                   output version information and exit\n"
msgstr ""
"--versao                    Mostra informações de versão e sai do programa\n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior <%s> \n"
"Este software é livre: você pode modificá-lo e redistribuí-lo. \n"
"Não há garantias, dentro dos limites legais permitidos."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr ""
"%s Parâmetro: Não é permitido o uso de formatos com largura variável neste "
"local."

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr ""
"%s parâmetro: Neste local, não é permitido o uso de um formato com precisão "
"variável."

msgid "%s argument: A format directive with a size is not allowed here."
msgstr ""
"%s Parâmetro: Não é permitido o uso de um comando diretivo que inclua "
"tamanho aqui."

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s parâmetro: a string termina no meio de uma instrução."

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr ""
"%s  parâmetro: o caractere '\\x%c' não é um especificador de escape válido."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"%s Parâmetro: Caracter que termina o formato não é um especificador de "
"conversão válido."

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não foi possível converter os bytes para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"Não foi possível converter os caracteres Unicode para o código de "
"codificação alvo: %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr ""
"não foi possível converter os bytes de substituição em uma string ancha: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"Não foi possível converter os caracteres anchos para o código de codificação"
" alvo: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr ""
"não foi possível converter os bytes para o código de saída desejado: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%d:%d: não é possível converter"

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: sequência de caracteres inválida ou incompleta"

msgid "%s:%u:%u"
msgstr "%s:%u:%u"

msgid "%s: I/O error"
msgstr "%s: erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "não é suportado a conversão de %s"

msgid "conversion to %s unsupported"
msgstr "não é suportado o processamento para %s"

msgid "conversion from %s to %s unsupported"
msgstr "não é suportada a conversão de %s para %s"

msgid "try '%s -l' to get the list of supported encodings"
msgstr "Tente usar ‘%s -l’ para obter a lista de codificações suportadas."

msgid "(stdin)"
msgstr "(entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "Erro de entrada/saída"
