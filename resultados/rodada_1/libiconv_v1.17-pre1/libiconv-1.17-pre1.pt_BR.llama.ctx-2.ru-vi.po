msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr ""
"Utilização: iconv [-c] [-s] [-f in_encoding] [-t out_encoding] [arquivo ...]"

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente ‘%s --help’ para obter mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr "Utilização: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"

msgid "or:    %s -l\n"
msgstr "ou:    %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converte o texto de uma codificação para outra."

msgid "Options controlling the input and output format:\n"
msgstr ""
"Opções de controle para formatos de entrada e saída: \n"
" \"%s\": %d, \n"
" \"VI\": [\"%<PRIuMAX> - Opção do formato Vídeo (vídeo) que define o tamanho máximo da janela. Por padrão é 1920x1080 pixels.\",\n"
" \"RU\": [\"%s: %d\", \n"
" \"Opções de controle para formatos Raster UV, incluindo resolução e profundidade do canal (chanel). O valor por definição padrão é 32x16. Por exemplo, se você deseja usar uma resolução maior que o tamanho máximo permitido para a janela de vídeo, pode especificar isso como \"%s: %d\".\" ]"

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                               Entrada em codificação"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              кодировка вихідних даних\n"

msgid "Options controlling conversion problems:\n"
msgstr ""
"Opções de controle para problemas de conversão de caracteres: \n"
"\t'RU': Opção que permite ajustar o comportamento do sistema ao lidar com erros durante a conversão. Por exemplo, pode ser usada para definir um limiar acima do qual os erros são considerados significativos e devem desencadear uma mensagem de aviso ou bloquear determinadas operações.\n"
"\t'VI': Opção que permite ao utilizador visualizar as configurações atuais relacionadas à conversão, incluindo o limiar para a detecção de erros. Esta opção é útil para fins de depuração e auditoria do sistema."

msgid "  -c                          discard unconvertible characters\n"
msgstr " -c                           ignorar caracteres não convertíveis"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"--unicode-subst=STRING_FORMAT\n"
"                              Substituição para caracteres Unicode não convertíveis."

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=STRING_FORMAT\n"
"                          substituição para bytes que não podem ser convertidos."

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=STRING_FORMAT\n"
"                              substituição para caracteres não convertíveis em largura de palavra."

msgid "Options controlling error output:\n"
msgstr ""
"Opções de controle para a saída dos erros: \n"
"\t'--show_errors': Mostrar todos os erros detectados. \n"
"\t'--log_to_file': Registrar mensagens de erro em um arquivo específico (nome do arquivo como variável)."

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
"  -s, --silent                não exibir mensagens relacionadas a erros de "
"conversão\n"

msgid "Informative output:\n"
msgstr "Informações de saída:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   lista de codificações suportadas"

msgid "  --help                      display this help and exit\n"
msgstr "--help                       Mostrar esta ajuda e sair\n"

msgid "  --version                   output version information and exit\n"
msgstr "--versao                   Mostrar informações sobre a versão e sair\n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior <%s> \n"
"Este software é livre. Você pode modificá-lo e reimprimi-lo.\n"
"Nenhum acordo de confidencialidade fora do que a lei permite atualmente."

msgid "Written by %s.\n"
msgstr "Autorado por %s. \n"

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr "%s 参数: 在此处不允许使用可变长度的命令格式。"

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr "%s 参数: 在此处不允许使用可变精度的命令格式。"

msgid "%s argument: A format directive with a size is not allowed here."
msgstr "%s 参数: 在此处不允许使用大小命令格式。"

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s 参数: 字符串在命令中部终止。"

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr "%s argument: caractere ‘%c’ não é um especificador de escape válido."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr "%s 参数: 用于终止命令格式的字符不是有效的转义符。"

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não é possível converter os bytes para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"não é possível converter a substituição Unicode para o código de caracteres "
"alvo: %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr "não foi possível converter os bytes para uma string aninhada: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"não é possível converter a substituição de caracteres ampla para o código "
"alvo: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr "não foi possível converter os bytes para a codificação alvo: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%d:%d: não é possível converter"

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: não completo de caracteres ou sequência com deslocamento"

msgid "%s:%u:%u"
msgstr "%s:%u:%u"

msgid "%s: I/O error"
msgstr "%s: erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "não é suportado realizar conversão a partir de %s"

msgid "conversion to %s unsupported"
msgstr "não é suportado o processamento para %s"

msgid "conversion from %s to %s unsupported"
msgstr "não é suportado converter do %s para o %s"

msgid "try '%s -l' to get the list of supported encodings"
msgstr "Tente usar ‘%s -l’ para obter a lista de codificações suportadas."

msgid "(stdin)"
msgstr "(entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "Erro de entrada/saída"
