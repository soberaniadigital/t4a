msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr "Penggunaan: iconv [-c] [-s] [-f fromcode] [-t tocode] [berkas ...]"

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"    iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente '%s --help' para mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr ""
"Penggunaan: %s [OPSI...] [-f PENGKODEAN] [-e PENGKODEAN] [BERKAS MASUKAN...]"

msgid "or:    %s -l\n"
msgstr "ou também: %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converta o texto de uma codificação para outra."

msgid "Options controlling the input and output format:\n"
msgstr "Opciones para controlar o formato de entrada e saída: 'DE'"

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              Entrada em codificação"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              Saída em codificação"

msgid "Options controlling conversion problems:\n"
msgstr "Opcões de controle para a transformação dos caracteres: 'ID', 'DE'"

msgid "  -c                          discard unconvertible characters\n"
msgstr ""
" -c                           ignorar caracteres que não podem ser "
"convertidos"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"--unicode-subst=FORMATSTRING\n"
"                              Substituição para caracteres Unicode que não podem ser convertidos."

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=FORMATSTRING   substitui bytes que não podem ser convertidos "
"para string\n"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"substituição de caracteres em largura --widechar-subst=FORMATSTRING\n"
"                              para caractere que não pode ser convertido."

msgid "Options controlling error output:\n"
msgstr "Opciones para controlar la salida de errores: 'ID', 'DE'."

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
"  -s, --silent                Não exibir mensagens relacionadas a problemas "
"de conversão\n"

msgid "Informative output:\n"
msgstr "Keluaran informasi:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   listagem de códigos suportados"

msgid "  --help                      display this help and exit\n"
msgstr " --help                       Mostrar este comando de ajuda e sair\n"

msgid "  --version                   output version information and exit\n"
msgstr "--versao                    Exibir versão e sair\n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Lisensi GPLv3+: GNU GPL versão 3 ou posterior <%s> \n"
"Este software é livre para que você o possa modificar e redistribuir. Sem garantias, exceto aquelas permitidas pela lei.\n"

msgid "Written by %s.\n"
msgstr "Ditulis oleh %s."

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr ""
"%s argumento: Um formatador direto com uma variável de comprimento variável "
"não é permitido aqui."

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr ""
"%s argumento: Um formatador diretivo com uma variável de precisão não é "
"permitido aqui."

msgid "%s argument: A format directive with a size is not allowed here."
msgstr "%s argumento: Um formatador com tamanho não é permitido aqui."

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s argumento: String termina no meio de uma instrução."

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr "%s argumento: Caracter '%c' não é um escape válido."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"%s argumento: Caracter que é processado com o sinal de percentagem não "
"representa uma conversão válida."

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não é possível converter os bytes para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"não é possível converter os caracteres unicode para a codificação alvo: %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr "não é possível converter os bytes para uma string ancha: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"não é possível converter o caractere de ampla largura para a codificação "
"alvo: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr "não é possível converter os bytes para a codificação alvo: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%d:%d: não é possível converter."

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: karacter atau urutan shift tidak lengkap"

msgid "%s:%u:%u"
msgstr "%s:%d:%d"

msgid "%s: I/O error"
msgstr "%s: Erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "a conversão do %s não é suportada."

msgid "conversion to %s unsupported"
msgstr "a conversão para %s não é suportada."

msgid "conversion from %s to %s unsupported"
msgstr "a conversão de %s para %s não é suportada."

msgid "try '%s -l' to get the list of supported encodings"
msgstr "Tente usar '%s -l' para obter a lista de codificações suportadas."

msgid "(stdin)"
msgstr "(entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "Erro de entrada/saída"
