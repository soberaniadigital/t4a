msgid "-b, --print-bytes          print differing bytes"
msgstr "-b, --print-bytes      Mostrar bytes diferentes."

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=SKIP\n"
"         Ignora as primeiras SKIP bytes da entrada."

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:%d SKIP2:%<PRIuMAX> \n"
"          Anticipe o primeiro %d byte de FILE1 e os primeiros %<PRIuMAX> bytes do FILE2."

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose          Imprime bytes e valores de todos os bytes diferentes."

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr "-n, --bytes=LIMIT      Comparar o máximo LIMIT bytes."

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s --quiet, -silente      cegar todas as saídas normais."

msgid "    --help                 display this help and exit"
msgstr "    --help             Mostrar ajuda e sair."

msgid "-v, --version              output version information and exit"
msgstr "-v --versão             Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "Uso: %s [PILIHAN]... BERKAS1 [BERKAS2 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandar duas pastas byte por byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 e SKIP2 são o número de bytes que devem ser pulados no início de cada "
"arquivo (valor padrão é zero)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos obrigatórios para opções de comprimento também são necessários"
" para as opções curtas."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Valores SKIP podem ser acompanhados pelos seguintes sufixos multiplicativos a seguir:\n"
"KB 1000, KB 1024, MB 1.000.000, MB 1.048.576,\n"
"GB 1.000.000.000, GB 1.073.741.824 e assim por diante para TB, PB, EB, ZB, YB."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se a FILE for '-' ou não existir, lê da entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"O status de saída do programa é 0 se as entradas forem idênticas, 1 caso "
"contrário e 2 em caso de falha."

msgid "invalid --bytes value %s"
msgstr "valor de %s --bytes inválido"

msgid "missing operand after %s"
msgstr "não há operando após %s"

msgid "extra operand %s"
msgstr "operando extra %s"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s são diferentes: byte %<PRIdMAX>, linha %<PRIdMAX>"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX> is %3o %s %3o %s\n"
msgstr ""
"%s %s diferem em byte e linha, que são respectivamente o valor da variável "
"do sistema '%d' bytes e a quantidade de caracteres naquela mesma linha igual"
" ao número da variável 'linhas_atual', ou seja, por exemplo, um arquivo com "
"1024 bytes ocupa uma única linha."

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF pada %s que está vazia."

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF após byte %<PRIdMAX> em '%s'."

msgid "cmp: EOF on %s after byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "cmp: EOF pada %s após byte %<PRIdMAX>, linha %<PRIdMAX>"

