msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file ambos são especificados."

msgid "    --normal                  output a normal diff (the default)"
msgstr ""
"    --normal                      Exibir diferença normal (básica) (Padrão)."

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                     Nur auszugeben, ob die Dateien verschieden "
"sind."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical_files    Comparar e relatar quando duas pastas são "
"idênticas."

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C NUMBER, --context[=NUMBER]   ZAMAN do NUMERO de linhas do contexto "
"copiado"

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   ZAHL linhas do contexto unificado\n"
"                    exibir (valor padrão: %<PRIuMAX>)\n"

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      Exibe um script ed."

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     keluaran dalam format RCS diff\n"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side              Em duas colunas."

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W,--width=NUM             saída do máximo NUM (valor padrão 130) colunas de"
" impressão por linha"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             nur linke Spalte der gemeinsamen Zeilen "
"ausgegeben."

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines     Não exiba linhas comuns."

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function           Para cada alteração mostrar em qual função C"
" ela está."

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE     Mostrar a linha de código que corresponde ao"
" padrão RE."

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pacote com o nome do label e o timestamp\n"
"                                (pode ser repetido)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Ekspansi tab para espaços na saída do "
"sorteio\n"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab             cria uma tabulação reta com indentações à "
"esquerda no início das linhas de texto."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty      Cegue os espaços em branco ou tabulação "
"antes de linhas vazias na saída."

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                   Envia resultados para o terminal 'pr' para "
"paginação."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 Reconhecendo e comparando recursivamente "
"todos os subdiretórios."

msgid "    --no-dereference            don't follow symbolic links"
msgstr ""
"    --no-dereference            Não siga simbolicamente as referências."

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                   Não considerar arquivos ausentes como "
"vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   primeira criação de arquivo sem conteúdo"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     Ignorar diferenças entre maiúsculas e "
"minúsculas nos nomes dos arquivos."

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
" --no-ignore-file-name-case Considere diferenças de maiúsculas e minúsculas "
"nos nomes dos arquivos."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr "-x, --exclude=PAT               files that do not match PAT\n"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         excluir arquivos que correspondam aos "
"padrões no FILE\n"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        começa com FILE ao comparar diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"--from-file=FILE1         FILE1 com todos os operandos comparados. \n"
"                                FILE1 pode ser um diretório."

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"--to-file=FILE2             comparar todos os operandos com FILE2; \n"
"                                   FILE2 pode ser um diretório."

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               Ignorar diferenças entre letras maiúsculas e"
" minúsculas no conteúdo do arquivo."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      Ignorar as alterações decorrentes da "
"expansão de tabulação."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space     Ignorar espaços em branco no final da linha."

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       Ignore changes in the amount of white space."

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space          Ignorar espaços em branco."

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines        Ignorar alterações em que todas as linhas "
"são vazias."

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore changes in lines that match the "
"pattern RE."

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      Perlacar todas as pastas como texto."

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar retorno de linha final ao final da "
"entrada\n"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                    baca dan tulis data dalam mode biner."

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr "-D, --ifdef=NAME                Datei combinada com '#ifdef NAME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatar GTYPE em grupo com o formato GFMT."

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          Formate todas linhas de entrada com o "
"formato LFMT."

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr "--LTYPE-line-format=LFMT formatar linha LTYPE com LFMT"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"As opções de formato disponibilizam controle fino sobre a entrada "
"diferencial, em geral -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'antigo', 'novo' ou 'sem alterações'. GTYPE é LTYPE ou "
"'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"O GFMT pode conter as seguints informações:\n"
"    %<  linhas da FILE1.\n"
"    %>  linhas da FILE2.\n"
"    %=  linhas que pertencem tanto à FILE1 quanto ao FILE2.\n"
"\n"
"Para os BUCHST, a letra inicial depende do grupo. Para novos grupos: F (primeira), L (última) e N (quantidade total = última - primeira + 1). Para antigos grupos: E (antecessor da última). As letras são as seguintes:\n"
"    %[-][BREITE][.[PRÄZ]]{doxX}BUCHST\n"
"        F  Primeira linha.\n"
"        L  Última linha.\n"
"        N  Quantidade total de linhas = Última - Primeira + 1.\n"
"        E  Antecessora da última linha.\n"
"    %(A=B?T:E)  Se A for igual a B, então T; caso contrário, E."

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"{'LFMT pode conter:\\n\\t%L é a linha.\\n\\t%l é a linha sem "
"nova.\\n\\t%[-][BREITE][.[PRÄZ]]{doxX}n é uma numeração de linha printf-"
"style.': {'context': [{'lang': 'en', 'translation': 'DE'}, {'lang': 'pt-BR',"
" 'translation': '  LFMT pode conter:\\n\\t%L é a linha.\\n\\t%l é a linha "
"sem nova.\\n\\t%[-][BREITE][.[PRÄZ]]{doxX}n é uma numeração de linha printf-"
"style.'}]}}"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"GFMT ou LFMT podem conter:\n"
"%%\n"
"%c'C'\n"
"de caracter único C\n"
"%c'Stant (satu simbolo OOO em código octal)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal             Intensiv após uma pequena quantidade de alterações"
" para encontrar as mudanças menores possíveis."

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM  NUM Linhas com prefíxo e sufixo comuns\n"
"            manter."

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files   É assumido que grandes arquivos com poucas "
"alterações dispersas são processados."

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"{'original_text': \"\\n--color[=WHEN]       warnai keluaran; WHEN adalah "
"'never', 'always', atau 'auto';\\n                           --color polos "
"berarti --color='auto'\", 'translation_pt-BR': {'original_text': \"\\n--"
"color[=WANN]       warna keluaran; WANN muda para 'sempre', 'jamais' ou "
"'automático';\\n                           --color polos berartinha em "
"'automático'\"}}"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    paleta de cores utilizada quando o --color está "
"ativo; PALETTE é uma lista separada por dois pontos que contém as "
"capacidades terminfo."

msgid "    --help               display this help and exit"
msgstr "    --help                Mostrar ajuda e sair."

msgid "-v, --version            output version information and exit"
msgstr "-v --versão               Mostrar informações de versão e sair."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES podem ser 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Se --from-file ou --to-file fornecido, não há limitações para arquivos(s)."

msgid "If a FILE is '-', read standard input."
msgstr "Se a FILE for '-', ler de entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Aufruf: %s [OPTION]... BERKAS"

msgid "Compare FILES line by line."
msgstr "Bandar FILE barras por barra."

msgid "conflicting %s option value %s"
msgstr "Valor ocioso da opção %s é inconsistente com a opção %s"

msgid "conflicting output style options"
msgstr "Opcions conflitantes para o estilo de saída."

msgid "invalid color %s"
msgstr "FARBA INVALIDA %s"

msgid "-D option not supported with directories"
msgstr "A opção '-D' não é suportada em diretórios."

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios sama: %s e %s. \n"

msgid "Only in %s: %s\n"
msgstr "Nur em %s: %s."

msgid "File %s is a %s while file %s is a %s\n"
msgstr "Berkas %{s} adalah %{d}, sementara berkas %{s} adalah %{d}.\n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o caractere '-' com diretório."

msgid "Files %s and %s are identical\n"
msgstr "Berkas %s dan %s identik."

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "Opção não compatível."

msgid "'-' specified for more than one input file"
msgstr "'-' descreve mais de uma pasta de entrada especificada."

msgid "read failed"
msgstr "erro de leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all               Exibe todas as alterações e conflitos em "
"parênteses.\n"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    exibe o script ed que contém alterações de "
"OLDFILE para YOURFILE e insere em MYFILE\n"

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E --mostrar-sobreposicao           Semelhante a -e, mas conflitos em "
"parênteses."

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only              Como -e, mas apenas não sobreposíveis "
"alterações integrar."

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only           Como -e, mas apenas sobreposições de alterações"
" que se conectam\n"

msgid "-X                          like -x, but bracket conflicts"
msgstr "-X                          como -x, mas com conflitos em colchetes."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          imbuhkan perintah 'w' dan 'q' ke skrip ed\n"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                 Conjunto de arquivos concatenados emitido "
"conforme -A, sem opções alternativas\n"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                   Aplicação de todos os arquivos como texto."

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      Remover retorno de linha (CR) no final da "
"entrada\n"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab           cria uma tabulação reta com um espaço a mais "
"antes da primeira tabulação."

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM  PROGRAM para comparar arquivos utilizar."

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL            LABEL em vez do nome de arquivo utilizar (pode "
"ser repetido até três vezes)"

msgid "    --help                  display this help and exit"
msgstr "    --help                   Mostrar esta ajuda e sair."

msgid "-v, --version               output version information and exit"
msgstr "-v --versão                 Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Pemakaian: %s [OPTION]... MEUARQUIVO ANTIGOYOURFILE"

msgid "Compare three files line by line."
msgstr "Bandingkan três blocos de linhas por linha."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída keluaran baku é uma representação que pode ser lida por "
"humanos. As opções -e, -E, -x e -X (juntamente com suas versões longas "
"relacionadas) fazem com que ed produza um script em vez do formato padrão. "
"No final, a opção --merge leva diff3 a juntar as alterações internamente e a"
" exportar uma cópia real da alteração combinada. Para entradas incomuns, "
"isso é mais robusto que o uso de ed."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do resultado é 0 se tudo correu, 1 em caso de conflito e 2 quando "
"ocorreu um erro."

msgid "internal error: screwup in format of diff blocks"
msgstr "Erro interno de lógica: format para bloco diff está desordenado."

msgid "%s: diff failed: "
msgstr "%s: diferença de arquivos falhou: "

msgid "internal error: invalid diff type in process_diff"
msgstr "Erro interno: tipo de diferença não é válido no processamento_diff."

msgid "invalid diff format; invalid change separator"
msgstr "formato de diferença inválido; separador de alterações inválido."

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença inválido; linha final incompleta."

msgid "subsidiary program %s could not be invoked"
msgstr "programa subordinado %s não pode ser chamado."

msgid "invalid diff format; incorrect leading line chars"
msgstr "formato de diferença inválido; caractere líder na linha não correto."

msgid "internal error: invalid diff type passed to output"
msgstr ""
"Erro interno do sistema: tipo de diferença difere e não é válido para saída."

msgid "input file shrank"
msgstr "o arquivo de entrada reduziu de tamanho inesperadamente."

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar os nomes das pastas %s e %s."

msgid "%s: recursive directory loop"
msgstr "%s: itinerário de diretório recursivo"

msgid "Thomas Lord"
msgstr "Senhor Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o --output=FILE        executa a operação interativamente, envia o "
"resultado para FILE."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr ""
"-i, --ignore-case            Não distingue entre maiúsculas e minúsculas."

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   Ignore asignações de largura devido à expansão "
"do tab"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr "-Z, --ignore-trailing-space  abaikan white space di akhir baris"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    Ignorar as alterações na quantidade de espaços "
"em branco."

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space       Ignorar espaços em branco."

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     Ignore changes where all lines are empty."

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignorem as alterações nas linhas que se "
"conformem ao padrão RE."

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      elimina o retorno de carro (CR) no final da "
"linha ao inserir."

msgid "-a, --text                   treat all files as text"
msgstr ""
"-a, --text                   Permite que todas as pastas sejam tratadas como"
" texto."

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              Kelihatan banyak NUM (kolom) kolumn perbagi "
"baris (voreq. 130)."

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            Nur linke Spalte der gemeinsamen Zeilen "
"ausgeben."

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines Já não é permitido exibir linhas comuns."

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs            Tabuleiros em sequências de caracteres para "
"espaços\n"

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM           Tabulação de tabuladores é a cada NUM colunas "
"(por omissão, uma tabulação padrão para 8)"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                Intensiv após uma pequena quantidade de "
"alterações procurar."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      Es são grandes arquivos com muitas pequenas "
"alterações espalhadas."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM   utilize PROGRAM para comparar arquivos\n"

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar ajuda e sair."

msgid "-v, --version                output version information and exit"
msgstr "-v, --version                Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Aufruf: %s [OPTION]... DATEI1 DATEI2\n"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Conjunto diferenciado de FILE1 e FILE2."

msgid "cannot interactively merge standard input"
msgstr "não é possível juntar a entrada padrão de forma interativa."

msgid "both files to be compared are directories"
msgstr "As duas pastas a serem comparadas são diretórios."

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed:\tUbah lalu gunakan kedua versi, dekorasikan dengan header.\n"
"eb:\tUbah lalu gunakan kedua versi.\n"
"el atau e1:\tEdit lalu gunakan versi kiri.\n"
"er atau e2:\tEdit lalu gunakan versi kanan.\n"
"e:\tEdit versi baru.\n"
"l  atau e1:\tGunakan versi kiri.\n"
"r  atau e2:\tGunakan versi kanan.\n"
"s:\tSertakan baris bersama secara diam-diam.\n"
"v:\tSertakan baris bersama secara verbose.\n"
"q:\tKeluar.\n"

msgid "unrecognized prefix: %s"
msgstr "Préfixo desconhecido: %s"

msgid "unparsable value for --palette"
msgstr "valor que não pode ser avaliado para --palette"
