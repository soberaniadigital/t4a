msgstr "cmp: EOF na linha %s após byte %<PRIdMAX>, coluna %<PRIuMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, in line %<PRIdMAX>\n"
msgstr "cmp: EOF na linha %s após byte %<PRIdMAX>, dentro da mesma linha\n"

