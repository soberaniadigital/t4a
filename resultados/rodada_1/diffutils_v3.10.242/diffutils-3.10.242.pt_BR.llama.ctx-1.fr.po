msgstr "a longua do contexto %s nao e valid"

msgid "pagination not supported on this host"
msgstr "a paginasi não é suportada neste host"

msgid "too many file label options"
msgstr ""
"Existe muito mais opções de arquivos do que o necessário para os labels"

msgid "invalid width %s"
msgstr "largura %s inválida"

msgid "conflicting width options"
msgstr "opções de largura conflitantes"

msgid "invalid horizon length %s"
msgstr "panjang horizon %s inválido"

msgid "invalid tabsize %s"
msgstr "tamanho do campo %s inválido"

msgid "conflicting tabsize options"
msgstr "conflicto de opções tabsize"

msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan"

msgid "    --normal                  output a normal diff (the default)"
msgstr ""
"    --normal                  Produzir um 'diff' em formato normal (padrão)"

msgid "-q, --brief                   report only when files differ"
msgstr "-q, --brief                   Indicar apenas se os arquivos diferem"

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical-files Indicar se duas pastas contêm arquivos "
"idênticos."

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c NUM --context[=NUM]   elimine NUM (3 por padrão) linhas do contexto "
"copiado."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   elimine NUM (baku 3) linhas do contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      excluir um script para edição (edit)"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     gerar um arquivo 'diff' no formato RCS\n"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            Visualização em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM               keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             apenas tampilca coluna esquerda das linhas "
"idênticas"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   Não exiba linhas idênticas"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         Mostrar na qual função C ocorre cada "
"alteração\n"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   Mostrar a linha mais recente correspondente à "
"RE"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label ETIQUETTE         utilizar ETIQUETTE ao invés do nome de fichier e da hora\n"
"                                (pode ser repetido)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Exponha os tabulações em espaços na saída"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tabular   alinhe os tabuladores adicionando um caractere de "
"tabulação no início do tabuleiro"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty   Cegar espaços e tabulações antes de linhas em "
"branco"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr "-l, --paginate                Relay the output to 'pr' for pagination"

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive               Comparar os subdiretórios de forma recursiva "
"encontrados."

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            Não siga links simbólicos."

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                Trata os arquivos ausentes como se fossem "
"arquivos vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   cria o primeiro arquivo de entrada sem "
"conteúdo (vazio)"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-case     ignorar diferenças de maiúsculas e minúsculas ao "
"comparar nomes de arquivos"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case considere grande pequeno ao comparar nomes de"
" arquivos"

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT            Excluir os arquivos cujos nomes concordam com o"
" Padrão"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FICHIER   Exclua os arquivos cujos nomes concordam com "
"aqueles contidos no FICHIER."

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FICHIER Comece a comparar os diretórios utilizando o "
"FICHIER."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FICHIER1     Comparar FICHIER1 com todas as operandas. \n"
"                                  FICHIER1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FICHIER2       Comparar todas as opções com FICHIER2. \n"
"                                  FICHIER2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case            Ignorar diferenças entre maiúsculas e "
"minúsculas nos arquivos de texto."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   Ignorar as alterações relacionadas à expansão "
"das tabulações."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignorar espaços em branco à direita da "
"linha final\n"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change     Ignorar as alterações no número de espaços\n"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space        Ignorar todos os espaços em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     Ignorar alterações em que todas as linhas são "
"brancas"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore as para linhas que concordam com a "
"expressão regular RE."

msgid "-a, --text                      treat all files as text"
msgstr ""
"-a, --text                    Aplique a todos os arquivos como texto para "
"processamento"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr "    --strip-trailing-cr       Elimina os retornos de carro da entrada"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                      Leia e escreva dados em binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NOM              Excluir arquivos combinados e marcar diferenças"
" com '##ifdef NOM'."

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT Formate os grupos de entrada GTYPE com o "
"formato GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT       Formatar todas as linhas de entrada com LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT Formate os dados LTYPE com o formato LFMT\n"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"As opções de formatação do Opsi fornecem controle fino sobre a saída "
"diferencial e generalizam -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'antigo', 'novo' ou 'sem alterações'. GTYPE assume uma das "
"opções de LTYPE, ou seja, 'modificado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"  GFMT dapat berisi:\n"
"    %<  baris dari FILE1\n"
"    %>  baris dari FILE2\n"
"    %=  baris bersama FILE1 dan FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec untuk LETTER\n"
"      LETTERs adalah sebagai berikut untuk grup baru, huruf kecil untuk grup tua:\n"
"        F  nomor baris pertama\n"
"        L  nomor baris terakhir\n"
"        N  jumlah baris = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"GFMT ou LFMT podem conter : \n"
"%%\n"
"%c\"C\"     o caractere \"C\" em si mesmo\n"
"%c'^'   o caractere com código octal '^'\n"
"... (continue with the rest of translations)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal            pesquisa assiduamente o conjunto de diferenças mais"
" pequeno do Keras"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM     reter NUM linhas com prefijos e sufixos padrão\n"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files assume that large files with small, scattered "
"changes are being processed."

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=QUAND]      colorize o output; QUAND é 'sempre' (todos os tempos), 'jamais' (nunca) ou 'automático' (por padrão);\n"
"                           --color sem argumento é equivalente a --color='automático'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    paleta de cores utilizada quando --color está "
"ativo; PALETTE é uma lista separada por vírgulas das capacidades terminfo."

msgid "    --help               display this help and exit"
msgstr "    --help               Mostrar ajuda deste assistente e sair"

msgid "-v, --version            output version information and exit"
msgstr "-v --versão            Mostrar versão e sair do programa."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FICHIERS são 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FICHIER' ou 'FILE DIR'. Se"
" não souber qual é o tipo de arquivo, use a opção '-t filetype' para "
"especificar."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Bila --from-file ou --to-file são fornecidos, não há limite para os "
"arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se um arquivo for '-', ler de entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Utilização: %s [OPÇÃO]... FILES"

msgid "Compare FILES line by line."
msgstr "Bandar FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr "valor %2$s opção de conflito do %1$s"

msgid "conflicting output style options"
msgstr "opções de gaya conflictuais"

msgid "invalid color %s"
msgstr "cor da %s não é válida"

msgid "-D option not supported with directories"
msgstr "-D opção não suporta diretórios"

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios sama: %s e %s\n"

msgid "Only in %s: %s\n"
msgstr ""
"Sobrescrever o texto original para ajustar ao idioma e contextualizar de "
"acordo com as traduções anteriores."

msgid "File %s is a %s while file %s is a %s\n"
msgstr ""
"O arquivo %s é um fichier temporário enquanto o arquivo %s é um fichier "
"permanente\n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Os símbolos '%s' -> '%s', '%s' -> '%s' são diferentes."

msgid "cannot compare '-' to a directory"
msgstr "não pode comparar o sinal negativo (-) com um diretório de arquivo"

msgid "Files %s and %s are identical\n"
msgstr "As pastas de arquivo %s e %s são idênticas"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opções não compatíveis"

msgid "'-' specified for more than one input file"
msgstr "'--' descreve que mais de um arquivo pode ser fornecido como entrada."

msgid "read failed"
msgstr "falha na leitura"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all               Exiba todas as alterações e conflitos presentes"
" no arquivo de transferência"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    Excluir o script ed que contém alterações do "
"arquivo OLDFILE para YOURFILE e depois copiar para MYFILE."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap           Com como -e mas os conflitos estão entre sinais"
" de abertura e fechamento (brackets)"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only              Como -e mas inclui apenas alterações que não se"
" recupõem"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only    Com como -e mas inclui apenas os alterações que se "
"sobrepõem à linha anterior."

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          Com como -x mas o conflitos são entre crochets."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr ""
"-i                            Adicionar as comandas 'w' e 'q' ao script 'ed'"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                 Escreva o arquivo resultante da fusão de acordo "
"com -A se nenhuma outra opção for especificada\n"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                    Aplique a todos os arquivos como texto para "
"processamento"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr "    --strip-trailing-cr       Elimina os retornos de carro da entrada"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tabular   preencha tabulação horizontal com um tabulador no "
"início da linha de texto"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAM Utilize o PROGRAMA para comparar os arquivos."

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=ETIQUETA                Utilizar a ETIQUETTA ao invés do nome de fichier\n"
"                       (possívelmente repetir até três vezes)"

msgid "    --help                  display this help and exit"
msgstr "    --help                    Mostrar ajuda deste menu e sair"

msgid "-v, --version               output version information and exit"
msgstr "-v --versão                 Mostrar versão e sair do programa."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Pemakaian: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"

msgid "Compare three files line by line."
msgstr "Bandar três arquivos em linhas por linhas."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída para keluaran baku é uma representação mais ou menos "
"legível por humanos dos alterações. As opções -e, -E, -x e -X (além das suas"
" contrapartes longas) causam a escrita de um script ed em vez da saída "
"padrão. Por fim, a opção --merge faz com que diff3 realize uma fusão "
"internamente e envie o arquivo combinado realmente. Para entradas não "
"convencionais, isso é mais robusto do que usar ed."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do resultado é 0 se tudo correu, 1 em caso de conflito e 2 quando "
"houve problemas."

msgid "internal error: screwup in format of diff blocks"
msgstr "erro interno: mistura no formato dos blocos 'diff'."

msgid "%s: diff failed: "
msgstr "%s: falha ao executar o comando 'diff' : "

msgid "internal error: invalid diff type in process_diff"
msgstr "erro interno: tipo de 'diff' inválido no process_diff"

msgid "invalid diff format; invalid change separator"
msgstr ""
"formato de diferença (diff) inválido; separador de alterações invalido"

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença (diff) inválido; última linha incompleta"

msgid "subsidiary program %s could not be invoked"
msgstr "programa subsidiário %s não pode ser chamado"

msgid "invalid diff format; incorrect leading line chars"
msgstr ""
"formato de diferença (diff) inválido; caracteres iniciais da linha "
"incorretos"

msgid "internal error: invalid diff type passed to output"
msgstr "erro interno : tipo de 'diff' inválido fornecido na saída"

msgid "input file shrank"
msgstr "o arquivo de entrada diminuiu em tamanho"

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar os nomes dos arquivos %s e %s"

msgid "%s: recursive directory loop"
msgstr "%s: loop direto no recurso do diretório"

msgid "Thomas Lord"
msgstr "Senhor Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=FICHIER         Operar interativamente, com saída para FICHIER."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr ""
"-i, --ignore-case            Ignorar maiúsculas e minúsculas semelhantes"

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   Ignorar as alterações relacionadas à expansão "
"das tabulações"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignorar espaços em branco à beira da "
"linha\n"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    Ignorar as mudanças no número de espaços em "
"branco"

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space       Ignorar todos os espaços em branco"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     Ignore os alterações em que todas as linhas são"
" brancas"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore as para todas as alterações em linhas "
"que correspondam à expressão regular RE"

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr "    --strip-trailing-cr      Elimina os retornos de carro da entrada"

msgid "-a, --text                   treat all files as text"
msgstr "-a, --text                   Aplique a todos os arquivos como texto"

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              limite a saída à no máximo NUM (130 por padrão)"
" colunas impressas."

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            Mostrar apenas a coluna de esquerda das linhas "
"idênticas."

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines  Não exiba linhas semelhantes."

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs            Expande os tabulações em espaços na saída\n"

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                Rechercar ativamente o conjunto de diferenças "
"mais pequeno possível em Keras."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      Suponha de grandes arquivos e muitos pequenos "
"alterações dispersas."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAM   utilizar o PROGRAM para comparar os arquivos"

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar ajuda deste assistente e sair"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v, --version                Mostrar versão e informações do software e "
"sair."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Pemakaian: %s [OPÇÃO]... FILIAL1 FILIAL2\n"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Fusão síncrona das diferenças entre o arquivo %s e o arquivo %s."

msgid "cannot interactively merge standard input"
msgstr "não é possível mesclar a entrada padrão de forma interativa"

msgid "both files to be compared are directories"
msgstr "as duas pastas que estão sendo comparadas são diretórios"

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed: Utilize as duas versões, cada uma com seu próprio cabeçalho. \n"
" eb: Use as duas versões. \n"
" el ou e1: Edite a versão de esquerda. \n"
" er ou e2: Edite a versão de direita. \n"
" e: Abandone ambas as versões para criar uma nova. \n"
" l ou 1: Utilize a versão da esquerda. \n"
" r ou 2: Utilize a versão da direita. \n"
" s: Inclua linhas idênticas silenciosamente. \n"
" v: Inclua linhas idênticas e as anuncie. \n"
" q: Sair."

msgid "unrecognized prefix: %s"
msgstr "préfixo não reconhecido: %s"

msgid "unparsable value for --palette"
msgstr "valor impossível de ser dividido para --palette"
