msgstr ""
"%s %s diferente: byte %<PRIuMAX>, linha %<PRIuMAX> é de %3o bits e %3o "
"bytes."

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF encontrado em %s vazio"

