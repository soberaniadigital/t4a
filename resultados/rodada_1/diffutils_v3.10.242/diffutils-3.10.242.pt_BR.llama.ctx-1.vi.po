msgstr "Dois arquivos que serão comparados são diretórios"

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"[{'original_command': 'ed', 'portuguese_translation': 'sửa'}, "
"{'original_command': 'eb', 'portuguese_translation': 'sửa rồi sử dụng cả hai"
" phiên bản.'}, {'originalterminal command': 'el atau e1', "
"'portuguese_translation': 'sửa rồi sử dụng phiên bản bên trái.'}, "
"{'originalcommand': 'er atau e2', 'portuguese_translation': 'sửa rồi sử dụng"
" phiên bản bên phải.'}, {'terminal command': 'e', 'portuguese_translation': "
"'hủy cả hai phiên bản rồi sửa một phiên bản mới.'}, {'originalcommand': 'l "
"atau e1', 'portuguese_translation': 'sử dụng phiên bản bên trái.'}, "
"{'originalcommand': 'r atau e2', 'portuguese_translation': 'sử dụng phiên "
"bản bên phải.'}, {'terminal command': 's', 'portuguese_translation': 'bao "
"gồm dòng chung nhưng không xuất chi tiết.'}, {'terminalcommand': 'v', "
"'portuguese_translation': 'bao gồm dòng chung xuất một cách chi tiết.'}, "
"{'terminal command': 'q', 'portuguese_translation': 'thoát.'}]"

