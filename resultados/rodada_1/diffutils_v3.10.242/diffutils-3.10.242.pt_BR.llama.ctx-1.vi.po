msgstr "Paulo Eggert"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Richard Stallman"
msgstr "Richard Stallman"

msgid "Len Tower"
msgstr "Torre de Len"

msgid "invalid context length %s"
msgstr "o comprimento do contexto %s não é válido"

msgid "pagination not supported on this host"
msgstr "não há suporte para paginamento neste host"

msgid "too many file label options"
msgstr "há muitos opções de rótulo para o arquivo"

msgid "invalid width %s"
msgstr "o valor '%s' não é válido para o tamanho do campo"

msgid "conflicting width options"
msgstr "conflicto de opções amplas entre si"

msgid "invalid horizon length %s"
msgstr "o horizonte de %s não é válido"

msgid "invalid tabsize %s"
msgstr "cỡ ký tự tab %s không hợp lệ"

msgid "conflicting tabsize options"
msgstr "conflicto de opção tabsize"

msgid "--from-file and --to-file both specified"
msgstr ""
"Selecione dois caminhos de entrada --from-file (de um arquivo) e saída --to-"
"file (para outro arquivo).\n"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                  sair com o diff padrão (básico)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   chiare apenas quando as pastas de origem e "
"destino forem diferentes."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical_files  relatório quando duas pastas contêm arquivos "
"idênticos."

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C NUM, --context[=NUM]   xuất ra NUM (baku 3) dòng của ngữ cảnh từ "
"keluaran yang sáng"

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U SỐ, --unified[=SỐ]     xuất ra SỐ (mặc định là 3) dòng của ngữ cảnh "
"hợp nhất"

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      xuất tập lệnh ed"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     keluaran dalam format RCS diff"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            keluaran dalam dua kolom"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W,--width=SỐ                xuất tối đa SỐ cột đã in ra (mặc định là 130)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             kết xuất chỉ cột bên trái của các dòng chung"

msgid "    --suppress-common-lines   do not output common lines"
msgstr ""
"    --suppress-common-lines   não exibir linhas com conteúdo duplicado"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         hiển thị cái mà từng hàm C thay đổi ở trong "
"đó."

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   mostra a linha de função correspondente RE"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pacote NHÃN (não utilizar nome do arquivo nem estampas de tempo) \n"
"                                (possível repetição)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             mở rộng ký tự tab ra ký tự khoảng cách khi kết"
" xuất\n"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab             sabe criar uma tabulação reta adicionando um \n"
"                                tabo à frente da linha de texto."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=Só               🙌 cacha tab s sau mỗi Só coluna imprimida "
"(mặc định là 8)"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr "    --suppress-blank-empty    cegah spazi ou tab antes da linha vazia\n"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                transfira dados de saída para o arquivo 'pr' "
"para paginação"

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 sincronização de diretórios e subdiretórios "
"recursivamente"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não aceitar link simbólico"

msgid "-N, --new-file                  treat absent files as empty"
msgstr "-N --novo-arquivo                    coi tập tin vắng mặt là trống."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   anggap berkas pertama yang tidak ada sebagai"
" kosong"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     abaixe ou ignore diferenças entre maiúsculas"
" e minúsculas ao comparar os nomes dos arquivos"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  pertimbangkan besar kecil saat membandingkan"
" nama berkas"

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr "-x, --exclude=PAT               tanpa berkas yang cocok dengan PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         abaixa todas as linhas que correspondem a um"
" padrão especificado em FILE"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting_file=FILE        iniciar com FILE ao comparar diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1        carregar FILE1 com todos os operandos; \n"
"                                  FILE1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2             bandar todos os operand com FILE2; \n"
"                                  FILE2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               desconsidera diferenças entre letras "
"maiúsculas e minúsculas no conteúdo do arquivo."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      abaixa quaisquer alterações devidas à "
"expansão do tabulação\n"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr "-Z, --ignore-trailing-space     bỏ qua tất cả dấu cách ở cuối dòng"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       abaixa quaisquer alterações no número de "
"espaços em branco\n"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space          bora qua tacao de espaço"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        bỏ qua thay đổi do dòng trống"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore changes in lines that match the "
"regular expression RE."

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      xử lý mọi tập tin là văn bản thường"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar carro-retorno no final da entrada (dê"
" para remover o retorno de linha ao fim do input)"

msgid "    --binary                    read and write data in binary mode"
msgstr ""
"    --binary                     leitura e escrita de dados em modo binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=TÊN                 kết xuất tập tin đã trộn với khác biệt "
"“#ifdef TÊN”"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   format grup masukan GTYPE dengan GFMT "

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          formato para todas as linhas de entrada em "
"LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr "    --LTYPE-line-format=LFMT    định dạng nhập LTYPE với LFMT"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Opsi format inicial oferece controle suave sobre a diferença de saída, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE é 'antigo', 'novo' ou 'sem alteração'. GTYPE é LTYPE ou 'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"    GFMT pode conter o seguinte:\n"
"        %< linhas do arquivo TP_TIN1\n"
"        %> linhas do arquivo TP_TIN2\n"
"        %= linhas combinadas dos arquivos TP_TIN1 e TP_TIN2\n"
"        %[-][DIMENSÃO][.[PRECISÃO]]{doxX}NUMEROS  especificadores printf para NUMEROS, que são os seguints para novos grupos de letras maiúsculas: F - Primeira linha (linhas), L - Última linha (linhas), N - Total de linhas = L-F+1\n"
"        E - Linha antes da primeira linha (linhas)\n"
"        M - Linha após a última linha (linhas)\n"
"    %(A=B?T:E)  se A for igual B, então T; caso contrário, E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"LFMT pode conter: \n"
"    %L contém a linha\n"
"    %l contém a linha, sem adicionar uma nova linha após esta\n"
"    %[-][WIDTH][.[PREC]]{doxX}n especificador printf para o número de linhas inseridas"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"O GFMT e o LFMT podem conter: \n"
"%%\n"
"%c'C'\tcaractere único C\n"
"%c'^'\tcaracter com mã bát octal ^^^\n"
"C\tcaractere C (os caracteres diferentes representam este)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal            cópia de usaçao do Keras para encontrar alterações "
"mínimas em um conjunto perceptual."

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM  preservar NUM linhas do prefíxo e sufixo comuns"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files assume that large and numerous small changes are "
"rapidly spread"

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=WHEN]       cor da saída; WHEN pode ser 'sem', 'permanente' ou 'automático' (padrão)\n"
"                           --color='auto'\n"
"\t"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    códigos de cor utilizados quando o --color está "
"ativo; PALETTE é um conjunto de capacidades terminfo separadas por pontos "
"duplos."

msgid "    --help               display this help and exit"
msgstr "    --help               exiba ajuda deste comando e saia"

msgid "-v, --version            output version information and exit"
msgstr ""
"-v, --version             mostra informações de versão e sai da aplicação\n"

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES adalah 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Seja utilizado o --from-file (de um tp.txt) ou --to-file, sem limite para os"
" arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o FILE for '-', ler de entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Cách dùng: %s [OPTION]... CÁC_TẬP_TIN"

msgid "Compare FILES line by line."
msgstr "Bandar FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr "valor %2s opção %1s conflito"

msgid "conflicting output style options"
msgstr ""
"conflicto de opções guiado por vários campos e formatos para gerar "
"resultados distintos entre si"

msgid "invalid color %s"
msgstr "màu không hợp lệ %s"

msgid "-D option not supported with directories"
msgstr "-D opção não suportada para diretório"

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios idênticos: %s e %s\n"

msgid "Only in %s: %s\n"
msgstr "Chinês apenas em %s: %s\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr "Berkas %s adalah mínimo sementara berkas %s adalah máximo. \n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o caractere '-' com um diretório"

msgid "Files %s and %s are identical\n"
msgstr "Berkas %s dan %s identik\n"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opções não compatíveis"

msgid "'-' specified for more than one input file"
msgstr "O sinal '-' indica que mais de uma pasta de entrada foi especificada."

msgid "read failed"
msgstr "falha na leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exibe todas as alterações e conflitos no "
"documento\n"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    saída do script ed com alterações hibridas\n"
"                                de T_P_TIN_CŨ para T_P_TIN_CỦA_BẠN em MY_FILE"

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap          semelhante ao -e, mas mostra conflito dentro do "
"pacote\n"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             seperti -e, tapi hanya melibatkan perubahan yang"
" tidak bertindih"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          semelhante ao -e, mas somente considera "
"alterações que se sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          seperati -x, tapi apit konflik dalam kurung"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          nóximo de comandos 'w' e 'q' ao script ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                 keluar tipe siklus yang sebenarnya, sempati -A "
"jika tidak diberikan opsi lain\n"

msgid "-a, --text                  treat all files as text"
msgstr "-a, --text                  perlakukan semua berkas sebagai teks"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     apagar carro-retas no final da entrada de dados"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab           cria uma tabulação horizontal adicionando um \n"
"\t'\\t' antes da linha atual.\n"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM  utilize PROGRAM para comparar arquivos"

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL           pakai LABEL sebagai pengganti nama berkas\n"
"                                (dapat diulang sampai dengan tiga kali)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  exiba ajuda deste assistente e saia"

msgid "-v, --version               output version information and exit"
msgstr ""
"-v, --version               mostra informações de versão e sai da "
"aplicação\n"

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Cách dùng: %s [OPTION]... TÍVEL_ARQUIVO OBSOLETE_ARQUIVO SEU_ARQUIVO"

msgid "Compare three files line by line."
msgstr "Bandingkan tiga berkas baris per baris."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída para keluaran baku adalah representação perubahan yang "
"kurang lebih dapat serap oleh manusia. As opções -e, -E, -x e -X (e as suas "
"variantes mais longas) causam a geração de um script como substituto para "
"uma saída padrão. Por fim, a escolha da opção --merge faz com que o diff3 "
"realize a fusão internamente e envie uma pasta realmente combinada. Para "
"entradas não convencionais, isso é mais robusto do que usar ed."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do keluruan é o número 0 se tiver sucesso, número 1 em caso de "
"conflito e número 2 quando enfrentar problemas."

msgid "internal error: screwup in format of diff blocks"
msgstr "Erro interno de sintaxe: não é possível formatar o bloco diferencial."

msgid "%s: diff failed: "
msgstr "%s: diferença de erro: "

msgid "internal error: invalid diff type in process_diff"
msgstr ""
"Erro interno do sistema: tipo de diferença não é válido no "
"processamento_diff (revisão de diferenças)"

msgid "invalid diff format; invalid change separator"
msgstr "formato difícil de validar; separador alterado inválido"

msgid "invalid diff format; incomplete last line"
msgstr ""
"formato de diferença não é válido; a última linha do arquivo está "
"incompleta."

msgid "subsidiary program %s could not be invoked"
msgstr "programa de suporte ao usuário %s não pode ser chamado"

msgid "invalid diff format; incorrect leading line chars"
msgstr ""
"formato diferenciado inválido; carácter líder da linha não está correto"

msgid "internal error: invalid diff type passed to output"
msgstr ""
"Erro interno de tipo: o diferencial '%s' não é válido para ser inserido no "
"resultado"

