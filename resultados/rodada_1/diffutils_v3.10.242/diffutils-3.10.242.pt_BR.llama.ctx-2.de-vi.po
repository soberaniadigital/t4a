msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr "FILES são 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Se --from-file ou --to-file fornecer, não há limites para os arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o arquivo for '-', ler de entrada padrão."

