msgstr ""
"    --color[=WANN]        Warnai keluaran; WANN pode ser 'sem', 'todas as vezes' ou 'automático';\n"
"                           --color sem argumentos significa `--color='automático'`."

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
