msgid "-b, --print-bytes          print differing bytes"
msgstr "-b --print-bytes          exibe bytes diferentes."

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=SKIP         lewati SKIP byte awal dari kedua masukan"

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:SKIP2      bora SKIP1 byte de início do arquivo "
"FILE1 e SKIP2 byte de início do arquivo FILE2."

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose              exibe bytes de dados e valores distintos para "
"todos os bytes"

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr ""
"-n, --bytes=LIMIT          bandar o maior número possível de LIMIT byte"

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s, --quiet, --silent      suprime toda a saída normal"

msgid "    --help                 display this help and exit"
msgstr "    --help                 hiển thị trợ giúp này rồi thoát"

msgid "-v, --version              output version information and exit"
msgstr ""
"-v, --version              mostra informações de versão e sai da aplicação."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "CÓDIGO_DE_USO1 [TÚMEN]… BERKAS2 [BERKAS3 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandingkan dua berkas byte per byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 e SKIP2 representam o número de bytes que devem ser pulados no início "
"de cada arquivo (valor padrão é zero)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos obrigatórios para as opções de comprimento longo também são "
"obrigatórios para as opções de comprimento curto."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Nilai SKIP dapat diikuti oleh suffiks perkalian berikut: \n"
"kB x 1000, K x 1024, MB x 1.000.000, M x 1.048.576, \n"
"GB x 1.000.000.000, G x 1.073.741.824, tương tự với T, P, E, Z, Y."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se um arquivo for '-' ou não existir, lê a entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"O estado de saída é 0 se as duas entradas forem idênticas, sinaliza um valor"
" diferente para situações distintas e indica o status '2' em caso de erro."

