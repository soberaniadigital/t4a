msgstr "Paul Eggert"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Richard Stallman"
msgstr "Richard Stallman"

msgid "Len Tower"
msgstr "Torre de Len"

msgid "invalid context length %s"
msgstr "o comprimento do contexto '%s' não é válido"

msgid "pagination not supported on this host"
msgstr "não há suporte para paginação neste host"

msgid "too many file label options"
msgstr "ter muitos opções de rótulo de arquivo"

msgid "invalid width %s"
msgstr "o tamanho %s não é válido"

msgid "conflicting width options"
msgstr "opções de largura conflitantes"

msgid "invalid horizon length %s"
msgstr "o horizonte à linha de visão não é válido para o valor %s"

msgid "invalid tabsize %s"
msgstr "tamanho do campo tab '%s' não é válido"

msgid "conflicting tabsize options"
msgstr "opções de tabsize em conflito"

msgid "--from-file and --to-file both specified"
msgstr ""
"Seja utilizado tanto --from-file quanto --to-file para transferir dados "
"entre arquivos."

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                  sair com diff normal (padrão)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   chama somente quando arquivos diferentes forem"
" carregados."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical-files  notifica cuándo dois arquivos são idênticos"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr "-c, -C NUM, --context[=NUM]   xuất ra NUM (baku 3) dòng của ngữ cảnh"

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   exclui NUM (por omissão 3) linhas do contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      excluir um script ed"

msgid "-n, --rcs                     output an RCS format diff"
msgstr ""
"-n, --rcs                     gera diferenças no formato RCS para o arquivo "
"de saída."

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            mostra em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NUM               mude o tamanho máximo de NUM colunas (padrão é"
" 130)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             kết xuất chỉ cột bên trái của các dòng chung"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não exiba linhas comuns"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         hiển thị cái mà từng hàm C thay đổi ở trong "
"đó."

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   mostra a linha de função mais recente que se "
"encaixa com RE"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pakai LABEL bukan nama berkas dan stempel waktu\n"
"                                (dapat diulang)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             expande os ký tự tab para espaços na saída\n"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab             sabe criar uma tabulação vertical com um \n"
"                                caractere de tabulador adicionado no início da linha\n"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty    suprime espaços ou tabs antes de uma linha "
"vazia\n"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                chame o arquivo 'pr' para paginar a saída de "
"dados."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 sancionando os subdiretórios de forma "
"recursiva"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não aceite seguir links simbólicos"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N --novo-arquivo                    trata os arquivos que não existam como "
"vazios"

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new_file   cria o primeiro arquivo de dados que não tem"
" conteúdo"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     bỏ qua chữ HOA/thường khi so sánh các tên "
"tập tin"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  considere grandes e pequenos ao comparar o "
"nome do arquivo."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               excluir arquivos que correspondam ao padrão "
"PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         minta berkat yang cocok dengan pola dalam "
"FILE"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        começa com FILE quando comparando "
"diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1           bandar FILE1 para todos os operandos; \n"
"                                  FILE1 pode ser um diretório ou arquivo de texto"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2             bandar todos os operandos com FILE2; \n"
"                                  FILE2 pode ser um diretório ou outro tipo de arquivo"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               desconsidera diferenças entre letras "
"maiúsculas e minúsculas no conteúdo dos arquivos."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      bora qua mudanças devidas a expansões de "
"tabs"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr "-Z, --ignore-trailing-space     bỏ qua tất cả dấu cách ở cuối dòng"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       abaixa quaisquer alterações no número de "
"espaços em branco\n"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space          abaixa tudo o que é espaço em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        abaixa as alterações em linhas vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE  bora quitar linhas que coincidam com RE"

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      perlakukan semua berkas sebagai teks"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar o retorno de carro (carriage return) "
"no final da entrada\n"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                     leia e escreva dados em modo binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NOME                 gera um arquivo combinado que mostra as "
"diferenças com '#ifdef NOME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatar o grupo de entrada GTYPE com GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          formata todas as linhas de entrada com LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT    định dạng các baris mua LTYPE với LFMT"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Opsi format inicial oferece controle fino sobre o resultado de diff, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE adala 'antigo', 'novo' ou 'sem alteração'. GTYPE é LTYPE ou "
"'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode conter as seguints informações:\n"
"    %< linhas do arquivo TP_TIN1\n"
"    %> linhas do arquivo TP_TIN2\n"
"    %= linhas comuns aos arquivos TP_TIN1 e TP end TP_TIN2\n"
"    %[-][ANCHO][.[PRECISÃO]]{doxX}LETRAS  especificação printf para LETRAS\n"
"      As LETRAS podem ser como segue para grupos novos (em minúsculas para grupos antigos):\n"
"        F número da primeira linha\n"
"        L número da última linha\n"
"        N número de linhas = L-F+1\n"
"        E F-1\n"
"        M L+1    %(A=B?T:E)  se A for igual a B então T caso contrário E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"Tanto GFMT quanto LFMT podem conter: \n"
"    %%\n"
"    %c'C'\tcaractere único C\n"
"    %c'^'\tcara com código octal ^OOO^ (com mã bát phân)\n"
"    C\ttipo de carácter C (tipos diferentes se representam a si mesmos)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr "-d, --minimal            tenta encontrar uma mudança mínima no Keras"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM mantém NUM linhas de prefijos e sufíxios comuns"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files  assume que arquivos grandes e com poucas mudanças "
"dispersas por todo o conteúdo"

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=WHEN]       cor da saída; WHEN pode ser 'sem', 'sóce sempre' ou 'auto';\n"
"                           --color por si só significa 'cor='+'='+'auto'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    cadeiras de cores que são utilizadas quando o "
"--color está ativo; PALETTE é um conjunto separado por dois pontos das "
"capacidades terminfo."

msgid "    --help               display this help and exit"
msgstr "    --help               Mostrar ajuda deste comando e sair"

msgid "-v, --version            output version information and exit"
msgstr "-v, --version            mostra a versão e sai da aplicação\n"

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES adalah 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Seja utilizado o --from-file (de um arquivo) ou --to-file (para salvar em um"
" arquivo), sem limite para a quantidade de ARQUIVOS."

msgid "If a FILE is '-', read standard input."
msgstr "Se um arquivo for '-', lê a entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "CÓDIGO_DE_USO: %s [OPTUMA]... BÉRKAS"

msgid "Compare FILES line by line."
msgstr "Bandar FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr ""
"o valor da opção %s é conflitivo, ocorrendo uma escolha entre as "
"alternativas '%s' e '%s'"

msgid "conflicting output style options"
msgstr ""
"conflicto de opções do gerenciador de layout com o resultado da loteria"

msgid "invalid color %s"
msgstr "cor do campo '%s' não é válido"

msgid "-D option not supported with directories"
msgstr "-D opção não é suportada para diretórios."

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios sama: %s e %s\n"

msgid "Only in %s: %s\n"
msgstr "Chinês só em %s: %s\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr "O arquivo %s é um %s enquanto que o diretório %s é um %s. \n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o caractere '-' com um diretório"

msgid "Files %s and %s are identical\n"
msgstr "Os arquivos %s e %s são idênticos."

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opções não compatíveis"

msgid "'-' specified for more than one input file"
msgstr "Dispesifikado mais de um arquivo de entrada"

msgid "read failed"
msgstr "falha na leitura"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exibe todos os alterações e conflitos presentes "
"no documento\n"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"--ed                    exclui o script ed com alterações de OLDFILE para "
"YOURFILE e coloca no MYFILE\n"

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap          seperto -e, mas mostra conflitos dentro do kit "
"de desenvolvimento"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             semelhante a -e, mas apenas envolve alterações "
"que não se sobrepõem"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          semelhante a -e, mas somente mostra alterações "
"que se sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          seperati -x, tapi apit konflik dalam kurung"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          nóique as ordens 'w' e 'q' ao script ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m --merge                 exclui o arquivo realmente combinado, de acordo "
"com -A se nenhuma outra opção for especificada"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                  trata todos os arquivos como de tipo texto"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     apagar o retorno de carro final após a entrada"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab           tenta tabular com um tab adicionado na frente do"
" primeiro tab\n"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAM  utiliza PROGRAM para comparar as diferenças "
"entre os arquivos."

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL           pakai LABEL sebagai pengganti nama berkas\n"
"                                (dapat diulang sampai dengan tiga kali)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  mostra o assistente deste comando e sai"

msgid "-v, --version               output version information and exit"
msgstr ""
"-v --versao               mostra informações de versão e sai do programa."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "CÓDIGO DE UTILIZAÇÃO: %s [OPTION]... MEUARQUIVO OLDEFILE SEUARQUIVO\n"

msgid "Compare three files line by line."
msgstr "Bandingkan tiga berkas baris per baris."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída predeterminado é uma representação mais ou menos legível "
"dos alterações. As opções -e, -E, -x e -X (além das suas correspondentes "
"versões longas) geram um 'script' ed em vez do resultado predeterminado. "
"Finalmente, a opção --merge faz com que diff3 realize a combinação "
"internamente e exiba o arquivo combinado. Para certos casos de entrada, isso"
" é mais robusto do que usar ed."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do keluaran é 0 caso de sucesso, 1 em caso de conflito e 2 em caso "
"de erro."

msgid "internal error: screwup in format of diff blocks"
msgstr ""
"erro interno de sintaxe: falha na definição do formato dos blocos "
"diferenciais (diff)"

msgid "%s: diff failed: "
msgstr "%s: diferença de erro: "

msgid "internal error: invalid diff type in process_diff"
msgstr "Erro interno: tipe diff inválido no process_diff (xử lý khác biệt)"

msgid "invalid diff format; invalid change separator"
msgstr "formato de diferença não é válido; separador para alteração inválido"

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença inválido; linha final incompleta"

msgid "subsidiary program %s could not be invoked"
msgstr "programa subsidiário %s não pode ser chamado"

msgid "invalid diff format; incorrect leading line chars"
msgstr "DIFF format inválido; caracteres leading line incorretos"

msgid "internal error: invalid diff type passed to output"
msgstr "Erro interno: tipo de diferença inválido passado para a saída"

msgid "input file shrank"
msgstr "o arquivo de entrada tem menos bytes do que o esperado."

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar o nome do arquivo %s e %s"

msgid "%s: recursive directory loop"
msgstr "%s: bucle de diretório recursivo"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=FILE            Execute interactively, send output to FILE."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr ""
"-i, --ignore-case            desconsidera maiúsculas e minúsculas como "
"equivalentes"

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr "-E, --ignore-tab-expansion   bỏ qua mọi thay đổi do mở rộng tab."

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr "-Z, --ignore-trailing-space  bỏ qua tất cả dấu cách ở cuối dòng"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    bora quitar a diferença na quantidade de espaço"
" em branco\n"

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space       bora qua tacao de espaço em branco"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     bora quitar as alterações que representam "
"linhas em branco"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE  bora quitar as linhas que coincidam com RE"

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      apagar o retorno de carro no final da entrada "
"(carriage return)"

msgid "-a, --text                   treat all files as text"
msgstr ""
"-a, --text                   trata todos os arquivos como texto padrão"

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            kết xuất chỉ cột bên trái của các dòng chung "
"nhau."

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines  não exibir linhas comuns"

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr "-t, --expand-tabs            ekspansi ký tự tab ke spasi dalam output\n"

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
