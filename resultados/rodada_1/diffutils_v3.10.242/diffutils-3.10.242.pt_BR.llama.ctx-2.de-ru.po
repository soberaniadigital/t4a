msgid "-b, --print-bytes          print differing bytes"
msgstr "-b, --print-bytes      Exibir bytes diferentes."

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=%s\n"
"Skip the first %s byte(s) of input."

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:SKIP2\n"
"                        Ignore the first SKIP1 bytes of FILE1 and the first SKIP2 bytes of FILE2."

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose          Exibir as numerações e valores de todos os bytes "
"diferentes."

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr "-n, --bytes=LIMIT      comparando o máximo de LIMIT bytes."

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s, --quiet, --silent   não exibir mensagens normais."

msgid "    --help                 display this help and exit"
msgstr "    --help             Mostrar ajuda desta interface e sair."

msgid "-v, --version              output version information and exit"
msgstr "-v, --version              mostra informações de versão e sai."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "Aufruf: %s [PILIHAN]... BERKAS1 [BERKAS2 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandar dua berkas byte per byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 e SKIP2 representam o número de bytes que devem ser pulados no início "
"de cada arquivo (valor padrão é zero)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos obrigatórios para opções longas também são necessários para as"
" opções curtas."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Os valores SKIP podem ser acompanhados pelos seguintes sufixos multiplicativos subsequentes:\n"
"KB 1000, K 1024, MB 1.000.000,\n"
"M 1.048.576, GB 1.000.000.000,\n"
"G 1.073.741.824, e assim por diante para T, P, E, Z, Y."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se o arquivo for '-' ou não existir, lê a entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"Status de saída é 0 se as entradas forem idênticas, 1 caso contrário e 2 em "
"caso de falha."

msgid "invalid --bytes value %s"
msgstr "valor de byte %s inválido"

msgid "missing operand after %s"
msgstr "não há operando após %s"

msgid "extra operand %s"
msgstr "operando extra %s"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s diferente: byte %<PRIdMAX>, linha %<PRIdMAX>"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX> is %3o %s %3o %s\n"
msgstr ""
"%s %s diferem em byte e linha, que são respectivamente %<PRIdMAX> bytes e "
"%<PRIdMAX> lines. O tamanho é de %3o por %3o."

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF na %s que está vazia."

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF em %s após byte %<PRIdMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "cmp: EOF em %s após byte %<PRIdMAX>, linha %<PRIdMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, in line %<PRIdMAX>\n"
msgstr "cmp: EOF em %s após byte %<PRIdMAX>, na linha %<PRIdMAX>"

