"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"[{'original_key': 'ed', 'translated_to': 'editar, depois usar ambas as "
"versões decoradas com cabeçalho.'}, {'original_key': 'eb', 'translated_to': "
"'editar e utilizar ambas as versões sem decoração de cabeçalho.'}, "
"{'originalterminal.exe': 'editar, depois usar a versão esquerda.', "
"'translated_to': 'editar, depois utilizar a versão esquerda.'}, "
"{'original_key': 'el', 'translated_to': 'utilizar a versão esquerda sem "
"edição adicional.'}, {'original_key': 'er', 'translated_to': 'utilizar a "
"versão direita sem edição adicional.'}, {'original_key': 'e', "
"'translated_to': 'rejeitar ambas as versões e criar uma nova para editá-"
"la.'}, {'original_key': 'l', 'translated_to': 'utilizar a versão esquerda "
"sem edição adicional.'}, {'original_key': 'r', 'translated_to': 'utilizar a "
"versão direita sem edição adicional.'}, {'original_key': 's', "
"'translated_to': 'adicionar linhas comuns de forma silenciosa (sem "
"mensagens).'}, {'original_key': 'v', 'translated_to': 'adicionar linhas "
"comuns em detalhe, exibindo as mensagens.'}, {'original_key': 'q', "
"'translated_to': 'sair.'}]"

