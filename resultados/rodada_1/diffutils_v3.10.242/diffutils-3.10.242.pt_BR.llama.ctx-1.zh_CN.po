msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan"

msgid "    --normal                  output a normal diff (the default)"
msgstr ""
"    --normal                   saída do diff em um formato normal (padrão)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                    somente quando o arquivo for diferente para "
"relatório breve."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr "-s, --report-identical-files  当两个文件相同时也进行报告"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C NUM, --context[=NUM]   excluir NUM (baku 3) linhas do contexto que "
"está sendo lida."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   excluir NUM (baco 3) linhas do contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      saída em ed script formatado."

msgid "-n, --rcs                     output an RCS format diff"
msgstr ""
"-n, --rcs                      com diferenças no RCS formatado para keluaran"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side             em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W,--width=NUM               keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             hanya tampilkan kolom kiri baris yang sama"

msgid "    --suppress-common-lines   do not output common lines"
msgstr ""
"    --suppress-common-lines     Não exiba linhas com conteúdo duplicado"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function          Mostrar em qual função C cada alteração está "
"localizada."

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr "-F, --show-function-line=RE  تظهر فيلتاب الخطأ (mistake) RE"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label <LABEL>             utilizar o label em vez do nome de arquivo e timestamp\n"
"                                (possível repetição)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs              Converte os tabuais em espaços no resultado "
"da saída."

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab              adiciona um tab no início de cada linha para "
"alinhamento à esquerda."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty    quebra de linha antes da linha em branco ou "
"tabulação"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                 Enviar resultados para o comando 'pr' para "
"paginação"

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                   µbandar subdiretórios recursivamente"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference             não deve seguir links simbólicos"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                   Considerar arquivos não existentes como "
"vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   se o arquivo de entrada não existir, ele é "
"tratado como um arquivo vazio."

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-case     desconsidere diferenças de maiúsculas e minúsculas ao "
"comparar o nome do arquivo"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  Considere grande pequeno ao comparar nomes "
"de arquivos"

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr "-x, --exclude=PAT               tanpa berkas yang cocok dengan PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=arquivo         Excluir qualquer arquivo que corresponda "
"a um padrão listado no arquivo\n"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        começa com FILE ao comparar diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1           bandar FILE1 para todos os operandos; \n"
"                                  FILE1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2             transferir todos os operand para FILE2; \n"
"                                  FILE2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               desabaixa diferenças entre letras maiúsculas"
" e minúsculas na carga de texto."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion       desconsidere ajustes causados pela expansão"
" de tabulação\n"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space      § abaixa o espaço em branco no final da "
"linha\n"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change        desconsidera mudanças no número de espaços "
"em branco devido a diferenças na quantidade de texto longo"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-W,--ignore-all-space          abaixa todos os espaços em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines         ignora alterações em linhas que estejam "
"todas vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE abaixa as alterações das linhas que se "
"encaixam com RE"

msgid "-a, --text                      treat all files as text"
msgstr ""
"-a, --text                       Aplica-se a todos os arquivos como texto"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr          apagar o caractere de retorno de linha no "
"final da entrada"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                     em modo binário para escrever dados."

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=<nome>                    Excluir o conteúdo do arquivo que "
"inclui '#ifdef <nome>' format diff após a junção."

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr "    --GTYPE-group-format=GFMT   format grup masukan GTYPE dengan GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr "    --line-format=LFMT          format semua baris masukan denga LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT\n"
"formata a linha de entrada do tipo LTYPE usando o formato <LINE_FORMAT>."

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Os formatos de opção inicializam um controle suave sobre a saída "
"diferencial, generalizando o -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"O LTYPE pode ser 'antigo', 'novo' ou 'inalterado'. O GTYPE é o mesmo que o "
"LTYPE, ou seja, todas as opções do LTYPE, ou 'modificado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode conter as seguints informações:\n"
"    %<   linhas do arquivo1\n"
"    %>   linhas do arquivo2\n"
"    %=  linhas comuns entre o arquivo1 e o arquivo2\n"
"    %[-][largura][.[precisão]]{doxX}caracter   utilizando a sintaxe printf para caracteres:\n"
"      F  primeira linha do grupo de linhas no início da coluna 1 (linhas menores)\n"
"      L  última linha do grupo de linhas na última coluna 2 (linhas maiores)\n"
"      N  quantidade total de linhas, igual a L-F+1\n"
"      E  F-1\n"
"      M  L+1"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"O GFMT ou o LFMT podem conter: \n"
"    %%\n"
"    %c'C'\tCaractere único C\n"
"    %c'^'\tCaracter com cifra octal OOO (que representa um caractere)\n"
"    C\tCaractere C (excluindo as conversões de escape, exceto os caracteres mencionados)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal             busca para encontrar as mudanças mais mínimas em "
"Keras"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM mantendo NUM linhas comuns para prefixo e sufixo\n"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files   assume files are large and contain many small, "
"scattered changes"

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=QUANTO]       pinta keluaran; QUANTO pode ser 'sempre', 'sempre' ou 'automático';\n"
"                            apenas especificar o --color é equivalente a definir como 'automático'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE      Cor da paleta utilizada quando o --color está "
"ativo; PALETTE é um conjunto de cores definido por terminfo, separado por "
"dois pontos."

msgid "    --help               display this help and exit"
msgstr "    --help                Mostrar ajuda deste assistente e sair"

msgid "-v, --version            output version information and exit"
msgstr "-v --versão             Mostrar informações de versão e sair."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES podem ser 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr "Bila --from-file ou --to-file diri, sem limite para arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o arquivo for '-', lerá a entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Utilização: %s [Opção]... Biblioteca"

msgid "Compare FILES line by line."
msgstr "Bandar FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr "%s valor oci%s tem conflito com %s opção"

msgid "conflicting output style options"
msgstr "Há conflito nas opções de gaya keluaran."

msgid "invalid color %s"
msgstr "a cor %s não é válida"

msgid "-D option not supported with directories"
msgstr "O -D opção não é suportada para diretórios."

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios sama: %s e %s\n"

msgid "Only in %s: %s\n"
msgstr "Somente no %s há a presença de :%s\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr "Berkas %s adalah%s sementara berkas %s adalah%s\n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o sinal de menos '-' com diretório"

msgid "Files %s and %s are identical\n"
msgstr "Bilhas %s e %s idênticas"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opção não compatível"

msgid "'-' specified for more than one input file"
msgstr ""
"O sinal '-' indica que mais de um arquivo está sendo lido como entrada."

msgid "read failed"
msgstr "falha na leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              keluarkan semua perubahan dan konflik dalam "
"tanda kurung."

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    saída pode conter alterações do <ficheiro "
"antigo> para o <seu ficheiro>, integradas no ed script em <meu ficheiro>."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap           similar to -e, but using parentheses to mark "
"conflicts within the bracketed section."

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only              similar ao -e, mas somente apresenta alterações"
" que não se sobrepõem"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only           similar to -e, but only overlapping changes are"
" shown."

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          seperati como -x, porém apit konflik dalam "
"kurung\n"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          imbuhkan perintah 'w' dan 'q' ke skrip ed\n"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                   Excluir o arquivo realmente resultante da "
"fusão de dados, conforme -A se não for especificado nenhuma outra opção\n"

msgid "-a, --text                  treat all files as text"
msgstr "-a, --text                   Aplica-se a todos os arquivos como texto"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      elimina o caractere de retorno de linha no "
"final da entrada"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab           adicionar tab vertical com símbolo de tabulação "
"no início da linha anterior para alinhamento horizontal\n"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAM      utilizar o PROGRAM para comparar arquivos\n"

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL           pakai LABEL sebagai pengganti nama berkas\n"
"                                (dapat diulang sampai dengan tiga kali)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  Mostrar ajuda deste assistente e sair"

msgid "-v, --version               output version information and exit"
msgstr "-v --versão               Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr ""
"Pemakaian: %s [OPÇÃO]... O Meu Arquivo O Antigo Arquivo Você's Archivo"

msgid "Compare three files line by line."
msgstr "Bandeirar três linhas por linha."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída do keluaran baku é uma representação que pode ser lida por"
" humanos. A opção -e, -E, -x e -X (além das suas variantes mais longas) "
"resulta na emissão de um script edit no formato fixo como substituto para o "
"padrão original. Por fim, a escolha do parâmetro -m ('--merge') faz com que "
"diff3 realize uma fusão internamente e envie realmente o arquivo combinado."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do keluaran é 0 se tiver sucesso, 1 para conflito e 2 para erro."

msgid "internal error: screwup in format of diff blocks"
msgstr "Erro interno de sintaxe: o formato do bloco diff não está correto"

msgid "%s: diff failed: "
msgstr "%s: diferença falha:%s"

msgid "internal error: invalid diff type in process_diff"
msgstr ""
"Erro interno: tipo difícil não é válido no processamento de diferença "
"(process_diff)"

msgid "invalid diff format; invalid change separator"
msgstr "formato de diferença inválido; separador para alterações inválido"

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença inválido; linha final não completa"

msgid "subsidiary program %s could not be invoked"
msgstr "programa não pode ser chamado %s"

msgid "invalid diff format; incorrect leading line chars"
msgstr "formato de diferença inválido; caractere líder da linha não correto"

msgid "internal error: invalid diff type passed to output"
msgstr ""
"Erro interno: tipo de diferença (diff) não é válido para ser inserido no "
"resultado"

msgid "input file shrank"
msgstr "o arquivo de entrada foi reduzido em tamanho"

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar o nome do arquivo %s e %s"

msgid "%s: recursive directory loop"
msgstr "%s: loop diretório recursivo"

msgid "Thomas Lord"
msgstr "Senhor Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o --output=FILE            operação interativa, envio dos resultados para "
"FILE."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr "-i, --ignore-case             Ignora maiúsculas e minúsculas"

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion    desconsidera alterações decorrentes da "
"expansão de tabulação"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space  abaixa o espaço em branco no final da linha\n"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change     Desconsiderar alterações no número de "
"caracteres em branco devido a mudanças na quantidade desses espaços."

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space        ignorar todos os espaços em branco"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines      desconsidera alterações em linhas que estejam "
"todas vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE abaixa todas as alterações em linhas que "
"correspondam ao padrão RE"

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      Remove o caractere de retorno de linha no final"
" da entrada."

msgid "-a, --text                   treat all files as text"
msgstr ""
"-a, --text                    Aplica-se a todos os arquivos como texto."

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NUM              Keliara mais de NUM (base 130) colunas "
"impressas"

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column             hanya tampilkan kolom kiri baris yang sama"

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines  抑制输出相同行的显示"

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Expande os tabuletas (tab) em espaços na "
"saída\n"

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                 para encontrar as mudanças mais mínimas em um "
"conjunto de dados do Keras."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files       Supõe-se que o arquivo seja grande e contenha "
"muitas pequenas alterações dispersas."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAM       utilize o PROGRAM para comparar arquivos\n"

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar ajuda deste assistente e sair"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v, --version                 Exibe informações de versão e sai do programa."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Pemakaian: %s [OPTION]... FILE1 FILE2"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Conjunto de diferenças entre o arquivo %s e o arquivo %s."

msgid "cannot interactively merge standard input"
msgstr ""
"não é possível interagir para mesclar a entrada padrão de forma coletiva"

msgid "both files to be compared are directories"
msgstr "Dois arquivos que estão sendo comparados são diretórios"

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed: Edite as duas versões e use. As duas versões devem ter seus respectivos cabeçalhos para reconhecimento adequado.\n"
"\n"
"eb: Edite as duas versões e use. Cada uma deve ser decorada com seu próprio header para identificação correta.\n"
"el ou 1: Edite a versão esquerda, depois utilize. A versão esquerda é utilizada após edição.\n"
"er ou 2: Edite a versão direita, então use. A versão direita também deve ser editada antes de uso.\n"
"e: Apague as duas versões e crie uma nova versão para usar. Isso elimina o risco de conflitos entre diferentes itens modificados.\n"
"l ou 1: Use a versão esquerda após edição, semelhante ao exemplo anterior.\n"
"r ou 2: Utilize a versão direita depois que foi editada."

msgid "unrecognized prefix: %s"
msgstr "Não é reconhecido o prefixo '%s'"

msgid "unparsable value for --palette"
msgstr "o valor `--palette' não pode ser interpretado para obter um nilai"
