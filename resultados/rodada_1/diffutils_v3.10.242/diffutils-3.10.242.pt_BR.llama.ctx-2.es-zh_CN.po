msgid "-b, --print-bytes          print differing bytes"
msgstr "-b --print-bytes           mostra os bytes que são diferentes"

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=SKIP         lewati SKIP byte awal dari kedua masukan"

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:SKIP2 \n"
"                    salta os primeiros SKIP1 bytes de FILE1\n"
"                    e os primeiros SKIP2 bytes de FILE2"

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose              exibe todos os bytes diferentes e seus valores em"
" byte."

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr ""
"-n --bytes=LIMIT          bandar o maior número possível de LIMIT byte."

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s, --quiet, --silent       suprime toda a saída normal"

msgid "    --help                 display this help and exit"
msgstr "    --help                 mostra esta ajuda e sai do programa"

msgid "-v, --version              output version information and exit"
msgstr ""
"-v, --version              mostra informações de versão e sai da utilidade."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "Modo de uso: %s [PILIHAN]... BERKAS1 [BERKAS2 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandingkan dua berkas byte per byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 dan SKIP2 adalah jumlah byte yang harus dilewati di awal setiap berkas"
" (nilai baku adalah nol)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos obrigatórios para as opções longas também são obrigatórios "
"para as opções curtas."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Os valores SKIP podem ser seguidos pelos seguintes sufixos de multiplicação:\n"
"kB = 1000, K = 1024, MB = 1.000.000, M = 1.048.576,\n"
"GB = 1.000.000.000, G = 1.073.741.824 e assim por diante para T, P, E, Z, Y."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se um arquivo for '-' ou não existir, lê a entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"O estado de saída é 0 se as entradas forem idênticas, 1 se forem diferentes,"
" e 2 em caso de erro."

msgid "invalid --bytes value %s"
msgstr "valor --bytes inválido '%s'"

msgid "missing operand after %s"
msgstr "%s depois dele não tem operando"

msgid "extra operand %s"
msgstr "operando extra '%s'"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s são distintos: byte %<PRIuMAX>, linha %<PRIuMAX>"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX> is %3o %s %3o %s\n"
msgstr ""
"%s %s são distintos: o byte %d, na linha %<PRIuMAX> é de %3o e %3o para as "
"duas últimas casas decimais\n"

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF encontrado em %s que está vazio\n"

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF encontrado em %s após o byte %<PRIuMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "cmp: EOF em %s após byte %<PRIuMAX>, linha %<PRIuMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, in line %<PRIdMAX>\n"
msgstr "cmp: EOF em %s após byte %<PRIuMAX>, na linha %<PRIuMAX> \n"

msgid "Paul Eggert"
msgstr "Paul Eggert"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Richard Stallman"
msgstr "Richard Stallman"

msgid "Len Tower"
msgstr "Len Tower"

msgid "invalid context length %s"
msgstr "longitude de contexto inválida '%s'"

msgid "pagination not supported on this host"
msgstr "paginasi não é suportada neste host."

msgid "too many file label options"
msgstr "demasiadas opções de etiqueta de arquivo"

msgid "invalid width %s"
msgstr "largura '%s' inválida"

msgid "conflicting width options"
msgstr "opções de ancho conflitantes"

msgid "invalid horizon length %s"
msgstr "a longitude do horizonte %s não é válida"

msgid "invalid tabsize %s"
msgstr "tamanho de tab '%s' não é válido"

msgid "conflicting tabsize options"
msgstr "opções de tamanho do tabulador com conflitos"

msgid "--from-file and --to-file both specified"
msgstr "se ha especificado tanto --from-file como --to-file"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                   produz um diff normal (padrão)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   indica apenas se os arquivos são diferentes ou"
" não."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical-files notifica cuándo dois arquivos são idênticos"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c NUM --context[=NUM]   exibe NÚM (por omissão 3) linhas de contexto da "
"entrada."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   exibe NÚM (por omissão 3) linhas de contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      produz um script ed\n"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     gerar diferença no formato RCS\n"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            mostra em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W,--width=NUM               mostra como máximo NUM colunas de impressão "
"(por omissão 130)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             mostra apenas a coluna esquerda as linhas "
"comuns"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não exibe linhas comuns"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         mostra em qual função C cada alteração está "
"localizada"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=%s   mostra a linha mais recente que se encaixa com"
" %s"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             utilizar ETIQUETA em vez do nome do arquivo e "
"da marca de tempo (possível repetição)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             expande os tabuladores por espaços na saída"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab             faz com que os tabuladores fiquem alinhados na"
" frente do próximo tab\n"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty    suprime espaços ou tabs antes de uma linha "
"vazia"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr "-l, --paginate                passeie a saída por 'pr' para paginarla"

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 membandaçando subdiretorios de forma "
"recursiva"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não sigam os links simbólicos"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                   trata os arquivos que não existam como "
"vazios"

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   trata dos arquivos originais que não existem"
" como vazios"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     descarta diferenças entre maiúsculas e "
"minúsculas ao comparar os nomes de arquivos."

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  considere distintas maiúsculas e minúsculas "
"ao comparar os nomes dos arquivos."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               exclui os arquivos que coincidam com PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=ARQUIVO      excluir os arquivos que correspondam com "
"alguma expressão regular no ARQUIVO"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=ARQUIVO     começa por ARQUIVO quando se comparam "
"diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=ARQUIVO1        compara ARQUIVO1 com todos os operandos; \n"
"                                  ARQUIVO1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=ARQUIVO2          compara todos os operandos com ARQUIVO2; \n"
"                                  ARQUIVO2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               descarta diferenças entre letras maiúsculas "
"e minúsculas no conteúdo dos arquivos."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      descarta mudanças devidas a expansões de "
"tabs."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space     descarta espaço em branco ao final de linha"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change        Descarta as diferenças nas quantidades de "
"espaços em branco\n"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space          descarta todos os espaços em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines        descarta os campos em linhas completamente "
"vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=%s RE abaixa as linhas que se adequem ao padrão "
"de expressão regular RE"

msgid "-a, --text                      treat all files as text"
msgstr ""
"-a, --text                      trata todos os arquivos como de tipo texto"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         elimina os retornos de carro finais na "
"entrada"

msgid "    --binary                    read and write data in binary mode"
msgstr ""
"    --binary                    leia e escreva os dados no modo binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NOMBRE              gera um arquivo combinado que mostra as "
"diferenças com '#ifdef NOMBRE'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatagem do grupo de entrada GTYPE com o "
"formato GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          format sem todas as linhas de entrada com "
"LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT    formatando linhas de entrada LTYPE com LFMT"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"As opções de formato fornecem um controle suave sobre o resultado "
"diferencial, generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE adala 'antigo', 'novo' ou 'sem mudanças'. GTYPE é como LTYPE, podendo "
"ser 'cambiado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT (solamente) pode conter: \n"
"    %< linhas do ARCHIVO1\n"
"    %> linhas do ARCHIVO2\n"
"    %= linhas comuns ao ARCHIVO1 e ARCHIVO2\n"
"    %[-][ANCHO][.[PRECISIÃO]]{doxX}LETRA  especificação printf para LETRA \n"
"      As LETRAS podem ser como seguidas para grupos novos (em maiúsculas para grupos antigos):\n"
"        F número da primeira linha\n"
"        L número da última linha\n"
"        N número de linhas = L-F+1\n"
"        E F - 1\n"
"        M L + 1"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"Tanto GFMT quanto LFMT podem conter: \n"
"%%\n"
"%c'C'\tcaractere único C\n"
"%c'^'\tcaracter com código octal \\u005eO\n"
"C\trepresenta o carácter C (os outros caracteres se representam a si mesmos)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr "-d, --minimal             busca por alterações mínimas no Keras"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM mantém NUM linhas de prefíxos e sufixos comuns"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files   supõe que os arquivos são grandes e as alterações "
"pequenas, dispersas e numerosas."

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=QUALIDADE]     aplica cor de saída; QUALIDADE pode ser 'sem', 'permanente' ou 'automático';\n"
"                           --color sozinho significa --color='automático'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE     os tons de cor utilizados quando o --color está "
"ativo; PALETTE é uma lista separada por dois pontos das capacidades "
"terminfo."

msgid "    --help               display this help and exit"
msgstr "    --help               mostra esta ajuda e sai do programa"

msgid "-v, --version            output version information and exit"
msgstr "-v, --version            mostra a versão e sai da utilidade."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"ARQUIVOS podem ser 'ARQUIVO1 ARQUIVO2' ou 'DIRETORIO1 DIRETORIO2' ou "
"'DIRETORIO ARQUIVO' ou 'ARQUIVO DIRETORIO'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr "Bila --from-file ou --to-file, não há limitações para arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se um arquivo for '-', lê a entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Modo de uso: %s [OPÇÃO]... BÉRCHAS"

msgid "Compare FILES line by line."
msgstr "Bandingkan FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr "%s opção tem o valor de conflito '%s'."

msgid "conflicting output style options"
msgstr ""
"As opções de gaya keluaran estão em conflito com as especificações do estilo"
" de saída."

msgid "invalid color %s"
msgstr "cor inválida '%s'"

msgid "-D option not supported with directories"
msgstr "-D opção não suportada para diretórios."

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios comuns: %s e %s"

msgid "Only in %s: %s\n"
msgstr "Sólo en %s: %s\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr ""
"O arquivo %s é um sementara berkas, enquanto o arquivo %s é um outro tipo de"
" berkas."

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr ""
"Os símbolos %s e %s são distintos, enquanto os links simbólicos %s -> %s e "
"%s -> %s não são diferentes."

msgid "cannot compare '-' to a directory"
msgstr ""
"não é possível comparar o sinal negativo (-) com um diretório (diretório)"

msgid "Files %s and %s are identical\n"
msgstr "As pastas %s e %s são idênticas"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opções não compatíveis"

msgid "'-' specified for more than one input file"
msgstr "O sinal '-' indica que há mais de um arquivo de entrada."

msgid "read failed"
msgstr "falha na leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exibe todos os alterações e encerra conflitos "
"entre parênteses."

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    exibe um `script' ed incorporando as alterações "
"entre o ARCHIVO-ANTAQUIA e OU-ARQUIVO para MI-ARQUIVO"

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap          como -e, mas indicando os conflitos entre "
"parênteses\n"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             como -e, mas apenas incorpora os alterações que "
"não se sobrepõem."

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          como -e, mas somente mostra os alterações que se"
" sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          como -x, mas envolve conflitos entre parênteses."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr ""
"-i                          adiciona as ordens 'w' e 'q' aos scripts ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                 exibe o arquivo combinado conforme -A se não for"
" especificada nenhuma outra opção\n"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                  trata todos os arquivos como de tipo texto"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     elimina os retornos de carro finais na entrada\n"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab           cria um tabulador reto adicionando antes dele "
"uma linha em branco\n"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM utiliza PROGRAM para comparar os arquivos."

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL           utilize LABEL como substituição para o nome do "
"arquivo (possível repetir até três vezes)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  mostra esta ajuda e sai"

msgid "-v, --version               output version information and exit"
msgstr ""
"-v --versao               mostra informações de versão e sai do programa."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr ""
"Modo de utilizar: %s [OPÇÃO]... MEU ARQUIVO OBSOLETE_ARCHIVE SEU_ARQUIVO"

msgid "Compare three files line by line."
msgstr "Bandingkan tiga berkas baris per baris."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída predeterminado é uma representação mais ou menos legível "
"dos alterações. As opções -e, -E, -x e -X (além das suas versões "
"correspondentes longas) resultam na geração de um script ed em vez do "
"resultado padrão. Por fim, a opção -m (--merge) faz com que diff3 realize o "
"processo internamente e apresente o arquivo combinado realmente existente. "
"Para entradas incomuns, isso é mais robusto do que usar ed."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O estado de saída é 0 se tudo correu bem, 1 em caso de conflito e 2 quando "
"houve algum problema."

msgid "internal error: screwup in format of diff blocks"
msgstr "erro interno de sintaxe no formato bloco diff"

msgid "%s: diff failed: "
msgstr "%s: diff falhou: "

msgid "internal error: invalid diff type in process_diff"
msgstr "erro interno: tipo de diferença inválido no process_diff"

msgid "invalid diff format; invalid change separator"
msgstr "formato de diferença inválido; separador para mudança inválido"

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença inválido; linha final incompleta"

msgid "subsidiary program %s could not be invoked"
msgstr "o programa subsidiário %s não pode ser chamado"

msgid "invalid diff format; incorrect leading line chars"
msgstr ""
"formato de diferença inválido; caracteres não corretos no início da linha"

msgid "internal error: invalid diff type passed to output"
msgstr "erro interno: tipo de diferença inválido passado para a saída"

msgid "input file shrank"
msgstr "o arquivo de entrada diminuiu em tamanho"

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar os nomes de arquivo '%s' e '%s'"

msgid "%s: recursive directory loop"
msgstr "%s: loop de diretório recursivo"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=ARQUIVO         opera interativamente, enviando o resultado "
"para ARQUIVO"

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr ""
"-i, --ignore-case            considera as letras maiúsculas e minúsculas "
"iguais."

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   descarta mudanças devidas a expansões de tabs"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space descarta espaço em branco ao final da linha"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    descarta as diferenças no número de espaços em "
"branco\n"

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space        descarta todo el espacio em branco"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     descarta os campos que sejam todas as linhas "
"vazias."

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=%s RE abaixa todas as alterações em linhas que "
"correspondam ao expressão regular %s"

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      elimina os retornos de carro finais na entrada "
"da linha\n"

msgid "-a, --text                   treat all files as text"
msgstr ""
"-a, --text                   trata todos os arquivos como de tipo texto"

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              mostra como máximo NUM colunas de impressão "
"(por omissão 130)"

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            mostra apenas a coluna esquerda das linhas "
"comuns."

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines   não exibe linhas comuns."

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs            expande os tabuladores por espaços na saída"

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                busca por pequenos grupos de alterações no "
"Keras."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      supõe que os arquivos sejam grandes e as "
"alterações sejam numerosas, pequenas e dispersas."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAMA  utiliza PROGRAMA para comparar os arquivos."

msgid "    --help                   display this help and exit"
msgstr ""
"    --help                   mostra esta ajuda e sai de agora em diante"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v, --version                informa da versão do software e finaliza a "
"execução."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Modo de emprego: %s [OPÇÕES]... ARQUIVO1 ARQUIVO2"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Combinação a duas colunas das diferenças entre ARQUIVO1 e ARQUIVO2."

msgid "cannot interactively merge standard input"
msgstr "não é possível misturar a entrada padrão de forma interativa"

msgid "both files to be compared are directories"
msgstr "As duas pastas que devem ser comparadas são diretórios."

