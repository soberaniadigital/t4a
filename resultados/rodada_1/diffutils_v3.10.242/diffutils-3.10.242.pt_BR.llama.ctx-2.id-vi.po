msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                  exibir diferenças normais (básicas)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   lapração apenas quando as pastas de origem e "
"destino forem diferentes"

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical_files  relatar quando duas pastas contêm arquivos "
"idênticos\n"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C NUM, --context[=NUM]   excluir NUM (baku 3) linhas do contexto que "
"está sendo lida."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   excluir NUM (baku 3) linhas do contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      excluir um script de edição"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     keluaran em RCS diferença formatada"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            keluaran dalam dua kolom"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NUM               keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             apenas exibe a coluna esquerda igual à "
"original da linha\n"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não mostre linhas comuns"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         menitkan no função C mãe de cada alteração"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   mostra a linha de função atual que corresponde"
" ao RE\n"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pakai LABEL bukan nama berkas dan stempel waktu\n"
"                                (dapat diulang)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr "-t, --expand-tabs             ekspansi tab ke spasi dalam keluaran"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab             criar tabular com inserção de espaços antes do"
" primeiro caractere da linha\n"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty    cegah espaços ou tabulação antes de uma linha "
"vazia\n"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                gereieiro keluaran para 'pr' para paginação"

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 membandação de subdiretórios recursivamente"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não aceite taut simbolik"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                    perlacução de um arquivo vazio como novo\n"

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   adiciona bkp pertama yang belum tersedia "
"sebagai kosong"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     abaixe grande pequeno ao comparar nome do "
"arquivo"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  pertimbangque grande pequeno ao comparar o "
"nome do arquivo"

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr "-x, --exclude=PAT               tanpa berkas yang cocok dengan PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         remova todas as linhas do arquivo que "
"correspondam aos padrões no FILE\n"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        comece com FILE quando comparar diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1           bandar FILE1 para todos os operandos; \n"
"                                  FILE1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2             bandar sempre todos os operand com FILE2; \n"
"                                  FILE2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               abaixa diferença entre letras maiúsculas e "
"minúsculas no conteúdo do arquivo\n"

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      abaixa as alterações decorrentes da expansão"
" do tabulação\n"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr "-Z, --ignore-trailing-space     bỏ qua tất cả dấu cách ở cuối dòng"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       abaixa a alteração causada por múltiplas "
"mudanças de espaço\n"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-W, --ignore-all-space          abaixa sempre todas as white spaces\n"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        abaixa as alterações em linhas vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Abaixe as alterações das linhas que "
"correspondam ao RE"

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      perlacupe todas as blocs como texto\n"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar retorno de carro no final da entrada "
"(input)"

msgid "    --binary                    read and write data in binary mode"
msgstr ""
"    --binary                     baca dan tulis data dalam mode binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NAME                keluarkan berkas yang tergabung dengan diff "
"'#ifdef NAME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   format grupo de entrada GTYPE com o formato "
"GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr "    --line-format=LFMT          format semua baris masukan denga LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT    format baris masukan LTYPE dengan LFMT\n"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"O format inicial oferece controle suave sobre diferenças de saída, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE adala 'antigo', 'novo' ou 'sem alteração'. GTYPE é LTYPE ou 'alterado'"

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode conter o seguinte:\n"
"    %< baris do arquivo FILE1\n"
"    %> baris do arquivo FILE2\n"
"    %= baris combinadas dos arquivos FILE1 e FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  especificador printf-style para LETTER,\n"
"      onde LETTERs representam o seguinte para grupos novos, letras minúsculas para grupos antigos:\n"
"        F número de linha inicial\n"
"        L número da última linha\n"
"        N quantidade total de linhas = L-F+1\n"
"        E (F)-1\n"
"        M (L)+1    %(A=B?T:E)  se A for igual a B, então T caso contrário E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"LFMT pode conter: \n"
"    %L linha\n"
"    %l linhas, sem adicionar uma nova linha após a última linha atualizada\n"
"    %[-][WIDTH][.[PREC]]{doxX}n printf-style spec para o número da linha de entrada"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"ID ou VI pode conter: \n"
"%%\n"
"%c'C'\tcaractere único C\n"
"%c'ôOOO'\trepresenta caractere com códigos octais OOO\n"
"C\tcaracter C (os caracteres diferentes representam)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal            usa a API do Keras para encontrar as mudanças "
"mínimas\n"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM  pertahankan NUM baris prefiks dan suffiks umum"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files assume that large and numerous small changes are "
"dispersed"

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=WHEN]       warnai keluaran; WHEN adalah 'sempre', 'jamais' ou 'automático';\n"
"                           --color polos berarti --color='automático'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    warna que é utilizada quando o --color está ativo; "
"PALETTE representa um conjunto de pontos duais da terminfo capabilities."

msgid "    --help               display this help and exit"
msgstr "    --help                 mostrar ajuda deste comando e sair"

msgid "-v, --version            output version information and exit"
msgstr ""
"-v, --version             mostra informações de versão e sai da aplicação."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES adalah 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Bila --from-file atau --to-file diberikan, tidak ada batasan untuk arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o arquivo for '-', ler a entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Penggunaan: %s [OPTION]... BERKAS"

msgid "Compare FILES line by line."
msgstr "Bandingkan FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr "valor %2s opção %1s conflito"

msgid "conflicting output style options"
msgstr "conflicto de opções gera keluaran"

msgid "invalid color %s"
msgstr "cor da %s não é válida"

msgid "-D option not supported with directories"
msgstr ""
"-D option not supported with directory (-D não é suportado com diretório)"

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdirektori sama: %s dan %s\n"

msgid "Only in %s: %s\n"
msgstr "Somente no %s há informações relevantes para o processo atual.\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr "Berkas %s adalah %d sementara berkas %s adalah %d. \n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda"

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o caractere '-' com um diretório"

msgid "Files %s and %s are identical\n"
msgstr "Berkas %s dan %s identik\n"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opção não é compatível"

msgid "'-' specified for more than one input file"
msgstr ""
"'--' especifica mais de uma pasta para entrada. Se você quiser saber como "
"usar, tente '--help'.\n"

msgid "read failed"
msgstr "falha na leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              keluarkan semua perubahan, konflik dalam tanda "
"kurung"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    excluir script ed que contém alterações do "
"arquivo OLDFILE para YOURFILE e salvar no MYFILE."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap          seperti -e, tapi apit konflik dalam kurung"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             semelhante a -e, mas apenas envolve alterações "
"que não se conectam"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          semelhante a -e, porém somente considera "
"alterações que se sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          seperati como -x, porém apit conflito na curung."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          imbuhkan perintah 'w' e 'q' ke skrip ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"--merge                 liberar o conteúdo realmente mesclado que "
"corresponde ao -A, quando nenhuma outra opção é fornecida\n"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                    Aplique sempre a todos os arquivos como texto."

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     apagar retorno de carro no final da entrada"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab           cria uma tabulação reta adicionando um \n"
"\t'\\t' antes da linha atual."

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM  utilize PROGRAM para comparar arquivos\n"

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL           pakai LABEL sebagai pengganti nama berkas\n"
"                                (dapat diulang sampai dengan tiga kali)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  exiba ajuda neste comando e saia"

msgid "-v, --version               output version information and exit"
msgstr "-v, --version               mostrar informações de versão e sair"

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Pemakaian: %s [OPTION]... MYFILE OLDFILE YOURFILE"

msgid "Compare three files line by line."
msgstr "Bandicote três blocos por linha."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída para keluaran baku é uma representação que pode ser lida "
"por humanos. As opções -e, -E, -x e -X (além das suas versões longas "
"relacionadas) causam a geração de um script em ed como substituto do padrão "
"original. Por fim, o uso da opção --merge faz com que diff3 realize uma "
"fusão internamente e envie para você um arquivo combinado realmente."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"Status keluaran adalah 0 jika sucesso, 1 se caso de conflito e 2 em caso de "
"erro."

msgid "internal error: screwup in format of diff blocks"
msgstr "Erro interno de sintaxe: falha ao formatar bloco diferencial."

msgid "%s: diff failed: "
msgstr "%s: diferença gargalosa: "

msgid "internal error: invalid diff type in process_diff"
msgstr ""
"Erro interno de tipo difícil em process_diff: tipe diferente inválido no "
"contexto do processamento diferencial (tratamento de diferentes tipos)"

msgid "invalid diff format; invalid change separator"
msgstr ""
"o diferencial de formatos não é válido; o separador alterado também não é "
"válido"

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença não é válido; linha final incompleta"

msgid "subsidiary program %s could not be invoked"
msgstr "program subsider %s não pode ser chamado"

msgid "invalid diff format; incorrect leading line chars"
msgstr ""
"formato de diferença não é válido; caractere líder da linha não está correto"

msgid "internal error: invalid diff type passed to output"
msgstr ""
"Erro interno de sintaxe: tipo difícil não é um valor válido para o resultado"

msgid "input file shrank"
msgstr "arquivo de entrada menor que o esperado"

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar o nome do arquivo %s e %s"

msgid "%s: recursive directory loop"
msgstr "%s: loop direto de pastas recursivo"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=FILE            operacao interativa, enviar saída para FILE"

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr "-i, --ignore-case            anggap huruf besar dan kecil sama"

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   abaixa as alterações decorrentes da expansão do"
" tabulação"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr "-Z, --ignore-trailing-space abaixa white space di akhir baris"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    abaixa a alteração causada por múltiplas "
"mudanças de espaço em branco"

msgid "-W, --ignore-all-space       ignore all white space"
msgstr ""
"-W, --ignore-all-space       abaixa sempre todas as espessuras de espaço "
"(white space)"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr "-B, --ignore-blank-lines     abaixa as alterações em linhas vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Abaixo as linhas que correspondem ao padrão "
"RE serão ignoradas.\n"

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      apagar retorno de carro no final da entrada "
"(masukan)"

msgid "-a, --text                   treat all files as text"
msgstr "-a, --text                   perlacupe todas as blocs como texto"

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            hanya tampilkan kolom kiri baris yang sama"

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines  não exiba linhas com conteúdo duplicado."

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr "-t, --expand-tabs            ekspansi tab ke spasi dalam keluaran"

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                ushao do keras para encontrar conjuntos de "
"alterações pequenas"

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      assume blocs grandes, muitas pequenas mudanças "
"dispersas\n"

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM   utilize PROGRAM para comparar arquivos\n"

msgid "    --help                   display this help and exit"
msgstr "    --help                   exiba ajuda nesta ferramenta e saia"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v, --version                mostra informações de versão e sai da "
"utilidade."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Pemakaian: %s [OPTION]... FILE1 FILE2\n"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Penggabungan bersisian dari perbedaan antara FILE1 dan FILE2."

msgid "cannot interactively merge standard input"
msgstr "não é possível combinar a entrada padrão de forma interativa."

msgid "both files to be compared are directories"
msgstr "A segunda pasta de dados utilizada para comparação é o diretório."

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed: Siga e utilize ambas as versões, adicione um cabeçalho. \n"
" eb: Siga e utilize ambas as versões. \n"
" el ou e1: Edite utilizando a versão esquerda. \n"
" er ou e2: Edite utilizando a versão direita. \n"
" e: Crie uma nova versão editável. \n"
" l  ou e1: Utilize a versão esquerda. \n"
" r  ou e2: Utilize a versão direita. \n"
" s: Insira linhas juntas, sem separação de texto. \n"
" v: Insira linhas juntas com detalhes adicionais (verbose). \n"
" q: Sair."

msgid "unrecognized prefix: %s"
msgstr "prefiks tidak dikenal: %s"

msgid "unparsable value for --palette"
msgstr "não é possível dividir o valor para --palette"
