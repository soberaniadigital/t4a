msgstr "o contexto '%s' não é válido"

msgid "pagination not supported on this host"
msgstr "paginamento não é suportado neste host."

msgid "too many file label options"
msgstr "existe uma grande variedade de opções para o label do arquivo"

msgid "invalid width %s"
msgstr "o valor '%s' não é válido."

msgid "conflicting width options"
msgstr "conflicto de opção aberta"

msgid "invalid horizon length %s"
msgstr "o horizonte do panorama %s não é válido"

msgid "invalid tabsize %s"
msgstr "O tamanho do campo %s não é válido"

msgid "conflicting tabsize options"
msgstr "conflicto de opção tabsize"

msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                   exibir diferenças normais (básicas)"

msgid "-q, --brief                   report only when files differ"
msgstr "-q --brief                   : quando o conteúdo muda."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr "-s, --report identical files laporkan ketika dua berkas sama"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c NUM --context=NUM   excluir NUM (3) linhas de contexto que foi lido"

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr "-u NUM --unified=NUM   exclui NUM (3) linhas do contexto unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      sai de um script ed."

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     diferenças no formato RCS\n"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y --side-by-side, opção para colunas lado a lado\n"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr "-W --largura=NUM   exibe NUM (padrão 130) colunas na tela"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             apenas tampilca a coluna esquerda da mesma "
"linha barra\n"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "--supressao de linhas comuns   não mostre as mesmas linhas\n"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         mostra onde em função C cada alteração do "
"código\n"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr "-F, --show-function-line=RE   mostra a linha de função atual RE"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pacote com o nome LABEL, não utilizando um identificador de arquivo e timestamp\n"
"                                (repetível)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             expande os tabs para espaços no resultado da "
"loteria."

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab             cria tab horizontal com inserção no canto "
"superior do tab"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --supresso-de-linhas-vazias_e_vairias   cegah spazi e tab antes de uma "
"linha vazia ou sem conteúdo"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                     forneça resultados para o terminal 'pr' "
"por páginas."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r --recursive                 membandação recursiva de subdiretórios e "
"arquivos"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "--não-dereferência            não deve seguir símbolos de referência"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N --novo-arquivo                    utilize arquivos que não contenham "
"dados previamente\n"

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   criação de um arquivo inicial que não tem "
"conteúdo anterior"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignora-nome-do-arquivo     abaixa grande pequeno quando comparando "
"nome do arquivo"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"--não ignorar diferenças de maiúsculas e minúsculas no nome do arquivo\n"
"perconsidere grandes pequenos ao comparar nomes de arquivos."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               sem arquivos que correspondam ao padrão PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         excluir linhas que correspondam aos padrões "
"listados no FILE"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr "-S --starting-file=FILE iniciar com FILE ao comparar diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1           carregar FILE1 para todos os operandos; \n"
"                                   FILE1 pode ser um diretório ou arquivo"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2             transferir todos os operand para FILE2; \n"
"                                   FILE2 pode ser um diretório."

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case\n"
"    abaixa diferença entre letras maiúsculas e minúsculas no conteúdo do arquivo."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr "-E, --ignore-tab-expansion      abaixa a expansão de tabulação\n"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore trailing space    abaixa espaços em branco no final da linha"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b --ignorar-mudanças-de-espaço\n"
"    Abaixa as mudanças de espaços em branco."

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-W --ignora todos os espaços em branco\n"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        abaixa as alterações em linhas vazias"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE abaixa as linhas que se adequam ao RE para "
"evitar alterações"

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      aplica todos os arquivos como texto"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr "--remover o retorno de carrote no final da entrada"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                     modo binário\n"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NAME                excluir o arquivo com diferença '#ifdef "
"NAME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   format grupo de GTYPE com o formato GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          format todas as linhas de entrada no formato"
" LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr "    --LTYPE-linha-formato=LFMT formatar linhas com LTYPE usando LFMT\n"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Opsi format inicial oferece controle suave sobre diferenças de saída, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"O LTYPE é 'antigo', 'novo' ou 'sem alterações'. O GTYPE é o LTYPE ou "
"'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"  GFMT dapat berisi:\n"
"    %<  baris dari FILE1\n"
"    %>  baris dari FILE2\n"
"    %=  baris bersama FILE1 dan FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec untuk LETTER\n"
"      LETTERs adalah sebagai berikut untuk grup baru, huruf kecil untuk grup tua:\n"
"        F  nomor baris pertama\n"
"        L  nomor baris terakhir\n"
"        N  jumlah baris = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"  GFMT atau LFMT dapat berisikan:\n"
"    %%  %\n"
"    %c'C'  karakter tunggal C\n"
"    %c'\\OOO'  karakter dengan kode oktal OOO"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr "-d --minimal, busca por pequenos set de mudanças no Keras\n"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --linhas de visÃ¡ncia=NUM mantendo NUM linhas prefissos e suficientes\n"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files assume that large and numerous small changes are "
"dispersed"

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=WHEN]      cor da sorte; WHEN é 'sempre', 'jamais' ou 'automático';\n"
"                           --color polos significa que o valor de `--color` seja 'automático'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE     cor da paleta utilizada quando o --color está "
"ativo; PALETTE é um conjunto de cores definido pela capacidade terminfo."

msgid "    --help               display this help and exit"
msgstr "    --help                 Mostrar ajuda e sair\n"

msgid "-v, --version            output version information and exit"
msgstr "-v --versão, mostrar informações sobre a versão e sair."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"Os arquivos podem ser 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE "
"DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr "Bila --from-file ou --to-file diri, sem limite para arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o arquivo for '-', ler a entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Utilização: %s [OPÇÃO]... BÉRNAIS"

msgid "Compare FILES line by line."
msgstr "Bandar file por linha por linha."

msgid "conflicting %s option value %s"
msgstr "valor do opcional %2s conflito com o valor padrão %1s"

msgid "conflicting output style options"
msgstr "conflicto de opção gráfica do keluaran"

msgid "invalid color %s"
msgstr "cor da %s não é válida"

msgid "-D option not supported with directories"
msgstr "-D opção não suportada em diretório"

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios idênticos: %s e %s\n"

msgid "Only in %s: %s\n"
msgstr "Só dentro de %s, é possível executar a opção '%s' com argumento\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr ""
"Berkas %s adalah berkas sementara, dengan %d kali meningkatkan keamanan\n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o caractere '-' com diretórios (directories)"

msgid "Files %s and %s are identical\n"
msgstr "Bilheteria %s e %s idênticas"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opção não é compatível"

msgid "'-' specified for more than one input file"
msgstr "O sinal '-' desabilita mais de uma pasta de entrada."

msgid "read failed"
msgstr "falha na leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A --mostar tudo                   exibir todas as alterações e conflitos no"
" documento de sincronização"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    sai do script ed que contém alterações da "
"OLDFILE para YOURFILE e coloca no MYFILE\n"

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap          seperto -e, mas com apit de conflito dentro da "
"curva\n"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3 --easy-only                      como -e, mas apenas envolve alterações "
"que não se conectam"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          semelhante ao -e, mas somente considera "
"alterações que se sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr "-X                          seperati -x, apit konflik dalam kurung"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          imbuhkan perintah 'w' dan 'q' ke skrip ed\n"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m --merge                 excluir arquivos concatenados que realmente "
"existem, conforme especificado em -A sem opções alternativas fornecidas."

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                   aplicação de todos os arquivos como texto"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     apagar o retorno de carro no final da entrada\n"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab           cria tab horizontal com preenchimento no canto "
"superior do tab\n"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM use o PROGRAM para comparar arquivos\n"

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL           utilizar LABEL como substituto do nome de "
"arquivo (possível repetir até três vezes)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  Mostrar ajuda e sair"

msgid "-v, --version               output version information and exit"
msgstr ""
"-v --versão, mostra informações sobre a versão e sai da linha de comando."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Uso do programa: %s [OPÇÃO]... MYFILE OLDFILE YOURFILE\n"

msgid "Compare three files line by line."
msgstr "Bandeirar três blocos de linhas por bloco."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"A representação do keluaran baku adalah alteração que pode ser lida por pessoas. \n"
"\n"
"As opções -e, -E, -x e -X (e as suas variantes de comprimento) causam a saída de um script em formato padrão como substituto do original. Por outro lado, a opção --merge faz com que o diff3 realize uma fusão internamente e gere um arquivo combinado realmente."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do resultado é 0 se for bem sucedido, 1 em caso de conflito e 2 "
"quando há problemas."

msgid "internal error: screwup in format of diff blocks"
msgstr ""
"Erro interno de sintaxe: encontrou um erro ao analisar o bloco diferencial "
"(diff)"

msgid "%s: diff failed: "
msgstr "%s: falha ao executar o comando\n"

msgid "internal error: invalid diff type in process_diff"
msgstr "Erro interno de tipo inválido para diferença no processamento_diff"

msgid "invalid diff format; invalid change separator"
msgstr ""
"a diferença de formato não é válida; o separador alterado também não é "
"válido."

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença não é válido; linha final incompleta."

msgid "subsidiary program %s could not be invoked"
msgstr "o programa não pode ser chamado com %s"

msgid "invalid diff format; incorrect leading line chars"
msgstr ""
"formato de diferença entre linhas não é válido; caractere líder da primeira "
"linha está incorreto"

msgid "internal error: invalid diff type passed to output"
msgstr "Erro interno de tipo inválido inserido no resultado"

msgid "input file shrank"
msgstr "arquivo de entrada inválido"

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar o nome do arquivo %s com %s"

msgid "%s: recursive directory loop"
msgstr "%s: loop direto recursivo em %d caminhos do diretório"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o --output=FILE operar de forma interativa, enviar resultado para FILE."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr "-i, --ignore-case            ignora maiúsculas e minúsculas sama"

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   abaixa a alteração causada pela expansão de "
"tabulação"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space abaixa o espaço em branco no final da linha"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b --ignora-mudanças-de-espaço    abaixa as mudanças de espaços em branco"

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W --ignora todos os espaços em branco\n"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr "-B,--ignore-blank-lines     abaixa as alterações em linhas vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE abaixa todas as alterações em linhas que "
"correspondam ao RE\n"

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      remove o retorno de carro da entrada final\n"

msgid "-a, --text                   treat all files as text"
msgstr ""
"-a, --text                   Aplicação de todos os arquivos como texto."

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              exibe mais de NUM (130 por padrão) colunas "
"impressas"

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            Há apenas a exibição da coluna esquerda igual à"
" original barra de linhas."

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines Não mostre linhas comuns."

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs            Expande os tabs para espaços no resultado "
"final."

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                   usaçao minimal do keras para encontrar "
"pequenos set de mudanças."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      assume asumes um arquivo grande com poucas "
"alterações dispersas."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM   utilize PROGRAM para comparar arquivos\n"

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar ajuda e sair"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v --versão, mostra informações sobre a versão e sai da linha de comando."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr ""
"Uso do programa:\n"
"%s [OPÇÃO]... ARQUIVO1 ARQUIVO2\n"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Fusão de sinal diferenciada entre arquivo %s e arquivo %s."

msgid "cannot interactively merge standard input"
msgstr "não é possível combinar a entrada padrão de forma interativa"

msgid "both files to be compared are directories"
msgstr "as duas pastas que estão sendo comparadas é o diretório"

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"{'ed': 'Edite e utilize ambas as versões, adicione com um cabeçalho.', 'eb':"
" 'Edite e utilize ambas as versões.', 'el atau e1': 'Edite utilizando a "
"versão esquerda.', 'er at oue2': 'Edite utilizando a versão direita.', 'e': "
"'Crie uma nova versão.', 'l  at ou e1': 'Utilize a versão esquerda.', 'r  at"
" ou e2': 'Utilize a versão direita.', 's': 'Coloque linhas juntas sem "
"espaços entre elas.', 'v': 'Coloque linhas juntas com detalhes (verbose).', "
"'q': 'Sair.'}"

msgid "unrecognized prefix: %s"
msgstr "falta de reconhecimento para o prefixo: %s"

msgid "unparsable value for --palette"
msgstr "valor que não pode ser calculado para --palette"
