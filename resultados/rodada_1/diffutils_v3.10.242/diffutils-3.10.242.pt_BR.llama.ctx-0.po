msgid "-b, --print-bytes          print differing bytes"
msgstr "-b --imprimir-bytes          imprime bytes diferentes."

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=SKIP         leva SKIP byte awal dados de entrada"

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:SKIP2 leva SKIP1 byte inicial do arquivo FILE1 e "
"SKIP2 byte inicial do arquivo FILE2."

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l --verbose   exibir todos os bytes de dados e seus valores distintos."

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr ""
"-n --bytes=LIMIT limite o número máximo de bytes a serem transferidos."

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s --quiet, -S silente      cegam todos os resultados normais."

msgid "    --help                 display this help and exit"
msgstr "    --help                 Mostrar ajuda e sair\n"

msgid "-v, --version              output version information and exit"
msgstr "-v --versão, mostrar informações sobre a versão e sair."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr ""
"Utilização: [PILIHAN] %s\n"
"Berkas1 [Berka2]\n"
"[SKIP1 SKIP2]"

msgid "Compare two files byte by byte."
msgstr "Bandeamento byte a byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 e SKIP2 representam o tamanho em bytes que devem ser pulados no início"
" de cada arquivo (valor padrão é zero)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr "O argumento obrigatório também deve conter a opção curta."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Os valores SKIP podem ser acompanhados pelos seguintes sufixos de multiplicação:\n"
"KB = 1000, KB = 1024, MB = 1.000.000, Mb = 1.048.576\n"
"GB = 1.000.000.000, GB = 1.073.741.824, e assim por diante para T, P, E, Z, Y."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se o arquivo for '-' ou não existir, ler a entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"Status de saída é 0 se o input for igual, 1 caso contrário e 2 em caso de "
"erro."

msgid "invalid --bytes value %s"
msgstr "valor '%s' --byte inválido"

msgid "missing operand after %s"
msgstr "não há operando após %s"

msgid "extra operand %s"
msgstr "operando extra %s"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s diferente: byte %<PRIuMAX>, linhas %<PRIuMAX>"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX> is %3o %s %3o %s\n"
msgstr ""
"%s %s diferente: byte %<PRIuMAX>, linhas %<PRIuMAX> são %3o bytes, %3o "
"caracteres\n"

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF em %s vazio"

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF na posição %s após byte %<PRIuMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "cmp: EOF na posição %s após byte %<PRIdMAX>, linha %<PRIuMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, in line %<PRIdMAX>\n"
msgstr ""
"cmp: EOF na posição %s após byte %<PRIdMAX>, no final da linha %<PRIdMAX>"

