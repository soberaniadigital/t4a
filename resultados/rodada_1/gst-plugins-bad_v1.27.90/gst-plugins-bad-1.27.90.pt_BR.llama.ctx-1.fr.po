msgid "OpenCV failed to load template image"
msgstr "falha ao carregar a imagem modelo com OpenCV"

msgid "Could not read title information for DVD."
msgstr "não foi possível obter as informações do título do DVD."

msgid "Failed to open DVD device '%s'."
msgstr "Não foi possível abrir o dispositivo do DVD \"%s\"."

msgid "Failed to set PGC based seeking."
msgstr "não é possível definir a pesquisa baseada em PGC."

msgid ""
"Could not read DVD. This may be because the DVD is encrypted and a DVD "
"decryption library is not installed."
msgstr ""
"Não foi possível ler o DVD. Isso pode ser devido ao fato de que ele está "
"criptografado e nenhuma biblioteca para descriptografia do DVD não estiver "
"instalada."

msgid "Could not read DVD."
msgstr "não foi possível ler o DVD."

msgid "This file contains no playable streams."
msgstr "Este arquivo contém um fluxo inválido para reprodução."

msgid "Could not open sndfile stream for reading."
msgstr "não foi possível abrir e ler o fluxo sndfile."

msgid "Generated file has a larger preroll time than its streams duration"
msgstr "A cena gerada excede o tempo de duração do próprio fluxo."

msgid "Missing element '%s' - check your GStreamer installation."
msgstr ""
"Falta o componente \"%s\" — Por favor, verifique sua instalação do "
"GStreamer."

msgid "File location is set to NULL, please set it to a valid filename"
msgstr ""
"O local do arquivo é nulo (NULL), por favor, defina um nome de arquivo "
"válido."

msgid "Digitalzoom element couldn't be created"
msgstr "não foi possível criar o componente Digitalzoom"

msgid "Subpicture format was not configured before data flow"
msgstr "O formato de sub-tela não foi configurado antes do fluxo de dados."

msgid "Failed to get fragment URL."
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Couldn't download fragments"
msgstr "não foi possível baixar o fragmento."

msgid "Internal data stream error."
msgstr "Erro interno de fluxo de dados."

msgid "Device \"%s\" does not exist."
msgstr "Não existe o dispositivo \"%s\"."

msgid "Could not open frontend device \"%s\"."
msgstr "Não foi possível abrir o dispositivo de interface frontal \"%s\"."

msgid "Could not get settings from frontend device \"%s\"."
msgstr "Não foi possível obter o estado (stat) do dispositivo frontal \"%s\"."

msgid "Cannot enumerate delivery systems from frontend device \"%s\"."
msgstr ""
"Não é possível enumerar os sistemas de transmissão do dispositivo frontal "
"\"%s\"."

msgid "Could not open file \"%s\" for reading."
msgstr "não foi possível abrir o arquivo %s em modo de leitura."

msgid "Couldn't find channel configuration file"
msgstr "não foi possível encontrar o arquivo de configuração do canal"

msgid "Couldn't load channel configuration file: '%s'"
msgstr "Não foi possível carregar o arquivo de configuração do canal %s\n"

msgid "Couldn't find details for channel '%s'"
msgstr "não foi possível obter informações detalhadas sobre o canal \"%s\""

msgid "No properties for channel '%s'"
msgstr "o canal “%s” não possui atributos"

msgid "Failed to set properties for channel '%s'"
msgstr "não foi possível configurar o atributo do canal \"%s\"."

msgid "Couldn't find channel configuration file: '%s'"
msgstr "Não foi possível encontrar o arquivo de configuração do canal \"%s\"."

msgid "Channel configuration file doesn't contain any channels"
msgstr ""
"No ficheiro de configuração contém nenhum canal (ou seja, não há canais "
"definidos)"
