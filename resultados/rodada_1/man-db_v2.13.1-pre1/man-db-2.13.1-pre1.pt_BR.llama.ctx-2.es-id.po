msgstr "CHEMIN"

msgid "set search path for manual pages to PATH"
msgstr "estabeleça o caminho de pesquisa para as páginas do manual a CHEMIN"

msgid "FILE"
msgstr "FICHERO"

msgid "use this user configuration file"
msgstr "utilize este fichero de configuração do usuário"

