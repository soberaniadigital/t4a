msgid "warning: %s: ignoring bogus filename"
msgstr "atenção: %s: nome de arquivo inválido, ignorado"

msgid "can't determine current directory"
msgstr "não foi possível determinar qual é o diretório atual"

msgid "can't set effective uid"
msgstr "não é possível posicionar o proprietário (UID) efetivo"

msgid "the setuid man user \"%s\" does not exist"
msgstr "o utilizador com privilégio setuid \"%s\" não existe"

msgid "fatal: regex `%s': %s"
msgstr "erreur fatale : expression rationnelle « %s » : %s"

msgid "multi key %s does not exist"
msgstr "A chave múltipla %s não existe"

msgid "can't lock index cache %s"
msgstr "não foi possível verificar o bloqueio do cache de índice %s"

msgid "index cache %s corrupt"
msgstr "o cache de índice %s está danificado"

msgid "cannot replace key %s"
msgstr "não é possível substituir a chave %s"

msgid "bad fetch on multi key %s"
msgstr "acesso inválido para chave múltipla %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"A base de dados %s está corrompida; reconstrua-lá com 'mandb --create'."

msgid "warning: %s has no version identifier\n"
msgstr "cão báfio: %s não possui identificador de versão"

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cão báfio: %s é a versão %s, em vez de %s\n"

msgid "fatal: unable to insert version identifier into %s"
msgstr "erro fatal : impossível inserir o identificador de versão no campo %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỀU LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão possui o valor mínimo %s%s."

msgid "emit debugging messages"
msgstr "exibição de mensagens para depuração"

msgid "can't open %s for reading"
msgstr "não é possível abrir %s em leitura"

msgid "[SECTION...]"
msgstr "[SEÇÃO...]"

msgid "PATH"
msgstr "CHEMIN_DANTE"

msgid "set search path for manual pages to PATH"
msgstr "configurar o caminho de pesquisa para as páginas do manual a CHEMIN"

msgid "FILE"
msgstr "FICHIER"

msgid "use this user configuration file"
msgstr "utilize este arquivo de configuração do usuário"

msgid "man command failed with exit status %d"
msgstr "a commande 'man' falhou com %d como código de retorno"

msgid "NULL content for key: %s"
msgstr "conteúdo vazio (NULL) para a chave : %s"

msgid ""
"\n"
"Updating cat files for section %s of man hierarchy %s\n"
msgstr ""
"Mudança em andamento dos arquivos préformados para a seção %s da "
"documentação do software %s."

msgid "cannot write within %s"
msgstr "não é possível escrever dentro de %s"

msgid "cannot read database %s"
msgstr "não é possível ler a base de dados %s"

msgid "unable to update %s"
msgstr "não é possível atualizar %s"

msgid "warning: %s/man%s/%s.%s*: competing extensions"
msgstr "cão báfio: %s/man%s/%s.%s*: extensões em conflito"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de index %s"

msgid "warning: %s: bad symlink or ROFF `.so' request"
msgstr ""
"cão de guarda: %s: símbolo em rede mau formado, ou diretiva ROFF para '.so' "
"inválida"

msgid "warning: %s: ignoring empty file"
msgstr "cão báfio: %s: arquivo vazio ignorado"

msgid "warning: %s: whatis parse for %s(%s) failed"
msgstr ""
"coração báfar: %s: falha na análise de o que é (o que é?) no site "
"http://whatis.info/%s(%s)"

msgid "can't search directory %s"
msgstr "não é possível procurar no diretório %s"

msgid "can't chown %s"
msgstr "não é possível alterar o proprietário de %s"

msgid "warning: cannot create catdir %s"
msgstr "cãonhoto: não é possível criar o diretório de páginas préformatas %s"

msgid "can't chmod %s"
msgstr "não é possível alterar os direitos de %s"

msgid "can't change to directory %s"
msgstr "não é possível ir para o diretório %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de índice %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr "Atualização do cache de índice para o caminho «%s/%s». Aguarde…"

msgid "done.\n"
msgstr "concluído."

msgid "Purging old database entries in %s...\n"
msgstr "Efetuação da remoção de entradas desnecessárias em %s…"

msgid "warning: failed to store entry for %s(%s)"
msgstr "cãonh báo: gặp lỗi khi lưu trữ mục tin cho '%s(%s)'"

msgid "PATH SECTION NAME"
msgstr "Caminho do Section Nome"

msgid "EXTENSION"
msgstr "EXTENSION"

msgid "limit search to extension type EXTENSION"
msgstr "limite a pesquisa apenas à extensões EXTENSION"

msgid "look for pages case-insensitively (default)"
msgstr "pesquisar as páginas sem distinguir maiúsculas e minúsculas (padrão)"

msgid "look for pages case-sensitively"
msgstr ""
"realce as diferenças de maiúsculas e minúsculas para localizar páginas"

msgid "interpret page name as a regex"
msgstr "considere o nome da página como uma expressão regular"

msgid "the page name contains wildcards"
msgstr "o nome da página contém caracteres de jogo"

msgid "can't open %s"
msgstr "não é possível abrir %s"

msgid "FILE..."
msgstr "Ficheiro ..."

msgid "The defaults are --man and --whatis."
msgstr "As opções padrão são --man e --whatis."

msgid "parse as man page"
msgstr "realiza o perfil dos arquivos como páginas de manual"

msgid "parse as cat page"
msgstr "lê os arquivos como páginas preformatadas"

msgid "show whatis information"
msgstr "exibir informações como whatis (como o VI e DE)"

msgid "show guessed series of preprocessing filters"
msgstr "exibir a lista suposta dos filtros de pré-processamento aplicados"

msgid "ENCODING"
msgstr "ENCODAGE"

msgid "use selected output encoding"
msgstr "utilize o código de exibição escolhido"

msgid "%s: incompatible options"
msgstr "%s: opções incompatíveis"

msgid "command exited with status %d: %s"
msgstr "comando concluído com %d como código de retorno : %s"

msgid "[SECTION] PAGE..."
msgstr ""
"[SEÇÃO] Página [PHÂN] TRANG...\n"
"[ABSCHNITT] SEITE ...\n"

msgid "reset all options to their default values"
msgstr "reinicializa as opções para seus valores padrão"

msgid "WARNINGS"
msgstr "AVISO_AVERIGENDO"

msgid "enable warnings from groff"
msgstr "ativar avisos de groff"

msgid "Main modes of operation:"
msgstr "Modos operacionais principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "equivalent to apropos"
msgstr "equivalente a aproximadamente"

msgid "search for text in all pages"
msgstr "recherche le texte dans toutes les pages"

msgid "print physical location of man page(s)"
msgstr "exibir o local das páginas do manual"

msgid "print physical location of cat file(s)"
msgstr "exibir o local dos arquivos cat"

msgid "interpret PAGE argument(s) as local filename(s)"
msgstr "interprete o argumento PAGE como um nome de arquivo"

msgid "used by catman to reformat out of date cat pages"
msgstr "utilizado por Catman para reformatar as páginas muito antigas."

msgid "output source page encoded in ENCODING"
msgstr "affiche le code source converti en ENCODAGE"

msgid "Finding manual pages:"
msgstr "Recherche des pages de manuel:"

msgid "LOCALE"
msgstr "LOCALE"

msgid "define the locale for this particular man search"
msgstr "definir a localidade para esta pesquisa de manual específico"

msgid "SYSTEM"
msgstr "Sistema"

msgid "use manual pages from other systems"
msgstr "utilize as páginas de manual de outros sistemas"

msgid "LIST"
msgstr "LISTA"

msgid "use colon separated section list"
msgstr "utilize a lista de seções separadas por dois pontos."

msgid "show all pages matching regex"
msgstr "montre todas as páginas correspondentes à expressão regular"

msgid "show all pages matching wildcard"
msgstr "montre todas as páginas correspondentes ao caractere joker"

msgid "make --regex and --wildcard match page names only, not descriptions"
msgstr ""
"correspondem apenas aos nomes de páginas com --regex e --wildcard, não às "
"descrições."

msgid "find all matching manual pages"
msgstr "encontra todas as páginas correspondentes"

msgid "force a cache consistency check"
msgstr "forçar uma verificação de consistência do cache"

msgid "don't try subpages, e.g. 'man foo bar' => 'man foo-bar'"
msgstr ""
"não prenda em conta as subcomandos, por exemplo 'man truc bidule' => 'man "
"truc-bidule'"

msgid "Controlling formatted output:"
msgstr "Controle do formato de exibição:"

msgid "PAGER"
msgstr "AFFICHEUR"

msgid "use program PAGER to display output"
msgstr "utilize do programa AFFICHEUR para o exibição da saída."

msgid "STRING"
msgstr "Caminho"

msgid "provide the `less' pager with a prompt"
msgstr "cumpra uma sequência de entrada para o programa 'less'"

msgid "display ASCII translation of certain latin1 chars"
msgstr "exibir equivalente ASCII de alguns caracteres latim1"

msgid "turn off hyphenation"
msgstr "tela desligada para evitar a interrupção de chamadas em sequência."

msgid "turn off justification"
msgstr "tampa o alinhamento da linha de texto."

msgid ""
"STRING indicates which preprocessors to run:\n"
"e - [n]eqn, p - pic, t - tbl,\n"
"g - grap, r - refer, v - vgrind"
msgstr ""
"CENA indique os préprocessadores a utilizar : e - [n]eqn, p - pic, t - tbl, "
"g - grap, r - refer, v - vgrind"

msgid "use %s to format pages"
msgstr "utilize %s para formatar as páginas."

msgid "DEVICE"
msgstr "PÉRIPHÉRIQUE"

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "BROWSER"
msgstr "Navegador"

msgid "use %s or BROWSER to display HTML output"
msgstr "utilize %s ou NAVIGATOR para o exibição HTML"

msgid "RESOLUTION"
msgstr "RESOLUÇÃO"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba com gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e forçá-lo a produzir ditroff."

msgid "No manual entry for %s\n"
msgstr "Não há entrada manual para %s"

msgid "(Alternatively, what manual page do you want from section %s?)\n"
msgstr "(Sinon, quelle page de manuel de la section %s voulez-vous ?)"

msgid "What manual page do you want?\n"
msgstr "Qual é a página de manual que você deseja ver?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há entrada manual para %s na seção %s."

msgid "See '%s' for help when manual pages are not available.\n"
msgstr ""
"Tente ver \"%s\" para obter ajuda quando as páginas de manuel não estão "
"disponíveis."

msgid "ignoring unknown preprocessor `%c'"
msgstr "O pré-processador \"%c\" é desconhecido e ignorado."

msgid "can't rename %s to %s"
msgstr "não é possível renomear %s em %s"

msgid "can't set times on %s"
msgstr "não é possível alterar a data de %s"

msgid "can't unlink %s"
msgstr "não é possível remover %s"

msgid "can't create temporary cat for %s"
msgstr "não é possível criar uma página temporária chamada 'cat' para %s"

msgid "can't create temporary directory"
msgstr "não foi possível criar o diretório temporário"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s"

msgid "can't remove directory %s"
msgstr "não é possível excluir o diretório %s"

msgid "--Man-- next: %s [ view (return) | skip (Ctrl-D) | quit (Ctrl-C) ]\n"
msgstr ""
"--Man-- próximo: %s [ visualizar (Enter) | pular para a seguinte linha "
"(Ctrl+D) | sair (Ctrl+C) ]\n"

msgid ""
"\n"
"cannot write to %s in catman mode"
msgstr "não é possível escrever para %s no modo catman"

msgid "Can't convert %s to cat name"
msgstr "Não é possível converter %s em nome de página préformatada"

msgid "%s: relying on whatis refs is deprecated\n"
msgstr ""
"%s: não é recomendado confiar em referências do comando 'whatis' devido a "
"possíveis incompatibilidades e obsoletude."

msgid "mandb command failed with exit status %d"
msgstr "a commande 'mandb' falhou com o código de retorno %d."

msgid "internal error: candidate type %d out of range"
msgstr "erro interno : o tipo candidato %d está fora do alcance"

msgid " Manual page "
msgstr "Página de manual"

msgid "CODE"
msgstr "codificação"

msgid "encoding for output"
msgstr "codificação de exibição"

msgid "produce fewer warnings"
msgstr "tire menos avisos"

msgid "must specify an output encoding"
msgstr "a codificação de saída deve ser especificada"

msgid "can't remove %s"
msgstr "não é possível excluir %s"

msgid "can't write to standard output"
msgstr "não é possível escrever para a saída padrão"

msgid "iconv: incomplete character at end of buffer"
msgstr "iconv: caractere incompleto no final do buffer"

msgid "[-f CODE[:...]] -t CODE [FILENAME]"
msgstr "-f CODE -t CODE [NOM_DE_FICHIER]"

msgid "CODE[:...]"
msgstr "CODIFICAR[:...]"

msgid "possible encodings of original text"
msgstr "codificações possíveis do texto original"

msgid "[MANPATH]"
msgstr "[MANPATH]"

msgid "work quietly, except for 'bogus' warning"
msgstr "não exibe nada além de avisos de dysfonctionnement"

msgid "don't look for or add stray cats to the dbs"
msgstr ""
"não deve procurar nem adicionar arquivos cat parasitários na base de dados."

msgid "don't purge obsolete entries from the dbs"
msgstr "Não remova as entradas obsoletas da base de dados."

msgid "produce user databases only"
msgstr "produz apenas as bases de dados do usuário"

msgid "create dbs from scratch, rather than updating"
msgstr ""
"tome o cuidado para não criar bases novas no início, mas sim atualizar as "
"existentes."

msgid "check manual pages for correctness"
msgstr "verificar a validade das páginas de manual do sistema"

msgid "FILENAME"
msgstr "NOM_DE_FICHIER"

msgid "update just the entry for this filename"
msgstr "chamou apenas a entrada correspondente ao este nome de fichê"

msgid "can't write to %s"
msgstr "não é possível escrever no %s"

msgid "can't read from %s"
msgstr "não é possível ler a partir de %s"

msgid "Processing manual pages under %s...\n"
msgstr "Tratamento das páginas do manual sob %s…"

msgid "Removing obsolete cat directory %s...\n"
msgstr "Supressão do diretório « cat » obsoleto %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"atenção: não há diretiva MANDB_MAP no arquivo %s, seu caminho de maneira "
"manual é utilizado."

msgid "No databases created."
msgstr "Nenhuma base de dados foi criada."

msgid "can't make sense of the manpath configuration file %s"
msgstr "O arquivo de configuração do caminho `manpath %s` é estranho."

msgid "warning: %s"
msgstr "coração bater mais rápido do que o normal, consulte seu médico."

msgid "warning: %s isn't a directory"
msgstr "coração báfaro: %s não é um diretório"

msgid "warning: $PATH not set"
msgstr "coração báfaro: a variável $PATH não está posicionada"

msgid "warning: empty $PATH"
msgstr "atenção: a variável $PATH está vazia"

msgid "warning: $MANPATH set, prepending %s"
msgstr ""
"coração báfaro: o têmporo $MANPATH está posicionado, ele é precedido por %s"

msgid "warning: $MANPATH set, appending %s"
msgstr ""
"coração báfaro: a variável $MANPATH está posicionada e é seguida por %s"

msgid "warning: $MANPATH set, inserting %s"
msgstr "cão báfio: tâng tuệ $MANPATH (đường dẫn hướng dẫn), chèn %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "coração báfaro: o teto $MANPATH está posicionado, %s é ignorado."

msgid "can't parse directory list `%s'"
msgstr "não foi possível parcourir a lista de diretório \"%s\""

msgid "can't open the manpath configuration file %s"
msgstr "não é possível abrir o arquivo de configuração do manpath %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cão báfio: o diretório requerido %s não existe"

msgid "warning: %s does not begin with %s"
msgstr "cão bágua: %s não começa com %s"

msgid "show relative catpaths"
msgstr "exibir os caminhos de acesso relativos às páginas 'cat'"

msgid "show the entire global manpath"
msgstr "exibir os caminhos completos de páginas do manual (manpath)"

msgid "warning: no global manpaths set in config file %s"
msgstr ""
"atenção: nenhum caminho de páginas do manual definido no arquivo de "
"configuração %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Estamos procurando arquivos préformatados sem fontes sob %s…"

msgid "warning: %s is a dangling symlink"
msgstr "atenção: '%s' é um link simbólico flutuante"

msgid "can't resolve %s"
msgstr "não é possível resolver %s"

msgid "%s is self referencing"
msgstr "%s s'auto-référence"

msgid "KEYWORD..."
msgstr "MOT-CLEF... (continuação da tradução para o português brasileiro)"

msgid "The --regex option is enabled by default."
msgstr "A opção --regex está habilitada por padrão."

msgid "print verbose warning messages"
msgstr "affiche des messages d'avertissement étendus"

msgid "interpret each keyword as a regex"
msgstr "interpretar cada palavra-chave como uma expressão regular"

msgid "search each keyword for exact match"
msgstr "buscar correspondência exata para cada palavra chave"

msgid "the keyword(s) contain wildcards"
msgstr "As palavras-chave contêm jokers (substituições)"

msgid "require all keywords to match"
msgstr "todos os palavrões devem corresponder"

msgid "do not trim output to terminal width"
msgstr "não reduz a exibição à largura do terminal"

msgid "search only these sections (colon-separated)"
msgstr "recherche limitée à ces sections (séparées par des deux-points)"

msgid "define the locale for this search"
msgstr "definir a localidade para esta pesquisa"

msgid "%s what?\n"
msgstr "%s comentar?\n"

msgid "warning: %s contains a pointer loop"
msgstr "cão báfio: %s contém uma referência circular"

msgid "(unknown subject)"
msgstr "(saber não temos)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: nenhum ajuste adequado encontrado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: requetes .so imbriquées trop profondément ou récursivement"

msgid "%s:%d: warning: failed .so request"
msgstr "%s:%d: atenção: requisição para arquivo .so falhou"

msgid "%s:%d: warning: newline in .so request, ignoring"
msgstr "%s:%d: aviso: volta à linha em uma requisição .so, ignorada"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: volta à linha em uma requisição '.lf', ignorada"

msgid "%s:%d: unterminated quote in roff request"
msgstr "%s:%d: yêu cầu roff chứa đoạn trích dẫn chưa được chấm dứt."

msgid "compatibility switch (ignored)"
msgstr "mudança de compatibilidade (ignorada)"
