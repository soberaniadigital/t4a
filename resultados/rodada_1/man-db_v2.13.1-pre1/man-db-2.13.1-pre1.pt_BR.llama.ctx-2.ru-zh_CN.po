msgid "warning: %s: ignoring bogus filename"
msgstr "atenção: '%s': nome de arquivo inválido, ignorado"

msgid "can't determine current directory"
msgstr "não foi possível determinar qual é o diretório atual"

msgid "can't set effective uid"
msgstr ""
"não foi possível posicionar o proprietário efetivo (UID) baseado no seu "
"estado atual."

msgid "the setuid man user \"%s\" does not exist"
msgstr "o utilizador com privilégio setuid \"%s\" não existe"

msgid "fatal: regex `%s': %s"
msgstr "erro fatal: expressão racional '\\%s': %s"

msgid "multi key %s does not exist"
msgstr "a chave múltipla %s não existe"

msgid "can't lock index cache %s"
msgstr "não foi possível verificar o cache de índice %s"

msgid "index cache %s corrupt"
msgstr "o cache de índice %s está danificado"

msgid "cannot replace key %s"
msgstr "não foi possível substituir a chave %s"

msgid "bad fetch on multi key %s"
msgstr "acesso inválido para chave múltipla %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr "A base de dados %s está corrompida, reconstrua-lá com mandb --create."

msgid "warning: %s has no version identifier\n"
msgstr "Pré-aviso: %s não possui identificador de versão"

msgid "warning: %s is version %s, expecting %s\n"
msgstr "préstige: %s tem versão %s ao invés de %s"

msgid "fatal: unable to insert version identifier into %s"
msgstr "erro fatal: impossível inserir o identificador de versão no campo %s"

msgid "[MAN DATABASE]"
msgstr "[BASE DE DONNÉES DE MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão é %s%s."

msgid "emit debugging messages"
msgstr "exibição de mensagens de depuração"

msgid "can't open %s for reading"
msgstr "não foi possível abrir %s em leitura"

msgid "[SECTION...]"
msgstr "[SEÇÃO...]"

msgid "PATH"
msgstr "CHEMIN"

msgid "set search path for manual pages to PATH"
msgstr "configurar o caminho de pesquisa das páginas do manual para CHEMIN"

msgid "FILE"
msgstr "Arquivo"

msgid "use this user configuration file"
msgstr "utilize este arquivo de configuração do usuário."

msgid "man command failed with exit status %d"
msgstr "a commande man falhou com %d como código de retorno"

msgid "NULL content for key: %s"
msgstr "contenuto vazio (NULL) para a chave : %s"

msgid ""
"\n"
"Updating cat files for section %s of man hierarchy %s\n"
msgstr ""
"Atualização dos arquivos préformatados para a seção %s da documentação do "
"sistema operacional"

msgid "cannot write within %s"
msgstr "não foi possível escrever no %s"

msgid "cannot read database %s"
msgstr "não foi possível obter estado (stat) da base de dados %s"

msgid "unable to update %s"
msgstr "não foi possível atualizar %s"

msgid "warning: %s/man%s/%s.%s*: competing extensions"
msgstr "prévenção: %s/man%s/%s.%s*: extensões conflitantes"

msgid "can't update index cache %s"
msgstr "não foi possível atualizar o cache de indexação %s"

msgid "warning: %s: bad symlink or ROFF `.so' request"
msgstr ""
"atenção: '%s': símbolo de ligação simbólica ou diretiva ROFF ‘.so’ incorreto"

msgid "warning: %s: ignoring empty file"
msgstr "atenção: %s: arquivo vazio ignorado"

msgid "warning: %s: whatis parse for %s(%s) failed"
msgstr "atenção: %s: análise do whatis no diretório %s(%s) falhou"

msgid "can't search directory %s"
msgstr "não foi possível encontrar o diretório %s"

msgid "can't chown %s"
msgstr "não foi possível alterar o proprietário do arquivo %s"

msgid "warning: cannot create catdir %s"
msgstr ""
"préstape para impressão: não foi possível criar o diretório de páginas "
"préformatas %s"

msgid "can't chmod %s"
msgstr "não foi possível alterar os direitos de %s"

msgid "can't change to directory %s"
msgstr "não foi possível ir para o diretório %s"

msgid "can't create index cache %s"
msgstr "não foi possível criar o cache de índice %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr "Atualização do cache de indexação para o caminho `%s/%s'. Aguarde…"

msgid "done.\n"
msgstr "terminado."

msgid "Purging old database entries in %s...\n"
msgstr "Efetuação da remoção de entradas desnecessárias na base %s...\n"

msgid "warning: failed to store entry for %s(%s)"
msgstr "préstige: não é possível armazenar a entrada para %s(%s)"

msgid "PATH SECTION NAME"
msgstr "Caminho da Seção Nome"

msgid "EXTENSION"
msgstr "EXTENSION"

msgid "limit search to extension type EXTENSION"
msgstr "limite a pesquisa apenas nas extensões EXTENSION"

msgid "look for pages case-insensitively (default)"
msgstr ""
"pesquisar as páginas sem distinguir maiúsculas das minúsculas (padrão)"

msgid "look for pages case-sensitively"
msgstr "considerar maiúsculas e minúsculas ao pesquisar as páginas do manual"

msgid "interpret page name as a regex"
msgstr "considere o nome da página como uma expressão regular"

msgid "the page name contains wildcards"
msgstr "o nome da página contém caracteres de jogo"

msgid "can't open %s"
msgstr "não foi possível abrir %s"

msgid "FILE..."
msgstr "FICHIER..."

msgid "The defaults are --man and --whatis."
msgstr "Por padrão, são utilizadas as opções --man e --whatis."

msgid "parse as man page"
msgstr "lê os arquivos como páginas de manual"

msgid "parse as cat page"
msgstr "lê os arquivos como páginas formatadas prévias"

msgid "show whatis information"
msgstr "exibir informações como whatis"

msgid "show guessed series of preprocessing filters"
msgstr "exibir a lista suposta de filtros de pré-processamento"

msgid "ENCODING"
msgstr "ENCODAGE"

msgid "use selected output encoding"
msgstr "utilize a codificação de exibição escolhida"

msgid "%s: incompatible options"
msgstr "%s: opções incompatíveis"

msgid "command exited with status %d: %s"
msgstr "comando concluído com código de saída %d: %s"

msgid "[SECTION] PAGE..."
msgstr "[СЕКЦИЯ] ПЕРША СТРАНИЦА..."

msgid "reset all options to their default values"
msgstr "reinicializa as configurações padrão das opções"

msgid "WARNINGS"
msgstr "AVISO(s)"

msgid "enable warnings from groff"
msgstr "ativar alertas de groff"

msgid "Main modes of operation:"
msgstr "Modos operacionais principais:"

msgid "equivalent to whatis"
msgstr "equivalente ao whatis"

msgid "equivalent to apropos"
msgstr "equivalente a aproximadamente igual ao apropos"

msgid "search for text in all pages"
msgstr "busque o texto em todas as páginas"

msgid "print physical location of man page(s)"
msgstr "exibir o local das páginas do manual"

msgid "print physical location of cat file(s)"
msgstr "exibir o local físico dos arquivos cat"

msgid "interpret PAGE argument(s) as local filename(s)"
msgstr "interpretar o argumento PAGE como um nome de arquivo"

msgid "used by catman to reformat out of date cat pages"
msgstr "utilizado por catman para reformatar as páginas muito antigas."

msgid "output source page encoded in ENCODING"
msgstr "exibir o código fonte convertido em ENCODAGE"

msgid "Finding manual pages:"
msgstr "Pesquisa de páginas do manual:"

msgid "LOCALE"
msgstr "LOCALE"

msgid "define the locale for this particular man search"
msgstr "defina a localização para esta pesquisa de manual"

msgid "SYSTEM"
msgstr "Sistema"

msgid "use manual pages from other systems"
msgstr "utilize as páginas de manual de outros sistemas"

msgid "LIST"
msgstr "LISTA"

msgid "use colon separated section list"
msgstr "utilize a lista de seções separadas por dois pontos"

msgid "show all pages matching regex"
msgstr "mostra todas as páginas correspondentes à expressão regular"

msgid "show all pages matching wildcard"
msgstr "mostra todas as páginas correspondentes ao caractere joker"

msgid "make --regex and --wildcard match page names only, not descriptions"
msgstr ""
"correspondem apenas aos nomes de páginas com --regex e --wildcard, não às "
"descrições."

msgid "find all matching manual pages"
msgstr "encontra todas as páginas correspondentes"

msgid "force a cache consistency check"
msgstr "forçar uma verificação de consistência do cache"

msgid "don't try subpages, e.g. 'man foo bar' => 'man foo-bar'"
msgstr ""
"não se preocupar com as subcomandos, por exemplo, 'man foo bar' => 'man foo-"
"bar'"

msgid "Controlling formatted output:"
msgstr "Controle do formato de exibição:"

msgid "PAGER"
msgstr "AFFICHEUR"

msgid "use program PAGER to display output"
msgstr "utilize do programa AFFICHEUR para o exibição"

msgid "STRING"
msgstr "cadeia"

msgid "provide the `less' pager with a prompt"
msgstr "use o paginador `less' com a dica 'menos'"

msgid "display ASCII translation of certain latin1 chars"
msgstr "exibir equivalente ASCII de certos caracteres latim1"

msgid "turn off hyphenation"
msgstr "desligue a césura"

msgid "turn off justification"
msgstr "desabilitar a justificação"

msgid ""
"STRING indicates which preprocessors to run:\n"
"e - [n]eqn, p - pic, t - tbl,\n"
"g - grap, r - refer, v - vgrind"
msgstr ""
"Cadeia indica os pré-processadores a utilizar : e - [n]eqn, p - pic, t - "
"tbl, g - gráfico, r - referência, v - vgrind"

msgid "use %s to format pages"
msgstr "utilize o comando %s para formatar as páginas."

msgid "DEVICE"
msgstr "Périfré"

msgid "use %s with selected device"
msgstr "utilize o %s com o dispositivo selecionado"

msgid "BROWSER"
msgstr "Navegador"

msgid "use %s or BROWSER to display HTML output"
msgstr "utilize %s ou NAVIGATOR para exibir HTML."

msgid "RESOLUTION"
msgstr "RESOLUÇÃO"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize groff e exiba com gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e forçar para que ele produza ditroff."

msgid "No manual entry for %s\n"
msgstr "Não há manual para %s"

msgid "(Alternatively, what manual page do you want from section %s?)\n"
msgstr ""
"(Sinon, qual é a página de manual específica da seção %s que você precisa?)"

msgid "What manual page do you want?\n"
msgstr "Qual é a página de ajuda que você deseja visualizar?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há nenhuma página de manual para %s na seção %s."

msgid "See '%s' for help when manual pages are not available.\n"
msgstr ""
"Para obter ajuda quando as páginas do manual não estão disponíveis, consulte"
" ' %s ' na seção de auxilio."

msgid "ignoring unknown preprocessor `%c'"
msgstr "o préprocesseur `%c' é desconhecido e ignorado."

msgid "can't rename %s to %s"
msgstr "não foi possível renomear %s em %s"

msgid "can't set times on %s"
msgstr "não foi possível alterar a data de %s"

msgid "can't unlink %s"
msgstr "não foi possível remover (excluir) %s"

msgid "can't create temporary cat for %s"
msgstr "não foi possível criar uma página temporária cat para %s"

msgid "can't create temporary directory"
msgstr "não foi possível criar o diretório temporário"

msgid "can't open temporary file %s"
msgstr "não foi possível abrir o arquivo temporário %s"

msgid "can't remove directory %s"
msgstr "não foi possível excluir o diretório %s"

msgid "--Man-- next: %s [ view (return) | skip (Ctrl-D) | quit (Ctrl-C) ]\n"
msgstr ""
"--Man-- proximo: %s [ consulte (entrada) | avance (Ctrl-D) | sair (Ctrl-C) "
"]\n"

msgid ""
"\n"
"cannot write to %s in catman mode"
msgstr "não foi possível escrever no %s em modo catman"

msgid "Can't convert %s to cat name"
msgstr "Não foi possível converter %s em nome de página préformata"

msgid "%s: relying on whatis refs is deprecated\n"
msgstr ""
"%s : não é recomendável se basear nas referências do whatis atualizado"

msgid "mandb command failed with exit status %d"
msgstr "Comando `mandb` falhou com o código de retorno %d."

msgid "internal error: candidate type %d out of range"
msgstr "erro interno : o tipo candidato %d é fora de alcance"

msgid " Manual page "
msgstr "Página de manual"

msgid "CODE"
msgstr "Código"

msgid "encoding for output"
msgstr "codificação de saída"

msgid "produce fewer warnings"
msgstr "crie menos avisões"

msgid "must specify an output encoding"
msgstr "a codificação de saída deve ser especificada."

msgid "can't remove %s"
msgstr "não foi possível remover %s"

msgid "can't write to standard output"
msgstr "não foi possível escrever para o fluxo de saída padrão"

msgid "iconv: incomplete character at end of buffer"
msgstr "iconv: caractere incompleto em final de tampon"

msgid "[-f CODE[:...]] -t CODE [FILENAME]"
msgstr "['[-f %s[:...]] -t %s [%s]']"

msgid "CODE[:...]"
msgstr "Código[:...]"

msgid "possible encodings of original text"
msgstr "codificações possíveis do texto original"

msgid "[MANPATH]"
msgstr "[MANPATH]"

msgid "work quietly, except for 'bogus' warning"
msgstr "não exibir mensagens, além dos avisos de falha do sistema"

msgid "don't look for or add stray cats to the dbs"
msgstr ""
"não deve procurar nem adicionar arquivos cat parasitários na base de dados."

msgid "don't purge obsolete entries from the dbs"
msgstr "Não remova as entradas desatualizadas da base de dados."

msgid "produce user databases only"
msgstr "só criar bases de usuários"

msgid "create dbs from scratch, rather than updating"
msgstr "crée les bases du début plutôt qu'une mise à jour"

msgid "check manual pages for correctness"
msgstr "verificar a validade das páginas de manual do sistema"

msgid "FILENAME"
msgstr "NOM_DE_FICHIER"

msgid "update just the entry for this filename"
msgstr "atualize apenas a entrada correspondente ao este nome de arquivo"

msgid "can't write to %s"
msgstr "não foi possível escrever no %s"

msgid "can't read from %s"
msgstr "não foi possível ler a partir de %s"

msgid "Processing manual pages under %s...\n"
msgstr "Tratamento das páginas do manual em %s...\n"

msgid "Removing obsolete cat directory %s...\n"
msgstr "Supressão do diretório cat obsoleto %s...\n"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"atenção: não há diretiva MANDB_MAP no %s, seu caminho do manual é utilizado"

msgid "No databases created."
msgstr "Nenhuma base de dados foi criada."

msgid "can't make sense of the manpath configuration file %s"
msgstr "o arquivo de configuração do manpath %s é estranho"

msgid "warning: %s"
msgstr "préstancia: %s"

msgid "warning: %s isn't a directory"
msgstr "préstige: %s não é um diretório"

msgid "warning: $PATH not set"
msgstr "Pré-aviso: a variável $PATH não está configurada"

msgid "warning: empty $PATH"
msgstr "préocupação: a variável $PATH está vazia"

msgid "warning: $MANPATH set, prepending %s"
msgstr "atenção : a variável $MANPATH foi posicionada, ela é precedida por %s"

msgid "warning: $MANPATH set, appending %s"
msgstr ""
"atenção: a variável $MANPATH foi encontrada e será adicionada ao final %s"

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"Pré-aviso : a variável $MANPATH foi encontrada e insere-se no local %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr ""
"atenção: a variável $MANPATH foi encontrada e ignorada, %s é desconsiderado."

msgid "can't parse directory list `%s'"
msgstr "não foi possível parcourir a lista de diretórios `%s'"

msgid "can't open the manpath configuration file %s"
msgstr "não foi possível abrir o arquivo de configuração do manpath %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "atenção: o diretório necessário %s não existe"

msgid "warning: %s does not begin with %s"
msgstr "préstige: %s não começa com %s"

msgid "show relative catpaths"
msgstr "exibir os caminhos de acesso relativos às páginas 'cat'."

msgid "show the entire global manpath"
msgstr ""
"exibir os caminhos completos das páginas de manual do sistema operacional"

msgid "warning: no global manpaths set in config file %s"
msgstr ""
"atenção: não há caminho de páginas do manual definido no arquivo de "
"configuração %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Pesquisa de arquivos préformatados sem fontes sob %s...\n"

msgid "warning: %s is a dangling symlink"
msgstr "Prévisação: %s é um link simbólico flutuante"

msgid "can't resolve %s"
msgstr "não foi possível resolver %s"

msgid "%s is self referencing"
msgstr "%s se auto-referencia"

msgid "KEYWORD..."
msgstr "MOT-CLEF... (continuação da tradução necessária)"

msgid "The --regex option is enabled by default."
msgstr "A opção --regex está habilitada por padrão."

msgid "print verbose warning messages"
msgstr "exibindo mensagens de aviso extensivas"

msgid "interpret each keyword as a regex"
msgstr "interpretar cada palavra-chave como uma expressão regular"

msgid "search each keyword for exact match"
msgstr "buscar uma correspondência exata para cada palavra chave"

msgid "the keyword(s) contain wildcards"
msgstr "As palavras-chave contêm jokers (substitutos)"

msgid "require all keywords to match"
msgstr "todos os termos-chave devem corresponder"

msgid "do not trim output to terminal width"
msgstr "não reduza o tamanho do display para a largura do terminal"

msgid "search only these sections (colon-separated)"
msgstr "pesquisa limitada a essas seções (separadas por dois pontos)"

msgid "define the locale for this search"
msgstr "defina a localização para esta pesquisa"

msgid "%s what?\n"
msgstr "%s o que?\n"

msgid "warning: %s contains a pointer loop"
msgstr "atenção: %s contém uma referência circular"

msgid "(unknown subject)"
msgstr "(objeto desconhecido)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: nada adequado encontrado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: requetes .so imbriquées excessivamente profondément ou récursivement"

msgid "%s:%d: warning: failed .so request"
msgstr "%s:%d: atenção: requisição .so falhou"

msgid "%s:%d: warning: newline in .so request, ignoring"
msgstr "%s:%d: aviso: volta para a linha em uma solicitação .so, ignorada"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: volta à linha em .lf requisição, ignorada"

msgid "%s:%d: unterminated quote in roff request"
msgstr "%s:%d: guilhetes não fechadas em uma requisição roff"

msgid "compatibility switch (ignored)"
msgstr "opção de compatibilidade (ignorada)"
