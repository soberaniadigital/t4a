msgid "Print the GStreamer version"
msgstr "Exibir a versão do GStreamer"

msgid "Make all warnings fatal"
msgstr "Tratamento de todas as advertências como erros"

msgid "Print available debug categories and exit"
msgstr ""
"Apresenta as categorias de diagnóstico de erros disponíveis e termina o "
"programa."

msgid ""
"Default debug level from 1 (only error) to 9 (anything) or 0 for no output"
msgstr ""
"Nível de diagnóstico por defeito, de 1 (erros apenas) a 9 (tudo incluído), "
"ou 0 para nenhuma saída"

msgid "LEVEL"
msgstr "Estagão"

msgid ""
"Comma-separated list of category_name:level pairs to set specific levels for"
" the individual categories. Example: GST_AUTOPLUG:5,GST_ELEMENT_*:3"
msgstr ""
"Lista separada por vírgulas de pares 'Categoria_Name':Nível, para atribuir "
"níveis específicos a cada categoria. Exemplo : "
"GST_AUTOPLUG:5,GST_ELEMENT_*:3"

msgid "LIST"
msgstr "LISTE"

msgid "Disable colored debugging output"
msgstr "Desabilitando a exibição de cores das mensagens de erro do depurador."

msgid ""
"Changes coloring mode of the debug log. Possible modes: off, on, disable, "
"auto, unix"
msgstr ""
"Modificação do modo de cor da ferramenta diagnóstica. Modos disponíveis: "
"off, on, disable (desativado), auto e unix"

msgid "Disable debugging"
msgstr "Desabilita o diagnóstico de erros"

msgid "Colon-separated paths containing plugins"
msgstr "Caminhos com plugins, separados por dois pontos"

msgid "PATHS"
msgstr "CHEMINS"

msgid ""
"Comma-separated list of plugins to preload in addition to the list stored in"
" environment variable GST_PLUGIN_PATH"
msgstr ""
"Lista de plugins separados por vírgulas, que serão carregados além dos "
"presentes na variável d'ambiente GST_PLUGIN_PATH"

msgid "PLUGINS"
msgstr "PLUGINS"

msgid "Disable trapping of segmentation faults during plugin loading"
msgstr ""
"Desabilitado o rastreamento de falhas de acesso ao armazenamento durante o "
"carregamento dos plugins"

msgid "Disable updating the registry"
msgstr "Desabilitar a actualização da Registry."

msgid "Disable spawning a helper process while scanning the registry"
msgstr ""
"Desativa o processo auxiliar ao ler a registro de configuração do sistema."

msgid "GStreamer Options"
msgstr "Opções de GStreamer"

msgid "Show GStreamer Options"
msgstr "Exibir as opções de GStreamer"

msgid "Unknown option"
msgstr "opção desconhecida"

msgid "GStreamer encountered a general core library error."
msgstr "GStreamer detectou um erro geral na biblioteca central."

msgid ""
"GStreamer developers were too lazy to assign an error code to this error."
msgstr ""
"Os desenvolvedores de GStreamer foram considerados preguiçosos, não "
"atribuindo um número para este erro."

msgid "Internal GStreamer error: code not implemented."
msgstr "Erro interno do GStreamer : código não implementado."

msgid ""
"GStreamer error: state change failed and some element failed to post a "
"proper error message with the reason for the failure."
msgstr ""
"Erro GStreamer : falha no estado e alguns elementos não conseguiram enviar "
"uma mensagem de erro correta com a justificativa do problema."

msgid "Internal GStreamer error: pad problem."
msgstr "Erro interno do GStreamer : problema de padding."

msgid "Internal GStreamer error: thread problem."
msgstr "Erro interno do GStreamer : problema de thread."

msgid "GStreamer error: negotiation problem."
msgstr "Erro GStreamer : problema de negociação."

msgid "Internal GStreamer error: event problem."
msgstr "Erro interno do GStreamer : problema de evento."

msgid "Internal GStreamer error: seek problem."
msgstr "Erro interno do GStreamer : problema de pesquisa."

msgid "Internal GStreamer error: caps problem."
msgstr "Erro interno do GStreamer : problema de capacidades."

msgid "Internal GStreamer error: tag problem."
msgstr "Erro interno do GStreamer : problema de marcação."

msgid "Your GStreamer installation is missing a plug-in."
msgstr "Sua instalação de GStreamer fica com falta do plugin."

msgid "GStreamer error: clock problem."
msgstr "Erro GStreamer : problema de relógio."

msgid ""
"This application is trying to use GStreamer functionality that has been "
"disabled."
msgstr ""
"Esta aplicação tenta utilizar uma funcionalidade do GStreamer que foi "
"desabilitada."

msgid "GStreamer encountered a general supporting library error."
msgstr ""
"Erro do GStreamer da Internet: Problema com a biblioteca de suporte. Por "
"favor, envie um relatório de erro."

msgid "Could not initialize supporting library."
msgstr "A biblioteca de suporte não pôde ser inicializada."

msgid "Could not close supporting library."
msgstr "A biblioteca de suporte não pôde ser fechada."

msgid "Could not configure supporting library."
msgstr "A biblioteca de suporte não pôde ser configurada."

msgid "Encoding error."
msgstr "Erro de codificação."

msgid "GStreamer encountered a general resource error."
msgstr "GStreamer detectou um erro geral de recurso."

msgid "Resource not found."
msgstr "Recursos não encontrados."

msgid "Resource busy or not available."
msgstr "Recurso em uso ou não disponível."

msgid "Could not open resource for reading."
msgstr "Não foi possível abrir a recurso para leitura."

msgid "Could not open resource for writing."
msgstr "Não foi possível abrir a recurso para escrita."

msgid "Could not open resource for reading and writing."
msgstr "Não foi possível abrir a recurso para leitura e escrita."

msgid "Could not close resource."
msgstr "Não foi possível fechar a recurso."

msgid "Could not read from resource."
msgstr "não foi possível ler da fonte de dados."

msgid "Could not write to resource."
msgstr "não foi possível escrever na recurso."

msgid "Could not perform seek on resource."
msgstr "Não foi possível executar o pesquisador na recurso."

msgid "Could not synchronize on resource."
msgstr "Não foi possível sincronizar a recurso."

msgid "Could not get/set settings from/on resource."
msgstr "Os ajustes não podem ser lidos ou gravados na fonte."

msgid "No space left on the resource."
msgstr "Não há espaço livre suficiente na recurso."

msgid "Not authorized to access resource."
msgstr "Permissão negada para acesso à recurso."

msgid "GStreamer encountered a general stream error."
msgstr "GStreamer detectou um erro geral no fluxo de dados."

msgid "Element doesn't implement handling of this stream. Please file a bug."
msgstr ""
"O elemento não consegue processar este fluxo de dados. Por favor, envie um "
"relatório de erro."

msgid "Could not determine type of stream."
msgstr "não foi possível determinar o tipo do fluxo de dados."

msgid "The stream is of a different type than handled by this element."
msgstr "O tipo de fluxo é diferente do processado por este elemento."

msgid "There is no codec present that can handle the stream's type."
msgstr ""
"Não há nenhum codec disponível que possa processar esse tipo de fluxo."

msgid "Could not decode stream."
msgstr "não foi possível decodificar o fluxo de dados."

msgid "Could not encode stream."
msgstr "não foi possível codificar o fluxo de dados."

msgid "Could not demultiplex stream."
msgstr "não foi possível multiplexar o fluxo de dados."

msgid "Could not multiplex stream."
msgstr "não foi possível multiplexar o fluxo de dados."

msgid "The stream is in the wrong format."
msgstr "O fluxo de dados possui o formato errado."

msgid "The stream is encrypted and decryption is not supported."
msgstr ""
"O fluxo de dados está criptografado, mas a descriptografia não é suportada."

msgid ""
"The stream is encrypted and can't be decrypted because no suitable key has "
"been supplied."
msgstr ""
"O fluxo de dados está criptografado e não pode ser descriptografado porque "
"nenhum chave válida foi fornecida."

msgid "No error message for domain %s."
msgstr "Não há mensagem de erro para o domínio %s."

msgid "No standard error message for domain %s and code %d."
msgstr "Não há mensagem de erro padrão para o domínio %s e código de erro %d."

msgid "Selected clock cannot be used in pipeline."
msgstr "O referencial selecionado não pode ser utilizado na linha."

msgid "Error writing registry cache to %s: %s"
msgstr "Erro ao escrever no cache da Registry após %s: %s"

msgid "title"
msgstr "Título"

msgid "commonly used title"
msgstr "Título usual"

msgid "title sortname"
msgstr "Nome para classificação do título"

msgid "commonly used title for sorting purposes"
msgstr "Título utilizado habitualmente para fins de ordenação"

msgid "artist"
msgstr "artista"

msgid "person(s) responsible for the recording"
msgstr "pessoa(s) responsável(a) pela gravação"

msgid "artist sortname"
msgstr "Nome do artista para o sortimento"

msgid "person(s) responsible for the recording for sorting purposes"
msgstr ""
"Para a captura de dados, responsável(s) pela seleção e organização dos "
"mesmos para fins de classificação"

msgid "album"
msgstr "Álbum"

msgid "album containing this data"
msgstr "Album que contém estas informações"

msgid "album sortname"
msgstr "Nome do álbum para o ordenamento"

msgid "album containing this data for sorting purposes"
msgstr "Album que contém esses dados, para fins de ordenação"

msgid "album artist"
msgstr "artista do álbum"

msgid "The artist of the entire album, as it should be displayed"
msgstr "O artista do álbum inteiro, como ele deve ser apresentado"

msgid "album artist sortname"
msgstr "Nome do artista da obra"

msgid "The artist of the entire album, as it should be sorted"
msgstr ""
"O artista do álbum inteiro, como deve ser classificado para o ordenamento"

msgid "date"
msgstr "data"

msgid "date the data was created (as a GDate structure)"
msgstr ""
"Dado de criação, em que as informações foram geradas (como estrutura GDate)"

msgid "datetime"
msgstr "data e hora"

msgid "date and time the data was created (as a GstDateTime structure)"
msgstr ""
"Data e hora em que foram geradas as informações (como uma estrutura "
"GstDateTime)"

msgid "genre"
msgstr "gênero"

msgid "genre this data belongs to"
msgstr "Gênero, ao qual estas dados pertencem"

msgid "comment"
msgstr "Comentário"

msgid "free text commenting the data"
msgstr "um texto livre que descreve os dados"

msgid "extended comment"
msgstr "Comentário ampliado"

msgid "free text commenting the data in key=value or key[en]=comment form"
msgstr ""
"um texto livre que descreve os dados na forma chave=valor ou "
"chave[de]=comentário"

msgid "track number"
msgstr "número de título"

msgid "track number inside a collection"
msgstr "Número de título dentro da coleção"

msgid "track count"
msgstr "número de títulos"

msgid "count of tracks inside collection this track belongs to"
msgstr "Número de títulos na coleção à qual pertence este item"

msgid "disc number"
msgstr "número da placa"

msgid "disc number inside a collection"
msgstr "número da placa dentro do conjunto de coleções"

msgid "disc count"
msgstr "número de discos"

msgid "count of discs inside collection this disc belongs to"
msgstr "Número de discos na coleção à qual pertence esta placa"

msgid "location"
msgstr "localização do objeto 'ort' para o local desejado."

msgid ""
"Origin of media as a URI (location, where the original of the file or stream"
" is hosted)"
msgstr ""
"Origem do meio como URI (local onde o original da fonte de dados ou fluxo "
"está disponível)"

msgid "homepage"
msgstr "página da internet"

msgid "Homepage for this media (i.e. artist or movie homepage)"
msgstr ""
"Página da internet desse meio (por exemplo, página do artista ou de filme)"

msgid "description"
msgstr "Descrição"

msgid "short text describing the content of the data"
msgstr "Uma breve descrição do conteúdo das informações"

msgid "version"
msgstr "versão"

msgid "version of this data"
msgstr "versão destas informações"

msgid "ISRC"
msgstr "ISRC"

msgid "International Standard Recording Code - see http://www.ifpi.org/isrc/"
msgstr "Código Internacional de Gravação - consulte http://www.ifpi.org/isrc/"

msgid "organization"
msgstr "organização"

msgid "copyright"
msgstr "copyright"

msgid "copyright notice of the data"
msgstr "Agradecimento pela cópia de direitos autorais dos dados"

msgid "copyright uri"
msgstr "URI do copyright"

msgid "URI to the copyright notice of the data"
msgstr "URI para a citação de copyright dos dados"

msgid "encoded by"
msgstr "codificado por"

msgid "name of the encoding person or organization"
msgstr "Nome da pessoa ou organização que realizou o codificamento"

msgid "contact"
msgstr "contato"

msgid "contact information"
msgstr "Informações de contato"

msgid "license"
msgstr "Licença"

msgid "license of data"
msgstr "licença dos dados"

msgid "license uri"
msgstr "URI da licença Lizenz-URI"

msgid "URI to the license of the data"
msgstr "URI para a licença dos dados"

msgid "performer"
msgstr "ator"

msgid "person(s) performing"
msgstr "a(s) pessoa(s) que interpreta(m/s)"

msgid "composer"
msgstr "compositor"

msgid "person(s) who composed the recording"
msgstr "A pessoa(s) responsável pela gravação"

msgid "conductor"
msgstr "diretor"

msgid "conductor/performer refinement"
msgstr "Detaillierung Dirigent/Darsteller"

msgid "duration"
msgstr "duração"

msgid "length in GStreamer time units (nanoseconds)"
msgstr "comprimento em unidades de tempo GStreamer (nanosegundos)"

msgid "codec"
msgstr "código"

msgid "codec the data is stored in"
msgstr "formato de dados, no qual as informações são armazenadas"

msgid "video codec"
msgstr "codec de vídeo"

msgid "codec the video data is stored in"
msgstr "formato de dados, no qual as informações do vídeo são armazenadas"

msgid "audio codec"
msgstr "Codificador de áudio"

msgid "codec the audio data is stored in"
msgstr "formato de dados, no qual as gravações sonoras são armazenadas"

msgid "subtitle codec"
msgstr "Codificador de subtítulos"

msgid "codec the subtitle data is stored in"
msgstr "formato de dados, no qual os subtítulos são armazenados"

msgid "container format"
msgstr "Formato do Containerformat"

msgid "container format the data is stored in"
msgstr "Formato do container no qual as dados estão armazenados"

msgid "bitrate"
msgstr "Bitrate"

msgid "exact or average bitrate in bits/s"
msgstr "taxa de bits exata ou média em bits por segundo"

msgid "nominal bitrate"
msgstr "Bitrate nominal"

msgid "nominal bitrate in bits/s"
msgstr ""
"Ao variar o bitrate, uma média de %<PRIuMAX> bits por segundo é recomendada."

msgid "minimum bitrate"
msgstr "Bitrate mínima"

msgid "minimum bitrate in bits/s"
msgstr "Débit mínimo em bits por segundo"

msgid "maximum bitrate"
msgstr "Bitrate máxima"

msgid "maximum bitrate in bits/s"
msgstr "débit máximo em bits por segundo"

msgid "encoder"
msgstr "coder"

msgid "encoder used to encode this stream"
msgstr "coder utilizado para este fluxo de dados"

msgid "encoder version"
msgstr "Versão dos Codificadores"

msgid "version of the encoder used to encode this stream"
msgstr "Versão dos Codificadores para este fluxo de dados"

msgid "serial"
msgstr "número de série"

msgid "serial number of track"
msgstr "número de série do título"

msgid "replaygain track gain"
msgstr "ajuste de volume do título replaygain"

msgid "track gain in dB"
msgstr "nível de título em dB"

msgid "r128 track gain"
msgstr "nível de título replaygain r128"

msgid "track gain in dB (r128)"
msgstr "nível de título em dB (R128)"

msgid "replaygain track peak"
msgstr "ajuste de volume do pico da curva"

msgid "peak of the track"
msgstr "pico do título"

msgid "replaygain album gain"
msgstr "ajuste de volume do padrão replaygain para álbuns"

msgid "album gain in dB"
msgstr "nível de gravação em dB do álbum"

msgid "r128 album gain"
msgstr "níveis de ganho dos álbuns replaygain"

msgid "album gain in dB (r128)"
msgstr "nível de gravação do álbum em dB (R128)"

msgid "replaygain album peak"
msgstr "ajuste de volume do pico da crête d'album replaygain"

msgid "peak of the album"
msgstr "pico do álbum"

msgid "replaygain reference level"
msgstr "nível de referência para ajuste de volume replaygain"

msgid "reference level of track and album gain values"
msgstr "nível de referência para asjustes dos níveis do título e álbum"

msgid "language code"
msgstr "código linguístico"

msgid "language code for this stream, conforming to ISO-639-1 or ISO-639-2"
msgstr ""
"Código linguístico para este fluxo de energia, conforme a norma ISO-639-1 ou"
" ISO-639-2"

msgid "language name"
msgstr "Nome da Lingua"

msgid "freeform name of the language this stream is in"
msgstr "Nome da linguagem em que o fluxo de dados está localizado."

msgid "image"
msgstr "imagem"

msgid "image related to this stream"
msgstr "imagem para este fluxo de dados"

msgid "preview image"
msgstr "imagem de avaliação"

msgid "preview image related to this stream"
msgstr "Aviso prévio para este fluxo de dados"

msgid "attachment"
msgstr "anexo"

msgid "file attached to this stream"
msgstr "ficheiro anexado a este fluxo de dados"

msgid "beats per minute"
msgstr "batidas por minuto"

msgid "number of beats per minute in audio"
msgstr "Número de batidas por minuto no áudio"

msgid "keywords"
msgstr "palavras-chave"

msgid "comma separated keywords describing the content"
msgstr "palavras-chave separadas por vírgula que descrevem o conteúdo"

msgid "geo location name"
msgstr "localização geográfica do emplazamento"

msgid ""
"human readable descriptive location of where the media has been recorded or "
"produced"
msgstr "Descrição inteligível do local onde o meio foi gravado ou produzido."

msgid "geo location latitude"
msgstr "grau geográfico de latitude do local"

msgid ""
"geo latitude location of where the media has been recorded or produced in "
"degrees according to WGS84 (zero at the equator, negative values for "
"southern latitudes)"
msgstr ""
"grau geográfico do local onde o meio foi gravado ou produzido, em graus "
"conforme WGS84 (0 no equador e valores negativos nos trópicos sul)"

msgid "geo location longitude"
msgstr "grau de longitude geográfica"

msgid ""
"geo longitude location of where the media has been recorded or produced in "
"degrees according to WGS84 (zero at the prime meridian in Greenwich/UK,  "
"negative values for western longitudes)"
msgstr ""
"o grau de longitude geográfica do local onde o conteúdo foi gravado ou "
"produzido, em graus conforme WGS84 (0 para o meridiano principal através de "
"Greenwich/Reino Unido, valores negativos para os longitudes ocidentais)"

msgid "geo location elevation"
msgstr "altitude geográfica do local"

msgid ""
"geo elevation of where the media has been recorded or produced in meters "
"according to WGS84 (zero is average sea level)"
msgstr ""
"altitude geográfica do local em metros conforme WGS84 (nível zero "
"corresponde ao nível médio de maré)"

msgid "geo location country"
msgstr "terreno geográfico"

msgid "country (english name) where the media has been recorded or produced"
msgstr "País (nome em inglês) onde o meio foi gravado ou produzido."

msgid "geo location city"
msgstr "cidade geográfica"

msgid "city (english name) where the media has been recorded or produced"
msgstr "A cidade (nome inglês) onde o meio foi gravado ou produzido"

msgid "geo location sublocation"
msgstr "bairro geográfico"

msgid ""
"a location within a city where the media has been produced or created (e.g. "
"the neighborhood)"
msgstr ""
"um local dentro da cidade, onde o meio foi gravado ou produzido (por "
"exemplo, um bairro)"

msgid "geo location horizontal error"
msgstr "erro de localização horizontal geográfica"

msgid "expected error of the horizontal positioning measures (in meters)"
msgstr "erro provável da medição horizontal de posição (em metros)"

msgid "geo location movement speed"
msgstr "velocidade de movimento geográfica"

msgid ""
"movement speed of the capturing device while performing the capture in m/s"
msgstr ""
"velocidade de movimento do dispositivo de gravação durante a gravação, "
"medida em metros por segundo"

msgid "geo location movement direction"
msgstr "direção da movimentação geográfica"

msgid ""
"indicates the movement direction of the device performing the capture of a "
"media. It is represented as degrees in floating point representation, 0 "
"means the geographic north, and increases clockwise"
msgstr ""
"Indica a direção do movimento da ferramenta de gravação durante o registro "
"de um meio. A representação é em graus, como número decimal com ponto "
"flutuante. 0 corresponde ao norte geográfico e o valor aumenta no sentido "
"horário"

msgid "geo location capture direction"
msgstr "direção de captura geolocalizada"

msgid ""
"indicates the direction the device is pointing to when capturing  a media. "
"It is represented as degrees in floating point  representation, 0 means the "
"geographic north, and increases clockwise"
msgstr ""
"Indica a direção do dispositivo durante o registro de um meio. A "
"representação é em graus, como número decimal com ponto flutuante. 0 "
"corresponde ao norte geográfico e o valor aumenta no sentido horário"

msgid "show name"
msgstr "Nome do programa"

msgid "Name of the tv/podcast/series show the media is from"
msgstr "Nome do conteúdo da TV/Podcast/Série, de onde o meio se origina"

msgid "show sortname"
msgstr "Nome do arquivo para mostrar após o processamento de ordenação"

msgid ""
"Name of the tv/podcast/series show the media is from, for sorting purposes"
msgstr ""
"Nome do conteúdo da TV/Podcast/Série, de onde o meio se origina, para "
"organizar"

msgid "episode number"
msgstr "número da sequência"

msgid "The episode number in the season the media is part of"
msgstr "O número da sequência na série, cujo meio faz parte"

msgid "season number"
msgstr "número da série"

msgid "The season number of the show the media is part of"
msgstr "O número da série da transmissão, cujo meio faz parte"

msgid "lyrics"
msgstr "texto falso"

msgid "The lyrics of the media, commonly used for songs"
msgstr "Os textos do meio, normalmente utilizados para canções"

msgid "composer sortname"
msgstr "Nome do Compositor para o Ordenamento"

msgid "person(s) who composed the recording, for sorting purposes"
msgstr ""
"Para a gravação, responsável pela pessoa(s) que tenha/tenham composição e "
"para fins de ordenação"

msgid "grouping"
msgstr "agrupamento"

msgid ""
"Groups related media that spans multiple tracks, like the different pieces "
"of a concerto. It is a higher level than a track, but lower than an album"
msgstr ""
"Unidade de grupo para mídias que contêm vários títulos, semelhantes aos "
"diferentes segmentos em um concerto. É uma camada acima do título "
"individual, mas abaixo da unidade musical completa (álbum)"

msgid "user rating"
msgstr "avaliação do usuário"

msgid ""
"Rating attributed by a user. The higher the rank, the more the user likes "
"this media"
msgstr ""
"Avaliado por um usuário. Quanto maior a nota, mais popular o meio para esse "
"usuário."

msgid "device manufacturer"
msgstr "Fabricante de dispositivos eletrônicos"

msgid "Manufacturer of the device used to create this media"
msgstr "Fabricante do dispositivo utilizado para criar este meio"

msgid "device model"
msgstr "Gerätemodell"

msgid "Model of the device used to create this media"
msgstr "O modelo do dispositivo utilizado para a criação deste meio digital"

msgid "application name"
msgstr "Nome do aplicativo"

msgid "Application used to create the media"
msgstr "A aplicação utilizada para criar este meio"

msgid "application data"
msgstr "Dados aplicacionais"

msgid "Arbitrary application data to be serialized into the media"
msgstr "Dados arbitrários da aplicação para serialização no meio"

msgid "image orientation"
msgstr "orientação da imagem"

msgid "How the image should be rotated or flipped before display"
msgstr "Indique como girar ou refletir a imagem antes da sua exibição"

msgid "publisher"
msgstr "editora/autora"

msgid "Name of the label or publisher"
msgstr "Nome do rótulo ou editorial"

msgid "interpreted-by"
msgstr "interpretado por"

msgid ""
"Information about the people behind a remix and similar interpretations"
msgstr ""
"Informações sobre as pessoas por trás de um remix e interpretações "
"semelhantes"

msgid "midi-base-note"
msgstr "nota base do midi"

msgid "Midi note number of the audio track."
msgstr "Número de notas Midi da trilha sonora."

msgid "private-data"
msgstr "Dados privados"

msgid "Private data"
msgstr "Dados privados"

msgid ", "
msgstr ", "

msgid "No URI handler for the %s protocol found"
msgstr "Não foi possível encontrar um handler de endereço para o protocolo %s"

msgid "URI scheme '%s' not supported"
msgstr "O esquema de endereço 'URI do schéma %s' não é suportado."

msgid "ERROR: from element %s: %s\n"
msgstr "ERRO : do elemento %s : %s"

msgid ""
"Additional debug info:\n"
"%s\n"
msgstr ""
"Informação de diagnóstico adicional : \n"
"%s\n"

