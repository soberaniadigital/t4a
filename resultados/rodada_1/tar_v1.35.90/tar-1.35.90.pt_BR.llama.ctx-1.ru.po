msgstr ""
"As seguintes opções foram utilizadas após argumentos não opcionais. Essas "
"opções são posicionais e afetam apenas os argumentos que vêm depois delas. "
"Deve-se recolocá-las adequadamente."

msgid "-C %s has no effect"
msgstr "-C %s carece de efeito"

msgid "--%s %s has no effect"
msgstr "--%s %s não tem efeito"

msgid "--%s has no effect"
msgstr "--%s não tem efeito"

msgid "command line"
msgstr "linha de ordens"

msgid "%s: file list requested from %s already read from %s"
msgstr "%s: a lista de arquivos solicitados em %s já foi lida do %s"

msgid "cannot split string '%s': %s"
msgstr "não é possível dividir a string '%s': %s"

msgid "too many options"
msgstr "demasiadas opções"

msgid "%s: file name read contains nul character"
msgstr "%s: o nome do arquivo lido contém caractere nulo (null)"

msgid "Pattern matching characters used in file names"
msgstr "Utilizaram caracteres de expressões regulares nos nomes dos arquivos."

msgid ""
"Use --wildcards to enable pattern matching, or --no-wildcards to suppress "
