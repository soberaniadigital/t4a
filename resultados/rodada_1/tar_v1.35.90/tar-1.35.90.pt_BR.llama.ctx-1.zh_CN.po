msgstr "Sem uma lista de arquivos, a opção --ocorrencia não tem sentido."

msgid "Multiple archive files require '-M' option"
msgstr "Os arquivos múltiplos requerem a opção '-M'."

msgid "--level is meaningless without --listed-incremental"
msgstr "O --level sem o --listed-incremental é inválido e não tem sentido."

msgid "%s: Volume label length exceeds %d bytes"
msgstr "%s: A extensão da etiqueta do volume excede %d bytes"

msgid "Cannot verify multi-volume archives"
msgstr "não é possível verificar arquivos multivolumen"

msgid "Cannot verify compressed archives"
msgstr "Não é possível verificar arquivos comprimidos"

msgid "Cannot use multi-volume compressed archives"
msgstr "Não é possível utilizar arquivos multivolumen comprimidos."

msgid "Cannot concatenate compressed archives"
msgstr "Não é possível concatenar arquivos comprimidos."

msgid "--clamp-mtime needs a date specified using --mtime"
msgstr ""
"Para o uso do --clamp-mtime, é necessário especificar uma data com o "
"parâmetro --mtime."

msgid "--pax-option can be used only on POSIX archives"
msgstr "--pax-option só pode ser usado em arquivos POSIX."

msgid "--acls can be used only on POSIX archives"
msgstr "--acls somente pode ser usado em arquivos POSIX."

msgid "--selinux can be used only on POSIX archives"
msgstr "--selinux só pode ser usado em arquivos POSIX."

msgid "--xattrs can be used only on POSIX archives"
msgstr "--xattrs só pode ser usado em arquivos POSIX."

msgid ""
"Cannot deduce top-level directory name; please set it explicitly with --one-"
"top-level=DIR"
msgstr ""
"Não é possível deduzir o nome do diretório superior; indique explicitamente "
"com --one-top-level=DIR."

msgid "Volume length cannot be less than record size"
msgstr "A longitud do volume não pode ser menor que o tamanho de registro"

msgid "Cowardly refusing to create an empty archive"
msgstr "Rejeitou covardemente a criação de um arquivo vazio"

msgid "Options '-Aru' are incompatible with '-f -'"
msgstr "As opções '-Aru' não são compatíveis com as flags '-f -'"

msgid "failed to assert availability of the standard file descriptors"
msgstr ""
"não é possível garantir que os descriptores de arquivos padrão estejam "
"disponíveis"

msgid ""
"You must specify one of the '-Acdtrux', '--delete' or '--test-label' options"
msgstr ""
"É necessário especificar uma das opções '-Acdtrux', '--delete' ou '--test-"
"label'."

msgid "Exiting with failure status due to previous errors"
msgstr ""
"devido a falhas anteriores, o sistema saiu do estado de falha para "
"reiniciar."

msgid "Keyword %s is unknown or not yet implemented"
msgstr "A palavra chave %s é desconhecida ou não está implementada ainda."

msgid "Time stamp is out of allowed range"
msgstr "A marca de tempo está fora do rango permitido."

msgid "Malformed pax option: %s"
msgstr "Opção pax mal formada: %s"

msgid "Pattern %s cannot be used"
msgstr "não é possível usar o padrão %s"

msgid "Keyword %s cannot be overridden"
msgstr "A palavra chave %s não pode ser substituída"

msgid "can't update global extended header record"
msgstr "não é possível atualizar o registro de cabeçalho estendido global"

msgid "Malformed extended header: missing length"
msgstr "Cabeçalho estendido incorreto: falta a extensão (length)"

msgid "Extended header length %.*s is out of range"
msgstr "A longitud da cabecera extendida %.*s está fora do rango"

msgid "Malformed extended header: missing blank after length"
msgstr ""
"Cabeçalho estendido incorreto: falta espaço após a medida de comprimento"

msgid "Malformed extended header: missing equal sign"
msgstr "Cabeçalha estendida incorreta: falta de sinal igual"

msgid "Malformed extended header: missing newline"
msgstr "Cabeçalho estendido incorreto: faltando uma nova linha."

msgid "Ignoring unknown extended header keyword %s"
msgstr "Oculta a palavra chave de cabeçalho estendido desconhecida '%s'."

msgid "Extended header %s=%s is out of range %jd..%ju"
msgstr "Cabeçalha estendida %s=%s está fora do intervalo %jd..%ju"

msgid "Malformed extended header: invalid %s=%s"
msgstr "Cabeçalho estendido incorreto: %s=%s inválido"

msgid "Malformed extended header: excess %s=%s"
msgstr "Cabeçalho estendido incorreto: sobra %s=%s"

msgid "Malformed extended header: invalid %s: unexpected delimiter %c"
msgstr ""
"Cabeçalho estendido incorreto: %s inválido: delimitador de separação "
"inesperado \\u00a7%c"

msgid "Malformed extended header: invalid %s: odd number of values"
msgstr "Cabeçalho estendido incorreto: %s inválido: número par de valores"

msgid "%s: not a valid timeout"
msgstr "%s: não é um tempo de expiração válido"

msgid "%s: unknown checkpoint action"
msgstr "%s: ação de ponto de comprovação desconhecida"

msgid "write"
msgstr "escritura"

msgid "read"
msgstr "leitura"

msgid "Write checkpoint %u"
msgstr "ponto de checagem para escrita %u"

msgid "Read checkpoint %u"
msgstr "ponto de checagem para leitura %u"

msgid "too many words in '%s'"
msgstr "demasiadas palavras em '%s'"

msgid ""
"genfile manipulates data files for GNU paxutils test suite.\n"
"OPTIONS are:\n"
msgstr ""
"gf_file manipula arquivos de dados para a «suite» do teste software GNU paxutils. \n"
"\n"
"opcionas:\n"

msgid "File creation options:"
msgstr "Opciones de criação de arquivos:"

msgid "SIZE"
msgstr "TAMAGNTE"

msgid "Create file of the given SIZE"
msgstr "cria um arquivo do tamanho especificado"

msgid "Write to file NAME, instead of standard output"
msgstr "Escria no ficheiro %s; em vez da saída padrão está o ficheiro."

msgid "Read file names from FILE"
msgstr "Leia os nomes dos arquivos no FICHERO"

msgid "-T reads null-terminated names"
msgstr "-T lee nombres terminados em nulo"

msgid "Fill the file with the given PATTERN. PATTERN is 'default' or 'zeros'"
msgstr ""
"Renomeie o arquivo com o PATRÓN dado, que pode ser 'default' ou 'zeros'"

msgid "Size of a block for sparse file"
msgstr "Tamanho de um bloco para arquivo disperso em sistemas distribuídos."

msgid "Generate sparse file. Rest of the command line gives the file map."
msgstr ""
"Gerar um arquivo disperso. O restante das linhas de comando fornecem o mapa "
"do arquivo."

msgid "OFFSET"
msgstr "Deslocamento"

msgid "Seek to the given offset before writing data"
msgstr "Busca no deslocamento indicado antes de escrever os dados."

msgid "Suppress non-fatal diagnostic messages"
msgstr "suprime mensagens de diagnóstico não fatales"

msgid "File statistics options:"
msgstr "Opciones de estatísticas de arquivos:"

msgid "Print contents of struct stat for each given file. Default FORMAT is: "
msgstr ""
"Imprime os conteúdos da estrutura de estatísticas para cada arquivo "
"indicado. FORMATO predeterminado:"

msgid "Synchronous execution options:"
msgstr "opções de execução síncrona:"

msgid "N"
msgstr "N"

msgid ""
"Execute ARGS. Trigger checkpoints every Nth record (default 1). Useful with "
"--checkpoint and one of --cut, --append, --touch, --unlink"
msgstr ""
"Executa ARGS. Inicia pontos de verificação a cada N registros (1 por "
"padrão). Utiliza com --checkpoint e uma das opções -cut, --append, --touch "
"ou --unlink"

msgid "Perform given action (see below) upon reaching checkpoint NUMBER"
msgstr ""
"Realiza a acção indicada (veja mais abaixo) ao chegar no ponto de "
"comprovação NÚMERO"

msgid "Set date for next --touch option"
msgstr "Estabeleça a data para o próximo --touch"

msgid "Display executed checkpoints and exit status of COMMAND"
msgstr ""
"Mostra os pontos de verificação executados e o estado da saída do processo "
"ORDEN"

msgid ""
"Synchronous execution actions. These are executed when checkpoint number "
"given by --checkpoint option is reached."
msgstr ""
"Ações de execução síncrona. São executadas quando se alcança o ponto de "
"verificação indicado pela opção --checkpoint."

msgid ""
"Truncate FILE to the size specified by previous --length option (or 0, if it"
" is not given)"
msgstr ""
"Falha ao truncar o arquivo para o tamanho especificado anteriormente na "
"opção --length (ou zero, se nenhum valor for indicado)."

msgid "Append SIZE bytes to FILE. SIZE is given by previous --length option."
msgstr ""
"Adicione tamanho bytes ao arquivo. Tamanho é indicado anteriormente em uma "
"opção --length."

msgid "Update the access and modification times of FILE"
msgstr "Actualiza as datas de acesso e modificação do arquivo FICHERO"

msgid "Execute COMMAND"
msgstr "Execute ORDER"

msgid "Delete FILE"
msgstr "Remover arquivo"

msgid "Invalid size: %s"
msgstr "Tamanho inválido: %s"

msgid "Negative size: %s"
msgstr "Tamanho negativo: %s"

msgid "Number out of allowed range: %s"
msgstr "Número fora do intervalo permitido: %s"

msgid "stat(%s) failed"
msgstr "falha na verificação do estado (stat) do arquivo %s"

msgid "requested file length %jd, actual %jd"
msgstr "longitude do arquivo solicitado %jd, efetiva %jd"

msgid "created file is not sparse"
msgstr "o arquivo criado não é disperso"

msgid "Error parsing number near `%s'"
msgstr "falha ao analisar número próximo a '%s'"

msgid "Unknown date format"
msgstr "Formato de data desconhecido"

msgid "[ARGS...]"
msgstr "[ARGUMENTOS...]"

msgid "cannot open `%s'"
msgstr "não é possível abrir o arquivo `%s'"

msgid "cannot seek"
msgstr "não é possível executar o `seek`"

msgid "file name contains null character"
msgstr "o nome do arquivo contém o caractere nulo"

msgid "cannot generate sparse files on standard output, use --file option"
msgstr ""
"não é possível gerar arquivos dispersos na saída padrão; utilize a opção "
"--file."

msgid "incorrect mask (near `%s')"
msgstr "máscara incorreta (cerca de `%s')"

msgid "Unknown field `%s'"
msgstr "Campo desconhecido `%s'"

msgid "cannot set time on `%s'"
msgstr "não é possível definir a data para o arquivo %s"

msgid "cannot truncate `%s'"
msgstr "não é possível truncar o arquivo %s"

msgid "command failed: %s"
msgstr "falha na execução da ordem: %s"

msgid "cannot stat `%s'"
msgstr "não é possível obter o estado (stat) do arquivo %s"

msgid "cannot remove directory `%s'"
msgstr "não é possível excluir o diretório `%s'"

msgid "cannot unlink `%s'"
msgstr "não é possível desanexar '%s'"

msgid "Command exited successfully\n"
msgstr "A ordem finalizou com sucesso."

msgid "Command failed with status %d\n"
msgstr "A ordem falhou com o estado %d"

msgid "Command terminated on signal %d\n"
msgstr "A ordem foi encerrada com a sinalização %d"

msgid "Command stopped on signal %d\n"
msgstr "A ordem foi interrompida com a sinalização %d"

msgid "Command dumped core\n"
msgstr "A ordem enviou um núcleo para armazenamento"

msgid "Command terminated\n"
msgstr "A ordem foi concluída."

msgid "--stat requires file names"
msgstr "--stat opção necessita nomes de arquivos"

msgid "--set-times requires file names"
msgstr "--set-times necessita nomes de arquivos"
