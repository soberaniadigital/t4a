msgstr "Se houver sido especificado mais de uma data limite."

msgid "Invalid sparse version value"
msgstr "Valor de versão dispersa inválido"

msgid "--atime-preserve='system' is not supported on this platform"
msgstr "--atime-preserve='system' não é suportado nesta plataforma."

msgid "invalid --checkpoint value"
msgstr "valor inválido para o opção --checkpoint"

msgid "Invalid mode given on option"
msgstr "Se houver especificado um modo inválido na opção."

msgid "Invalid number"
msgstr "Número inválido"

msgid "Invalid record size"
msgstr "O tamanho do registro é inválido"

msgid "Record size must be a multiple of %d."
msgstr "O tamanho do registro deve ser múltiplo de %d."

msgid "Invalid number of elements"
msgstr "Número inválido de elementos"

msgid "Only one --to-command option allowed"
msgstr "Só se permite uma opção --to-command."

msgid "%s:%jd: location of the error"
msgstr "%s:%d: localização do erro"

