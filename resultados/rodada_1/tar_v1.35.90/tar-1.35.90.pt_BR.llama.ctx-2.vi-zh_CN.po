msgid "archive is seekable"
msgstr "o arquivo permite `seek`"

msgid "archive is not seekable"
msgstr "o arquivo não permite `seek'"

msgid "do not check device numbers when creating incremental archives"
msgstr ""
"não é necessário verificar os números de dispositivo quando se criam "
