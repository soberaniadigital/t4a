msgid "Syntax definition to use for coloring"
msgstr "Utilizar o descrever do sintaxe para ajustar as cores"

msgid "Let Bsp and Del erase a marked region"
msgstr "Limpar a região selecionada utilizando Bsp e Del."

msgid "When soft-wrapping, do it at whitespace"
msgstr "Fazer o transporte suave apenas em espaços em branco."

msgid "Automatically hard-wrap overlong lines"
msgstr "жестко переносить слишком длинные строки"

msgid "Constantly show cursor position"
