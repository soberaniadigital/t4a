msgstr "--operatingdir=<diretório>"

msgid "Set operating directory"
msgstr "Definir o diretório de trabalho"

msgid "Preserve XON (^Q) and XOFF (^S) keys"
msgstr "Reservado os botões XON (^Q) e XOFF (^S)"

msgid "Show a position+portion indicator"
msgstr "Exibir indicador de posição+parte"

msgid "-r <number>"
msgstr "-r <число>"

msgid "--fill=<number>"
msgstr "--fill=<число>"

msgid "Set width for hard-wrap and justify"
msgstr "Defina a largura para o alinhamento e corte rígidos."

msgid "-s <program>"
msgstr "-s <programa>"

msgid "--speller=<program>"
msgstr "--speller=<программа>"

msgid "Use this alternative spell checker"
msgstr "Utilizar esta alternativa de verificação ortográfica"

msgid "Save changes on exit, don't prompt"
msgstr "Não solicitar salvamento de alterações ao sair."

msgid "Save a file by default in Unix format"
msgstr "Por padrão, salvar o arquivo no formato Unix."

msgid "View mode (read-only)"
msgstr "Modo de visualização (apenas leitura)"

msgid "Don't hard-wrap long lines [default]"
msgstr "Não fornecer longas linhas [padrão]."

msgid "Don't show the two help lines"
msgstr "Não mostre duas linhas de ajuda abaixo."

msgid "Make Ctrl+Right stop at word ends"
msgstr "Parar ao final das palavras com Ctrl+Right pressionado"

msgid "Also try magic to determine syntax"
msgstr "Utilizar magia para determinar sintaxe."

msgid "Show some states on the title bar"
msgstr "Exibir estados no título da janela."

msgid "Show a feedback bar at the bottom"
msgstr "Exibir a linha nesta coluna."

