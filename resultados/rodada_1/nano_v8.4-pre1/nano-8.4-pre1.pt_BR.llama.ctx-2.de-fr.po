msgstr "Configurar o diretório de trabalho"

msgid "Preserve XON (^Q) and XOFF (^S) keys"
msgstr "Reservar as teclas XON (^Q) e XOFF (^S)"

msgid "Show a position+portion indicator"
msgstr "Exibir o indicador de posição e parte"

msgid "-r <number>"
msgstr "-r <число>"

msgid "--fill=<number>"
msgstr "--fill=<число>"

msgid "Set width for hard-wrap and justify"
msgstr ""
"Defina a largura para o alinhamento e corte de texto em um limiar rígido."

msgid "-s <program>"
msgstr "-s <programa>"

msgid "--speller=<program>"
msgstr "--speller=<programa>"

msgid "Use this alternative spell checker"
msgstr "Utilizar esta alternativa de verificação ortográfica"

msgid "Save changes on exit, don't prompt"
msgstr "sem solicitar, ao sair, não salvar alterações"

msgid "Save a file by default in Unix format"
msgstr "Por padrão, salvar o arquivo no formato Unix."

msgid "View mode (read-only)"
msgstr "Modo de visualização (apenas leitura)"

msgid "Don't hard-wrap long lines [default]"
msgstr "Não permitir a continuação automática de linhas longas [padrão]"

msgid "Don't show the two help lines"
msgstr "Não mostrar as duas linhas de ajuda abaixo."

msgid "Make Ctrl+Right stop at word ends"
msgstr ""
"Parar ao chegar às extremidades das palavras enquanto o Ctrl está "
