msgid "Error expanding %s: %s"
msgstr "Erro ao expandir %s: %s"

msgid "Color '%s' takes no prefix"
msgstr "A cor \"%s\" não pode ter prefixo adicionado"

msgid "Color \"%s\" not understood"
msgstr "Не foi possível interpretar o símbolo de cor '\\u0425'."

msgid "An attribute requires a subsequent comma"
msgstr "O atributo requer uma vírgula após si mesma."

msgid "Missing color name"
msgstr "Não há nome de cor definido"

msgid "Missing regex string after '%s' command"
msgstr "Falha na aplicação de uma expressão regular após o comando \"%s\"."

msgid "\"start=\" requires a corresponding \"end=\""
msgstr "«start=» requer um «end=» correspondente."

msgid "A '%s' command requires a preceding 'syntax' command"
