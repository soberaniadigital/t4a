msgstr "-f <arquivo>"

msgid "--rcfile=<file>"
msgstr "--rcfile=<файл>"

msgid "Use only this file for configuring nano"
msgstr "Utilize apenas este arquivo para as configurações do nano."

msgid "Show cursor in file browser & help text"
msgstr ""
"Mostrar o cursor e texto de ajuda no gerenciador do explorador de arquivos"

msgid "Show this help text and exit"
msgstr "Exibir este texto e sair."

msgid "Automatically indent new lines"
msgstr "automático de recuo em novas linhas"

msgid "Scroll per half-screen, not per line"
msgstr "Rolamento por meio do centro da tela, e não linha a linha."

msgid "Cut from cursor to end of line"
msgstr "Cortar do cursor até o final da linha"

msgid "Show line numbers in front of the text"
msgstr "mostrar números das linhas antes do texto"

msgid "Enable the use of the mouse"
msgstr "Permitir o uso da mouse."

msgid "Do not read the file (only write it)"
msgstr "Não ler o arquivo (só escrever nele)"

