msgstr "-C <diretório>"

msgid "--backupdir=<dir>"
msgstr "--backupdir=<diretório>"

msgid "Directory for saving unique backup files"
msgstr "Catalogo de Armazenamento para Backups Únicos e Indivisíveis"

msgid "Use bold instead of reverse video text"
msgstr "Utilizar fonte em negrito"

msgid "Convert typed tabs to spaces"
msgstr "Converter tabulações em espaços"

msgid "Read a file into a new buffer by default"
msgstr "Por padrão, ler o arquivo no novo buffer"

msgid "Use (vim-style) lock files"
msgstr "Utilizar arquivos de bloqueio (como no vim)"

msgid "Save & reload old search/replace strings"
msgstr "Salvar a história de pesquisa/substituição das strings"

msgid "Don't look at nanorc files"
msgstr "Não utilize em arquivos nanorc."

msgid "-J <number>"
msgstr "-J <число>"

msgid "--guidestripe=<number>"
msgstr "--guidestripe=<число>"

msgid "Show a guiding bar at this column"
