msgstr "Código inválido para o caractere numérico"

msgid "Can open just one file\n"
msgstr "Posso abrir apenas um arquivo."

msgid "Welcome to nano.  For basic help, type Ctrl+G."
msgstr ""
"Bom dia, você está em nano. Para obter informações básicas, pressione "
"Ctrl+G."

