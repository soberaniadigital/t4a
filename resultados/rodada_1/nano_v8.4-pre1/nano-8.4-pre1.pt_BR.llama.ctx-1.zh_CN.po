msgid "Unknown menu: %s"
msgstr "Desconhecido nome de sintaxe: %s"

msgid "Function '%s' does not exist in menu '%s'"
msgstr "A função \"%s\" não está presente no menu \"%s\"."

msgid "Keystroke %s may not be rebound"
msgstr "Combinação de teclas %s não pode ser reassinbrada"

msgid "Command \"%s\" not understood"
msgstr "Comando inválido ou não reconhecido: \"%s\""

msgid "Error expanding %s: %s"
msgstr "Erro ao expandir %s: %s"

msgid "Color '%s' takes no prefix"
msgstr "O prefíxo '\\u0417' não pode ser adicionado ao colorido \"%s\"."

msgid "Color \"%s\" not understood"
msgstr "Не удалось разобрать цвет «%s»"

msgid "An attribute requires a subsequent comma"
msgstr "O atributo requer uma vírgula após si mesmo."

msgid "Missing color name"
msgstr "falta de nome do tom de cor"

msgid "Missing regex string after '%s' command"
msgstr "Falha na execução da expressão regular após a instrução \"%s\""

msgid "\"start=\" requires a corresponding \"end=\""
msgstr "«start=» requer a correspondente «end=»"

msgid "A '%s' command requires a preceding 'syntax' command"
