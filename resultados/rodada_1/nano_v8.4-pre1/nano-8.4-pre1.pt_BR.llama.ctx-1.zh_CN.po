msgid "Fix numeric keypad key confusion problem"
msgstr "Resolver o problema de travamento da teclado virtual"

msgid "Don't add an automatic newline"
msgstr "Não adicione uma string vazia no final"

msgid "Trim tail spaces when hard-wrapping"
msgstr "eliminar espaços em branco finais ao rodar linhas manualmente"

msgid "Don't convert files from DOS/Mac format"
msgstr "Não converta do DOS/Mac para o Linux formatado."

msgid "Leading whitespace means new paragraph"
msgstr "O espaço em branco indica o início de um novo parágrafo"

msgid "Save & restore position of the cursor"
msgstr "Mostrar a posição do cursor."

msgid "-Q <regex>"
msgstr "-Q <regex>"

msgid "--quotestr=<regex>"
msgstr "--quotestr=<regex>"

msgid "Regular expression to match quoting"
msgstr "expressão regular para encontrar aspas"

msgid "Restrict access to the filesystem"
msgstr "limitar o acesso à sistema de arquivos"

msgid "Display overlong lines on multiple rows"
msgstr "Transferir longas linhas ao visualizar"

msgid "-T <number>"
msgstr "-T <número>"

msgid "--tabsize=<number>"
msgstr "--tabsize=<число>"

msgid "Make a tab this number of columns wide"
msgstr "Defina a largura da tabulação para linhas específicas."

msgid "Wipe status bar upon next keystroke"
msgstr "Após o clique, a linha de estado é limpa."

msgid "Print version information and exit"
msgstr "Exibir versão e sair"

msgid "Detect word boundaries more accurately"
msgstr "definir limites de palavras com maior precisão"

msgid "-X <string>"
msgstr "-X <string>"

msgid "--wordchars=<string>"
msgstr "--wordchars=<строка>"

msgid "Which other characters are word parts"
msgstr ""
"Quais são os outros caracteres especiais que também constituem uma palavra?"

msgid "-Y <name>"
msgstr "-Y <nome>"

msgid "--syntax=<name>"
msgstr "--syntax=<nome>"

msgid "Syntax definition to use for coloring"
msgstr "Utilizar o descrição do sintaxe para a subtilização"

msgid "Let Bsp and Del erase a marked region"
msgstr "Limpar a área selecionada utilizando Bsp e Del."

msgid "When soft-wrapping, do it at whitespace"
msgstr "Realizar transporte suave apenas em espaços em branco."

msgid "Automatically hard-wrap overlong lines"
msgstr "rigidly forcing wrap of excessively long lines"

msgid "Constantly show cursor position"
msgstr "mostrar posição do cursor em tempo real"

msgid "Fix Backspace/Delete confusion problem"
msgstr "Resolver problema de Backspace/Delete"

msgid "Keep the line below the title bar empty"
msgstr "Não preencha a linha abaixo do cabeçalho da tabela"

msgid "-f <file>"
msgstr "-f <arquivo>"

msgid "--rcfile=<file>"
msgstr "--rcfile=<arquivo>"

msgid "Use only this file for configuring nano"
msgstr "Utilize apenas este arquivo para as configurações do nano."

msgid "Show cursor in file browser & help text"
msgstr "Mostrar o cursor e texto de ajuda no gerenciador de arquivos."

msgid "Show this help text and exit"
msgstr "Exibir este texto e sair."

msgid "Automatically indent new lines"
msgstr "Deslize automaticamente para novas linhas"

msgid "Scroll per half-screen, not per line"
msgstr "Por favor, desligue o computador para evitar danos ao sistema."

msgid "Cut from cursor to end of line"
msgstr "cortar a linha selecionada até o final da mesma"

msgid "Show line numbers in front of the text"
msgstr "mostrar números das linhas antes do texto"

msgid "Enable the use of the mouse"
msgstr "Permissão concedida para o uso da mouse."

msgid "Do not read the file (only write it)"
msgstr "Não ler o arquivo (só escrever nele)"

msgid "-o <dir>"
msgstr "-o <diretório>"

msgid "--operatingdir=<dir>"
msgstr "--operatingdir=<diretório>"

msgid "Set operating directory"
msgstr "Definir o diretório de trabalho"

msgid "Preserve XON (^Q) and XOFF (^S) keys"
msgstr "Reservado os botões XON (^Q) e XOFF (^S)"

msgid "Show a position+portion indicator"
msgstr "Exibir indicador de posição+parte"

msgid "-r <number>"
msgstr "-r <число>"

msgid "--fill=<number>"
msgstr "--fill=<число>"

msgid "Set width for hard-wrap and justify"
msgstr "Defina a largura para o alinhamento e quebra de linha forçada."

msgid "-s <program>"
msgstr "-s <programa>"

msgid "--speller=<program>"
msgstr "--speller=<programa>"

msgid "Use this alternative spell checker"
msgstr "Utilizar esta alternativa de verificação ortográfica"

msgid "Save changes on exit, don't prompt"
msgstr "Não solicitar salvamento de alterações ao sair."

msgid "Save a file by default in Unix format"
msgstr "Por padrão, salvar o arquivo no formato Unix."

msgid "View mode (read-only)"
msgstr "Modo de visualização (somente leitura)"

msgid "Don't hard-wrap long lines [default]"
msgstr "Não permitirá ajuste automático de linhas longas [padrão]."

msgid "Don't show the two help lines"
msgstr "Não mostre duas linhas de ajuda abaixo."

msgid "Make Ctrl+Right stop at word ends"
msgstr "Parar ao pressionar Ctrl+Right nas extremidades das palavras."

msgid "Also try magic to determine syntax"
msgstr "Utilizar magia para determinar sintaxe."

msgid "Show some states on the title bar"
msgstr "Exibir o estado na parte superior da janela."

msgid "Show a feedback bar at the bottom"
msgstr "Exibir a linha nesta coluna."

msgid " GNU nano, version %s\n"
msgstr " GNU nano, versão %s\n"

msgid " (C) %s the Free Software Foundation and various contributors\n"
msgstr ""
"A Fundação Free Software (Fundação para o Acesso Livre ao Programas de "
"Computador)"

msgid " Compiled options:"
msgstr "Parâmetros de compilação:"

msgid "Could not reconnect stdin to keyboard\n"
msgstr ""
"Não foi possível reconectar o padrão de entrada para a tecla do computador."

msgid "Reading data from keyboard; type ^D or ^D^D to finish.\n"
msgstr "Lendo dados da entrada do teclado; digite ^D ou ^D^D para finalizar."

msgid "Failed to open stdin: %s"
msgstr "falha ao abrir o padrão de entrada/saída: %s"

msgid "Received SIGHUP or SIGTERM\n"
msgstr "Recebeu SIGHUP ou SIGTERM"

msgid "Sorry! Nano crashed!  Code: %d.  Please report a bug.\n"
msgstr ""
"Oi! Nano caiu! Código de erro: %d. Por favor, relata essa falha aos autores."

msgid "Use \"fg\" to return to nano.\n"
msgstr "Utilize 'fg' para retornar ao nano."

msgid "enabled"
msgstr "adiado"

msgid "disabled"
msgstr "Desligado"

msgid "Unknown sequence"
msgstr "sequência desconhecida"

msgid "Unknown function: %s"
msgstr "opção desconhecida: %s"

msgid "Missing }"
msgstr "Parâmetro ausente"

msgid "Unbound key: F%i"
msgstr "A tecla não está ligada: F%i"

msgid "Unbound key"
msgstr "A chave não foi atribuída"

msgid "Unbindable key: M-^%c"
msgstr ""
"Não é possível atribuir a tecla de escape do modo alternativo: Ctrl+^%c"

msgid "Unbound key: %s%c"
msgstr "A chave não foi atribuída para o %s%c"

msgid "Unbindable key: ^["
msgstr "Não é possível pressionar a tecla: ^["

