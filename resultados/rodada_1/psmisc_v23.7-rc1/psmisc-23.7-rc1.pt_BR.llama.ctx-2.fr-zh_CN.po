msgid ""
"Usage: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        output 8 bit clean streams.\n"
"    -n, --no-headers             don't display read/write from fd headers.\n"
"    -c, --follow                 peek at any new child processes too.\n"
"    -t, --tgid                   peek at all threads where tgid equals <pid>.\n"
"    -d, --duplicates-removed     remove duplicate read/writes from the output.\n"
"    -V, --version                prints version info.\n"
"    -h, --help                   prints this help.\n"
"\n"
"  Press CTRL-C to end output.\n"
msgstr ""
"Utilização do peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        lê dados sem o bit de paridade.\n"
"    -n, --no-headers             não exibe informações sobre leitura/gravação no cabeçalho do fd.\n"
"    -c, --follow                  também observa novos processos filhos criados.\n"
"    -t, --tgid                    observa todos os threads cujo tgid é igual ao <pid>.\n"
"    -d, --duplicates-removed     ignora leituras/gravações duplicadas na saída.\n"
"    -V, --version               exibe a versão do programa.\n"
"    -h, --help                   exibe esta mensagem de ajuda. \n"
"\n"
"Pressione CTRL+C para interromper."

