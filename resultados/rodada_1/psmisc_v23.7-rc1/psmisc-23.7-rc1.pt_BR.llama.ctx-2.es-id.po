msgstr "peekfd (PSmisc) %s"

msgid ""
"Copyright (C) 2007 Trent Waddington\n"
"\n"
msgstr "Tác quyền (C) de Trent Waddington, © 2007."

msgid ""
"Usage: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        output 8 bit clean streams.\n"
"    -n, --no-headers             don't display read/write from fd headers.\n"
"    -c, --follow                 peek at any new child processes too.\n"
"    -t, --tgid                   peek at all threads where tgid equals <pid>.\n"
"    -d, --duplicates-removed     remove duplicate read/writes from the output.\n"
"    -V, --version                prints version info.\n"
"    -h, --help                   prints this help.\n"
"\n"
"  Press CTRL-C to end output.\n"
msgstr ""
"Utilização do peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]:\n"
"    -8, --eight-bit-clean        exibe fluxos limpos de dados em 8 bits.\n"
"    -n, --no-headers             não mostra a leitura/escrevimento desde o cabeçalho fd.\n"
"    -c, --follow                 lê também qualquer novo processo filho que seja criado.\n"
"    -t, --tgid                   observa todos os threads em que tgid é igual ao <pid>.\n"
"    -d, --duplicates-removed     remove leituras/escrituras duplicadas da saída. \n"
"    -V, --version                exibe informações sobre a versão.\n"
"    -h, --help                   mostra este texto de ajuda.\n"
"Pulse CTRL-C para finalizar o output."

