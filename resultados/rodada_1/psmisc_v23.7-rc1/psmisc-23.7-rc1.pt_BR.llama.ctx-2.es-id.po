msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"       killall -l, --list\n"
"       killall -V, --version\n"
" \n"
"--exact          requer a coincidência exata para nomes muy largos\n"
"-I,--ignore-case    MAYÚS/minux indistinguibles para coincidencia de nombre del proceso\n"
"-g,--process-group  mata grupo de processos do mesmo vez que o próprio processo\n"
"-y,--younger-than   matar processos mais recentes que HORA_GIAN\n"
"-o,--older-than     matar processos mais antigos que HORA_GIAN\n"
"-i,--interactive    pedir confirmação antes de mata processos (opcional)\n"
"-l,--list           listagem dos nomes das sinapsis conhecidas\n"
"-q,--quiet          não escrever mensagens de erro (_im_)\n"
"-r,--regexp         interpretar NOMBRE como uma expressão regular estendida (TÊN)\n"
"-s,--signal SEÑAL   enviar esta señal em vez da SIGTERM\n"
"-u,--user USUARIO   matar apenas processos que executam atualmente com o usuário especificado\n"
"-v,--verbose        informar se a sinapse foi transmitida corretamente (opcional)\n"
"-V,--version        exibir versão do programa killall\n"
"-w,--wait           aguardar que os processos terminem de executar antes da saída\n"
"-n,--ns PID         coincidir com processos pertencentes ao mesmo espaço nominal (PID)"

