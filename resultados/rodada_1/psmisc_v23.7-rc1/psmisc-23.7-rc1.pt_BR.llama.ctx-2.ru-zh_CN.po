msgid ""
"Usage: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        output 8 bit clean streams.\n"
"    -n, --no-headers             don't display read/write from fd headers.\n"
"    -c, --follow                 peek at any new child processes too.\n"
"    -t, --tgid                   peek at all threads where tgid equals <pid>.\n"
"    -d, --duplicates-removed     remove duplicate read/writes from the output.\n"
"    -V, --version                prints version info.\n"
"    -h, --help                   prints this help.\n"
"\n"
"  Press CTRL-C to end output.\n"
msgstr ""
"Usado: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..] \n"
"    -8, --eight-bit-clean     saída de dados limpa para o formato 8 bits. \n"
"    -n, --no-headers         não exibir informações sobre cabeçalhos do fd ao ler/escrever. \n"
"    -c, --follow             observar também novos processos filhos. \n"
"    -t, --tgid                  monitorar todos os threads com o mesmo tgid igual a <pid>.\n"
"    -d, --duplicates-removed excluir operações de leitura/escrevimento duplicadas ao imprimir.\n"
"    -V, --version            mostrar informações sobre versão. \n"
"    -h, --help               apresentar esta ajuda. \n"
"\n"
"Pressione CTRL-C para encerrar."

