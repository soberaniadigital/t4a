msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'line_1': '-e,--exact          membutuhkan pencocokan tepat untuk setiap "
"nama panjang', 'line_2': '', 'line_3': ''}, {'line_1': '-I,--ignore-case"
"     pencocokan nama proses tidak memperhatikan besar huruf', 'line_2': '', "
"'line_3': ''}, {'line_1': '-g,--process-group   hentikan grup daripada "
"proses', 'line_2': '', 'line_3': ''}, {'line_1': '-y,--younger-than   "
"hentikan proses lebih muda dari WAKTU', 'line_2': '', 'line_3': ''}, "
"{'line_1': '-o,--older-than     hentikan proses lebih tua dari WAKTU', "
"'line_2': '', 'line_3': ''}, {'line_1': '-i,--interactive    tanya untuk "
"konfirmasi sebelum menghentikan', 'line_2': '', 'line_3': ''}, {'line_1': "
"'-l,--list           daftar seluruh nama sinyal yang diketahui', 'line_2': "
"'', 'line_3': ''}, {'line_1': '-q,--quiet          jangan tampilkan "
"komlain', 'line_2': '', 'line_3': ''}, {'line_1': '-r,--regexp         "
"interpretasikan NAMA sebagai sebuah ekstensi ekpresi regular', 'line_2': '',"
" 'line_3': ''}, {'line_1': '-s,--signal SINYAL  kirim sinyal ini daripada "
"SIGTERM', 'line_2': '', 'line_3': ''}, {'line_1': '-u,--user PENGGUNA  "
"hentikan hanya proses yang berjalan sebagai PENGGUNA', 'line_2': '', "
"'line_3': ''}, {'line_1': '-v,--verbose        laporkan jika sinyal telah "
"secara sukses dikirimkan', 'line_2': '', 'line_3': ''}, {'line_1': '-V,--"
"version         tampilkan informasi versi', 'line_2': '', 'line_3': ''}, "
"{'line_1': '-w,--wait           tunggu untuk proses untuk mati', 'line_2': "
"'', 'line_3': ''}, {'line_1': '-n,--ns PID         cocokkan dengan proses "
"milik ruang nama yang sama, dengan PID', 'line_2': '', 'line_3': ''}]"

