msgid ""
"Usage: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        output 8 bit clean streams.\n"
"    -n, --no-headers             don't display read/write from fd headers.\n"
"    -c, --follow                 peek at any new child processes too.\n"
"    -t, --tgid                   peek at all threads where tgid equals <pid>.\n"
"    -d, --duplicates-removed     remove duplicate read/writes from the output.\n"
"    -V, --version                prints version info.\n"
"    -h, --help                   prints this help.\n"
"\n"
"  Press CTRL-C to end output.\n"
msgstr ""
"Utilização do peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]:\n"
"    -8, --eight-bit-clean        limpa o fluxo de dados em 8 bits.\n"
"    -n, --no-headers             não exibe cabeçalhos ao ler/escrever no fd.\n"
"    -c, --follow                 observa também novos processos filhos e threads com tgid igual a <pid>.\n"
"    -t, --tgid                   observe todas as threads cujo tgid é o mesmo que <pid>.\n"
"    -d, --duplicates-removed     elimina operações duplicadas de leitura/escrita ao sair do programa.\n"
"    -V, --version                exibe informações sobre a versão da ferramenta.\n"
"    -h, --help                   mostra esta ajuda. Para encerrar o processo, pressione CTRL-C."

