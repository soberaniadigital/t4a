msgid ""
"Usage: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        output 8 bit clean streams.\n"
"    -n, --no-headers             don't display read/write from fd headers.\n"
"    -c, --follow                 peek at any new child processes too.\n"
"    -t, --tgid                   peek at all threads where tgid equals <pid>.\n"
"    -d, --duplicates-removed     remove duplicate read/writes from the output.\n"
"    -V, --version                prints version info.\n"
"    -h, --help                   prints this help.\n"
"\n"
"  Press CTRL-C to end output.\n"
msgstr ""
"Utilização: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..] \n"
"ação -8, --eight-bit-clean        xuất luồng dữ liệu sạch 8 bít. \n"
"não headers -\n"
"de--no-headers             n'affiche pas les lectures/écritures dans les en-têtes fd. \n"
"seguindo -c, --follow                 examinando também cada novo processo filho. \n"
"tgid -t, --tgid                  xem tất cả các threads mới nào chỉ có thể sống khi tgid bằng <pid>.\n"
"duplicates-removed -d, --duplicates-removed     gỡ lạc trùng lặp ra khỏi kết xuất. \n"
"versão -V, --version              affiche thông tin về phiên bản. \n"
"help -h, --help                  affiche hệ thống giúp này."

