msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'line_1': 'killall -l, --list', 'line_2': '-e,--exact          requiert "
"uma concordância porfeita dos nomes muito longos'}, {'line_3': '-I,--ignore-"
"case      pesquisa ignorando a diferença entre maiúsculas e minúsculas', "
"'lineincorrect': False, 'correction': True, 'explanation': \"'--ignore-case'"
" não deve ser traduzido como 'pesquisa', mas sim mantendo o termo original "
"em inglês para manter a precisão técnica.\"}, {'line_4': '-g,--process-group"
"  tue o grupo associado ao programa ao invés de quebrar individualmente', "
"'translation': 'tuer o processo pertencente à gerenciamento do mesmo'}, "
"{'line_5': '-y,--younger-than     tue os programas criados antes da hora "
"especificada HEURE', 'translation': 'exterminar as aplicações que foram "
"iniciadas após a data e horário definidos'}, {'line_6': '-o,--older-than"
"       tue as aplicações criadas antes da hora especificada HEURE', "
"'translation': 'exterminar as aplicações que foram iniciadas antes da data e"
" horário definidos'}, {'line_7': '-i,--interactive      solicitar "
"confirmação do usuário antes de exterminar programas', 'translation': 'pedir"
" a confirmação ao utilizador antes de terminar os processos'}, {'line_8': "
"'-l,--list             listagem dos nomes conhecidos dos sinais disponíveis "
"para uso com killall', 'translation': \"lista dos nomes das mensagens "
"reconhecidas que podem ser usadas em conjunto com o 'killall'\"}, {'line_9':"
" '-q,--quiet          não exibir avisos e erros ao utilizador', "
"'translation': 'não apresentar notificações ou mensagens de erro ao "
"utilizador'}, {'line_10': '-r,--regexp         NAME é interpretado como um "
"expressão regular estendida para uso com killall', 'translation': \"'--"
"regexp' interpreta o nome fornecido como uma expressão regular expandida, "
"que pode ser usada em conjunto com 'killall'\"}, {'line_11': '-s,--signal "
"SIGNAL  enviar um sinal personalizado ao invés de SIGTERM', 'translation': "
"\"'--signal' envia o sinal especificado pelo usuário em vez do padrão "
"'SIGTERM'\"}, {'line_12': '-u,--user UTILISATEUR  apenas exterminar "
"processos executados por um utilizador específico', 'translation': \"'--"
"user' limita o termino de programas que podem ser interrompidos a aqueles "
"pertencentes ao mesmo espaço de nomes do usuário fornecido\"}, {'line_13': "
"'-v,--verbose          informar se o sinal foi enviado com sucesso', "
"'translation': \"'--verbose' notifica sobre a entrega bem-sucedida do sinal "
"ao processo alvo\"}, {'line_14': \"-V,--version          exibir informações "
"de versão para o 'killall'\"}]"

