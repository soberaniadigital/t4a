msgstr ""
"[{'original_text': '-n, --numeric-sort', 'translated_text': 'urut keluaran "
"berdasarkan PID'}, {'original_text': '-N KIỂU, --ns-sort=KIỂU', "
"'translated_text': 'urut keluaran berdasarkan tipe ruang nama ini (cgroup, "
"ipc, mnt, net, pid, time, user, uts)'}, {'original_text': '-p, --show-pids',"
" 'translated_text': 'tampilkan PID; menyiratkan -c'}]"

msgid ""
