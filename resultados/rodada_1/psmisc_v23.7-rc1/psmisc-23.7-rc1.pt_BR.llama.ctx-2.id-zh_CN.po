msgid "peekfd (PSmisc) %s\n"
msgstr "peekfd (PSmisc) %s\n"

msgid ""
"Copyright (C) 2007 Trent Waddington\n"
"\n"
msgstr ""
"Privilégio de propriedade (copyright) da Trent Waddington COPYRIGHT © 2007"

msgid ""
"Usage: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        output 8 bit clean streams.\n"
"    -n, --no-headers             don't display read/write from fd headers.\n"
"    -c, --follow                 peek at any new child processes too.\n"
"    -t, --tgid                   peek at all threads where tgid equals <pid>.\n"
"    -d, --duplicates-removed     remove duplicate read/writes from the output.\n"
"    -V, --version                prints version info.\n"
"    -h, --help                   prints this help.\n"
"\n"
"  Press CTRL-C to end output.\n"
msgstr ""
"Utilização do peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]:\n"
"    -8, --eight-bit-clean        exibe fluxo de dados 8 bits limpo.\n"
"    -n, --no-headers             não mostra informações sobre o cabeçalho do fd para ler/escrever.\n"
"    -c, --follow                 xe mãosomente verifica novos processos filhos que tenham tgid igual ao <pid>.\n"
"    -t, --tgid                   exibe informações sobre todos os threads com o mesmo tgid do <pid>.\n"
"    -d, --duplicates-removed      remove duplicatas de leitura/escrevimento da saída.\n"
"    -V, --version                mostra a versão deste programa.\n"
"    -h, --help                   exibe este conjunto de ajuda. Para encerrar o output, pressione CTRL-C."

