msgid ""
"\n"
"Display a tree of processes.\n"
"\n"
msgstr "Hiênti cây tiến trình."

msgid ""
"  -a, --arguments     show command line arguments\n"
"  -A, --ascii         use ASCII line drawing characters\n"
"  -c, --compact-not   don't compact identical subtrees\n"
msgstr ""
"{'hiển thị tham số dòng lệnh': '-a, --arguments', 'dùng chữ cái ASCII để vẽ "
"dòng': '-A, --ascii', 'đừng nén gọn các cây con thụt đầu dòng': '-c, "
