msgid "Not enough memory."
msgstr "Não há mais memória disponível."

msgid "Setting a value for this tag is unsupported!"
msgstr "Não há suporte para atribuir um valor a este descriptor!"

msgid "Too few components specified (need %d, found %d)\n"
msgstr ""
"Chamado para indicar insuficiência de componentes especificados (%d "
"necessários, %d disponíveis)"

msgid "Numeric value expected\n"
msgstr "Valor numérico esperado"

msgid "Internal error. Please contact <%s>."
msgstr "Lỗi nội bộ. Hãy liên lạc với <%s>."

msgid "Not yet implemented!"
msgstr "Não foi possível concluir a operação!"

msgid "Warning; Too many components specified!"
msgstr "Aviso de falta de componentes especificados!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr "Existe muito dado EXIF (%i bytes). Somente %i bytes são permitidos."

msgid "Could not write '%s' (%s)."
msgstr "Não pode escrever \"%s\" (%s)."

msgid "Wrote file '%s'."
msgstr "Fez treino no arquivo \"%s\"."

msgid "EXIF entry '%s' "
msgstr "Mục tin EXIF « %s » "

msgid "(0x%x, '%s') "
msgstr "(0x%x, '%s') "

msgid "exists in IFD '%s':\n"
msgstr "existe no IFD «%s»:"

msgid "Adding entry..."
msgstr "Adicione o campo..."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr "IFD \"%s\" não contém nenhum sinal de interrupção para o termo \"%s\"!"

msgid "Could not open '%s' (%s)!"
msgstr "Não pode abrir \"%s\" (%s)!"

msgid "Could not determine size of '%s' (%s)."
msgstr "Não é possível determinar o tamanho do arquivo \"%s\" (%s)."

msgid "Could not read '%s' (%s)."
msgstr "Não é possível ler o arquivo %s (%s)."

msgid "IFD '%s' does not contain tag '%s'."
msgstr "Se o IFD \"%s\" não contém a marcação \"%s\"."

msgid "'%s' does not contain tag '%s'."
msgstr "%s"

msgid "'%s' does not contain a thumbnail!"
msgstr "Se o IFD '%s' não contém nenhuma imagem de modelo, avise ao usuário!"

msgid "Could not open '%s' for writing (%s)!"
msgstr "Não é possível abrir \"%s\" para escrita (%s)!"

msgid "EXIF tags in '%s':"
msgstr "Trilhas EXIF dentro de « %s » :"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr ""
"Não foi possível identificar o formato ou não há informações de MakerNote. "
"\n"

msgid "MakerNote does not contain any value.\n"
msgstr "A Makernote não contém valor."

msgid "Unknown Tag"
msgstr "Thẻ desconhecido"

msgid "Unknown value"
msgstr "Valor desconhecido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thẻ EXIF trong «%s» (thứ tự byte %<PRIuMAX>):"

msgid "Tag"
msgstr "marqueur"

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "As dados EXIF contêm uma miniatura (%i bytes)."

msgid "ThumbnailSize\t%i\n"
msgstr "Tamanho da miniatura %i"

msgid "Display software version"
msgstr "Hipervisor de interface gráfica"

msgid "Show IDs instead of tag names"
msgstr "Olá! Para identificar os marcadores, utilize as IDs em vez dos nomes."

msgid "Select tag"
msgstr "Escolha do marcador"

msgid "tag"
msgstr "etiqueta"

msgid "Select IFD"
msgstr "Seleção do IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Liste todos os marqueiros EXIF"

msgid "Show contents of tag MakerNote"
msgstr "Contém o conteúdo do marcação de nota MakerNote."

msgid "Remove tag or ifd"
msgstr "Borra o marcador ou IFD."

msgid "Show description of tag"
msgstr "Esta é a descrição atual do marcador."

msgid "Extract thumbnail"
msgstr "Truncar a imagem pequena"

msgid "Remove thumbnail"
msgstr "Remova a imagem pequena."

msgid "Insert FILE as thumbnail"
msgstr "Insira o arquivo como imagem de modelo."

msgid "FILE"
msgstr "TARJETA TIN"

msgid "Do not fix existing tags in files"
msgstr "Não faça alterações nos marcadores já presentes no arquivo."

msgid "Write data to FILE"
msgstr "Digite os dados no TAPE INI"

msgid "Value of tag"
msgstr "Valor do marcador"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Se não houver dados EXIF, crie-os."

msgid "Output in a machine-readable (tab delimited) format"
msgstr "Saída em um formato legível para máquina (delimitado por tabulação)"

msgid "Width of output"
msgstr "largura da saída de produto finalizado"

msgid "WIDTH"
msgstr "largura do rio"

msgid "Output in a XML format"
msgstr "Saída no formato XML"

msgid "Show debugging messages"
msgstr "Boa tarde, estamos apresentando mensagens de depuração."

msgid "Help options:"
msgstr "Opções de ajuda :"

msgid "Show this help message"
msgstr "Olá! Estou aqui para ajudar."

msgid "Display brief usage message"
msgstr "Olá! Aqui está uma breve nota de utilização."

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tabela"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD for inválido, as opções válidas são: \n"
" • 0\n"
" • 1\n"
" • EXIF\n"
" • GPS\n"
" • Tương hành."

msgid "Invalid tag '%s'!"
msgstr "Thẻ không hợp lệ \"%s\"!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar um marcador!"

msgid "You need to specify an IFD!"
msgstr "Você precisa especificar um IFD!"

msgid "Tag '%s' "
msgstr "Marqueur «%s» "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr "Chame um teto de proteção ou --create-exif para criar metadados EXIF."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s não pode ser lido ou não contém dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O formato XML não está disponível para notas do criador."
