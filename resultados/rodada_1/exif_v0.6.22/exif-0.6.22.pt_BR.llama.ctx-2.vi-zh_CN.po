msgstr "CANALHAO: a quantidade de componentes é excessiva!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr ""
"Excepcional quantidade de dados EXIF (%i byte). Permite apenas %i byte."

msgid "Could not write '%s' (%s)."
msgstr "Não é possível gravar no arquivo '%s' (%s)."

msgid "Wrote file '%s'."
msgstr "GHIU TIN %s."

