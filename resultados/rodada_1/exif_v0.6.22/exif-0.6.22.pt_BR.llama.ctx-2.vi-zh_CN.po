msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"IFD không hợp lệ '%s'. Các IFD hợp lệ là: \n"
" • 0\n"
" • 1\n"
" • EXIF\n"
" • GPS\n"
" • Interoperability (Tương hành)."

msgid "Invalid tag '%s'!"
msgstr "Thẻ không hợp lệ \"%s\"!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar um label!"

msgid "You need to specify an IFD!"
msgstr "Você precisa especificar um IFD!"

msgid "Tag '%s' "
msgstr "Thẻ \"%s\""

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Chamando a função para criar metadados EXIF no arquivo de entrada ou "
"-create-exif."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s"

msgid "XML format is not available for Maker Notes"
msgstr "O formato XML não é utilizado para notas do Makers Notes."
