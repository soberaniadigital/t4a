msgid "Not enough memory."
msgstr "Não há memória suficiente."

msgid "Setting a value for this tag is unsupported!"
msgstr "Não há suporte para a definição de um valor para esta marcação!"

msgid "Too few components specified (need %d, found %d)\n"
msgstr ""
"Chamado para indicar insuficiência de componentes (%d necessitados, %d "
"identificados)"

msgid "Numeric value expected\n"
msgstr "É necessário um valor numérico"

msgid "Internal error. Please contact <%s>."
msgstr "Erro de nível inferior. Por favor, entre em contato com <%s>."

msgid "Not yet implemented!"
msgstr "Não foi possível concluir a operação!"

msgid "Warning; Too many components specified!"
msgstr "CANALHA BAO: Há muito pouco informações sobre os componentes!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr "Existe muito dado EXIF (%i byte). O máximo é %i byte."

msgid "Could not write '%s' (%s)."
msgstr "Não foi possível escrever '%s' (%s)."

msgid "Wrote file '%s'."
msgstr "Foi feito treino na pasta %s."

msgid "EXIF entry '%s' "
msgstr "Mục tin EXIF »%s« "

msgid "(0x%x, '%s') "
msgstr "(0x%x, »%s«) "

msgid "exists in IFD '%s':\n"
msgstr "existiu no IFD »%s«:"

msgid "Adding entry..."
msgstr "Adicionar item..."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr "IFD \"%s\" não contém nenhuma marcação de '%s'!"

msgid "Could not open '%s' (%s)!"
msgstr "Não foi possível abrir o arquivo %s (%s)!"

msgid "Could not determine size of '%s' (%s)."
msgstr "Não foi possível determinar o tamanho do arquivo %s (%d)."

msgid "Could not read '%s' (%s)."
msgstr "Não foi possível ler o arquivo %s (%s)."

msgid "IFD '%s' does not contain tag '%s'."
msgstr "IFD \"%s\" não contém a marcação '%s'."

msgid "'%s' does not contain tag '%s'."
msgstr "O arquivo '%s' não contém a marcação de 'DE'."

msgid "'%s' does not contain a thumbnail!"
msgstr "Se o IFD \"%s\" não contém nenhuma imagem de exemplo!"

msgid "Could not open '%s' for writing (%s)!"
msgstr "Não foi possível abrir o arquivo %s para gravar (%s)!"

msgid "EXIF tags in '%s':"
msgstr "Thêm EXIF trong »%s«:"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr ""
"Não há informações sobre o formato ou não existe anotação do fabricante."

msgid "MakerNote does not contain any value.\n"
msgstr "MakerNote não contém valor."

msgid "Unknown Tag"
msgstr "Marcação desconhecida"

msgid "Unknown value"
msgstr "Valor desconhecido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thẻ EXIF trong »%s« (thứ tự byte %d):"

msgid "Tag"
msgstr ""
"marcação do termo 'thẻ' para o português brasileiro, considerando as "
"traduções anteriores e os critérios técnicos especificados."

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "Dados EXIF contêm uma imagem de exemplo (%i bytes)."

msgid "ThumbnailSize\t%i\n"
msgstr "Tamanho da prévisualização %i"

msgid "Display software version"
msgstr "Hipervisor de software em análise"

msgid "Show IDs instead of tag names"
msgstr "Hiêrên thị mã số cho tên thẻ"

msgid "Select tag"
msgstr "Escolha a marcação DE"

msgid "tag"
msgstr ""
"marcação do termo 'thẻ' para o português brasileiro, considerando as "
"traduções anteriores e os critérios técnicos especificados."

msgid "Select IFD"
msgstr "Escolha IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Listagem de todas as marcações EXIF"

msgid "Show contents of tag MakerNote"
msgstr "Contenido da nota do fabricante mostrar"

msgid "Remove tag or ifd"
msgstr "Remova a marcação ou o IFD"

msgid "Show description of tag"
msgstr "Descrição da marca atualizada do sinal"

msgid "Extract thumbnail"
msgstr "Truncar imagem pequena"

msgid "Remove thumbnail"
msgstr "remover a imagem pequena"

msgid "Insert FILE as thumbnail"
msgstr "Colar a imagem de referência na área do texto"

msgid "FILE"
msgstr "DATA DE TERMINO"

msgid "Do not fix existing tags in files"
msgstr "Não corrija marcações existentes em arquivos"

msgid "Write data to FILE"
msgstr "Digite dados na tabela de texto."

msgid "Value of tag"
msgstr "Valor da marcação do sinal"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Caso não haja EXIF dados, eles serão gerados automaticamente."

msgid "Output in a machine-readable (tab delimited) format"
msgstr "Xuất ra một định dạng cho máy đọc được (định giới bằng khoảng tab)"

msgid "Width of output"
msgstr "Chiêu róng kết xuất"

msgid "WIDTH"
msgstr "Rua"

msgid "Output in a XML format"
msgstr "Saída em formato XML"

msgid "Show debugging messages"
msgstr "Boa tarde, você recebeu uma mensagem de erro?"

msgid "Help options:"
msgstr "Túy chọn trợ giúp:"

msgid "Show this help message"
msgstr "Olá, este pedido de assistência é para você"

msgid "Display brief usage message"
msgstr "Aviso curto de assistência necessária"

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD não for híbrido EXIF/GPS, ele é inválido. Os IFDs válidos são: %d "
"(0), %d (1), EXIF, GPS e Tương hành."

msgid "Invalid tag '%s'!"
msgstr "Marking '%s' is not allowed!"

msgid "You need to specify a tag!"
msgstr "Você precisa marcar uma etiqueta!"

msgid "You need to specify an IFD!"
msgstr "Você precisa especificar um IFD!"

msgid "Tag '%s' "
msgstr "Marcação »%s« "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Digite o nome do arquivo de entrada ou --create-exif para adicionar "
"metadados EXIF."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s não pode ser lido ou está vazio de dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O XML não é utilizado para notas do Makers Notes."
