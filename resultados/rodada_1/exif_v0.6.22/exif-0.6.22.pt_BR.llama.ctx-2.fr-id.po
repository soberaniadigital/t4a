msgstr "Chame um teto de proteção ou --create-exif para criar metadados EXIF."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s"

msgid "XML format is not available for Maker Notes"
msgstr "O formato XML não está disponível para as notas do criador."
