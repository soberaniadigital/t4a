msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD for '%s', ele é inválido. Os IFD válidos são '0', '1', 'EXIF', "
"'GPS' e 'Tiovoltais'."

