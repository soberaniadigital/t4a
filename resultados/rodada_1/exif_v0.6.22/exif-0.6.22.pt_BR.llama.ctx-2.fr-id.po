msgstr "Thẻ không hợp lệ \"%s\"!"

msgid "You need to specify a tag!"
msgstr "É necessário especificar um marcador!"

msgid "You need to specify an IFD!"
msgstr "É necessário especificar um IFD!"

msgid "Tag '%s' "
msgstr "Marqueur « %s » "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

