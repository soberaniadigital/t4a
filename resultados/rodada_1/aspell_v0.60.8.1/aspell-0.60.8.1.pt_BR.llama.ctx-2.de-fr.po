msgstr "Verificar se as palavras são válidas."

msgid "create a backup file by appending \".bak\""
msgstr "Criar uma cópia de backup com a extensão '.bak'."

msgid "use byte offsets instead of character offsets"
msgstr "Use byte offsets instead of character offsets."

msgid "create missing root/affix combinations"
msgstr "erigir combinações de raiz e terminação ausentes"

msgid "keymapping for check mode: \"aspell\" or \"ispell\""
msgstr "Teclado de entrada para modo de verificação: 'aspell' ou 'ispell'"

msgid "reverse the order of the suggest list"
msgstr "Reihenfolge der Vorschlagsliste umdrehen"

msgid "suggest possible replacements"
msgstr "sugerir possíveis substituições"

msgid "time load time and suggest time in pipe mode"
msgstr "medir o tempo para carregar e sugerir no modo Pipe do GNU/Linux"

msgid ""
"This could also mean that the file \"%s\" could not be opened for reading or"
" does not exist."
msgstr ""
"Das pode também significar que a pasta de arquivo \"%s\" não pôde ser aberta"
" para leitura ou simplesmente não existe."

msgid "The Unicode code point U+%04X is unsupported."
msgstr "O caractere Unicode na posição U+%04X não é suportado."

msgid "Invalid UTF-8 sequence at position %ld."
msgstr "Sequência UTF-8 inválida na posição %ld."

msgid "Operation Not Supported: %what:1"
msgstr "Operação não suportada: %what:1"

msgid "The method \"%what:1\" is unimplemented in \"%where:2\"."
msgstr "A metodologia \"%what:1\" não foi implementada no local \"%where:2\"."

msgid "%file:1:"
msgstr "%file:1:"

msgid "The file \"%file:1\" can not be opened"
msgstr ""
"A ferramenta de localização do modo CLI para GNU/Linux não pode abrir a "
"pasta \"%file:1\"."

msgid "The file \"%file:1\" can not be opened for reading."
msgstr "A ferramenta de localização do guia não está presente."

msgid "The file \"%file:1\" can not be opened for writing."
msgstr ""
"A ferramenta de localização do sistema operacional GNU/Linux não pode abrir "
"a pasta \"%file:1\" para escrita."

msgid "The file name \"%file:1\" is invalid."
msgstr "O nome do arquivo »%file:1« é inválido."

msgid "The file \"%file:1\" is not in the proper format."
msgstr "A ficha de arquivo %file:1% não possui o formato correto."

msgid "The directory \"%dir:1\" can not be opened for reading."
msgstr "O diretório \"%dir:1\" não pode ser aberto para leitura."

msgid "The key \"%key:1\" is unknown."
msgstr "O chaveiro \"%key:1\" é desconhecido."

msgid "The value for option \"%key:1\" can not be changed."
msgstr "O valor da opção \"%key:1\" não pode ser alterado."

msgid "The key \"%key:1\" is not %accepted:2 and is thus invalid."
msgstr ""
"O chave \"%key:1\" não é aceita porque está diferente de %accepted:2 e, "
"portanto, inválida."

msgid ""
"The value \"%value:2\" is not %accepted:3 and is thus invalid for the key "
"\"%key:1\"."
msgstr ""
"O valor \"%value:2\" não é %accepted:3 e, portanto, para o campo de chave "
"\"%key:1\", está inválido."

msgid "The key \"%key:1\" is not a string."
msgstr "O chave \"%key:1\" não é uma cadeia de caracteres."

msgid "The key \"%key:1\" is not an integer."
msgstr "O chave \"%key:1\" não é um número inteiro."

msgid "The key \"%key:1\" is not a boolean."
msgstr "O chave \"%key:1\" não é um valor de verdade."

msgid "The key \"%key:1\" is not a list."
msgstr "O chave \"%key:1\" não é uma lista."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"reset-\"."
msgstr "O chave \"%key:1\" não pode ter parâmetros se for precedida por 'reset-'."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by an "
"\"enable-\"."
msgstr "O chave \"%key:1\" não pode ter parâmetros quando precedida por \"enable-\"."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by a \"dont-\""
" or \"disable-\"."
msgstr ""
"O chave \"%key:1\" não pode ter parâmetros se for precedida por \"dont-\" ou"
" \"disable-\"."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"clear-\"."
msgstr "O chave \"%key:1\" não pode ter parâmetros se for precedida por \"clear-\"."

msgid "The language \"%lang:1\" is not known."
msgstr "A linguagem \"%lang:1\" é desconhecida."

msgid "The soundslike \"%sl:2\" is not known."
msgstr "O som do termo \"%sl:2\" não é conhecido."

msgid "The language \"%lang:1\" is not supported."
msgstr "A linguagem \"%lang:1\" não é suportada."

msgid "No word lists can be found for the language \"%lang:1\"."
msgstr "Para a língua \"%lang:1\" não há disponibilidade de listas de palavras."

msgid "Expected language \"%lang:1\" but got \"%prev:2\"."
msgstr ""
"Linguagem esperada é »%lang:1«, mas foi encontrada a linguagem anterior "
"%prev:2."

msgid "Affix '%aff:1' is corrupt."
msgstr "O termo 'Endung »%aff:1«' está danificado."

msgid "The condition \"%cond:1\" is invalid."
msgstr "A condição \"%cond:1\" é inválida."

msgid ""
"The condition \"%cond:1\" does not guarantee that \"%strip:2\" can always be"
" stripped."
msgstr ""
"A condição \"%cond:1\" não garante que a remoção de '%strip:2' seja sempre "
"possível."

msgid ""
"The file \"%file:1\" is not in the proper format. Expected the file to be in"
" \"%exp:2\" not \"%got:3\"."
msgstr ""
"A ficha de dados \"%file:1\" não possui o formato correto. Ela foi esperada "
"em \"%exp:2\", e não em \"%got:3\". Para obter mais informações, tente ' %s "
"--help'."

msgid "The encoding \"%encod:1\" is not known."
msgstr "A codificação '\\%encod:1' não é conhecida."

msgid "The encoding \"%encod:1\" is not supported."
msgstr "A codificação '\\%encod:1' não é suportada."

msgid "The conversion from \"%encod:1\" to \"%encod2:2\" is not supported."
msgstr "A conversão de '\\%encod:1' para '\\%encod:2' não é suportada."

msgid "The string \"%str:1\" is invalid."
msgstr "A cadeia de caracteres '##str:1' é inválida."

msgid "The word \"%word:1\" is invalid."
msgstr "O termo \"%word:1\" é inválido."

msgid "The affix flag '%aff:1' is invalid for word \"%word:2\"."
msgstr "O símbolo de terminação \"%aff:1\" é inválido para o termo \"%word:2\"."

msgid "The affix flag '%aff:1' can not be applied to word \"%word:2\"."
msgstr ""
"O símbolo de terminação do flag \"%aff:1\" não pode ser aplicado ao palavra "
"\"%word:2\"."

msgid "not a version number"
msgstr "Esta não é uma versão da linguagem de programação."

msgid "dlopen returned \"%return:1\"."
msgstr "falha ao abrir módulo com dlopen gab »%return:1« de volta."

