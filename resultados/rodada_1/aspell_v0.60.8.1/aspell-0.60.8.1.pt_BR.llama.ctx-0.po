msgid "a number between 0 and 1"
msgstr "Uma número entre 0 e 1"

msgid "in the form \"<name> <value>\""
msgstr "Na forma '&lt;Nome> &lt;Valor>'"

msgid "string"
msgstr "cadeia de caracteres"

msgid "integer"
msgstr "número inteiro"

msgid "boolean"
msgstr "Valor de verdade"

msgid "list"
msgstr "Lista"

msgid "either \"true\" or \"false\""
msgstr "Entweder 'verdadeiro' (true) ou 'falso' (false)"

msgid "a positive integer"
msgstr "uma número inteiro positivo"

