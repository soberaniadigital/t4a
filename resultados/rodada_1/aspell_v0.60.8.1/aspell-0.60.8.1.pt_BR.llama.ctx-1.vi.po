msgstr "# mặc định: "

msgid ""
"\n"
"#######################################################################\n"
"#\n"
"# Filter: %s\n"
"#   %s\n"
"#\n"
"# configured as follows:\n"
"\n"
msgstr ""
"Bloco de filtragem: %s\n"
"   %s\n"
"\n"
"Foi configurado da seguinte forma:\n"

msgid "ASPELL_CONF env var"
msgstr "ASPELL_CONF Umgebungsvariable (variável de ambiente do Aspell)"

msgid "main configuration file"
msgstr "arquivo de configuração principal"

msgid "location of main configuration file"
msgstr "Nome da tabela de configuração principal"

msgid "location of language data files"
msgstr "Nome dos arquivos de dados linguísticos"

msgid "create dictionary aliases"
msgstr "gerar aliases de palavras no dicionário"

msgid "location of the main word list"
msgstr "Nome da lista principal de palavras"

msgid "encoding to expect data to be in"
msgstr "codificação, na qual os dados são esperados para ocorrer"

msgid "add or removes a filter"
msgstr "adiciona ou remove um filtro"

msgid "path(s) aspell looks for filters"
msgstr "Pfade(e) nos quais aspell procura filtros."

msgid "filter mode"
msgstr "modo de filtragem"

msgid "extra dictionaries to use"
msgstr "từ điển thêm cần dùng"

msgid "location for personal files"
msgstr "Nome para arquivos pessoais"

msgid "ignore words <= n chars"
msgstr "ignore words with <= n characters"

msgid "ignore accents when checking words -- CURRENTLY IGNORED"
msgstr "ignorar acentuação ao verificar -- EM QUEIMADA PARTICIPAÇÃO LÓGICA"

msgid "ignore case when checking words"
msgstr "ignore diferença de maiúsculas e minúsculas ao verificar"

msgid "ignore commands to store replacement pairs"
msgstr "ignore comandos, pares de substituição para serem salvos."

msgid "extra information for the word list"
msgstr "informação adicional para a lista de palavras"

msgid "keyboard definition to use for typo analysis"
msgstr "Definição de tela para análise dos erros de digitação."

msgid "language code"
msgstr ""
"código de linguagem (VI é o acrônimo para Việt ngữ, que significa 'Vi')"

msgid "deprecated, use lang instead"
msgstr "obsoleto, usem 'lang' em vez disso."

msgid "location of local language data files"
msgstr "nome dos arquivos de dados linguísticos locais"

msgid "base name of the main dictionary to use"
msgstr "Nome do principal dicionário de palavras"

msgid "set module name"
msgstr "nome do módulo definir"

msgid "search order for modules"
msgstr "Suchreihenfolge für Module"

msgid "enable Unicode normalization"
msgstr "Ativar normalização Unicodenormalizacao"

msgid "Unicode normalization required for current lang"
msgstr "A normalização Unicodenormalizada é necessária para a língua atual."

msgid "Unicode normalization form: none, nfd, nfc, comp"
msgstr ""
"Forma de normalização Unicode Não Formada (NFD), Normalizada sem formatação "
"adicional (NFC), Comparações, e Conjunto completo"

msgid "avoid lossy conversions when normalization"
msgstr "Evite conversões de erro ao normalizar para prevenir perda de dados."

msgid "personal configuration file"
msgstr "arquivos de configuração pessoal"

msgid "personal dictionary file name"
msgstr "Nome do seu dicionário pessoal"

msgid "prefix directory"
msgstr "diretório raiz"

msgid "replacements list file name"
msgstr "Nome do arquivo de substituição da lista"

msgid "consider run-together words legal"
msgstr "aceitam palavras compostas"

msgid "maximum number that can be strung together"
msgstr "soma máxima de palavras compostas"

msgid "minimal length of interior words"
msgstr "mínima extensão dos termos internos da sequência de palavras"

msgid "consider camel case words legal"
msgstr "Wörter in CamelCase como válidos aceitos"

msgid "save replacement pairs on save all"
msgstr ""
"bei »Todos os dados salvarem, incluindo as pares de substituição também\"."

msgid "set the prefix based on executable location"
msgstr "fix prefix based on the program's name set up"

msgid "size of the word list"
msgstr "tamanho da lista de palavras"

msgid "no longer used"
msgstr "não é mais utilizado"

msgid "suggestion mode"
msgstr "chave de sugestão"

msgid "use typo analysis, override sug-mode default"
msgstr "Realizar análise de erros típicos em vez do modo sugerido por padrão"

msgid "use replacement tables, override sug-mode default"
msgstr "uso de tabelas de substituição em vez do modo de sugestão"

msgid "characters to insert when a word is split"
msgstr ""
"quando um caractere for adicionado, se uma palavra estiver sendo separada"

msgid "use personal, replacement & session dictionaries"
msgstr "use personalized, replacement and session dictionaries"

msgid "search path for word list information files"
msgstr ""
"Pasta de pesquisa para arquivos com informações sobre listas de palavras"

msgid "enable warnings"
msgstr "ativar alertas"

msgid "indicator for affix flags in word lists -- CURRENTLY IGNORED"
msgstr ""
"Indicador para flags de conclusão em listas de palavras -- MODAISMENTE "
"INATÁVEL"

msgid "use affix compression when creating dictionaries"
msgstr "Endungen beim Erzeugen von Wörterbüchern komprimieren"

msgid "remove invalid affix flags"
msgstr "remover flags de terminação inválidos"

msgid "attempts to clean words so that they are valid"
msgstr "palavras que foram limpas para garantir sua validade"

msgid "compute soundslike on demand rather than storing"
msgstr "Calcular o Wortklang em vez de armazená-lo, conforme necessário."

msgid "partially expand affixes for better suggestions"
msgstr "Parte dos anexos para melhores sugestões é expandida parcialmente."

msgid "skip invalid words"
msgstr "palavras inválidas ignoradas"

msgid "check if affix flags are valid"
msgstr "Verifique se os flags de finalização são válidos."

msgid "check if words are valid"
msgstr "Prüfen, ob die Wörter gültig sind."

msgid "create a backup file by appending \".bak\""
msgstr "Criar backup com a extensão '.bak' adicionando ao arquivo expandido"

msgid "use byte offsets instead of character offsets"
msgstr "uso de offsets em bytes ao invés de caracteres"

msgid "create missing root/affix combinations"
msgstr ""
"eram criadas combinações de palavras sem a terminação do radical e da "
"morfologia associada"

msgid "keymapping for check mode: \"aspell\" or \"ispell\""
msgstr "Tecnologia de Tastenmape para Modo de Testes: 'aspell' ou 'ispell'"

msgid "reverse the order of the suggest list"
msgstr "Reihenfolge der Vorschlagsliste umdrehen"

msgid "suggest possible replacements"
msgstr "sugerimos substituições possíveis"

msgid "time load time and suggest time in pipe mode"
msgstr "medir o tempo para carregar e sugerir no modo Pipe do GNU/Linux"

msgid ""
"This could also mean that the file \"%s\" could not be opened for reading or"
" does not exist."
msgstr ""
"Das também poderia significar que a tabela de dados »%s« não pôde ser aberta"
" para leitura ou simplesmente não existe."

msgid "The Unicode code point U+%04X is unsupported."
msgstr ""
"Onde está localizado o ponto de codificação Unicode U+%04X não é suportado."

msgid "Invalid UTF-8 sequence at position %ld."
msgstr "Sequência UTF-8 inválida na posição %ld."

msgid "Operation Not Supported: %what:1"
msgstr "Operação não suportada: %what:1."

msgid "The method \"%what:1\" is unimplemented in \"%where:2\"."
msgstr "A metodologia \"%what:1\" não está implementada no local \"%where:2\"."

msgid "%file:1:"
msgstr "%file:1:"

msgid "The file \"%file:1\" can not be opened"
msgstr "A tabela de dados »%file:1« não pode ser aberta."

msgid "The file \"%file:1\" can not be opened for reading."
msgstr "A tabela de dados »%file:1« não pode ser aberta para leitura."

msgid "The file \"%file:1\" can not be opened for writing."
msgstr "A tabela de dados \"%file:1\" não pode ser aberta para escrita."

msgid "The file name \"%file:1\" is invalid."
msgstr "O nome do arquivo '%file:1' não é válido."

msgid "The file \"%file:1\" is not in the proper format."
msgstr "A ficheiro %file:1 não possui o formato correto."

msgid "The directory \"%dir:1\" can not be opened for reading."
msgstr "Não é possível abrir o diretório \"%dir:1\" para leitura."

msgid "The key \"%key:1\" is unknown."
msgstr "O chaveiro \"%key:1\" é desconhecido."

msgid "The value for option \"%key:1\" can not be changed."
msgstr "O valor da opção \"%key:1\" não pode ser alterado."

msgid "The key \"%key:1\" is not %accepted:2 and is thus invalid."
msgstr "O chave \"%key:1\" não é aceita como %accepted:2 e, portanto, inválida."

msgid ""
"The value \"%value:2\" is not %accepted:3 and is thus invalid for the key "
"\"%key:1\"."
msgstr ""
"O valor \"%value:2\" não é aceito como %accepted:3 e, portanto, está "
"incompatível com o campo de chave \"%key:1\"."

msgid "The key \"%key:1\" is not a string."
msgstr "O chave \"%key:1\" não é uma cadeia de caracteres."

msgid "The key \"%key:1\" is not an integer."
msgstr "O chave \"%key:1\" não é um número inteiro."

msgid "The key \"%key:1\" is not a boolean."
msgstr "O chave \"%key:1\" não é um valor verdadeiro."

msgid "The key \"%key:1\" is not a list."
msgstr "O chave \"%key:1\" não é uma lista."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"reset-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por "
"\"reset-\" (reiniciar)."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by an "
"\"enable-\"."
msgstr ""
"O chave \"%key:1\" não pode aceitar parâmetros quando precedida por "
"\"enable-\" (força)."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by a \"dont-\""
" or \"disable-\"."
msgstr ""
"Chave \"%key:1\" não pode conter parâmetros quando precedida por \"dont-\" "
"(não) ou \"disable-\" (desligar)."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"clear-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por "
"\"clear-\" (limpar)."

msgid "The language \"%lang:1\" is not known."
msgstr "A linguagem \"%lang:1\" é desconhecida."

msgid "The soundslike \"%sl:2\" is not known."
msgstr "O som do termo '\\%sl:2' não é conhecido."

msgid "The language \"%lang:1\" is not supported."
msgstr "A linguagem \"%lang:1\" não é suportada."

msgid "No word lists can be found for the language \"%lang:1\"."
msgstr "Não é possível encontrar listagens de palavras para a língua \"%lang:1\"."

msgid "Expected language \"%lang:1\" but got \"%prev:2\"."
msgstr "Linguagem esperada é '%lang:1', mas recebida foi '%prev:2'."

msgid "Affix '%aff:1' is corrupt."
msgstr "O termo '»%aff:1«' está danificado."

msgid "The condition \"%cond:1\" is invalid."
msgstr "A condição \"%cond:1\" não é válida."

msgid ""
"The condition \"%cond:1\" does not guarantee that \"%strip:2\" can always be"
" stripped."
msgstr ""
"A condição \"%cond:1\" não garante que a operação de remoção da parte final,"
" representada por \"%strip:2\", seja sempre possível."

msgid ""
"The file \"%file:1\" is not in the proper format. Expected the file to be in"
" \"%exp:2\" not \"%got:3\"."
msgstr ""
"A ficheiro \"%file:1\" não possui o formato correto. O esperado era uma "
"cópia em \"%exp:2\", e não em \"%got:3\"."

msgid "The encoding \"%encod:1\" is not known."
msgstr "A codificação '»%encod:1«' não é conhecida."

msgid "The encoding \"%encod:1\" is not supported."
msgstr "A codificação '\\%encod:1' não é suportada."

msgid "The conversion from \"%encod:1\" to \"%encod2:2\" is not supported."
msgstr "A conversão de '»%encod:1«' para '»%encod:2«' não é suportada."

msgid "The string \"%str:1\" is invalid."
msgstr "A sequência de caracteres '##str:1' não é válida."

msgid "The word \"%word:1\" is invalid."
msgstr "O termo \"%word:1\" não é válido."

msgid "The affix flag '%aff:1' is invalid for word \"%word:2\"."
msgstr ""
"O uso do termo de aférese 'C%aff:1' é inválido para o termo 'C%word:2'."

msgid "The affix flag '%aff:1' can not be applied to word \"%word:2\"."
msgstr "O cópia afixo '%aff:1' não pode ser aplicada ao termo '%word:2'."

msgid "not a version number"
msgstr "Esta não é uma versão numérica"

msgid "dlopen returned \"%return:1\"."
msgstr ""
"lendo o soquete do módulo 'gab' retornou com erro. Por favor, verifique se "
"está utilizando a sintaxe correta para referenciá-lo."

msgid "The file \"%filter:1\" does not contain any filters."
msgstr "A tabela de dados ' %filter%1%' não contém nenhum filtro."

msgid "The filter \"%filter:1\" does not exist."
msgstr "O filtro \"%filter:1\" não existe."

msgid "Confused by version control."
msgstr "Confuso pela versão de controle de versão."

msgid "Aspell version does not match filter's requirement."
msgstr "A versão do Aspell não atende aos requisitos do filtro."

msgid "Filter option already exists."
msgstr "A opção de filtragem já existe."

msgid "Use option modifiers only within named option."
msgstr "Utilize modificadores de opções somente dentro das opções nomeadas."

msgid "Option modifier unknown."
msgstr "Opção modificadora desconhecida."

msgid "Error setting filter description."
msgstr "Erro ao definir a descrição do filtro."

msgid "Empty option specifier."
msgstr "Opções não especificadas."

msgid "Option \"%option:1\" possibly specified prior to filter."
msgstr "A opção »%option:1« pode ter sido especificada antes do filtro."

msgid "Unknown mode description key \"%key:1\"."
msgstr "Khóa mô tả chế độ desconhecido \"%key:1\"."

msgid "Expecting \"%modekey:1\" key."
msgstr "Chave de segurança »%modekey:1« esperada."

msgid "Version specifier missing key: \"aspell\"."
msgstr "Falta de versão do pacote 'aspell'."

msgid "Aspell version does not match mode's requirement."
msgstr "A versão do Aspell não atende às exigências do filtro."

msgid "Missing magic mode expression."
msgstr "Oração do »Modo de Magia« faltante."

msgid "Empty extension at char %char:1."
msgstr "Expansão em branco na sequência de caracteres %char:1."

msgid "\"%mode:1\" error"
msgstr "Modo de operação inválido \"%mode:1\" - Erro"

msgid "Unknown mode: \"%mode:1\"."
msgstr "Modo desconhecido: »%mode:1«."

msgid "\"%mode:1\" error while extend Aspell modes. (out of memory?)"
msgstr ""
"Erro ao expandir a opção Aspell no modo %mode:1. (Possível falta de "
"memória?)."

msgid "\"%mode:1\": no start for magic search given for magic \"%magic:2\"."
msgstr ""
"»%mode:1«: Não foi especificado o modo de pesquisa mágica para a entrada "
"'»%magic:2«'."

msgid "\"%mode:1\": no range for magic search given for magic \"%magic:2\"."
msgstr "»%mode:1«: Não há seção para pesquisa de módulos magiais »%magic:2«."

msgid "\"%mode:1\": no magic expression available for magic \"%magic:2\"."
msgstr "«%mode:1»: nenhum código mágico disponível para \"%magic:2\"."

msgid ""
"\"%mode:1\": Magic \"%magic:2\": bad regular expression after location "
"specifier; regexp reports: \"%regerr:3\"."
msgstr ""
"»%mode:1«: Magic »%magic:2«: Expressão regular inválida após a localização; "
"regexp diz isso: »%regerr:3«."

msgid "\"%expression:1\" is not a valid regular expression."
msgstr "«%expression:1» não é um expressão regular válida."

msgid "Unhandled Error: "
msgstr "Erro não gerenciado: \""

msgid "Error: %s\n"
msgstr "Lỗi: %s"

msgid "Error: "
msgstr "Lỗi: "

msgid "enter Email mode."
msgstr ""
"Você está no modo de e-mail? Se não, vá para o chaveiro do protocolo de "
"transferência eletrônica."

msgid "enter HTML mode."
msgstr "Vou ao modo HTML."

msgid "enter TeX mode."
msgstr "Vou ao modo TeX."

msgid "enter Nroff mode."
msgstr "Troque para modo nroff."

msgid "enter Markdown mode."
msgstr "Em modo Markdown, altere para o chaveiro."

msgid "Invalid Option: %s"
msgstr "Opção inválida: %s"

msgid "'%s' does not take any parameters."
msgstr "A opção »%s« não aceita parâmetros."

msgid "You must specify a parameter for \"%s\"."
msgstr "Sua senhora, por favor, informe o valor para o parâmetro '%s'."

msgid "You must specify an action"
msgstr "Sua ação deve ser especificada."

msgid "Unknown Action: %s"
msgstr "Ação desconhecida: %s"

msgid "Error: You must specify at least %d parameters for \"%s\".\n"
msgstr "Lỗi: é necessário informar ao menos %d parâmetros para a opção »%s«."

msgid "Invalid Input"
msgstr "Entrada inválida"

msgid "WARNING: Unable to enter Nroff mode: %s\n"
msgstr "Cênh B¡o : nótamente não pode entrar no modo Nroff: %s"

msgid "Time to load word list: "
msgstr "Tempo para carregar a lista de palavras:"

msgid "Suggestion Time: %f\n"
msgstr "Tempo de apresentação do projeto: %f"

msgid "You must specify a file name."
msgstr "Sua senhora, é necessário que você indique o nome do arquivo."

msgid "Only one file name may be specified."
msgstr "Só pode haver um nome para o arquivo."

msgid "Could not open the file \"%s\" for reading"
msgstr "Não foi possível abrir a tabela de dados \"%s\" para leitura."

msgid "Invalid keymapping: %s"
msgstr "Ungültige Tastaturbelegung: %s"

msgid "\"%s\" is not a regular file"
msgstr "« %s » não é uma arquivo normal."

msgid "Could not open the file \"%s\" for writing. File not saved."
msgstr ""
"Não foi possível abrir a tabela de dados \"%s\" para gravação. Tabela não "
"salva."

msgid "Ignore"
msgstr "Ignorar"

msgid "Ignore all"
msgstr "Ignorar todas as solicitações ignoradas."

msgid "Replace"
msgstr "substituir"

msgid "Replace all"
msgstr "todos os elementos serão substituídos."

msgid "Add"
msgstr "Adicionar"

msgid "Add Lower"
msgstr "Adicione em letras minusculas"

msgid "Abort"
msgstr "Húy bỏ"

msgid "Exit"
msgstr "Terminar"

msgid "Are you sure you want to abort (y/n)? "
msgstr "Está certo que deseja encerrar a operação (j/n)? "

msgid "Yy"
msgstr "Jj"

msgid "With: "
msgstr "Mit: "

msgid "Sorry that is an invalid choice!"
msgstr "Desculpe, mas essa é uma escolha inválida!"

msgid "Can't merge a master word list yet. Sorry."
msgstr "Desculpe, mas não é possível unir a lista de palavras-chave master."

msgid "Sorry \"create/merge personal\" is currently unimplemented.\n"
msgstr ""
"Desculpe, a funcionalidade para criar ou unir sua lista pessoal ainda não "
"foi implementada."

msgid "Sorry I won't overwrite \"%s\""
msgstr "Desculpe, mas eu não vou substituir »%s«"

msgid "Sorry \"create/merge repl\" is currently unimplemented.\n"
msgstr ""
"Desculpe, a funcionalidade de criação e junção da lista de substituições "
"ainda não foi implementada."

msgid "\"%s\" is not a valid flag for the \"munch-list\" command."
msgstr "A opção \"%s\" não é válida para o comando de lista munch (munch-list)."

msgid "Usage: aspell [options] <command>"
msgstr "Aufruf: aspell [Opções] <Comando>"

msgid "<command> is one of:"
msgstr "<lệnh> é um dos comandos do sistema:"

msgid "  -?|usage         display a brief usage message"
msgstr "  -?|usage         Exibir texto de ajuda breve sobre o _uso_"

msgid "  help             display a detailed help message"
msgstr "Esteja no menu de ajuda para obter assistência detalhada."

msgid "  -c|check <file>  spellchecks a file"
msgstr ""
"  -c|check <tarefa_de_verificação>  _kiểm tra_ tarea nesta, verificando se "
"ela está correta."

msgid "  -a|pipe          \"ispell -a\" compatibility mode"
msgstr ""
"chave de opção -a|pipe\n"
"    compatibilidade com o modo 'ispell -a' (óculos dando)"

msgid "  [dump] config    dumps the current configuration to stdout"
msgstr ""
"  [dump] config    Gere a cadeia de caracteres atual da configuração na "
"saída padrão"

msgid "  config <key>     prints the current value of an option"
msgstr ""
"config <khóa>     Gibt den aktuellen Wert einer Option aus (_carga de "
"configuração_)"

msgid "  [dump] dicts | filters | modes"
msgstr " [dump] dicionários | filtros | modos"

msgid "    lists available dictionaries / filters / filter modes"
msgstr ""
"    Lista disponíveis dos dicionários / filtros / modos de filtrar são:\n"

msgid "[options] is any of the following:"
msgstr "[tùy_chọn ...] pode conter qualquer número de as seguintes:"

msgid ""
"  list             produce a list of misspelled words from standard input"
msgstr "Lista de palavras escritas incorretamente da entrada padrão emitidas."

msgid ""
"  soundslike       returns the sounds like equivalent for each word entered"
msgstr ""
"soundslike       trarLhida o som como se fosse _como_ ouvido a cada palavra "
"digitada"

msgid "  munch            generate possible root words and affixes"
msgstr ""
"gerar móduos e morfemas possíveis a partir de raízes (têm em comum) e afixos"
" (_nhai_)"

msgid "  expand [1-4]     expands affix flags"
msgstr "expande [1-4] Endungskennzeichen erweitern"

msgid ""
"  clean [strict]   cleans a word list so that every line is a valid word"
msgstr ""
"limpar [estrito]   _xoá sạch_ lista de palavras, para que cada linha seja uma palavra válida\n"
"(stricto)"

msgid "  -v|version       prints a version line"
msgstr ""
" -v|versão       Mostra uma linha com informações de versão em formato JSON"

msgid "  munch-list [simple] [single|multi] [keep]"
msgstr ""
"munch-list [simple] [single|multi] [keep] (lista de mordom-s, simples, "
"unico, multi)"

msgid "    reduce the size of a word list via affix compression"
msgstr "Reduza a §grão da lista de palavras com sufixos comprimidos."

msgid "  conv <from> <to> [<norm-form>]"
msgstr "conv <von> <nach> [<Normalform>] (_conversão_)"

msgid "    converts from one encoding to another"
msgstr "Convertemos de uma codificação para outra."

msgid "  norm (<norm-map> | <from> <norm-map> <to>) [<norm-form>]"
msgstr ""
"norm (<mapa de normas> | <este> <mapa de normas> <outro>) [<forma "
"normalizada>]"

msgid "    perform Unicode normalization"
msgstr "Ativar normalização para o padrão Unicode único"

msgid "  dump|create|merge master|personal|repl [<name>]"
msgstr "dump|create|merge master|personal|repl [<nome>]"

msgid ""
"    dumps, creates or merges a master, personal, or replacement dictionary."
msgstr ""
"    Dump da lista principal (Haupt-) - ou personal/substituição, criar ou "
"misturar."

msgid ""
"  <norm-form>      normalization form to use, either none, internal, or "
"strict"
msgstr ""
"ZU utilizar a normalização de dados conforme escolhido, seja como 'nenhum', "
"'interno' ou 'estrito'. Para mais informações sobre as formas disponíveis e "
"suas aplicações específicas em sistemas Linux, consulte o manual do sistema."

msgid ""
"\n"
"Aspell %s.  Copyright 2000-2023 by Kevin Atkinson.\n"
"\n"
msgstr "Aspell %s. Copyright 2000–2 philosophia de Kevin Atkinson.\n"

msgid ""
"Available Dictionaries:\n"
"    Dictionaries can be selected directly via the \"-d\" or \"master\"\n"
"    option.  They can also be selected indirectly via the \"lang\",\n"
"    \"variety\", and \"size\" options.\n"
msgstr ""
"Vocabularios disponíveis: \n"
"    Você pode escolher dicionários diretamente com a opção \" -d \" ou \" master\". \n"
"Outras maneiras incluem as opções \" lang\", \" variety\" e \" size\"."

msgid ""
"Available Filters (and associated options):\n"
"    Filters can be added or removed via the \"filter\" option.\n"
msgstr ""
"Blocos de filtragem (e opções associadas): \n"
"    É possível adicionar ou remover blocos com a tampa 'filter'."

msgid ""
"\n"
"  %s filter: %s\n"
msgstr "%s filtro: %s"

msgid ""
"Available Filter Modes:\n"
"    Filter Modes are reconfigured combinations of filters optimized for\n"
"    files of a specific type. A mode is selected via the \"mode\" option.\n"
"    This will happen implicitly if Aspell is able to identify the file\n"
"    type from the extension, and possibility the contents, of the file.\n"
msgstr ""
"Modos de filtragem disponíveis: \n"
"\n"
"Os modos de filtração são combinações personalizadas de diferentes filtros, otimizados para tipos específicos de arquivos. Você pode definir o modo de filtro usando a opção 'mode'. Se não for especificado, Aspell tentará determinar o tipo correto do arquivo e seu modo correspondente com base na extensão da pasta e (possivelmente) no conteúdo dentro dela. \n"
"\n"

