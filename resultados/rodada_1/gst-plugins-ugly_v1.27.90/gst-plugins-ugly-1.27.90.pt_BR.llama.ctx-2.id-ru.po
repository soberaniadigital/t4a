msgid "Could not read from CD."
msgstr "Tenha em vista ler do CD."

msgid "Could not open CD device for reading."
msgstr "Tenha em mente abrir o dispositivo de CD para leitura."

msgid "Disc is not an Audio CD."
msgstr "Cakram bukan CD Audio."

msgid "Could not open DVD"
msgstr "Tenha em mente abrir o DVD."

msgid "Could not open DVD title %d"
msgstr "Tenha em mente abrir o título do DVD %d."

msgid "Failed to go to chapter %d of DVD title %d"
msgstr ""
"Não foi possível percorrer para a babai %d do DVD com número de registro %d."

msgid ""
"Could not open DVD title %d. Interactive titles are not supported by this "
"element"
msgstr ""
"Tak dapat membuka judul DVD %d. Judul interaktif tidak didukung oleh elemen "
"ini"

msgid ""
"Could not read DVD. This may be because the DVD is encrypted and a DVD "
"decryption library is not installed."
msgstr ""
"Tenha em mente que é necessário instalar o software de decodificação para "
"ler um DVD. Isso se deve ao fato do DVD estar criptografado e a biblioteca "
"de descriptografia não estando presente."

msgid "Could not read DVD."
msgstr "Tenha em mente ler o DVD."

msgid "This stream contains no data."
msgstr "Arus ini não contém dados."
