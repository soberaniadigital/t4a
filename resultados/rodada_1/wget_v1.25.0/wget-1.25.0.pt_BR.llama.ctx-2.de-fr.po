msgstr ""
"GnuTLS: valor %d para o parâmetro 'secure-protocol' não está implementado"

msgid ""
"GnuTLS: Cannot set prio string directly. Falling back to default priority.\n"
msgstr ""
"GnuTLS: não é possível definir diretamente a prioridade. Utilize a "
"prioridade padrão como substituto."

msgid "ERROR"
msgstr "ОШИБКА"

msgid "WARNING"
msgstr "PREDÚPRAREJEITADE"

msgid "%s: No certificate presented by %s.\n"
msgstr "%s: Não há certificado apresentado por %s. (Sem Certificado)"

