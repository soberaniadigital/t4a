msgstr "Заголовок last-modified inválido — horários de modificação ignorados."

msgid ""
"Server file no newer than local file %s -- not retrieving.\n"
"\n"
msgstr ""
"Arquivo no servidor não é mais recente do que o arquivo local %s -- nenhum "
"download."

msgid "The sizes do not match (local %s) -- retrieving.\n"
msgstr ""
"Os tamanhos dos arquivos não são os mesmos (tamanho local %s) -- nova carga."

msgid "Remote file is newer, retrieving.\n"
msgstr "O arquivo remoto é mais recente, carregando."

