msgstr ""
"       --random-file=FILE        arquivo com dados aleatórios para "
"inicializar o gerador de números pseudoaleatórios SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=СТРОКА         Designar STR de prioridade (GnuTLS) ou lista de cifrados STR (OpenSSL) diretamente. \n"
"                                Use com cuidado. Essa opção substitui o valor '--secure-protocol'.\n"
"                                O formato e a sintaxe dessa string dependem da biblioteca SSL/TLS utilizada."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                   Desabilitar HSTS\n"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho da base de dados HSTS (sobe o valor "
"padrão) \n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"binários ftp\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr ""
"       --ftp-user=USUÁRIO FTP         USAR o USUÁRIO FTP como nome de "
"usuário\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=PAROLEL     definir parola de accedere al FTP"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr ""
"       --no-remove-listing         não remova arquivos de listação "
"('.listing')\n"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"--no-glob                   Desligue o globbing de nomes de arquivos FTP"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp        desligue o modo de transferência 'pasivo' \n"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"--preserve-permissions      preservar os direitos de acesso às arquivos "
"remotos"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         na recursão, carregar arquivos vinculados "
"(sem diretórios)"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                 Use implicitamente FTPS (porta padrão"
" é 990) \n"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               reiniciar o sessão SSL/TLS iniciada "
"na conexão de controle, ao abrir a conexão de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"       --ftps-clear-data-connection    apenas o canal de controle é "
"criptografado; os dados permanecem em texto puro\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"--ftps-fallback-to-ftp          volte para FTP se o FTPS não for suportado "
"pelo servidor"

msgid "WARC options:\n"
msgstr "WARC-Parametros:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILENAME         salvar as solicitações e respostas em um"
" arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr ""
"       --warc-header=CHARKETTE  CHARKETTE no conjunto warcinfo inserir\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=%<PRIuMAX>        O tamanho máximo dos arquivos WARC "
"é %<PRIuMAX> bytes\n"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                  Indexar arquivos CDX\n"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILENAME      Não salvar registros que estejam naquela "
"arquivo CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr "       --no-warc-compression     não comprimir arquivos WARC com GZIP\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "--no-warc-digests           não calcula digestas SHA1"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr "--no-warc-keep-log          não salvar o arquivo de log em um WARC"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=CATALOGO    diretório para arquivos temporários, "
"criados pela escrita WARC\n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive          включение рекурсивной загрузки\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
