msgid "ERROR: GnuTLS requires the key and the cert to be of the same type.\n"
msgstr ""
"ERRO: Para GnuTLS é necessário o par chave/certificado de um único tipo."

msgid "Your GnuTLS version is too old to support TLS 1.3\n"
msgstr ""
"A versão GnuTLS que você está utilizando é muito antiga para suportar o TLS "
"1.3."

msgid "GnuTLS: unimplemented 'secure-protocol' option value %u\n"
msgstr ""
"GnuTLS: valor %u do parâmetro 'secure-protocol' não está implementado."

msgid "Please report this issue to bug-wget@gnu.org\n"
msgstr "Sintam hospedar informações sobre este erro para <bug-wget@gnu.org>."

msgid "GnuTLS: unimplemented 'secure-protocol' option value %d\n"
msgstr "GnuTLS: valor %d parâmetro \"secure-protocol\" não está implementado."

msgid ""
"GnuTLS: Cannot set prio string directly. Falling back to default priority.\n"
msgstr ""
"GnuTLS: não é possível definir a prioridade diretamente. Voltemos ao nível "
"de prioridade padrão."

msgid "ERROR"
msgstr "ERRO"

msgid "WARNING"
msgstr "PREDÚPRAZDENÍE"

msgid "%s: No certificate presented by %s.\n"
msgstr ""
"%s: Não há certificado, apresentado por %s. (Nenhum certificado encontrado "
"para o item representado por %s.)"

msgid "%s: The certificate of %s is not trusted.\n"
msgstr ""
"%s: Não há confiança no certificado para %s. A segurança da conexão pode ser"
" comprometida se o certificado não for devidamente verificado."

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr ""
"%s: Não foi possível identificar o editor de certificação %s. A fonte não é "
"reconhecida."

msgid "%s: The certificate of %s has been revoked.\n"
msgstr ""
"%s: Certificado para %s expirou. (Certidão de identidade ou credenciais "
"digitais que permitem a comunicação segura entre sistemas foi emitido por "
"uma autoridade confiável, mas agora está no horizonte da validade.)"

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr ""
"%s: O certificado assinado por %s não está presente no UC. (Certificado "
"ausente do signatário)"

msgid "%s: The certificate of %s was signed using an insecure algorithm.\n"
msgstr ""
"%s: Para assinar o certificado %s foi utilizado um algoritmo não seguro. A "
"autenticação do certificado está comprometida."

msgid "%s: The certificate of %s is not yet activated.\n"
msgstr ""
"%s: Certificado %s ainda não está ativado. (Certificate of %s still not "
"activated.)"

msgid "%s: The certificate of %s has expired.\n"
msgstr ""
"%s: O certificado de %s expirou. A data limite para o seu uso está atingida."

