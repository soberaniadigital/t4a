msgstr ""
"%s: WGETRC indica que a linha %d possui o valor '%<PRIuMAX>', mas não pode "
"ser lida devido à falha no sistema de arquivos, erro: '%s'."

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: Não é possível ler %s (%s)."

msgid "%s: Error in %s at line %d.\n"
msgstr "%s: Erro no %s na linha %d."

msgid "%s: Syntax error in %s at line %d.\n"
msgstr "%s: Erro de sintaxe no %s na linha %d. \n"

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %<PRIuMAX> da coluna %d. \n"

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo de configuração do sistema wgetrc (env "
"SYSTEM_WGETRC). Tente verificar “%s”, ou especifique outro arquivo "
"utilizando --config.\n"

msgid ""
"Parsing system wgetrc file failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo wgetrc. Tente verificar "
"'\\n{variable_placeholder}', ou especifique outro arquivo utilizando "
"--config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Cãovoredo: Cả wgetrc do sistema e do usuário indicam ambos em %s. \n"

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Expressão lógica inválida; use 'on' ou 'off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr ""
"%s: %s: %s không hợp lệ; dùng “on” (bật), “off” (tắt) hay “quiet” (im lặng)."

msgid "%s: %s: Invalid number %s.\n"
msgstr ""
"%s: %s: Número %d inválido. (Somente números inteiros entre 0 e 9 inclusive)"

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor byte %d sai. (invalido)"

msgid "%s: %s: Invalid time period %s\n"
msgstr ""
"%s: %s: Tempo de entrada ou saída inválido. Ajuste o intervalo para um valor"
" aceitável."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Chu kỳ thời gian âm %s. \n"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso de askpass é necessário uma linha de texto ou a variável ambiente"
" WGET_ASKPASS ou SSH_ASKPASS definida."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor %s inválido. (Invalido)%d} (Invalid Value)"

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: O título do cabeçalho está incorreto. \n"

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr ""
"%s: %s: O nome do arquivo WARC não é válido. Por favor, verifique o formato "
"e tente novamente."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr "%s: %s: Sai kiểu tiến độ %s. (Incorrect progress type)"

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição não permitida %s, utilize "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "Codificação %s inválida"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O conversor de %s para %s não é suportado"

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes não formatada ou inválida"

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado de código %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: local não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "idn_encode (%d): %s\n"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d: %s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; desligamento do registro. (logging is disabled)"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "CÓPIA DE UTILIZAR: %s [PARÂMETRO]... [URL] ..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas são também necessários para as"
" opções curtas."

msgid "Startup:\n"
msgstr "Khởi động:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version                   Mostrar versão do Wget e encerrar a "
"execução."

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      mostrar esta ajuda."

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do processamento para retornar ao "
"modo de fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr "  -e,  --execute=%s   executar comando no estilo de «.wgetrc»\n"

msgid "Logging and input file:\n"
msgstr "Jornalização e ficheiro de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrever mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=%s     adicionar mensagens ao final do arquivo %s\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                     Mostrar informações de depuração para "
"ajudar a encontrar e corrigir erros."

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr ""
"       --wdebug              apresentar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "  -q,  --quiet                     silencioso (sem saída para a tela)"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "  -v,  --verbose                   hipertexto detalhado (padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose                desligar o relatório detalhado sem "
"silenciá-lo completamente."

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos listados no FILE Metalink "
"localizado\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML."

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL            considere que as ligações do arquivo de entrada"
" (-i -F) são relativas à URL especificada\n"

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=FILE         definir arquivo de configuração\n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                      não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registros das razões para a rejeição de URL no "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir ЧИСЛО tentativas (0 = sem limite)\n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused         tentar novamente, mesmo que o servidor "
"tenha recusado a conexão. \n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error     considere erros de host como não críticos, "
"temporários\n"

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS_HTTP   lista (separada por vírgula) de erros HTTP que provocam recomeço, \n"
"                                         para mais informações tente '--help'"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    escrever documentos no FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              ignora as cargas que levariam à substituição de arquivos existentes\n"
"(e suas recriações)\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr ""
"       --no-netrc                  não tenta obter dados a partir do "
".netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                  continuar a carregamento parcialmente de "
"um arquivo já em processo. \n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=СМЕЩЕНИЯ      iniciar a transferência do buffer a partir "
"da posição de meio (considerado como zero) \n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIPO            escolher tipo de indicador de progresso."

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress           mostrar o indicador de progresso em "
"qualquer modo detalhado\n"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping              não carregar arquivos repetidamente, "
"apenas se forem mais novos do que os locais."

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"       --no-use-server-timestamps    não utilizar a condição if-modified-"
"since para solicitações no modo de marcação do tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"       --no-use-server-timestamps   não usar a marcação de tempo local do "
"arquivo, obtida do servidor. \n"

msgid "  -S,  --server-response           print server response\n"
msgstr ""
"  -S,  --server-response         Resposta do servidor para solicitações de "
"usuário."

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                    sem carregar nada."

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEKUNDOS         configuração de todos os valores dos "
"limites de tempo igual ao número SEKUNDOS. \n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSES      lista de endereços dos servidores DNS "
"solicitados (separado por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE  associar o resolver DNS à ADRESSE (nome "
"do computador ou IP) local. \n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr "--dns-timeout=СЕК         установка тайм-аута поиска в DNS в СЕК\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"       --connect-timeout=СЕК     установка тайм-аута подключения в СЕК\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=СЕК  define o timeout de leitura em сек"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEKUNDAS             espera SEKUNDAS entre os downloads (para "
"mais de uma URL) \n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEKUNDOS       pausa de até SEKUNDOS entre tentativas "
"sucessivas ao carregar (para mais de uma URL) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --random-wait             pausa de 0.5*WAIT até 1.5*WAIT segundos "
"entre as operações (quando mais de uma URL for carregada)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                    Não utilize proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=ЧИСЛО             установить величину квоты загрузки в "
"ЧИСЛО\n"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRESSE      ligar ADRESSE (nome do computador ou endereço IP) localmente\n"
"                                     em um computador desktop."

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED         limitar a velocidade de transferência para"
" SPEED\n"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr ""
"       --no-dns-cache              Desligue o cache de DNS para evitar "
"dependências em memória do sistema."

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS    limitar ao utilizar em nomes de arquivos "
"caracteres, permitidos no sistema operacional. \n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             não levar em consideração o caso da letra "
"ao comparar arquivos e/ou pastas\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "  -4,  --inet4-only              conectar apenas a endereços IPv4. \n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr ""
"chave apenas IPv6 --inet6-only                conectar somente a endereços "
"IPv6."

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar primeiro aos endereços do grupo "
"especificado (pode ser IPv6, IPv4 ou nada) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr ""
"       --user=POLIZOTEUELHE             instalar e ftp- e http-usuário para "
"o POLIZOTEUELHE. \n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr ""
"       --password=ПАРОЛЬ         установить ftp- и http-пароль в ПАРОЛЬ\n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password              pedir o password. \n"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=CHAMAR          definir o tratamento para solicitações "
"de senha e nome do usuário. Se a CHAMAR não for especificada, será utilizado"
" a variável ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                    desligue a suporte para IRI. \n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=BẢNG-MỘ-ĐƯỚI      utilizar BẢNG MỘ ĐƯỚI como "
"localização mã para IRI. \n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como codificação remota por "
"padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"       --unlink                    remover arquivo antes de sobrescrever."

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash              mantenha arquivos com somas de hash "
"incorretas (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=NOME    ordem alfabética Metalink "
"application/metalink4+xml metaurl\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar dados Metalink do cabeçalho de "
"resposta HTTP"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location      vila local preferida para acesso aos "
"recursos Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                    ativar o armazenamento de metadados nos "
"extensores dos arquivos virtuais\n"

msgid "Directories:\n"
msgstr "Thư mục:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories            não criar pastas."

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories         Epíbuco criar pastas. \n"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr "  -nH, --no-host-directories      não criar pastas no host."

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories     utilizar o nome do protocolo em pastas\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr ""
"  -P,  --directory-prefix=ПРЕФИКС  salvar arquivos no diretório ПРЕФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО componentes do catálogo "
"remoto. \n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=ПОЛЬЗОВ.        utilizador http no utilizador POLEZOVATEL"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "       --http-password=ПАРОЛЬ  установить http-пароль в ПАРОЛЬ\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "       --no-cache              ignorar dados cacheados do servidor\n"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=ÍMÊN      alterar o nome da página por padrão "
"(geralmente é \"index.html\")\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E,  --adjust-extension          salvar documentos HTML/CSS com extensões "
"apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"       --ignore-length             ignorar o campo de cabeçalho \"Content-"
"Length\" do início."

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=%s              inserir CHUỖI entre os cabeçotes. \n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TIP        escolha do método de compressão: auto, gzip "
"ou none. (por padrão: none)\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          максимально допустимое число перенаправлений "
"на страницу\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=ПОЛЬЗОВ.   установить ПОЛЬЗОВАТЕЛЯ в качестве имени "
"пользователя для прокси\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROL    utilizar PAROL como senha para o proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           включить в HTTP-запрос заголовок «Referer: "
"URL»"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "--save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENT      identificar como AGENT em vez de "
"Wget/VERSÃO\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive        desligue o HTTP persistente (conexões "
"longas duração).\n"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                não utilizar cookies."

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies a partir do FILE antes de "
"iniciar o trabalho. \n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      carregar e salvar cookies de sessão (não "
"permanentes) \n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=СТРОКА      использовать метод POST; отправка СТРОКИ в "
"качестве данных\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILE. \n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod         utilizar método \"HTTPMethod\" no "
"cabeçalho."

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      отправка СТРОКИ в качестве данных; \n"
"                               ДОЛЖЕН быть указан параметр --method\n"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envio do conteúdo da FILE; \n"
"                               DEVE SER INCLUÍDO O PARAMETRO --method. \n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   considerar o cabeçalho Content-Disposition\n"
"                               ao escolher nomes para arquivos locais (EXPERIMENTAL)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"       --content-on-error      exibir dados aceitos em caso de erro do "
"servidor. \n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"       --auth-no-challenge     enviar informações sobre autenticação HTTP "
"Basic sem esperar o primeiro resposta do servidor\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR        escolha do protocolo de segurança, uma "
"das opções disponíveis são: auto, SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, "
"TLSv1_3 ou PFS. \n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr ""
"       --https-only             transitando apenas por links seguros HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr ""
"       --no-check-certificate      não verificar o certificado do servidor\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       arquivo de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=ТИП   тип сертификата пользователя: PEM або DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr "       --private-key=FILE       arquivo com chave privada. \n"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr ""
"       --private-key-type=KIỂU     kiểu chìa khóa riêng tư, PEM hoặc DER. \n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr "       --ca-certificate=FILE    arquivo com a coleção de CAs. \n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=КАТ       catálogo, no qual está armazenado o lista de"
" certificados autofornecidos pela CA. \n"

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          arquivo com a lista CRL\n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE_HASHES  Arquivo com chave pública (PEM/DER) ou "
"qualquer número de hashes sha256 em base64, começando por \"sha256//\" e "
"separados por ';', para verificar o nó receptor no caminho da mensagem"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE      arquivo com dados aleatórios para gerar PRNG "
"SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=СТРОКА         приоритетнувати строку (GnuTLS) або список шифрів (OpenSSL) немедiatно. Use with caution. This option replaces the value of --secure-protocol.\n"
"                                The format and syntax depend on which SSL/TLS library is used."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                   desligue HSTS\n"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS (substitui "
"o valor padrão) \n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"binários arquivos FTP nível de dúvida. \n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr ""
"       --ftp-user=POLZOWANE        utilizar POLZOWANE nesta configuração "
"para se conectar ao FTP."

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=ПАРОЛЬ   установить ftp-пароль в ПАРОЛЬ\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr ""
"       --no-remove-listing         não remova a lista de arquivos "
"«.listing»."

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"       --no-glob                   desligue o globbing para nomes de "
"arquivos FTP."

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp            desligue o modo 'passivo' de "
"transferência (usar método ativo)"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"       --preserve-permissions      manter as permissões dos arquivos "
"remotos. \n"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         quando recursivo, carregar arquivos por meio "
"de links (não diretórios)\n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                 utilizando FTPS implicitamente (port "
"default é 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               retomando sessão SSL/TLS, iniciada no"
" canal de controle, ao abrir o canal de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"       --ftps-clear-data-connection    apenas criptografar o canal de "
"controle; os dados não são criptografados\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"       --ftps-fallback-to-ftp          volte para FTP, se o FTPS não for "
"suportado pelo servidor\n"

msgid "WARC options:\n"
msgstr "Parâmetros WARC:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILE          salvar dados de solicitação/resposta em "
"arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr "       --warc-header=CHUỖI         chèn CHUỖI vào bản ghi warcinfo.\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=%<PRIuMAX>     максимального размеу файлів WARC равен"
" ЧИСЛУ"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                  escrever arquivos indexados CDX."

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILE         não salvar registros, listados no arquivo "
"CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr ""
"       --no-warc-compression     não sinalizar para a compressão GZIP dos "
"arquivos WARC."

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "       --no-warc-digests           não calcula digestas SHA1."

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr ""
"       --no-warc-keep-log        não salvar o arquivo de log no formato "
"WARC. \n"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=КАТАЛОГ    місце para armazenamento temporário de "
"arquivos, criados pelo processo de gravação WARC."

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:\n"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive          включение рекурсивной загрузки"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
