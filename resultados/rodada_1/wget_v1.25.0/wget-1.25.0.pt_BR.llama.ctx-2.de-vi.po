msgstr ""
"       --reject-regex=РЕГВЫР       регулярное выражение для запрещённых URL"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr ""
"       --regex-type=TIPO_REGEX           Tipo do biểu thức regular "
"(posix|pcre).\n"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr "       --regex-type=TIPO            tipo biểu thức regular (posix) \n"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr ""
"  -D,  --domains=LISTA_DE_DOMÍNIO       lista de domínios permitidos, "
"separados por vírgula\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr ""
"       --exclude-domains=СПИСОК    список запрещённых доменов, через "
"запятую\n"

