"verifique as configurações para corrigir esse erro."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Falha lógica; use 'on' ou 'off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: Incorrecto; use 'on', 'off' ou 'quiet'."

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %d."

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor byte inválido %d. (esperado %<PRIuMAX>)"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Horário de tempo inválido %s. Por favor, verifique novamente."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s\n"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso de askpass é necessário uma string ou variável ambiente "
"WGET_ASKPASS ou SSH_ASKPASS."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor %s inválido."

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: Campo de título inválido. (%d)"

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s: %s: Inválido WARC %s. Cabeçalho incorreto."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr ""
"%s: %s: Tipo de progresso %s inválido. Por favor, verifique se está "
"utilizando o tipo correto para acompanhar seu trabalho."

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição de uso inválida, utilize "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "Codificação %s não é permitida"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O conversor de %s para %s não é suportado"

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência multibyte incompleta ou inválida."

msgid "Unhandled errno %d\n"
msgstr "Erro de código não tratado %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: localização não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha na codificação idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d: %s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; registro de log desligado. (logging disabled)."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL]...\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas e curtas são igualmente "
"necessários."

msgid "Startup:\n"
msgstr "Início do processo:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version           Mostrar versão do Wget e encerrar a operação\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help              Mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa iniciar em modo de "
"fundo\n"

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr "  -e,  --execute=%s   executar a comando no estilo de `.wgetrc'`\n"

msgid "Logging and input file:\n"
msgstr "Jornalização e arquivo de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrevendo mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr "--append-output=%s  adicionar mensagens ao final do arquivo %s\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug               exibir uma quantidade significativa de "
"informações para fins de depuração\n"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostre informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "--quiet\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "--verbose                   mostrar informações detalhadas (padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose          desligue o relatório detalhado (parcialmente)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregue URLs de acordo com o arquivo local ou "
"externo\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"   --input-metalink=FILE     baixar arquivos, listados no FILE de Metalink "
"local\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL            considerar que as ligações do arquivo de "
"entrada (-i -F) são relativas à URL especificada\n"

msgid "       --config=FILE               specify config file to use\n"
msgstr ""
"       --config=FILE         especifique o arquivo de configuração a "
"utilizar\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config                 não ler arquivos de configuração"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registra as razões para rejeição de URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir ЧИСЛО tentativas adicionais\n"
"                                 (0 sem limite)\n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused       повтори, mesmo que a conexão seja negada\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error     considere erros de host como não críticos e"
" aleatórios."

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS    lista separada por vírgula de erros "
"HTTP, a reintenta\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr ""
"  -O,  --output-document=FILE    escrevendo documentos no arquivo FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              ignorar as descargas que levariam à "
"sobreescrita de arquivos existentes\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr "--no-netrc                       não tentar obter dados do .netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                continue a leitura parcial de um arquivo "
"parcialmente carregado\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=SEMANA          iniciar a carregamento desde o início da "
"semana (considerado como zero) SEMANA\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TYPE            selecionar tipo de indicador de "
"progresso\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress           mostrar o indicador de progresso em "
"qualquer modo de detalhes"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N, --timestamping            não carregue novamente arquivos que já foram"
" carregados se eles forem mais antigos do que os locais\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"--no-use-server-timestamps    não utilizar a verificação if-modified-since "
"para solicitações em modo de marcação do tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--no-use-server-timestamps     não utilizar a marca de tempo local, obtida "
"do servidor\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         resposta do servidor\n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                  nada para carregar"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         configuração de todos os valores de tempo "
"igual ao número SEGUNDO\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSES      lista de servidores DNS a serem consultados\n"
"                                 (separados por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE  associar o resolver DNS ao endereço de "
"rede local (nome do computador ou IP) da máquina local\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEC         configuração de tempo limite para pesquisa "
"DNS em SEC\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"--conexao-timeout=СЕК     configuração do tempo limite de conexão em СЕК\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=SEC     instalação do timeout de leitura em SEC\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDOS            pausa de tantos SEGUNDOS entre carregamentos\n"
"                                 (aplicável se forem mais do que um URL para serem baixados)\n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS       espera de 1..SEGUNDOS entre reintentos da "
"carga (quando for carregar mais do que um URL) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"--random-wait             pausa de 0.5*WAIT...1.5*WAIT segundos entre as "
"carregamentos (quando forem mais do que um URL)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                    explicitamente desligue o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=ЧИСЛО             establecer a quantia da quota de "
"transferência em ЧИСЛО\n"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRESS      associar ADRESS (nome do computador ou "
"endereço IP) local\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr "       --limit-rate=СКОРОСТЬ     ограничить СКОРОСТЬ загрузки\n"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "--no-dns-cache            Desligue o cache de DNS-pedidos"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS  utilizar em nomes de arquivos caracteres, \n"
"                                aceitos pela OS\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             ignorar maiúsculas/minúsculas ao comparar "
"arquivos e/ou diretórios\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "--ipv4-only              conectar apenas a endereços IPv4\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--ipv6-somente              conectar apenas a endereços IPv6\n"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar primeiro aos endereços do família"
" especificada (possivelmente IPv6, IPv4 ou nenhum) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr "       --user=USUARIO       instale e ftp- e http-usuário no USUARIO\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr ""
"       --password=ПАРОЛЬ         instale o ftp- e http-senha em ПАРОЛЬ\n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password            pedir senhas"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=COMMANDA     especifique o manejador de credenciais "
"para solicitar nome do usuário e senha. Se nenhuma COMMANDA for "
"especificada, será utilizado a variável de ambiente WGET_ASKPASS ou "
"SSH_ASKPASS.\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                  desligue a suporte IRI\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como a codificação local para "
"IRIs\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como a codificação remota por "
"padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                    remover arquivo antes de desmontar\n"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash            deixar arquivos com hashes de controle "
"inválidos (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=NÚMERO    ordem do NÚMERO metaurl\n"
"                 Metalink application/metalink4+xml\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar metadados Metalink a partir do "
"cabeçalho de resposta HTTP"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location      localização preferida para os recursos "
"Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                   habilitar o armazenamento de dados "
"metadados nos atributos extensos do arquivo\n"

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories           não criar pastas"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        принудительно criar diretórios"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr "  -nH, --no-host-directories      não criar diretórios como no host\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories     utilizar o nome do protocolo nas pastas\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "  -P,  --directory-prefix=ПРЕФИКС  salvar arquivos no ПРЕФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО componentes de catálogo "
"remoto\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=ПОЛЬЗОВ.    estabelecer usuário http no usuário POLEZOV"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "       --http-password=ПАРОЛЬ  definir http-senha com ПАРОЛЬ\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"       --no-cache              ignorar dados armazenados no servidor local\n"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=NAME      altera o nome da página por defeito "
"(geralmente é \"index.html\")\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E,  --adjust-extension      salvar documentos HTML/CSS com as extensões "
"apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr "--ignora-tamanho         ignorar campo `Content-Length' em cabeçalhos"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=STRING         inserir STRING entre cabeçalhos\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=ТИП       tipo de compressão: auto, gzip ou none\n"
"                               (por padrão: none)"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          máximo permitido de redirecionamentos para a "
"página\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USUARIO        pone USUARIO como nome de usuário do "
"proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=ПАРОЛЬ   instale ПАРОЛЬ como senha para o proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           inclui no cabeçalho HTTP do pedido o campo "
"'Referer: URL' \n"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "--save-headers          salvar HTTP-cabeçalhos em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENTE      identificar como AGENTE em vez de "
"Wget/VERSIÓN\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive    desligue o HTTP keep-alive (conexões "
"persistentes) \n"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies            não utilizar cookies"

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregue as cookies do FILE antes de iniciar "
"o jogo\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"--keep-session-cookies  carregar e salvar cookies de sessão (não "
"permanentes)"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=СТРОКА      utilizar método POST; envio de STRING como "
"dados\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=ARQUIVO        utilizar método POST; envio do conteúdo da"
" ARQUIVO\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod     utilizar método \"HTTPMethod\" no cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      envio de STRING como dados; \n"
"                               DEVE ser especificado o parâmetro --method\n"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envocação do conteúdo de FILE; \n"
"                               DEVE ser especificado o parâmetro --method\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   considere o cabeçalho Content-Disposition\n"
"                               ao escolher nomes para arquivos locais (EXPERIMENTAL)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"       --content-on-error      exibir dados aceitos em caso de erro do "
"servidor"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"       --auth-no-challenge     enviar informações de autenticação HTTP "
"básica sem esperar pelo desafio do servidor\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=ПР     escolha do protocolo de segurança: auto, "
"SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr ""
"--https-only             fazendo apenas transferências por links seguros "
"HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr "--no-check-certificate      não verificar certificado do servidor"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       arquivo de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=TIPO   tipo de certificado do usuário: PEM ou "
"DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr ""
"       --private-key=FILE\n"
"        fichero de chave privada"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr ""
"       --private-key-type=ТИП   tipo de chave privada secreta: PEM ou DER\n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr "       --ca-certificate=FILE    arquivo com a agrupamento de CAs\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=КАТ       diretório, no qual está armazenado o lista "
"de CA\n"

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          arquivo com o conjunto de CRLs"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES  Fichero de clave pública (PEM/DER), o "
"qual pode conter um ou mais hashes sha256 codificados como base64, iniciando"
" com 'sha256//' e separados por ';', para verificar contra el par"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE        arquivo com dados aleatórios para semente "
"SSL PRNG\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo o soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=RU         definir a string de prioridade (GnuTLS) ou lista"
" de cifrados (OpenSSL) diretamente. Tenha cuidado com isso. Este parâmetro "
"substitui o valor do parâmetro '--secure-protocol'. O formato e sintaxe da "
"string dependem do motor SSL/TLS específico utilizado."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--no-hsts               desligue o HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS (substitui "
"o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"arquivos binários FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr ""
"       --ftp-user=USUÁRIOS          instale USUÁRIOS como ftp-usuários\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=ПАРОЛЬ   definir senha ftp em ПАРОЛЬ\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "       --no-remove-listing     não remova listagens de arquivo"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"       --no-glob               desligue as macros para nomes de arquivos FTP"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp        desligue o modo 'pasivo' de transferência"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr "--preserve-permissions      preservar permissões de arquivos remotos"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         при рекурсивному доступу загрузить файли по "
"ссылкам (не каталоги) \n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"      --ftps-implicit                 use FTPS implicitamente (puerto por "
"omissão é o 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               reiniciar sessão SSL/TLS iniciada no "
"canal de controle ao abrir o canal de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"--ftps-clear-data-connection    cifrar apenas o canal de controle; dados não"
" serão criptografados\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"       --ftps-fallback-to-ftp          volte para FTP, se o FTPS não for "
"suportado pelo servidor\n"

msgid "WARC options:\n"
msgstr "Parâmetros WARC:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILENAME          salvar dados do pedido/resposta em um "
"arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr ""
"       --warc-header=STRING        inscrever STRING no registro warcinfo\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=ЧИСЛО     tamanho máximo de arquivos WARC é igual ao "
"ЧИСЛУ\n"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                salvar arquivos indexados CDX\n"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILENAME         não salvar registros, listados no "
"arquivo CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr "       --no-warc-compression     não comprime arquivos WARC com GZIP\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "       --no-warc-digests         não calcula digestes SHA1\n"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr ""
"       --no-warc-keep-log        não salvar o arquivo de log em registros "
"WARC"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=CATALOG    localização para arquivos temporários, "
"criados pela procedimento de gravação WARC\n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive          incluindo carregamento recursivo\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr ""
"  -l,  --level=%s        profundidade máxima de recursão (inf ou 0 para "
"infinito) \n"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr ""
"       --delete-after       apagar arquivos locais após a carregamento\n"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
"  -k,  --convert-links      fazer com que os links no HTML ou CSS carregado "
"sejam locais\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr ""
"       --convert-file-only  converter apenas a parte do arquivo da URL (base"
" nome) \n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N               antes de escrever o arquivo X, fazer backup até N\n"
"                        cópias do arquivo original."

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X, fazer uma cópia "
"de segurança no formato X_orig\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X, fazer uma cópia "
"de segurança no formato X.orig\n"

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"  -m,  --mirror             короткий параметр, эквивалентен\n"
"                            -N -r -l inf --no-remove-listing\n"

msgid ""
"  -p,  --page-requisites           get all images, etc. needed to display "
"HTML page\n"
msgstr ""
"  -p,  --page-requisites    carregar todas as imagens e outros elementos "
"necessários para a exibição da página HTML\n"

msgid ""
"       --strict-comments           turn on strict (SGML) handling of HTML "
"comments\n"
msgstr ""
"       --strict-comments    habilitar tratamento estrito (SGML) de "
"comentários em HTML\n"

msgid "Recursive accept/reject:\n"
msgstr "Permissões/proibições recursivas: \n"

msgid ""
"  -A,  --accept=LIST               comma-separated list of accepted "
"extensions\n"
msgstr ""
"  -A,  --accept=LIST               lista separada por vírgula de extensões "
"aceitas\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R, --reject=LIST               lista separada por vírgulas de extensões "
"rejeitadas\n"

msgid "       --accept-regex=REGEX        regex matching accepted URLs\n"
msgstr ""
"       --accept-regex=РЕГВЫР       регулярное выражение для разрешённых URL"

msgid "       --reject-regex=REGEX        regex matching rejected URLs\n"
msgstr "       --reject-regex=РЕГВЫР       regex que exclui URLs desejadas\n"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr ""
"       --regex-type=ТИП            tipo de expressão regular (posix|pcre) \n"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr "       --regex-type=ТИП            tipo de expressão regular (posix) \n"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr ""
"  -D,  --domains=СПИСОК            списки допустимых доменів, через "
"запятую\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr ""
"       --exclude-domains=СПИСОК    список запрещённых доменів, через "
"запятую\n"

msgid ""
"       --follow-ftp                follow FTP links from HTML documents\n"
msgstr "--follow-ftp                seguir links FTP nos documentos HTML"

msgid ""
"       --follow-tags=LIST          comma-separated list of followed HTML "
"tags\n"
msgstr ""
"       --follow-tags=СПИСОК        lista utilizada de tags HTML, separadas "
"por vírgula\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignore-tags=СПИСОК        lista de tags HTML a serem ignoradas, "
"separada por vírgula\n"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"  -H,  --span-hosts                acessando hosts externos durante o "
"recurso recursivo\n"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr "  -L,  --relative                  seguir apenas por links relativos \n"

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr "  -I,  --include-directories=LIST  lista de diretórios permitidos \n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"--trust-server-names  utilizar o nome, indicado no URL redirecionante final "
"do componente."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--excluir-diretórios=%s"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr "  -np, --no-parent                 não subirá no diretório pai\n"

