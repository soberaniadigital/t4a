msgstr ""
"Não foi possível encontrar os dados da Metalink na resposta HTTP. A "
"ferramenta de download está usando o método GET do protocolo HTTP para "
"baixar o arquivo."

msgid "Metalink headers found. Switching to Metalink mode.\n"
msgstr "Encontrados os cabeçalhos Metalink. Passando para o modo Metalink."

msgid "Remote file does not exist -- broken link!!!\n"
msgstr "Arquivo remoto não existe -- referência inválida!"

