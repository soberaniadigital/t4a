msgstr ""
"GnuTLS: valor do parâmetro \"secure-protocol\" não é implementado para o "
"número %d"

msgid ""
"GnuTLS: Cannot set prio string directly. Falling back to default priority.\n"
msgstr ""
"GnuTLS: não é possível definir a prioridade diretamente. Use a prioridade "
"padrão como alternativa."

msgid "ERROR"
msgstr "ОШИБКА"

msgid "WARNING"
msgstr "PREDÚPRAZÃO"

msgid "%s: No certificate presented by %s.\n"
msgstr "%s: Não há certificado apresentado por %s."

