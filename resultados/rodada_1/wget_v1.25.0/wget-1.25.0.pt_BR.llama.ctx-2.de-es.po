msgstr "%s: Erro em %s na linha %d.%n"

msgid "%s: Syntax error in %s at line %d.\n"
msgstr "%s: Erro de sintaxe na %s na linha %d."

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %d da fonte.\"\n"

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo de configuração do sistema wgetrc (env "
"SYSTEM_WGETRC). Por favor, verifique '\\%s' ou especifique outro arquivo "
"usando --config."

msgid ""
"Parsing system wgetrc file failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo wgetrc do sistema. Por favor, verifique '\\%s' "
"ou especifique outro arquivo usando --config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Aviso de erro: ambos os arquivos wgetrc do sistema e do usuário apontam "
"para %s. Por favor, verifique a localização correta."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Erro lógico de operador %s; use 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr ""
"%s: %s: O valor do campo '%c' é inválido; utilize 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Numero inválido %d.%<PRIuMAX>."

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor do byte inválido %d. (byte incorrect value)"

msgid "%s: %s: Invalid time period %s\n"
msgstr ""
"%s: %s: Período de tempo inválido %s. Para obter mais informações, tente 'DE"
" --help' ou 'ES --help'.\n"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso de askpass é necessário uma string ou a variável ambiente "
"WGET_ASKPASS estabelecida, ou SSH_ASKPASS. Se nenhuma das condições for "
"atendida, um erro será apresentado."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor de entrada inválido. Por favor, verifique novamente."

msgid "%s: %s: Invalid header %s.\n"
msgstr ""
"%s: %s: Título inválido. A linha contém apenas letras e números, mas não "
"começa com 'DE' ou 'ES'."

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s: %s: Campo WARC inválido. Cabeçalho incorreto."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr ""
"%s: %s: Tipo de progresso inválido. Por favor, verifique seu input e tente "
"novamente."

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição %s inválida, use "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "A codificação %s não é aceita"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão de %s para %s não é suportada."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes multibyte incompleta ou inválida."

msgid "Unhandled errno %d\n"
msgstr "Erro de código %d não tratado"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: local não está definido"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d: %s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; Protokollioagem será desligada. (logging will be turned off)."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL] ..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas e curtas são igualmente "
"necessários."

msgid "Startup:\n"
msgstr "Beim Start:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version                   Mostrar a versão do Wget e encerrar o "
"processo\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para entrar no modo de"
" fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr ""
"  -e,  --execute=%s\n"
"    executar comando no estilo de '.wgetrc'\n"

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrever mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=FILE        adicionar mensagens ao final da FILE\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                     Mostrar informações de depuração "
"extensivas\n"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "  -q,  --quiet                     silente (sem mensagens de saída)"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "--verbose                   mostrar informações detalhadas (padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose                desativa modo verboso, mas não silencia "
"completamente"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=BANDWIDTH    Unidades de medida da largura de banda. "
"Tipo pode ser bits."

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos listados na local Metalink "
"FILE\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL            considere que as referências na ficheiro de "
"entrada (-i -F) são relativas à URL especificada\n"

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=%s         especifique o arquivo de configuração\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "       --no-config                 nenhuma configuração utilizada"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registra as razões para rejeição da URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             configurar ЧИСЛО tentativas adicionais (0 "
"para sem limite)\n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused         Repetir, mesmo que o parceiro tenha "
"recusado a conexão\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error=ERRO_HOST      Considere erros de host como não"
" críticos, temporários. \n"

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS  lista separada por vírgula de erros HTTP, a serem reintentados\n"
"                                   \n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O, --output-document=FILE    escrever documentos no arquivo FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              ignora as atualizações que levariam à substituição de arquivos existentes\n"
"(e suas recriações)\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr "--no-netrc                       Não tentar obter dados do .netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                      Continuar a carga de um arquivo "
"parcialmente baixado\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=SEMARENCIA          Iniciar a descarga do local de "
"SEMARENCIAS (considerado como zero) \n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=ТИП            selecionar tipo de indicador de progresso "
"com ТИП representá-lo\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress             Mostrar indicador de progresso em "
"qualquer modo de detalhamento"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping            não carregue novamente arquivos que já "
"foram baixados, apenas se eles forem mais recentes do que os locais\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"--no-use-server-timestamps    não utilizar a condição if-modified-since para"
" solicitações em modo de marcação do tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--no-use-server-timestamps     não instale a marca de tempo local, recebida "
"do servidor\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         Resposta do servidor exibir\n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                    nenhum download (nada baixar)"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         configuração de todos os timeouts para "
"segundos igual ao número SEGUNDO\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSES      Lista de Servidores DNS a serem "
"consultados (separados por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE      vincular o resolver DNS ao ADRESSE "
"(nome do computador ou IP) local\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEK         configuração do timeout para a pesquisa DNS"
" em segundos\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr "--connect-timeout=SEK\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=СЕК"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEGUNDOS            pausa em SEGUNDAS entre as cargas de dados"
" (para mais de uma URL) \n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS        espera 1..SEGUNDOS entre reintentos de uma descarga\n"
"                                     (aplicável se for para baixar mais do que um URL)\n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --random-wait             pausa de 0,5*WAIT até 1,5*WAIT segundos "
"entre as solicitações (quando houver mais do que uma URL para baixar)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                 Keinen Proxy verwenden\n"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓMO_SE_ESCREVER_NO_PORTUGUESE  definir a quantidade de quota"
" para download em CÓMO_SE_ESCREVER_NO_PORTUGUESE"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRESSE      ligar ADRESSE (nome de host ou endereço "
"IP) do computador local\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED           limitar a velocidade de download para "
"SPEED\n"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "--no-dns-cache              Desabilitar cacheamento de consultas DNS"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS    Utilizar caracteres em nomes de arquivos "
"que são aceitos pelo sistema operacional\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             ignorar maiúsculas/minúsculas ao comparar "
"nomes de arquivos e/ou diretórios\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "--inet4-only                conectar apenas a endereços IPv4\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only                conectar apenas a direções IPv6"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=FAMILIA conectar primeiro a diretórios da família "
"especificada, seja IPv6, IPv4 ou nenhum (none)\n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr "       --user=USUÁRIO             USUÁRIO para ftp e http utilizar\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr "       --password=PAROLHO         utilizar PAROLHO para ftp e http\n"

msgid "       --ask-password              prompt for passwords\n"
msgstr ""
"       --ask-password              pedir o seu próprio nome de usuário e "
"senha\n"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=КОМАНДА       especifica um comando para solicitar o "
"nome de usuário e senha. Se nenhum comando for definido, será utilizado a "
"variável ambiente WGET_ASKPASS ou SSH_ASKPASS.\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                     Desligue a suporte para IRI\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como a codificação local para "
"IRIs\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     использовать КДР как удалённую кодировку\n"
"                                 по умолчанию\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                    Excluir arquivo antes de sobrescrever"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"--keep-badhash              mantenha arquivos com hashes de verificação "
"inválidos (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=%s    Metalink Applikation/metalink4+xml metaurl "
"Ordnungszahl %d\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar metadados Metalink a partir do "
"cabeçalho de resposta HTTP\n"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"--preferred-location        localização preferida para os recursos Metalink"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                     armazenamento de metadados em arquivos "
"com atributos expandidos\n"

msgid "Directories:\n"
msgstr "Verzeichnisse:"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories            nenhum diretório criado"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "forçar a criação de diretórios\n"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr " -nH, --no-host-directories       não cria diretórios do host"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories     utilizar o nome do protocolo nas pastas\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr ""
"  -P,  --directory-prefix=ПРЕФИКС   salvar arquivos no diretório "
"PRЭФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО níveis de diretório da localização contrária\n"
"                                   pulá-los"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=POLIZOV\n"
"        Estabelecer http-usuário no POLIZOV\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr ""
"       --http-password=PASSWORD      http-password para PASSWORD definir em "
"PASSWORD\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"       --no-cache              ignorar dados armazenados em cache no "
"servidor\n"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"        --default-page=NAME        Alterar o nome da página por padrão\n"
"                                (geralmente \"index.html\")"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E,  --adjust-extension          salvar documentos HTML/CSS com as "
"extensões apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"--ignorar-comprimento         ignorar o campo de cabeçalho 'Content-Length'"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=STRING\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=ТИП       тип сжатия: auto, gzip або none\n"
"                               (по умолчанию: none)"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"--max-redirect          максимально допустимое число перенаправлений на "
"страницу\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USUARIO.   utilizar USUARIO como nome de usuário para "
"proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLHA   utilizar PAROLHA como senha para o proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           inclua no cabeçalho HTTP do pedido a linha "
"'Referer: URL'."

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENT      identificar como AGENTE em vez de "
"Wget/VERSÃO\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive    desligue o HTTP keep-alive (ativos persistentes) \n"
"\t(desativar conexões permanentes)\n"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                não usa cookies"

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies antes do jogo a partir de "
"FILE\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      (não permanentes) Cookies de sessão \n"
"                                      carregar e salvar\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"        --post-data=СТРОКА      использовать метод POST; отправка СТРОКИ в "
"качестве данных\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILE\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod         utilizar método \"HTTPMethod\" no "
"cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      отправка СТРОКИ в качестве данных; \n"
"                               ДОЛЖЕН быть указан параметр --method\n"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envio do conteúdo da FILE; \n"
"                         --method« deve ser especificado. \n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
