msgstr ""
"       --random-file=ARQUIVO        arquivo com dados aleatórios para "
"inicializar a geração de números pseudoaleatórios SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=СТРОКА         признача string prioridades (GnuTLS) ou list"
" strings cipher (OpenSSL) diretamente. Use com cautela. Opção deste modo "
"substitui o valor de --secure-protocol. O formato e sintaxe da STR dependem "
"do motor SSL/TLS utilizado."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--nonaktivokan HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS (sobe o "
"valor padrão)\n"

msgid "FTP options:\n"
msgstr ""
"Opsi FTP:\n"
"\tID: %s\n"
"\tFR: %d\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"blocos de dados FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr "       --ftp-user=PENGGUNA         menata pengguna ftp ke PENGGUNA\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "--ftp-password=PAROL\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "       --no-remove-listing         não remova listagens (.listing)"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"       --no-glob                   desligue o globbing para nomes de "
"arquivos FTP\n"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr "--no-passive-ftp            desligar o modo de transferência passivo"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"--preserve-permissions      preservar os direitos de acesso aos arquivos "
"remotos\n"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         quando realizar uma recusa, carregar arquivos"
" por meio de links (não diretórios) \n"

msgid "FTPS options:\n"
msgstr "Opsi FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                 utilizar FTPS implicitamente (porta "
"padrão é 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               recomeça o sessão SSL/TLS iniciada no"
" canal de controle, ao abrir o canal de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"--ftps-clear-data-connection    criptografar apenas o canal de controle; "
"todas as informações serão em texto simples\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"       --ftps-fallback-to-ftp          volte para FTP se o FTPS não for "
"suportado pelo servidor target\n"

msgid "WARC options:\n"
msgstr ""
"Opsi WARC:\n"
"\tID: %s;\n"
"\tFR: %d;"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILENAME        salvar dados de solicitação/resposta em "
"arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr ""
"       --warc-header=STRING        inscrever STRING no registro warcinfo\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=CÓDIGO      controla o tamanho máximo dos arquivos "
"WARC para CÓDIGO"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                  escrever blocos de índices CDX\n"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILENAME       não salvar registros que tenham sido "
"listados no arquivo CDX atual\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr ""
"       --no-warc-compression       não comprimir arquivos WARC usando GZIP\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "--no-warc-digests           não calcula digestas SHA1"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr ""
"       --no-warc-keep-log        não salvar o arquivo de log nas entradas "
"WARC\n"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=DIREKTORI    localização para arquivos temporários "
"criados pela escrita WARC\n"

msgid "Recursive download:\n"
msgstr "Recuperação recursiva:\n"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr ""
"  -r,  --recursive                 especifica a inclusão de carregamento "
"recursivo\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
