msgstr "%s: %s: Boolean não válido; utilize 'on' ou 'off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: %s inválido; utilize 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. (Número não é válido em português.)"

msgid "%s: %s must only be used once\n"
msgstr "%s: %s somente pode ser utilizado uma vez\n"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor byte não válido %d\n"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Período de tempo não válido %s"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s\n"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"use-askpass necessita uma string ou a definição de variável ambiente "
"WGET_ASKPASS ou SSH_ASKPASS para ser utilizado."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor %s inválido. Por favor, verifique novamente."

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: Header não válido (%s).\n"

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s: %s: Header WARC %d inválido. \n"

msgid "%s: %s: Invalid progress type %s.\n"
msgstr "%s: %s: Tipo de progresso inválido %s. \n"

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição não permitida %s, utilize [unix|vms|windows], "
"[lowercase|uppercase], [nocontrol] e [ascii].\n"

msgid "Encoding %s isn't valid\n"
msgstr "Pengkodean %s tidak valid"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão do %s para o %s não é suportada."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência multibyte não completa ou inválida."

msgid "Unhandled errno %d\n"
msgstr "Erro de código não tratado %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: local não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d: %s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O E/S padrão é redirecionada para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; desativar a captura de log. \n"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Penggunaan: %s [OPSI]... [URL]..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para os parâmetros de comprimento também são "
"necessários para os parâmetros de curto formato."

msgid "Startup:\n"
msgstr "Démarrage :"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr "  -V,  --version                   mostrar versão do Wget e sair\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      mostre a ajuda deste comando\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para retornar ao modo "
"de fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr ""
"  -e,  --execute=COMMAND           executar uma instrução no estilo "
"'.wgetrc'"

msgid "Logging and input file:\n"
msgstr ""
"Journalização e ficheiro de entrada : \n"
"\tID: %s, FR: %d, PRIuMAX: %<PRIuMAX>."

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrever mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=%s\n"
"dodisponha mensagens no final do arquivo %s."

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                     mostre muitas informações de depuração"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              exibir informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "senyap (sem keluaran)"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
"--verbose, --v\n"
"    Mostrar informações detalhadas (padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose                desligue o modo verboso, sem ser "
"silencioso\n"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=UNIDADES_METRICAS    determinar UNIDADEM. A unidade "
"pode ser igual a bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregue as URLs conforme o arquivo local ou "
"externo\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos listados no FILE Metalink "
"local\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html                considerar o arquivo de entrada como "
"HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL                  considerar as ligações do arquivo HTML de"
" entrada como relativas à URL especificada. \n"

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=%s         definir arquivo de configuração\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config           não ler arquivos de configuração"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registar as razões para a exclusão de URL no "
"FILE\n"

msgid "Download:\n"
msgstr "Unduh:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir o número de tentativas (0 para sem "
"limite) \n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused         tentar novamente mesmo que a conexão seja"
" negada\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error      considera erros de host como falhas não "
"críticas e aleatórias que podem ser ignoradas\n"

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROES HTTP\n"
"                                   lista de erros (separados por vírgula) que podem causar uma conexão repetida, como timeouts ou respostas inesperadas.\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=%s    escrever documentos no arquivo %s\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              ignora as atualizações que levariam a sobreescrever arquivos existentes\n"
"                                 (e suas recriações)\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr ""
"       --no-netrc                  não tente obter dados do arquivo .netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                  continue a leitura parcial de um arquivo "
"que já foi lido em partes\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=SEMANA          iniciar a transferência de dados do local"
" da SEMANA (começando em zero)\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TYPE             escolher o tipo de indicador de "
"progresso\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress             mostre a barra de progresso em qualquer "
"modo detalhado\n"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping              não reutilize blocos de dados que já "
"estão presentes no sistema a menos que sejam mais recentes do que os "
"locais\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"       --no-use-server-timestamps    não utilizar a condição if-modified-"
"since para solicitações em modo de marcação de tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"       --no-use-server-timestamps  não usar a marca de tempo local, obtida "
"do servidor\n"

msgid "  -S,  --server-response           print server response\n"
msgstr " -S, --server-response           Recebe resposta do servidor."

msgid "       --spider                    don't download anything\n"
msgstr "jangan unduh apa pun"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEKUNDOS         definir todos os valores de tempo limite "
"igual ao número SEKUNDOS\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSES      lista de servidores DNS para consulta "
"(separada por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE  ligar o resolver DNS ao ADRESSE (nome do "
"host ou endereço IP) local\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEC         instalação do timeout de pesquisa no DNS em"
" segundos\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"--connect-timeout=SEK     atribui o tempo de espera para conexão em SEK\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"       --read-timeout=SEC        estabelecimento do tempo de espera para "
"leitura em segundos\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDOS            pausa de um segundo entre as solicitações\n"
"                                 (aplica-se quando mais de uma URL fornecida para abertura)\n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS       espera de 1..SEGUNDOS entre tentativas "
"sucessivas para a recuperação (aplicável quando mais de uma URL será "
"baixada) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --random-wait             pausa de 0,5*WAIT...1,5*WAIT segundos entre"
" as cargas (quando mais do que uma URL for carregada)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                  desligar o proxy explicitamente"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=%s              definir a quantidade de quota da "
"transferência em %s"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRESSE      ligar ADRESSE (nome do host ou endereço "
"IP) localmente\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED           limitar a velocidade de upload para "
"SPEED\n"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "       --no-dns-cache              desligue o cache de consultas DNS\n"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS    restringir caracteres no nome dos "
"arquivos para aqueles aceitos pela operadora do sistema de trabalho \n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             ignorar diferenças de maiúsculas e "
"minúsculas ao comparar arquivos ou diretórios\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "--inet4-only              подключаться только к адресам IPv4"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only              подключаться только к адресам IPv6"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar primeiro aos endereços da família"
" (pode ser IPv6, IPv4 ou nenhum) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr ""
"       --user=USUÁRIO                 instale o usuário ftp e http para "
"USUÁRIO\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr "       --password=PAROL          definir ftp- e http-parábol em PAROL"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password            pedir senhas"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=КОМАНДА       especifique o manejo de credenciais para "
"solicitações ao nome do usuário e senha. Se nenhuma COMMAND for definida, "
"será utilizada a variável ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "--no-iri                    desligar suporte aos IRIs"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como ponteiro de codificação "
"local para IRI\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como ponteiro de codificação "
"remota por padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"       --unlink                    apagar arquivo antes de sobrescrever"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash            deixar arquivos com somas de hash "
"incorretas (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=NOMBRE    ordem numérica metaurl\n"
"                 Metalink application/metalink4+xml"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http        utilizar as metadados Metalink a partir "
"do cabeçalho da resposta HTTP\n"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr "--preferred-location      localização preferida dos recursos Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                   habilitar armazenamento de dados metadados "
"nos atributos extensivos do arquivo\n"

msgid "Directories:\n"
msgstr "Diretórios:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories           não criar diretórios\n"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        forçar a criação de diretórios\n"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr " -nH, --no-host-directories       não criar diretórios como no nó"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories      utilizar diretórios com o nome do "
"protocolo\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "  -P,  --directory-prefix=ПРЕФИКС   salvar arquivos no ПРЕФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=CÓMODO           ignore CÓMODO components of the removed "
"directory\n"

msgid "HTTP options:\n"
msgstr "Opciones HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=POLIZOVATEL\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "       --http-password=PASSWORD        definir senha HTTP em PASSWORD\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "--no-cache                   ignorar dados tersinggah do servidor"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=PAISHA        altere o nome da página por defeito "
"(geralmente é 'index.html')\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E,  --adjust-extension          salvar documentos HTML/CSS com extensões "
"apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr "--ignorar-comprimento         abaixo do cabeçalho 'Content-Length'"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=STRING             inserir STRING no cabeçalho\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TYPE       escolha de compressão: auto, gzip ou none. "
"(por padrão: none) \n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"--max-redirect              batas maksimal yang diperbolehkan untuk "
"redirection per halaman\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr "       --proxy-user=USUÁRIO   definir USUÁRIOS para proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLLE   instale PAROLLE como senha para o proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           incluir no pedido HTTP o cabeçalho 'Referer: "
"URL' \n"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGÊNTE      identificar como AGÊNTE em vez de "
"Wget/VERDADEIRO\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"--no-http-keep-alive    desligar o suporte HTTP keep-alive (conexões "
"persistentes)"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                não utilizar cookies"

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies do FILE antes de iniciar o "
"jogo\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr ""
"       --save-cookies=ARQUIVO     salvar cookies no ARQUIVO após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      salvar e manter cookies de sessão (non-"
"permanent) \n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING          utilizar método POST; envio de STRING "
"como dados\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILE\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod         utilizar método \"HTTPMethod\" no "
"cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      envio STRING como dados; \n"
"                               DEDONHES ser especificado o parâmetro --method."

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        criação de conteúdo FILE; --method HARUS "
"diatur\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   принимати o header Content-Disposition  ao escolher nomes para arquivos locais\n"
"(EXPERIMENTAL)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"       --content-on-error      exibir dados aceitos em caso de erro do "
"servidor\n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"       --auth-no-challenge     enviar informações sobre autenticação HTTP "
"básica sem esperar por um primeiro reconhecimento do servidor\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Opciones HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR        escolha do protocolo seguro PR entre "
"auto, SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr "--https-only             apenas por HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr ""
"       --no-check-certificate      não validar o certificado do servidor\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE          fichero de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=ТИП   тип сертификата пользователя: PEM або DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr "       --private-key=%s       arquivo chave privada\n"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr "       --private-key-type=ТИП   тип секретного ключа: PEM або DER\n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr "       --ca-certificate=FILE    ficheiro com um conjunto de CA\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=КАТ       catálogo, no qual é armazenado a lista de "
"CA\n"

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          ficheiro com lista de revocações CRL\n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES  fichero de chave pública (PEM/DER), ou "
"qualquer número de hash sha256 codificado em base64 precedido por 'sha256//'"
" e separado por ';', para verificação das pares\n"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
