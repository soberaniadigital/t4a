"FINISHED --%s--\n"
"Total wall clock time: %s\n"
"Downloaded: %d files, %s in %s (%s)\n"
msgstr ""
"Завершено — %s —\n"
"Tempo total de execução : %s\n"
"Arquivos carregados : %d, %s em %s (%s) \n"

