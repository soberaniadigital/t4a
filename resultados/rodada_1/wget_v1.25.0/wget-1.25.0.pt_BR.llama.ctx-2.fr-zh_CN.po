msgstr "Arquivo de lista de revocações do certificado '\\"

msgid "ERROR: GnuTLS requires the key and the cert to be of the same type.\n"
msgstr ""
"ERRO: Para GnuTLS é necessário que o par de chave e certificado sejam do "
"mesmo tipo."

msgid "Your GnuTLS version is too old to support TLS 1.3\n"
msgstr ""
"A versão do GnuTLS que você está utilizando é muito antiga para suportar o "
"TLS 1.3."

