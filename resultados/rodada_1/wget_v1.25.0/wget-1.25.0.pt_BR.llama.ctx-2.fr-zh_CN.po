msgstr "Erro ao inicializar o libcares"

msgid "Failed to init c-ares channel\n"
msgstr "Erro na inicialização do canal c-ares"

msgid "Failed to parse IP address '%s'\n"
msgstr "Не foi possível analisar a adresa IP \"%s\""

msgid "Failed to set DNS server(s) '%s' (%d)\n"
msgstr "Não foi possível atribuir o servidor DNS \"%s\" (%d)."

msgid "No URLs found in %s.\n"
msgstr "Urls não encontradas no arquivo %s."

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Could not download all resources from %s.\n"
msgstr "Não é possível baixar todos os recursos do %s."

