msgstr ""
"GnuTLS : valor %u para o parâmetro 'secure-protocol' não está implementado"

msgid "Please report this issue to bug-wget@gnu.org\n"
msgstr "Comunique-se sobre esta falha para <bug-wget@gnu.org>"

msgid "GnuTLS: unimplemented 'secure-protocol' option value %d\n"
msgstr ""
"GnuTLS: valor %d para o parâmetro 'secure-protocol' não está implementado"

msgid ""
"GnuTLS: Cannot set prio string directly. Falling back to default priority.\n"
msgstr ""
"GnuTLS: não é possível definir diretamente a cadeia de prioridade. A "
"prioridade padrão será utilizada."

msgid "ERROR"
msgstr "ОШИБКА"

