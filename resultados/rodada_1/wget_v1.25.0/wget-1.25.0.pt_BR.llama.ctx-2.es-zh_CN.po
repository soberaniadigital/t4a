msgstr "O parâmetro '-O' não é suportado para download de metalink. IGNORADO."

msgid "[--trust-server-names %s, --directory-prefix=%s]\n"
msgstr "[--trust-server-names %s, --directory-prefix=%s]"

msgid "Planned metalink file: %s\n"
msgstr "Ficheiro metalink planejado: %s"

msgid "Secured metalink file: %s\n"
msgstr "Arquivo metalink seguro: %s"

