msgid "Please send bug reports and questions to <bug-wget@gnu.org>.\n"
msgstr "Envie mensagens sobre erros e perguntas para <bug-wget@gnu.org>."

msgid "Memory allocation problem\n"
msgstr "Problema de alocação de memória"

msgid "Exiting due to error in %s\n"
msgstr "Terminação do trabalho devido a erro em %s"

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações sobre os parâmetros adicionais, tente usar a "
"comando `%%s --help`."

msgid "%s: illegal option -- `-n%c'\n"
msgstr "%s: parâmetro inválido — “-n%c”"

msgid "Debugging support not compiled in. Ignoring --debug flag.\n"
msgstr "Reunido sem suporte para depuração. O flag --debug é ignorado."

msgid ""
"Both --no-clobber and --convert-links were specified, only --convert-links "
"will be used.\n"
msgstr ""
"Serão utilizados somente os parâmetros --convert-links. Os outros, como o "
"--no-clobber e --convert-links, foram especificados simultaneamente."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"Указаны сразу --no-clobber и --convert-file-only, будет использоваться "
"только --convert-file-only."

msgid "Can't be verbose and quiet at the same time.\n"
msgstr ""
"Não é possível utilizar simultaneamente os modos verboso e silencioso."

msgid "Can't timestamp and not clobber old files at the same time.\n"
msgstr ""
"Não é possível utilizar marcadores de tempo simultâneos e não apagar "
"arquivos antigos ao mesmo tempo."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar ao mesmo tempo as opções --inet4-only e "
"--inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é possível especificar simultaneamente -k (ou --convert-file-only) e -O "
"se URLs múltiplas forem dadas, ou em combinação com os parâmetros -p ou -r. "
"Consulte o manual para detalhes."

msgid ""
"WARNING: combining -O with -r or -p will mean that all downloaded content\n"
"will be placed in the single file you specified.\n"
"\n"
msgstr ""
"AVISO: ao combinar o parâmetro -O com os opções -r ou -p, todos os dados carregados serão armazenados em um único arquivo. \n"
"\n"

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"AVISO: trabalhar com marcações de tempo não tem efeito quando usado em "
"combinação com o parâmetro -O. Para obter mais informações, consulte o "
"manual."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com o parâmetro --no-clobber, esse parâmetro será"
" desabilitado."

msgid ""
"WARC output does not work with timestamping, timestamping will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com marcações de tempo, as marcações de tempo "
"serão desligadas."

msgid "WARC output does not work with --spider.\n"
msgstr "O output WARC não funciona com --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com as opções --continue ou --start-pos; elas "
"serão desabilitadas. \n"

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Desculpe, mas o feed está desativado; a deduplicação WARC não encontrará "
"registros duplicados."

msgid ""
"Compression does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O compressão não funciona com --continue nem --start-pos; o último será "
"desativado."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente as opções --ask-password e "
"--password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"AVISO: O --ask-password foi especificado sem indicar o nome de usuário. Isso"
" geralmente não é a intenção."

msgid ""
"Specifying both --start-pos and --continue is not recommended; --continue "
"will be disabled.\n"
msgstr ""
"Não é recomendado especificar ao mesmo tempo --start-pos e --continue; o "
"último será desligado."

msgid "%s: missing URL\n"
msgstr "%s: URL não especificada"

msgid "You cannot specify both --post-data and --post-file.\n"
msgstr "Não é possível especificar --post-data e --post-file ao mesmo tempo."

msgid ""
"You cannot use --post-data or --post-file along with --method. --method "
"expects data through --body-data and --body-file options\n"
msgstr ""
"Não é permitido o uso simultâneo de --post-data e --post-file com o "
"parâmetro --method. O método espera que os dados sejam enviados através dos "
"campos --body-data e --body-file."

msgid ""
"You must specify a method through --method=HTTPMethod to use with --body-"
"data or --body-file.\n"
msgstr ""
"Para utilizar os parâmetros --body-data ou --body-file, é necessário "
"especificar o método de transporte através do parâmetro --method=HTTPMethod."

msgid "You cannot specify both --body-data and --body-file.\n"
msgstr ""
"Não é permitido especificar simultaneamente --body-data e --body-file."

msgid "This version does not have support for IRIs\n"
msgstr "Esta versão não suporta IRI"

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"Parâmetro -k ou -r pode ser utilizado somente em conjunto com -O, se a saída"
" for para um arquivo normal."

msgid ""
"--convert-links or --convert-file-only can be used together only if "
"outputting to a regular file.\n"
msgstr ""
"O parâmetro --convert-links ou --convert-file-only podem ser utilizados "
"juntos apenas se o resultado for produzido em um arquivo regular."

