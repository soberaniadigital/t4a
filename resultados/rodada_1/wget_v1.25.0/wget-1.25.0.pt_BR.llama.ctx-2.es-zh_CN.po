msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: логика lógica inválida %s; use `on' ou `off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr ""
"%s: %s: não é permitido um argumento para a opção '%s'; use `on', `off' ou "
"`quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. Por favor, verifique novamente."

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: valor byte inválido %d. Por favor, verifique novamente."

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Horário de tempo inválido %s. Por favor, verifique novamente."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: período de tempo negativo %s"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso de askpass é necessário uma string ou a variável ambiente "
"WGET_ASKPASS ou SSH_ASKPASS. Estes são os dados que permitem ao programa "
"autenticar com senhas."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: valor %s inválido. (ZH_CN)"

msgid "%s: %s: Invalid header %s.\n"
msgstr ""
"%s: %s: Nome inválido do cabeçalho de arquivo %s. Por favor, verifique "
"novamente."

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s: %s: Nome inválido do arquivo WARC %s. \n"

msgid "%s: %s: Invalid progress type %s.\n"
msgstr "%s: %s: Tipo de progresso inválido %s. \n"

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição %s inválida, use "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "A codificação %s é inválida"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O processamento de conversão de %s para %s não é suportado"

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes inválida ou incompleta."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: locale não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d:%s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O E/S está sendo redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; desativando a registragem de log."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Modo de utilizar: %s [PARÂMETRO]... [URL]..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para os parâmetros longos também são necessários "
"para os parâmetros curtos."

msgid "Startup:\n"
msgstr "Início do processo:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version                    Mostrar a versão do Wget e encerrar o "
"processo."

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                       Mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para iniciar no modo "
"de fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr ""
"  -e, --execute=%s\n"
"    Execute a command in the style of `.wgetrc`."

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o, --output-file=FILE    salvar mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr "--append-output=FILE        adicionar mensagens ao final do FILE\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                      Mostrar uma quantidade significativa de "
"informações para depuração."

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr ""
"  -q,  --quiet                      modo silencioso (sem saída de "
"informações)"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
" -v, --verbose                    Mostrar saída detalhada (por padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose          Desligue o output de informações detalhadas "
"(parcialmente) \n"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=UNIDADES_METRICAS    determinar UNIDADEM. UNIDADE pode"
" ser bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo <FILE> \n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos listados no FILE Metalink "
"<FILE> local\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL            considerar que as ligações das URLs no arquivo "
"de entrada (-i -F) são relativas à URL especificada."

msgid "       --config=FILE               specify config file to use\n"
msgstr ""
"       --config=%s         especifique o arquivo de configuração a ser "
"utilizado\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config                 não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registre as razões para rejeição de URL no "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             configurar число de tentativas <ЧИСЛО> (0 "
"para sem limite) \n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused          mesmo se a conexão for recusada, tente "
"novamente\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"considera erros de hospedeiro como não críticos e temporários, em vez de "
"fatais."

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS     Lista separada por vírgula de erros HTTP que devem ser reintentados, como: \n"
"\t404 Not Found (Não Encontrado), \n"
"\t503 Service Unavailable (Indisponível do Serviço), \n"
"\tInternal Server Error (Erro Interno no Servidor) etc."

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    escrever documentos no arquivo FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              não fazer uploads que levariam à "
"substituição de arquivos já existentes\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr "--no-netrc                   Não tentar obter dados do arquivo .netrc"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                   continuar a descarga parcial de um "
"arquivo carregado em partes\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=POSIÇÃO_DE_MESA           iniciar a descarga desde o "
"ponto de <POSIÇÃO_DE_MESA> (começando do zero)\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIPO            escolher tipo de indicador de progresso\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress              Mostrar o indicador de progresso em "
"qualquer modo de detalhe."

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping            não carregue novamente arquivos que já "
"foram processados, apenas se eles forem mais recentes do que os locais\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"--no-use-server-timestamps    não utilizar a verificação if-modified-since "
"para solicitações no modo de marcação do tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--no-use-server-timestamps   Não usar o timestamp obtido do servidor para "
"definir a marca de tempo local no arquivo\n"

msgid "  -S,  --server-response           print server response\n"
msgstr " -S, --server-response            Resposta do servidor\n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                    Não carregar nenhum arquivo"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         define timeouts igual para todos em "
"segundos\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADDRÉSSES      lista de servidores DNS a serem "
"solicitados (separados por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE\n"
"         Ligar o resolver DNS ao endereço de domínio especificado (nome do computador ou IP) local. \n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"--dns-timeout=SEKS         configura o timeout para a busca DNS em segundos "
"SEKS\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"       --connect-timeout=SEC     configuração de tempo limite para conexão "
"em SEC\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"       --read-timeout=SEC        configuração do tempo limite de leitura em "
"segundos\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDOS            pausa de SEGUNDOS entre as chamadas para "
"carregar (aplicável se houver mais de uma URL) \n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS       espera entre reintentos de carregamento "
"por X segundos (aplicável para mais de um URL)\n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --random-wait             pausa aleatória em 0.5*WAIT...1.5*WAIT segundos\n"
"                                 entre carregamentos (quando forem mais de 1 URL)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                   Desligue explicitamente o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓMO_SE_ESCREVER_NUMERO             definir a quantidade de "
"quota para transferência em NUMERO bytes"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRÉS      vincular ADRÉS (nome do computador ou "
"endereço IP) local\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED            limitar a velocidade de download para "
"SPEED\n"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "--no-dns-cache             Desligue o cache de consultas DNS"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=SO    restringe caracteres em nomes de arquivos"
" a aqueles que o SO permite\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"--ignorar-case                        ignorando maiúsculas/minúsculas ao "
"comparar arquivos/diretórios\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "  -4,  --inet4-only                仅连接至 IPv4 地址"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--ipv6-only                 conectar apenas a endereços IPv6\n"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar primeiro aos endereços da família"
" especificada (possivelmente IPv6, IPv4 ou nenhum) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr ""
"       --user=USUÁRIO                   instale e ftp- e http-usuários com o"
" mesmo nome <USUARIO> \n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr ""
"       --password=<PASSWORD>         definir ftp e http com o mesmo "
"<PASSWORD> \n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password               solicitar senha"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=COMMAND     especificar o gerenciador de senhas para "
"solicitar nome do usuário e senha. Se nenhuma COMMAND for definida, será "
"utilizado a variável ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "--no-iri                     Desligue o suporte IRI"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como a codificação local para "
"IRI (International Resource Identifier) \n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como codificação remota por "
"padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                     remover arquivo antes de desmontar"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash            deixar arquivos com hashes inválidos "
"(adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=NUMERO    aplicação Metalink/metalink4+xml metaurl "
"NUMBER\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar metadados Metalink a partir do "
"cabeçalho de resposta HTTP\n"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"--preferred-location        localização preferida para os recursos "
"Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                      no alteração da tradução, mantendo a "
"consistência com as traduções anteriores em inglês e espanhol."

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories             não criar pastas\n"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        forçar a criação de pastas diretórios"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr " -nH, --no-host-directories        Não cria diretórios no host\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories     utilizar o nome do protocolo nas pastas\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "  -P,  --directory-prefix=ПРЕФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО de caminhos adicionais de um"
" catálogo remoto\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=POLIZOV\n"
"        Estabelecer http usuário para POLIZOVATEL\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr ""
"       --http-password=<PASSWORD>        definir a senha http como "
"<PASSWORD> \n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"--no-cache                   Não utilizar dados armazenados no servidor."

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=PAISHAO          alterar o nome da página por defeito "
"(geralmente é \"pagina.html\")\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr "  -E,  --adjust-extension          保持 HTML/CSS 文档的正确扩展名\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"--ignorar-tamanho              ignorando o campo 'Content-Length' nas "
"cabeceras"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr ""
"       --header=STRING              inserir STRING entre os cabeçalhos\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TIPO       escolha o tipo de compressão: auto, gzip ou "
"nenhum (por padrão: nenhum)\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          максимально permitido número de "
"redirecionamentos para a página\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USUARIO.   utilizar USUARIO como nome de usuário para "
"proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLHA        utilizar PAROLHA como a senha do "
"proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL                incluir no cabeçalho HTTP do pedido o "
"campo 'Referer: URL'"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENTE      identificar como AGENTE em vez de "
"Wget/VERSIÓN."

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive         Desligue o HTTP keep-alive (conexões "
"persistentes)。."

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                 não utilizar cookies."

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies a partir de FILE antes do "
"jogo\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      salvar e manter cookies de sessão (não "
"permanentes)\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING      utilizar método POST; envio de STRING como "
"dados\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envocação do conteúdo "
"da FILE\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr "       --method=HTTPMethod     utilizar método \"HTTPMethod\" na cabecera\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      enviar STRING como dados; \n"
"                               ДЕЛИВЕТ быть указан параметр --method\n"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envocação do conteúdo de FILE; \n"
"                               DEVE ser especificado o parâmetro --method\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   принимати conteúdo-disspost no nome dos "
"arquivos locais (EXPERIMENTAL)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"--content-on-error           Em caso de erro do servidor, exibe os dados "
"recebidos."

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"--auth-no-challenge     enviar informações de autenticação básica HTTP sem "
"esperar pelo desafio do servidor."

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR         escolha do protocolo de segurança: auto,"
" SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr "--https-only                   apenas seguindo links HTTPS seguros"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr "--no-check-certificate      não verificar o certificado do servidor."

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       arquivo de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=ТИП   тип сертификата пользователя: PEM або DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr ""
"       --private-key=FILE\n"
"        Arquivo de chave privada."

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr "       --private-key-type=TYPE   tipo de secreto key, PEM ou DER."

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr ""
"       --ca-certificate=FILE    arquivo com um conjunto de certificados CA\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=КАТ       каталог, no qual é armazenado o listagem dos"
" certificados de CA com hash\n"

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr ""
"       --crl-file=FILE          arquivo com o conjunto de CRLs (Certificado "
"Revogados) \n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES   Arquivo de chave pública (PEM/DER), "
"qualquer número de hashes sha256, codificados como base64 e começando com "
"'sha256//', separados por ';', para verificar contra o par"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE        arquivo com dados aleatórios para "
"inicializar o pseudo-gerador de números aleatórios (PRNG) do SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo o soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=STRING         definir a string de prioridade (GnuTLS) ou lista de cifrados (OpenSSL) diretamente. Use com cuidado. Este parâmetro substitui o valor do protocolo seguro padrão.\n"
"                                O formato e sintaxe da string dependem do motor SSL/TLS específico utilizado."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--no-hsts                    Desligue HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS "
"(sobreescreve o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"arquivos binários FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr ""
"       --ftp-user=USER          defina USER como o nome de usuário ftp\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=ПАРОЛЬ   установить ftp-пароль в ПАРОЛЬ\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "       --no-remove-listing         Não remova arquivos ‘.listing’"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"--no-glob                    desligue a expansão de padrões para nomes de "
"arquivos FTP\n"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp             desligue o modo 'pasivo' de "
"transferência"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr "--preserve-permissions      preservar permissões de arquivos remotos"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"--retr-symlinks              --recursão, carregar arquivos ligados (não "
"diretórios) \n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                  utilizar FTPS implicitamente (porta "
"padrão é o 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"--ftps-resume-ssl               reinicia a sessão SSL/TLS iniciada no canal "
"de controle ao abrir o canal de dados."

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"       --ftps-clear-data-connection    apenas criptografa o canal de "
"controle; os dados não são criptografados\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"--ftps-fallback-to-ftp           Retorna ao FTP, se o servidor não suportar "
"FTPS\n"

msgid "WARC options:\n"
msgstr "Parâmetros WARC:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"--warc-file=FILENAME\n"
"Guardar dados da solicitação/resposta em um arquivo .warc.gz."

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr ""
"--warc-header=STRING        insere STRING no início do registro warcinfo\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=ЧИСЛО     максимального размеу файлів WARC равен "
"ЧИСЛУ\n"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr ""
"       --warc-cdx                   escrever em arquivos CDX indexados"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILENAME          não salvar registros que estejam "
"listados no arquivo CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr "--no-warc-compression        Não comprime arquivos WARC com GZIP\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "--no-warc-digests            Não calcule digestas SHA1"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr "--no-warc-keep-log           Não salve o arquivo de log no campo WARC"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=ARQUIVO         Diretório temporário para arquivos "
"gerados pela ferramenta de gravação WARC\n"

msgid "Recursive download:\n"
msgstr "Descarregar recursivamente:"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr ""
"--recursão\n"
"    especifica a carga recursiva do diretório para baixar arquivos e subdiretórios."

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr ""
"  -l,  --level=ЧИСЛО        глубина рекурсивного обхода (inf или 0 — "
"бесконечность) \n"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr ""
"--delete-after              Apagar arquivos locais após a conclusão da "
"transferência de dados"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
"  -k,  --convert-links      transformar links locais em HTML ou CSS "
"carregados\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr ""
"       --convert-file-only  converter apenas a parte do arquivo da URL (a "
"base nome) \n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                      antes de escrever o arquivo X, rota até um "
"máximo N de cópias de backup\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
"--backup-converted           Antes de converter o arquivo X, fazer uma cópia"
" como X_orig.\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"--backup-converted           Antes de converter o arquivo X, fazer uma cópia"
" de backup como X.orig.\n"

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"  -m,  --mirror                    -N -r -l inf --no-remove-listing 的缩写形式。\n"

msgid ""
"  -p,  --page-requisites           get all images, etc. needed to display "
"HTML page\n"
msgstr ""
"  -p, --page-requisites    carregar todas as imagens e outros elementos "
"necessários para a exibição de uma página HTML."

msgid ""
"       --strict-comments           turn on strict (SGML) handling of HTML "
"comments\n"
msgstr ""
"       --strict-comments            utilizar o manejo estrito (SGML) dos "
"comentários em HTML\n"

msgid "Recursive accept/reject:\n"
msgstr ""
"Permissões/proibições para recursão: \n"
"\"%s\": \"%d\",\n"
"\"%<PRIuMAX>\": \"%<PRIuMAX>\"}."

msgid ""
"  -A,  --accept=LIST               comma-separated list of accepted "
"extensions\n"
msgstr ""
"  -A,  --accept=LIST                Lista separada por vírgula de extensões "
"aceitas\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LIST                Lista separada por vírgula de extensões "
"rejeitadas\n"

msgid "       --accept-regex=REGEX        regex matching accepted URLs\n"
msgstr ""
"       --accept-regex=РЕГВЫР       регулярное выражение для разрешённых URL"

msgid "       --reject-regex=REGEX        regex matching rejected URLs\n"
msgstr ""
"       --reject-regex=РЕГВЫР       регулярное выражение для запрещённых URL"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr "       --regex-type=ТИП            tipo de regex (posix|pcre) \n"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr "       --regex-type=ТИП            tipo de regex (posix)"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr ""
"  -D,  --domains=СПИСОК            списки разрешённых доменов, через "
"запятую\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr ""
"       --exclude-domains=LIST    lista separada por vírgula de nomes de "
"domínio proibidos\n"

msgid ""
"       --follow-ftp                follow FTP links from HTML documents\n"
msgstr ""
"--follow-ftp                 rastreie os links FTP nos documentos HTML"

msgid ""
"       --follow-tags=LIST          comma-separated list of followed HTML "
"tags\n"
msgstr ""
"       --follow-tags=LIST           Lista separada por vírgula de tags HTML "
"a seguir\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignore-tags=LIST\n"
"        lista separada por vírgula de etiquetas HTML a ignorar"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"  -H,  --span-hosts                   visitando hosts externos na recursão\n"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr "  -L,  --relative                   apenas segue links relativos"

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr "  -I,  --include-directories=LISTA DE CATALOGAS ACEITAS\n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"--trust-server-names  utilizar o nome, indicado no URL redirecionante final,"
" como último componente."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclude-directories=LISTA DE CATALOGOS EXCLUÍDOS\n"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr "  -np, --no-parent                 não subirá no diretório pai\n"

msgid ""
"Email bug reports, questions, discussions to <bug-wget@gnu.org>\n"
"and/or open issues at https://savannah.gnu.org/bugs/?func=additem&group=wget.\n"
msgstr ""
"Envie mensagens sobre erros, perguntas e sugestões para <bug-wget@gnu.org> "
"ou abra o problema no site "
"https://savannah.gnu.org/bugs/?func=additem&group=wget."

