msgstr "%s: Comando desconhecido %s na linha %<PRIuMAX> da fonte de dados. \n"

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro de processamento do arquivo wgetrc (env SYSTEM_WGETRC). Por favor, "
"verifique '`%s`' ou especifique outro arquivo com a ajuda da opção '-c'."

msgid ""
"Parsing system wgetrc file failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr "Erro ao processar o arquivo wgetrc do sistema. Por favor, verifique '\\"

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Aviso: os arquivos wgetrc do sistema e do usuário indicam ambos em %s. "
"Por favor, verifique se não há erros no seu .wgetrc."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Expressão lógica inválida; use 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: DE: %s é inválido; use 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. Por favor, verifique novamente."

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor de byte inválido %s. Por favor, verifique novamente."

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Período de tempo inválido %s"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso de askpass é necessário uma string ou a variável ambiente "
"WGET_ASKPASS definida, também SSH_ASKPASS."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor inválido %s. (Invalido)%d} (Invalid Value)"

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: Cabeçalho inválido %s. Por favor, verifique novamente."

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s: %s: Cabeçalho WARC %s inválido. Por favor, verifique novamente."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr ""
"%s: %s: Tipo de progresso inválido %s. Por favor, verifique o tipo do seu "
"arquivo e tente novamente."

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição inválida %s, utilize "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "A codificação %s não é permitida"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão de %s para %s não é suportada."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes parcial ou inválida"

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado de código %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: local não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha na codificação IDN (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d:%s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr ""
"%s: Protokollierung des %s%s wird ausgeschaltet. Aguardando novas "
"instruções."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL] ..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas são também necessários para as"
" opções curtas."

msgid "Startup:\n"
msgstr "Beim Start:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version                   Mostrar versão do Wget e encerrar a "
"execução\n"

msgid "  -h,  --help                      print this help\n"
msgstr " -h, --help                      mostrar esta ajuda"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para entrar no modo de"
" fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr ""
"  -e,  --execute=%s           executar comando no estilo de '.wgetrc' \n"

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrever mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=FILE\n"
"    Adicionar mensagens ao final do arquivo FILE."

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr "  -d,  --debug                     Ausgabe de depuração mostrar\n"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "  -q,  --quiet                     sem mensagens de erro ou aviso"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
"  -v,  --verbose                   mostrar informações detalhadas (padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose                menos mensagens, mas não em silêncio\n"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com a lista local ou externa\n"
"                             do FILE\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos listados na local Metalink "
"FILE\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL            considere que as referências na ficheiro de "
"entrada (-i -F) são relativas à URL especificada\n"

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=%s         definir arquivo de configuração\n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                 nenhuma configuração de arquivo utilizar"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registros das razões para a recusa da URL no "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=CÓMOSEIRO             definir o número de tentativas (como "
"seja) com CÓMOSEIRO sete ou sem limite. \n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused         Repetir, mesmo que o parceiro tenha "
"recusado a conexão\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error=ERRO DE HOST\n"
"        Trata os erros de host como não críticos e temporários."

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS  COMMA-SEPARATED LIST OF HTTP ERRORS, AT "
"WHICH A RETRY IS INITIATED\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    escrever documentos no FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              Ignorar a cópia de arquivos que levariam à sobregravação dos existentes\n"
"                                     (e suas recriações)"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr ""
"--no-netrc                      Não tente obter credenciais do arquivo "
".netrc."

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                   Continuar o download de um arquivo "
"parcialmente baixado\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=POSICAO_INICIAL          Iniciar a descarga do local de "
"INÍCIO (considerado como 0)\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=DE            Escolher o tipo de indicador do progresso "
"com DE representar"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress             Mostrar uma barra de progresso em "
"qualquer modo detalhado\n"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping            não carregar novamente arquivos que já "
"estão presentes no sistema de forma a garantir apenas o envio dos mais "
"recentes em relação aos locais. \n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"       --no-use-server-timestamps    não utilizar a condição if-modified-"
"since para solicitações em modo de marcação do tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--no-use-server-timestamps     não instale a marca de tempo local da linha, "
"obtida do servidor. \n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         Resposta do servidor exibir\n"

msgid "       --spider                    don't download anything\n"
msgstr ""
"       --spider                    nenhum download (não carregar nada)"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         configuração de todos os tempos limite "
"igual ao número SEGUNDO\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSEN      Lista de servidores DNS a serem "
"consultados (separado por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE      vincular o resolver DNS à ADRESSE "
"(nome do computador ou IP) local\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEK         configuração do timeout para busca no DNS "
"em SEK\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr "--connect-timeout=SEK\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=SEK\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEGUNDAS             espera em SEGUNDAS entre os downloads "
"(para mais de uma URL) \n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDAS        1..SEGUNDAS entre as tentativas repetidas"
" de carregar (para mais de uma URL para download) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"--espera aleatória\n"
"                    Esperar entre 0,5*WAIT e 1,5*WAIT segundos\n"
"                    Entre as requisições (para mais de uma URL para baixar)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                 Keinen Proxy verwenden"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓDIGO                Estabelecer a quantidade de quota em "
"CÓDIGO setar\n"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRESSE      ligar ADRESSE (nome de host ou endereço "
"IP) do computador local\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr "       --limit-rate=СКОРОСТЬ     ограничить СКОРОСТЬ загрузки"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr ""
"--no-dns-cache              Desabilitar o cache de DNS para as solicitações. \n"
"\tPara obter mais informações, tente '--help'."

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS    Utilizar apenas caracteres aceitáveis "
"pelo sistema operacional em nomes de arquivos\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             ignorar maiúsculas e minúsculas ao comparar"
" nomes de arquivos ou diretórios\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "  -4,  --inet4-only              conectar apenas a endereços IPv4\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only              conectar apenas a adresses IPv6\n"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=FAMILIA conectar primeiro aos endereços do sistema "
"familiar (pode ser IPv6, IPv4 ou nenhum) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr "       --user=USUÁRIO             USUÁRIOS para ftp e http utilizar\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr "       --password=PAROLHOS         utilizar PAROLHOS para ftp e http\n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password              Pedir o password"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=КОМАНДА       especifica um comando para solicitar o "
"nome de usuário e senha. Se nenhum comando for definido, será utilizado a "
"variável ambiente WGET_ASKPASS ou SSH_ASKPASS.\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                     Desativar suporte para IRI\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      использовать КДР как локальную кодировку "
"для IRI\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     использовать КДР как удалённую кодировку\n"
"                                 по умолчанию\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"       --unlink                    Excluir arquivo antes de sobrescrever\n"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash              mantenha arquivos com somas de "
"verificação incorretas (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=%s    Metalink Application/metalink4+xml metaurl "
"Ordem de número %d\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar métricas de Metalink a partir do "
"cabeçalho da resposta HTTP\n"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location        localização preferida para Metalink "
"recursos"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                     Metadados em atributos de arquivo "
"estendidos armazenar\n"

msgid "Directories:\n"
msgstr "Verzeichnisse:"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "nenhum diretório, nenhuma pasta\n"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        Analisar e criar diretórios se necessário."

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr "  -nH, --no-host-directories      não criar diretórios como no nó\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories     utilizar o nome do protocolo em "
"diretórios\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr ""
"  -P,  --directory-prefix=ПРЕФИКС   salvar arquivos no diretório "
"PRЭФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО níveis de diretório da localização contrária\n"
"                                   pulá-los"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=ПОЛЬЗОВ.    установить http-пользователя в ПОЛЬЗОВАТЕЛЬ\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "       --http-password=PASSWORD     http-password em PASSWORD definir\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"       --no-cache              Rejeitar dados armazenadas em cache do "
"servidor\n"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"        --default-page=NAME        Alterar o nome da página por padrão "
"(geralmente é \"index.html\")\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E, --ajustar-extensão      salvar documentos HTML/CSS com as extensões "
"corretas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"--ignorar-comprimento         ignorar o campo de cabeçalho 'Content-Length'"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=%s        inserir STRINGA entre cabeçalhos\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=ТИП       тип сжатия: auto, gzip або none\n"
"                               (по умолчанию: none)"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"--max-redirect          максимально допустимое число перенаправлений\n"
"                               на страницу\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USUÁRIO_PROXY   utilizar o USUÁRIO_PROXY como nome de "
"usuário para proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLH   utilizar PAROLH como a senha para o proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           incluir no cabeçalho HTTP do pedido a linha "
"'Referer: URL'"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "--save-headers          salvar HTTP-vôspãs em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENT      identificar como AGENT em vez de "
"Wget/VERSÃO\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive    отключить поддержку активности HTTP (постоянные подключения)\n"
"\n"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                Não utilizar cookies"

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies antes do jogo a partir de "
"FILE\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      (não permanentes) Cookies de sessão lendo"
" e salvar\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"        --post-data=STRINGA utilizar método POST; envio de STRINGA como "
"dados\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILE\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod         método HTTP \"HTTPMethod\" utilizar no "
"cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      передача СТРОКИ como dados; \n"
"                               »--method« precisa ser especificado."

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envio do conteúdo da FILE; \n"
"                               DEVE ser especificado o parâmetro \"--method\"."

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   принимати conteúdo-disspostao no cabeçalho Content-Disposition, ao escolher nomes para arquivos locais\n"
"(EXPERIMENTELL)."

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"       --content-on-error      exibir o conteúdo aceito quando houver erro "
"no servidor. \n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"        --auth-no-challenge     отправлять информацию об аутентификации "
"Basic HTTP без ожидания ответа сервера\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR        Escolha do protocolo de segurança: auto, "
"SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr ""
"       --https-only             apenas por meio de redes seguras HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr ""
"--no-check-certificate      Não verificar o certificado do servidor DE"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE        Arquivo com certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=ТИП   тип сертификата пользователя: PEM або DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr "       --private-key=FILE      Arquivo com chave privada\n"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr "       --private-key-type=ТИП   тип секретного ключа: PEM або DER\n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr "       --ca-certificate=FILE    arquivo com a coleção de CA\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr "       --ca-directory=CATALHO\n"

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          arquivo com a coleção CRL\n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES Chave pública aberta (PEM/DER) ou qualquer"
" número de hashes sha256 em base64, começando com 'sha256//' e separados por"
" ';', para verificar o nó responderente."

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE        arquivo com dados aleatórios para "
"inicialização do gerador de números pseudoaleatórios SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=STRINGA         definir a string de prioridade (GnuTLS) ou "
"lista de cifras (OpenSSL) diretamente. Use com cuidado. Essa opção substitui"
" o valor do parâmetro '--secure-protocol'. O formato e sintaxe dessa string "
"dependem da biblioteca SSL/TLS utilizada."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                   HSTS не utilizar"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file                 Pfad da base de dados HSTS "
"(sobrempletando o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"binários arquivos FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr ""
"       --ftp-user=USUÁRIO FTP para utilizar o USUÁRIO como nome de usuário "
"do FTP\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=PAROLEl     utilizar PAROLEl como ftp-senha\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr ""
"       --no-remove-listing         «.listing» arquivos não serão removidos"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr "--no-glob                   FTP-arquivos com padrões de nome desligar"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp        desligue o modo 'passivo' de transferência "
"FTP\n"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"--preserve-permissions      Preservar as permissões da cópia remota do "
"arquivo"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         при рекурсивному доступе завантажити файли по"
" символьних ссылкам (не категорійки) \n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                 безусловно использовать FTPS (порт по"
" умолчанию — 990) \n"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               reiniciar sessão SSL/TLS, iniciada na"
" conexão de controle, ao abrir a conexão de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"       --ftps-clear-data-connection    apenas o canal de controle é "
"criptografado; os dados permanecem em texto puro\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"--ftps-fallback-to-ftp          volte para FTP, se o FTPS não for suportado "
"pelo servidor."

msgid "WARC options:\n"
msgstr "WARC-Optionen:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILENAME         Armazenar as solicitações e respostas em"
" um arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr "--warc-header=СТРОКА embutir СТРОКА no conteúdo warcinfo."

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=%<PRIuMAX>        O tamanho máximo dos arquivos WARC "
"é %<PRIuMAX> bytes\n"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                  CDX-Index-Dateien schreiben\n"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILENAME      Não salvar registros, listados neste "
"arquivo CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr ""
"       --no-warc-compression     não sinalizar WARC arquivos para compressão"
" GZIP\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "--no-warc-digests           nenhuma SHA1 de arquivo calculada"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr "--no-warc-keep-log          Não salvar o arquivo de log em um WARC\n"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=VERZEICHNIS  Diretório para arquivos temporários, "
"gerados pelo WARC-Schreiber\n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:\n"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive                 rekursiver Download\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr ""
"  -l,  --level=ЧИСЛО        глубина рекурсивної (inf e 0 — без ограницу) \n"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr ""
"       --delete-after              arquivos locais apagar após a carga\n"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
"  -k,  --convert-links      converter de links locais em HTML ou CSS "
"carregado\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr ""
"       --convert-file-only         Converta apenas a parte do nome de "
"arquivo da URL (também conhecida como 'Basename')\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                   antes de escrever o arquivo X, fazer backup até N\n"
"                     cópias de segurança mantidas."

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X, fazer uma cópia "
"como X_orig."

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X fazer uma cópia "
"de segurança no formato X.orig."

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"  -m,  --mirror                    Kurzform, que corresponde ao\n"
"                            '-N -r -l inf --no-remove-listing'."

msgid ""
"  -p,  --page-requisites           get all images, etc. needed to display "
"HTML page\n"
msgstr ""
" -p, --page-requisites           carregar todas as imagens e outros "
"elementos necessários para a exibição da página HTML\n"

msgid ""
"       --strict-comments           turn on strict (SGML) handling of HTML "
"comments\n"
msgstr ""
"       --strict-comments           Handomagem estrita (SGML) de comentários "
"HTML\n"

msgid "Recursive accept/reject:\n"
msgstr "Permissões/proibições recursivas:\n"

msgid ""
"  -A,  --accept=LIST               comma-separated list of accepted "
"extensions\n"
msgstr ""
"  -A,  --accept=%s                           lista de extensões permitidas "
"separadas por vírgula\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LISTA              lista de extensões proibidas, separadas "
"por vírgula."

msgid "       --accept-regex=REGEX        regex matching accepted URLs\n"
msgstr ""
"       --accept-regex=РЕГВЫР       регулярное выражение для разрешённых URL"

msgid "       --reject-regex=REGEX        regex matching rejected URLs\n"
msgstr ""
"       --reject-regex=РЕГВЫР       регулярное выражение для запрещённых URL"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr ""
"       --regex-type=ТИП            tipo de expressão regular (posix|pcre).\n"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr "       --regex-type=ТИП            tipo de expressão regular (posix) \n"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr ""
"  -D,  --domains=LISTA             lista de domínios separada por vírgula\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr ""
"       --exclude-domains=LISTE     lista de domínios proibidos, separados "
"por vírgula\n"

msgid ""
"       --follow-ftp                follow FTP links from HTML documents\n"
msgstr ""
"       --follow-ftp                FTP-Verweisen de HTML-Documentos seguir\n"

msgid ""
"       --follow-tags=LIST          comma-separated list of followed HTML "
"tags\n"
msgstr ""
"       --follow-tags=LISTA         lista de tags HTML, separada por "
"vírgula\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignore-tags=LISTE         lista de tags HTML a serem ignorados, "
"separada por vírgula\n"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"  -H,  --span-hosts                se \"--recursive\", também visa outros "
"hosts \n"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr "  -L,  --relative                  nur relativen Verweise folgen\n"

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr "  -I,  --include-directories=LISTA_DES_CARTEIRAS_ADICIONALES\n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"--trust-server-names utilizar o nome, indicado no URL de redirecionamento "
"final. \n"

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclude-directories=%s\n"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr "  -np, --no-parent                 não subir no diretório pai\n"

msgid ""
"Email bug reports, questions, discussions to <bug-wget@gnu.org>\n"
"and/or open issues at https://savannah.gnu.org/bugs/?func=additem&group=wget.\n"
msgstr ""
"Comunicar erros, perguntas e sugestões para o <bug-wget@gnu.org> ou abrir "
"problemas no site https://savannah.gnu.org/bugs/?func=additem&group=wget."

