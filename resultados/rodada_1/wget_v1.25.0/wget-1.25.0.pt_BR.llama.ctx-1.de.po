msgstr "GnuTLS: valor do parâmetro \"secure-protocol\" não está implementado"

msgid "Please report this issue to bug-wget@gnu.org\n"
msgstr ""
"Comunique-se sobre esta falha por meio do endereço de correio <bug-"
"wget@gnu.org>."

