msgid "Please send bug reports and questions to <bug-wget@gnu.org>.\n"
msgstr ""
"Para enviar mensagens sobre erros e sugestões de melhorias, envie para <bug-"
"wget@gnu.org>. Para a lista de correio da comunidade em alemão, consulte "
"<de@li.org>."

msgid "Memory allocation problem\n"
msgstr "Problema de alocação de memória"

msgid "Exiting due to error in %s\n"
msgstr "A execução será encerrada devido a uma falha em %s"

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações, digite a seguinte combinação de teclas: "
"'Ctrl+H'."

msgid "%s: illegal option -- `-n%c'\n"
msgstr "%s: parâmetro inválido — «-n%c»"

msgid "Debugging support not compiled in. Ignoring --debug flag.\n"
msgstr "Sobrado sem suporte à depuração. O flag --debug é ignorado."

msgid ""
"Both --no-clobber and --convert-links were specified, only --convert-links "
"will be used.\n"
msgstr ""
"São indicadas imediatamente --no-clobber e --convert-links, porém será "
"utilizado apenas o --convert-links."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"São indicadas imediatamente --no-clobber e --convert-file-only, será "
"utilizado apenas o --convert-file-only."

msgid "Can't be verbose and quiet at the same time.\n"
msgstr "Não é possível usar ao mesmo tempo o modo verboso e o silencioso."

msgid "Can't timestamp and not clobber old files at the same time.\n"
msgstr ""
"Не é possível utilizar simultaneamente marcadores de tempo e sobrescrever "
"arquivos antigos. \n"

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar ao mesmo tempo as opções --inet4-only e "
"--inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Нельзя укажити ao mesmo tempo -k ou --convert-file-only e -O, se URLs "
"múltiplas forem especificadas, ou em combinação com parâmetros -p ou -r. "
"Para detalhes, consulte a documentação."

msgid ""
"WARNING: combining -O with -r or -p will mean that all downloaded content\n"
"will be placed in the single file you specified.\n"
"\n"
msgstr ""
"PRECEDÊMENTES: a combinação do parâmetro -O com os parâmetros -r ou -p "
"indica que todos os dados baixados serão armazenados em um único arquivo. \n"

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"PRELUDE PARA O PROCESSO DE TRANSCRIÇÃO EM BRASILEIRO:\n"
"\n"
"'ПРЕДУПРЕЖДЕНИЕ: работа с метками времени не выполняется, если указан\n"
"параметр -O. Подробности смотрите в руководстве.'\n"
"\n"
"'WARNING: A funcionamento dos temporais não é possível quando o parâmetro –O for especificado.\n"
"Para mais informações, consulte o manual.'"

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com o parâmetro '--no-clobber', esse parâmetro será "
"desabilitado."

msgid ""
"WARC output does not work with timestamping, timestamping will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com marcas de tempo, as marcações de tempo serão "
"desligadas."

msgid "WARC output does not work with --spider.\n"
msgstr "Saída WARC não funciona com '--spider'."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com --continue ou --start-pos; essas opções serão "
"desabilitadas."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório de desligamento; a deduplicação WARC não encontrará registros "
"duplicados. \n"

msgid ""
"Compression does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"A compressão não funciona com --continue ou --start-pos; essas opções serão "
"desabilitadas."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente as opções --ask-password e "
"--password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"PRECISÃO: não foi especificado o nome de usuário, mas utilizou a opção "
"--ask-password. Isso geralmente não é necessário."

msgid ""
"Specifying both --start-pos and --continue is not recommended; --continue "
"will be disabled.\n"
msgstr ""
"Não é recomendado especificar ao mesmo tempo --start-pos e --continue; o "
"último será desabilitado."

msgid "%s: missing URL\n"
msgstr "%s: URL ausente"

msgid "You cannot specify both --post-data and --post-file.\n"
msgstr ""
"Não é permitido especificar --post-data e --post-file simultaneamente."

msgid ""
"You cannot use --post-data or --post-file along with --method. --method "
"expects data through --body-data and --body-file options\n"
msgstr ""
"Não é permitido o uso simultâneo das opções --post-data ou --post-file com a"
" opção --method. Ao selecionar a opção --method, são especificados dados em "
"parâmetros --body-data e --body-file."

msgid ""
"You must specify a method through --method=HTTPMethod to use with --body-"
"data or --body-file.\n"
msgstr ""
"Para utilizar `--body-data` ou `--body-file`, é necessário especificar o "
"método de comunicação através do parâmetro `--method=HTTPMethod`."

msgid "You cannot specify both --body-data and --body-file.\n"
msgstr ""
"Não é permitido especificar simultaneamente --body-data e --body-file."

msgid "This version does not have support for IRIs\n"
msgstr "Esta versão não suporta IRIs."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"O parâmetro '-k' ou '-r' pode ser utilizado apenas em conjunto com o -O, se "
"a saída for para um arquivo normal."

msgid ""
"--convert-links or --convert-file-only can be used together only if "
"outputting to a regular file.\n"
msgstr ""
"O parâmetro --convert-links ou --convert-file-only podem ser usados juntos "
"apenas se o resultado for produzido em um arquivo normal."

msgid "Failed to init libcares\n"
msgstr "Erro ao inicializar a biblioteca libcares"

msgid "Failed to init c-ares channel\n"
msgstr "Erro durante a inicialização do canal c-ares"

msgid "Failed to parse IP address '%s'\n"
msgstr "Не foi possível analisar o endereço IP \"%s\""

msgid "Failed to set DNS server(s) '%s' (%d)\n"
msgstr "Не foi possível configurar DNS-сервер(es) \"%s\" (%d)"

msgid "No URLs found in %s.\n"
