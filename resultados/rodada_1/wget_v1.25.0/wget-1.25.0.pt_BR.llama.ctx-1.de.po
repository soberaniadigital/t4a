"GnuTLS: Cannot set prio string directly. Falling back to default priority.\n"
msgstr ""
"GnuTLS: não é possível definir a prioridade diretamente. Voltemos ao padrão "
"de prioridade."

msgid "ERROR"
msgstr "ОШИБКА"

msgid "WARNING"
msgstr "PREDÚPRAZÃO"

msgid "%s: No certificate presented by %s.\n"
