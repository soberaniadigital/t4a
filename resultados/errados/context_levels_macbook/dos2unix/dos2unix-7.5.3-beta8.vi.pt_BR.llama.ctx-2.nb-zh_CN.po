msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         tillat endring av fileierskap\n"

msgid " -ascii                default conversion mode\n"
msgstr ""
"-ascii - modo padrão de conversão textual para caracteres sem acento (ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converter entre caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               utilizar codificação Windows 1252 (Taiu)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caráter DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar código DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar interface gráfica DOS 860 (Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar código DOS 863 (Chinês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar código de caráter DOS 865 (países nórdicos)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converter de caracteres 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preserva o “Marca de Ordem do Byte” (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preserva o “Marca de Ordem do Byte” (padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de modo de conversão -c, --convmode         chave do modo de convergência\n"
"   modo de convergência:\n"
"      ascii, 7bit, iso, mac (padrão é ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens de alerta\n"
"   table codec:            ansi, unicode, utf8 (ansi é padrão)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione um caractere de nova linha no final da linha se ela"
" não tiver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar conversão de arquivos binários em tabelas "
"separadas por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            mostra este ajuda ao utilizador."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o conjunto de dados (tabela) a ser analisado\n"
"   tabelas …            conjuntos de dados que precisam da análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        mantenha o tempo original da data de criação do "
"arquivo\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibe aviso sobre o acordo de licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập-tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma nova linha no final do arquivo, mesmo"
" que o arquivo fique sem caracteres de nova linha (configuração padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       gera saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            conjuntos de dados que precisam ser convertidos para o modo do arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave modo silencioso, mudo todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar “Marca de Ordem do Byte” (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gỉr -r --remove-bom      gelo bôn"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            excluir linhas em ordem de processamento (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato do arquivo de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato do dado de entrada é "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o link simbólico e convertendo a diretiva de"
" comando"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca o símbolo de ligação por arquivos convertidos\n"
"(arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha ambos os símbolos e o objetivo inalterados "
"(padrão)"

