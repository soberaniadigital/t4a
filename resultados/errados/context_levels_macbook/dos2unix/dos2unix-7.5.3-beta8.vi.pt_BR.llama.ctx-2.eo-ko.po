msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các tùy chọn] [tập tin ...] [-n tập tin vào tập tin ra ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento padrão de conversão ASCII para texto "
"plano"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converte caracteres entre o conjunto DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando página de código Windows 1252 (Tây Ái) "
"para o sistema operacional Vindozan."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                Utilizando o código padrão DOS 437 (Estados Unidos) "
"(definitivo)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"-850                Utilizando o trânslator de código DOS 850 (Tây Ái) do "
"sistema operacional MS-DOS."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando interface gráfica do DOS com paginação em "
"860 (Bolivia)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                Utilizando caminho de diretório DOS 863 (Ca Na Đa Pháp) "
"para acesso ao sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                Utilizando o driver DOS de código Page 865 (Baía da "
"Ilha) do sistema operacional MS-DOS."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte caracteres de kyu tsu 8 bit para espaço 7 "
"bit\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b, --keep-bom        reteni o “Byte Order Mark” em sua ordem original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o “Byte Order Mark” (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   Modo de Conversão:\n"
"ascii, 7bit, iso, mac ou mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     configuração da tela para exibir mensagens de erro\n"
"   TIPO DE BÁZARAÇÃO: 'ansi', 'unicode', ou 'utf8'\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adiciona o caractere de quebra de linha ao final da linha "
"se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório para converter arquivos binários em pares "
"de bytes (binário/texto)"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Exibe este ajuda textual."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
"-i, --info[=CỜ]        exibe informações do arquivo\n"
"   tập-tin ...            aplica análise em vários conjuntos de dados"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        preserva o dia de criação do arquivo original\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr "-l --newline         adiciona uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"-m, --add-bom         adiciona o 'Byte Order Mark' (marca de ordem de bytes "
"padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite a alteração do proprietário de arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dáfines ao final do texto se nenhum deles"
" estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi vào saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          gera o arquivo cópia (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet         modo silencioso. suprimindo todas as mensagens de "
"aviso."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      gelo byte ordenar (mặc định) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      excluindo 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            borra qua tabela binaria (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     reteni bd mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le com base na premissa de que o formato do dado de "
"entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na premissa de que o formato do dado de "
"entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        relata detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F --follow-symlink   para obedecer ao vínculo simbólico e converter o "
"objetivo desejado."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por cópias reais dos arquivos de destino\n"
"                         (arquivos originais não são alterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preserva links macios e objetivos sem alteração "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostra versão do programa."

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS 16 bit (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

