msgstr "Esta é a tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"'%s' encontra um erro ao interpretar o link mole de símbolo pequeno '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir arquivo temporário de saída: %s"

msgid "using %s as temporary file\n"
msgstr ""
"%s está sendo utilizado como um arquivo temporário para armazenar dados."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar os permissões do arquivo de saída temporária %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo que possui o arquivo %s não pode manter seus direitos "
"de propriedade. Por favor, revise suas ações."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, não foi possível alterar o proprietário e grupo do arquivo de saída"
" temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "'%s' nome para '%s': problema ao converter o nome."

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          '%s' é o objetivo do link macio de simbolo “%s”\n"

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está presente em '%s'"

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados separados por linha %s\n"

msgid "code page %d is not supported.\n"
msgstr ""
"Não há suporte para a página de código %d. Por favor, entre em contato com o"
" administrador do sistema."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, cujo tamanho do wchar_t não é necessariamente de "
"%d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que causou um erro ao converter a codificação "
"UTF-16 na linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão deste programa. Para obter mais informações sobre as opções "
"disponíveis e como converter de UTF-16 para UTF-8 em diferentes sistemas "
"operacionais, consulte o manual do usuário."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra {%s}, aqui não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra {%s}, o arquivo de saída %s é um link curto."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link fino %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borra o link fino %s, objetivo dele não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o vínculo fino %s, objetivo de ligação finita não é um arquivo típico."
" \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s para o formato de tabela Unix está em "
"andamento...\n"

msgid "converting file %s to Unix format...\n"
msgstr "A conversão do arquivo \"%s\" para o formato Unix está em andamento...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Convergindo o arquivo de texto '%s' para um formato Mac do tipo '%s'...\n"

msgid "converting file %s to Mac format...\n"
msgstr ""
"O processo de conversão do arquivo `%s` para o formato Mac está em "
"andamento...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Convergindo o arquivo de texto '%s' para um formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr ""
"O processo de conversão do arquivo '%s' para o formato DOS está em "
"andamento...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato de arquivo Unix "
"%s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para formato Unix %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Macintosh %s...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para formato Mac %s...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Convergindo o arquivo %s “%s” para o formato do arquivo de sistema "
"operacional DOS...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "A conversão do arquivo %s “%s” para o formato DOS está em processo..."

msgid "problems converting file %s to file %s\n"
msgstr "Ao converter o arquivo %s para o arquivo %s, houve um erro."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O comando 'cờ %c' para a opção '-i' ou '--info' apresentou um erro."

msgid "active code page: %d\n"
msgstr "a tela está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já definiu um modo de conversão %s inválido"

msgid "option '%s' requires an argument\n"
msgstr ""
"Selecione o \"%s\" solicitando um número de exemplo. Por favor, forneça um "
"valor numérico."

msgid "invalid %s display encoding specified\n"
msgstr "Já enviou uma tabela de visualização inválida %s\n"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no novo modo de abertura do "
"arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Substituição incompleta abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cadeia de substituição inválida. Substituto superior falhou."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
