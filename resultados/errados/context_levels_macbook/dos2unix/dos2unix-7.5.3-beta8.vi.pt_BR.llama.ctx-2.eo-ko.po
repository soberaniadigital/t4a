msgstr "%s BOM gritando. \n"

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "%s tem BOM %s. Para mais informações, tente `%s --help'."

