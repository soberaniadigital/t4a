msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivos ...] [-n entrada_arq saída_arq "
"…]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "opção --allow-chown permite a alteração do proprietário de um arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento de caracteres ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converte o conjunto de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizado o código de caracteres DOS 437 (US) "
"(padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizado para DOS Codepage 850 (Oeste Europeu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizado para DOS Codepage 860 (Português "
"Brasileiro)    "

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizado para DOS Codepage 863 (Codificação de Texto"
" Francês Canadense) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits em aqueles do espaço"
" dos 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o “Marca de Ordem dos Bits” (BOM) original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão:   ASCII, 7bits, ISO, MAC, padrão"
" é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação de exibição para mensagens de erro\n"
"   encodings disponíses: ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se necessário complementar\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           bússola ferramenta de conversão binária para arquivos"
" divididos em duas partes"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         çodificação GB18030 de UTF-16\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            dá aqui assistência nesta tarefa."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do ficheiro de entrada\n"
"   Ficheiro …            para análise dos ficheiros a serem processados."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantém o dia de criação do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         dá a licença da ferramenta\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona um novo caractere de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar o Byte Order Mark (marcação de ordem de "
"bytes) para UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          gera um novo arquivo de entrada e saída\n"
"   tápi-tin-vào      ficheiro original no modo do novo arquivo\n"
"   tápi-tin-ra           ficheiro gerado no modo do novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite alteração do proprietário (padrão) "
"da pasta de trabalho\n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dóis vírgula (,) no final da última "
"linha se nenhum deles estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       para saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          adiciona ao ficheiro atual (método de conversão) \n"
"   Ficheiro …            os arquivos que precisam ser convertidos no modo antigo-arquivo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, suprime todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apaga o “Byte Order Mark” (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga o “Byte Order Mark” (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            elimina o arquivo de saída (método seguro)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva UTF-16 codificação do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be considera que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguimento de símbolos e a conversão dos "
"objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos reais (as "
"origens permanecem inalteradas) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    permite a exclusão de símbolos virtuais (alta "
"prioridade) e não altera o caminho original do arquivo. A opção é obsoleta."

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do programa"

