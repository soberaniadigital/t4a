msgstr "Ao converter o arquivo de texto “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão da tabela de dados %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para a representação Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Fazendo a conversão da tabela de dados %s “%s” para o formato Macintosh…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo a conversão do arquivo de texto '%s' para o formato Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Fazendo a conversão da tabela de dados %s “%s” para o formato DOS, ..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo a conversão da pasta de dados %s “%s” para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, foram encontrados problemas."

msgid "problems converting file %s\n"
msgstr "Ao converter o arquivo %s, encontrou problemas."

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "cógio escolher a opção -i ou --info, mas o flag '%s' é inválido."

msgid "active code page: %d\n"
msgstr "A tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"O cálculo de tempo médio para a camada %s não foi concluído devido à falta "
"de dados."

msgid "option '%s' requires an argument\n"
msgstr "Para escolher a opção '%s', é necessário um número inteiro."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo da pasta de dados %s não foi especificado no novo modo de acesso "
"ao arquivo."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever na pasta de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. O par surrogado inferior é "
"inadequado."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. O paratexto superior não é válido."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
