msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [flags] [arquivos ...] [-n input file for sorting …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         permite a alteração do proprietário de arquivo\n"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  conversão entre codificações DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               usa página de codificação Windows 1252 (europeia "
"ocidental)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utiliza página de codificação DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utiliza página de código DOS 850 (europeia ocidental)"
" \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                använd DOS teckentabell 860 (portugisisk)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utiliza página de código DOS 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utiliza página de código DOS 865 (nórdico)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de 8 bits para o padrão de 7 "
"bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b --keep_bom        manté a marca de ordem dos bytes (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --manterBOM (padrão) Mantê a marca de ordem dos bytes (Byte Order Mark)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão\n"
"   modo de conversão    ascii, 7bit, iso, mac, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     defina a codificação dos textos mostrados\n"
"   codificação             ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma quebra de linha no final da última linha"
" se nenhum for encontrado\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           para a conversão forçada de arquivos binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converterá UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h --help            mostra este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] mostra a informação do arquivo\n"
"   ficheiro ... filas para analisar."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         mostra a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicione uma linha nova adicional\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a marca de ordem dos bytes (Byte Order Mark)"
" (padrão para UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escreve no novo arquivo\n"
"   original    ficheiro de entrada em nova versão do formato\n"
"   saída       ficheiro de saída em nova versão do formato"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração do acesso ao arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar uma nova linha no final da última se a "
"linha já existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to_stdout       escreve para a saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreve no arquivo antigo (padrão) \n"
"   ficheiro …              ficheiros para converter na versão antiga\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      Remove byte order mark (BOM) by default\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      remove a marca de ordem dos bytes (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --safe            saltar sobre os arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le fica assumindo que o formato de entrada é UTF-16LE."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        operação detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink segueix els enllaços simbòlics i converteix "
"osbjectius\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos\n"
"                         (arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr "-S, --skip-symlink    preserva links simbólicos e objetos (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         mostra versão número"

