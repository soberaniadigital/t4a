msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Passear sobre o arquivo UTF-16 %s, a medida do wchar_t é de %d bytes. \n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Hoje em dia, sobre o arquivo UTF-16 %s, um erro de conversão para a linha %u"
" foi gerado. Para obter mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hopar sobre o arquivo UTF-16 %s, a conversão para UTF-16 não está suportada "
"nesta versão do programa. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Pular sobre '%s', é um arquivo não padrão. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Pular sobre '%s', o arquivo de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Pular sobre o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Hoppar över symbolisk länk %s, målet är inte en vanlig fil. \n"
"\tOBS.: Ao utilizar este símbolico link (%s), lembre-se de que a destinação não é um arquivo normal."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Pular sobre '%s', o objetivo do link simbólico '%s' não é um arquivo normal."
" \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "converter o arquivo %s para o arquivo %s no formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "estão convertendo o arquivo %s para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "converter o arquivo %s para o arquivo %s no formato Mac…"

