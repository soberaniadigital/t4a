msgstr "problemes en resoldre l'enllaç simbòlic «%s»"

msgid "Failed to open temporary output file: %s\n"
msgstr "falha na abertura do arquivo de saída temporal: %s"

msgid "using %s as temporary file\n"
msgstr "s'està usant %s com a fitxer temporal."

