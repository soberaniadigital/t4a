msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a alteração do proprietário do arquivo de "
"texto"

msgid " -ascii                default conversion mode\n"
msgstr "chave -ascii                modo de conversão padrão para ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converter de caracteres entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando trângulo de caracteres Windows 1252 (Tây "
"Ái)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar trama de código DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando trângulo de controle DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizar trâng mã DOS 860 (Bồ Đào Nha)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar trâng mã DOS 863 (Ca Na Đa Pháp) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar trângulo de caracteres DOS 865 (línguas do "
"Norte da Europa)    "

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o espaço dos 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém o 'Byte Order Mark' original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o sinal de byte order mark (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de convergência para codificação/decodificação\n"
"   modo de conversão: ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir codificação para exibição de mensagens\n"
"   codificação:\tansi, unicode, utf8,\tdefault ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar quebra de linha no final da última linha se não "
"houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos binários em "
"formatos separados por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb160949 chame um conversor para GB18030 a partir de UTF-16."

msgid " -h, --help            display this help text\n"
msgstr ""
"opção --help\n"
"                    Mostrar esta ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações da tabela de dados (base) do arquivo\n"
"   base-de-dados …            bases de dados que precisam ser analisadas"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        mantém o dia e mês da data de criação do arquivo "
"gerado"

msgid " -L, --license         display software license\n"
msgstr ""
"licença -L, --license         exibir a licença para uso da interface gráfica"

msgid " -l, --newline         add additional newline\n"
msgstr "bổ xung thêm dòng mới"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione o 'Byte Order Mark' (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"
" \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adicionar quebra de linha ao final da última linha se não houver uma "
"(padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       enviar para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gera no arquivo antigo (padrão) \n"
"   tape-tin ...            os arquivos que precisam ser convertidos para o modo do armazenamento de backup"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, ocultando todas as mensagens de"
" aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            excluir do conjunto de dados fatiado (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le considera que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be implica que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguir links simbólicos e fazer a conversão dos "
"objetivos"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca links simbólicas por arquivos convertidos (os "
"originais não serão modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    manter links simbólicas e seus alvos inalterados "
"(padrão)\n"

