msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [-n tabela_entrada ficheiro_de_input filho.txt "
"...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite alteração de permissões para o arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão ASCII implicitamente"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para conversão entre DOS e codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows Code Page 1252 (Tây Anh) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Utilize o código de codificação DOS 437 (padrão) para converter a linha "
"%<PRIuMAX>."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS850 (Tây Árabe) para acessar os dados do sistema operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o transtorno DOS860 (Portugal) para acessar as opções de formatação "
"do seu sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o transtorno DOS 863 (Ca Na Đa Pháp) para análise de entrada/saída "
"padrão."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o DOS865 (Bacia) para acessar as informações do sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de 8 bits para o espaço dos 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preserva a marcação de ordem dos bytes (marca da "
"ordem de bits)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva a marcação de ordem dos bytes (byte order "
"mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chave de convergência:   ASCII, 7bit, "
"ISO e MAC (implicitmente é “ASCII”)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adiciona o código de codificare a ser utilizada para"
" as mensagens na tela (ansi, unicode, utf8 – padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione uma linha em branco no final se não houver nenhuma"
" presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Forçar, --force           force a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            afiçae a ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỜ]        exibe informações sobre o arquivo de entrada"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva o dia da data de criação do arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa a licenciar o software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicione uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marcação de byte order mark (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não permite a alteração do proprietário de arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dâng gói trong dòng cuối cùng nếu chưa có "
"gói (mặc định)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreve no stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"    salvar o conteúdo do tamanho de entrada para uso posterior\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           silencioso, mudo\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      eliminar marcação de ordem dos bytes (Byte Order "
"Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gelo bônus byte order mark (BOM) eliminação"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva o código UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rẽ que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        oferece informações detalhadas sobre as operações "
"realizadas."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bặn tập tin chuyển đổi (các tập"
" tin đích nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações simbólicas e links de destino "
"fixos (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versão"

