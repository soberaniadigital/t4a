msgstr ""
"Fiquei com dificuldades para traduzir o texto em UTF-16 '%s', a conversão de"
" codificações não é suportada nesta versão do programa %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho, não é um arquivo típico. \n"

