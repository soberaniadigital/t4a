msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [-n <input_file> <output_file> ...]}"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converte o conjunto de caracteres DOS para "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows Code Page 1252 (Tây Âu) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código DOS 437 (USA) padrão"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS Code Page 850 (Tây Anh) para acessar os dados do sistema "
"operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS 860 (Bồ Đào Nha) para acessar os dados de entrada/saída "
"padrão."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS Code Page 863 (Ca Na Đa Pháp) para acessar as opções de saída "
"padrão."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS Code Page 865 (Baía Árabe) para acessar os dados do sistema "
"operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"fazer o conversor de caracteres para um sistema baseado em binário, onde "
"cada caractere é representado por no máximo sete bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        بOM 유지"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantenha o byte order mark (BOM) padrão (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   chaveamento ASCII, 7bit, ISO, "
"MAC, padrão"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adiciona o código de codificação para a exibição dos"
" avisos. A configura0123456789rcia padrão é ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia solar, que é um componente essencial para a conversão "
"eficiente do sistema energético. Ao utilizar o comando `solarpower` no "
"Linux, você pode iniciar ou parar as operações da bateria em tempo real sem "
"interrupção ao trabalhar dentro de uma sessão Bash. Para executá-lo "
"corretamente, é necessário que a variável `${1}` seja preenchida com o "
"caminho para um arquivo JSON contendo os dados do seu sistema e `solarpower`"
" deve ser chamado sem argumentos adicionais."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help             visar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỜ]        exibe informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        출력 파일 날짜를 유지합니다."

msgid " -L, --license         display software license\n"
msgstr ""
"visa programar o programa com licença -L, --license         프로그래밍 라이얻스를 "
"표시합니다."

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline          adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Byte Order Mark” (marca de ordem de bytes) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dấu ngắt trong cuốn từ (không có dấu ngắm)"
" nếu không có dấu ngắm\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -O, --to-stdout       escrever para a saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carrega o arquivo antigo (padrão) \n"
"    criação de tabelas em um formato compatível com a versão anterior do programa."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, mudo todas as mensagens de erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      remover o byte order mark (byte order mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"gostaria de verificar se o arquivo está em um determinado formato. Se sim, "
"você pode usar a opção `--remove-bom` para remover os bytes BOM (Byte Order "
"Mark) do início da linha."

msgid " -s, --safe            skip binary files (default)\n"
msgstr "Saída -s, --safe             Apagar linha de entrada (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 codificação de maneira a mantê-la"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rá que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  심볼릭 링크를 따르고 대상을 변환합니다"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos e objetivos não alterados "
"(padrão)"

