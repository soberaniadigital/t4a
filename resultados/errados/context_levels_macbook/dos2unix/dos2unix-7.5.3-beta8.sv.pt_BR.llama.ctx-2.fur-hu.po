msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção -b, --keep-bom        mantenha a marca de byte ordenação (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        manter byte order mark (Byte Order Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteringsläge   ascii, 7bit, iso, mac, padrão "
"árabbi"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stáilize a codificação dos mensagens de texto para "
"visualização. Opções disponíveis: ansi, unicode, utf8, padrão é ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar uma linha em branco após a última linha de "
"um arquivo\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Fora de força           binarização em fita dos arquivos"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre chest test di jutori"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR]   mostre informações dos arquivos"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data do arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar mais linhas ao final do arquivo"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar byte ordning markering (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skripi til ny fil\n"
"   infil               fôr origjinâl i modalitât gnûf-file\n"
"   utfil             fôr di jessude i modalitât gnûf-file"

