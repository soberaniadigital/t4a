msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n input_file ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite a modificação do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrões de conversão pré-definidos"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               do Windows Codepage 1252 (padrão europeu ocidental)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação do DOS -437 (USA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS Tecnológico de Sinalização (DTS) para acessar as informações sobre"
" os campos do arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tecnologia de Codificação do Sistema (DTS) para obter informações "
"sobre a linha %<PRIuMAX>."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS teckentabell 863 (français canadien)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-Tekken 865 (nordisk)"

