msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [arquivos ...] [-n arquivo_entrada output.txt]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         wijziging van bestandseigenaar toestaan"

msgid " -ascii                default conversion mode\n"
msgstr "chave -ascii                modo padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converter entre codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar codificação Windows-1252 (Vietnamita) para o"
" trânslado de texto entre aplicações."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar código DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar tabuada DOS 860 (portuguesa brasileiro)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                dùng trang mã DOS 863 (Ca Na Đa Pháp)\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converter de caracteres para o padrão ASCII\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantenha o Byte Order Mark (BOM) original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preservar o “Byte Order Mark” (marca de byte padrão) "
"\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chave de conversão modo:   ascii, "
"7bit, ISO ou mac (modus padrão é 'ascii')"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      defina o codificador de texto para exibir mensagens no terminal\n"
"   Codificadores do Banner:\n"
"    'ansi', 'unicode', ou 'utf8'\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar um caractere de nova linha no final da última "
"linha se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocar conversão de arquivos binários em formato "
"separado por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            hiêrên tiết biệu hẹp này"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo de entrada\n"
"   ficheiro(s) que precisam ser analisados."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        behold utdata-filenames dato\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         licença de software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom          adicionar “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tây-tin-vào         tập tin gốc trong chế độ tập tin-mới\n"
"tây-tin-ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown       não permite a alteração do proprietário de "
"arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dòng vào cuối cùng nếu không có dòng ngắn "
"(mặc định) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregar tabela de origem (padrão) \n"
"   ficheiro ...            arquivos que precisam ser convertidos para o modo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, desabilitar todas as avisões\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o byte order mark (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe             binárias seguras (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        detalhamento da saída"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   seguir links simbólicos e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos\n"
"                   (as pastas de origem permanecerão inalteradas)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha a conexão fraca e o objetivo inalterável "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha técnica do DOS em 16 bits (WATCOM C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica do DOS em 16 bits (TurboC).\n"

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficha técnica do DOS em 32 bits (WATCOM C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha técnica DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficheiro não encontrado."

msgid "Cygwin version.\n"
msgstr "Ficha técnica do Cygwin. \n"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenômeno Windows 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha técnica do Windows 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows para arquitetura de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de %s.%s"

msgid "With Unicode UTF-16 support.\n"
msgstr "Có homenagem ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Có homenagem ao desenvolvedor que contribuiu para o projeto. Obrigado, %s."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Có horação de apoio linguístico. Para obter mais informações, tente `%s "
"--help' para mais detalhes."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte para o proprietário e grupo de usuários do arquivo. Para obter "
"mais informações, tente `%s --help'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter a propriedade de usuários e grupos do arquivo. "
"Para obter mais informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "Rota de entrada para arquivo temporário é muito longa:"

msgid "Writing %s BOM.\n"
msgstr "Embaralhando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM (Byte Order Mark) '%s'.\n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação UTF-16BE é a seguir."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrou um erro ao tentar dividir o link simbólico '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como temporário de arquivo."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões temporárias do arquivo de saída %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo que possui o arquivo %s não podem ser preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gerou erro ao alterar o diretório de origem e a associação da pasta %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "encontrou erro ao alterar o nome do arquivo para \"%s\"."

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"O objetivo da associação mínima entre as variáveis '%s' é obter um caminho "
"mais curto."

msgid "          output file remains in '%s'\n"
msgstr "tabela de saída ainda está presente no arquivo \"%s\""

msgid "Skipping binary file %s\n"
msgstr "Remover o arquivo de texto nº %s."

msgid "code page %d is not supported.\n"
msgstr "Não há suporte para o terminal de usuário %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Remova o conteúdo do arquivo UTF-16 %s, pois a dimensão de 'wchar_t' não é "
"igual ao esperado %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que causou um erro de conversão UTF-16 na linha "
"%u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra qua tabela de dados UTF-16 %s, converte a conversão para UTF-16 não é "
"suportada nesta versão do programa.%d"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra-se %s, pois este não é um arquivo regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico. O ficheiro de saída inicial %s"
" representa uma conexão complexa."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova a conexão mínima %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borracho de conexão mínima, %s. O objetivo dela não é um arquivo regular."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borracho o vínculo curto, porque o objetivo do link curto não é um arquivo "
"regular. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Embaralhamento em andamento de tabela %s “%s” para formato Unix (%d)...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Em processo de conversão da tabela `%s” para o formato Mac, ..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato Mac (%d)...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s...\n"

msgid "problems converting file %s to file %s\n"
msgstr "Está a convertendo o arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrou problemas ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O flago '%c' para a opção '-i' ou '--info' está incorreto."

msgid "active code page: %d\n"
msgstr "tráfego de rede atualizado: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "o modo de conversão %s não é válido."

msgid "option '%s' requires an argument\n"
msgstr "opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi especificado no modo de criação novo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Par de substituição inválido. Substitua abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: parceiro inválido. Parceiro anterior não foi removido."

msgid "has %s BOM.\n"
msgstr "Não foi possível obter estado (stat) do arquivo %s."

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Remova o arquivo UTF-16 %s, pois a codificação de caracteres atual da região"
" linguística não é UTF-8."
