msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         cho phép thay đổi chủ sở hữu tập tin"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão para texto em ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte caracteres entre DOS e ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando código de caracteres Windows 1252 (Tây Âu)"
" \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) "
"(padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando código de caractere DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando código de caractere DOS 860 (Boha Da Nova)"
"    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizando código de caráter DOS 863 (Chinês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando código de caracteres DOS 865 (Europa do "
"Norte)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de códigos ASCII 8 bits para 7"
" bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        giúme nguyên “Marca de Ordem dos Bits” (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b, --keep-bom        mantém o 'Byte Order Mark' (marca de ordem de bytes) "
"padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão: ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     monta a tabela de codificação para exibir mensagens comunicativas\n"
"    tabela de codificação:            ansi, unicode, utf8. Padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da linha se "
"não houver nenhum presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocada obrigatoriedade de conversão dos arquivos "
"binários em tabelas separadas por linhas."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            apresentação deste auxílio\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do arquivo\n"
"   tập tin …            os conjuntos de dados a serem analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        preserva o timestamp original da linha de entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir aviso de licença"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo carro em linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (opção "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona um caractere de nova linha no final da "
"linha, mesmo que o arquivo fique sem caracteres de nova linha (padrão por "
"defeito)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi vào saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão) \n"
"   tabela ...            as tabelas que precisam ser convertidas neste modo de armazenamento"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave de silêncio -q, --quiet           modo silencioso, sem mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            跳过二进制文件 (默认)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     giúmar mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régando que o formato do arquivo de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be coi réindo dândio de formato do arquivo como UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        exibição detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  根据符号链接转换其目标文件"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca o link simbólico por uma cópia do arquivo "
"convertido. (Arquivos de destino permanecem inalterados.)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr " -S, --skip-symlink   保持符号链接及其目标不变（默认）"

msgid " -V, --version         display version number\n"
msgstr "--versão         Mostra versão do programa"

