msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [ficheiro ...] [-n infile outfile …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permissão para alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversor ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre o conjunto de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizando codificação tabulação de caracteres Windows "
"1252 (europeia ocidental)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tabela de codificação DOS 437 (EUA) "
"(padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a tabela de codificação DOS 850 (viz. "
"europeia ocidental)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS Tecnológico Tabuletas de Blocos (860) do Brasil\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a tabulação de espaços DOS 863 (francesa-"
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar a tabela de sinalização DOS/Windows 865 "
"(nordic) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o plano de "
"codificação de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        beholda byteordermarkering (Byte Order Mark) \n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        behåll byteordningsmarkering (Byte Order Mark) "
"(standard)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteriasão de codificacórios \n"
"   converters de ASCII, BCD (7 bits), ISO-8859-1 e MacRoman; padrão é o ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     staja em códigos para exibição de mensagens de erro"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar uma quebra de linha no final da última "
"linha se nenhum for encontrado\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           tvinga konvertering av binära filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            visualizar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa informações sobre o arquivo\n"
"   ficheiro ...               ficheiros para analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo caractere de nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adição de marcador byte order (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skript do novo plik\n"
"   início de arquivo original i novo pliki\n"
"   saída para o novo plik\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário de arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar um caractere de nova linha ao final da "
"última linha (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever na saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro ...               Ficheiros para converter em formato de arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           tática silenciosa, minimizar todas as notificações"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      retirar o marcador de ordem de bytes (Byte Order "
"Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      retirar o marcador de ordem de bytes (Byte Order "
"Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            pular sobre arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le przyjęcie formatu pliku wejściowego UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be pretende que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utensidade detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink seguir links simbólicos e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetando links simbólicos de arquivos com cópias "
"convertidas (originais documentos permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos e alterações de objetivos "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versão numerica"

