msgstr "Hoje em dia, o tamanho do arquivo UTF-16 '%s' é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Hoje em dia, ocorreu um erro ao converter para UTF-16 no arquivo %s na linha"
" %u. Para obter mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
