msgstr ""
"Hoppar över UTF-16-fil %s, UTF-16-konvertering saknar stöd i denna version "
"av %s. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Hoppar sobre %s, não é um arquivo comum. Porem, se você precisa de ajuda "
"para entender o que isso significa em português, por favor, consulte a "
"documentação do seu sistema operacional."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Hoje, %s, o arquivo de entrada '%s' é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Pominięto dowiadzenie symbolico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Hoppar över symbolisk länken %s, målet är inte en vanlig fil. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Hoppar över %s, o objeto de sinalização para a ligação simbólica %s não é um"
" arquivo comum. Para obter mais informações sobre como utilizá-lo "
"corretamente, tente `%s --help'."

