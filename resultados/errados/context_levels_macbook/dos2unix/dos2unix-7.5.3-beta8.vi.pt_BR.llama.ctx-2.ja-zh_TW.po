msgstr "Esta interface oferece suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos no formato Unicode."

msgid "With native language support.\n"
msgstr "Có oferecer suporte ao mapeamento de localização do idioma nativo."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao proprietário original e grupo de propriedade do arquivo. "
"Para manter a posse exclusiva."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e grupo de propriedade do"
" arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo salvo está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

