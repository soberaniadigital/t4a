msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrado problema ao resolver o link simbólico '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Ocorreu um erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "atualmente utilizando %s como arquivo temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar a senha do arquivo de saída "
"temporária %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e o grupo de proprietários do arquivo %s não possuem direitos "
"exclusivos."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar a propriedade e o grupo do "
"arquivo de saída temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Ocorreu erro ao renomear o nome de usuário ‘%s’ para ‘%s’:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o objetivo do link simbólico '%s'."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída '%s' ainda contém dados"

msgid "Skipping binary file %s\n"
msgstr "Borra o arquivo de dados divididos em dois fatores %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o código da página %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a largura do wchar_t não é necessariamente de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Bordem o arquivo UTF-16 %s, que apresentou erro de conversão UTF-16 na linha"
" %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para ISO-8859-1. A conversão de "
"UTF-16 não é suportada nesta versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra %s, aqui não é um arquivo típico."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra %s, tabela de saída %s é um simbolico link."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link fino %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o símbolo de ligação pequeno %s, pois seu alvo não é um arquivo "
"típico. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link curto %s, objetivo %s do link curto não é um arquivo típico. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s para o formato de tabela Unix é realizada "
"atualmente...\n"

msgid "converting file %s to Unix format...\n"
msgstr "A conversão do arquivo “%s” para o formato Unix está em andamento..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"O processo de conversão do arquivo “%s” para o formato Mac está em "
"andamento. Arquivo convertido será chamado ‘%s’."

msgid "converting file %s to Mac format...\n"
msgstr "A conversão do arquivo “%s” para o formato Mac está em andamento..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato DOS está em "
"andamento...\n"

msgid "converting file %s to DOS format...\n"
msgstr "A conversão do arquivo “%s” para o formato DOS está em andamento...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de arquivo Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato Unix está em andamento..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato Macintosh de arquivo "
"%s…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato Mac está em andamento...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato de arquivo DOS %s está em "
"andamento..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato DOS está em andamento...\n"

msgid "problems converting file %s to file %s\n"
msgstr ""
"A conversão do arquivo %s para o arquivo %s foi iniciada. Se houver "
"problemas durante a conversão, por favor informe."

msgid "problems converting file %s\n"
msgstr ""
"Encontrado problema ao converter o arquivo %s durante a conversão do "
"arquivo."

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O comando '%c' selecionado para -i ou --info contém um erro de sintaxe."

msgid "active code page: %d\n"
msgstr "A página de tradução está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já foi enviado um modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "Já foi enviado uma tabela de exibição inválida %s\n"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de criação de novos "
"arquivos"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Falta cadeia de substituição "
"inferior."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cadeia de substituição inválida. Falta sequência superior."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a codificação atual do idioma não é UTF-8. Para "
"obter mais informações sobre as diferenças entre os formatos de texto e como"
" converter um para outro, consulte 'UTF-8 vs UTF-16'."
