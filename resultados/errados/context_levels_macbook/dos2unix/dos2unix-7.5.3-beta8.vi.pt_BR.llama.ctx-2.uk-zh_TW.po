msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilização: %s [parâmetros] [arquivo ...] [-n entrada_de_dados saída...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "chave de conversão ISO-8859-1 para DOS"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize a tabela de codificação do Windows 1252 (Tâmil) para o português "
"brasileiro."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a linha de código DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize a faixa de código DOS 850 (Tây Âu) para o processamento do arquivo "
"%s"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Utilize a linha de comando DOS 860 (português) para o seu projeto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize a linha de comando DOS 863 (Canadá Francês) para o seu projeto."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize a página DOS 865 (Europa do Norte) para o seu projeto de teste."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpia o arquivo '%s' com a opção '-b', para manter os sinais de ordem dos "
"bytes (BOM)."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "giúpia o BOM (Byte Order Mark) por padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão: ascii, 7bit, iso, mac, padrão é "
"ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir các thông báo\n"
"   bảng mã: ansi, unicode, utf8, type default é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha ao final da última coluna se ela não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bắt buôn câu -f, --force           forçar a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          convertem o UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use --help para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO] exibir dados do arquivo ...             informações sobre"
" o arquivo que precisa ser analisado\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr "Preservar o dia de criação do arquivo para a saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         Mostrar licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar um caractere de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marca de ordem (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         寫入新檔\n"
"   tập tin gốc trong chế độ tập tin-tính\n"
"   tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração de proprietário do arquivo "
"(valor padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dado de nova linha após a última coluna"
" se ela não existir (padrão)    "

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       imprimir em saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile         寫入原檔案 (預設) 文件 ...            旧檔案 ..."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      apagar o sinal de byte order mark (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o sinal de byte order mark (BOM) -r, --remove-bom      "
"apagar a marca do Byte Order Mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção segura -s, --safe            ignorar linhas duplicadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar em UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi rão de que o formato de entrada deve ser UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rá que o formato de entrada deve ser UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos e arquivos adicionados "
"(padrão) "

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostrar versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS em 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de referência para o Phiên bản DOS 16 bit (Turbo C)."

