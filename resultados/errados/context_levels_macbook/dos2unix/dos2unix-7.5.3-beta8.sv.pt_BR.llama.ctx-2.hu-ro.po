msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n ficheiro_entrada file ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alteração do acesso ao proprietário para o "
"ficheiro"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modul de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"converter entre DOS e conversão para o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (Europa do Leste) para acessar os dados de "
"entrada/saída padrão."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o codificador DOS 437 (padrão) para conversor de caracteres."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS850 (padrão europeu) para codificar dados."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS teckentabell 860 (portugues) para acessar as opções do sistema."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Utilize o DOS teckentabell 863 (frança-canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS 865 (nordisk) para utilização."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        păstrează marcajul de ordine dos bytes (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preserva a marca de ordem dos bytes (Byte Order "
"Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteringsläge   ascii, 7bit, iso, mac, padrão "
"árabe"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stabileça a codificação dos mensagens de erro e aviso"
" utilizadas para mostrar o logotipo do terminal. Ao invés disso, use UTF8 ou"
" Unicode."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma linha ao final do arquivo se não houver "
"nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Fora de -f, --force           forçar conversão dos ficheiros binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            vê este mensagem de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] visa filinformações \n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva o timestamp do arquivo de entrada"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa licenças de software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicione uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione marcação de byte ordenação (Byte Order Mark)"
" para UTF-8 (padrão)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile         escrever em um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (implicit)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          nu adaugă o intrerupere de linie la ultima rândul om "
"sau niciun (standard)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreve no stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro ...               ficheiro a ser convertido para o formato de arquivo velho"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           tela em silêncio, suprimindo todas as avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      eliminar marcação de ordem dos bytes (Byte Order"
" Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      eliminar marcação de ordem dos bytes (Byte Order"
" Mark) do arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte sobre ficheiros binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     păstreaja codificarea UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utmálias detalhes sobre as operações realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguem as links simbólicos e converte a entrada para "
"o formato desejado."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetze symbolische links mit convertidos fileres "
"(originais ficheiros permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e alterações de diretório "
"(padrão) \n"

