msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "chave -ascii                modo de conversão padrão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o conjunto de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizado trângulo de codificação Windows 1252 (Taiu)"
"    "

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa página de código DOS 437 (US) como referência "
"padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizado o trângulo de código DOS 850 (Tây Átina) do"
" padrão CPT-12/437 para a interface com sistemas Unix"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utiliza trens de caracteres DOS 860 (Boha Doanh) para"
" o Português do Brasil."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utiliza trens de caracteres DOS 863 (Ca Na Dialetto "
"do Sul da França) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizando página de codificação DOS 865 (Brasil)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte cátas de caracteres 8 bits para essa do "
"espaço dos 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o 'Byte Order Mark' na ordem de bytes "
"originais"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantém o “Marca de Ordem dos Bits” (método padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de convergência para a codificação/decodificação\n"
"   modo de conversão:\n"
"ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     출력 텍스트 메시지 인코딩을 설정합니다\n"
"  인코딩            ansi, unicode, utf8, Vorgabe ist ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar caractere de quebra de linha no final da linha se"
" não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           obrigatório para converter arquivos n-afiliados"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         transforma tabelas UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            exibe este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do arquivo\n"
"   tập-tin …            listagem de nomes dos arquivos a serem analisados."

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"giúpia -k, --keepdate        mantém o dia de entrada original da tabela de "
"saída"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibe a licença para uso de software em formato "
"gráfico"

msgid " -l, --newline         add additional newline\n"
msgstr "-l, --newline         adiciona um caractere de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marca de Ordem de Bits’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite a alteração do proprietário (direito de "
"propriedade) da pasta/arquivo padrão (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona o caractere de nova linha no final da "
"linha se nenhum for presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to-stdout       ghi vào a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          inscrever no arquivo antigo (padrão) \n"
"   tabela ...            as tabelas que precisam ser convertidas para o modo do arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave de impressão silenciosa, muda o modo para menos ruídos. Nenhum aviso "
"será emitido."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "gỡ bỏ “Marca de Ordem da Codificação” (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gỗ bỏ “Marca de Ordem da Codificação” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            excluí tabela de dados divididas em duas partes "
"(padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     mantém a codificação UTF-16 do arquivo\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régime de codificacão do dado como UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be implica que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  심볼릭 링크를 따르며 대상을 변환합니다"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos de conversão "
"(as origens permanecem inalteradas)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links macios e objetivos fixos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do software"

