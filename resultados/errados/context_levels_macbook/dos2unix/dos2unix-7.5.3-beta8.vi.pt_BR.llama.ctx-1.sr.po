msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Caminho de uso: %s [seleções] [arquivos ...] [-n arquivo_de_entrada para o "
"arquivo_de_saída …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar proprietário do diretório de dados\n"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o código de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "-1252               utilizando página de código Windows 1252 (tây Âu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                utilizando tela de texto DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"-850                utilizando trângulo de codificação DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando trâng web DOS 860 (Português do Brasil)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizando o sistema operacional DOS para acessar a "
"página da web Canadá francês (Ca Na Đa Pháp)    \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizando o código DOS para a página 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converte os caracteres de 8 bits para 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        задржава назнаку поретка бајта"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        задржава назнаку поретка бајта (основно) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão chave para ascii, 7bit, iso, mac, padrão é ascii\n"
"   modo de conversão chave para ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     monta a tabela de símbolos para exibir os avisos\n"
"   tabela de símbolos:\n"
"       ansi (padrão), unicode, utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add_eol   adiciona um caractere de nova linha no final da linha se "
"não houver"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           obrigatório para converter arquivos binários divididos "
"em duas partes."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         변환 UTF-16 상 GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "hi -h, --help            mostra este texto para ajudar"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o conjunto de dados para análise\n"
"   tabelas ...            conjuntos de dados que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        задржава датум излазне датотеке\n"

msgid " -L, --license         display software license\n"
msgstr ""
"licença -L -- licenças concedem permissão para o uso de software "
"inteligente."

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona novo fim de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adiciona “Marca de Ordem da Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập tin ra             tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (por "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem-adicao-eol          não adiciona quebra de linha no final da linha se "
"houver nenhuma (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập-tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimindo todas as mensagens de "
"aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      excluir 'Byte Order Mark' (padrão)\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      excluir o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            apagar linhas fracionadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     giúmar bdng mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ định dạng đầu vào là UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi régula que o dado de entrada seja em UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        registração detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink para o efeito de ligação simbólica entre múltiplas "
"pastas e a conversão dos objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ignorar links simbólicos macios e objetivos fixos "
"(principalmente)"

