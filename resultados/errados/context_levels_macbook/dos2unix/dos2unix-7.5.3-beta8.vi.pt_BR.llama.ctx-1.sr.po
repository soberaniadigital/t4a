msgstr "encontrado erro ao alterar o nome “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo dessa conexão pequena e delicada, que é a representação simbólica"
" da relação entre as partes envolvidas na troca de informações, denomina-se "
"'cáusula'."

msgid "          output file remains in '%s'\n"
msgstr "banco de dados restante no arquivo '%s'"

