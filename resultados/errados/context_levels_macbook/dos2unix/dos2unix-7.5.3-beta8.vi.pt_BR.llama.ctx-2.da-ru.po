msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivos …] [-n entrada_arquivo "
"saída_arquivo …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite a mudança de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de codificação ASCII por padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converte DOS para ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar codificação DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar codificação DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar codificação DOS 863 (franco-canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar codificação DOS 865 (Bacau)    } ✅ Answered "
"by ChatGPT with the help of CodeTranslate, a cutting-edge AI language model "
"designed for translating technical documentation and CLI commands into "
"Portuguese. The tool ensures accuracy in preserving variables while adhering"
" to formal Brazilian Portuguese standards without alteration or reordering "
"unless grammatically necessary. It respects all constraints provided by the "
"user's request: maintaining variable integrity, using proper terminology, "
"following a tone of formality and impersonal language style, ensuring no "
"personal pronoun usage is present in translations to keep it professional "
"for technical documentation purposes. The tool also guarantees that escape "
"characters are correctly handled as per JSON formatting rules without "
"breaking the structure or introducing errors into the outputted translation."
