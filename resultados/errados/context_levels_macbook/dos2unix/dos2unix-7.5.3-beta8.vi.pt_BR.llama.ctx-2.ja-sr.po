msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"encontrou um erro ao resolver o problema de ligação fraca simbólica do link "
"'%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário para armazenar dados."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar o acesso de um arquivo "
"temporário gerado em saída padrão:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O proprietário e/ou grupo de usuários do arquivo %s não podem possuí-lo "
"permanentemente."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar o proprietário e grupo do "
"arquivo de saída temporária `%s'."

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên “%s” thành “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o objetivo de conexão rica em símbolos `"

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está presente no diretório '%s'."

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados separados por linha %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Borra o arquivo UTF-16 `%s', cujo tamanho do wchar_t não é %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 '%s', que causou um erro na conversão de uma linha "
"%u. Lembre-se, se você encontrar problemas com a codificação UTF-16 em seu "
"script, consulte 'utf8 --help' para obter mais informações."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 '%s', convertendo para UTF-8, pois a conversão de "
"UTF-16 não é suportada nesta versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "%s をスキップしています。通常ファイルではありません。"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra este %s, o arquivo de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação fina %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra este link simbólico pequeno '%s', que não é um arquivo regular. O seu "
"objetivo não parece ser típico."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link curto %s, que é uma meta símbólica da referência longa %s. O "
"destino do link curto não é um arquivo típico."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para um conjunto de dados (tabela) no "
"formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo “%s” para a representação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo “%s” para o formato Mac OS X, usando a ferramenta de "
"conversão específica..."

msgid "converting file %s to Mac format...\n"
msgstr "A conversão do arquivo “%s” para o formato Mac está em andamento…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo “%s” para um arquivo de texto do Windows "
"(DOS)…"

msgid "converting file %s to DOS format...\n"
msgstr "A conversão do arquivo “%s” para o formato DOS está em andamento…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para o formato de texto plano do "
"Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para a representação Unix do tipo "
"%s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estão convertendo o arquivo %s “%s” para o formato de tabela dinâmica do "
"Mac..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para um formato de tabela ASCII no "
"DOS...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão DOS do formato…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, houve problemas com a conversão"
" do tipo de dados."

msgid "problems converting file %s\n"
msgstr "Encontrado problema ao converter o arquivo %s."

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O comando \"%c\" foi escolhido para a opção '-i' ou '--info', mas isso não é"
" válido."

msgid "active code page: %d\n"
msgstr "A página está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já foi enviado o modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "Opção `%s' requer um número inteiro como argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"Já recebi uma mensagem de que a codificação %s para exibição gráfica não é "
"válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de abertura novo/criado "
"para o arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Cadeia de substituição inválida. Não há pares complementares."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cadeia substituta inválida. Não há mais valores para ajustar."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 `%s', banco de dados não é UTF-8. A codificação atual"
" do idioma neste local é UTF-8."
