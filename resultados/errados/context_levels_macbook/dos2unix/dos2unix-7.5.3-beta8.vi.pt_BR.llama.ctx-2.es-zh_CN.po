msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar o proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   conversão entre DOS e o conjunto de caracteres "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               usa a página de códigos Windows 1252 (Tây Âu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                usa trama de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usa trama de caracteres DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                usa trâng mã DOS 860 (Bồ Đào Nha)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa a página de códigos DOS 863 (Ca Na Đa Pháp) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                usa trângulo de código DOS 865 (Bacau) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte caracteres de 8 bits para espaço de 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conserva a Marca de Orden del Byte (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        conserva a Marca de Orden del Byte (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de convergência chinês (ZH_CN) ou"
" espanhol (ES)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens de alerta\n"
"   tabela de codificação:\n"
"ansi, unicode, utf8, default to ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da linha se "
"não houver nenhum presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           força a conversão de arquivos binários em formato "
"texto separado por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            exibe esta ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=ZH_CN]        exibe informações do arquivo de entrada \n"
"   tabela ...            nomes dos campos a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva la fecha en el archivo de salida\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adiciona o “marca de ordem do byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         ghi ra tập tin mới\n"
"   tập tin vào          tập tin trong chế độ tập tin mới\n"
"   tập tin ra             tập tin sau khi xửa lý"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (opção "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona nova linha no final do arquivo, mesmo que"
" o arquivo fique sem caracteres de nova linha (padrão por defeito)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi vào saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão) \n"
"   tabela-de-dados ...            conjuntos de dados a converter para o modo do arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, suprime todas as notificações de erro e aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção --remove-bom      elimina o “Byte Order Mark” (por defeito)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gỗ bỏ ‘Marca de Orden del Byte’, BOM"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignora arquivos separados por linhas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     mantém a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul --assume-utf16le coi régula \n"
"dãnsiＭformato de entrada eUTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be coi régido que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o link simbólico e convertendo a função alvo"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos\n"
"                   (arquivos originais de destino não são modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    mantém o link simbólico e seu destino inalterados "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         exibe o número da versão do software"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica DOS de 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS de 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenótipo DOS de 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha técnica do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha técnica do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenótipo Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome do Windows de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenômeno Windows de 32 bits (MSVC %d).\n"

msgid "OS/2 version (Watcom C).\n"
msgstr "Fonte do OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha técnica %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Suporte Unicode para nomes de arquivos."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Có hỗ trợ bản địa hóa ngôn ngữ."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como parte do suporte de proteção, mantenha o proprietário original e a "
"organização da pasta em seus valores atuais."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para proteger arquivos de propriedade original e "
"proprietária."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

