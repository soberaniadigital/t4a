msgstr "Gravando BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s. \n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Assumindo a codificação UTF-16LE da tabela de caracteres."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Assumindo a codificação UTF-16BE da tabela de caracteres."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na análise do link simbólico mínimo '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Gabriel encontrou um erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando o %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gặp lỗi khi thay đổi quyền hạn của tập tin đầu ra tạm %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e/ou o grupo de proprietários do arquivo %s não podem manter a "
"propriedade original."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel encontrou um erro ao alterar o proprietário e grupo do arquivo de "
"saída temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao renomear o arquivo ‘%s’ para ‘%s’:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo deste link simbólico '%s' é ser um meio de acessar o caminho para"
" outro arquivo ou diretório."

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída ainda contém o conteúdo do arquivo '%s'"

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados binários %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borar o arquivo UTF-16 %s, tamanho do wchar_t não é necessariamente %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, houve um erro na conversão de UTF-16 no dado %u. "
"Para mais informações sobre como lidar com esses tipos de arquivos em C++, "
"consulte a documentação do GNU gettext."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra este arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão deste programa."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aqui não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra o %s, tápe de entrada com arquivo %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico mole %s, porque seu objetivo não é um arquivo comum. "
"\n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link simbólico mole %s, alvo do link simbólico mole que não é um "
"arquivo regular."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Converting file %s to 'filename' using Unix format...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Converting file %s to Mac format...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Mac...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Converting file \"%s\" to DOS format as file \"%s\"...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Converte o arquivo %s para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Converting file %s “%s” to Unix format file %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Converting file %s “%s” to file %s ”%s” in Mac format..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Macintosh...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Converting file %s “%s” to DOS format file %s…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s...\n"

msgid "problems converting file %s to file %s\n"
msgstr "Ao converter o arquivo %s para o arquivo %s, encontramos um erro."

msgid "problems converting file %s\n"
msgstr "encontrou o erro ao converter arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"'%c' não é um valor válido para a opção -i ou --info. Por favor, tente "
"novamente."

msgid "active code page: %d\n"
msgstr "Página de códigos ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s, que não é válido."

msgid "option '%s' requires an argument\n"
msgstr "opção “%s” requer um argumento"

msgid "invalid %s display encoding specified\n"
msgstr "ocorreu erro ao gerar a tabela de visualização inválida %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi especificado no modo de arquivo novo."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Pares de substituição inválidos. Substituto faltando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Pares de substituição inválidos. Falta parceiro para troca."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borar o arquivo UTF-16 %s, a codificação atual não é UTF-8. Apresente um "
"estado de fato."
