msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dáfima (não acrescenta nova linha) no "
"final do texto se nenhum delimitador de linha for encontrado (padrão)\n"

