msgstr " -h, --help            ajuda de exemplo súgószöveg megjelenítése"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=ANALISE]        exibe informações sobre o arquivo de entrada "
"... ficheiros para análise"

