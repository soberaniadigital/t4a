msgstr "Ao converter o arquivo “%s” para a representação do Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Ao converter o arquivo “%s” para o arquivo “%s”, em formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo \"%s\" para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato Mac do Arquivo %s “%s”, por "
"favor, siga as etapas a seguir...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para a codificação Mac %s...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato de arquivo DOS "
"%s…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr "Em processo de conversão do arquivo %s para o arquivo %s"

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "nie possível ler do ficheiro de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "cachorro 'bílfico' da opção '-i' ou --info está errado."

msgid "active code page: %d\n"
msgstr "tela ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "deixou de enviar o arquivo %s. Ocorreu um erro ao converter."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn \"%s\" yêu cầu một đối số (argumento)"

msgid "invalid %s display encoding specified\n"
msgstr "ocorreu erro de codificação inválida para exibição %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de criação de novos "
"arquivos\n"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível salvar no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro de substituição incorreta. Substituição inferior ausente."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro de substituição incorreta. Falha ao aplicar a nova troca acima."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
