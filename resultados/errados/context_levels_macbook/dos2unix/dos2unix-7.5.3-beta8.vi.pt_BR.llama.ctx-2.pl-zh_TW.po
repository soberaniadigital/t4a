msgstr ""
"O sistema de arquivos é um componente crítico do Linux, que permite acesso e"
" manipulação direta dos dados armazenados em dispositivos externos como "
"discos rígidos ou unidades USB. O objetivo deste documento é fornecer uma "
"visão geral sobre o uso de arquivos no sistema operacional Unix/Linux, "
"abordando conceitos básicos e práticas comuns para desenvolvedores que "
"desejam utilizar essa funcionalidade em seus projetos."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Método de uso: %s [opções] [arquivo ...] [-n arquivo_entrada "
"página_saida...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permissão para alterar o proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                domyślny tryb konwersji ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte o texto entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de caracteres Windows-1252 (Tây Dong) para acessar as "
"linhas da tabela."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar a codificação DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Utilize a codificação DOS 850 (Tây Âu) para o arquivo %s"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o sistema de codificação DOS 860 (Bồ Đào Nha) para acessar as linhas da "
"tabela do arquivo."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o código DOS 863 (Ca Na Da Pháp) para acessar as linhas de texto."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use a codificação DOS 865 (nordestina) para o diretório de trabalho."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpia o arquivo '%s' com a opção '-b', que mantém os caracteres BOM (Byte "
"Order Mark) na saída."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        conservando o marcador de ordem dos bytes (BOM) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão   modo de converção: ascii, 7bit,"
" iso, mac; padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir notificações de erro\n"
"   bảng mã: ansi, unicode, utf8; padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar dógrafo de linha ao final da última linha se não "
"houver nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de conversão forçada -f, --force           bắt buôn chuyển đổi cái "
"tập tin nhị phân"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            Mostrar este comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo ...             "
"ficheiro para análise de tabelas\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"preservar o dia de criação do arquivo saída, ou seja, a data em que um "
"determinado evento foi registrado no log."

msgid " -L, --license         display software license\n"
msgstr " -L, --license         licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha extra ao final do arquivo"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar o indicador BOM (byte order mark) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          wprowadzanie nowego pliku\n"
"   táp-tin-vào      tập tin gốc trong chế độ tập tin mới\n"
"   táp-tin-ra           tập tin wyjściowy w chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          Não adicionar dáfima (dấu ngắt) no final da última "
"linha se não houver nenhum (método padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       escrever na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          escrever no arquivo antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem nenhuma mensagem de erro"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"gostaria de remover o BOM (Byte Order Mark) padrão, seja como um marcador "
"para indicar a codificação do arquivo."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"gostaria de verificar se o arquivo está em um determinado formato. Se sim, "
"você pode usar a opção `--format` para especificar esse tipo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar em UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi rá que o formato de entrada §%s§ é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rá que o formato de entrada é UTF-16BE (Big "
"Endian)"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink zastępowanie dowiadzenia symboliczne plikami "
"wynikowymi (các tập tin đích nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos e seus objetivos sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         wyświetlenie numeru wersji"

