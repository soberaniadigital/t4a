msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [arquivo ...] [-n infil utfil …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a modificação do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII                padrão de conversor"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a tabela de codificação do Windows 1252 "
"(latino ocidental europeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação do DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use a tela de linha DOS 850 (padrão europeu ocidental) para o seu projeto."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS860 (português) para continuar."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS Tabellen 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use a tabela de sinalização DOS 865 (nordic) para o seu projeto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção -b, --keep-bom        mantenha a ordem dos bytes (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preservar o byte order mark (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr " -c, --convmode        modo de conversão"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     instale a codificação para mostrar mensagens de teste"
" em ansi, unicode e utf8. O padrão é o ANSI."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol         adicione uma linha em branco após cada linha de "
"entrada\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           forçar conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] mostre informações do arquivo %s"

msgid " -k, --keepdate        keep output file date\n"
msgstr "keepdate"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr "Use '--newline' para adicionar um caractere de nova linha."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marca de byte (Byte Order Mark) (padrão "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile         escrever em um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar uma linha em branco após a última linha"
" se ela não existir (tipo de interface)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para o padrão de saída"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
"opção -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   file ...            i files a serem convertidos para o formato de ficheiro velho."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, sem mensagens de erro"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      remover marca de byte ordenação (Byte Order "
"Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o Byte Order Mark (BOM) -r, --remove-bom      gjave il "
"segn di ordin dal byte ordningmarkering (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            hoppa över binära filer (standard)\n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"Fora de -ul, --assume-utf16le assuma que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"Fora de -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "uso do parâmetro --verbose para habilitar a saída detalhada."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguir links simbólicos e converter para diretório de"
" trabalho atual."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"opção --replace-symlink substituir links simbólicos com arquivos "
"convertidos, mantendo os originais inalterados."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera símbolos e destinos invariáveis (padrão)"

