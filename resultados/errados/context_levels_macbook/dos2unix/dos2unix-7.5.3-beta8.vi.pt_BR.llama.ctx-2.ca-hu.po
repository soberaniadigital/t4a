msgstr "Borra o ficheiro UTF-16 %s, a medida do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o ficheiro UTF-16 %s, que produziu um erro ao converter para a linha "
"%u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o ficheiro UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho o %s, isso não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borracho o %s, ficheiro de saída é um link simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Remova o link simbólico mínimo %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o link mêm %s, que não é um arquivo de texto comum. A sua finalidade "
"não pode ser considerada como uma tarefa padrão."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Remova o link mínimo, objetivo do link reduzido não é um arquivo normal. "
"Aceitá-lo como tal poderia levar a comportamentos inesperados."

