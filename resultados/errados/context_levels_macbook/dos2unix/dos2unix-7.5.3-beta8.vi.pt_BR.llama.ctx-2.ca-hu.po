msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópias de segurança para %s [opções] [arquivos ...] [-n arquivo_de_saída.txt"
" ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "opção --allow-chown         permite alterar a propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    conversão entre codificação dos caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa página de codificação DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                usa página de código DOS 860 (português brasileiro)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                usa página de código DOS 863 (Canadá francês)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                usa página de código DOS 865 (nórdico)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        manté a marca d'ordem de bytes (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        manté a marca d'ordre de bytes (por defeito) (método "
"default)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão de caracteres:   ASCII, 7bit, ISO,"
" MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação dos mensagens mostradas na tela\n"
"   codificaçÃ£o da bÃ¡sisca mÃ³dio: ansi, unicode, utf8 (por omissão), padrÃ¢ncia é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"linha se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           força conversão de arquivos binários em formato "
"separado por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra este texto de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỌ]        exibe informações do ficheiro de entrada\n"
"   Ficheiro ...            Fichas a analisar."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte o dia da data original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem de Bits” (padrão UTF-8) \n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tái-tin-vào         tập tin gốc trong chế độ tập tin-mới\n"
"tái-tin-ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite alterar a propriedade do arquivo "
"(por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona dóis de nova linha no final se nenhum "
"for encontrado (predefinido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva na saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào távola de dúzió cũ (mặc định) \n"
"   ficheiro ...            fitxers a converter no modo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apaga o “Byte Order Mark” (marca de ordem dos bytes) "
"padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga o “Byte Order Mark” (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            borrar linhas de um arquivo binário (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assume que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguir os links simbólicos e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca os links simbólicos por arquivos reais (não substitui o conteúdo dos ficheiros) \n"
"                   (ficheiros originais não devem ser modificados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos mínimos e não alteráveis "
"(padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro de texto para linguagem C# (WATCOMC)."

