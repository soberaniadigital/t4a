msgstr ""
"DENNA MJUKVARA TILLHANDA HÅLLS AV UPPHOVSRÄTTSINNEHAVAREN I BEFÖRSTALKOM "
"SAMMANDAG (AS IS) OCH ANSVAR FÖR UTTRYCKLIGA ELLER UNDERFÖRSTÅDDA, INKLUSIVE"
" MEN INTE BEGRÄNSAT TILL UNDERFÖRSTÅDDA GARANTIER VID KÖP OCH LÄMPLIGHET FÖR"
" ETT VISST ÄNDAMÅL AVVISAS. INTIN I NÅGONDRYKT FALL SKAL "
"UPPHOVSRÄTTSINNEHAVAREN VARA SKRYDIG UTGE ERSÄTTNING FÖR DIREKT, INDIREKT, "
"OFÖRUTSEDD, SPECIELL, EXEMPLARISK ELLER FÖLJDRELATERAD SKADA (INKLUSIVE MEN "
"INTIN BEGRÄNSAT TILL ANSKAFFNING AV ERSÄTTNINGSVAROR OM MÖJLIGHETEN FÖR "
"SÅDAN SKADA. DENNA MJUKVARA, ÄVEN OM UNDERRÄTTADOM ÖMOJLIG HET EKONOMIAL "
"VARIABELER (%s, %d, %<PRIuMAX>, etc.) FÖR TYPERNORMMALLFRAGT KRYPTED MÅL."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilização: %s [flags] [arquivos ...] [-n de arquivo para entrada do arquivo"
" …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         permite alteração de propriedade para arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "-ASCII -conversor de sinais padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte entre as representações DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizar o código de página Windows 1252 (latino-"
"europeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizar o código DOS para a página de erro 437 (USA) "
"(padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar o código DOS para a página de referência do "
"Eurotabel 850 (extreamente europeu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                använd DOS teckentabell 860 (portugisisk)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizar o código DOS para a página 863 (franco-"
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar tabela DOS para a página de código 865 "
"(nórdico)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converterá sinais de 8 bits para campo em branco no "
"maquçãnte de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        beholda byteordningmarkering (Byte Order Mark) \n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva a marcação de byte (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão \n"
"   modo de conversão   ASCII, 7Bits, ISO, MAC, padrão é ASCII\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     staja em código para textos exibidos\n"
"   codificação             ansi, unicode, utf8, padrão é ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma quebra de linha no final da última linha"
" se não houver nenhum"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           tenta converter binários em formatos de arquivo "
"compatíveis."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converterá UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            visa este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa informações sobre o arquivo para análise. file "
"...               filer atributo analisado."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        beholda datum för utmatningsfilen"

msgid " -L, --license         display software license\n"
msgstr " -L --license         visa o licenciamento do software para uso"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione ao fim do conteúdo um novo carro\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione byteordningsmarkering (Byte Order Mark) "
"(padrão para UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escreve em novo arquivo\n"
"   inicia nova pasta de trabalho     cria um novo diretório com a mesma estrutura do original no modo criar novos arquivos e pastas\n"
"   termina o processamento    finaliza as operações no modo criar novos arquivos e pastas"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário para arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma quebra de linha no final se houver "
"texto (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to stdout       escreve para saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreve no arquivo antigo (padrão) \n"
"   arq ...               converte os arquivos para versão antiga"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimindo todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      elimina a marca de ordem dos bytes (Byte Order Mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      elimina marca de ordem bytes (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte sobre binários de arquivos (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     behåll UTF-16 teckenkodning\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le для suposição de que o formato do input é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be для suposição de que o formato do input é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utensário detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink seguir símbolos de ligação e converter múltiplas "
"referências em uma única linha do caminho."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzt symbolische lika&#39;s com arquivos convertidos\n"
"                         (originais arquivos de entrada permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e metas não alteradas "
"(padrão)"

