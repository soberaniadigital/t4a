msgstr "Pular sobre o arquivo UTF-16 '%s', tamanho do tipo wchar_t é %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Pular sobre o arquivo UTF-16-%s, um erro de conversão para UTF-16 aconteceu "
"na linha %u. Redundância."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
