msgstr ""
"Pular sobre o arquivo UTF-16-%s, a conversão para outro formato não é "
"suportada nesta versão do %s. Para obter mais informações, tente `%s "
"--help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Pular sobre '%s', não é um arquivo comum."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Pular sobre '%s', sair do terminal com o comando 'exit' é um símbolo "
"icônico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Pular sobre o símbolo de ligação %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Pular sobre o link simbólico `%s', objetivo não é um arquivo comum."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Pular sobre '%s', o alvo para a ligação simbólica '%s' não é um arquivo "
"comum. \n"

