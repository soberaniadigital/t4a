msgstr ""
"Pular sobre o arquivo UTF-16 %s, a conversão para UTF-16 não é suportada "
"nesta versão do programa %s. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Passear sobre %s, não é um arquivo comum."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Hop over '%s', output file %s is a symbolic link."

msgid "Skipping symbolic link %s.\n"
msgstr "Pular sobre o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Pular sobre o link simbólico %s, a metade é não um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Pular sobre '%s', alvo para o link simbólico '%s' não é um arquivo comum. \n"

