msgstr ""
"não há suporte para o código de página %d. Por favor, informe um valor "
"válido."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Pular sobre o arquivo UTF-16 %s, tamanho do wchar_t é de %d bytes. \n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Ponte sobre o arquivo UTF-16 %s, um erro de conversão para UTF-8 introuxe na"
" linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
