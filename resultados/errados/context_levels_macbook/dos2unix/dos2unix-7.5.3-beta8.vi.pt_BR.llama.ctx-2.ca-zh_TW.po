msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Método de uso: %s [opções] [arquivo ...] [-n arquivo_de_entrada "
"tápixe_saída...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite o alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão por padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "chave de conversão entre caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação Windows-1252 (Tây Dong) para acessar este "
"documento."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa página de codificação DOS 432 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS 850 (Tây Árabe) para codificar texto em chinês simplificado."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use a página de codificação DOS 860 (português) para o arquivo %s."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS 863 (Ca Na Da Pháp) para codificar em chinês simplificado."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use a página de código DOS 865 (Nórdico) para o seu projeto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "giúpia o BOM (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        manté la marca d'ordem de bytes (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de converção: ascii, 7bit, iso, "
"mac (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir os avisos mostrados\n"
"   codificação da tela: ansi, unicode, utf8, por padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"coluna se não houver nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia para o processo, forçar conversão dos arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỜ]        mostra a informação do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "mantém a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marca de byte ordenado (BOM) padrão UTF-8 por ¡padrão\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva ao novo arquivo\n"
"   táp tin gọi mới trong chế độ tập tin nữa\n"
"   táp tin ra"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar a propriedade do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dado de linha final se nenhum "
"delimitador for encontrado (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       escreve na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no ficheiro antigo (padrão) \n"
"   Ficheiro ...            fitxers a converter em o arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, suprime os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      apaga o sinal de byte order mark (BOM) padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"Remover o BOM (Byte Order Mark) -r, --remove-bom      apagar a marca d'ordem"
" de bytes"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"opção segura -s, --safe            omet els fitxers binaris (per defecte)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assume que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assuma que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anúncio detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink segueix els enllaços simbòlics i converteix les "
"connexions entre dues línies de fichers"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os links simbólicos por arquivos reais (sem"
" alterar o conteúdo dos originas)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    manté sense canvis els enllaços simbòlics i els "
"objectius (per defecte) \n"

