msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivos ...] [-n arquivo_entrada "
"arquivo_saida …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permissão para alterar proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                domyślny tryb konwersji"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter DOS para ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar codificação de caracteres Windows 1252 "
"(padrão europeu ocidental)    "

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar codificação DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar codificação DOS 860 (portuguesa brasileira)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar codificação DOS 863 (franco-canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para o espaço de bits de 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preservar o “Byte Order Mark” (BOM) originalmente "
"inserido no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preservar o marcador de ordem dos bytes (BOM) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC; padrão é"
" ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     дата основа для видимості повідомлень текстовових "
"повідомлених"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocando a conversão de arquivos binários em tabelas "
"de dados separadas por linhas e colunas."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "opção --help            Mostrar ajuda para esta opção"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo de entrada\n"
"   ficheiro ...            ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        conservando a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar separador de linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “Marca de Ordem dos Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          salvar em novo arquivo\n"
"   tabela de entrada no modo do novo arquivo\n"
"   tabela de saída para o novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a mudança do proprietário de arquivo"
" (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar o caractere de nova linha no final da "
"última linha, se ele não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          salvar no arquivo antigo (padrão) \n"
"   ficheiro ...            ficheiros para conversão em modo de arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           silêncio, sem nenhuma mensagem de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção '-r' ou '--remove-bom', remover o marcador de ordem dos bytes (BOM) "
"padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      remover o BOM (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignorar linhas de saída (método padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rá que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção -F, --follow-symlink para seguir links simbólicos e converter "
"objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitua links simbólicos por arquivos transformados\n"
"                   (arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha as ligações simbólicas e objetivos sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         exibir número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Fenome do DOS Versão para Windows, 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenome do DOS Versão para Windows, 16 bits (Turbo C).\n"

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome da versão DOS para Windows, 32 bits (WATCOMC)."

