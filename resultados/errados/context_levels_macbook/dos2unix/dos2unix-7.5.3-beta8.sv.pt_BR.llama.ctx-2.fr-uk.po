msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilização: %s [parâmetros] [arquivo ...] [-n entrada_arquivo resultado...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         autorizar alterações de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo padrão de conversão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para ISO-8859-1 de um arquivo DOS"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilize a tabela de codificação do Windows 1252 "
"(português europeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tabela de codificação DOS 437 (EUA) "
"(padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o código page DOS 850 (padrão europeu) para acessar os arquivos de "
"texto."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilize a tela DOS com código de página 860 (português)   -860"
"                utilizar janela do DOS com codificação de página 860 "
"(português)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS tablc de codificação 863 (français canadien)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS865 (escocês) para acessar as linhas de erro."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de 8 bits para o modo binário de 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        zerar a ordem dos bytes (Byte Order Mark) para o "
"formato de arquivo original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preservar a ordem dos bytes (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão   como ascii, 7bit, iso, mac, "
"padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     escolha o código de codificação para exibir mensagens"
" textuais, ansi, unicode ou utf8 (ansi padrão)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma quebra de linha ao final da última linha"
" se ela não existir"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           forçar a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            verificar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] mostre as informações do arquivo %s"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserve a data da criação do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar caracteres de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a marca de ordem dos bytes (Byte Order Mark)"
" (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile         escrever em um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adicionar uma nova linha ao final do último registro se não houver "
"(padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro ...           arquivos para converter neste formato de linha por linha"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimir todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover a marca de ordem dos bytes (Byte Order Mark) padrão "
"(standard)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover a marca de ordem dos bytes (Byte Order "
"Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignorar arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte o codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suppose que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be pressupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        modo detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguir links simbólicos e converter arquivos "
"indicados"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"Substitua links simbólicos por arquivos convertidos -R, --replace-symlink "
"(os originais dos caminhos de entrada não serão alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos e arquivos de destino "
"(padrão)"

