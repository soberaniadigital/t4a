msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dúvida: %s [cópias] [ficheiro ...] [-n ficheiro_entrada saída...] \n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite alteração do proprietário da pasta de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                modo ASCII padrão para conversão de caracteres "
"básicos\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converter de caracteres entre o sistema DOS e a "
"codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizar código padrão Windows 1252 (Tây Ái) para "
"aplicações em sistema operacional Microsoft Windows."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar código de paginação DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a tabela de códigos DOS 850 (Tây Ái) para o "
"formato do ficheiro\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"-860                utilizar a linha de comando DOS 860 (português) para o "
"sistema operacional Windows em português."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar página DOS 863 (Canadá francês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizar página de código DOS 865 (Bacia do Mar Negro) "
"para o ambiente Linux\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converter de caracteres 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservar o sinal de byte order mark (BOM) "
"originalmente inserido no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preservar o sinal de byte order mark (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:\n"
"audio, texto, imagem, vídeo, mime\n"
"    tipo padrão é audio."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     configurar a codificação da mensagem para exibição\n"
"   codificação mãe:            ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr "Adicionar nova linha final (--add-eol) se o arquivo não tiver uma."

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           obrigatório converter arquivos n-tupla (%s)"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            apresentar este mensagem de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CÓDIGO]        exibir informações do arquivo\n"
"   tape-tin ...            os arquivos que precisam ser analisados."

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"-k, --keepdate        mantendo a data de criação do arquivo para o resultado"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o símbolo de Byte Order Mark (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          novo arquivo criado\n"
"   ficheiro_entrada         ficheiro de entrada no modo criação do ficheiro\n"
"   ficheiro_saida           ficheiro de saída gerado"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar o proprietário do arquivo "
"(padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem adição de nova linha final --não acrescentar quebra de linha no final "
"se não houver (padrão) §"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       вивести дані до стандартного виведення"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập-tin ...            các tập tin cần chuyển đổi trong chế độ tập-tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimir todas as mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            excluir linhas em dois ficheiros (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     preservar a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be presumindo que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        modo de detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  追蹤 символізуванcia e realizar transformação de "
"objetivo"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink trocar links simbólicos por arquivos convertidos\n"
"                   (arquivos originais não serão alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera a ligação simbólica e o objetivo (padrão)"

