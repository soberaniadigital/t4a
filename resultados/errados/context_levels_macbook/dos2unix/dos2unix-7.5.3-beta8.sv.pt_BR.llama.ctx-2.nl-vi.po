"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrões de conversão básicos"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e ISO-8859-1 codificação de caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (padrão europeu) para acessar os dados do "
"arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Codepage 437 (USA) como padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (tâmiluropeisk) para acessar os dados do sistema "
"operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tabellen 860 (português) para acessar as opções de formatação do "
"sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS-codetabel 863 (français canadien) para acessar as opções de "
"formatação do sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-codetabel 865 (escandinavo) para acessar os dados de saída/entrada"
" padrão."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converterá os caracteres de sinalização para o padrão ASCII em um único "
"byte."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        mantenha o “Byte Order Mark” (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção -b, --keep-bom        mantenha o “Byte Order Mark” (máscara de byte "
"order mark) padrão\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão   ascii, 7bit, iso, mac, padrão é "
"'ascii'"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     utilizar codificação para mostrar mensagens de erro"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione um caractere de nova linha ao final da "
"última linha se ele não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"converter de ficheiros binários -f, --force           tvinga konvertering af"
" binaire filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Visar denha hjälptext"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformation\n"
"fil ...               ficheiro para analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção -k, --keepdate        mantenha o timestamp do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         visa programvarulicensão"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicione “Byte Order Mark” (marca de ordem de "
"bytes) (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe til ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil              utmatningsfil i nyfilsläge"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção não permitida --no-allow-chown      không cho phép thay đổi chủ sở hữu"
" tập tin (mày định mệnh)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dòng vào trong sốt cùng cuối (mặc định)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         skriên fil ...               ficheiro para converter "
"em formato de origem (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silêncio de execução, reduz a saída para apenas erros"
" e avisos."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção '-r' ou '--remove-bom', remover o Byte Order Mark (BOM) padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      remover byte order mark (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"Saída para o terminal -s, --safe            salte sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le förmoda att inmatningens formatet är UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be förmoda att inmatningsformatet är UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   seguir links simbólicos e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzen symbolische links mit convertidas arquivos "
"(originais devem permanecer inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ligar links simbólicas e opções não alteradas "
"(padrão)"

