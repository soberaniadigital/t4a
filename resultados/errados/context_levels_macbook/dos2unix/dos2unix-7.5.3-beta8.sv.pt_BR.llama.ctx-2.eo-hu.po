msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n input_file ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permissão para alterar o proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                apenas conversores de codificação padrão (defeito)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte entre DOS e codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               Windows Code Page (Windows-1252) usado para análise "
"de texto em português."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Use o DOS Tecnobufu (DOS) com codificação de caracteres do padrão dos "
"Estados Unidos (US)."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS Tecnologia de Codificação Tabu para acessar as opções do sistema "
"operacional. Para obter mais informações, tente 'DosTech --help'."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tecnologia de Codificação Tabular (DOST) para acessar as opções do"
" sistema operacional. Para obter mais informações, tente 'DOST --help'."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS Tecnoblocks de 863 (francia-kanadai) para acessar os dados do "
"sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-tecnotabell de código -865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom         retenha byte ordnamentação (Marca de Ordem do Byte)"
" (byte order mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom         retenha byte ordre (Byte Order Mark) padrão "
"(standard)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        átalakítási mód\n"
"   konverteringsläge ascii, '7bit', iso, mac, standard är ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     megjelenítési kódolásának lehetőségek: ansi, unicode,"
" utf8, alapértelmeztetve: ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr "opção --add-eol adicionar uma linha em branco ao final do arquivo"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"Use o parâmetro '-f' ou '--force', para forçar a conversão de dois ficheiros"
" binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "visar este help text"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformációk megjelenítése fájl ..."
"               filaszkönyv megjelenítése"

msgid " -k, --keepdate        keep output file date\n"
msgstr "Keep date of the file %s"

msgid " -L, --license         display software license\n"
msgstr " -L, --license          visualize o licenciamento do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar mais linhas ao final do arquivo"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         bájtordömsmarkering (byte order mark) (standartför "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skriv till ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil             utmatningsfil i nyfilsläge"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais -o, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   file ...               converterá o ficheiro existente para a versão anterior do formato\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           tystelevääntöinen läge, dölj alle varmistelmat"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      remover byte order mark (byteorder mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover marca de byte order mark (Byte Order "
"Mark) [pt-BR]"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"Saída para o modo seguro (padrão) -s, --safe            salta sobre os "
"ficheiros binários"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     retenha UTF-16-kodprezenton"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presumir que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be pressa que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utmóvel"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   seguir simbolicamente links e converter os campos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzi symbolikaj ligojn per konvertitajn filaron "
"(la celan dosieron ne restas malkonserta) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    behåll symboliska länkar och mål oförändrade "
"(standard) \n"

