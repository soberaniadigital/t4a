msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows, versão de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficheiro de texto não encontrado."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficheiro de texto para o Windows, versão em 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficheiro de texto para o Windows, versão em 32 bits (MinGW)"

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows, versão de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficheiro de texto para o Windows, versão em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro de log do sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro de origem %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Com a ajuda Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Com a ajuda de nomes Unicode para arquivos."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Ajuda para a língua nativa. Ajudar na tradução."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Com a ajuda do usuário e da equipe de proprietários, você pode garantir que "
"seus arquivos permanecem privados."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Não há suporte para o usuário e grupo proprietários dos arquivos."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estamos gravando o BOM para %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Suponha que temos um arquivo codificado em UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "supondo um código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução do link simbólico ' %s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar as permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador ou o grupo de proprietários do arquivo %s não podem ser "
"preservados. Para obter mais informações, tente '`%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar proprietário e grupo do arquivo temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome para “%s” em vez de “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo deste link simbólico é o %s."

msgid "          output file remains in '%s'\n"
msgstr "a saída do arquivo de entrada permanece no diretório '%s'."

msgid "Skipping binary file %s\n"
msgstr "Ignorem o arquivo binário %s"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Ignoremos o arquivo UTF-16 %s, cujo tamanho do wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borracho o arquivo UTF-16 %s, uma falha na conversão de UTF-16 ocorreu no "
"item da linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borracho o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho o arquivo %s, não é um ficheiro regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Ignoremos o %s, ficheiro de saída inicial é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Ignorem o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Ignorem o link simbólico %s, pois ele não é um arquivo regular. A carga de "
"trabalho para a análise do caminho da pasta e dos diretórios foi concluída."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ignorem o link simbólico %s, objeto no qual está armazenado um arquivo "
"irregular. O caminho do link simbólico não é um ficheiro regular."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a representação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um arquivo no formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a ferramenta Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um arquivo no formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para a formação DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a linguagem C++ no formato Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para a codificação Unix..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Đang chuyển đổi tập tin %s “%s” thành tập tin “%s” theo định dạng Mac %s…\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s para a codificação Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a linguagem C++ no formato DOS... "
"(cont.)"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para a codificação DOS... (cont.)"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o ficheiro %s e encontraram problemas "
"durante a conversão."

msgid "problems converting file %s\n"
msgstr "Durante a conversão do arquivo %s, foram encontradas problemas."

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O fio incorreto '%%c' para o parâmetro -i ou --info causou um erro."

msgid "active code page: %d\n"
msgstr ""
"A tarefa em execução no terminal é a seguir o processo de análise do arquivo"
" '%s'."

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s não é válida."

msgid "option '%s' requires an argument\n"
msgstr "Para o parâmetro \"%s\", é necessário especificar um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na análise do arquivo %s. Ocorreu um erro ao tentar ler o conteúdo "
"desse caminho."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Código inválido. O componente inferior está faltando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"erro: Código de entrada inválido. Ocorreu um erro ao substituir o elemento "
"superior."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borraremos o arquivo UTF-16 %s, pois a codificação de caracteres da linha "
"atual não é UTF-8."
