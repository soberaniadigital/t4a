" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para o código DOS em ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Use a tabela de codificação Windows (1252) para o português do Brasil\n"

