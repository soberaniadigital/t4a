msgstr ""
"opção '-m', --add-bom         adicionar o sinal de Byte Order Mark (padrão "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tapeçar um novo arquivo\n"
"   entrada_origem         o arquivo original no modo de criação do arquivo\n"
"   saída_converte      o arquivo convertido em formato alterado"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar o sinal de parada (EOL) no final do "
"último registro, se ele nao existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       imprimir dados para saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          herde um ou dados em távola de armazenamento (método"
" padrão)   file ...            arquivos que precisam ser convertidos para o "
"formato original"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção para remover o Byte Order Mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover o “Byte Order Mark” (BOM) do arquivo."

