msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cácioon utilizar: %s [opções] [arquivos ...] [-n arquivo_entrada "
"arquivo_saida ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento padrão de conversão do modo texto para "
"ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converte o texto entre os sistemas de codificação "
"DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar página de codificação Windows 1252 (Tây "
"Dương) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar código padrão DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                DOS コードページ 850 (西欧) を使用する\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar página de código DOS 860 (português do "
"Brasil) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar página de código DOS 863 (francesa do "
"Canadá) para o sistema operacional dos anos 90."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar página de código DOS 865 (da Europa do "
"Norte) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte caracteres de 8 bits para o espaço de 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantendo o “Marca de Ordem dos Bits” (Byte Order "
"Mark) na ordem original das bytes."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b, --keep-bom        zhänge o “Byte Order Mark” (padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão: ascii, 7bit, iso, mac; padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     configuração da codificação de mensagens para exibição\n"
"   codificações:            ansi, unicode, utf8; padrão é ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final da última linha se não estiver "
"presente (--add-eol)"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           bússola obrigatória para converter arquivos binários "
"em tabelas de dados separadas por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         conversão de UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Ajuda disponível para este comando."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do arquivo\n"
"   tập-tin ...            identificar e analisar os campos de cada tập tin para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        mantendo a data original da linha de entrada\n"

msgid " -L, --license         display software license\n"
msgstr "-L, --license         exibição da licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “Marca de Ordem dos Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          novo arquivo criado\n"
"   tabela de entrada      tabela original no modo de criação do novo arquivo\n"
"   tabela de saída     tabela gerada em um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar o proprietário do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem adição de nova linha --não acrescenta um caractere de quebra de linha "
"no final da última linha se não houver nenhum (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       gera saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định)\n"
"tápia-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimir todas as mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o “Marca de Ordem dos Bits” (byte order mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Marca de Ordem do Byte” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            bora linhas separadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     manter a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink para seguir símbolos de ligação e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substituição de símbolo link para o caminho do arquivo resultante\n"
"                         (os padrões originais não são alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preservar links simbólicos e objetivos sem alterações "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         hiçenhia s/n da versão do software"

