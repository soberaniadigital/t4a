msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"encontrou um erro ao resolver o link simbólico '%s' durante a divisão de "
"ligações mínimas."

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"Gabriel, você encontrou um erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabriel, ao tentar alterar os permissões temporárias do arquivo de saída "
"final %s, encontrou um erro:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O proprietário e/ou grupo de segurança do arquivo %s não tem permissão para "
"modificar o conteúdo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar o proprietário e grupo do "
"arquivo de saída temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên `%s' thành `%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o objetivo de um link simbólico '%s'."

msgid "          output file remains in '%s'\n"
msgstr "Obtido arquivo de saída '%s' no local especificado."

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados separados por linhas %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Borra o arquivo UTF-16 %s, tamanho do wchar_t não é igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Bordei o arquivo UTF-16 %s, houve erro na conversão de UTF-16 no registro da"
" linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra este tabela de texto UTF-16 %s, conversão para UTF-16 não é suportada "
"nesta versão do programa %s. Para obter mais informações sobre a opção "
"--help."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aqui não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra este %s, o arquivo de saída %s é um simbolo referenciado."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação fina %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando o link simbólico %s, que não é um arquivo regular. O objetivo dele "
"não pode ser considerado como uma pasta típica."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borracho o link fino %s, destino do link fino %s não é um arquivo típico."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s para o formato de tabela Unix está em andamento. A"
" saída será um conjunto chamado 'arquivo_convertido'."

msgid "converting file %s to Unix format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato Unix está em "
"andamento...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato Mac do arquivo “%s”, "
"você está realizando uma operação que requer atenção cuidadosa."

msgid "converting file %s to Mac format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato Mac está em "
"andamento...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo “%s” para o formato DOS, utilizando a "
"ferramenta %s...\n"

msgid "converting file %s to DOS format...\n"
msgstr "A conversão do arquivo “%s” para o formato DOS está em andamento..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de arquivo Unix "
"%s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Unix..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "A conversão do arquivo %s “%s” para o formato Mac é realizada..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato de arquivo DOS é realizada..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "A conversão do arquivo %s “%s” para o formato DOS está em processo...\n"

msgid "problems converting file %s to file %s\n"
msgstr "Ao converter o arquivo %s para o arquivo %s, houve um problema."

msgid "problems converting file %s\n"
msgstr "Encontrado problema ao converter o arquivo %s."

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "A flag '%c' para a opção -i ou --info foi utilizada incorretamente."

msgid "active code page: %d\n"
msgstr "A tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já foi enviado o modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "Túm escolha a opção '%s' que requer um número inteiro."

msgid "invalid %s display encoding specified\n"
msgstr "Já foi enviado a tabela de exibição inválida %s."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de abertura de novos "
"arquivos"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Cadeia de substituição inválida. Substituição inferior ausente."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Não há cadeia superior para troca."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
