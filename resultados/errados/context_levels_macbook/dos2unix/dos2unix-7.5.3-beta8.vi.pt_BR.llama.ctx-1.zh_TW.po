msgstr "O objetivo dessa conexão fina é o alvo '%s' do sinal de cadeia."

msgid "          output file remains in '%s'\n"
msgstr "Arquivo de saída '%s' não foi modificado"

msgid "Skipping binary file %s\n"
msgstr "Borrar o arquivo de dados separados por linha %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o site com codificação %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a largura do wchar_t não é necessariamente de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, houve um erro de conversão do UTF-16 na linha "
"%u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para ISO-8859-1 não é suportado nesta"
" versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este arquivo %s, aqui não é um documento comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra este %s, o arquivo de saída %s é um sinal forte."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link pequeno %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o sinal de porcentagem pequeno em '%s', que não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link fino %s, objetivo %s do link fino não é um arquivo comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato “%s” Unix..."

msgid "converting file %s to Unix format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato Unix está em "
"andamento...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato Mac, você está "
