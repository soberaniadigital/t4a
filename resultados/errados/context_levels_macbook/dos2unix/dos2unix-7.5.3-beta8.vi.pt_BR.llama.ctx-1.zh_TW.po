msgstr "Erro: Cadeia de proxy (surrogate) incorreta. Falta baixa cadeia."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cópia de substituição inválida. Falta de alto proxy."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

