msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Método de uso: %s [opções] [arquivos …] [-n entrada_e saída.ext]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite alterar proprietário do arquivo de texto\n"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                modo padrão de conversão para caracteres sem acento"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte entre DOS e ISO-8859-1 \n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizando codificação de caracteres Windows 1252 (Taiu)"
" \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                Utilize código de trângulagem DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "-850                Utilize o código de caracteres DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"-860                Utilize o modo DOS 860 (Boha Doanh) para acessar páginas"
" da tela do computador."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando código de caracteres DOS 863 (Cingapura) "
"\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                Utilizando codificação de caracteres DOS 865 (Europa do "
"Norte)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte caracteres de 8 bits para espaço reservado a "
"7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        Preserva o “Marca de Ordem do Byte” (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --keep-bom         mantém o “Marca de Ordem do Byte” (BOM) por padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:\n"
"ascii, 7bit, iso, mac, mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     sete o modo de exibição do código de mensagens para "
"ansi, unicode ou utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicionar caractere de quebra de linha ao final da última "
"coluna se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório para converter arquivos hexadecimais\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Exibir ajuda para este comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do arquivo\n"
"   ficheiro …            os ficheiros que precisam de análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"-k, --keepdate        preserva o dia e mês de origem do arquivo gerado\n"

msgid " -L, --license         display software license\n"
msgstr "-L --license         Exibe a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicionar uma nova linha ao final"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marca de Ordem do Byte’ (por padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em novo arquivo\n"
"   entrada de origem         o arquivo original no modo tape-in\n"
"   saída para novo arquivo    o arquivo gerado no modo tape-out"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dónde linha se o fim da coluna não tem "
"um caractere de quebra (valor padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to-stdout       escreve no padrão de saída normal"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         輸入原檔案 (預設) \n"
"  檔案 ...            需要進行的檔案轉換"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, oculta todas as mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar “Marca de Ordem dos Bits” (BOM) por padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            略過二進位檔案 (預設)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     preserva a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi rằng o formato do arquivo de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rằng o formato do arquivo de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "-v, --verbose        registra em detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca o símbolo de ligação com a versão convertida do"
" arquivo. (Arquivos originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    giúp mặt trọng lượng và không thay đổi liên kết mềm "
"(và đích) của chú ý (trong ngữ cảnh phù hợp cho việc giữ liên kết)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostra versão da ferramenta"

