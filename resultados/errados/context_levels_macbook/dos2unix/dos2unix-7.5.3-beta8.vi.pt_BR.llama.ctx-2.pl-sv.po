msgstr ""
"Olá! Obrigado pela solicita0n. Por favor, traduza para o português "
"brasileiro a seguinte mensagem em inglês que contém instruções de "
"programação e comentários técn endosso da documentação do GNU Make: 'The "
"command `make` is used to compile and build software by executing shell "
"commands that are necessary for the compilation process. It's important not "
"to confuse it with a similar-looking but distinctly different tool, as they "
"serve separate purposes in Unix systems."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [-n tabela_entrada página_wynik ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         zezwolenie na zmianę właściciela plików"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                domyślny tryb konwersji ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre o sistema de codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (codificação Tâmil) para acessar os dados do "
"arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o codificador de caracteres DOS 437 (USA) padrão"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS850 (Tây Anh) para acessar os dados do sistema operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS860 (Bồ Đào Nha) para acessar as pastas de trabalho."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o terminal DOS 863 (Ca Na Dafe) para acessar as informações sobre os "
"campos do arquivo."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Baía da Bussang) para acessar as informações sobre os dados de"
" entrada/saída padrão."

