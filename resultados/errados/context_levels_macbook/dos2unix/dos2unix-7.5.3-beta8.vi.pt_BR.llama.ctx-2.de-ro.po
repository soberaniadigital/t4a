msgstr "Falha na verificação do arquivo %s"

msgid "Cygwin version.\n"
msgstr ""
"Falha na verificação da linha %s possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Versão Windows para 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Falha na verificação do arquivo de entrada (Watcom C): %s"

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Versão Windows para x64 (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr ""
"A versão Windows para x64 do MinGW é acessível em "
"https://github.com/migurshin/win32gui."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr ""
"Falha na verificação do arquivo de entrada (%s) para o Windows no sistema "
"operacional Microsoft Visual C++."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Versão Windows para x64 (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Falha na verificação do arquivo %s"

msgid "OS/2 version (EMX).\n"
msgstr "Phiên bản OS/2 (EMX).\n"

msgid "%s version.\n"
msgstr ""
"Falha na verificação da linha %s possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "With Unicode UTF-16 support.\n"
msgstr "Có houver suporte Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não foi possível obter suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Código de erro do sistema operacional não é válido."

msgid "Without Unicode file name support.\n"
msgstr "Não foi possível obter suporte para Unicode filenames."

msgid "With native language support.\n"
msgstr ""
"Código de verificação do sistema operacional é um conceito essencial para "
"garantir que o programa seja executado corretamente. Ele permite a execução "
"simultânea e seguro dos comandos, permitindo-nos identificar erros no código"
" antes da conclusão completa."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Với hỗ trợ giữ nguyên người và nhóm sở hữu tập tin.\n"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não foi possível obter suporte para acessar o arquivo de diretório. Por "
"favor, verifique se você tem permissões adequadas."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para a pasta de saída é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou em um estado de emergência."

msgid "UTF-16LE"
msgstr "O arquivo '%s' não foi encontrado."

msgid "UTF-16BE"
msgstr "O arquivo '%s' não foi encontrado."

msgid "GB18030"
msgstr ""
"falha na verificação da linha %s possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "UTF-8"
msgstr ""
"falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %.2f."

msgid "Assuming UTF-16LE encoding.\n"
msgstr ""
"Se o arquivo não foi encontrado, você pode usar a função `os.path.exists` "
"para verificar se um determinado caminho existe."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Coi là bảng mã UTF-16BE.\n"

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"Ocorreu um erro ao tentar resolver a ligação simbólica '%s'. Para obter mais"
" informações, consulte o manual do sistema."

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"Erro ao abrir a pasta de saída temporária, pois não foi possível encontrar o"
" caminho para ela."

msgid "using %s as temporary file\n"
msgstr "Está usando o %s como caminho para a pasta de trabalho atual."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Ocorreu um erro ao alterar as permissões de saída do arquivo %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "O arquivo de entrada %s não foi encontrado."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Erro ao alterar o proprietário e a equipe da pasta temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Ocorreu um erro ao alterar o nome para “%s” em “%s”."

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          cái là đích của liên kết mềm “%s”\n"

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída permanece em '%s'."

msgid "Skipping binary file %s\n"
msgstr "O arquivo de entrada não foi encontrado."

msgid "code page %d is not supported.\n"
msgstr "A linha de entrada %s não é suportada."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"O arquivo UTF-16 %s foi ignorado, pois o tamanho do campo wchar_t é maior "
"que %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"O arquivo UTF-16 %s foi ignorado, pois ocorreu um erro ao converter para "
"UTF-16 na linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"O arquivo UTF-16 %s não é suportado nesta versão. Para obter mais "
"informações, tente `%s --help' para obter ajuda."

msgid "Skipping %s, not a regular file.\n"
msgstr "Se não houver %s, isso é um erro."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "O arquivo de entrada %s não foi encontrado."

msgid "Skipping symbolic link %s.\n"
msgstr "A linha de entrada %s não foi encontrada."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"A linha de entrada não é um arquivo regular. A opção '%s' não permite "
"argumentos."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr "O arquivo de entrada não foi encontrado."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"O arquivo '%s' não pode ser convertido para o formato Unix porque ele já "
"está no formato de texto padrão."

msgid "converting file %s to Unix format...\n"
msgstr "Đang chuyển đổi tập tin “%s” sang định dạng Unix…\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"O arquivo '%s' não pode ser convertido para o Mac OS X format (%d) devido a "
"um erro de permissão."

msgid "converting file %s to Mac format...\n"
msgstr ""
"Estou trabalhando em um projeto de aprendizado de máquina que envolve a "
"conversão do formato dos dados para o Macintosh, mas estou cometendo erros "
"ao tentar converter uma string no Python. O código abaixo é escrito em C# e "
"preciso traduzir-lo para um script em JavaScript (NodeJS). Por favor, ajude "
"a corrigi-la."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "O arquivo '%s' não pode ser convertido para o DOS format."

msgid "converting file %s to DOS format...\n"
msgstr ""
"Falha na verificação do arquivo '%s' possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "O arquivo '%s' não foi encontrado."

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estou trabalhando em um projeto de aprendizado profundo para o Python, mas "
"estou cometendo erros ao tentar converter uma string que contém espaços "
"entre aspas. Por favor, ajude-me a corrigir isso."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "O arquivo '%s' foi convertido para o formato Mac no formato %s."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Đang chuyển đổi tập tin %s “%s” sang định dạng Mac %s…\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Falha na verificação de entrada/saída do arquivo %s (%<PRIuMAX>) para o "
"formato DOS."

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Estou convertendo o arquivo %s (%s) para o formato DOS no sistema de dados "
"do Windows, mas não consigo encontrar a opção '--help'."

msgid "problems converting file %s to file %s\n"
msgstr "Đang chuyển đổi tập tin %s thành tập tin %s\n"

msgid "problems converting file %s\n"
msgstr "Ocorreu um erro ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "Não é possível ler o arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação do caminho de entrada/saída (%s) para o arquivo "
"%<PRIuMAX>."

msgid "active code page: %d\n"
msgstr "A tela de erro do sistema não foi encontrada."

msgid "invalid %s conversion mode specified\n"
msgstr "O arquivo de entrada não foi encontrado."

msgid "option '%s' requires an argument\n"
msgstr "A opção '%s' requer um argumento"

msgid "invalid %s display encoding specified\n"
msgstr "A falha na análise do arquivo %s não é permitida."

msgid "target of file %s not specified in new-file mode\n"
msgstr "O arquivo de entrada %s não foi encontrado."

msgid "can not read from input file: %s\n"
msgstr "Não foi possível ler o arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "Não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro de execução do programa. O arquivo %s não foi encontrado."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro de sintaxe inválido. O arquivo %s não foi encontrado."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
