msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela está codificada em UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação é UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando o %s como tabela temporal."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo que possui o arquivo %s não pode ser preservado. Para "
"obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Erro ao alterar proprietário e grupo do arquivo temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "falha na conversão do nome “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"O objetivo deste link simbólico '%s' é facilitar a comunicação entre os "
"membros da rede."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está no diretório '%s'."

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para o painel de código %d. Para obter mais informações, "
"tente `%s --help'."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Cancelar o arquivo UTF-16 %s, a dimensão do tipo wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, foi detectado um erro de conversão UTF-16 na "
"linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para a versão atual não é suportado. "
"A conversão de UTF-16 nesta versão do programa não está disponível."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borraremos %s, que não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borracho o %s, ficheiro de saída é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borracho o link simbólico %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Separar a ligação fraca %s, o objetivo dela não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Seja cuidadoso ao remover o link curto %s, pois este não é um arquivo "
"regular. A opção '%c' apresenta erro."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s para o formato de tabela Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Macintosh..."

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS..."

