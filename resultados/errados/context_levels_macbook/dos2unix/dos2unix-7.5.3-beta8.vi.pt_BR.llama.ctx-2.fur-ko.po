msgstr "FUR"

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin. \n"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenômeno Windows de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "FENDA DE PHÍNCEANS DO WINDOWS 32 BIT (MINGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenome do OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenome do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Fenome do %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Ocupa suporte Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Suporte ao nome do arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte ao nome de arquivo Unicode."

msgid "With native language support.\n"
msgstr ""
"Olá! O programa não pode ser executado nesta versão do GNU/Linux. Para obter"
" suporte ao seu idioma, por favor, visite "
"https://www.gnu.org/software/gettext/"

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como suporte ao proprietário original e aos usuários do arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e usuários do arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de entrada para o arquivo temporário é muito longo:"

