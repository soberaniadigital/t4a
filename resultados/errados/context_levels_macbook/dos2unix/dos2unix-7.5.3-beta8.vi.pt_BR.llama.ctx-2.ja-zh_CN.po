msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar o proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão (ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converter de caracteres entre DOS e ISO-8859-1 \n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               utilizar codificação Windows 1252 (Tây Dương) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizando código de página DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar código de página DOS 860 (Boha) para o "
"português do Brasil"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar código de carácter DOS 863 (Ca Na Đa Pháp) "
"\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando código de página DOS 865 (Bacia do "
"Mediterrâneo) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para o espaço reservado em 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        giúres o “Marca de Ordem do Byte” (BOM) originalmente"
" presente no início dos dados em UTF-8."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b, --keep-bom         mantém o “Marca de Ordem dos Bits” (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de convergência\n"
"   modo de convergência:\n"
"ascii, 7bit, iso, mac, moldura padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     set the encoding used to display messages\n"
"   encodings:            ansi, unicode, utf8 (default is ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da linha se "
"não houver nenhum presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           basta converter arquivos binários divididos em duas "
"partes."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16094         converte UTF-16 para GB16094\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            Ajuda disponível para este recurso\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=ZH_CN]        exibir informações do arquivo\n"
"   tabela ...            as listas de arquivos para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        guarde a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibir aviso sobre o acordo de licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo caráter de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin truyền thống trong chế độ tập tin mới\n"
"   tập tin ra           tập tin xuất ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona o caractere de nova linha no final da "
"linha, mesmo que a linha não tenha um caractere de nova linha (configuração "
"padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi vào saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            as tabelas de dados que precisam ser convertidas neste modo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimindo todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Marca de Ordem dos Bits” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --safe            bór qua tabela separada por linhas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     giúmar bảng mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régulo de que o formato do arquivo é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be coi régido dãas de entrada como UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        exibir detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  跟隨符号链接转换目标文件"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca o símbolo de ligação por arquivo convertido\n"
"(arquivos objetivos permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e seu destino não é "
"alterado (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         Mostrar versão do software"

