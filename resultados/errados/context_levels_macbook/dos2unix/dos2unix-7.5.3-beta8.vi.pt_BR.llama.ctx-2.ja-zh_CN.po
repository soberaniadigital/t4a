msgstr ""
"Borra o arquivo UTF-16 %s, a largura do wchar_t não é necessariamente de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que teve erro ao converter UTF-16 na linha %u. "
"Para obter mais informações sobre como lidar com esses problemas de "
"conversão, consulte a documentação."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta versão "
"do %s. Para obter mais informações sobre a compatibilidade dos formatos e "
"como converter entre eles, consulte as seções 'Compatibilidade' e "
"'Conversões'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este arquivo %s, ele não é um típico ficheiro de texto. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra %s, tabela de saída %s é um link simbólico. ."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o símbolo de ligação macia %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o símbolo de ligação pequena %s, alvo dela não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o símbolo de ligação pequeno %s, alvo %s do símbolo de ligação pequeno"
" não é um arquivo comum."

