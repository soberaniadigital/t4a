msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estão convertendo o arquivo %s para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para o formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo de entrada '%s' para um formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para um formatodei Unix..."

