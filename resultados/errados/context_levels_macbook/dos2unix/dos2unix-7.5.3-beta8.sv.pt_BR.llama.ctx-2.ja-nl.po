msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando `grep` para encontrar e exibir as linhas que contêm a "
"palavra 'error' em um arquivo de log. Se você quiser ver apenas os erros, "
"use `-e error`. Para filtrar por uma string específica como 'ERROR', "
"substitua `%s` pelo seu termo desejado e para exibir somente as linhas que "
"contêm a palavra completa `error`, utilize o parâmetro `--word-"
"regexp=pattern."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                standardkonverteringsläge\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e ISO-8859-1 codificação de caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Use Windows Code Page 1252 (Veikosteuropéis) para o seu computador."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Code Page 437 (USA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use a codificação DOS (8.3) para o sistema operacional Windows."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use a página de código DOS -860 (português) para o seu computador."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS-codetabel 863 (português da América do Norte) para uso."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-codetabel 865 (nordisk) para utilizar a codificação do padrão de "
"fuso horário da Noruega."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom         beholda byte order mark (Byte Order Mark) para "
"manter a ordem dos bytes."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom         Byte Order Mark (BOM) conservar (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        conversão de modo (ascii, 7bit, iso ou mac) , "
"standard é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     especificar a codificação para as mensagens de erro\n"
"   kodning             'ansi', 'unicode', of 'utf8' (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um newline à última linha sem alterar o "
"conteúdo da mesma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"converter de binário para texto -f, --force            conversão de arquivos"
" binários em formato de texto"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            verificar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] visa informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        beholda data de criação do arquivo"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         mostra o software license"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar um Byte Order Mark (BOM) ao arquivo de "
"texto (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe naar een nieuw bestand schrijven\n"
"   INVÍCIO               het originele bestand in nieuwe filenleg\n"
"   UTILISERFOLKE       het geconverteerd bestand in nieuwe filenleg"

