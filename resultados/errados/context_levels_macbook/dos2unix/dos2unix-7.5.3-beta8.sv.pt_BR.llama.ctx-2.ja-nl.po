msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             binaire arquivos verificar (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 codificação a ser mantida"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le acredite que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be para assumir que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utensido de detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção --follow-symlink   seguir símbolos links e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzen symbolische links met convertidas entidades "
"(de origem) door tekenen overig naar de geconverteerde bestanden. Dit "
"betekent dat de oorsprongelijke mapfile niet veranderd wordt."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ignorar símbolos de links e manter o estado original "
"(padrão)"

