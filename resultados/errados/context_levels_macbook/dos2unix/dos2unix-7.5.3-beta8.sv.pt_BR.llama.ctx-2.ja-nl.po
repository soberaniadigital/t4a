msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          ikke tilleggte regeleindetekken till siste raden om "
"det ingen (standard)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   file ...             para converter os ficheiros em formato de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimir todas as warnings"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover o byte order mark (BOM) -r, --remove-bom      retirar a "
"marca de ordem do byte (Byte Order Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover byte order mark (byteorder mark) do "
