"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"coluna se ele não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia para o processo, ou seja, a força necessária para "
"converter dados em binário."

