msgid "Binary symbol 0x00%02X found at line %u\n"
msgstr ""
"Olá! O código de erro 'Ký hiệu nhị phân' (%s) foi encontrado na linha %d."

msgid "Added line break to last line.\n"
msgstr "Foi adicionado um novo dado ao final da linha."

msgid "program error, invalid conversion mode %d\n"
msgstr "Erro de programa, o modo conversor %d não é permitido."

msgid "Converted %u out of %u line breaks.\n"
msgstr "Foi convertido %s no número de linhas do arquivo, que é igual a %d."

msgid "using code page %d.\n"
msgstr "utilize o soquete %d para acessar os dados."

msgid "Binary symbol 0x%02X found at line %u\n"
msgstr ""
"Falha na análise de linha %<PRIuMAX> com base no número de campos (%d) "
"encontrados. O arquivo não foi aberto."

