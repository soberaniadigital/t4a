msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando '%s' [opções] [arquivo ...] [-n entrada/saída.txt -r "
"ra...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "chave de conversão ASCII -modo padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre o sinal de entrada e o sinal ISO-8859-1."

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows Codepage 1252 (Tây Âu) para acessar os dados do arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o CodePage 437 do DOS (US) como padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o código de codificação DOS 850 (Tây Árabe) para acessar este "
"documento."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o código DOS 860 (Português) para acessar os dados do sistema "
"operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS Codepage 863 (Canadees Frans) para acessar os dados do sistema"
" operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o código de codificação DOS 865 (Baixi) para processamento do "
"sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o espaço em "
"branco (ASCII) usando um mapeamento personalizado."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        mantém a marca de byte order mark (BOM) original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chéche modo de codificação:   ascii, "
"7bit, iso, mac, padrão é 'ascii'."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para exibir mensagens de erro\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um dógrafo de linha final à última linha se não "
"estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia solar -f, --force           força a conversão dos "
"arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        mostra informações sobre o távola de trabalho "
"(workspace) e/ou a versão do programa. A opção é útil para debuggen van een "
"bestand in het workspace te analyseren."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserve o timestamp da linha de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         dá a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr ""
" -l, --newline         adiciona uma nova linha ao final da mensagem de erro."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicionar uma marca de ordem byte (byte order "
"mark) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr " --no-add-eol          không thêm dâng gói trong cuốn sách (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       para saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          herde o ou dados em um távola de trabalho (padrão) \n"
"   Ficheiro ...             os ficheiros que precisam ser convertidos no modo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todas as avisões"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"gostaria de verificar se o arquivo está corrompido. Se sim, você pode usar a"
" opção `--checksum` para gerar um checksum do conteúdo e compará-lo com uma "
"referência conhecida."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remove a marca de byte order mark (BOM) do "
"arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            saída binária básica (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr ""
" -u, --keep-utf16     behalte UTF-16 codificação ao manter a linha de "
"execução."

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le asegura que o formato de entrada é UTF-16LE."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rão dizer que o formato de entrada deve ser "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada produzir"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   segue em seguida as symbolic links e converte os "
"destinos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay tập tin mềm bặt tập tin chuyển đổi (các tập tin "
"dựa trên nguyên khối của học sinh sẽ làm sao?)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    permite que symbolic links sejam ignoradas (padrão) "
"\n"

msgid " -V, --version         display version number\n"
msgstr "Opção -V, --version         dê a versão do programa."

msgid "DOS 16 bit version (Watcom C).\n"
msgstr ""
"Ficha de referência para o Phiên bản DOS em versão dos 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de referência para o programa DOS16 (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr ""
"Ficha de referência do sistema operacional DOS em versão 32 bits (Watcom C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha de referência do sistema operacional DOS (32 bits) [DJGPP]."

msgid "MSYS version.\n"
msgstr "Ficha de versão do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha técnica do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows para sistemas de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de versão Windows em 32 bits (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha de referência para o Phiên bản Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha de referência do Windows XP (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas operacionais em 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows XP (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha de referência do sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de testeio %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có homenagem para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Có homenagem ao desenvolvedor que criou este documento. Obrigado por "
"contribuir para o OpenStack, especialmente no contexto de CLI e shell "
"scripting."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Có hora de apoio para linguagens locais. Para obter mais informações, tente "
"`%s --help'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para ajustar o tamanho do buffer. Para obter mais "
"informações, consulte '--help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estamos gravando o %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de caracteres UTF-16LE é adotada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de caracteres UTF-16BE é adotada."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da ligação simbólica '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário para leitura pendente: %s"

msgid "using %s as temporary file\n"
msgstr "Estou usando %s como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gerou um erro ao alterar as permissões temporárias do arquivo de saída %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "O arquivo de entrada %s não pode ser salvo. Acesso negado."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gerou um erro ao alterar o proprietário e a grupo da pasta de saída "
"temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome para 'Arquivo':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo desta ligação simbólica é o %s."

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr ""
"Falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"O arquivo UTF-16 %s foi ignorado, pois o tamanho do wchar_t é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Bem-vindo ao terminal de comando do Linux. Para iniciar o processo, você "
"deve digitar `cd` seguido por um espaço e depois a localização da pasta que "
"deseja copiar."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"O arquivo de entrada %s foi ignorado; o caminho do diretório %s é uma "
"associação simbólica."

msgid "Skipping symbolic link %s.\n"
msgstr "Falha na conexão com o servidor. Acesso ao serviço de rede bloqueado."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"A ligação simbólica %s não pode ser feita, pois o alvo é um arquivo regular."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu uma falha na conexão com o servidor. O arquivo %s não é um "
"diretório."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Fazendo a conversão da tabela de dados %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo a conversão da pasta de dados “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto “%s” para formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão da pasta de trabalho '%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão da pasta de entrada “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Fazendo a conversão da pasta de entrada %s “%s” para o formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão Macintosh (%s)..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Fazendo o conversor de arquivo %s para tamanho do campo (%d) no formato DOS,"
" ..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo a conversão da pasta de entrada %s “%s” para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato de texto plano (Plain Text) "
"e encontraram problemas durante a conversão."

msgid "problems converting file %s\n"
msgstr ""
"falha na conversão de arquivo %s, ocorreu um erro ao tentar converter a "
"linha %d."

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação da opção '-i' ou '--info': não foi possível obter "
"estado (stat) do arquivo %s"

msgid "active code page: %d\n"
msgstr "A tarefa está em execução no terminal %s."

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão do modo %s não é permitida."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na análise de entrada/saída padrão %s possui um número insuficiente de"
" campos (esperado %<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo desta mensagem de erro é que o arquivo %s não foi definido para "
"um novo estado."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída inicial: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: O par de substituição não é válido. Esse erro ocorre porque você "
"esqueceram adicionar um valor para a opção `--help`. Para obter mais "
"informações, tente '`%s --help'."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: O par de substituição não é válido. Esse valor deve ser especificado."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
