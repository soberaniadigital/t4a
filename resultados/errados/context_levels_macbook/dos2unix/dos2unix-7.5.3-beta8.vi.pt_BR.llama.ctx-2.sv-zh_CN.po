msgstr "Borar o conjunto de dados dividido em dois ficheiros %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o navegador %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borar o conjunto de dados UTF-16 %s, tamanho do wchar_t não é "
"necessariamente %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borar o arquivo UTF-16 %s, houve um erro ao converter UTF-16 na linha %u. "
"Para obter mais informações sobre como lidar com esse tipo de falha, "
"consulte a documentação do software."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borar o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta versão "
"do programa. Para obter mais informações sobre a compatibilidade e as opções"
" disponíveis para processamento alternativo, consulte os comentários no "
"final da documentação."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borar o arquivo %s, aqui não é um típico ficheiro. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra sobre %s, saída do arquivo de origem é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borar o sinal de ligação mole %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico fino %s, alvo do seu objetivo não é um arquivo comum."
" \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borrar o link curto %s, alvo %s do link curtinho não é um arquivo comum. \n"

