msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Cómo usar: %s [opções] [ficheiros …] [-n infile outfile …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar o proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii                modo padrão de conversor de caracteres"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   conversão entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar codificação de caracteres Windows 1252 "
"(Taiu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar código de caracteres DOS 850 (Tây Ático)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar código de caracteres DOS 860 (Boha Da Nova)"
"    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar código DOS 863 (português do Brasil)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar código de caracteres DOS 865 (país nórdico)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converterá os caracteres de códigos BINários 8 bits "
"para espaços reservados em ASCII (7 bits)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém o 'Byte Order Mark' original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        mantém o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr "chave de modo de conversão:   ASCII, BIT7, ISO, MAC, padrão é ASCII."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens de alerta\n"
"   tabela de codificação:\n"
"ansi, unicode, utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione um caractere de nova linha no final da linha se ela"
" não tiver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar conversão de arquivos binários em tabelas "
"separadas por linhas"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            exibe este texto de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
"-i, --info[=CỜ]        exibe informações sobre o arquivo\n"
"   tập tin …            os conjuntos de dados a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha o dia de criação do arquivo gerado\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibe aviso sobre o acordo de licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “marca de ordem de bytes” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         gera novo arquivo de texto\n"
"   tabela-de-dados-vai     inserir dados no arquivo original dentro do modo de criação de novos arquivos\n"
"   tabela-de-dados-vem      exportar os dados para o novo arquivo criado"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma quebra de linha no final do arquivo "
"se ela ainda não estiver presente (configuração padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       gera saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados …            as bases de dados que precisam ser convertidas para o formato do banco de dados antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave modo silencioso, mudo todas as alertas"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apague o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            excluir linhas em partição binária (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régulo de que o formato do arquivo de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rã que o formato do arquivo de entrada seja "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   Segue o link simbólico e converta a função de "
"destino."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui o link simbólico pelo arquivo convertido. "
"(os originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links macios e alteração de destino não "
"permitida (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra versão do programa"

