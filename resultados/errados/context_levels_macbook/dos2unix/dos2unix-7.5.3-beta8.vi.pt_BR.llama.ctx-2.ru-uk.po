msgstr ""
"O arquivo de entrada %s contém um BOM. Para remover o BOM, execute `%s "
"--remove-bom`."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação é UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução de ligações simbólicas do tipo 'm%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na alteração de permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "Usuário e grupo do arquivo %s não podem ser preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar proprietário e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao renomear o arquivo \"%s\" para \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          cái é o objetivo do link simbólico «%s»\n"

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está no diretório '%s'."

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados %s para reduzir a carga do sistema."

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para a página de código %d. Para obter mais informações, "
"tente `%s --help'."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Removemos o arquivo UTF-16 %s, cujo tamanho do wchar_t não é compatível com "
"%d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão de UTF-16 do arquivo %s, ocorreu um erro ao converter "
"dados UTF-16 em linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta "
"versão do software. Para obter mais informações sobre a compatibilidade com "
"diferentes codificações de caracteres e como converter para outra "
"codificação, consulte as seções 'Codificação' no manual."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o arquivo %s, isso não é um tipo de ficheiro comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o arquivo %s, ficheiro de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação fraca %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a ligação rica em %s, o objetivo dela não é um arquivo padrão. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borrando a ligação rica em %s, destino da relação de alta densidade não é um"
" arquivo típico. Para obter mais informações, tente `%s --help'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Fazendo o conversor de arquivo %s para o arquivo “%s” no formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo o conversor de arquivo para Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto “%s” para formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Unix %s..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Macintosh "
"(arquivo %s)..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Mac OS…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato DOS %s..."

msgid "problems converting file %s to file %s\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo %s, foram encontradas "
"problemas."

msgid "problems converting file %s\n"
msgstr "Encontrou problemas ao converter o arquivo %s."

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "página de código ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s inadequado."

msgid "option '%s' requires an argument\n"
msgstr ""
"Para o parâmetro \"%s\", é necessário especificar um valor para argumento."

msgid "invalid %s display encoding specified\n"
msgstr "falha na análise de entrada (%s)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de criação de novos "
"arquivos\n"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"erro: parâmetro inválido. Ocorreu um erro ao substituir o valor do segundo "
"argumento."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro de parâmetro incorreto. Ocorreu uma falha na troca do elemento "
"superior."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X"

