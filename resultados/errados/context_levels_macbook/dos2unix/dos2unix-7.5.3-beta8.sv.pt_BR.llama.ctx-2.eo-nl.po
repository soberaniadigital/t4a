msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando `grep` para encontrar e exibir as linhas que contêm a "
"palavra 'error' em um arquivo de log. Se você não souber como usar este "
"comando, consulte os exemplos abaixo:"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                standardkonverteringsläge\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Use o Windows Codepage 1252 (Ocidental Europeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS-codetabel 437 (USA) como padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (padrão europeu ocidental) para acessar os dados de "
"saída/entrada."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS-codetabel 860 (portugues) para continuar."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS-kodetabel 863 (français canadien) para verificar se a linha "
"%<PRIuMAX> é válida."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-kodetabel 865 (escandinavo) para verificar se a linha %<PRIuMAX> é"
" válida."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converterá os caracteres de sete bits para o formato "
"ASCII sem espaços em branco"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        retenha o byte order mark (Byte Order Mark) [pt-BR]"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        beholda byteorderingmarkering (Byte Order Mark) "
"(standart)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        conversão de modo '%s' ascii, '7bit', iso ou 'mac', "
"padrão é 'ascii'"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     utilizar codificação para apresentar os textos em "
"monitoraĵo\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um newline à última linha sem alterar o "
"conteúdo da mesma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Opção -f, --force           força a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para ver este texto de ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformatie\n"
"   para analisar o arquivo %s"

msgid " -k, --keepdate        keep output file date\n"
msgstr "Keep date of execution file"

msgid " -L, --license         display software license\n"
msgstr "visa o licenciamento do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar mais linhas\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         adicionar um Byte Order Mark (BOM) ao texto\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe til ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil              utmatningsfil i nyfilsläge"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          ikke tilleggte regeleindetekken till siste raden om "
"det ingen (standard)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro ...               converter os ficheiros para o formato de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           silencioso, suprimir todas as warnings"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção para remover o byte order mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o byte order mark (BOM) -r, --remove-bom      retirar a "
"marca de ordem dos bytes (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             binaire bestanden overslaan (standaard) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le para supor que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utente profundo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   seguir símbolos ligados e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzi symbolikaj ligeroj med konvertitajn dosierojn"
" per la konverto por kovrofilaro (la origina filo ne ŝanĝiĝas)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservando símbolos links e não as alterações "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Versão DOS em 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Versão DOS 16 bits (TURBOC)."

