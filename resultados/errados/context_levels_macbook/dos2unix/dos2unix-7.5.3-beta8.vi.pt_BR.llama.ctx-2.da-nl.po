msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Use o comando 'grep' para encontrar e exibir as linhas que contêm a palavra "
"chave '%s'. Se você quiser ver todas as alterações feitas no arquivo, use "
"'-v', caso contrário, utilize um número específico como argumento. Para "
"obter mais informações sobre o uso do comando 'grep' em seu sistema "
"operacional, digite `man grep`."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         wijziging van bestandseigenaar toestaan"

msgid " -ascii                default conversion mode\n"
msgstr "converter para ASCII (standar) "

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converteren entre os conjuntos de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows-1252 (codificação do ponto e vírgula) para codificar a linha "
"de entrada."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código padrão DOS 437 (US) para conversão de caracteres."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o codificador DOS 850 (Tây Árabe) para converter um arquivo de texto em "
"UTF-8."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o sistema DOS em modo de codificação BÔNDI (Bồ Đào Nha) com a versão "
"860."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o comando 'grep' para encontrar e exibir as linhas que contêm a palavra "
"chave `error` em um arquivo de log. Se você não souber como usar este "
"comando, consulte os exemplos abaixo:"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Baixo/Nordeste) para acessar os dados do sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converter para o plano de bits 8/7 bit"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        mantenha o byte order mark (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom        mantenha o byte order mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chétude do modo de converção:   "
"ascii, 7bit, iso, mac, padrão é 'ascii'."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para a apresentação dos avisos\n"
"   Codificação da tela de saída: ansi, unicode ou utf8 (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar um dógrau de nova linha no final caso não "
"esteja presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn câu -f, --force           gennemmandling af binære filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          convertem UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        hiển thị tính toán của một số lượng dữ liệu (%s) "
"trong file(s) %d. Các bạn có thể chọn nhiều fil, để biết hơn về kích thước "
"tập tin của mỗi phần tử."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        behold outputfils dato\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         licença de software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicionar marca de byte ordenado (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tape nao criar novo arquivo no modo de entrada/saída do script (tập tin gốc) para o novo arquivo\n"
"   infile              origemfil em mode-in-neu\n"
"   outfile             outputfil em mode-out-nu"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"opção --no-add-eol          không thêm dâng gỗi dòng vào cuối cùng nếu chưa "
"có dấu ngắt (mặc định)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       saída padrão escrever"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          adicionar ao távola de trabalho (método padrão) \n"
"   ficheiro ...            filtro para conversão em estado original do arquivo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           silencioso, sem aviso (chute) de erros"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção para remover o Byte Order Mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      remover o byte order mark (BOM) do ficheiro"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            bẩn binær filer (standaard)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16-kodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rằng o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção -F, --follow-symlink converter os símbolos de ligação para o formato "
"desejado e executar a conversão."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bặn (các tập tin dựng) thì để "
"nguyên không thay đổi"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ignore links simbólicos (máximo/minimum) (default)"

msgid " -V, --version         display version number\n"
msgstr "Opção -V, --version         versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr ""
"Ficha de referência do sistema operacional DOS em versão WATCOMC (16 bits)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficha técnica do DOS em versão de 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha de referência do sistema operacional DOS (32 bits) [DJGPP]."

msgid "MSYS version.\n"
msgstr ""
"Ficha de versão do MSYS. (Português) - Fica aqui o resumo da mensagem que "
"você recebeu."

msgid "Cygwin version.\n"
msgstr "Ficha de referência do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficheiro de texto para o Windows em 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de Windows 32 bits (WATCOMC)"

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows para sistemas de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha técnica do Windows para sistemas de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas operacionais em 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas em execução no modo gráfico (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de referência %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có homenagem para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Có homenagem ao desenvolvedor do sistema operacional Windows, que é "
"responsável por fornecer suporte para nomes Unicode. Para obter mais "
"informações sobre o uso de filas e colunas em Python com a biblioteca "
"pandas, consulte as seções 'Pandas - Fila' (Queue) e 'Pandas - Coluna'."

msgid "Without Unicode file name support.\n"
msgstr ""
"Não há suporte para nomes de arquivos Unicode. Para obter mais informações, "
"tente `%s --help'."

msgid "With native language support.\n"
msgstr ""
"Có homenagem ao desenvolvimento do sistema de tradução automática para o "
"português brasileiro."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o armazenamento de dados do usuário e grupo. Para obter "
"mais informações, tente `%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de entrada para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de codificação UTF-16LE é adotada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação UTF-16BE é adotada."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o ficheiro de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está usando %s como temporário de arquivo"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Acontece um erro ao alterar as permissões temporárias do arquivo de saída "
"%s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário ou grupo de arquivos %s não podem manter o registro. Para obter "
"mais informações, tente 'git checkout'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gerou um erro ao alterar o diretório e/ou grupo de arquivos temporários %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome para 'Arquivo':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo deste link é permitir que você possa usar o comando 'grep' para "
"pesquisar por palavras em um arquivo de texto. O programa irá ler a entrada "
"do usuário e, se houver uma correspondência encontrada no conteúdo da linha,"
" ele imprimirá essa linha na saída padrão (stdout). Se não forneceram "
"nenhuma palavra-chave de pesquisa ou ocorrer um erro ao ler a entrada do "
"usuário, uma mensagem será exibida para avisar que as opções estão ausentes."
" O programa irá continuar pedindo por novas entradas até que você interrompa"
" seu uso."

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"O arquivo UTF-16 '%s' não pode conter mais do que %d bytes. A tamanho máximo"
" de um 'wchar_t' é %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"falha na conversão UTF-16 da tabela de caracteres %s, ocorreu um erro ao "
"converter UTF-16 nesta linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"O arquivo '%s' não é um ficheiro regular. Para obter mais informações, tente"
" '`%s --help`'."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"O arquivo de entrada %s foi removido; o caminho do diretório %s é uma "
"associação simbólica."

msgid "Skipping symbolic link %s.\n"
msgstr "Falha na conexão com o servidor. Acesso ao arquivo %s não é possível."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"A ligação múltipla %s não pode ser feita, pois o destino é um arquivo "
"regular. O objetivo dessa operação nem sempre é uma tabela de dados."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu uma falha na conexão com o servidor. O arquivo %s não é um "
"diretório."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para a formatação Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto “%s” para formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para a ferramenta Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo de texto “%s” para formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo de entrada %s para um arquivo no formato Unix,"
" utilizando a ferramenta `gzip` com as opções `--stdout`, `-c`, e `--output-"
"format=json"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para a codificação Unix (%s)..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para o formato Mac %s..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo de texto '%s' para a codificação Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para tamanho de linha máxima (%d) em "
"formato DOS...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Đang chuyển đổi tập tin %s “%s” sang định dạng DOS %s…\n"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato de texto plano (Plain Text) "
"e salvando no diretório '%d'."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "A tela está em execução no modo de linha do terminal."

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de dados %s não é permitida."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr "falha na verificação da linha %s possui %s campos (esperado %d)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro de sintaxe incorreta. Ocorreu um erro ao substituir o parâmetro do "
"socket."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro de sintaxe inválida. Ocorreu um erro ao tentar ler o arquivo %s."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
