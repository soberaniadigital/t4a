msgstr "A linha de entrada %d não está disponível."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "O arquivo '%s' tem tamanho de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Houve um erro ao converter o arquivo %s, que é necessário para a conversão "
"UTF-16. Aqui estão as mensagens de erro e avisos relacionados à codificação "
"do sistema operacional."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
