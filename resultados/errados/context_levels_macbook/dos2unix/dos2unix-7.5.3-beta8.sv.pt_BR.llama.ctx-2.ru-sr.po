msgstr "falha na verificação do arquivo %s para o formato DOS"

msgid "problems converting file %s to file %s\n"
msgstr "falha na conversão de arquivo %s para o arquivo %s"

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação da linha %s possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo de entrada '%s'."

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação do comando 'grep' para o arquivo de entrada, pois ele "
"não foi encontrado."

msgid "active code page: %d\n"
msgstr "A linha de trabalho %s não pode ser encontrada."

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falha na verificação do sistema de arquivos, o que pode ser causado por um "
"erro no caminho específico para a pasta 'C:\\Users\\user\n"

msgid "option '%s' requires an argument\n"
msgstr "O arquivo '%s' não pode ser encontrado."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação do caminho de entrada/saída (%s) para o arquivo %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr "O arquivo de entrada %s não foi definido no novo formato."

msgid "can not read from input file: %s\n"
msgstr "Não foi possível ler o arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na verificação do arquivo de entrada. Ocorreu um erro ao ler o "
"ficheiro '%s'."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha na verificação do arquivo de entrada. Ocorreu um erro ao ler o "
"ficheiro '%s'."
