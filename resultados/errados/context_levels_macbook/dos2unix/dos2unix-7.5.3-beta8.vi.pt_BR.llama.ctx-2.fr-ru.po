msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [ficheiro …] [-n fichier_entrada "
"fichier_saida …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         autorise o alteração do proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão ASCII padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre os conjuntos de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar a codificação DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizar a codificação DOS 860 (Bohaiole) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a codificação DOS 863 (Codificação Canadense"
" Francês)    \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de códigos ASCII em um espaço "
"de bits de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conserte a marca de ordem dos bytes (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantenha a marca original do Byte Order Mark (por "
"padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ascii, 7bit, iso, mac, padrão é"
" ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8 (ansi mặc định là ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"linha se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar a conversão de arquivos binários em campos "
"separados por linha\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "opção --help            mostrar ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do arquivo de entrada\n"
"   ficheiro …           ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserve a data de saída do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione separador de linha adicionais\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “marca d’água de ordem dos bytes” (por "
"padrão em UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo\n"
"   fonte_entrada      arquivo original no modo de entrada nova\n"
"   destino_saida     arquivo de saída no modo de entrada nova"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não permite a mudança do proprietário de arquivo (por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona um caractere de nova linha no final da "
"última linha se ele não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão) \n"
"   ficheiro …            os ficheiros a serem convertidos para o modo do arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção --remove-bom      apagar o Byte Order Mark (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      apagar o Byte Order Mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            ignorar o arquivo de saída (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserve a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rã que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rão que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        modo detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink para seguir links simbólicos e converter objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca os links simbólicos por arquivos convertidos\n"
"(arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserve as ligações simbólicas e alvos inalterados "
"(por padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         exibir o número da versão do software"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro não encontrado."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica DOS 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficheiro não encontrado."

