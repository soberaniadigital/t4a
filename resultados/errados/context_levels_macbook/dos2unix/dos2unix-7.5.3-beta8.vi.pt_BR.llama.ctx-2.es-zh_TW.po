msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação Windows-1252 (Tây Dân) para acessar as "
"linhas da tabela."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                usa a página de códigos DOS 432 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize a página de código DOS 850 (Europa Ocidental) para o processamento "
"do arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o código DOS 860 (Português) para acessar as configurações do "
"sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa a página de código DOS 863 (Francês Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o código DOS 865 (Baixo/Norte) para acessar as pastas de trabalho "
"compartilhadas."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"Falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpia o BOM (Byte Order Mark) originalmente presente no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "giúpia o BOM (Byte Order Mark) padrão, se desejado."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC, por "
"defeito é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir các thông tin liên hệ\n"
"   bảng mã: ansi, unicode, utf8 (mặc định là ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção --add-eol   adicionar dógrafo ao final da linha se não houver "
"delimitador de linha (EOL) presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "bateria de conversão forçada dos arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do arquivo ...                    "
"c/a.fasta"

msgid " -k, --keepdate        keep output file date\n"
msgstr "conserte a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona linha extra ao final da entrada."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o Byte Order Mark (BOM), por padrão em UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreve em um novo arquivo\n"
"   táp-tin-vào         o arquivo original no modo de entrada do novo arquivo\n"
"   táp-tin-ra           o arquivo gerado nesse modo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          Não adicione um caractere de nova linha se não houver"
" nenhum no final da última coluna (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       escrever no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão) \n"
"    Arquivo ...         os arquivos a serem convertidos para o formato de arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, suprime todas as avisões"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção -r, --remove-bom      elimina o Byte Order Mark (BOM) padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"Remova o BOM (Byte Order Mark) -r, --remove-bom      elimina a Marca de "
"Orden do Byte."

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção --safe            ignora arquivos binários (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantém a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rão que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be supõe que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anúncio detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os enlaces simbólicos por arquivos "
"convertidos (os arquivos originas não são alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos nem seus destinos (por "
"defeito)"

