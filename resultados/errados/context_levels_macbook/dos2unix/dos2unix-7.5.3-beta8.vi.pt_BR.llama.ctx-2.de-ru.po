msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivos …] [-n entrada_arquivo "
"saída_arquivo …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "opção --allow-chown permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modo -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converte o texto entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar codificação DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar codificação DOS 850 (Tây Árabe) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizar codificação DOS 860 (Bohaio) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar codificação DOS 863 (Ca Na Da França) PT-BR"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de códigos ASCII em um espaço "
"reservado para o contexto do arquivo (context_file) usando a função "
"'converterASCIIToUnicode'."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preserva o Byte Order Mark (BOM) original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva o “Marca de Ordem dos Bits” (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de convergência:   ascii, 7bit, "
"iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"bảng mã:\tanpH, ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar um caractere de nova linha no final da última "
"linha se não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos de entrada em "
"formato binário\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "opção -h, --help            mostra a ajuda deste comando."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CPF]        exibe informações sobre o arquivo de entrada [arquivos para análise]\n"
"   Arquivo …            arquivos a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         Mostrar a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione um novo separador de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem dos Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          gera um novo arquivo\n"
"   tápia-tin-vào         original file no modo de entrada do novo arquivo\n"
"   tápia-tin-ra           saída para o novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"não permite a alteração do proprietário (chave) de arquivo padrão (método)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar um caractere de nova linha no final da "
"última linha, se ele não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          salvar no arquivo antigo (padrão) \n"
"   ficheiro …            os ficheiros para converter neste modo de conversão do ficheiro antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, suprimindo todas as mensagens de aviso."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção '-r', '--remove-bom'      apagar o Byte Order Mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      apagar o “Byte Order Mark” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignora arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantém a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  para seguir links simbólicos e converter objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(as originais permanecerão inalteradas) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha as ligações simbólicas e os objetivos sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         Mostrar versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha técnica do DOS 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica do DOS em 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do DOS em versão 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do DOS 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Fenome do MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Ficheiro não encontrado."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows para 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome do Windows 32 bit (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows para arquitetura de 32 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows para arquitetura de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome do Windows para arquitetura de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome do Windows para arquitetura de 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro não encontrado."

msgid "With Unicode UTF-16 support.\n"
msgstr "Sua tradução aqui"

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Ao trabalhar com nomes de arquivos Unicode, é importante garantir que o "
"sistema possa lidar corretamente com a codificação dessas strings."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Não foi possível obter estado (stat) do arquivo %s."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Para o suporte ao armazenamento de arquivos por proprietários e grupos, "
"utilize as funções apropriadas."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para a preservação do proprietário e da associação de grupo "
"no arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Está gravando o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s contém um BOM UTF-8. Para remover o BOM, execute `%s"
" --remove-bom`."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "É assumida a codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "É assumida a codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução da ligação simbólica '`%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilização de %s como arquivo temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na alteração dos direitos de acesso ao arquivo temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e a grupo que possuem o arquivo %s não podem ser preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"falha na alteração do proprietário e da grupo da pasta de saída temporária "
"%s:"

msgid "problems renaming '%s' to '%s':"
msgstr "encontrado erro ao alterar o nome do arquivo para 'nome_do_arquivo'."

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo dessa ligação simbólica de curto alcance, conhecida como \"%s\", "
"é acessar o arquivo localizado em %d."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída permanece no local \"%s\"."

msgid "Skipping binary file %s\n"
msgstr "O arquivo de texto binário %s foi pulado."

msgid "code page %d is not supported.\n"
msgstr "Apagamento não é suportado nesta página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"O arquivo UTF-16 %s não pode ser ignorado, pois o tamanho wchar_t é de %d "
"bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"falha na conversão UTF-16 da linha %<PRIuMAX> em '%s' com erro. Por favor, "
"verifique se o arquivo é um formato de texto válido."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Bora delevar a tabela UTF-16 %s, pois não há suporte para conversão do "
"UTF-16 nesta versão deste software. Para obter mais informações sobre o "
"formato correto da entrada e as opções disponísas, consulte '--help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho o arquivo %s, pois ele não é um ficheiro regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Ocorreu erro ao processar a linha %<PRIuMAX> com o número de campos esperado"
" %<PRIuMAX>. Para obter mais informações, tente '`%s --help`'."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação fraca %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a ligação mêmica %s, o objetivo dela não é um arquivo regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu falha na conexão com o servidor %s, a URL %s não é válida. Para "
"obter mais informações sobre como configurar uma nova senha para este "
"usuário, consulte 'https://example.com/help'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Fazendo o conversor de arquivo %s para o formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo o conversor de arquivo “%s” para a representação Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo o conversor de arquivo para Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo o conversor de arquivo para a representação Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo o conversor de arquivo para um novo formatador DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo o conversor de arquivo para DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato Unix…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Fazendo a conversão da tabela de dados %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Fazendo a conversão da tabela de dados %s “%s” para o formato DOS…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o arquivo %s. Por favor, tenha "
"paciência."

msgid "problems converting file %s\n"
msgstr "Acontecem problemas ao converter o arquivo %s."

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "falha na escolha do fio -i ou --info bateu falso\n"

msgid "active code page: %d\n"
msgstr "A thread está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falha na conversão do %s para o modo de codificação UTF-8, pois este não é "
"um formato suportado pelo sistema."

msgid "option '%s' requires an argument\n"
msgstr "Para o parâmetro \"%s\", é necessário um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo da tabela de dados %s não foi definido no modo novo arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Par de substituição inválido. Ocorreu um erro ao tentar converter o "
"par surrogate."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cadeia de caracteres inválida. O par surrogado não é válido."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
