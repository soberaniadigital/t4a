msgstr "Foi adicionado um novo caractere de quebra de linha na última linha."

msgid "program error, invalid conversion mode %d\n"
msgstr "Erro no programa, o modo de conversão %d não é permitido."

msgid "Converted %u out of %u line breaks.\n"
msgstr ""
"Foi convertido %s%u vezes de \n"
" para \\n. O número total de linhas é igual a %<PRIuMAX>."

