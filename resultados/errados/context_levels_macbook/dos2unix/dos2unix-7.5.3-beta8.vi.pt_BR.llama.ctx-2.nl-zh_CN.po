msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         escolher alterar o proprietário do arquivo de "
"texto"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento padrão de conversão textual para ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converter de caracteres entre o conjunto DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar codificação de caracteres Windows 1252 (Tây "
"Dương)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar tabela de caracteres DOS 850 (Tây Âu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar tabela de caracteres DOS 860 (Bồ Đào Nha)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando tabela de caracteres DOS 863 (China) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utilizar tabela de caracteres DOS 865 (Bacau) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converter de caracteres para o espaço reservado (7 "
"bits)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom         manter o 'Byte Order Mark' original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b, --keep-bom        mantém o 'Byte Order Mark' (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode\n"
"   modo de conversão: 'ascii', '7bit', 'iso', 'mac' (padrão é 'ascii')"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir codificação para exibição de mensagens\n"
"   CODIFICAÇÃO          'ansi', 'unicode', ou 'utf8' (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione um caractere de nova linha no final da última linha"
" se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar conversão de arquivos binários em tabelas "
"separadas por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Exibe este ajuda ao utilizador."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o conjunto de dados \n"
"   conjuntos de dados ...            os conjuntos de dados a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        giúp mãi nguyên ngày tháng tập tin đầu ra\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         Mostrar aviso de licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar 'Byte Order Mark' (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin trong chế độ tập-tin-mới\n"
"   tập tin ra           tập tin khác trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona quebra de linha no final da linha, mesmo "
"sem a presença do caractere de nova linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi para saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            as listas de dados que precisam ser convertidas para o modo do banco de dados antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, suprimir todas as avisas"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção --remove-bom      remover o “Byte Order Mark” (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar 'Byte Order Mark' (BOM) §﻿"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"-s --safe            Ignorar arquivos binários de segmentação (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato do arquivo de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        exibir detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "-F --follow-symlink   seguir links simbólicos e converter objetivos"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos em texto\n"
"                   (arquivos de destino permanecem não modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    lidem vínculos macios e objetivos fixos (padrão)"

msgid " -V, --version         display version number\n"
msgstr "--versao         Mostrar versão do programa"

