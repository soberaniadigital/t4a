msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo de texto “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Falha na verificação da linha %s possui %s campos (esperado %d)."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo a tabela de dados %s para o formato Mac no arquivo '%s'…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo a tabela de dados %s para o formato Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo a tabela de dados %s para o formato DOS no arquivo "
"'%s'..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Estamos convertendo a tabela de dados %s para o formato DOS do Windows, que "
"é compatível com sistemas antigos."

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo a tabela de dados %s para o formato JSON, mas "
"encontramos problemas ao tentar ler do arquivo '%s'."

msgid "problems converting file %s\n"
msgstr "Ao converter o arquivo %s, você encontrou problemas."

msgid "can not read from input file %s:"
msgstr "não foi possível ler a partir da entrada de dados %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação da opção '-i' ou '--info': não é uma opção válida."

msgid "active code page: %d\n"
msgstr "A tarefa em execução no terminal do Linux é a seguir:"

