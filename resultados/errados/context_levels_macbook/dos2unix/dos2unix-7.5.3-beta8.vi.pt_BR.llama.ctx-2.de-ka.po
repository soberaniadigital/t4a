msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de chamada para o comando 'grep': %s [opções] [-n entrada.txt "
"saída.txt ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "Modo de conversão -ascii                Vorgabeumwandlungmodus"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "chute zero para o final do texto."

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "usar o Windows Codepage 1252 (Tây Âu) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "usar o código de codificação DOS 437 (US) padrão"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                usado o CodePage DOS 850 (Tây Árabe) para codificação"
" de caracteres."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                usa o código de caracteres DOS 860 (Bồ Đào Nha) para "
"acessar e manipular arquivos no Windows XP."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"usar o trânsfere de caracteres DOS para Codepage 863 (Kanadês) usando a "
"ferramenta 'trs2dos'."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o espaço dos "
"bits a 7 (7-bit) bit."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        preserva o byte order mark (BOM) original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom        preserva o byte order mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de "
"codificação/decodificação: ASCII, 7bit, ISO, MAC, padrões definidos por "
"definição."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr " -D, --display-enc     đặt bảng mã para exibir notificações de erro\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicione um caractere de nova linha no final da última"
" linha se necessário complementar"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"Use o parâmetro --force para forçar a conversão de arquivos binários em "
"formato .pdb."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỌ]        mostra informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"keepdate        -k, --keepdate         preserva o dia da data original do "
"arquivo de entrada"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         dá a licença da software"

msgid " -l, --newline         add additional newline\n"
msgstr ""
" -l, --newline         adiciona um caractere de nova linha ao final da "
"entrada do usuário."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicionar “Marca de Ordem da Bits” (vigésima "
"primeira linha UTF-8)padrão"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         ახალ ფაილში გადმოყვაiante პარკა zero tolerance policy"
" for the document. The system should not only translate but also adapt to "
"different contexts and nuances of language use in Brazilian Portuguese, "
"ensuring that technical terms are accurately conveyed without altering their"
" meaning or introducing ambiguity into legal terminology related to software"
" development practices within a Linux environment: "

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "opção não permite a alteração do proprietário (válido) de um arquivo"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dáfima (dígito zero) ao final da última "
"linha se nenhum delimitador de linha for encontrado."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       para saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"    tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "opção silenciosa, sem saída para mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção --remove-bom      apaga o byte order mark (vigésima primeira posição) "
"(método)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"Remover o Byte Order Mark (BOM) -r, --remove-bom      remove o byte order "
"mark\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"opção segura -s, --safe            ignora o conteúdo do arquivo de entrada "
"(método padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva UTF-16 codificação."

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ định dạng đầu vào là UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be impõe UTF-16BE como formato de entrada"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Sempre que você encontrar um erro, por favor, informe o número de linhas do "
"arquivo (%s) e a posição da mensagem para obter mais ajuda."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por suas versões "
"convertidas (as origens permanecem inalteradas)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"lê a linha de comando e verifica se o caminho do arquivo é um link "
"simbólico. Se for, ele não será alterado (padrão)."

msgid " -V, --version         display version number\n"
msgstr " -V, --version         dê a versão (versão) do programa."

