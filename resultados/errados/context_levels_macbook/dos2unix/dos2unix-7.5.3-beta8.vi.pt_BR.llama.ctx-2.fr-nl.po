msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando '%s' [opções] [ficheiro …] [-n fichier_entrada "
"fichier_saida …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre os conjuntos de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação Windows-1252 (Tây Âu) para acessar os dados "
"do arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código de caracteres DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o código page DOS 850 (Tây Árabe) para acessar os dados do arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o código de codificação DOS 860 (Português) para este programa."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o código de página DOS 863 (Canadees Francês) para acessar os dados "
"do sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o código de codificação DOS 865 (Baixi) para processamento do "
"sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantenha a marca de ordem dos bytes"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom        garde a marca de ordem dos bytes (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de convergência:   ascii, 7bit, "
"iso ou mac, padrão é 'ascii'."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para exibir mensagens de erro"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicione um caractere de nova linha ao final da última"
" linha se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn cử"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use --help para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỌ]        mostra as informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção --keepdate        conserve a data de origem do ficheiro de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione linhas extras"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicione a marca de ordem dos bytes (padrão "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tape nao criar um novo ficheiro\n"
"   entrada em modo de criação do ficheiro original no modem \"novos arquivos\"\n"
"   saída para o ficheiro de saída nesse mesmo modo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona um caractere de nova linha no final da última linha se não "
"houver nenhum (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          importe no estado antigo (padrão) \n"
"   ficheiro(s) para converter em formato de arquivo original\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      remover a marca de ordem dos bytes (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      remover a marca de ordem dos bytes"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            ignorar arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte o codificação UTF-128"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suppose que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suppose que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção -F, --follow-symlink   seguir links simbólicos e converter os "
"destinos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay tãy không chuyển đổi các liên hệ symbolik (có "
"nhiều phép viết mới) bằng file convertidos. Os ficheiros originais não serão"
" modificados."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserve os links simbólicos e as cargas inalteradas "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr "Opção -V, --version         mostra o número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS em 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de versão DOS em 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS em 32 bits (Watcom C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha de versão DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha de versão MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha de referência do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficheiro de texto para o Windows em 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de versão Windows para sistemas em 32 bits (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficheiro de texto para o Windows XP (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha de versão Windows para sistemas em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas em execução no modo gráfico (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha de versão OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Phiên bản OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de versão %s."

msgid "With Unicode UTF-16 support.\n"
msgstr ""
"Có homenagem ao desenvolvimento do Python, que é uma linguagem de "
"programação poderosa e flexível. O PyCharm IDE permite a criação fácil de "
"scripts em python para automatizar tarefas comuns."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có homenagem para o suporte Unicode de nomes de arquivos."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Có homenagem ao desenvolvimento da linguagem C#. Ou seja, o que você está "
"procurando é uma tradução para a língua portuguesa do texto em inglês "
"fornecido."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Não há suporte para o usuário e grupo proprietários do arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estamos gerindo o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de codificação UTF-16LE é adotada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação UTF-16BE é adotada."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da ligação simbólica '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "Estou utilizando %s como ficheiro temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar as permissões temporárias do arquivo de saída %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador ou o grupo de proprietários do arquivo %s não podem ser "
"preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo '{}' para '{}':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o propósito do link simbólico '%s' é"

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr "falha na verificação da linha %s possui %s campos (esperado %d)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borracho o ficheiro UTF-16 %s, a tamanho do wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão UTF-16 %s, ocorreu um erro de convergência em linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"O arquivo UTF-16 %s não é suportado nesta versão do programa '%s'. A "
"conversão de UTF-16 não está disponível."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho, pois não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"O arquivo de entrada %s foi ignorado; o ficheiro de saída '%s' é um link "
"simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Ocorreu um erro ao conectar o link simbólico %s. Para obter mais "
"informações, tente '`%s --help'."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Ocorreu um erro ao tentar abrir o arquivo %s. O sistema não consegue "
"encontrá-lo."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu uma falha na conexão com o servidor. O arquivo %s não é um ficheiro "
"regular."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a representação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo de entrada '%s' para um formato compatível com"
" Mac, mas não conseguimos encontrar a versão do sistema operacional. Por "
"favor, verifique se você está utilizando uma máquina Linux ou Windows."

msgid "converting file %s to Mac format...\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Đang chuyển đổi tập tin “%s” thành tập tin “%s” theo định dạng DOS…\n"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a formação DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix %s... (cont.)"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a representação Unix do formato %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato Mac ao utilizar a ferramenta"
" de conversão do OpenOffice.org, mas não conseguimos encontrar um aplicativo"
" que possa fazer isso."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s para a representação Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato DOS em um processo que pode "
"durar minutos, pois ele é grande. Por favor, espere enquanto eu trabalho no "
"seu computador."

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a representação DOS do formato %d…"

msgid "problems converting file %s to file %s\n"
msgstr "Estamos convertendo o arquivo %s para o ficheiro %s."

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação: a linha %s possui %d campos (esperado %<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "A tarefa está em execução no soquete %s."

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de modo %s inválido"

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Código de entrada inválido. O semi-código base está faltando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"erro: Código de operação inválido. O código do meio não foi especificado."

msgid "has %s BOM.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"O arquivo UTF-16 %s não pode ser processado; o encoding atual da região "
"linguística é diferente de UTF-8."
