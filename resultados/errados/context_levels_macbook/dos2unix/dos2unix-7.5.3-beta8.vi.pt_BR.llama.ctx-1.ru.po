msgstr "Fenome do MSYS. Versão RU."

msgid "Cygwin version.\n"
msgstr ""
"Ficheiro de origem Cygwin. \n"
"\tVersão %s."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenótipo Windows para 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome do Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficheiro de versão para Windows, 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome do Windows para 64 bits (MSVC %d).\n"

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenoméntêa Windows 32 bit (MSVC %d).\n"

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro não encontrado."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro não encontrado."

msgid "%s version.\n"
msgstr "Ficheiro de origem %s.%d\n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Có hỗ trợ Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Sem suporte ao nome de arquivo em codificação Unicode."

msgid "With native language support.\n"
msgstr "Forneça suporte ao localizador nativo do idioma."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte, mantenha o proprietário original e a equipe de propriedade do "
"arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Sem suporte para o proprietário e grupo de usuários do arquivo. \n"

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Embaralhando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "Tápia de entrada %s contém BOM %s. \n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "É previsto que a tabela de código UTF-16LE será utilizada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "É previsto que a tabela de código UTF-16BE será utilizada."

msgid "problems resolving symbolic link '%s'\n"
msgstr "erro ao resolver ligação simbólica pequena \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s\n"

msgid "using %s as temporary file\n"
msgstr "utilizando %s como arquivo temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "Người dùng và nhóm sở hữu của tập tin %s không được giữ nguyên. \n"

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar proprietário e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên \"%s\" thành \"%s\"."

msgid "          which is the target of symbolic link '%s'\n"
msgstr "cái é o objetivo da ligação simbólica fina “%s”"

msgid "          output file remains in '%s'\n"
msgstr "tápico de saída do arquivo permanece no diretório \"%s\""

msgid "Skipping binary file %s\n"
msgstr "Borrar tabela de dados separados por linhas %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, a medida do wchar_t não é de %d byte. Para "
"obter mais informações sobre as opções disponíveis para este processo, tente"
" executar 'getopt --help'."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, foi gerada uma exceção ao converter UTF-16 no "
"registro de linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta "
"versão do software. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o arquivo %s, isso não é um típico ficheiro. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrar o %s, ficheiro de saída inicial %s é uma ligação simbólica."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação macrossa %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a ligação esmaaçada %s, o objetivo deste não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borrando a ligação fina %s, objetivo %s da ligação fina não é um arquivo "
"comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo \"%s\" no formato "
"Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo `%s` para o arquivo `%s`, no formato "
"Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Macintosh "
"(arquivo %s)..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr "Em processo de conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrado erro ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O fio de opção '%c' para o parâmetro -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "página de código ativa: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o %s modo de conversão não aceito"

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn \"%s\" yêu cầu một đối số"

msgid "invalid %s display encoding specified\n"
msgstr ""
"ocorreu erro na apresentação da tabela de visualização %s. A codificação não"
" é compatível."

msgid "target of file %s not specified in new-file mode\n"
msgstr "O objetivo do arquivo %s não foi definido no modo de criação novo\n"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível gastar no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia substituição inválida. Falta o segundo elemento da cadeia."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Falta o último caráter da cadeia."

msgid "has %s BOM.\n"
msgstr "contém %s BOM."

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, a codificação atual da tabela de símbolos não "
"é UTF-8. Ainda que seja possível trabalhar com essa codificação em algumas "
"aplicações específicas."
