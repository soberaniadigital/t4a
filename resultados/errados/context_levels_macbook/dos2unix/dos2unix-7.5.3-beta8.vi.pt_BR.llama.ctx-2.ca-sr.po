msgstr ""
"Olá! O sinal de seleção '%c' para a opção -i ou --info apresentou um erro. "
"Por favor, tente novamente."

msgid "active code page: %d\n"
msgstr "página de codis ativa: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr "s'ha especificat un mode de conversió %s no valid"

