msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar proprietário do arquivo de texto\n"

msgid " -ascii                default conversion mode\n"
msgstr "-ASCII -modo padrão de conversão para texto simples"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converte entre o sistema DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizando código fonte Windows 1252 (Vestfália) do "
"inglês para o português brasileiro."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando código de fuso horário DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"-850                utilizando código de fuso horário DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando interface gráfica do DOS em modo de "
"codificação 860 (Bồ Đào Nha)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizando interface gráfica do sistema DOS 863 (Ca Na "
"Da França)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizando interface gráfica do DOS em código de fuso "
"horário 865 (Nordeste)   -865                usando interface gráfica do DOS"
" no fuso horário 865 (Nordeste)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converter %s para 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b --manter o “BOM” original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --manter BOM (marca de byte padrão)    -g, --keep-bom        giúp nữa "
"«Byte Order Mark» (mặc định)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:\n"
"ascii, 7bit, iso, mac (modo padrão é ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      mostra banners de mensagens codificados em texto\n"
"   codecs disponíveis: ansi (default), unicode, utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar uma quebra de linha no final da linha se não "
"houver nenhuma presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           obrigatório converter de arquivos binários para texto, "
"separando os dados em tabelas numeradas."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030         Converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            Ajuda nesta assistência\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo\n"
"   tabela ...            vários conjuntos de dados que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        guarde o dado de data/hora original do arquivo de "
"saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         vis programvarelisens\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem de Bits” (padrão UTF-8) \n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (diretório) de"
" arquivos padrão\n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dógrafo de nova linha no final da linha "
"se não houver (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr ""
" -O, --to-stdout       gera saída padrão conforme a especificação de exemplo"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"táp-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      excluir “Marca de Ordem do Byte” (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      excluir “Marca de Ordem do Byte” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --seguro            excluir linhas por padrão (método seguro)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     guia UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "-ul, --assume-utf16le considerando o formato de entrada como UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be considerando o dado de entrada como UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   o teo liên kết mềm và chuyển đổi đích\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi\n"
"                   (các tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha ambas as símbolos e objetivos sem alterações"
" (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostrar versão do software\n"

