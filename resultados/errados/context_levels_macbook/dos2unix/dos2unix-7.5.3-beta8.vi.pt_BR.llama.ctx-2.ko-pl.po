msgstr ""
"Olá! O comando 'c%<PRIuMAX> --info' apresentou um erro. A flag '%s' não é "
"válida para essa opção."

msgid "active code page: %d\n"
msgstr "A tela está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"Já defini um modo de conversão %s inválido. Por favor, verifique as "
"configurações e tente novamente."

msgid "option '%s' requires an argument\n"
msgstr "'%s' requer um número inteiro para o valor do argumento."

msgid "invalid %s display encoding specified\n"
msgstr "Já enviou uma tabela de exibição inválida %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi definido no modo de criação de novo "
"arquivo."

