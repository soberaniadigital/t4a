msgstr ""
"Está a converter o arquivo %s para um conjunto de dados no formato do "
"arquivo %s"

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

