msgstr ""
"Borra este arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta "
"versão do programa. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aqui não é um arquivo comum. \n"

