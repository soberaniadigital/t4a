msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [cóciaes de opção] [tápis...] [-n tápis-vào/entrada... -a "
"tápis-saída...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite alterar o proprietário do arquivo de entrada"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte entre o sinal DOS e ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               usado com trângulo de código Windows 1252 (Tây Átoph)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437 utilizado com a tela de texto DOS 437 (EUA) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usado com trâng mã DOS 850 (Tây Âu)    \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                usado com trâng mã DOS 860 (Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usado com trens de codificação DOS 863 (Ca Na Đa "
"Pháp) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                usado com trâng mã DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte 8-Bit-caracteres para aqueles do espaço de 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o Byte Order Mark (BOM) na ordem de bytes "
"original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantém a marcação do Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode\n"
"   chave de conversão:\n"
"ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir codificação para exibição de mensagens\n"
"   bárragem mãe:\n"
"       ansi (padrão)\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se necessário complementar"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force   obrigatório para converter arquivos binários em formatos "
"textuais."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          transforma UTF-16 em GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra esta ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações da tabela de dados (tabela) dos arquivos a serem analisados\n"
"   ficheiro(s)...            os ficheiros que precisam de análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        conserva o dia da data de origem do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L --license         mostra a licença da aplicação"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione ‘Byte Order Mark’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          gera uma nova pasta de arquivos\n"
"   entrada_de_arquivo    origem do arquivo no modo novo-pasta\n"
"   saida_de_arquivo      salva o arquivo gerado no modo novo-pasta"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar o proprietário do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dáfine de nova linha ao final da última "
"linha se nenhuma existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo padrão de saída"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, oculta todas as avisões\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      retira o 'Byte Order Mark' (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            borra tabela binária (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr ""
" -u,  --keep-utf16     preserva UTF-16 codificação da tabela de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "-ul, --assume-utf16le implica que o formato de entrada é UTF-16LE."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be significa que o formato de entrada é UTF-16BE."

msgid " -v,  --verbose        verbose operation\n"
msgstr "-v --verbose        relatório detalhado\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  para seguir links simbólicos e converter o destino"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    permite links simbólicos e seus alvos permanecerem "
"inalterados (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         mostra a versão da ferramenta"

