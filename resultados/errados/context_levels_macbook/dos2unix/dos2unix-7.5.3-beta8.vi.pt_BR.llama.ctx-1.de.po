msgstr ""
"Em processo de conversão da tabela de dados “%s” para a tabela de dados "
"“%s”, no formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Ao converter o arquivo de texto “%s” para a representação do Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Em processo de conversão da tabela de dados “%s” para a tabela de dados "
"“%s”, no formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Ao converter o arquivo “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para a versão Unix, você obterá um arquivo "
"chamado %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para a representação Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto %s “%s” para formato Mac, você terá um novo "
"arquivo chamado %s…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para a representação Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Em processo de conversão da tabela `%s” para a tabela “%s” no formato DOS "
"%s…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para a versão DOS do sistema operacional MS-"
"DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, foram encontrados problemas."

msgid "problems converting file %s\n"
msgstr "Encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O sinal de apontar para o 'código' '%c' na opção -i ou --info está "
"incorreto."

msgid "active code page: %d\n"
msgstr "A interface está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "O modo de conversão %s definido é inválido."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn \"%s\" yêu cầu một đối số (argumento)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"O código de exibição %s apresentado não é aceito para a tela principal."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo da pasta %s não foi especificado no modo de criação do novo "
"arquivo a partir dela."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever na tabela de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Ocorreu a falta do elemento inferior "
"da troca."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: CΗp thay thế không hợp lệ. Thiếu cái thay thế trên."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
