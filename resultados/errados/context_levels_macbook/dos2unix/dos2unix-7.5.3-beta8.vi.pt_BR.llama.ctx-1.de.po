msgstr "Bora sair da tabela de dados divididos %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para código de fonte %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"A tabela UTF-16 %s foi ignorada, pois o comprimento do wchar_t não é de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"A tabela UTF-16 %s foi ignorada, pois ocorreu um erro de conversão para "
"UTF-16 na linha %u. Para obter mais informações, consulte '%c'.\n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Bora abandonar a tabela de dados UTF-16 %s, pois não há suporte para "
"conversão entre os dois formatos nesta versão do software. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, pois não é uma pasta regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o %s, a saída de texto inicial %s é uma associação macia."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra a associação macia %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o laço de associação mole %s, pois seu objetivo não é uma pasta "
"regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Bora deixa o vínculo macio %s, objetivo %s do vínculo móvel não é uma pasta "
"regular. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão da tabela `%s' para a tabela '`%s'' no formato "
"Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo de texto “%s” para a representação Unix…"

