msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [arquivos ...] [-n arquivo_jentrade "
"arquivo_jessude ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"conversão ISO para DOS -iso                   converte caracteres entre "
"sistemas de codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação do preço Windows 1252 (Tây "
"Dong) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                utilizando codificação DOS 437 (EUA) (definitivo)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando o terminal de comando DOS 860 (Brasil) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando o terminal do DOS 863 (Canaã francês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando o terminal de comando DOS 865 (Nordic) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte i caracteres de 8 bit em 7 bit"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        manten o sinal do Byte Order Mark (BOM) original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        manten segn di ordin dal Byte Order Mark (byte order "
"mark) (predefinît)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO ou MAC (padrão"
" é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      defina a codificação de exibição para apresentar mensagens do teste\n"
"   CODIFIÇÃO DE EXIBIÇÃO: 'ansi', 'unicode' ou 'utf8'\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"Adicionar uma quebra de linha no final da entrada se não houver nenhuma "
"(--add-eol)"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocada conversão dos arquivos binários em formato de"
" texto e dois conjuntos adicionais."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre a ajuda deste utilitário\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações sobre o arquivo de entrada ..."
"            mostre as informações específicas do conjunto de dados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostre a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         boneco novo\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem do Byte” (marcação por byte)"
" (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a alteração do proprietário (de "
"arquivo) [predefinido]"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dóisng final (não inclui trailer newline)"
" se nenhum deles fornecido explicitamente."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem aviso algum\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      gỡ bỏ “Marca de Ordem do Byte” (mặc định) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM) do arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             preterpasi duumajn dosierojn (defaŭlto)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   sekvi simboliks ligojn kaj konverti ties celojn."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha as ligações simbólicas e listagens "
"invariáveis (defaul)"

