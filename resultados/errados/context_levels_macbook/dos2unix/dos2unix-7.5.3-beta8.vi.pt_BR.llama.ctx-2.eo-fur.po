msgstr ""
"Remova o arquivo UTF-16 %s, a quantidade de bytes do tipo 'wchar_t' não é "
"igual ao valor especificado (%d byte).\n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Se o arquivo UTF-16 %s, foi detectado um erro de conversão do formato UTF-16"
" na linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Seja removido o arquivo UTF-16 %s, a conversão de UTF-16 não é suportada "
"nesta versão deste software. Para obter mais informações sobre as opções "
"disponíveis para este tipo de ficheiro, tente 'EO --help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Seja removido %s, isso não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Apague a linha %s, o arquivo de entrada inicial é um link simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o laço mínimo %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Bỏ qua liên kết mềm %s, đích của nó không phải là một tập tin thường.\n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Seja removido o link curto, a carga de %s não é um arquivo regular. A "
"ligação simbólica entre links longos e curtos não pode ser feita."

