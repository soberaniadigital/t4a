msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO de uso: %s [opções] [arquivos ...] [-n arquivo_entrada arquivo_saida "
"...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite a modificação do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão -iso entre caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação de caracteres Windows 1252 "
"(padrão ocidental europeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                dùng trang mã DOS 437 (US) (mặc định)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a tela de código DOS 850 (tâmil ocidental)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a interface gráfica DOS 863 (Canadês "
"francês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando a interface gráfica do DOS 865 "
"(nordestina) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte i caracteres de 8 bits para o espaço em "
"branco de 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        manter o segn de ordem original do Byte (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantendo o sinal de Byte Order Mark (byte order mark)"
" (padrão definido)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:\n"
"ascii, 7bit, iso, mac; padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação de exibição para os mensagens "
"do teste. Codificações suportadas incluem ansi, unicode e utf8; padrão é "
"ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se ele não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocando a conversão dos arquivos binários em formato"
" de texto"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda nesta opção\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações sobre o arquivo de entrada\n"
"   ficheiro ...            ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        manter a data original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostre licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar “Marca de Ordem do Byte” (byte order mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      sem permissão para alterar o proprietário do "
"arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          sem adicionar o caractere de nova linha no final "
"(padrão) se não houver nenhum presente."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no stdout padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carrega o arquivo antigo (padrão) \n"
"   ficheiro ...            os ficheiros que precisam ser convertidos para formato novo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimindo todas as advertências\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      gelo bônus da ordem do byte (byte order mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gelo bônus da ordem do byte (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            zerar o conteúdo do arquivo de log (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo o formato UTF-16LE como dado."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        análise detalhada do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  o seguir símbolos e converter destinos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin dựa trải nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha o vínculo simbólico e as direções "
"(predefinido) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍNCEANDO DO DOS 16 BITS (WATCOM C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenome do sistema operacional DOS (16 bits) para TURBOC."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "FENDA DE PROGRAMAÇÃO WATCOM C COM FORMATAÇÃO DO DOS (32 BITS)"

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do sistema operacional DOS (DJGPP) em 32 bits."

msgid "MSYS version.\n"
msgstr "Fenome de base MSYS."

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome de Versão a 64 bits do Windows (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍNCEANS DO WINDOWS 32 BIT (WATCOM C)"

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome de base do Windows a 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "FENDA DE PHÍNCEANS DO WINDOWS 32 BIT (MINGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Fenome de %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "O suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Olá! O suporte para o nome do arquivo Unicode.nlm."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome do arquivo Unicode."

msgid "With native language support.\n"
msgstr ""
"Olá! O programa 'Có hỗ trợ bản địa hóa ngôn ngữ.' é um software que permite "
"a tradução automática de texto entre idiomas. Para obter mais informações, "
"tente executar o comando `python3 -m py_translator --help`."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como suporte para o usuário e grupos de proprietários do arquivo. \n"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Não há suporte para o proprietário original e grupo de arquivos."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída do arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estamos gravando o BOM %s. \n"

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s contém um BOM %s. Para obter mais informações, tente"
" `%s --help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"encontrou erro ao tentar resolver o problema de divisão simbólica '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando o %s como ficheiro temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Erro ao alterar permissões temporárias do arquivo de saída intermediário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo do arquivo %s não podem possuir o direito de leitura. "
"Para obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Encontrado erro ao alterar o proprietário e grupo do arquivo de saída "
"temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao alterar o nome do arquivo para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"O objetivo deste link simbólico '%s' é obter um valor de entrada para o "
"parâmetro 'input_file'"

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída ainda está no local '\\u0027%s\\'."

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr ""
"Não há suporte para o site %s. Para obter mais informações, tente `%s "
"--help'."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Remova o arquivo UTF-16 %s, tamanho do wchar_t não é igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, foi detectado um erro de conversão do UTF-16 na "
"linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Fora do arquivo UTF-16 %s, a conversão para UTF-8 não é suportada nesta "
"versão deste programa. Para obter mais informações sobre as opções "
"disponíinflas digite 'help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borraremos %s, isso não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Remova o arquivo %s, ficheiro de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova o vínculo mẽeio %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o link mais curto, %s, pois não é um arquivo comum. Para obter mais "
"informações, tente '`%s --help'."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Após remover o laço mínimo %s, a destinação simbólica do link curto não é um"
" padrão de arquivo. Para obter mais informações, tente `%s --help'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Está a converter o arquivo %s para o formato de texto plano do Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de tabela Unix...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s para o formato Unix...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Macintosh..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s para o formato Macintosh...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato DOS..."

msgid "problems converting file %s to file %s\n"
msgstr "Fazendo a conversão do arquivo %s para o arquivo %s."

msgid "problems converting file %s\n"
msgstr "encontrar trágem quando fazer conversão de arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "A opção '%c' para o comando '-i' ou '--info' está incorreta."

msgid "active code page: %d\n"
msgstr "A tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Falha na conversão de %s não é válida."

msgid "option '%s' requires an argument\n"
msgstr "Fora da opção '%s', é necessário um número inteiro."

msgid "invalid %s display encoding specified\n"
msgstr "Falha na análise de entrada/saída padrão %s\n"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não pode ser definido no modo de entrada/saída "
"padrão."

msgid "can not read from input file: %s\n"
msgstr "não é possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Cadeia de substituição inválida. Substitua abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: Cadeia de bytes não é válida. Campo inválido."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
