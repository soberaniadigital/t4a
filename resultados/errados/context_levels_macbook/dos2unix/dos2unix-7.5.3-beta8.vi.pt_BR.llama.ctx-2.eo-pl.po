msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cácio usado: %s [cursos] [arquivos ...] [-n arquivo_entrada arquivo_saída "
"...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permissão para alterar proprietário do arquivo de "
"texto"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento padrão de conversão para texto em ASCII "
"(defaulte)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte caracteres entre o DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               uso da tela Windows 1252 (Tây Dương)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                uso da tela de DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                uso do trângulo de dados DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                uso da tela DOS 860 (Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "-863                uso da tela DOS 863 (ca na diafam)    \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                uso da trângulo de mapeamento DOS 865 (do Norte) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de baseados em 8 bits para a "
"representação na base 7\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "--keep-bom        reteni nguyên Byte Order Mark (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        reteni nguyên Byte Order Mark (mặc định) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de modo conversão\n"
"   modo conversão: ascii, 7bit, iso, mac; padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      definir codificação para exibição de mensagens \n"
"   codificações disponíveis ansi, unicode, utf8; padrão é ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar o caractere de nova linha se não estiver presente no final da "
"última linha\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar conversão de arquivos comuns e binários em "
"pares"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         conversão de từ UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            exibir este ajudação"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo de texto\n"
"   do/para ...            aplica-se a esses tipos de arquivos para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conservar a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo caractere de nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập tin ra             tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração do proprietário de arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem adição de EOL --não acrescenta o caractere de nova linha ao final da "
"última linha se não houver nenhum (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       ghi vào saída tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định)\n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập-tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "ché -q --quiet chão, silencioso e sem alarme para o usuário."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      gelo bônus do “Byte Order Mark” (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "--remove-bom      apagar o BOM (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     retenção da tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le com base na hipótese de que o formato do arquivo de "
"entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na premissa de que o formato do arquivo de "
"entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   sekvi liên kết mềm và chuyển đổi cái cel"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca dos links simbólicos por cópias do conteúdo das"
" tabelas de dados (conteúdos) originais. As pastas e arquivos primordiais "
"permanecem inalterados."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    mantenha as ligações simbólicas mêre e objetivo fixos "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         exibe versão do programa"

