msgstr ""
"encontrado erro ao tentar resolver o problema de ligação fraca entre "
"símbolos '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utiliza o %s como ficheiro temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gặp erro ao alterar as permissões temporárias do arquivo de saída final %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo que possui o arquivo %s não podem manter a posse "
"original do mesmo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "encontrado erro ao alterar o nome do arquivo de '%s' para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o propósito do curto linkoso 'flexible' '%s'"

msgid "          output file remains in '%s'\n"
msgstr "tápia de saída com dados ainda na “%s”"

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados separados por linhas %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o site %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a largura do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, houve um erro ao converter UTF-16 na linha %u."
" \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, converte a codificação UTF-16 que não é suportada"
" nesta versão do programa %s. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o arquivo %s, isso não é um padrão de ficheiro. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Após remover %s, o arquivo de saída inicialmente é um ponto flutuante. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link fino %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o vínculo pequeno %s, pois seu objetivo não é um arquivo comum. "
"Aceite a diferença."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Após remover o laço fino macio %s, objetivo %s do laço fino macio não é um "
"arquivo comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s para o arquivo \"%s\" no formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr ""
"O processo de conversão do arquivo \"%s\" para o formato Unix está em "
"andamento...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Converte o arquivo de texto \"%s\" para o formato Mac do arquivo \"%s\"..."

