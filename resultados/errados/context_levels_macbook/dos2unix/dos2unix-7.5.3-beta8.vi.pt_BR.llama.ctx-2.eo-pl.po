msgstr "Fazendo a conversão do arquivo de texto \"%s\" para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato Unix está em "
"andamento...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato Mac está em "
"andamento...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Conversando o arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato DOS está em "
"andamento... (continuação necessária)"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato DOS %s está em "
"andamento...\n"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, você pode encontrar problemas "
"relacionados ao processamento do dado."

msgid "problems converting file %s\n"
msgstr "encontro tricô quando converto tabela %s"

msgid "can not read from input file %s:"
msgstr "nie można czytać z pliku wejściowego %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"a opção '-i' ou '--info' para a escolha do caminho de entrada está "
"incorreta."

msgid "active code page: %d\n"
msgstr "a tela atualmente está em execução: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"o uso do comando %s foi considerado inválido por indicações insuficientes."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn \"%s\" requer um número inteiro (%d)"

msgid "invalid %s display encoding specified\n"
msgstr "o código de apresentação visual não é adequado para a tabela %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi definido no novo formato de ficheiro"

msgid "can not read from input file: %s\n"
msgstr "não é possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível gravar no arquivo de saída: %s"

