msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [arquivos ...] [-n infil utfil …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         permite a mudança de propriedade do arquivo\n"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii                padrão de conversor de caracteres"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converteção entre DOS e codificações ISO-8859-1 de "
"caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizando o Microsoft Windows Code Page (padrão "
"europeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizar o tabuor de codificação DOS 437 (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar o tabuor DOS em codificação de caracteres "
"850 (europeu da Europa Ocidental) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar o tabuor de codificação DOS 860 (portuguesa)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar o tabuor de codificação DOS 863 (franco-"
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utilizar o tabuor DOS de 865 (nordeste)    \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converterá os caracteres de 8 bits para o espaço de 7 "
"bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --keep_bom        preserva o marcador de ordem dos bytes (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --keep_bom         Preservar a marcação de ordem dos bytes (Byte Order "
"Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão\n"
"   modo de conversão    ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     selecione o método de codificação para mensagens textuais a serem exibidas\n"
"   kodning             ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol         Adicionar uma quebra de linha na última coluna se "
"nenhum dela existir\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           tvinga konvertering av binära filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converterá UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            para visualização deste texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR]   visa informação sobre o arquivo «arquivo» para "
"análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "-L, --license         Visa o software para uso sob licença."

msgid " -l, --newline         add additional newline\n"
msgstr "-l --newline         adicione linha extra ao final da entrada."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione marcador de byte (Byte Order Mark) para "
"UTF-8 padrão\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever em novo arquivo\n"
"   infil               origem do arquivo na nova linha de leitura/escrita\n"
"   utfil               saída para um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário de arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          Não adicione uma quebra de linha na última coluna se "
"ela não tiver o caractere de divisão da linha (valor padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to stdout       escrever para saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile         escreve no arquivo antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, ocultar todas as mensagens\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r --remove-bom      Remove byte order mark (BOM) (default)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --remove-bom      Remove byte order mark (BOM) from the file"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            saltar sobre arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     preserva o UTF-16 codificação de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le fica assumindo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be fica assumindo que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        realização detalhada do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui símbolos de ligação por arquivos convertidos\n"
"                         (o objetivo original dos links permanece inalterado)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preserva links simbólicos e alterações de destino "
"(padrão)"

