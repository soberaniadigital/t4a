msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [arquivos ...] [-n arquivo_jentrade "
"arquivo_jessude ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento de conversão predefinido"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão -iso entre codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação de caracteres do Windows 1252 "
"(Tây Dòng) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando código de caracteres DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando tabuleiro de jogo DOS 863 (francês "
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o plano de 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "mantenha o sinal de Byte Order Mark (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantenha o sinal do Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC, padrão é"
" ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de exibição para mensagens de teste visualizadas\n"
"   códigos de formatação:\n"
"       ansi (padrão), unicode, utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"Adicionar uma quebra de linha no final da entrada se não houver nenhuma "
"(--add-eol)"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           blocar conversão dos arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda para este comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações do tập tin ...            arquivos"
" para análise\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostre licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o sinal de byte ordenação (marcação do Byte "
"Order Mark) (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a modificação do proprietário de "
"arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dóis vírgula(s) no final se nenhum for "
"encontrado (padrão definido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carrega o arquivo antigo (padrão) \n"
"   ficheiro …            filtro para conversão em um formato de arquivo mais novo."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimindo avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      excluir o sinal de byte ordenação (marca do Byte) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      gelo remover o sinal de Byte Order Mark (BOM) da "
"sequência binária"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte i file binære (predefinît) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de caracteres UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguir símbolos de ligação e converter para a "
"localização alvo\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha o link simbólico e as referências fixas "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Fenome do DOS em modo de 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenome do DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍNCEANDO DOS (WATCOMC) - Versão em 32 bits."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Fenome do MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows a 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome de base WATCOMC para Windows a 32 bits."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenômeno Windows de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows a versão de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Fenome de %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có habilitar suporte para arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome do arquivo em Unicode."

msgid "With native language support.\n"
msgstr ""
"Olá! O objetivo deste documento é fornecer suporte para a localização de "
"linguagem. Para obter mais informações, tente '`%s --help`'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como parte integrante da equipe, você pode compartilhar e manter o acesso "
"aos seus dados com outros usuários. Para obter mais informações sobre como "
"fazer isso, tente 'git add' para adicionar arquivos ao repositório."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para acessar informações originais de usuários e grupos. Para"
" obter mais detalhes, consulte o manual do programa."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s possui BOM %s. Para obter mais informações, tente "
"`%s --help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na análise de ligação mínima entre símbolos '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está usando %s como temporariamente para o arquivo de texto"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "O usuário e/ou grupo que possui o arquivo %s não podem alterá-lo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar proprietário e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên “%s” thành “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "O objetivo deste link simbólico '%s' é o seguinte:"

msgid "          output file remains in '%s'\n"
msgstr "arquivo de saída ainda não foi criado em '%s'."

msgid "Skipping binary file %s\n"
msgstr "Remover o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para o navegador %d. Para obter mais informações, tente `%s "
"--help'."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Remova o arquivo UTF-16 %s, a dimensão do tipo wchar_t não é igual ao "
"tamanho de %d byte. Para obter mais informações sobre opções válidas para "
"este comando, digite '--help'."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que causou um erro de conversão para UTF-8 na "
"linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Fora do arquivo UTF-16 %s, a conversão para UTF-16 não é suportada nesta "
"versão de %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrajei %s, isso não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Seja removido %s, o arquivo de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova o link mais curto entre %s e %d. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Separar a ligação mínima %s, o objetivo dela não é um arquivo típico. Ou "
"seja, ela representa uma conexão simbólica."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Seja cuidadoso ao remover o link curto entre %s e %d, pois este não é um "
"arquivo comum. A solução para a conexão simbólica de links mais curtos deve "
"ser encontrada em outro lugar."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s para o formato de ficheiro Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Está convertendo o arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo de texto “%s” para o formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo de texto “%s” para o formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de arquivo Unix…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Mac OS X…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato de arquivo DOS…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr "Fazendo a conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrar tráfego ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O '\\"

msgid "active code page: %d\n"
msgstr "Página de trabalho atual: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr "FUR não é uma opção válida para o estilo de conversão especificado."

msgid "option '%s' requires an argument\n"
msgstr "Fora a opção '%s', ela requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi definido no novo estado de ficheiro"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"erro: Cadeia de caracteres inválida. Ocorreu um erro ao substituir o "
"parâmetro."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cadeia de caracteres inválida. Campo incorreto."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
