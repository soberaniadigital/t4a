msgstr ""
"Borra o arquivo UTF-16 '%s', convertendo para BIN. Não é suportado a "
"conversão de UTF-16 nesta versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aí não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra este %s, o arquivo de saída é um link curto e denso. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link pequeno %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra este link pequeno '%s', o objetivo dele não é ser um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra este link pequeno, destino de links pequenos não é um arquivo comum. "
"\n"

