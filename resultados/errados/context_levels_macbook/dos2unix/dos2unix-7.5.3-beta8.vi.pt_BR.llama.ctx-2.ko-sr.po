msgstr ""
"Borra o arquivo UTF-16 '%s', cuja dimensão do tipo wchar_t não é %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 '%s', que apresentou erro ao converter UTF-16 na "
"linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
