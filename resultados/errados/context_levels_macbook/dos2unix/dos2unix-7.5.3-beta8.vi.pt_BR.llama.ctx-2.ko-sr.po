msgstr "'%s' problema ao interpretar ligação molecular pequena \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como tabela temporal"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissão de acesso do arquivo temporário saída %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo proprietários do arquivo %s não possuem mais o direito "
"de uso. A propriedade foi transferida para outra pessoa ou entidade."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, não foi possível alterar a propriedade e o grupo do arquivo de "
"saída temporário %s:"

