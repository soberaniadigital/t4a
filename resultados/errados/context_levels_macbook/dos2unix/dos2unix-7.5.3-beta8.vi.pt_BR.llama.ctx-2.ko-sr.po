msgstr ""
"Đang chuyển đổi tập tin %s “%s” thành tập tin “%s” theo định dạng DOS %s…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Ao converter o arquivo %s “%s” para a versão DOS do formato..."

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para um conjunto de dados (dataset) no "
"formato %s."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"Olá! O comando 'cờ %c' para a escolha -i ou --info apresentou um erro. Por "
"favor, verifique o uso do seu label '%c'. Para obter mais informações sobre "
"como usar este argumento corretamente, tente executar `get_help`."

msgid "active code page: %d\n"
msgstr "página de status atualizada: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "DESEMPREENIDO 변환 %s"

msgid "option '%s' requires an argument\n"
msgstr "'%s' solicita um número de exemplo."

msgid "invalid %s display encoding specified\n"
msgstr "ผลิตภัย ของ %s ไม่符合 แสดงรายการ"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no novo modo de abertura do "
"arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

