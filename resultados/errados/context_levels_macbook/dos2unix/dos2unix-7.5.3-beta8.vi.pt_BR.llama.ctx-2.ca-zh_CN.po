msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓMO USAR:\n"
"%s [opções] [arquivo(s)...]\n"
"[-n arquivo de entrada ... arquivo de saída...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite o alteração do proprietário de um arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii - modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   conversão entre sistemas de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               usa trâng mã Windows 1252 (Tây Âu)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa trângulo de código DOS 437 (US) (por defeito)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usa trângulo de código DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                usa trâng mã DOS 860 (Bồ Đào Nha)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa trâng mã DOS 863 (Canadá Francês, França do Sul) "
"\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                usa trângulo de código DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        manté a marca d'ordre de bytes (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        manté a marca d'ordre de bytes (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de convergência para caracteres\n"
"   modo de convergência: ascii, 7bit, iso, mac (padrão é ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens de alerta\n"
"   tabela de codificação:\n"
"ansi, unicode, utf8, por padrão ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione um caractere de nova linha no final da última linha"
" se não houver"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           força conversió de fitxers binaris nº2\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            hiérnia a assistência deste guia"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do arquivo de texto CỈOlíngua Chinesa (中文) [flags]    Mostra as informações do arquivo em chinês. \n"
"   tập-tin …            các tập tin a analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         mostra a licença do programa em computador/laptops "
"(Hipervisor) usado para execução de scripts e programas no Linux"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem dos Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập-tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "sem permissão para alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona quebra de linha no final do arquivo se o "
"texto original não tiver uma (método padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            conjuntos de dados para converter em o modo do formato de arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave modo silencioso, suprime alertas e avisos não necessários para reduzir"
" a interferência de ruído externo."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apaga o “Byte Order Mark” (por defeito)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga o “Marca de Ordem dos Bits” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            borrar o conjunto de dados divididos em dois (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  de acordo com o link simbólico converte a metade do "
"objetivo."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink trocar o link simbólico por arquivo de destino transformado\n"
"(os diretórios originais não serão modificados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    manté sense canvis els enllaços simbòlics i seus "
"objectius (per defecte)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do programa"

