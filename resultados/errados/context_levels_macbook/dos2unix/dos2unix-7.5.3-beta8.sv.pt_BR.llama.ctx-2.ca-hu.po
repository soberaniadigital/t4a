msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n ficheiro de entrada ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração do acesso ao arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               använd Windows teckentabell 1252 (västeuropeisk)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação DOS 437 (EUA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS850 (página de codificação do sistema operacional) para acessar as "
"opções avançadas."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tecnologia de Codificação do Sistema (DCS) para codificar em "
"base64."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS teckentabell 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS Tabellen 865 (nórdico)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção -b, --keep-bom        manté la marca d'ordem de bytes (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção -b, --keep-bom        preservar byte order mark (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr " -c, --convmode        modo de conversão"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     staja a codificação dos textos mostrados na tela como ansi, unicode ou utf8 (padrão é ansi) \n"
"    Codificações de saída para os arquivos: ansi, unicode, utf8\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma linha em branco após a última linha se "
"nenhuma for encontrada."

msgid " -f, --force           force conversion of binary files\n"
msgstr "Filtragem binária - Force conversion of binary files"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=JELZŐK] mostra a informação do arquivo ... ficheiro(s) para "
"analisar\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar byte ordning (Byte Order Mark) à marca de "
"bytes padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever no novo arquivo (inicial) ficheiro original em modo de texto/arquivo novo\n"
"   entrada               ficheiro original neste formato\n"
"   saída                    Ficheiro de saída em modo de texto/arquivo novo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma nova linha após a última linha se "
"ela já existir (predefinido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreva no arquivo antigo (padrão) \n"
"   ficheiro ...          fitxers para converter em um dos formatos de texto padrão"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           tela em silêncio, suprime os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção para remover marca de byte ordenação (Byte Order Mark) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      suprime a marca d'orderness (Marca de Ordem dos "
"Bits) da linha"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            sair dos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     beholda UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assume que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assume que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utmárias detalhadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink seguejam os links simbólicos e convertemos objetos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzen symbolische links por arquivos convertidos "
"(os originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos e objetos (por padrão) \n"

