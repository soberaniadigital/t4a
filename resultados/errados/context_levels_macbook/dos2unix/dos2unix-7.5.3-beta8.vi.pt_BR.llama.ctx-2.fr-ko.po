msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr ""
"utilize o arquivo temporário %s como ferramenta para acessar os dados de "
"entrada/saída do sistema."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar as permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador ou o grupo de proprietários do arquivo %s não podem ser "
"preservados. Para obter mais informações, tente 'git checkout'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"falha na alteração do proprietário e grupo da pasta temporária de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Problema ao alterar o nome do arquivo para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo deste link simbólico, '%s', é o seguinte."

msgid "          output file remains in '%s'\n"
msgstr "a saída do arquivo de entrada permanece no diretório '%s'."

msgid "Skipping binary file %s\n"
msgstr ""
"falha na verificação: a linha %s possui %d campos (esperado %<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "O arquivo UTF-16 %s, tamanho do wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Fique em silêncio, pois o arquivo UTF-16 %s não pode ser processado. Erro de"
" conversão UTF-16 na linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Ignore o ficheiro UTF-16 %s, a conversão de UTF-16 não é suportada nesta "
"versão do %s. Para obter mais informações, tente '`%s --help`'."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Borracho, este arquivo não é um ficheiro regular. Para obter mais "
"informações sobre o uso desse comando, tente 'git checkout'."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Remova o arquivo %s, ficheiro de saída é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Obrigado, mas não consigo encontrar o arquivo %s. Para obter mais "
"informações sobre como usar este comando, tente 'git checkout'."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Ignore o link simbólico %s, a carga não é um arquivo regular. A carga está "
"ausente."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Fiquei com dificuldade em encontrar o caminho mínimo para a pasta de "
"trabalho. O diretório %s não é um arquivo regular."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Está a converter o arquivo %s para um arquivo no formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo `%s' para um arquivo no formato Mac... (cont.)"

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a fórmula Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Đang chuyển đổi tập tin “%s” thành tập tin “%s” theo định dạng DOS…\n"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um formato DOS... (cont.)"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix %s..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a fórmula de entrada/saída padrão "
"Unix..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato Macintosh (Mac) formatado..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a representação Mac do formato..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato DOS do tipo '%d'..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para a versão DOS do formato..."

msgid "problems converting file %s to file %s\n"
msgstr "Estamos realizando a conversão do arquivo %s para o arquivo %s."

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler o arquivo de entrada %s:"

