msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [arquivo ...] [-n in_ficheiro input.txt]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         tillácia de permissão para alteração do proprietário "
"dos arquivos"

msgid " -ascii                default conversion mode\n"
msgstr "opção para conversão em ASCII - apenas funções de convergência padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e ISO-8859-1 codificação de caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (padrão europeu) para acessar os dados do "
"arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código DOS 437 (USA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (padrão europeu) para acessar os dados do sistema "
"operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS Tabela de Códigos (DOS) em 860 para análise/analisando."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS Tabela de Códigos (DTC) com base em 863, conforme descrito por "
"francês da Suécia. Para obter mais informações sobre a opção `--help`, tente"
" '`%s --help'."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-codetabel 865 (escandinavo) para acessar os dados do sistema "
"operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de sete bits para o padrão binário."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        mantenha o byte order mark (Byte Order Mark) ou "
"marcas de ordem do bitmoji (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        bájtoordnungsmarkering (Byte Order Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteringsläge   ascii, 7bit, iso, mac, padrão é "
"como o ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     kodering para mostrar textos em ansi, unicode ou utf8"
" (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um newline à última linha sem alterar o "
"conteúdo\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"converter binária para texto -f, --force           tvinga konvertendo fájlok"
" átalakítása"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        convertemo UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Visar este texto de ajuda -h, --help            para ver o súgvoltum"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=INFO]   informações sobre o arquivo(s) [%d]"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        preservar o timestamp do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção --license         visa programvarulicensen"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         bájtsorrendjel hozzáadása (alapértelmezetten "
"UTF-8) (standard for UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe para um novo ficheiro\n"
"   infil               origem do ficheiro em formato original\n"
"   utfil              saída de texto no novo ficheiro"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          ikke tilleggte regeleindetekken till siste raden om "
"det ingen (standard)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro ... filtrar o ficheiro original para converter em formato de backup"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silêncio de linha (tysteig) , minden figyelmeztetés "
"elnyomása"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover o byte order mark (BOM) -r, --remove-bom      retirar a "
"marca de ordem dos bytes eltávolítása (Byte Order Mark)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção '-r' ou '--remove-bom', remover marca de byte ordenação (Byte Order "
"Mark) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            hoppar binär filer (standart) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 kódolás megtartása"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le fica acreditado que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be fica a crença de que o formato padrão é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose, -v        utóltságos munkaszerzömbent"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  seguir links simbólicos e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzen symbolische links med convertidas arquivos "
"(originais ficheiros permanecerão inalterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    sybolik linkeket és célok változatlanul hagyása "
"(alapértelmezett)"

