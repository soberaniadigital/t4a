msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite a alteração do proprietário de arquivos \n"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii                modo de conversão padrão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    Conversão de caracteres entre DOS e ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               Utilizando página de código Windows 1252 (Tây Âu) para "
"processamento dos dados."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                Utilizando o código padrão DOS 437 (US) (por "
"definição)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando a página DOS 850 (Tây Ái) do sistema "
"operacional\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando a página DOS 860 (Bồ Đào Nha) para o "
"sistema operacional MS-DOS."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                Utilizando o painel de código DOS 863 (Ca Na Da Fic) "
"para acessar as linhas do arquivo."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                Utilizando página DOS 865 (Baía da Ilha) do sistema "
"operacional MS-DOS."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de kyu t'yo 8 bit para o espaço"
" de 7 bit\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --manter BOM original        manter o Byte Order Mark (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --manter BOM (marca de ordem de bytes padrão)    -m, --mark-byte-order   "
"marca o byte order como sendo a do sistema operacional local."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de conversão de caracteres\n"
"   modo de conversão de caracteres:\n"
"ascii, 7bit, iso, mac, default ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--add-eol   adicione o caractere de nova linha no final da linha se ele não "
"estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           bárbula o processamento de múltiplos arquivos "
"binários\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         변환 UTF-16 한 GB18030으로 수행합니다"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Exibição deste texto de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do arquivo\n"
"   tabela-de-tópicos ...            lista de tabelas para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"-k, --keepdate        giña um arquivo com a data de seu início sem "
"alteração\n"

msgid " -L, --license         display software license\n"
msgstr ""
"-L --license         Exibição do licenciamento para o software em formato de"
" papel"

msgid " -l, --newline         add additional newline\n"
msgstr "-l --novo \\\"linha nova\\\";"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marca de Ordem de Bits’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar a propriedade do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona o caractere de nova linha se ele não "
"estiver presente no final da linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       ghi vào saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gera um backup do arquivo anterior (padrão)\n"
"   tápeis-de-tapas …            lista de tápeis que precisam ser convertidos para o modo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "-q, --quiet           modo silencioso, sem mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      gelo o “Byte Order Mark” (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"-r, --remove-bom      excluir 'Byte Order Mark' (BOM) \n"
"\t(gỡ bỏ BOM para garantir a compatibilidade com diferentes sistemas de codificação)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"-s, --safe            Borra o conteúdo do arquivo dividido em duas partes "
"(padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     giúmar bárbaro UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be coi régando que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "-v, --verbose        exibição detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  링크 움직이기 위해 연결하고 대상을 전송합니다"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay liên kết mềm bằng tập tin đã chuyển đổi\n"
"                   (các tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links macios e objetivos fixos (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostra versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS 16 bit (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Phiên bản DOS 32 bit (DJGPP)."

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de Projeto Windows 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bit (MSVC %d).\n"

msgid "OS/2 version (Watcom C).\n"
msgstr "Phiên bản OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Phiên bản OS/2 (EMX)."

msgid "%s version.\n"
msgstr "%s Fase. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte a codificação Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode. \n"

msgid "With native language support.\n"
msgstr ""
"Não há suporte para a localização baseada em dados do idioma. Para obter "
"mais informações, tente `%s --help'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao uso original do arquivo por indivíduos e grupos "
"proprietários."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e grupo de propriedade do"
" arquivo. \n"

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "%s BOM. Ganhando registro."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "%s tem BOM %s no arquivo de entrada.\n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "'%s' encontra um erro ao interpretar o link macio \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "%s esta sendo utilizado como um arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissão temporária do arquivo de saída %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"%s proprietário do arquivo não pode manter o privilégio de uso original. "
"Acesso restrito."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "%s 임시 출력 파일의 소유자 및 그룹 변경 실패:"

msgid "problems renaming '%s' to '%s':"
msgstr "'%s' nome para '%s'(com ou sem 'e') alterado com erro:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          '%s' é o objetivo de um link macio \"%s\"\n"

msgid "          output file remains in '%s'\n"
msgstr "tápia de saída ainda está presente no arquivo '%s'"

msgid "Skipping binary file %s\n"
msgstr "%s sair do arquivo de dados separado por linhas %d\n"

msgid "code page %d is not supported.\n"
msgstr ""
"Não há suporte para a página de código %d. Por favor, entre em contato com o"
" administrador do sistema."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Baixe o arquivo UTF-16 %s e observe que a capacidade do wchar_t não é de %d "
"bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que apresentou erro ao converter a linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para a versão atual que não suporta "
"conversões de UTF-16. A última versão do programa permite essas "
"alterações.\n"

msgid "Skipping %s, not a regular file.\n"
msgstr "%s sair, aqui não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Bora sair %s, o arquivo de saída é um link curto e interessante. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação fina %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borra este link fino %s, o objetivo dele não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra este link pequeno, porque o destino do seu link curto não é um arquivo"
" comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s para o formato de tabela Unix está em "
"andamento...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo de texto “%s” para a forma Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "A conversão do arquivo '%s' para o formato Mac está em andamento...\n"

msgid "converting file %s to Mac format...\n"
msgstr "A conversão do arquivo `%s` para o formato Mac está em andamento...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo “%s” para o formato de arquivo DOS está em "
"andamento...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato de tabela Unix (tipo %s) está "
"em andamento...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato de Arquivo Macintosh (Mac) "
"está em processo...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato de arquivo DOS é "
"realizada...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "A conversão do arquivo %s “%s” para o formato DOS está em processo...\n"

msgid "problems converting file %s to file %s\n"
msgstr ""
"%s tá em processo de conversão do arquivo %s para o formato de conjunto "
"(set) no tipo %d."

msgid "problems converting file %s\n"
msgstr "%s Encontrado Erro ao converter o arquivo %s\n"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"Olá! O comando 'c%<PRIuMAX> --info' foi utilizado incorretamente. Por favor,"
" verifique as opções disponíveis."

msgid "active code page: %d\n"
msgstr "Página de atividade da tela em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já defini um modo de conversão %s inválido"

msgid "option '%s' requires an argument\n"
msgstr "'%s' opção requer um valor numérico"

msgid "invalid %s display encoding specified\n"
msgstr "Já enviou uma tabela de exibição inválida %s\n"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi definido no modo de criação de novos "
"arquivos"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Cópia de pares inválida. Subpar não foi executado."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cópia de pares inválida. Substituição inadequada acima."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
