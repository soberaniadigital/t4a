msgid "problems resolving symbolic link '%s'\n"
msgstr "gabbilement ao tentar resolver o link simbólico \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo temporário de saída: %s\n"

msgid "using %s as temporary file\n"
msgstr "utilize %s como fichier temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gặp lỗi khi thay đổi quyền hạn của tập tin đầu ra tạm %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e o grupo proprietário do arquivo %s não são preservados. Por "
"favor, verifique as configurações de segurança."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, você precisa ter cuidado ao alterar o proprietário e grupo do "
"arquivo temporário de saída %s."

msgid "problems renaming '%s' to '%s':"
msgstr "Problema ao renomear o arquivo \"%s\" para \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          cái là đích của liên kết mềm “%s”\n"

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída permanece no diretório \"%s\""

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados separados por linhas %s\n"

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para o código de caracteres %d. Por favor, verifique se está "
"utilizando um sistema compatível."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, a dimensão do wchar_t não é de %d bytes. \n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, houve um erro de conversão do formato UTF-16 "
"na linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, a conversão para UTF-16 não é suportada nesta "
"versão do programa. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o %s, aqui não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o item %s, ficheiro de saída %s é um link simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link simbólico %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico %s, pois seu objetivo não é um arquivo regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borrando o link simbólico pequeno %s, ponto final do objetivo desse link mínimo não é um arquivo regular. \n"
"\tOBS.: Ou seja, ele pode ser uma pasta ou outro tipo de referência que normalmente não representaria dados binários."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo \"%s\" no formato "
"Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo `%s` para o arquivo `%s`, no formato "
"Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo “%s” para o arquivo “%s”, no formato "
"DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o arquivo “%s”, no formato "
"Unix…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o arquivo “%s”, no formato "
"Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do ficheiro %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o arquivo “%s” no formato "
"DOS…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, foram encontrados problemas."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "impossible de ler desde o fichier d'entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "cachorro azedo de opção -i ou --info com o símbolo '%c' está errado."

msgid "active code page: %d\n"
msgstr "a tela está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s inválido"

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” requer um argumento\n"

msgid "invalid %s display encoding specified\n"
msgstr ""
"A tabela de exibição apresentada não é compatível com o código %s "
"especificado para a visualização."

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi especificado no modo novo ficheiro"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"erro: Código par inválido. O código de substituição inferior está faltando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: Código par inválido. O código superior não foi especificado."

msgid "has %s BOM.\n"
msgstr "có %s BOM."

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a codificação de caracteres do ambiente "
"linguístico atual não é UTF-8. \n"
