msgstr "utfil para permanecer no \"%s\""

msgid "Skipping binary file %s\n"
msgstr "Hoppar sobre bináriofil %s"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação da integridade do código de linha %d. A sakna stöd för "
"teckentabell %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Passear sobre o arquivo UTF-16 de %s, tamanho dos wchar_t é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Hopping over UTF-16 file %s, a conversion error occurred on line %u. Please "
"check the encoding and try again."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hopamos sobre o arquivo UTF-16 %s, a conversão para UTF-8 não tem suporte "
"nesta versão do programa. A opção '--convert' foi removida em favor da "
"utilização direta de caracteres."

msgid "Skipping %s, not a regular file.\n"
msgstr "Hoppar sobre %s, não é um arquivo comum."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Hoppar sobre %s, utfil %s é um símbolo icônico."

msgid "Skipping symbolic link %s.\n"
msgstr "Hoppar över symbolisk länk %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Hoppar över symbolisk länk %s, målet är inte en vanlig fil."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Hoppa sobre %s, o objeto para o qual a referência simbólica %s aponta não é "
"um arquivo comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "converterá o arquivo %s para o arquivo %s no formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "converteremos o arquivo %s para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "converterá o arquivo %s para o arquivo %s no formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "converteremos o arquivo %s para o formato Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "converterá o arquivo %s para o arquivo %s no formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "converterá o arquivo %s para o formato DOS..."

