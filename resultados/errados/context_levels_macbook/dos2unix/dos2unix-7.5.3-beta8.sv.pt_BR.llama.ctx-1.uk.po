msgstr ""
"DENNA MJUKVARA TILLHANDA HÅLLS AV UPPHOVSRÄTTSINNEHAVAREN I ”BEFINTLIGT "
"SKICK” (AS IS) OCH ANSVAR FÖR UTTRYCKLIGA ELLER UNDERFÖRSTÅDDA, INKLUSIVE "
"MEN INTE BEGRÄNSAT TILL UNDERFÖRSTÅDDA GARANTIER VID KÖP OCH LÄMPLIGHET FÖR "
"ETT VISST ÄNDAMÅL AVVISAS. INT I NÅGONAD FALL SKAL UPPHOVSRÄTTSINNEHAVAREN "
"VARA SKYLDIG UTGE ERSÄTTNING FÖR DIREKT, INDIREKT, OFÖRUTSEDD, SPECIELL, "
"EXEMPLARISK ELLER FÖLJDRELATERAD SKADA (INKLUSIVE MEN INTE BEGRÄNSAT TILL "
"ANSKAFFNING AV ERSÄTTNINGSVAROR OMLYGHET OR DRYCKT JÄSTER; FÖRLUST AV "
"ANVÄNDNING, DATA ELLER FÖRTJÄNST; ELLER AVBROTT I VERKSAMHET) OAVSETT HUR "
"DEN ORSAKATS OCH TEORIER OM ANSVAR, OAVSETT OM KONTRAKT, STRIKT SKYLDIGHET "
"ELLER FÖRSEELSE (INKLUSIVE OKTSAMHET OMLYGHET OR DRYCKT JÄSTER) SOM PÅ NÅGOT"
" SÄTT UPPSTÅTT VID ANVÄNDNING AV DENNA MJUKVARA, ÄVEN OM UNDERRÄTTAD ÖMOHET "
"FÖR EMMIG HEDLATADE SKADA.  "

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Användning: %s [flaggor] [fil …] [-n infil utfil …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         até permitir a mudança de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversores"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o código DOS para a codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a tabela de codificação do Windows 1252 "
"(língua europeia)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tabela de códigos DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a tabela de caracteres DOS 850 (línguas do "
"Reino Unido)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"-860                utilizar a tabela de sinalização DOS 860 (portuguesa)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a tabela de sinalização DOS 863 (franco-"
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865 utilizar a tabela DOS 865 (nordeste)   -865 utilizar a tabela DOS 865 "
"(nordeste)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de 8 bits para o espaço em "
"branco de 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --keep-bom        preservar a marcação de ordem dos bytes (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preservar a marcação do byte (marca de ordem dos "
"bytes) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão \n"
"   modo de conversão    ASCII, BITS(7), ISO, MAC, padrão é ASCII\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     instale a codificação dos textos visuais, ansi, "
"unicode ou utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar uma quebra de linha no final da última "
"linha se ela não existir\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           tvinga konvertering av binära filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030        converterá UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            visar denna hjälptext"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] mostrar informações sobre o arquivo \n"
"   ficheiro ...\n"
" filer para analisar."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        beholda datum för utmatningsfilen\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         visa licença para o programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicionar caracter de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione marcador de ordem dos bytes (Byte Order "
"Mark) (padrão para UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever para um novo arquivo\n"
"   início               original em uma nova pasta de trabalho\n"
"   saída                salvar no novo arquivo na pasta de trabalho"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      até não permitir a alteração do proprietário de "
"arquivo (comportamento padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem-adicao-eol          não adicionar quebra de linha no final da última "
"linha, se ela não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever para o arquivo antigo (padrão) \n"
"   file …               os arquivos que devem ser convertidos em versões antigas"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, não exibir mensagens nem avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      remover marcação de ordem dos bytes (Byte Order Mark)"
" (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"-r --remove-bom      remover marca de ordem dos bytes (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --safe            saltar sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 encoding"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le para supor que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        modo detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  seguir links simbólicos e converter módulos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui símbolos de ligação por referências a arquivos convertidos\n"
"                         (arquivos originais permanecerão inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar símbolos de ligação e objetivos não "
"modificados (tipicamente)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostrar versões do software (número de versão)"

