msgid "converting %s file %s to %s DOS format...\n"
msgstr "converteremos o arquivo %s para o formato DOS..."

msgid "problems converting file %s to file %s\n"
msgstr "fel vid konvertering från fil %s till fil %s\n"

msgid "problems converting file %s\n"
msgstr ""
"fel vídeo converter do arquivo %s, durante o processamento foram encontradas"
" problemas."

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "falha no reconhecimento do flagga '%c' para o argumento -i ou --info\n"

msgid "active code page: %d\n"
msgstr "активна кодова сторінка: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "vocação inválida para o modo de conversão %s indicado"

msgid "option '%s' requires an argument\n"
msgstr "o argumento para o parâmetro \"%s\" é necessário."

msgid "invalid %s display encoding specified\n"
msgstr "ogitig código %s-kodning angiven"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo para o arquivo %s não foi especificado em nenhuma das listas de "
"arquivos disponíveis para criação"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler os dados do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever para arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na verificação: a parcela de surrogado é incorreta. A parte inferior "
"do conjunto está ausente."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha de surrogado: parceiro não corretamente colocado. O superior conjunto "
"do parceiro está ausente."
