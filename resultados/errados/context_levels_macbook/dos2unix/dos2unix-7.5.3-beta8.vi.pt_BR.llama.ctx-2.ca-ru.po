msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivo …] [-n arquivo de entrada ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite a mudança de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modo -ascii chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converte DOS para ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar codificação DOS 437 (EUA) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar codificação DOS 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preservar a marca de ordem dos bytes (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        giữ nguyên “Byte Order Mark” (mặc định)\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ascii, 7bit, iso, mac, padrão é"
" comoçais"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"bảng mã:\tanpHYP, ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não houver"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           força conversió de ficheiros binários em formato "
"nativo para formatos compatíveis com o sistema operacional\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "opção --help            Mostrar ajuda para este comando."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informação do arquivo de entrada\n"
"   ficheiro ...            Ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra licença do programa\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a marca de ordem de bytes (por padrão em "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever no novo arquivo\n"
"   tabela de entrada    ficheiro original em modo novo arquivo\n"
"   saída do arquivo     ficheiro de saída em modo novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite alterar a propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona um salto de linha no final da última "
"linha se ele não existir (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão) \n"
"   ficheiro ...            dos fitxers a converter para o formato do arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção '-r', '--remove-bom'      apagar a marca de ordem dos bytes (BOM) "
"padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar a marca de ordem de bytes (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            esqueça o conjunto de linhas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink para seguir links simbólicos e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os links simbólicos por arquivos reais "
"(originais dos arquivos não serão alterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha as ligações simbólicas e os objetivos (por "
"padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha técnica do DOS de 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de versão para DOS, 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do DOS Versão para Windows 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do DOS Versão para 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Fenome do MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Ficheiro não encontrado."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows para sistemas de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome do Windows 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows para x86 (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha técnica do Windows de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de Versão para Windows (64 bits) do Visual Studio Code %d."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de Versão para Windows (32 bits) do Visual Studio Code %d."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro não encontrado."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro de origem %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Suporte ao nome do arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte ao nome do arquivo Unicode."

msgid "With native language support.\n"
msgstr "Não foi possível obter estado (stat) do arquivo %s."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao proprietário e às pessoas pertencentes a um grupo de "
"arquivos."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para a preservação do proprietário e da propriedade de grupo "
"dos arquivos."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Está a escrever %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s contém BOM. (Assuming 'BOM' refers to Byte Order "
"Mark and '%s' is a placeholder for the filename, while '%d' represents an "
"integer value.)"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Assumindo a codificação UTF-16LE. \n"

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Assumindo a codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "gặp lỗi khi phân giải liên kết mềm “%s”\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na alteração dos permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e a equipe de propriedade do arquivo %s não podem ser preservados."
" Para obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e agrupamento do arquivo de saída temporário "
"%s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao renomear o arquivo \"%s\" para \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo desta ligação simbólica é o %s."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está no local do “%s”."

msgid "Skipping binary file %s\n"
msgstr "Remover o arquivo de dados binários %s"

msgid "code page %d is not supported.\n"
msgstr "A página de código %d não é suportada."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "O arquivo UTF-16 %s, o tamanho do wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"O arquivo UTF-16 %s, causou um erro ao converter o UTF-16 na linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, converta para UTF-8 não é suportado nesta versão "
"do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Remova o arquivo %s, pois ele não é um ficheiro normal. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, ficheiro de saída inicial %s é um link simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Remova a associação simbólica mínima %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Ocorreu um erro ao tentar abrir a ligação simbólica %s, o destino não é um "
"arquivo normal."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu erro ao criar a ligação simbólica mínima %s, alvo da mesma não é um "
"arquivo regular. Para obter mais informações sobre como utilizá-la "
"corretamente, tente '`%s --help`'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato do sistema de ficheiros "
"Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Estão a converter o arquivo de texto `%s' para um formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Estão convertendo o arquivo de texto `%s' para um arquivo no formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Estão a converter o arquivo de texto `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Estão convertendo o arquivo de texto `%s' para um arquivo no formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "Estão convertendo o arquivo de texto “%s” para formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estão convertendo o arquivo de texto '%s' para o formato Unix %s..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estão convertendo o arquivo %s “%s” para o formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estão convertendo o arquivo de texto %s para o formato Macintosh... (arquivo"
" %s)"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estão convertendo o arquivo %s “%s” para o formato Mac %s...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estão convertendo o arquivo de texto %s para um arquivo no formato DOS... "
"(arquivo %s)"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estão convertendo o arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr "Fazendo o conversor de arquivos %s para %s\n"

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s\n"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "falha na verificação da opção -i ou --info; senalizador incorreto \"%c\"."

msgid "active code page: %d\n"
msgstr "página de código em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s, que não é válido."

msgid "option '%s' requires an argument\n"
msgstr "Para o parâmetro \"%s\" é necessário um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi especificado no modo de arquivo novo\n"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"erro de sintaxe inválida. Ocorreu um erro ao substituir o parâmetro "
"inferior."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: parceiro suplente inválido. Faltando um grande substituto."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
