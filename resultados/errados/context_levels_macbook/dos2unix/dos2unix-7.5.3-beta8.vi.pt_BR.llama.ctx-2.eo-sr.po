msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cóprocódio de uso: %s [seleções] [bancos ...] [-n banco-de-chaves-e-valores-"
"para-o-banco-de-entrada ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown permissão para alterar proprietário do diretório de arquivos"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento de caracteres padrão\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converte o sinal de interlingua entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando o trângulo de Windows 1252 (Tây Âu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando o sistema de codificação DOS 437 (EUA) "
"(padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"-850                utilizando o trângulo de memória DOS 850 (Tây Ái) do "
"Vietnã"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"-860                utilizando trânsferência de dados DOS para a codificação"
" da página 860 (do Brasil)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizando trânsferência de dados DOS na página 863 "
"(Cingapura) do sistema operacional"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizando o sistema de arquivos DOS para a página com "
"código 865 (Bacia do Danúbio)   -865        utilizando trânsito mãe dos "
"sistemas operacionais DOS para a página com código 865 (Nordland)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os ký týpu 8 bit para 7 bit\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom         reteni bajtordo-markon\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantém o “Byte Order Mark” (mantendo a ordem de bits)"
" (defaul)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chéfe de modo conversão\n"
"   chéfe de modo conversão:   ascii, 7bit, iso, mac, mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir codificação para apresentar mensagens na tela\n"
"   codificações disponíveis: 'ansi', 'unicode', 'utf8', por padrão é 'ansi'"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add_eol   adiciona um caractere de nova linha no final da linha se "
"não houver nenhum em excesso."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           força a conversão de arquivos com dados hexadecimais "
"separados por linhas"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16032          converte UTF-16 para GB18032"

msgid " -h, --help            display this help text\n"
msgstr ""
"hi o uso deste comando de ajuda -h, --help para obter mais informações sobre"
" como utilizar este programa."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do táp-tin\n"
"   nome_do_tap-tin ...            os nomes dos tap-tins que precisam de análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "hiển thị giấy phép dùng phần mềm"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona novo recuo\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar ‘Marca de Ordem da Bits’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập-tin-mới\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"EO --no-add-eol          não adiciona um caractere de nova linha no final da"
" linha se ele não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       ghi vào saída padrão tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập-tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chée ô modo silencioso, cai mói barreira de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      apagar o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            borrar linhas do arquivo (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     conservasse bdng mã UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le coi régulo dizendo que o formato de entrada óbjeto "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na hipótese de que o formato do carimbo é "
"UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        relatar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   sekvi liên kết mềm và chuyển đổi đích."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca simbolikan ligojn por tipej de dosieroj "
"convertitaj (dosiero ne alŝanĝiĝas) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links macios e objetivos fixos (padrão)"

