msgstr ""
"Olá! Aqui está a tradução para o portugu0lso do trecho fornecido em inglês, "
"observando as restrições e formatos solicitados. Por favor, note que os "
"acentos foram mantidos onde necessário:"

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n entrada_arquivo saída_arquivo]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                standardkonverteringsläge\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               använd Windows teckentabell 1252 (västeuropeisk)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Code Page 437 (padrão) para Windows."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS 850 (codificação do padrão europeu) para acessar este documento."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS 860 (português) para verificar se a linha %<PRIuMAX> possui "
"%<PRIuMAX> campos (esperado %<PRIuMAX>)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS 863 (codificação em francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS 865 (nordisk) para codificação de caracteres."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        保留位元組順序記號 (BOM) "

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        保留位元組順序記號 (BOM) (預設值)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        átalakítási mód   ascii, 7bit, iso, mac, standard é "
"ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     kódar a szöveget megjelenítések módszerében: ansi, "
"unicode, utf8, alapértelmeztetés szerint (default) \n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma quebra de linha após a última coluna se "
"nenhuma for encontrada."

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           forçar a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help             visualizar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformation\n"
"   ficheiro ...             para analisar o arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate         preservar o tempo de criação do arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa programvarulicensen"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção --add-bom         adicionar byte ordningsteknik (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile         escrever em um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          Não adicione uma linha de quebra em última coluna se "
"não houver nenhum (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile         escrever no arquivo antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"opção silenciosa -q, --quiet            modo de linha tátil, ocultar todas "
"as mensagens"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover o byte order mark (BOM) -r, --remove-bom       Elimina a "
"marca de ordem dos bytes (Byte Order Mark)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom       remover marca de byte order mark (BOM) do "
"arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe             binárias de bits (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     utilizar UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le ficação que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be pressou que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utseret"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetze symbolische links com versões convertidas dos"
" arquivos (os originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    behåll symboliska länkar och mål oförändrade "
"(standard) \n"

