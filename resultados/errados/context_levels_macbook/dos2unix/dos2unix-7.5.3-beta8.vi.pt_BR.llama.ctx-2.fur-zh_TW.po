msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilização: %s [opções] [arquivos ...] [-n entrada_arq.out saída_arq.]"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão -iso entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação de caracteres Windows 1252 "
"(Tây Dân Viên) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizando codificação DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar código DOS 863 (Codificação Canadês francês)"
" \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utilizar código de página DOS 865 (Nordic) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte i caracteres de 8 bits para o espaço de 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém o sinal do Byte Order Mark (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        manten segn do Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de converção para chaves de "
"caracteres"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define o mapeamento de mensagens para exibir os "
"avisos em diferentes codificações. Blocos de código possíveis: ansi, "
"unicode, utf8 (padrão é ansi)."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"coluna se não houver nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocar conversão dos arquivos binários em formato de "
"ficheiro"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda nesta ação de teste do peito\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações do arquivo de texto [file ...] para análise dos campos\n"
"    Arquivo(s) ...            os campos a serem analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        manten a data original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostre licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem do Byte” (byte order mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo\n"
"   entrada de origem         arquivo original no modo de escrita nova\n"
"   saída para o arquivo     arquivo gerado no modo de escrita nova"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown       não permite a alteração de proprietário do "
"arquivo (valor padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dónde no final se o último caractere da "
"coluna não tiver um delimitador de linha (valor padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no padrão de saída"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          carregar arquivo antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave de silêncio -q, --quiet           modo silencioso, ocultando todos os "
"avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o sinal de byte order mark (byte order mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte i file binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo o formato de entrada como UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin dịch lên các tập tin nguyên gốc, vào trong sự thay đổi) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos e destino invariáveis "
"(padrão)"

