msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando 'grep' para encontrar e exibir as linhas que contêm a "
"palavra chave `error` em um arquivo de log. Se você não souber como usar "
"este comando, consulte: %s"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre os conjuntos de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows-1252 (codificação do padrão europeu) para acessar este "
"documento."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use -437 para usar o código DOS 437 (US) como padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS-850 (codificação Tây Árabe) para acessar este documento."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS-860 (Português) para acessar as opções de formatação do sistema "
"operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use -863 para utilizar o tráfego de dados entre sistemas operacionais (DOS) "
"com base no protocolo DOS/863, que é um padrão internacionalmente "
"reconhecido e amplamente adotado. Este método permite a transferência segura"
" e confiável dos dados em rede sem interrupções."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Baixo/Norte) para acessar as informações de status do sistema "
"operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de letras para o sistema binário em 8 bits "
"a um formato de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantenha o byte order mark (BOM) na saída de texto"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantenha o byte order mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de conversão:   modeo ASCII,"
" 7bit, ISO, MAC, mặc định là ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para exibir os avisos\n"
"   Codificação da tela de mensagens:\n"
"    básica (ansi), unicode, utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar um dógrau de nova linha no final caso não "
"esteja presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn -f, --force           preservação de dados binários afastar"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          convertem para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO]        mostra informações sobre o arquivo ...         "
"cargas de dados para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr "Keep date of output file (--keepdate)"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         licenças tonê"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"adicionar o Byte Order Mark (BOM) -m, --add-bom         adicione um byte "
"order mark (mínimo UTFA)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tape nao criar um novo arquivo em modo de escrita. "
"Escrever no mesmo arquivo que está sendo lido."

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona um caractere de nova linha no final se "
"não houver nada para inserir (padrão)\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais -O, --to-stdout       escrever no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi ou editar o arquivo antigo (padrão) \n"
"   táp-tin ... các tập tin cần chuyển đổi trong chế độ táp-tin khác"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, suprimindo avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção '-r' ou '--remove-bom', que remove o Byte Order Mark (BOM) padrão, se "
"necessário."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção -r, --remove-bom      apagar o byte order mark (BOM) do arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            apagar linha de entrada (máximo)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conservando codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rão de que o formato do dado de entrada é "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção -F, --follow-symlink   seguir links simbólicos convertem"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay tập tin mềm bặn symbolike của chúng tôi (các tập"
" tin dự tiết kiệt không thay đổi) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    ignorar links simbólicas e diretório (método padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         hiển thị số hiệu phiên bản\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr ""
"Ficha de referência do sistema operacional DOS em versão 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de DOS em 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr ""
"Ficha de referência do sistema operacional DOS em versão DOSBox (Watcom C)."

