msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando 'grep' para encontrar e exibir as linhas que contêm a "
"palavra chave `error` em um arquivo de log. Se você não tiver certeza do "
"conteúdo, use '-v' opcionalmente."

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         erlaubt die Änderung des Dateieigentümers (acesso ao "
"proprietário do arquivo)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                standardkonverteringsläge\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e ISO-8859-1 codificação de caracteres."

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "uso o Windows Codepage 1252 (vesteuropeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                usa DOS Codepage 437 (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o CodePage 850 (padrão europeu) para DOS."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Codepage 860 (português) para acessar os dados do sistema "
"operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS Codepage 863 (français canadien) para acessar os dados de "
"saída/entrada."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS Codepage 865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converterá os caracteres de sete bits para o espaço em branco do séquito "
"binário."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        mantém a ordem de bytes (Marca da Ordem dos Bits)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        mantém a marca de byte order mark (byte order mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        convertemoda   ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     selecionar a codificação para as mensagens de erro mostradas\n"
"   kodning             'ansi', 'unicode', of 'utf8' (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione um retorno de carro em uma nova linha ao "
"final da última linha se necessário\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Opção -f, --force           força a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr ""
"Visar este texto de ajuda -h, --help            para obter esta ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] mostra informações de arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        mantém o timestamp da saída do arquivo"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         mostra a licença do software."

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adiciona um caractere de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         adicionar uma marca de ordem byte (Byte Order "
"Mark) para UTF-8\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe naar een nieuw bestand schrijven\n"
"   INPUT_FILE        de originele bestand in nieuwe-bestand-modus\n"
"   OUTPUT_FILE       het geconverteerde bestand in nieuwe-bestand-modus"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          ikke tilføje en radbrytning på sidan siden (standard)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreve o arquivo antigo (padrão) \n"
"    fil ...                   os arquivos para converter em formato de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todas as warnings"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      remove a marca de byte order mark (Byte Order "
"Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção '-r' ou '--remove-bom', remove a marca de byte order mark (BOM) do "
"arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     beholda UTF-16 codificação de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presume que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        ausführliche Ausgabe"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink folheia symbolicas e converte os caminhos para seus "
"nomes originais."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(as originais permanecem inalterados) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    permite que symbolische ligas e seus alvos sejam "
"ignorados (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão"

