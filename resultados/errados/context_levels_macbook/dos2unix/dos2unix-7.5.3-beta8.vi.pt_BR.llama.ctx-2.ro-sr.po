msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [-n diretório_de_entrada diretório_de_saída ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown permite o queixar a propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modulo de conversão -ascii                chave implicita"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilizează pagina de codificação Windows 1252 (Europa do Sul) para o seu "
"sistema operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "utilizează pagina de cod DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "utilizează pagina de cod DOS 850 (Europa de Vest)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "utilizează pagina de cod DOS 860 (Portugal)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "utilizează pagina de cod DOS 863 (França Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"utilizează pagina de cod DOS 865 (Brasil) para o sistema operacional "
"Windows."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits em um formato de 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preserva o byte order mark (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preserva o “Byte Order Mark” (BOM) padrão\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de conversão ASCII, 7bit, "
"ISO, MAC, mặc định là ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adiciona o código de caracteres utilizado para a "
"exibição do logotipo da mensagem\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final da última linha, se não houver "
"nenhuma atualmente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "forçar, --force           parafusă de dánya"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo ...   cadeia de "
"texto para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        preserva o dia da data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr "opção -L, --license         afiça a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marcação de ordem (BOM) UTF-8 implicitamente"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile          escreva no novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (implicit)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dáilha no final da linha, se nenhum "
"delimitador de linha (dấu ngắt) for encontrado."

msgid " -O, --to-stdout       write to standard output\n"
msgstr ""
" -O, --to-stdout       escreva no stdout o resultado da análise/analisando "
"do arquivo %s"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập tin ...        các tập tin cần chuyển đổi trong chế độ tập tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, suprimir todas as avisões "
"audíveis"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "eliminar o byte order mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "eliminar o byte order mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            remover linha de entrada (máximo)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva o UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le presupõe-se que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        anuncia informações detalhadas sobre as operações "
"realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink theo liên kết mềm và chuyển đổi đích\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bặn của tập tin chuyển đổi (các"
" tập tin gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações simbólicas e links de meio curto"
" (padrão) \n"

