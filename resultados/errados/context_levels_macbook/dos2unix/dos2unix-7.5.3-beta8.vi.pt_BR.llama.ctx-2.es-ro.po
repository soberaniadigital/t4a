msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "CÓDIGO DE EXITORES PARA ACESSO ESTÁTICO (GNU Make) - GNUmake.org"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown permite o chaveamento de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão implícita"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilize a página de codificação Windows 1252 (Europa Oriental) para o seu "
"projeto."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "utilizează pagina de codigos DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"utilize a página de código DOS 850 (Europa Oriental) para o seu projeto."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilizează pagina de codigo DOS 860 (Português)   -860                "
"utilize a página de código do sistema operacional DOS 860 (Português)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "utilizează pagina de codigo DOS 863 (Francês Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"utilize a página de código DOS 865 (Brasil) do Windows para o seu "
"computador."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de 8 bits para o espaço de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção -b, --keep-bom        conserva a marca de ordem dos bytes (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom         conserva a marca de ordem do byte (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   chave ASCII, 7bit, ISO, MAC, "
"por defeito é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      define a codificação de mensagens para o display "
"(ansi, unicode, utf8) [default to ansi]"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma linha de terminação à última se não houver nenhuma presente, "
"caso contrário ocorre um erro."

msgid " -f, --force           force conversion of binary files\n"
msgstr "forçar a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo ...   c/códigos de"
" erro"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva a data de criação do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar a Marca de Orden do Byte (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva em um novo arquivo\n"
"   t_input      ficheiro original no modo de entrada do arquivo\n"
"   t_output     ficheiro gerado no modo de saída"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      không cho phép thay đổi chủ sở hữu tập tin (mặt trọng "
"lượng)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dáfine na última linha se não houver um"
" (implicit) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva o resultado na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"   ficheiro ...         os arquivos para converter neste modo de arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, suprime todas as advertências"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "elimina o Byte Order Mark (BOM) padrão por omissão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "elimina a marca de ordem dos bytes (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignora arquivos binários (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le supõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        anuncia informações detalhadas sobre as operações "
"realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink segue os links simbólicos e converte o destino"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bặn tập tin chuyển đổi (các tập"
" tin dựa trải nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações simbólicas e seus destinos (por "
"padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         despliega o número da versão"

