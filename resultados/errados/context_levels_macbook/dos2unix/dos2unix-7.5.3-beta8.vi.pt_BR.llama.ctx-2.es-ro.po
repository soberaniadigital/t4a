msgid "Skipping binary file %s\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Se o arquivo UTF-16 %s, tamanho do wchar_t não é igual a %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr "Ocorreu um erro ao converter UTF-16 %s, na linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Se o arquivo UTF-16 %s for ignorado, a conversão para UTF-16 não é suportada"
" nesta versão do programa."

msgid "Skipping %s, not a regular file.\n"
msgstr "Se omite %s, neste arquivo não é um ficheiro regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo de entrada %s, que é um link simbólico. O caminho do "
"diretório '%s' não pode ser encontrado."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Obrigado, mas não consigo encontrar o arquivo %s. Para obter mais "
"informações sobre como usar este comando, tente 'git checkout' para "
"verificar se você está no diretório correto."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Se o enlace simbólico %s não for especificado, este é um arquivo regular. "
"Aqui está uma lista de comandos para verificar se ele foi criptografado."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Se ocorreu um erro ao tentar abrir a ligação simbólica %s, isso não é uma "
"pasta regular. A causa pode ser que você tenha digitado erroneamente seu "
"caminho de entrada ou saída."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Unix...\n"

