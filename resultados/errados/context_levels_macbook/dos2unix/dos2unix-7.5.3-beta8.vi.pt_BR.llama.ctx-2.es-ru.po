msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivo(s) …] [-n arquivo_de_entrada "
"arquivo_de_saída ...]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         разрешить смену владельца файла"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo ASCII padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar codificação DOS 437 (US) (por padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizar codificação DOS 860 (Bồng Trai)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar codificação DOS 863 (Francocanadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte caracteres de 8 bits para espaço de 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conserva a Marca de Orden del Byte (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom         conserva a Marca de Orden del Byte (BOM), padrão por"
" defeito"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ascii, 7bit, iso, mac, por "
"padrão é o modo ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de exibição para apresentar mensagens textuais\n"
"   código de codificação:\n"
"ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final se não houver, usando o parâmetro -e "
"ou --add-eol."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar a conversão de arquivos binários em formato "
"nível de linha"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "opção --help            Mostrar ajuda para este comando."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CPF]        exibe informações do arquivo CPF\n"
"   ficheiro ...            ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione separador de linha adicional"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a Marca de Orden do Byte (por padrão em "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva em um novo arquivo\n"
"   tabela de entrada no modo do novo arquivo\n"
"   tabela de saída no modo do novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a mudança de proprietário do arquivo"
" (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"opção --no-add-eol          não adicionar dógrafo no final da linha, se ele "
"não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (por padrão) \n"
"   ficheiro ...            os ficheiros a converter para o modo de ficheiro antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, suprime todas as avisões\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção --remove-bom      apagar a Marca de Orden del Byte (BOM) padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção --remove-bom      apagar a Marca de Orden del Byte, BOM (Byte Order "
"Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignora arquivos binários (por defeito)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantém a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le supõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be supõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  seguir links simbólicos e converter o destino"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os links simbólicos por arquivos "
"convertidos (arquivos originais não são alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha as ligações simbólicas e destinos sem "
"alterações (por padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         exibe o número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro de versão para DOS, 16 bits (WATCOMC).\n"

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica do DOS de 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficheiro de versão para DOS, 32 bits (WATCOMC).\n"

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome DOS de 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Fenome do MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Fenome do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha técnica do Windows de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha de versão para Windows, 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows de 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro não encontrado."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro não encontrado."

msgid "%s version.\n"
msgstr "Ficha de modelo %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "O suporte ao nome do arquivo em Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos em Unicode UTF-16."

msgid "With native language support.\n"
msgstr "Não foi possível obter estado (stat) do arquivo %s."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como suporte ao proprietário e grupo de propriedade do arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o proprietário e grupo do arquivo. Para obter mais "
"informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Está gravando BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s possui BOM %s. Para obter mais informações, tente "
"`%s --help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de codificação é UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação é UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "gặp lỗi khi phân giải liên kết mềm “%s”\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na alteração dos permisos do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e a equipe de proprietários do arquivo %s não conseguem manter o "
"direito exclusivo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "falha ao renomear o arquivo %s para %s:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo deste link simbólico '%s' é mínimo."

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída permanece em '%s'."

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo binário %s"

msgid "code page %d is not supported.\n"
msgstr "A página de códigos %d não é suportada."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "O arquivo UTF-16 %s, o tamanho do wchar_t não é igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão de UTF-16 do arquivo %s, ocorreu um erro ao converter "
"para UTF-16 no dado da linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, conversão para UTF-16 não é suportada nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o arquivo %s, isso não é um ficheiro regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico. O arquivo de saída inicial %s "
"é muito pequeno."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação simbólica %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a ligação mínima %s, o objetivo dela não é um arquivo regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu erro ao remover o link curto %s, alvo do link curto %s não é um "
"arquivo regular. Por favor, verifique se você digitou corretamente."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Fazendo o conversor de arquivo %s para tabela `%s` no formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo o conversor de arquivo “%s” para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo o conversor de arquivo para Mac...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo o conversor de arquivo para Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo o conversor de arquivo para um novo diretório..."

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo o conversor de arquivo do tipo DOS para %s...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Fazendo o conversor de arquivo %s para um arquivo no formato Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo o conversor de arquivo %s “%s” para formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato de texto plano (Plain "
"Text)..."

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "cờ “%c” cho tùy chọn -i hay --info bị sai\n"

msgid "active code page: %d\n"
msgstr "Página de códigos ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falha na conversão do %s para o modo de codificação especificado é inválido."

msgid "option '%s' requires an argument\n"
msgstr "Para o parâmetro \"%s\" é necessário um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na análise de entrada (%s): o modo %<PRIuMAX> especificado não é "
"válido."

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi definido no modo de novo arquivo\n"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Parceiros substitutos inválidos. Falta parceiro inferior."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: parâmetro inválido. O valor do argumento não é válido."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"
