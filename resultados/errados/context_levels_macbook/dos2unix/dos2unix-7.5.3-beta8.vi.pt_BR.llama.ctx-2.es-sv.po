msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "CÓDIGO DE FALHA ENCONTRADO"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows Code Page 1252 (Tây Árabe) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utiliza o código de códigos DOS 437 (EUA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS850 (Tây Árabe) para acessar as linhas de dados do arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS860 (Português Brasileiro) para acessar as opções de "
"codificação do sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS863 (Ca Na Dafe) para acessar as opções de codificação do "
"sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Utilize o DOS865 (Nórdico) para acessar as pastas de trabalho."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de entrada para o espaço dos bits ao menos."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conserva a Marca de Orden do Byte (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        conserva a Marca de Orden do Byte (Byte Order Mark), "
"BOM (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão: modo de converção ASCII, 7bit, "
"ISO e MAC por defeito é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      define a codificação de exibição para mensagens em "
"texto que seja ansi/unicode/utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção --add-eol   adicionar dado ao final da linha se não houver nenhum "
"antes de sair\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de conversão dos arquivos binários -f, --force           forçar a "
"convergência dos campos"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỜ]        exibe informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva a data de origem do arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a Marca de Orden do Byte (BOM) padrão para "
"UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      không cho phép thay đổi chủ sở hữu tập tin (mặt trọng "
"lượng)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dado ao final da linha se nenhum "
"delimitador de linha (padrão) estiver presente\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"    Arquivos para converter em formato de arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todas as advertências"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apaga a Marca de Orden do Byte (byte order mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      elimina a Marca de Orden do Byte (Byte Order "
"Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignora arquivos binários (por defeito)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva o código UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rá que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rá que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay từ mềm bằng tập tin chuyển đổi (các tập tin dựa "
"trải không thay đổi) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"skip_symlink -m, --skip-symlink    ignorar links simbólicos e seus destinos "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS em 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de versão DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS de 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha de versão DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha de versão do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha de versão do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows de 32 bits (WATCOMC)"

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha de referência do Windows em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha de versão Windows para sistemas de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows de 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de testeio para %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "O suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hora de apoio Unicode.UTF-16."

msgid "Without Unicode file name support.\n"
msgstr ""
"Não há suporte para o nome do arquivo Unicode. Para obter mais informações, "
"tente `%s --help'."

msgid "With native language support.\n"
msgstr ""
"Olá! O sistema não consegue encontrar o caminho para a pasta de trabalho. "
"Por favor, verifique se você digitou corretamente seu diretório e tente "
"novamente."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o usuário e grupo de proprietários do arquivo. Para "
"obter mais informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gerindo o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr ""
"Foi assumido que o código UTF-16LE é utilizado. Para obter mais informações,"
" tente `%s --help'."

msgid "Assuming UTF-16BE encoding.\n"
msgstr ""
"Foi assumido que o código UTF-16BE é utilizado. Para obter mais informações,"
" tente `%s --help'."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"falha na verificação da ligação simbólica '%s' possui %<PRIuMAX> campos "
"(esperado %<PRIuMAX>)"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como arquivo temporal."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar os permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O arquivo de texto %s permanece não sincronizado. Acessar o terminal para "
"verificar se ele está disponível."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o destino do enlace simbólico '%s' é o caminho para a pasta de trabalho."

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr ""
"Falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)."

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Falha na verificação da entrada UTF-16 %s, o tamanho do wchar_t não é igual "
"a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão de UTF-16 no arquivo %s, ocorreu um erro ao converter "
"para UTF-16 na linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho, não é um arquivo regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"O arquivo de entrada %s é um link simbólico. O tamanho do caminho para o "
"diretório raiz '%d' não pode ser determinado."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"O enlace simbólico %s não é um arquivo regular. O seu destino deve ser uma "
"pasta."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Olá! O objetivo do link simbólico %s não é um arquivo regular. Para obter "
"mais informações, tente 'git checkout'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo de entrada “%s” para formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um arquivo DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para um arquivo no formato Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a representação Unix de formato %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato Mac, mas falhou. Por favor, "
"verifique se você digitou a opção correta."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s para a versão Macintosh (DOS)…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para um arquivo no formato DOS... (cont.)"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Đang chuyển đổi tập tin %s “%s” sang định dạng DOS %s…\n"

msgid "problems converting file %s to file %s\n"
msgstr "Estamos convertendo o arquivo %s para tátil."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação da opção '%s' -i ou --info; não é um valor válido."

msgid "active code page: %d\n"
msgstr "A tarefa está em execu endouro: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s não é válida."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não é possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro de sintaxe inválida. O parâmetro '--help' não é válido."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"erro: O parâmetro de substituição não é válido. Falta o valor do alto."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
