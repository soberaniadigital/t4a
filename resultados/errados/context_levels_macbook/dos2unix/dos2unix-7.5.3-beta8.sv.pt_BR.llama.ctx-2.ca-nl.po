msgid " -ascii                default conversion mode\n"
msgstr "opção ASCII -modo padrão de conversão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Use o Windows Code Page 1252 (padrão europeu ocidental)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Codepage 437 (EUA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (padrão europeu ocidental) para acessar os dados do "
"arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS Tabellen 860 (português) para acessar as opções do sistema."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS-codetabel 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-codetabel 865 (nórdico)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de 8 bits para o padrão de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        manter a marca d'ordem de bytes (Marca de Ordem dos "
"Bits)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção -b, --keep-bom        manté a marca d'ordem de bytes (Byte Order Mark)"
" (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão   ascii, 7bit, iso ou mac, padrão é"
" 'ascii'."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     selecione a codificació dels missatges mostrats "
"'ansi', 'unicode' o 'utf8', por padrão ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione um caractere de nova linha à última linha se"
" não houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"converter de ficheiros binários -f, --force           força conversão de "
"arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para ver este texto de ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] mostra a informação do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção -k, --keepdate        mantenha a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license mostra a licença do programa."

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         adicionar a marca d'ordem de bytes (marca BOM)"
" para UTF-8 padrão"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever em um novo arquivo\n"
"   origemfil    ficheiro original no modo de entrada\n"
"   saidafil     Ficheiro de saída em formato binário"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"Lembrem-se de que o uso do parâmetro `--no-add-eol` não adiciona um "
"caractere nulo à linha final se ele já estiver presente. Para obter mais "
"informações, tente `%s --help'."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreva no ficheiro antigo (padrão) \n"
"   Ficheiro ...          converter os arquivos para o formato de texto plano"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           silencioso, suprime os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover a marca de byte order mark (BOM) -r, --remove-bom      "
"suprime la marca d'ordernament bytes (Byte Order Mark)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover a marca de byte order mark (BOM) -r, --remove-bom      "
"suprime a marca d'ordem dos bytes"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            sair sobre os arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     beholda UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assume que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assume que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        realiza o fluxo detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink segueix els enllaços simbòlics i converteix les "
"obxectius."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
