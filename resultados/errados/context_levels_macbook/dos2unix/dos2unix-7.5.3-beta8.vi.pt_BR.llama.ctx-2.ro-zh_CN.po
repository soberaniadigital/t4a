msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alteração do proprietário da pasta de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii - chave de conversão padrão para texto simples."

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converte entre o conjunto de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilize a página de código Windows 1252 (Tây Dương)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilize a página de código DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilize a página de código DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilize a tela de código DOS 860 (Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize a página de código DOS 863 (Ca Na Đa Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utilize a página de código DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para espaço de 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém o 'Byte Order Mark' (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        mantém o “Marcação de Ordem dos Bits” (BOM) padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão de caracteres\n"
"   modo de conversão de caracteres:\n"
"ascii, 7bit, iso, mac (padrão é ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens importantes\n"
"   tabela de codificação:\tansi, unicode, utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione uma quebra de linha no final da linha se ela não "
"tiver um\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"forçar a conversão de arquivos binários com base em critérios específicos\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16094       converte UTF-16 para GB16094\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            exibe este mensagem de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o conjunto de dados analisado\n"
"   conjuntos ...            os conjuntos a serem processados para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        conserva o dia e a data de criação do arquivo "
"gerado\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibe a licença do software em formato de papel"

msgid " -l, --newline         add additional newline\n"
msgstr "adauga uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marcação de Ordem” (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "sem permissão para alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma quebra de linha no final do arquivo "
"se ocorrer a ausência dessa (\"default\")."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       gera padrão (standard output)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            conjuntos de dados que precisam ser convertidos para o formato do banco de dados antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, muda para um estado de calma e "
"suprime todas as mensagens de aviso."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gỡ bỏ “Marcação de Ordem do Byte” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ometa tabela de dados em duas partes (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     preserva a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be com base na premissa de que o formato do arquivo é "
"UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        emit um aviso detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo as ligações simbólicas e convertendo o "
"destino do arquivo"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca as ligações simbólicas por arquivos "
"convertidos. (os originais permanecem inalterados.)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações macios e o objetivo sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr "--versao         Mostra versão do software"

