msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando '%s' [opções] [arquivo ...] [-n entrada/saída de texto …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr "converter para ASCII -ascii                padrão de conversão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para o código de caracteres ISO-8859-1 entre DOS e UTF-8"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (Tây Anh) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o codificador DOS-437 (US) como padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-850 (Tây Árabe) para acessar os dados do sistema operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS860 (Bồ Đào Nha) para acessar os dados do sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS-codetabel 863 (Ca Na Đa Pháp) para verificar se a linha %<PRIuMAX>"
" possui %<PRIuMAX> campos."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-codetabel 865 (escandinavo) para acessar os dados do sistema "
"operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"fazer a conversão dos caracteres de entrada para o padrão ASCII sem espaços "
"extras."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        mantenha o “Byte Order Mark” (BOM) original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom        mantenha o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chave de convergência:   ascii, 7bit, "
"iso, mac, padrão é comoçais"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para exibir avisos\n"
"   Codificação da tela de mensagens:\n"
"    kód           'ansi', 'unicode', of 'utf8' (standaariamente é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar um dógrave de nova linha no final se ele não"
" estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn -f, --force           tvinga konvertering af binära filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          convertemos UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO]        mostra informações sobre o arquivo(s) de entrada "
"(input file)"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção --keepdate        mantenha o dia de criação do arquivo original (dia "
"da semana)"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license visa programar o software com licença."

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicione o Byte Order Mark (byte order mark) "
"padrão para UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tape nao criar novo arquivo no modo de criação do arquivo (tập tin gốc) \n"
"   infil               original-file i nytt fil\n"
"   utfil              utmatningsfil i nytt fil"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção não permitida --no-allow-chown      nega a alteração de propriedade do"
" arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr " --no-add-eol          không thêm dây ngắt vào sáu lần hết (mặc định)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gereer of de oude bestand in/overschrijven (standaard) \n"
"   tapezoek van het oudste bestand(s) (mandaat)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"opção --quiet, silenciosa -q ou --quiet           mude o nível de saída para"
" um estado mais calmo."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção '-r' ou '--remove-bom', remover o Byte Order Mark (BOM) padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção --remove-bom      tira o byte order mark (Byte Order Mark) do texto."

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            sair da tabela de hash (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rẽnte que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Opção -F, --follow-symlink converte links simbólicos e converta os dados."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    skip symbolic links and unmodified targets (default)"

msgid " -V, --version         display version number\n"
msgstr "Opção -V, --version         visa versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de DOS em 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS em 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha de versão DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha de referência do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha de referência do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr ""
"Ficha de referência do Windows para sistemas operacionais em 64 bits "
"(MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de Windows 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha de referência para o Phiên bản Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha técnica do Windows para sistemas de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas operacionais em 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas em execução no modo gráfico (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de referência %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có houver suporte Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Có homenagem ao desenvolvedor que criou este documento. Obrigado por "
"contribuir para o OpenStack."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Có homenagem ao desenvolvimento da linguagem de programação Python. O "
"PyCharm é um IDE que oferece suporte completo para o Python, incluindo uma "
"interface gráfica e ferramentas avançadas como depuração condicional "
"(conditional breakpoints) e análise estática do código."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o usuário e grupo de proprietários. Para obter mais "
"informações, tente `%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de caracteres UTF-16LE é utilizada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de caracteres UTF-16BE é utilizada."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da ligação simbólica '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo temporário de saída até agora: %s"

msgid "using %s as temporary file\n"
msgstr "Está utilizando %s como um arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar as permissões temporárias do arquivo %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O arquivo de texto %s não pode ser salvo. Acessar o terminal para verificar "
"se ele existe."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gerou um erro ao alterar o diretório de trabalho atual e a pasta da nuvem "
"%s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo '{}' para '{}':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo deste link simbólico '%s' é obter o valor do campo 'field_name'"

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr "falha na verificação da linha %s possui %s campos (esperado %d)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Falha na verificação da entrada UTF-16 %s, o tamanho do tipo wchar_t não é "
"de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrar o arquivo %s, pois ele não é um ficheiro regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"O arquivo de entrada %s é um link simbólico. O caminho para o diretório '%s'"
" não pode ser encontrado."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Falha na conexão com o link simbólico %s. Para obter mais informações, tente"
" `%s --help'."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"A ligação simbólica %s não é um arquivo regular. O objetivo dela não pode "
"ser alcançado."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Olá! Aqui está a tradução para o português brasileiro do trecho de código em"
" inglês que você forneceu. Por favor, note que as variá0les (%s e %d) devem "
"ser mantidas exatamente como estão no texto original."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para a formatação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo de texto “%s” para o formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo de texto '%s' para a fórma Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo de entrada “%s” para formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para tamanho de linha máximo (PRIuMAX)"
" em formato Unix…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para a fomaci%C3%B3n Unix (%s)..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para o formato Mac, porém não foi "
"possível encontrar a extensão do sistema operacional. Por favor, verifique "
"se você digitou corretamente."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s para a ferramenta Mac (%s)..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a versão DOS do formato de texto "
"(DOS)…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato DOS (%s)..."

msgid "problems converting file %s to file %s\n"
msgstr "Estamos convertendo o arquivo %s para o formato de texto padrão."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "A tarefa está em execução no nível %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s não é permitida."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro de execução do programa. Ocorreu um erro ao executar o comando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro de sintaxe inválida. Ocorreu um erro ao tentar ler o arquivo %s."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
