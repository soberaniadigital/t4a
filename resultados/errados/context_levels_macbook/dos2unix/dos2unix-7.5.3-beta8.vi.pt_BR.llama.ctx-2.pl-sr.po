msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cácio usando: %s [cursos] [arquivos ...] [-n arquivo_entrada arquivo_saida "
"...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão para texto ASCII\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o conjunto de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               dúvida de usar trâng em Windows 1252 (Tây Ái)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                utilizando a tela de código DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "-850                utilizando a tela de DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando a janela gráfica DOS 860 (Bồ Đào Nha)    "
"\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a tela de comando DOS 863 (Ca Na Đa Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizando a tela de comando DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de códigos ASCII 8 bits para o"
" formato 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        giúpá usa o “Byte Order Mark” (BOM) originalmente "
"inserido no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preserva o “Byte Order Mark” (por padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de convergência para a codificação\n"
"   modo de convergência para a codificação:\n"
"ascii, 7bit, iso, mac, mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     defina a tabela de codificação para exibir mensagens\n"
"   tabela de codificação:\n"
"       ansi (padrão), unicode, utf8\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione caractere de nova linha no final da última linha se"
" não estiver presente"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos binários em "
"tabelas de dados separadas por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "opção -h, --help            exibe este aviso de ajuda para você."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CÓDIGO]        exibe informações sobre o arquivo de entrada "
"[FILHO...]            para análise estatística dos dados contidos nos "
"arquivos especificados."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        giúp mua nguyên ngày tháng tập tin đầu ra"

msgid " -L, --license         display software license\n"
msgstr "hiển thị giấy phép dùng phần mềm"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "sem escolha de chmod para alterar proprietário do arquivo (padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona o caractere de nova linha no final da "
"última linha se ele não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi vào stdout tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chéendo modo silencioso, sem emitir nenhum aviso ou alerta"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      excluir 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            exclusão de linhas por padrão (por default)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     conservando tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng định dạng đầu vào là UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rằng định dạng đầu vào là UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguimento de símbolos e conversão dos objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca links simbólicas por cópias reais dos arquivos de origem\n"
"                   (os arquivos originales não sofrem alterações)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links macios e objetivos fixos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         hiển thị số hiệu phiên bản"

