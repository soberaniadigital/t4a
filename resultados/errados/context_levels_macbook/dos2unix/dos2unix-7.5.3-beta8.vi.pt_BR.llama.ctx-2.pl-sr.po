msgstr "ficheiro de saída ainda permanece no “%s”"

msgid "Skipping binary file %s\n"
msgstr "Remova o conjunto de dados separados por linhas %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 '%s', cujo tamanho do caractere wchar_t não é %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que causou um erro na conversão de UTF-16 no "
"registro %u. Ready."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 '%s', conversão de UTF-16 não é suportada nesta "
"versão do programa '%s'.\n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aqui não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o arquivo %s, o ficheiro de saída %s é um vínculo simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação fina %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Remova o vínculo fino entre %s, que não é um caso usual."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o laço pequeno de %s, objetivo %s do laço pequeno não é um arquivo "
"típico. Por favor, verifique se você está usando a sintaxe correta para "
"criar loops em C++."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s para um conjunto de dados chamado “%s” no formato "
"Unix único..."

msgid "converting file %s to Unix format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para a representação do formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo \"%s\" para o arquivo \"%s\" no formato Macintosh "
