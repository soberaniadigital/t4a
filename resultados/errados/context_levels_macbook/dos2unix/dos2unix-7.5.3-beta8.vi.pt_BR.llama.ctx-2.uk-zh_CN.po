msgstr "Ficha técnica MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha técnica do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows, versão de 64 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenômeno Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows, versão de 32 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome de base Windows em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro não encontrado."

msgid "With Unicode UTF-16 support.\n"
msgstr "Tem suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Tem suporte ao nome de arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos no formato Unicode."

msgid "With native language support.\n"
msgstr "Oferece suporte ao localizador do idioma."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao proprietário original e grupo de propriedade do arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para proteção de arquivos por proprietários originais e "
