msgid "problems resolving symbolic link '%s'\n"
msgstr "gab um erro ao tentar analisar o link simbólico pequeno \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s\n"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabarito falha ao alterar permissão do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo que possui o arquivo %s não podem manter seus direitos "
"originais."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Erro ao alterar dono e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao renomear o arquivo “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo dessa ligação curta '\\2s' é o destino desejado."

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída ainda contém o conteúdo original do arquivo '%s'"

msgid "Skipping binary file %s\n"
msgstr "Borra o arquivo de dados divididos %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, cujo tamanho do wchar_t não é necessariamente %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que causou erro ao converter dados UTF-16 na "
"linha %u. Para mais informações sobre como lidar com tais falhas, consulte a"
" documentação do sistema."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo em codificação UTF-16 %s, convertendo a codificação UTF-16 não suportada nesta versão do programa. \n"
"\t%d dias para atualização necessária.\n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borraremos %s, aqui não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra o %s, tabela de saída inicial %s é um link curto e suave."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico mole %s, objetivo dele não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borraremos o linkoso símbolo %s, destino %s do mesmo tipo de ligação móvel "
"não é um arquivo comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo \"%s\" no formato "
"Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Unix...\n"

