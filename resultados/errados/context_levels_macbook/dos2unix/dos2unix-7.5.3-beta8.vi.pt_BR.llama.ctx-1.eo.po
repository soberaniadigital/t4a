msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Cómo usar: %s [opções] [arquivos ...] [-n arquivos-escolhidos...] \n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permissão para alterar o proprietário do arquivo de "
"entrada"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento de conversão m/c definido (padrão)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"-iso                   converte o sinal de interlingua entre DOS e "
"ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando o sistema operacional Windows com "
"codificação de caracteres 1252 (Tây Âu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando código DOS 437 (Estados Unidos) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"-850                utilizando conversor de caracteres DOS para o código "
"ASCII da região (Ocidente) do Brasil"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"-860                utilizando tecla DOS em código de Bồ Đào Nha (860)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizando o trângulo de código DOS 863 (Ca Na Đa Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizando tecla de atalho DOS 865 (Nordland)    \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converteria caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        reteni nguyên Byte Order Mark (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        reteni nguyên Byte Order Mark (mặc định) §↓"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de opção -c, --convmode         modo de conversão do caractere\n"
"   modo de conversão do caractere:\n"
"ascii (defeito), 7bit, iso, mac, mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      desmontrar codigo de apresentação por tela\n"
"   bárragem:\n"
"       ansi,\n"
"       unicode,\n"
"       utf8,\n"
"       definição padrão é 'ansi'\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--adicionar-eol   adicione um caractere de nova linha ao final da linha se "
"não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           obrigatório para converter dois arquivos separados\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Mostre este ajudação neste assistente"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo\n"
"   tabela ...            realizar análise em várias tabelas"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"-k, --keepdate        conserte o dia de data original do arquivo gerado\n"

msgid " -L, --license         display software license\n"
msgstr "--license         Mostre a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         Adicionar nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"-m, --add-bom         adiciona o “Byte Order Mark” (marca de ordem de bytes "
"padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração do proprietário (diretório) de "
"arquivo por padrão"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona dáfines ao final do último caractere se "
"não houver delimitadores (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định)\n"
"   tập-tin …            các tập tin cần chuyển đổi trong chế độ tập-tin-cũ\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      gostar bỏ “BOM” (defaul) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --remover-bom góra \"BOM\" (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            exclusão de dados por padrão (defaul)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     retenha bảng mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be com base na suposição de que o formato do input é "
"UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose, -v         relata detalhes\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink   se seguem simbolicamente ligas e convertam objetivos "
"mínimos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink trocando as ligações simbólicas por cópias dos "
"arquivos de origem (os arquivos primários não são alterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar libras simbolaj ligojn nek celojn không "
"thay đổi (defaŭlto)"

