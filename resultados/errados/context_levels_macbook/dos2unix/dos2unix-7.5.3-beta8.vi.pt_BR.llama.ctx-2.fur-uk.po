msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Códec de uso: %s [opções] [arquivo ...] [-n entrada_arquivo resultado ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "opção --allow-chown permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a tabela de codificação do Windows 1252 "
"(para as línguas ocidentais europeias)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                utilizar a tela de linha DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a linha de comando DOS 850 (máquinas "
"virtuais) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar a linha de comando DOS 860 (português do "
"Brasil) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar a página DOS 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converteria caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservar o segn de ordem original do Byte Order Mark"
" (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preservar o sinal do Byte Order Mark (padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, BIT/7, ISO, MAC, padrão "
"é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação de exibição para os mensagens de teste visualizadas\n"
"   código de caracteres:\n"
"       ansi, unicode, utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final do último "
"registro se ele não existir\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar conversão dos arquivos binários em formato de "
"texto"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda neste comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỌ]        exiba informações do arquivo [file ...] dos campos "
"que precisam de análise\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        manter a data original do arquivo para o resultado\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostre a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o sinal de Byte Order Mark (marcação do "
"byte) (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo\n"
"   tabela de entrada         table_in original in mode create file\n"
"   resultado            output file in write mode"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a alteração do proprietário de "
"arquivo (efeito padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dóis vírgula no final se o arquivo de "
"entrada (padrão) não possuir nenhum\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       gerar saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregar no arquivo antigo (padrão) \n"
"   ficheiro ...            os ficheiros que precisam ser convertidos para o formato do novo arquivo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o sinal de byte ordenação (byte order mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            excluir linhas do arquivo de saída (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assumindo que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  para obter links simbólicos e converter diretórios\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thia substitui links simbólicos para arquivos "
"convertidos (arquivos originais não serão alterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos e dependências (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostre o número de versão"

