msgstr ""
"Remova o arquivo UTF-16 %s, tamanho do campo wchar_t não é igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão UTF-16 do arquivo %s, ocorreu um erro ao converter dados "
"UTF-16 no bytecode da linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta versão "
"do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borraremos %s, isso não é um arquivo padrão. \n"

