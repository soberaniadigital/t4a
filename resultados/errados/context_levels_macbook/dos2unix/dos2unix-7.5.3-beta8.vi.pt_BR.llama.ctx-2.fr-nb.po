msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [-n tabela_entrada fichero_saida …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         autorise o alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII -ascii                padrão de conversão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter de codificação entre o sistema DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o código de codificação Windows-1252 (Vestfália) para processar "
"arquivos."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código page DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o código de codificação do DOS 850 (Tây Âu) para acessar os "
"arquivos."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o código de caracteres do DOS 860 (Português) para acessar este "
"documento."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o código de caracteres DOS 863 (Ca Na Da Pháp) para acessar seu "
"documento."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o código de caracteres do DOS 865 (Nordique) para processamento em "
"BAIXAS LATIMENTIDADES."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "Ficação da linha %s possui %d campos (esperado %<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        garde la marque d'ordre dos bytes"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        garde la marque d'ordre dos bytes (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de converção:   ASCII, 7bit, "
"ISO e MAC (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      escolha o código de codificação para exibir "
"mensagens textuais. Codificações aceitas são ansi e utf8 (padrão)."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicione um caractere de nova linha ao final da última"
" linha se não houver nenhuma existente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de conversão dos arquivos binários -f, --force           force a "
"convergência de ficheros binaires"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use --help para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo de entrada (tập "
"tin) ... ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserve a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione linhas extras"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a marca de ordem dos bytes (por padrão com "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona um caractere de nova linha no final se não houver nenhum "
"(padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"   ficheiro …            fichiers a serem convertidos para o modo de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apague a marca de ordem dos bytes (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apague a marca de byte ordem (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignore les fichiers binaires (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte o encoding UTF-16."

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suponha que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink o seguir símbolos e converter links"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin dựa trải lên cấp nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserve os links simbólicos e as cargas inalteradas "
"(padrão)"

