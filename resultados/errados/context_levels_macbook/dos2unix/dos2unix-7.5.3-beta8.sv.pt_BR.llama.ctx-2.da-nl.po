msgstr ""
" -m, --add-bom         toevoegen byteordningskodering (Byte Order Mark) "
"(standar UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe til ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil              utmatningsfil i nyfilsläge"

