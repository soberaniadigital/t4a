msgid " -ascii                default conversion mode\n"
msgstr "converter para ASCII (padrão)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para o codificação ISO-8859-1 entre DOS e UTF-8"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows codepage 1252 (Vesteuropa) para acessar os dados do sistema "
"operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Use o DOS Tecnicamnento de Codificação (DTC) -437 para acessar as "
"configurações do sistema operacional."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS Tabela de Codificação 850 (Vesteuropeu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tabellen 860 (portugues) para acessar os dados do sistema "
"operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS tabellen 863 (français canadien)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-tegnkodningstabel 865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converterá os caracteres de sete bits para o plano de bits de seis bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        behold byte order mark (BOM) preservação"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom        behold byte order mark (byteorder) (standard)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteringsläge   ascii, 7bit, iso, mac, standard "
"är ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stilize o código para textos em ansi, unicode ou utf8"
" (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um newline à última linha sem alterar o "
"conteúdo da mesma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Opção -f, --force           gennemtning omdannelse af binære filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "visar denna hjälptext"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAG]    vis filtration information"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção -k, --keepdate        mantenha o timestamp do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção --license         visa programa de licenciamento"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar linha extra\n"

