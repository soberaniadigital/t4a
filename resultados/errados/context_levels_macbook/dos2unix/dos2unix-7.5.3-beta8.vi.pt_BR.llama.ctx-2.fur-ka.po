msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivos ...] [-n arquivo_entrada...]}\",\n"
"\"translation2\": {\"translation\": \"Utilize o código abaixo para obter mais informações sobre as opções disponís e como utilizá-las."

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite a modificação do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converteção de caracteres entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizando codificação DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando o sistema de arquivos DOS 850 (Tây Anh) do"
" Windows XP"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando o sistema operacional DOS 860 (Português) "
"\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                dùng trang mã DOS 863 (Ca Na Đa Pháp)\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preservar o sinal do Byte Order Mark (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        manten segn do Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão (convmode)  7bit, ISO, MAC, "
"predefinido como ASCII\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"Adicionar uma quebra de linha no final do último caractere se não houver "
"(\"%s\") ou (\"--add-eol\"))."

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           bússola conversão dos arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda neste comando."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỌ]        exiba informações do tápete de entrada [arquivo ...]"
"            arquivos para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        manten a data original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostre licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         Linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem do Byte” (byte order mark) "
"(definição padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      ไม่พร้อมให้การเปลี่ยนใจของสิทธิ์ (ผู้ใช้) "
"ตัวเดียว"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dóis vírgula(s) no final se nenhum deles "
"fornecido (padrão definido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carrega o arquivo antigo (padrão) \n"
"    tâmpeiro ...            para os campos do tâmpeiro-arquivo antigo converter\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      gjave il segn di ordin dal Byte Order Mark (mặc định)"
" \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      gelo o Byte Order Mark (BOM) da linha de texto."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ბინარული შესყვამება (ნაგულისხმები) (mặc წღობი)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anuncios detalhados"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  theo liên kết mềm và chuyển đổi đích\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha a relação mínima e as configurações padrão "
"(predefinidas) do caminho simbólico."

