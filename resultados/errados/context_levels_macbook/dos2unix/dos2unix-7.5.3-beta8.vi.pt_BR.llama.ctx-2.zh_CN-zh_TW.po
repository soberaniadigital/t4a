msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE USE: %s [opções] [arquivos ...] [-n arquivo_entrada output_arq...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar o proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii                chave de conversão padrão mousseado"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   Troca de sinal entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação de caracteres Windows 1252 "
"(Tây Âu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando código de carácter DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"-860                utilizando interface gráfica DOS 860 (Boha Dao Nha)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando interface gráfica DOS 863 (Ca Na Đa Pháp) "
"\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizando código de caracteres DOS 865 (Bacia do "
"Mediterrâneo)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converte cós tóc ký toc 8 bit thành 7 bit."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        giúp BOM (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        mantém o “Marca de Ordem do Byte” (padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr "chave de modo de conversão:   ASCII, 7bit, ISO, MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     configura a tabela de codificação para exibir mensagens de alerta\n"
"    Tabela de Codificação:\n"
"ansi, unicode, utf8 (padrão ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione um caractere de nova linha no final da linha se ele"
" não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           obrigatório converter arquivos n-ésimos em binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb1609_32         converte UTF-16 para GB1609_32\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Exibe este suporte de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações da tabela de dados\n"
"    tabela ...             as tabelas que precisam ser analisadas para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        guarde o tempo original da data do arquivo de "
"entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir aviso de licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo caractere de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marca de Ordem do Byte’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin cơ sở trong chế độ tập tin mới\n"
"   tập tin ra           tập tin xuất ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona quebra de linha no final do arquivo, "
"mesmo sem a presença dela (configuração padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to-stdout       escreve no padrão de saída (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         輸入原檔案 (預設) \n"
"   檔案 ...            要進行轉換的檔案"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, oculta todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “BOM” (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --safe            bór qua táp tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     conservar a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul --assume-utf16le coi régando que o formato do arquivo de entrada seja "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be coi régido dândio de entrada como UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o símbolo macio e convertendo a metade do "
"caminho para um destino específico"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca o símbolo de ligação por uma cópia do arquivo "
"convertido. (Arquivos originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva o símbolo e seu alvo sem alteração (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostra versão do software"

