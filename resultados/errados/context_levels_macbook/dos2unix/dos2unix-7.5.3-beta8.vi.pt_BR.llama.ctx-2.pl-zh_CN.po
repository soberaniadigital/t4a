msgstr ""
"Convergindo o arquivo %s “%s” para o formato do arquivo de sistema Unix "
"%s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Converting file %s “%s” to Mac format file %s…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Mac...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato do sistema DOS "
"está em andamento...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s...\n"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, foi encontrada uma falha."

msgid "problems converting file %s\n"
msgstr "encontra tricôro quando fazendo conversão de arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "erro na escolha do símbolo '%c' para a opção -i ou --info\n"

msgid "active code page: %d\n"
msgstr "a tarefa está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s, que não é válido."

msgid "option '%s' requires an argument\n"
msgstr "opção '%s' requer um argumento"

msgid "invalid %s display encoding specified\n"
msgstr "Já foi enviado um gráfico de exibição inválido %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi especificado no novo modo de operação do "
"sistema de pastas e ficheiros."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Pares de substituição inválidos. Falta parceiro para a troca."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Parceiro inválido. Falta de substituição adequada."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
