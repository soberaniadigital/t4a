msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cómo usar: %s [opções] [ficheiro ...] [-n ficheiro_entrada <ficheiro_saida> "
"...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         fájltulajdonjog megváltoztatása"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o conjunto de caracteres DOS para ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando código page Windows 1252 (Oeste Europeu) "
"\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                DOS 437 (US) utilizado como padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando a página de código DOS 850 (Tây Át) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                DOS 860 (Bồ Đào Nha) utilizado para codificação de "
"texto em formato especializado."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                DOS 863 (Ca Na Đa Pháp) utilizando a interface "
"gráfica\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                DOS 865 (Birmânia) utilizando"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o espaço dos "
"bits (7 bits)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém o Byte Order Mark (BOM) original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantém o “Marca de Ordem do Byte” (método padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ascii, 7bit, iso, mac, padrão é"
" ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar dítio ao final da linha se não houver um caso de "
"quebra de linha presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bắt buôn chuyển đổi c/w tập tin nhị phân, utilizando o comando `--force'."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         변환 UTF-16 한 GB18030로"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help             Este texto de ajuda é exibido para você."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibição de informações sobre o ficheiro ...   "
"listagem dos ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        mantém o dia da data original no arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         hiçolatória licença para uso de ferramenta gráfica"

msgid " -l, --newline         add additional newline\n"
msgstr ""
" -l, --newline         adicionar um caráter de nova linha ao final da "
"entrada\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem do Byte” (padrão UTF-8) \n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin vào         tập tin gốc trong chế độ tập tin mới\n"
"tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown       não permite a alteração de propriedade do "
"arquivo (padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona dáfima (dígito zero) no final da linha "
"se nenhum for presente (por padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem mensagens de erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o “Byte Order Mark” (marca de ordem de bytes "
"padrão) (opção opcional)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom       apagar o “Byte Order Mark” (BOM) do arquivo\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 codificação de manutenção"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes do processo de execução"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  링크를 따라가며 변경을 수행합니다"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos mínimos e não altera "
"(padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         verzição do software\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro de texto não encontrado."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficheiro de texto não encontrado."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do DOS em 32 bits (Watcom C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản do Windows de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficheiro não encontrado."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome do Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro de texto para o processamento em Python.txt\n"

msgid "%s version.\n"
msgstr "%s versão."

msgid "With Unicode UTF-16 support.\n"
msgstr ""
"Hoje, o nosso sistema suporta Unicode UTF-16. Para obter mais informações "
"sobre opções adicionais ou para solicitar ajuda, por favor, digite '--help'."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Hoje em dia, o sistema suporta nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr ""
"Não há suporte para o nome do arquivo em Unicode. Para obter mais "
"informações, tente '`%s --help'."

msgid "With native language support.\n"
msgstr "Não é possível obter estado (stat) do arquivo %s."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao usuário original e proprietários de grupo, o sistema fornece"
" acesso aos arquivos."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o uso exclusivo de um indivíduo e grupo detentores do "
"direito autoral. Para obter mais informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de entrada para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "%s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é uma tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é uma tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na divisão da ligação múltipla de comprimento máximo `%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como ferramenta temporária para o arquivo .txt."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e/ou grupo de proprietários do arquivo %s não podem manter o "
"direito original. Acesso ao mesmo é restrito."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo de saída temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "falha na conversão do nome “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Olá! O objetivo deste link simbólico é '%s'."

msgid "          output file remains in '%s'\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Skipping binary file %s\n"
msgstr "Borra o arquivo %s binário em separador de tabelas (CSV) \n"

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para a página de código %d. Para obter mais informações, "
"tente `%s --help'."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a medida do wchar_t não é igual ao tamanho de %d "
"bytes. Ao invés disso, deve ser um valor inteiro."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão UTF-16 da linha %<PRIuMAX> do arquivo %s. Aconteceu uma "
"falha ao converter o UTF-16 nesta linha."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho o %s, aqui não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borracho o %s, ficheiro de saída é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borracho o link %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o link mínimo %s, que não é um arquivo típico. A origem deste tipo de"
" link pode ser útil para fins educacionais."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Remova o link mínimo, que não é um arquivo regular. A origem do link pequeno"
" e/ou complexo pode ser uma referência a um documento específico ou ao "
"próprio programa."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s para um arquivo Unix, você pode usar a ferramenta "
"`gzip` com as seguintes opções de linha de comando:`gzip -c --help`, que "
"fornece informações adicionais sobre como utilizar este utilitário. Para "
"obter mais detalhes sobre o uso do gzip, consulte a documentação oficial: "
"https://www.gnu.org/software/gzip/. Se você tiver dúvidas ou precisar de "
"ajuda com comandos específicos relacionados ao `gzip`, por favor, entre em "
"contato conosco."

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato Mac, você pode usar a "
"ferramenta 'Transfofix'…"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para um formato DOS, você pode usar a "
"ferramenta `dos2unix`…"

msgid "converting file %s to DOS format...\n"
msgstr "Ao converter o arquivo “%s” para a versão DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para um arquivo no formato Unix '%s',…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para a representação Unix %s..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Macintosh (Mac OS)…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para a versão Mac OS X (Código Fonte)…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato de ficheiro DOS, você pode "
"utilizar a opção --format=dos...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato DOS, você pode encontrar "
"problemas se não tiver certeza sobre a codificação do seu sistema "
"operacional. Para obter mais informações, consulte `%s --help'."

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato de texto plano. Se você "
"quiser mais informações, tente `%s --help'."

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"Habilitação do comando '%c' para a opção '-i' ou '--info' não é permitida."

msgid "active code page: %d\n"
msgstr "Página de atividade do terminal em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"não foi possível realizar a conversão de %s sem erro. Por favor, verifique "
"se o formato é válido."

msgid "option '%s' requires an argument\n"
msgstr "Selecione “%s” requisito de um número inteiro"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr "A linha de entrada %s não foi definida no novo modo do arquivo %s."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível salvar no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Cadeia de substituição inválida. Substitua abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de parâmetros inválida. O valor do primeiro argumento deve ser "
"especificado."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
