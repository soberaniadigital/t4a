"Ocorrido um erro na análise do arquivo %s. A linha %u não contém o número "
"esperado de campos (esperado %<PRIuMAX>)."

msgid "Added line break to last line.\n"
msgstr "Adicionado o último caractere ao final do texto."

msgid "program error, invalid conversion mode %d\n"
msgstr "Erro de programa, modo de conversão %d não é válido."

msgid "Converted %u out of %u line breaks.\n"
msgstr ""
"Foi convertido o %s no valor do número de linhas em um arquivo, que é igual "
"a %u."

msgid "using code page %d.\n"
msgstr "%s: opção inválida -- '%c'"

msgid "Binary symbol 0x%02X found at line %u\n"
