msgstr ""
"Olá! Aqui está a tradução para o portugu0lês do trecho fornecido em inglês, "
"observando as restrições acima. Por favor, note que os comandos e "
"terminologia técnica específica foram mantidos intactas:"

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [-n tabela_de_dados ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para a conversão entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (Tây Âu) para codificar a página de texto."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação DOS 437 (USA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS850 (Tây Árabe) para acessar as opções de formatação do sistema "
"operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS860 (Bồ Đào Nha) para verificar a linha %<PRIuMAX>."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS863 (Ca Na Dafe) para verificar se a linha %<PRIuMAX> é válida."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Baía Sul) para acessar as informações sobre os campos da linha"
" de entrada/saída padrão."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preservar o byte order mark (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preservar o byte order mark (byte order mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão:   modo de converção ASCII, 7bit,"
" ISO, MAC, padrão definido como ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adiciona a codificação de exibição para as mensagens"
" do log4j2. Antes disso, o texto é escrito em ansi (ansi), utf8 e padrão é "
"ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar dógravado no final de uma linha se não "
"houver nenhum antes do fim da linha caso contrário\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           impede a conversão de arquivos binários para texto"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO]        visa informar a tabela de dados do arquivo %s\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data original do arquivo"

msgid " -L, --license         display software license\n"
msgstr ""
"licença -L, --license         visa solicitar permissão para uso do software."

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicionar “Byte Order Mark” (padrão UTF-8) "

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tape nao_existente.txt em um novo arquivo no modo de entrada/saída do formato padrão\n"
"   tape-in      input file in the new format\n"
"   tape-out     output file from this command"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dáfsa no final da linha se nenhum "
"delimitador de linha (padrão) estiver presente"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreve no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"   para converter tabelas em formato de texto/csv\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem saída de mensagens"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o byte order mark (byte order mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o byte order mark (BOM) do arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignorar linhas de entrada (mínimo)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rá que o formato de entrada §%s§ é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"S -R, --replace-symlink thay thế liên kết mềm bằng tập tinh chuyển đổi (các "
"tập tin đích nguyên gốc thì để người dùng sẽ cần phản hồi) (tập tin đích mà "
"không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ignorar links simbólicos e diretório (método padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versionsnummer"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de referência do sistema operacional DOS para o WATCOM C."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr ""
"Ficha de referência para o sistema operacional DOS em versão 16 bits (Turbo "
"C)."

