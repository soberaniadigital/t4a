msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n infile utdatafil …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         tillat endição de permissões para alteração do "
"proprietário dos arquivos"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversor ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               Windows Code Page (Windows-1252) usado para "
"análise/analisando do código de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                DOS 437 (USA) (standard)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS Tecnológico de Codificação (DTC) para converter um arquivo em "
"formato .txt com extensão '.csv' no sistema operacional Windows. O programa "
"deve ser executado a partir do prompt de comando, utilizando as seguintes "
"etapas:"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tecnologia de Codificação do Windows (DOS Codec) para codificar e "
"decodificar dados em formato binário."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS Tecnoblocks (DOS) -863 para acessar as pastas de trabalho do "
"sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-kodeside 865 (nordisk) para acessar seu diretório de trabalho."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        behold Byte Order Mark (BOM) marking"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção -b, --keep-bom        behold Byte Order Mark (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteringsläge   ascii, 7bit, iso, mac, padrão "
"árabbi"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stáilize a codificação dos mensagens de texto em "
"formato de ansi/utf8 (padrão) \n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um salto de linha na última linha se nenhum"
" for encontrado."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"Use o parâmetro --force para converter arquivos binários. Para obter mais "
"informações, tente '`%s --help'."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "visar este comando de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGG]    vis informações sobre os arquivos que serão "
"analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        behold utdata-filen dato\n"

msgid " -L, --license         display software license\n"
msgstr "opção -L, --license         visa programvarilicensos"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marcação de byte order mark (byte order "
"mark) (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever em um novo arquivo (inicial) ficheiro "
"original ¡fí sário.txt¢ e o resultado no outro.\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o acesso ao arquivo (standard) ¡"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr "não adicione um newline à última linha se não houver nenhuma (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   file ...               ficheiro que será convertido para o formato de texto padrão"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover marca de byte order mark (BOM) padrão (Byte Order Mark)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      apagar marca de byte order (Byte Order Mark) do "
"arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salto sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 kodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "assumindo o padrão UTF-16LE para entrada/saída de dados"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose, opção --v\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguir símbolos de ligação e converter linguagem"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersette símbolos de ligação com links convertidos por"
" meio do programa `ln` (depois que eles foram criados) para os caminhos dos "
"arquivos originais. Os ficheiros originales permanecem inalterados."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    hold både symboliska länkar och mål oförändrade "
"(standard) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         veriçao das versões"

