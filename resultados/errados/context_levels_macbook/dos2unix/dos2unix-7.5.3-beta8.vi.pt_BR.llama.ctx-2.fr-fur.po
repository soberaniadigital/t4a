msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [ficheiro …] [-n ficheiro_entrada ficheiro_saida "
"…]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         autoriza o alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão -iso entre os conjuntos de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilize o código de caracteres Windows 1252 (padrão "
"da Europa Ocidental) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilize o código de caracteres DOS 437 (US) "
"(padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilize o código page DOS 850 (Tây Ático) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize o código de caracteres DOS 863 (Francês "
"Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o espaço em "
"branco 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        manten o sinal de Byte Order Mark (BOM) original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantenha a marca de ordem dos bytes (byte order mark)"
" (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC, por "
"padrão é o ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação para exibir mensagens de teste"
"                    código de caracteres: ansi, unicode ou utf8 (ansi por "
"padrão)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione uma quebra de linha no final da última linha se "
"não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar a conversão de arquivos binários em formato "
"ficheiro"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda para este comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba as informações do arquivo de entrada\n"
"   ficheiro …            ficheiros a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserve a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exiba a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione linhas de nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a marca de ordem dos bytes (por padrão com "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown       n'autorise pas o alteração do proprietário do "
"arquivo (por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma nova linha no final se nenhuma "
"fornecida (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       imprimir no fluxo padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carrega o arquivo antigo (padrão) \n"
"   ficheiro …            os ficheiros a serem convertidos no formato anterior\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apague o Byte Order Mark (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      apague a marca de ordem dos bytes (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            exclua linhas de teste (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserve a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suponha que o formato de entrada seja UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  o seguir links simbólicos e converter destinos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(ficheiros originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserve os links simbólicos e alvos inalterados "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostre o número de versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍNCEANDO DO DOS 16 BITS (WATCOM C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "FENDA DE PHÍNCEANDO DO DOS 16 BITS (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr ""
"FENDA DE PHÍNCEANDO DOS (WATCOMC) - Versão em 32 bits do sistema operacional"
" MS-DOS."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "FENDA DE PHÍNCEANDO DOS SISTEMAS DO X (DJGPP).\n"

msgid "MSYS version.\n"
msgstr "Fenome de Versão MSYS."

msgid "Cygwin version.\n"
msgstr "FUR"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome de Versão Windows 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍSiN BAZÉNS WATCOM C (32 bits)"

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome de Versão Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "FENDA DE PHÍNCEANS DO WINDOWS 32 BIT (MINGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de Versão Windows a 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de versão Windows 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenome do sistema operacional OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "FUR - Versão OS/2 (EMX).\n"

msgid "%s version.\n"
msgstr "Fenome de %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Có homenagear suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có habilitar suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Cuidado ao usar o comando 'rm' para remover arquivos. Ele não é recomendável"
" em sistemas Linux, pois ele remove permanentemente os dados e pode levar a "
"perda irreversível de informações."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao proprietário original e aos grupos de propriedade do "
"arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para preservar a propriedade original do usuário e grupo de "
"um arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando a BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s possui BOM %s. Para obter mais informações, tente "
"`%s --help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Considere o arquivo codificado em UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Considere a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução do link simbólico \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilize o arquivo %s como ficheiro temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador ou o grupo que possui este arquivo %s não pode alterá-lo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Falha ao alterar proprietário e grupo do arquivo temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao alterar o nome do arquivo para “%s” em vez de “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo do link simbólico '%s' é o seguinte."

msgid "          output file remains in '%s'\n"
msgstr "a saída ainda está no arquivo de entrada em «%s»."

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o código de fonte %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Remova o arquivo UTF-16 %s, a tamanho do wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, foi detectada uma falha na conversão de "
"codificação UTF-16 no dado da linha %u. Para mais informações, tente `%s "
"--help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a conversão para UTF-8 não é suportada nesta "
"versão do programa."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra seu arquivo %s, pois ele não é um ficheiro regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o arquivo %s, ficheiro de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borraje o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o link simbólico mínimo %s, pois ele não é um arquivo regular. A ação"
" requer permissão de root."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borrajei o link curto %s, porque a carga de trabalho mínima do link curto "
"não é um arquivo regular. Para obter mais informações sobre como criar links"
" longos e seus requisitos, tente `%s --help'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s para o formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Fazendo a conversão do arquivo `%s' para o arquivo '%s' no formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s para o formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Macintosh…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato DOS…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr "Fazendo a conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrar problemas ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler desde o ficheiro de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O 'código' '%s' para a opção -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "A tela está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s, modo inválido especificado."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"Falha na verificação de entrada do arquivo %s. O formato não é válido."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não pode ser definido no modo de novo arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Código de entrada inválido. O código base é inadequado."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: Cadeia de entrada inválida. O código faltando é invalido."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
