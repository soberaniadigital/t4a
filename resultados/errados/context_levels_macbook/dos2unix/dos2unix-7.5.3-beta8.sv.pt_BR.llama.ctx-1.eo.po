msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [ficheiros ...] [-n ficheurs preferidos …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permissão para alterar o proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrões de conversão para ASCII (defaut)    \n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converteção entre DOS e ISO-8859-1 codificações"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar o código de caracteres Windows 1252 (latino "
"ocidental) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar o código DOS para acesso ao sistema "
"operacional Windows (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar DOS tabuletas de caracteres 850 (vizigotho-"
"europeu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar o tabuor DOS para a versão 860 (portuguesa)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize a tabela de sinalização DOS para o código da "
"UE (Kebekia)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizar o DOS-tecledetabuletto de 865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converterá os caracteres de 8 bits para o espaço em "
"branco de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep_bom         reteni byteordningsmarkering (Byte Order Mark) \n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --keep_bom         reteni byteordningsmarkering (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konvertering mode\n"
"   modo de conversão    'ascii', '7bit', 'iso', 'mac' (defaults to 'ascii')"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stampa codificação para mensagens visuais\n"
"   kodning             ansi, unicode, utf8, padrão é 'ansi'\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--adicionar_EOL         adicionar uma quebra de linha final na última linha "
"se nenhuma for encontrada."

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           tive a conversão de arquivos binários\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converteria UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            visualizar esta ajuda de texto"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR]   visualize informações filtradas\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte o dia da data para arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         visa mostrar a licença do programa."

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicionar linha extra ao final da saída"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marcação de byte ordem (Byte Order Mark) "
"para UTF-8 padrão\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever no novo arquivo\n"
"   infil               original do arquivo na nova lâmina de trabalho\n"
"   utfil               utilitário para o novo arquivo em uso"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração de propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha na última linha se "
"nenhuma (padrão) existir."

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       escrever para a saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão)\n"
"   fil ...               converterá os arquivos para formato de arquivo antigo."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"-q, --quiet           silêncio total, ignorando todas as mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"-r, --remove-bom      remover marcação de byte order (Byte Order Mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"-r, --remove-bom      remover marcação de ordem do byte (Byte Order Mark) "
"para o bajtordo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            pula sobre os arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     retenha UTF-16 teckenskodning\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le traga enigma como UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be fica a suposição de que o formato do input é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        realização detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink  seguir símbolos de ligação e converter as medidas"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetas simboliska links por arquivos convertidos\n"
"(os originais dos caminhos não sofrerão alterações)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    mantenha as ligações simbólicas e não altera (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V, --versão         visa versõesnumeração"

