msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrou um problema ao resolver o link simbólico '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "falha na abertura temporária do arquivo de entrada/saída padrão: %s"

msgid "using %s as temporary file\n"
msgstr "utiliza %s como um arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Malsukcesis em alterar as permissões temporárias de arquivo %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"A posse de usuario ou grupo do arquivo %s não é mantida. Por favor, "
"verifique se o nome e/ou senha estão corretos."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Malsukcesis em alterar ágora e grupo de provisória eleição para o arquivo "
"temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "problemos decorrentes do atual de '%s' para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Qual é o alvo do link simbólico '%s'?"

msgid "          output file remains in '%s'\n"
msgstr "utfil permanece em '\\"

msgid "Skipping binary file %s\n"
msgstr "Pular sobre o arquivo binário %s\n"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Pular sobre o arquivo UTF-16-%s, tamanho do tipo 'wchar_t' é %d bytes. \n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Passear sobre o arquivo UTF-16-%s, um erro de conversão para UTF-16 "
"aconteceu na linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hopar sobre o arquivo UTF-16-%s, a conversão de UTF-16 não tem suporte nesta"
" versão do %s. Para obter mais informações, tente `%s --help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Pular sobre '%s', é um arquivo não convencional. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Pular sobre '%s', fazer upload de %s é um link simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Pular sobre o símboloico link %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Pular sobre o link simbólico %s, a metade não é um arquivo normal. A tarefa "
"consiste em executar uma operação de 'Hoppar' (jump) no sistema Linux usando"
" este símbolico caminho e garantir que ele leve ao destino pretendido sem "
"interromper o fluxo do programa."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Pular sobre '%s', o objetivo do ponteiro simbólico para %s não é um arquivo "
"normal. A ligação entre eles não segue a conveniência típica."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "converterá o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "converterá o arquivo %s para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "converterá o arquivo %s para o formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "converterá o arquivo %s para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "converterá o arquivo %s para o formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "converterá o arquivo %s para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"converterá o arquivo %s para o formato Unix... (continuação do texto "
"original em português)"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"O arquivo de texto %s está sendo convertido para o formato Unix (%2$s)..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"O arquivo do sistema operacional %s será convertido para o formato "
"Macintosh, de acordo com as configurações especificadas no caminho da pasta "
"'%s' e nome do arquivo '%s'."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "O arquivo %s-%s será convertido para o formato Mac (%s)..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"O arquivo %s está sendo convertido do formato %s para o DOS (8.3) no formato"
" de %s...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "O arquivo '%s' será convertido para o formato DOS (%2$s) do MS-DOS...\n"

msgid "problems converting file %s to file %s\n"
msgstr "falha na conversão de arquivo %s para o arquivo %s."

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "Pode ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O flago '%c' para o argumento '-i' ou '--info' está incorreto."

msgid "active code page: %d\n"
msgstr "aktiva teckentabell: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s especificada"

msgid "option '%s' requires an argument\n"
msgstr "O comando '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "a codificação %s apresentada não é válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s especificado não foi atualizado para novas versões."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não é permitido escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na validação do substituto de surrogato. A parte inferior da "
"porcentagem dos parceiros de surrogat não é necessária."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha na validação do parceiro surrogato. A maioria dos casos de parto com "
"um parceiro surrogado não é permitida."
