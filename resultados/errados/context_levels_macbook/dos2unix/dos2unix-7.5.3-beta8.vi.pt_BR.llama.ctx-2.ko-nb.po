msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Método de uso: %s [opções] [-n <input_file> <output_file> ...]}"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII -ascii                padrão de conversão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"ISO -iso                   converter entre conjunto de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows Code Page (1252) para codificação de caracteres no "
"Vestfália."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS Code Page 850 (Tây Âu) para acessar os arquivos de texto em "
"formato do Windows."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS 860 (Bồ Đào Nha) para acessar e manipular arquivos de texto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Utilize o DOS 863 (Ca Na Đa Pháp) para acessar as opções de tradução."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Utilize o DOS Code Page 865 (Baía Árabe) para processamento de texto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"Falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpia o arquivo '%s' com a opção '-b', para manter o Byte Order Mark (BOM) "
"intacto."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "giúpia -b, --keep-bom        바이트 순서 표시(BOM) 유지 (기본)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de conversão:   ascii, 7bit,"
" iso, mac\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir các thông báo\n"
"    bảng mã: ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar dógrafo no final da linha se ele não estiver "
"presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de conversão dos arquivos binários -f, --force            forçar "
"converção dos arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help             vis denne hjelpeteksten"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo de entrada\n"
"   tabela ...         lista de ficheiros para análise"

