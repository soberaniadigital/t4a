msgid " -ascii                default conversion mode\n"
msgstr "opção não permitida"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para entre em DOS e ISO-8859-1 codificação de caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               använd Windows teckentabell 1252 (västeuropeisk)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Use o DOS-кодитве 437 (USA) padrão para acessar as opções de codificação."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (DOS) para acessar os dados do sistema operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS-codetabel 860 (portugues) para acessar os dados de saída do "
"sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS-Codetabel 863 (fransk-kanadensisk) para acessar os dados de saída "
"do sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-Codetabel 865 (escandinavo) para acessar os dados de saída do "
"sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converterá os caracteres de entrada para o padrão do "
"ASCII sem espaços extras."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        behåll byteordningsmarkering (Byte Order Mark)\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        behouser byteorder markering (Byte Order Mark) "
"(standart)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        convergência de modos   ascii, 7bit, iso, mac, padrão"
" é 'ascii'"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     utilizar codificação para mostrar as mensagens de "
"erro"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um newline à última linha sem alterar o "
"conteúdo\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "opção forçar           convergência de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            visar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformation\n"
"fil ... filer att analysera"

msgid " -k, --keepdate        keep output file date\n"
msgstr "keepdate"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa programa de licença"

msgid " -l, --newline         add additional newline\n"
msgstr "opção -l, --newline         adicionar mais linhas de texto\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         доzerнеბის მიმდევრობის ნიშნის დამატება "
"(ნაგულისხმები UTF-8) (standard for UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe naar een nieuw bestand schrijven\n"
"   INVIORE                    originele fil in nieuwe filsläge\n"
"   UTILISER                     utmatningsfil i nieuwe filsläge"

