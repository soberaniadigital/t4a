msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cácioúndia usando: %s [seleções] [arquivos …] [-n arquivo_entrada "
"arquivo_saída …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento por padrão (conversor de caracteres "
"ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o conjunto de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               utilizado Windows Codepage 1252 (Tây Ái) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizado trâng mã DOS 437 (US) (vínculo padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "-850                utilizado trâng mã DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizado código de fonte DOS 860 (Bồ Đào Nha)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizando trângulo de sinais DOS 863 (Ca Na Đa Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utilizado trâng minh mã DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de códigos 8 bits para o "
"espaço dos 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém o Byte Order Mark original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o “Byte Order Mark” (padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave --convmode         modo de conversão do código fonte\n"
"   modo de conversão do código fonte:\n"
"ascii, 7bit, iso, mac; padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     configurar a codificação de exibição para mensagens visuais\n"
"   codificações possíveis: ansi, unicode, utf8; padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione um caractere de nova linha ao final da última linha"
" se não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório converter arquivos n-ais fracionados"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "opção -h, --help            mostra esta ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỸ]        exibe informações sobre o arquivo de entrada\n"
"   ficheiro …            ficheiros a serem processados para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva o dia de criação da tabela de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona um novo caractere de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar o marcador de ordem de bytes (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário de arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dáfima de linha fina se ela já estiver "
"presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr ""
" -O, --to_stdout       ghi para a saída padrão conforme o protocolo de "
"transmissão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          insere no arquivo antigo (padrão) \n"
"   arquivos de entrada ...            os arquivos que precisam ser convertidos para o modo do arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chée -q, --quiet chéfe modo im lêngo, cânh mói caanho báo\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      remove o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "usando o parâmetro -r, removerá a marcação de byte order mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            excluir linhas do arquivo dividido em duas partes "
"(padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     mantém a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo links simbólicos e convertendo os "
"objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos de texto transformados\n"
"(arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preserva as ligações simbólicas e seus objetivos sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do programa"

