msgstr "Fenômeno Cygwin. Wersja %d."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenômeno Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenômeno Windows 32 bit (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno EMX (OS/2)"

msgid "%s version.\n"
msgstr "Fenomeno %s. Wersja %d."

msgid "With Unicode UTF-16 support.\n"
msgstr "Há suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Há suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos em Unicode."

msgid "With native language support.\n"
msgstr "Não há suporte para a localização baseada no idioma."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao manter o proprietário original e grupo de usuários dos arquivos. \n"
"\tPara obter mais informações, tente 'command --help'. Para cancelar a operação atual, pressione '_Cancel'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e a associação de grupo "
"dos arquivos."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Gravando BOM %s. \n"

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s contém um BOM %s. \n"
"\t(Tipificação do formato)"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução de ligações mínimas simbólicas da expressão \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando o %s como arquivo temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gặp lỗi khi thay đổi quyền hạn của tập tin đầu ra tạm %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e/ou grupo que possui o arquivo %s não podem manter a "
"propriedade original. Para obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên \"%s\" thành \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo dessa conexão simbólica é o mesmo que a opção \"%s\"."

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída ainda contém o conteúdo do \"%s\""

msgid "Skipping binary file %s\n"
msgstr "Borrando o conjunto de dados divididos em dois fatores %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o painel de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a largura do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrado o arquivo UTF-16 %s, houve erro na conversão de UTF-16 na linha %u. "
"\n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a conversão de UTF-16 não é suportada nesta "
"versão do programa %s. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aí não é uma pasta comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o %s, ficheiro de saída %s é uma ligação simbólica."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o vínculo mole %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a associação macia %s, o objetivo dele não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o vínculo macio %s, objetivo do link macio %s não é uma pasta regular."
" \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Ao converter o arquivo %s para o arquivo \"%s\" no formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo de texto `%s' para a representação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Fazendo a conversão do arquivo de texto `%s` para o arquivo `%%s`, no "
"formato Macintosh…"

msgid "converting file %s to Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto `%s' para o formato Mac, você pode usar a "
"ferramenta 'PL'. Para obter mais informações sobre como utilizar essa "
"ferramenta ou qualquer outra que esteja disponível no seu sistema "
"operacional, consulte os recursos oficiais."

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato DOS está em andamento…"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo de dados “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para a versão do formato Unix, você obterá um"
" novo arquivo com nome alterado para %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para a representação Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para a versão do Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "A conversão do arquivo %s “%s” para o formato Mac está em processo…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo %s no formato DOS está em "
"processo…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para a versão DOS do sistema operacional MS-"
"DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, problemas foram encontrados."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "A bandeira '%c' para escolha da opção -i ou --info está errada."

msgid "active code page: %d\n"
msgstr "A tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s, que não é permitido."

msgid "option '%s' requires an argument\n"
msgstr "opção '%s' requer um número inteiro"

msgid "invalid %s display encoding specified\n"
msgstr "Oculto %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo da tabela de dados %s não foi especificado no modo novo do "
"arquivo de texto"

msgid "can not read from input file: %s\n"
msgstr "não é possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível gravar no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Caracter insuficiente para a troca."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Ocorreu falta do parâmetro para a "
"troca."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
