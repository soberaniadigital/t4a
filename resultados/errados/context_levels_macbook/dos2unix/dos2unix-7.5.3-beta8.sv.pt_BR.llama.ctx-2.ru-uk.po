msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"uso do programa 'gprof2dot': %s [parâmetros] [-n início_arquivo ...] [-o "
"saída_arquivo …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permita a mudança de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -modo ASCII                padrão de conversor"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"ISO -iso                   converter de codificação DOS para ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"uso a codificação Windows-1252 (latino-3) para o português brasileiro."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use a tabela de codificação DOS 437 (USA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use a tabela de codificação DOS 850 (vastaia europeia)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use a tabela de sinalização DOS 860 (portuguesa)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use a tabela de sinalização DOS 863 (franco-canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use a tabela de sinalização DOS 865 (escandinavo) para o seu projeto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preservar a marca de ordem dos bytes (BOM) do "
"arquivo"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preservar a marca de ordem dos bytes (Byte Order "
"Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr " -c, --convmode        конвертаção режим"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     завантажити кодирування текстовых повідомлень, "
"кодування           ansi, unicode, utf8, стандартний є ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar uma quebra de linha no final da última "
"linha se ela não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           tvinga konvertering av binära filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para visualizar este comando de ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR]  mostrar informações sobre o arquivo fil ..."
"               ficheiro para analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção -k, --keepdate        preservar a data de criação do arquivo para o "
"resultado"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         apresentar licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr "Use '--newline' para adicionar um caractere de nova linha à saída."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marcação de byte order mark (Byte Order "
"Mark) para UTF-8 (padrão)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         записати в новий файл ínfimo_arquivo.txt\n"
"   infil               origem_arquivo em novo formato de arquivo\n"
"   utfil              arquivo de saída no novo formato"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar quebra de linha em uma nova linha, se "
"ela não existir (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
"opção --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro ...                    arquivos para converter em formato de texto antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, não mostrar avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção --remove-bom      remover marca de byte order mark (BOM) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover marca de ordem do byte (BOM) -r, --remove-bom      "
"remover a marca de ordenação dos bytes (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            permita a passagem de binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conservando codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le pressupondo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be pressupondo que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        modo detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink  seguir sinais de links simbólicos e converter "
"arquivos referenciados."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"opção --replace-symlink substituir links simbólicos por arquivos "
"convertidos, mantendo os originais inalterados."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr " -S, --skip-symlink    não altera símbolos e destinos (padrão)"

