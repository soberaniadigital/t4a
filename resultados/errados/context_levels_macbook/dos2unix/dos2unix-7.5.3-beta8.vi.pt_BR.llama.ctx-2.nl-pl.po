msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [arquivo ...] [-n input_file output_file]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         zezwolenie na zmianie właściciela plików"

msgid " -ascii                default conversion mode\n"
msgstr "converter para ASCII -ascii                domyślny tryb konwersji"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre o conjunto de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o código de codificação Windows-1252 (codificação da Europa Ocidental) "
"para acessar os dados do arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação DOS 437 (US) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o sistema de codificação DOS 850 (Tây Árabe) para acessar os dados do "
"arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o sistema de codificação DOS 860 (Bồ Đào Nha) para acessar as linhas do "
"arquivo."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o soquete DOS 863 (Canadees Frans)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use a porta virtual de entrada/saída padrão (stdin/stdout) para análise e "
"processamento do arquivo."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        mantenha o “Znacrm” BOM (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        zapisuje znacznik BOM (Byte Order Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão (convmode):   chave de conversão, ASCII, 7bit, ISO ou "
"mac; padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para exibir avisos\n"
"   bárdia de mensagem: ansi, unicode, utf8; padrão é 'ansi'"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar um caractere de nova linha no final da "
"última linha se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn -f, --force           wymuszenie konwersji plików binarnych"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          convertem o UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use --help para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO]    mostra informações sobre o arquivo(s) [arquivos...]   "
"mostrar informações dos campos do ficheiro (ficheiros...)"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        mantenha o timestamp do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr "opção -L, --license         licença disponibilizar"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicionar “Marca de Ordem” (domyślnie UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tape nao criar novo arquivo\n"
"   plik_wej            plik oryginaalny w trybie nowego pliku\n"
"   plik_wyj            plik wyjściowy w trybie nowego pliku"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido modificar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dâng gói (dấu ngắt) trong cuốn suốt mặt "
"phổ biết nếem khi chưa có dấu ngắt (mặt rằng không cần thiết)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          herunterladen van een bestand naar standaardformat (standaard) \n"
"   Bestand ...            pôr ficheiro(s) em conversão para o formato de backup"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           silencioso, sem notificações"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção '-r', --remove-bom      apagar o sinal de byte order mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção -r, --remove-bom      remoção do sinal BOM (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            pomijanie plików binarnych (domyślne)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter o UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi ráguem o formato UTF-16LE como dânh de entrada"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi ráguem que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada produzir"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Opção -F, --follow-symlink converte links simbólicos e realiza conversão de "
"destino."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bặn tập tin chuyển đổi (các tập"
" tin dựa trải nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr " -S, --skip-symlink    bez zmian dowiązających i celów (domyślne) "

