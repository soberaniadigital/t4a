msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách de uso: %s [selecções] [arquivos …] [-n arquivo-de-entrada tabela-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração do proprietário de arquivo\n"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento padrão (método de conversão ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                      converteção de código entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               usando tabela de codificação Windows 1252 (Tây Ái) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando tabela de conversão DOS para codificação "
"437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando tabela de conversão DOS para o código dos "
"padrões do sistema operacional da Europa Central (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando tela de comando DOS em código do Brasil "
"(Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando tabela de mapeamento DOS 863 (Canadá "
"Francês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando tabela de conversão DOS para o código do "
"sistema 865 (norte da Europa)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    conversão de caracteres 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        mantém o byte order mark original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantenha o “Marca de Ordem dos Bits” (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão em texto\n"
"   modo de conversão em texto:\n"
"acii, 7bit, iso, mac, padrão é acii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     defina a codificação de texto para exibir mensagens\n"
"   codificações possíveis:\n"
"       ansi,\n"
"       unicode,\n"
"       utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--adicionar-eol   adicione um caractere de nova linha no final da linha se "
"não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório para converter arquivos binários em "
"formato de texto separado por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030         Converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Hiêln tỉa giúp này\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o conjunto de dados\n"
"   conjuntos-de-dados …            coleções de dados para análise\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        guarde o dado do dia/mês da saída de texto\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         vis software licença"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicionar novo dado de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione ‘Byte Order Mark’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      ninguém pode alterar o proprietário do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dáfines ao final do conteúdo se nenhum "
"deles estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"táp-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           chéresse silenciosa, tacanha mocidade de avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      excluir 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --seguro            excluir linhas por padrão (por default)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     preservar tabela em UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando o modo de codificação do formato de "
"entrada como UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   teor lienhoto e conversao de objetivo\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos reais que foram convertidos em um formato diferente\n"
"                   (arquivos de origem permanecerão inalterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserve ligações finas e objetivos não alteráveis "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         mostra versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS 16 bit (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Phiên bản DOS 32 bit (DJGPP)."

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)"

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)"

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bit (MSVC %d).\n"

msgid "OS/2 version (Watcom C).\n"
msgstr ""
"Ficha técnica do sistema operacional OS/2 (WATCOM), desenvolvido pela "
"WATCOM."

msgid "OS/2 version (EMX).\n"
msgstr "Phiên bản OS/2 (EMX)."

msgid "%s version.\n"
msgstr "%s Versão. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Có oferecer suporte à codificação Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có oferecer suporte ao nome do arquivo no formato Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte ao nome de um arquivo em formato Unicode."

msgid "With native language support.\n"
msgstr ""
"Có oferecer suporte à localização de linguagem. A Localização e Tradução do "
"Software (LIS) é responsável por fornecer essa assistência."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como você está, esperando ajuda para manter o registro de acessos e edições "
"por usuários individuais ou grupos. Para obter mais informações sobre como "
"configurar essa função, tente executar 'command --help'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter informações pessoais e de grupo em arquivos. Para"
" obter mais detalhes, consulte 'Por favor, ajude-nos a preservar as "
"identidades dos usuários.'"

msgid "Path for temporary output file is too long:"
msgstr "Rota de envio para arquivo temporário muito antigo:"

msgid "Writing %s BOM.\n"
msgstr "Gravando BOM para %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "Tápico de entrada %s possui BOM %s. \n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrou erro ao tentar resolver ligação fraca '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr ""
"usando o aplicativo %s como ferramenta intermediária para armazenar dados em"
" um arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo que possui o arquivo %s não podem manter a propriedade "
"original do arquivo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "encontrou erro ao alterar o nome do \"%s\" para \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "O objetivo dessa conexão de curto circuito é alcançar o sinal '%s'."

msgid "          output file remains in '%s'\n"
msgstr "tápia de saída còn trong “%s”"

msgid "Skipping binary file %s\n"
msgstr "Remova o conjunto de dados separado por linhas %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o navegador %d. \n"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Cancelar o arquivo UTF-16 %s, tamanho do caractere wchar_t não é "
"necessariamente de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Após remover o conjunto de dados UTF-16 %s, ocorreu um erro ao converter do "
"UTF-16 na linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta "
"versão do programa da %s. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o arquivo %s, isto não é um caso comum de texto. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o campo %s, ficheiro de saída %s é uma referência curta. Bỏ qua %s, "
"tập tin đầu ra %s là một liên kết mềm."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova a ligação fina %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Remova a conexão fina %s, o objetivo dela não é um arquivo padrão. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Após remover o link fino %s, objetivo final do link fino mínimo %s não é um "
"arquivo comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o conjunto de dados “%s” no "
"formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo `%s` para o formato Mac, utilizando a "
"ferramenta `mac2unix`.\n"

msgid "converting file %s to Mac format...\n"
msgstr "A conversão do arquivo “%s” para o formato Mac está em processo…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato do sistema DOS, crie um "
"novo arquivo chamado ‘%s’…"

msgid "converting file %s to DOS format...\n"
msgstr "Ao converter o arquivo “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Unix e salvá-lo "
"como arquivo %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato Mac, você terá um novo arquivo"
" chamado de ‘%s’…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato do sistema de ficheiros DOS, …"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, pode haver problemas durante a "
"conversão."

msgid "problems converting file %s\n"
msgstr "encontra truck control quando fazendo conversão de arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O comando '%c' para escolha -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "tela de trabalho atual: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu uma violação do estilo de conversão %s especificado."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” yêu cầu một đối số"

msgid "invalid %s display encoding specified\n"
msgstr ""
"ocorreu uma violação na apresentação gráfica do sistema %s especificada como"
" 'DA'"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi especificado no novo estado de tabela."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Parceiro de substituição inválido. Substitua com parceiro válido "
"abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Parceiro incorreto. Ocorreu uma falha na troca de parceiros."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
