msgstr ""
"Fique em dia com o arquivo UTF-16 %s, a conversão de UTF-16 não é suportada "
"nesta versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho em %s, isso não é um arquivo típico."

