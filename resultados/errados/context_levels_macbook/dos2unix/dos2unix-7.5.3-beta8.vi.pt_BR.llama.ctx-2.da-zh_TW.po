msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Método de uso: %s [opções] [-n tabela_de_entrada ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão (ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "chave de conversão entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows-1252 para codificação de caracteres (Tây Árabe) do sistema"
" operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o codificador DOS 437 (US) padrão"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS850 (Tây Árabe) para codificar texto em chinês simplificado."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o código DOS 860 (português brasileiro) para acessar as informações de "
"status do sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar tabela de codificação DOS 863 (Ca Na Da "
"Tâmil)    "

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o código de fuso horário POSIX (DOS 865) para a região da Europa do "
"Norte."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preservar o “byte order mark” (BOM) original do "
"arquivo"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preservar o “byte order mark” (marca de ordem dos "
"bytes) padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chave de modo de convergência: ascii, "
"7bit, iso, mac, padrão é ASCII."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir notificações de erro\n"
"   kodexaminação: ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"coluna se ele não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn chết các tập tin nhị phân"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            vis denne hjælpetekst"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do arquivo ...             "
"documento para analisar   cargas de dados"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"Keep date        -k, --keepdate         preservar o dia da data original do "
"arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         vis software licença"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione “Marca de Ordem Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo\n"
"   táp-tin-vào         táp tin gốc trong chế độ táp-tin mới\n"
"   táp-tin-ra           táp tin đầu ra trong chế độ táp-tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          Não adicionar dado de nova linha se não houver "
"delimitador (padrão) em caso nenhum."

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       escrever no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          escrever no arquivo antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           silencioso ou mudo, sem nenhuma mensagem de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção -r, --remove-bom      apagar o byte order mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o BOM (Byte Order Mark) -r, --remove-bom      apagar a "
"sequência de bytes em ordem"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar em UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi rão que o formato de entrada deve ser UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rão de que o formato do arquivo de entrada deve "
"ser UTF-16BE."

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi\n"
"                   (các tập tin đích nguyên gốc thì để nguyên không thay đổi)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos e seus objetivos sem "
"alteração (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         vis versão número"

