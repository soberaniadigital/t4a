msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Användning: %s [flaggor] [fil …] [-n infil utfil …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         zezwolenie na zmianę właściciela plik"

msgid " -ascii                default conversion mode\n"
msgstr "converter para ASCII --------------------------------\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre zestawy znaków DOS i ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use Windows code page 1252 (latino-americano) para o sistema operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Codepage 437 (USA) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (vizualização europeia ocidental) para acessar os "
"dados do arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS-codetabel 860 (portugues) para acessar as pastas de trabalho."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS-codetabel 863 (canadense francês)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-codetabel 865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converterá os caracteres de oito bits para a representação em binário no "
"espaço dos sete bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        mantenha o marcador de ordem dos bytes (Mnema) do "
"Byte Order Mark"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        mantenha o marcador de ordem byte (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteringsläge   ascii, 7bit, iso, mac; standard "
"är ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     kodowanie           ansi, unicode, utf8; domyślnie "
"ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um caractere de nova linha à última linha "
"do arquivo\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"conjunto de opções -f, --force           conversão binária dos arquivos"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            visar este opcional texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] visa informações sobre o arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        mantenha a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         visa licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m' ou '--add-bom', adicionar Byte Order Mark (BOM) padrão para UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe naar een nieuw bestand in nieuwe schrijvenlageringsmodus\n"
"   INVOERBESTAND        het originele bestand in nowe-schrijvingen lage\n"
"   UTJAZD BESTAND       de overgenoegde/geconverteerde versie van het originele bestand in nieuwe schrijvenlageringsmodus"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          nie adicionar um caractere de nova linha ao final da "
"última linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile         skriár o arquivo antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silencioso ou taciturno, ignorar todas as warnings"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção '-r' ou '--remove-bom', remover o BOM (Byte Order Mark) padrão."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover marca de byte order mark (Byte Order "
"Mark) [pt-BR]"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            pomija pedaços binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     beholda UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le pretende que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be pretende que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose, --help        executa o programa com verboso output."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink converte links simbólicos e converta os campos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzen symbolische links mit convertidas arquivos "
"(originais pedaços de dados não serão modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    bez zmian dowiązanych symbolicznych i celów "
"(domyślne)"

