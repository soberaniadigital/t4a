msgstr "Cun suporte a Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có habilitar o suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome do arquivo Unicode."

msgid "With native language support.\n"
msgstr ""
"Olá! Obrigado pela sua solicitação de tradução para o português brasileiro. "
"Por favor, forneça a frase que deseja traduzir."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte para o usuário original e grupos de proprietários do arquivo. "
"\n"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o acesso ao arquivo por parte de terceiros e grupos. "
"Para obter mais informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

