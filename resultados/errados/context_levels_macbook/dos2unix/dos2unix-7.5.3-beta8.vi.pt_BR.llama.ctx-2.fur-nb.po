msgstr "Fenômeno de Windows a 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome de Versão a 32-bit do Windows (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome de Versão a 32 bits do Windows (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows a 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base Phiên bản Windows a 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno OS/2 (EMX)."

