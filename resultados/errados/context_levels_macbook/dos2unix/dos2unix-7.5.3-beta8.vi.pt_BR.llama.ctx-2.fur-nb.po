msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [arquivos …] [-n arquivo_jentrade arquivo_jessude"
" ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo padrão de conversão ASCII predefinido\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"conversão ISO para DOS -iso                   converte caracteres entre o "
"formato de codificação do Windows (DOS) e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar codificação Windows-1252 (Tây Dong)    } ✅ 🎯"
"  # Translate the following English text to Brazilian Portuguese, adhering "
"strictly to technical terminology and formal language style. Ensure that all"
" variables are preserved exactly as they appear in their original form "
"within format specifiers like %s or ${var}. The translation must be suitable"
" for a CLI utility documentation context: "

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando o código de fim de linha DOS 863 (francês "
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando o Tratamento de Erros DOS 865 (nordestino)"
" \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        manten o sinal do Byte Order Mark (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantenha o “Byte Order Mark” (método padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC (padrão é"
" ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de exibição para mensagens de "
"teste. Codificações suportadas são ansi e utf8 (ansi é padrão)."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           blocar conversão dos arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda nesta ação\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações sobre o arquivo de entrada\n"
"   ficheiro …            dos ficheiros que serão analisados para extrair dados"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostre licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem do Byte” (marcação por byte)"
" (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite alterações no proprietário do "
"arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dóis vírgula no final se nenhum for "
"presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      gelo bônus da ordem do byte (byte order mark) "
"(predefinido)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gelo o “Byte Order Mark” (BOM) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte i file binaris (predefinît) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo o formato de entrada como UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguir símbolos de ligação e converter links para "
"caminhos reais."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha o vínculo simbólico e as direções "
"invariáveis (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostre a versão do programa\n"

