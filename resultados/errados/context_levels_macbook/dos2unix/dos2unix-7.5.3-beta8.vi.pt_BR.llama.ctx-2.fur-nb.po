msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da opção inválida -- '%c'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr ""
"está utilizando %s como ferramenta para acessar o banco de dados "
"temporariamente."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões temporárias do arquivo de entrada %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo proprietário do arquivo %s não podem manter o direito "
"de propriedade. Para obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Falha na alteração do proprietário e da associação para o arquivo de saída "
"temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao alterar o nome do usuário para “%s” em vez de “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"O objetivo deste link simbólico '%s' é facilitar a comunicação entre os "
"membros da rede."

msgid "          output file remains in '%s'\n"
msgstr "          tập tin đầu ra còn trong “%s”\n"

msgid "Skipping binary file %s\n"
msgstr "Remover o arquivo binário %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o navegador %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Remova o arquivo UTF-16 %s. O tamanho do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Se o arquivo UTF-16 %s for excluído, foi detectado um erro de conversão para"
" UTF-16 na linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Remova o arquivo UTF-16 %s, pois a conversão para UTF-8 não é suportada "
"nesta versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrajei %s, isso não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico. O caminho do primeiro registro"
" de entrada/saída padrão para este arquivo foi alterado."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova a ligação fraca %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Separar a conexão mínima %s, o objetivo dela não é um arquivo comum. Aqui "
"está mais informações."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Seja cuidadoso ao remover a ligação fraca, pois o destino do link curto não "
"é um arquivo comum. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo a conversão do arquivo “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac…"

