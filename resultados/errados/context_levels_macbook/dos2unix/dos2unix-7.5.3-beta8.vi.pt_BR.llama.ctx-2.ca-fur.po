msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cânone utilizado: %s [opções] [arquivo ...] [-n arquivo de entrada ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown permite a modificação da propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               usa página de código Windows 1252 (padrão ocidental)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                usa página de codificação DOS 432 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usa página de código DOS 850 (tâmil ocidental)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa trângulo de código DOS 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                usa página de código DOS 865 (nórdico)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        manten o sinal de Byte Order Mark (BOM) original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        manten a marca d'ordem de bytes (byte order mark) "
"(predefinido)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bits, ISO, MAC, padrão "
"é ASCII por defeito\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de caracteres para exibir mensagens de teste\n"
"   código de codificação:\n"
"       ansi (padrão), unicode ou utf8. Por padrão é definido como ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           força conversão dos arquivos binários em formato de "
"texto\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra a ajuda deste comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe as informações do arquivo de entrada\n"
"   ficheiro ...            fitxers a analisar para obter as suas informaçõestátuário"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a marca de ordem dos bytes (Byte Order Mark)"
" (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite alterar a propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona dóis de nova linha no final se nenhum "
"for encontrado (padrão definido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       imprime no fluxo de saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregue o arquivo antigo (padrão) \n"
"   ficheiro ...            os ficheiros para converter no formato de ficheiro antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apaga o Byte Order Mark (marca de ordem dos bytes) "
"por defeito"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga a marca de byte (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            borre a tabela de partições (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de caracteres UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo que o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assumindo que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink segue o link simbólico e converte os destinos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os links simbólicos por arquivos reais (não"
" alterando o conteúdo dos originais)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha o vínculo simbólico e os objetos (por "
"padrão) não podem ser modificados."

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr ""
"FENDA DE PROGRAMAÇÃO FUNDAMENTAL DO SOCKET (WATCOMC) - Versão de 16 bits do "
"DOS."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenome do DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr ""
"FENDA DE PROJETO DOS SISTEMAS Operacionais (WATCOMC) - Versão de 32 bits."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr ""
"FENDA DE PROJETO DOS SISTEMAS Operacionais (DJGPP) - Versão de 32 bits."

msgid "MSYS version.\n"
msgstr "Fenome de MSYS."

msgid "Cygwin version.\n"
msgstr "Fenome de Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍNCEANTE WINDOWS 32 BIT (WATCOMC)"

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "FENDA DE PHÍNCEANS DO WINDOWS 32 BIT (MINGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr ""
"FENDA DE PROJETO PARA A LINGUAGEM BRASILEIRO (Português) - Phiên bản Windows"
" 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de Versão Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Fenome de %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Có hospedar Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có habilitar suporte para nomes de arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome do arquivo Unicode."

msgid "With native language support.\n"
msgstr ""
"Olá! O suporte ao localizador de idiomas é necessário para acessar o "
"sistema. Por favor, informe seu país ou região."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao usuário e à propriedade dos arquivos, o sistema permite a "
"criação de um diretório compartilhado para armazenar os dados. Para iniciar "
"esse recurso, você deve executar: 'mkdir -p /home/user_name/shared-"
"directory'"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para a propriedade de direitos individuais e do grupo sobre o"
" arquivo. Para obter mais informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída excessivamente longo:"

msgid "Writing %s BOM.\n"
msgstr "Estão a escrever o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Coeja a tabela de caracteres UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da opção inválida -- '%c'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "está usando %s como ferramenta temporal para o arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Ocorreu um erro ao alterar os permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo que possui o arquivo %s não podem adquirir a "
"propriedade do mesmo. Para obter mais informações, tente '`%s --help`'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo de saída temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao alterar o nome do arquivo para \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"O objetivo do link simbólico 'CA' é acessar o arquivo '%s'. O propósito "
"desse enlace, que se estende por um período de tempo limitado e pode ser "
"interrompido em qualquer momento sem perda dos dados armazenados nele."

msgid "          output file remains in '%s'\n"
msgstr ""
"arquivo de saída ainda está no estado '%s' do programa 'FUR'. Para obter "
"mais informações, tente `%s --help'."

msgid "Skipping binary file %s\n"
msgstr ""
"Remova o arquivo binário %s do conjunto de dados parcialmente processado."

msgid "code page %d is not supported.\n"
msgstr ""
"Não há suporte para o site %s. Para obter mais informações, tente '`%s "
"--help''.\n"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Remova o arquivo UTF-16 %s, a medida do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Se o arquivo UTF-16 %s, foi detectado um erro de conversão do formato UTF-16"
" na linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a conversão para UTF-8 não é suportada nesta "
"versão deste programa."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra seu arquivo %s, pois este não é um ficheiro regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Remova o arquivo %s, o ficheiro de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Seja removido o link mínimo %s, a sua finalidade não é um arquivo normal. "
"Aqui está mais informações sobre isso."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Seja cuidadoso ao remover a ligação mínima, pois o objetivo dessa conexão "
"simbólica não é um arquivo normal. A linha %s possui %d campos (esperado "
"%<PRIuMAX>)."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Está a converter o arquivo %s para o formato do sistema de ficheiros "
"Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Está a convertir o arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Está a convertir o arquivo `%s' para o formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Está a convertir o arquivo %s “%s” para formato de texto plano Unix...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Đang chuyển đổi tập tin %s “%s” sang định dạng Unix %s…\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Está a convertir o arquivo %s em um arquivo de texto no formato Mac..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Está a converter o arquivo %s para o formato Mac %s...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Está a convertir o arquivo %s “%s” para formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Está a convertir o arquivo %s “%s” para formato DOS..."

msgid "problems converting file %s to file %s\n"
msgstr "Fazendo a conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrar problemas ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O 'CA' escolheu a opção -i ou --info, mas foi detectado um erro."

msgid "active code page: %d\n"
msgstr "Página de trabalho ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s não é válida."

msgid "option '%s' requires an argument\n"
msgstr "Fora de opção '%s' é necessário um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"Falha na análise de entrada/saída padrão (stdin/stdout): 'Codificação da "
"visualização %s' não é válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi definido no modo de arquivo novo."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Cadeia de caracteres inválida. Substitua abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: Cadeia de caracteres inválida. Campo insuficiente para o valor."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
