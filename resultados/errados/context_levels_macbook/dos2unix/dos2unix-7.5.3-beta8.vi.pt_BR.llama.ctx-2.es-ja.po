msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrado problema ao resolver o link simbólico '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Gabriel encontrou um erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gặp lỗi khi thay đổi quyền hạn của tập tin đầu ra tạm %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O proprietário ou grupo de propriedade do arquivo %s não tem permissão para "
"modificar o conteúdo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "encontrou problemas ao renomear o nome do arquivo '%s' para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o destino desse link simbólico '%s' é o objetivo 'JA'."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda permanece no “%s”."

msgid "Skipping binary file %s\n"
msgstr ""
"Borrando o arquivo binário %s do conjunto de dados separado por linhas"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a largura do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Bordem o arquivo UTF-16 %s, houve um erro na conversão de UTF-16 no registro"
" da linha %u. Para mais informações, tente 'cmd --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Bordem o arquivo UTF-16 %s, conversão para UTF-16 não é suportada nesta "
"versão do programa %s. Para obter mais informações sobre as opções "
"disponíveis e a compatibilidade dos formatos de texto, tente 'program "
"--help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "%s está sendo ignorada, não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra {%s} e o arquivo de saída é um simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra este link simbólico fino %s, o objetivo dele não é um arquivo regular."
" \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link curto %s, destino do link simbólico %s não é um arquivo "
"regular. A opção '%c' inválida."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Já está convertendo o arquivo %s para o arquivo \"%s\" no formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "A conversão do arquivo “%s” para o formato Unix está em andamento…"

