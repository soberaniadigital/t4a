msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Cách dúvida: %s [opções] [arquivos ...] [-n infile outfile ...]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         cho phép thay đổi chủ sở hữu tập tin"

msgid " -ascii                default conversion mode\n"
msgstr ""
"-ascii                chave de conversão padrão para caracteres ASCII único "
"(linha por linha)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converter entre o sistema DOS e a codificação "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizando página de codificação do Windows 1252 (Tây "
"Âu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando página de codificação DOS 437 (US) "
"(padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                Dúvida código página DOS 850 (Tây Bình) © utilizar"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando página de código DOS 860 (Boha Diau) do "
"Português Brasileiro\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "-863                utilizando página DOS 863 (francesa do Canadá)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizando página DOS 865 (Bacia do Danúbio) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converter de caracteres 8 bits para 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --keep-bom        Preservar o Byte Order Mark (BOM) originalmente "
"inserido no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --keep-bom         Preservar o “Byte Order Mark” (marca de byte) por "
"padrão."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:\n"
"audio (ascii, 7bit, iso, mac)\n"
"média (ascii, 7bit, iso, mac) [default: ascii]"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação de mensagem para exibição\n"
"   bárragem mãe:\n"
"ansi (padrão), unicode ou utf8\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--adicionar-eol   adicione um caractere de nova linha ao final da linha se "
"não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           bắt buộc chuyển đổi các tập tin nhị phân\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Ajuda disponível para este comando."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do arquivo\n"
"   tập tin ...            para análise de conjuntos de dados"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        giúp mua ngày tháng tập tin đầu ra"

msgid " -L, --license         display software license\n"
msgstr "-L, --license         Exibir licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "-m, --add-bom         adicione ‘Byte Order Mark’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          novo arquivo\n"
"tape-in-write      tape-in original no modo de criação do novo arquivo\n"
"tape-out            tape-out em modo criativo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar o proprietário do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona dáfines ao final do último caractere se "
"não houver delimitadores (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout --to\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định)\n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"-q, --quiet           modo silencioso, suprimindo todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      apagar o “Byte Order Mark” (por padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r, --remove-bom      apagar o “Byte Order Mark” (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     giúmar bảng mã UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose, -v        exibição detalhada dos logs"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  シンボリックリンクを辿り、対象を変換する"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay liên kết mềm bằng tập tin đã chuyển đổi\n"
"                   (các tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    ignorar símbolos de ligação maciça e manter o estado "
"original (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostrar versão do programa\n"

