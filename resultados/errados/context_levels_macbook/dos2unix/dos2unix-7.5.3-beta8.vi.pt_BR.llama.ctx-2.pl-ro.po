msgid "Windows 32 bit version (MSVC %d).\n"
msgstr ""
"Fenomenal, você está fazendo uma pergunta interessante. No entries "
"oferecidos para a tradução de texto em português do trecho fornecido acima."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha de versão do sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr ""
"Fenomenal, mas acho que você está errado. O 'soquete' é um termo técnico e "
"não deve ser traduzido para o português."

msgid "%s version.\n"
msgstr "Fenomeno %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "O suporte ao Unicode UTF-16 é necessário."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có suporte para o nome do arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome do arquivo Unicode."

msgid "With native language support.\n"
msgstr "Có suporte para a língua materna."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Với hỗ trợ giữ nguyên người và nhóm sở hữu tập tin.\n"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Não há suporte para o usuário e grupo de arquivos."

