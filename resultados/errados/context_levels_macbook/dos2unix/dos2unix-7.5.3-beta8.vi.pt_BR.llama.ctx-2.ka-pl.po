msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preservar o marcador de byte order mark (BOM) "
"original do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preserva o sinalizador BOM (Byte Order Mark) padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de convergência ASCII, 7bit,"
" ISO, MAC, molduras padrões como ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir alertas de erro e aviso\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final da última linha se não houver nenhum,"
" usando o parâmetro -e ou --add-eol."

msgid " -f, --force           force conversion of binary files\n"
msgstr "Use o parâmetro --force para forçar a conversão de arquivos binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte a codificação UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "opção inválida -- '%s' não permite argumento\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỌ]        hiển thị tập tin ... các bảng chữa trúc"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção --keepdate        preserva o dia da última modificação do arquivo de "
"saída (stdout)"

msgid " -L, --license         display software license\n"
msgstr "opção -L, --license         wyświetlenie licenças de software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicionar “Marca de Ordem” (dodanie znacznika "
"BOM) UTF-8 padrão"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         ახალ ფაილში ჩაწერა პაროვნული ფაილი ახალი-ფაილის რეჟიმში\n"
"   tập-tin-vàou პაროვნული ტანზი შესვლა და გამოყვარხავს პაროვნული ტანზი\n"
"   tập-tin-ra პაროვნული ტანზი შესვლა და გამოყვარხავს პაროვნული ტანზი"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"não é permitido alterar o proprietário do arquivo (padrão) para a conta de "
"usuário root."

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dáfima (não acrescenta um caractere de "
"nova linha) se nenhum delimitador for encontrado no final da linha."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặt địa phương) \n"
"   plik ...            cái tập tin cần chuyển đổi trong chế độ tập tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"opção silenciosa -q, --quiet           tentação de chumbo, desligamento "
"mínimo de mensagens"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      remoção do indicador BOM (byte order mark) "
"padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remoção do indicador BOM (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção segura -s, --safe            bỏ qua tập tin nhị phân (mặt chết)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar o código UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rẽ định dạng đầu vào é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "Use --verbose para obter informações detalhadas sobre o processo."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink, para seguir links simbólicos e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink zastępowanie dowiązań symbolicznych plików wynikowymi"
" (các tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    giữ liên kết mềm và đích không thay đổi (mặc định)\n"

