msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de autenticação do sistema operacional (OS): %s [opções] [-n "
"tabela_de_verificação página.txt ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite a alteração de permissões do proprietário para o arquivo %s"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                domyślny tryb konwersji"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                    converte o texto entre DOS e ISO-8859-1"

