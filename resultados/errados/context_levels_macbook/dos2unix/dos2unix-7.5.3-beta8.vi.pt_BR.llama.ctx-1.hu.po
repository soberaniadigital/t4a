msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Cómo usar: %s [opções] [arquivos …] [-n tápico_tín ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         fájltulajdonjog megváltoztatásának engedélyezése\n"

msgid " -ascii                default conversion mode\n"
msgstr "-ascii                chaveamento de estado padrão (chaveado)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  átalakítás DOS và ISO-8859-1 karakterkészlet között"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               Windows 1252 (codificação de caracteres do Windows) "
"usada para o sistema operacional Tây Âu."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando código de caracteres DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                DOS 850 (Tây Âu) usado com trang mã\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando o sistema operacional DOS 860 (Bồ Đào Nha)"
" \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                DUMA DE TRANSMISSÃO DO SISTEMA DOS 863 (França - "
"Canadá/Dinamarca)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    conversão de caracteres para bits, utilizando um bit "
"menos por caractere (6bit)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --manter o BOM original        guarda a sequência de bytes do Byte Order "
"Mark"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --manter-BOM        guarda o “Marca de Ordem dos Bits” (por padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de modo de conversão\n"
"   modo de conversão:\n"
"audio (ascii, 7bit), iso-8859-1 (iso, 8bit),\n"
"escape sequences ISO/IEC 646: Latin 1 (mac, mặc định là ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"bảng mã:\tansi, unicode, utf8, mặc định là tansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar ponto e vírgula ao final do texto se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           obrigatório para converter arquivos de múltiplas partes"
" binária\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Ajuda disponível nesta opção de ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibição de informações do arquivo\n"
"   ficheiro …            lista dos ficheiros que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        mantém o dia e mês original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         exibição do aviso de licença"

msgid " -l, --newline         add additional newline\n"
msgstr "-l --novo_linha         adição de nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marca de Ordem do Byte’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (por "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona dáfines ao final do último caractere se "
"não houver delimitadores (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gere o arquivo antigo (método padrão) \n"
"   tabela ...            as tabes de dados precisam ser convertidas no modo do banco de dados antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           chave de modo silencioso, suprimindo todas as "
"mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"-r --remover-bom      gomo o 'Marca de Ordem do Byte' (másculo definido)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --remover-bom      gelo bônus para remoção do 'Byte Order Mark'"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"-s --seguro            apagar arquivos divididos em duas partes (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     giúme bảng mã UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le coi régando que o formato de entrada óbjeto seja "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na suposição de que o formato do dado de "
"entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "-v --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink o seguimento de símbolos e a transformação dos "
"objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    ignorar símbolos macios e links não modificáveis "
"(opção padrão)"

