msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópias de segurança para %s [câmbio] [arquivo ...] [-n tápítan udfil …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento ASCII padrão (default)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  cadeia de caracteres entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               Windows-1252 kódlap használata (Nyugat-európai)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                Utilizando tabela de codificação DOS 432 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                DOS 850 (Tây Âu) usando trângulo de codificação do "
"sistema operacional\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                Dúvida sobre o uso do Tratamento de Extensões (TSE) "
"no sistema operacional MS-DOS em português."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                Dúvida sobre o uso do Tratamento de Mensagens (TDM) "
"no sistema operacional dos EUA, por favor forneça mais informações."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                Dúvida sobre o código de fuso horário do sistema "
"operacional (DOS) no formato BAHRAINIAN PORTUGUESE."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o padrão ASCII"
" (8 bits) \n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúme nguyên “Byte Order Mark” (BOM) -b, --keep-bom        behold byte-"
"rækkefølge-markering (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o byte order mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão ASCII/7bit/ISO/mac/padrão é o "
"ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação de exibição para os avisos do log\n"
"   kodering     ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção --add-eol   adicionar dóvio de nova linha ao final da entrada se não "
"estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn chuyển đổi c/%s binárias em tập tin nhị phân\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            ajuda nesta ação"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o ficheiro de entrada\n"
"   Ficheiro …                identificar os campos a serem analisados."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantém o dia de criação original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         licença de software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicionar o byte order mark (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin vào         tập tin gốc trong chế độ tập tin-mới\n"
"tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite alteração de propriedade do arquivo "
"(padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona dóis vírgula no final se não houver "
"delimitador de linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout -O, --to-stdout ghi vào đầu ra tiêu chuẩn."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gere o arquivo antigo (método padrão) \n"
"   ficheiro …            filtro para conversão de tabelas no estado do arquivo velho"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           estado silencioso, sem aviso de erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o byte order mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o byte order mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar a tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng định dạng đầu vào là UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguimento de símbolos e a conversão dos "
"objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos mínimos e fixos (padrão) "
"\n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         verzião do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro de texto em formato Plain Text (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica do DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr ""
"Ficheiro de texto para o sistema operacional DOS em versão 32 bits "
"(WATCOMC).\n"

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do Phiên bản DOS 32 bit (DJGPP).\n"

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenômeno Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản da versão Windows de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para arquitetura de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenômeno Windows de 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de versão %s."

msgid "With Unicode UTF-16 support.\n"
msgstr ""
"Có hospedar Unicode UTF-16. Para obter mais informações, tente `%s --help' "
"para mais detalhes."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có horação de apoio para Unicode files."

msgid "Without Unicode file name support.\n"
msgstr ""
"Não há suporte para o nome do arquivo em UTF-8. Para obter mais informações,"
" tente '`%s --help'."

msgid "With native language support.\n"
msgstr "Có horação de apoio à localização do idioma nativo."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao usuário e à comunidade de proprietários do arquivo. Para "
"obter mais informações, tente '`%s --help'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Sem suporte ao direito de propriedade exclusiva do proprietário original e "
"da comunidade para o arquivo. Para obter mais informações, tente '`%s "
"--help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de entrada para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "%s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da opção inválida -- '%c'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como ferramenta para acessar o arquivo .txt\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar a permissão do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e/ou grupo que possui o arquivo %s não podem possuí-lo de forma"
" direta."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o diretório e grupo de trabalho do arquivo inicial %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o objetivo de conexão mínima para a referência simbólica '%s'."

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o código de erro %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o ficheiro UTF-16 %s, cuja medida em bytes do wchar_t não é igual a %d"
" byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão UTF-16 da tabela de caracteres %s, ocorreu um erro ao "
"converter a linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o ficheiro UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borraremos o arquivo %s, que não é um típico ficheiro. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico. O caminho para este arquivo "
"está no diretório de saída."

msgid "Skipping symbolic link %s.\n"
msgstr "Borraremos o link mais curto entre %s e %d. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o link mínimo %s, que não é um arquivo típico. A opção '%c' não "
"permite argumentos."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"A remessa de dados mínima, %s e o objetivo dela, que não é um arquivo "
"regular. Ao invés disso, ele representa uma conexão única entre dois pontos."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s para o formato Unix, ele será salvo como “%s”…"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Está a convertendo o arquivo de texto “%s” para formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato Mac, você pode usar a "
"ferramenta 'Transfofix'…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato DOS, você pode usar a ferramenta 'dos2unix' com as seguintes opções:\n"
"\t-f [file] -i (input file)\n"
"\t-o [output filename]\n"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo de texto '%s' para um formato Unix %s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto '%s' para o formato Mac, você pode usar a "
"ferramenta 'Transfere TXT', que é uma opção recomendada. Para mais "
"informações sobre como utilizar esta ferramenta e outras alternativas "
"disponíinflorceiria no link: https://www.example-link.com/transfer_txt"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Macintosh (Mac OS)…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Está a convertendo o arquivo %s “%s” para formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr "Está a fazendo o conversor de arquivo %s para arquivo %s"

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "página de trabalho atual: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"não foi possível realizar a conversão de %s sem erros. Por favor, verifique "
"se o formato é válido."

msgid "option '%s' requires an argument\n"
msgstr "Selecione “%s” requer um número inteiro"

msgid "invalid %s display encoding specified\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi definido no novo estado de ficheiro"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro de substituição incorreta. Substitua abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Substitua pelo valor anteriormente "
"especificado."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
