msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n input_file ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração do acesso ao arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                apenas para conversores de caracteres ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte entre DOS e codificações ISO-8859-1 para "
"campos (expectando %<PRIuMAX>)"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               Windows Code Page (Windows-1252) utilizado para "
"análise de texto em português."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Tecnobuf (437) para conversão de caracteres em português."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS Tecnoblock 850 (válido para Windows) em vez do Linux. Ou seja, use"
" `echo -e 'Hello World' | dos2unix"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS Tecnoblocks (863) para acessar as configurações do sistema "
"operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-teckentabell 865 (nordisk) para acessar as opções do sistema."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        ბაიტების მიხეთული შეტანდრების გამოჩვენა"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        ბაიტების მიხეთული შეტანდრები (მიჩიM) (стандарт)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        átalakítási mód   ascii, 7bit, iso, mac, standard "
"ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     megjelenítési kódolásának lehetőségek: ansi, unicode,"
" utf8. Ansi alapértelmezett."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr "opção --add-eol adicionar uma linha ao final do arquivo"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"Use o parâmetro --force para converter arquivos binários. Para mais "
"informações, tente `%s --help'."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        UTF-16-ის GB18030-რა გადაყვანა"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            vizualize este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformation\n"
"    ficheiro ...               arquivo de informações do sistema"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção -k, --keepdate         Georgia's file system (GFS) is a robust and "
"efficient way to manage files. It provides an alternative approach for "
"handling large-scale data processing tasks by using the GFSSD library."

msgid " -L, --license         display software license\n"
msgstr "opção -L, --license         პროგラმის ლიცენზიის გამოტანა"

msgid " -l, --newline         add additional newline\n"
msgstr "Use '--newline' para adicionar uma nova linha ao final da entrada."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         bájtsorrendjel hozzáadása (byte order mark) (standart"
" UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skriv till ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil              utmatningsfil i nyfilsläge"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais - OU, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         skribe para o arquivo antigo (padrão) \n"
"    file ...               carregar os campos do ficheiro original em um novo formato."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"opção silenciosa, ou seja, sem saída para o usuário -q, --quiet           "
"tela de erro/oktatály"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      marca de byte order mark (byte order mark) "
"[standard]"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o byte order mark (BOM) -r, --remove-bom      "
"bájtsorrendjel eltávolítása"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            hoppa över binära filer (standard)\n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 kódificação de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le féltételezze, hogy a bemeneti formátum UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utförlig drift"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  följ symboliska länkar och konvertera målen\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetze symbolische links mit convertidos arquivos "
"(os origina01 filen para os novos) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    szimbolikus linkek és célok változatlanul hagyása "
"(alapértelmezett) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         verzião do programa"

