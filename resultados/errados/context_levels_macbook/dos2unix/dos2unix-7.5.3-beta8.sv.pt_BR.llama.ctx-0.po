msgstr ""
"DENNA MJUKVARA TILLHANDAHÅLLS AV UPPHOVSRÄTTSINNEHAVAREN I ”BEFINTLIGT\n"
"SKICK” (AS IS) OCH ANSVAR FÖR UTTRYCKLIGA ELLER UNDERFÖRSTÅDDA,\n"
"INKLUSIVE, MEN INTE BEGRÄNSAT TILL UNDERFÖRSTÅDDA GARANTIER VID KÖP\n"
"OCH LÄMPLIGHET FÖR ETT VISST ÄNDAMÅL AVVISAS. INTE I NÅGOT FALL SKALL\n"
"UPPHOVSRÄTTSINNEHAVAREN VARA SKYLDIG UTGE ERSÄTTNING FÖR DIREKT,\n"
"INDIREKT, OFÖRUTSEDD, SPECIELL, EXEMPLARISK ELLER FÖLJDRELATERAD SKADA\n"
"(INKLUSIVE, MEN INTE BEGRÄNSAT TILL ANSKAFFNING AV ERSÄTTNINGSVAROR\n"
"ELLER TJÄNSTER; FÖRLUST AV ANVÄNDNING, DATA ELLER FÖRTJÄNST; ELLER\n"
"AVBROTT I VERKSAMHET) OAVSETT HUR DEN ORSAKATS OCH TEORIER OM ANSVAR,\n"
"OAVSETT OM SKRIVET I KONTRAKT, STRIKT SKYLDIGHET ELLER FÖRSEELSE\n"
"(INKLUSIVE OAKTSAMHET ELLER ANNAT) SOM PÅ NÅGOT SÄTT UPPSTÅTT VID\n"
"ANVÄNDNING AV DENNA MJUKVARA, ÄVEN OM UNDERRÄTTAD OM MÖJLIGHETEN FÖR\n"
"SÅDAN SKADA.\n"

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [arquivos …] [-n de entrada para saída …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alterações no acesso ao arquivo\n"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii               padrão de conversor ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"Conversão -ISO                   entre DOS e ISO-8859-1 codificações de "
"caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "-1252               utilize o Windows Code Page 1252 (vasta Europa) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilize o DOS Code Page 437 (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilize o DOS Tabular de Ordem 850 (teckenskaplig "
"europeisk)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilize a tabela de sinalização do DOS no estilo "
"português (tipo 860)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize a tabela de sinalização DOS em francês-"
"canadense (tabuletas de sinalização do sistema operacional MS-DOS) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize a tabela de sinalização DOS para o padrão do "
"norte (nórdico) da EET\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converterá %s bits de caracteres para campos %d\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        -preservar o byteordermark (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b --keepprom markando byte ordens (Byte Order Mark) padrão\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"-c, --convmode       modo de conversão\n"
"   modos de conversão ASCII, BIT7, ISO, MAC e padrão são ASCII."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
"-D,--display-encoding\n"
"    Especifica a codificação para textos visuais.\n"
"    Codificações aceitas:\n"
"        - ANSI (default)\n"
"        - Unicode\n"
"        - UTF8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--add-eol         adicionar uma quebra de linha final em caso de não haver "
"nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f --force           tvinga konvertering av binära filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h --ajuda Visar este texto de ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr "opção --info[=FLAGGOR] visa obter informações sobre o arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        mantém a data para o arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr "--licença\n"

msgid " -l, --newline         add additional newline\n"
msgstr "-l --novo_linha         adicionar linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"-m, --add-bom         adicionar marcação de byte (Byte Order Mark) para "
"UTF-8 padrão\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
"-n, --newfile         escrever em novo arquivo\n"
"   infiliar original no novo formato de arquivo\n"
"   sair com o arquivo de saída no novo formato de arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração de propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha no final da última "
"linha se ela não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --para stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
"-o --oldfile         escrever no arquivo antigo (padrão)\n"
"fil ...\n"
"filer para converter em versões mais antigas."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "-q --quiet, silêncio ou mudo para todas as mensagens de erro."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      Remove BOM (Byte Order Mark) (standard)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --remove BOM\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --seguro\n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     beholda UTF-16 teckenskodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "--assume-utf16le para supor que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "--assume-utf16be, para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "-v --verbose, utensidora de dados detalhada."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink seguir símbolos de ligação e converter a mensagem."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"--replace-symlink, substitui links simbólicos por arquivos convertidos\n"
"(originais dos arquivos de destino permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preserva sinais simbólicos e alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         visa versão número"

