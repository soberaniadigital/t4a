msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cácioando usa: %s [opções] [arquivos …] [-n tabelas_entrada tabelas_saida "
"...]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão para texto simples"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o conjunto de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               uso da trama em codificação Windows 1252 (Tây Dương)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                Uso da tela DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                uso da tela de código DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando a tela de código DOS 860 (do Brasil)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                uso da tela DOS 863 (Ca Na Da Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizando a tela de código DOS 865 (nordestina)   -865"
"                utilizando a tela de código DOS 865 (Baixo-Austrália)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    conversão de caracteres 8 bits para a região 7 bit"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preserva o Byte Order Mark (BOM) originalmente "
"inserido no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        zachowanie znacznika BOM (Byte Order Mark) (domyślne)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chéia modo de conversão\n"
"   chéia modo de conversão: ascii, 7bit, iso, mac; domyślnie ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definição da codificação de caracteres para exibição dos avisos\n"
"   codificações aceitas:            ansi, unicode, utf8; padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar o caractere de nova linha ao final da última "
"linha se não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório converter arquivos binários com base em "
"padrões de separação\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Ajuda nesta ação."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo \n"
"   tập tin ...            os arquivos para análise\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        giúp mua nguyên ngày tháng tập tin đầu ra"

msgid " -L, --license         display software license\n"
msgstr " -L --license         hiển thị giấy phép dùng program tương đối"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicionar nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione o “Byte Order Mark” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"táp-tin-vào          táp-tin gốc trong chế độ tập tin mới\n"
"táp-tin-ra           táp-tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"sem escolha de chmod nem gerenciamento do proprietário (padrão) para o "
"arquivo em questão."

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona um caractere de nova linha no final da "
"última linha se nenhum for encontrado (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào đầu ra tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           chéire o modo silencioso, minimizando todas as "
"notificações de erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      excluir 'Byte Order Mark' (padrão)\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      excluir o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            pomija linhas separadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     giúmar bảng mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le coi régando que o formato de entrada óbito seja "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi régando que o formato de entrada óbjeto seja "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink para conexão simbólica e conversão de objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thia substituição do link simbólico por um arquivo real\n"
"                         (os originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links móveis e objetivos sem alteração "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         Mostrar versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Fenômeno DOS 16 bits (WATCOM C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenômeno DOS 16 bit (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenômeno DOS 32 bits (WATCOM C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenômeno DOS 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Phiên bản Wersja MSYS."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenômeno Windows 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenômeno Windows 32 bit (MSVC %d).\n"

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Fenômeno %s. Wersja %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Esta interface oferece suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Olá! Eu sou um assistente virtual especializado em sistemas operacionais "
"baseados no GNU/Linux e ferramentas de linha de comando. Como posso ajudar "
"você hoje?"

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome de arquivo em Unicode."

msgid "With native language support.\n"
msgstr ""
"Esta ferramenta fornece suporte à localização de dados em idiomas nativos."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como suporte ao seu proprietário e grupo de arquivos. \n"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o proprietário original e grupo de arquivos. Para obter "
"mais informações, tente 'Không hỗ trợ giữ nguyên người và nhóm sở hữu tập "
"tin'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída temporária para o arquivo gerado está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Gravando BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "Ficheiro de entrada %s contém BOM %s. \n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"gabbi em %s quando tenta resolver o problema de divisão simbólica '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando o %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gerou erro ao alterar permissões temporárias do arquivo de saída pendente "
"%s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e a sua equipe de proprietários do arquivo %s não conseguem "
"manter o conteúdo original. Por favor, verifique as configurações para "
"garantir que você tem permissão adequada."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên `%s` thành `%s`:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o propósito dessa conexão de curto alcance simbólica '%s' é estabelecer uma "
"ligação rápida e segura entre dispositivos."

msgid "          output file remains in '%s'\n"
msgstr "teto de dados em “%s” contém o arquivo de saída ainda não processado."

msgid "Skipping binary file %s\n"
msgstr "Remova o conjunto de dados dividido em duas partes do arquivo %s"

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para o site %d. Por favor, entre em contato com a equipe de "
"atendimento ao cliente."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Remova o arquivo UTF-16 %s, cujo tamanho do caractere wchar_t não é de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, foi detectado um erro na conversão de UTF-16 "
"no registro da linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, converte para UTF-16 sem suporte nesta versão do "
"programa %s. A conversão de tabelas não é suportada em esta versão."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aqui não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico para o arquivo de saída %s."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link fino %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Remova o vínculo pequeno %s, objetivo dele não é um arquivo padrão. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Após remover o laço fino de ligação pequeno, %s e %s do link fino não são "
"componentes normais. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo \"%s\" no formato Unix"
" único...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo de texto “%s” para um formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo `%s` para o arquivo `%s`, no formato "
"Macintosh...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo \"%s\" para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo de texto '%s' para o formato DOS está em "
"andamento...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo \"%s\" para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Unix %s, "
"utilizando a codificação padrão...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Macintosh…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o conjunto de dados %s para um conjunto de dados no formato do "
"arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrou trunfo ao converter tabela %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "A bandeira '%c' para a opção -i ou --info está errada."

msgid "active code page: %d\n"
msgstr "A tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro na configuração de conversão %s não é válida"

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” yêu cầu một số de argumento\n"

msgid "invalid %s display encoding specified\n"
msgstr "O código de exibição do gráfico %s não é válido."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi definido no novo modo de armazenamento do "
"banco de dados."

msgid "can not read from input file: %s\n"
msgstr "não é possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível gravar no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Parâmetro inválido. Opção não fornecida."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Parâmetro inválido. Nenhum substituto encontrado."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
