msgstr "Phiên bản DOS de 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha de referência do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha de referência do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha de referência do Windows XP (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de testeio %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "O suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "O suporte para Unicode UTF-16."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para Unicode filename. \n"

msgid "With native language support.\n"
msgstr ""
"Olá! O sistema não pode encontrar o arquivo especificado. Por favor, "
"verifique se você digitou a pasta correta e tente novamente."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o acesso ao usuário e grupo. Para obter mais "
"informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "Erro ao escrever no arquivo de saída temporário %s:"

msgid "Writing %s BOM.\n"
msgstr "Estou gerando o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de caracteres UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de caracteres UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "Ocorreu um erro ao tentar resolver o problema simbólico '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está usando %s como arquivo temporal."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e a equipe de proprietários do arquivo %s não podem obter "
"permissão para ler o conteúdo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o destino do link simbólico '%s' não é reconhecido."

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída permanece em '%s'."

msgid "Skipping binary file %s\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr "Não há suporte para o site %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borracho o arquivo UTF-16 %s, tamanho do wchar_t não é igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr "Ocorreu um erro de conversão para UTF-16 no arquivo %s, na linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)."

msgid "Skipping %s, not a regular file.\n"
msgstr "O arquivo '%s' não é um ficheiro regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico. O tamanho do caminho de "
"entrada/saída (%d) não pode ser maior que a memória disponível."

msgid "Skipping symbolic link %s.\n"
msgstr "Removendo o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Ocorreu um erro ao tentar abrir o arquivo %s. O caminho de entrada é "
"inválido."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Olá! O enlace simbólico %s não é um arquivo regular. A origem do link "
"simbólico %s não pode ser determinada."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para um arquivo no formato Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix... (cont.)"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato Mac, mas falhou. Por favor, "
"verifique se você digitou a opção correta."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Mac %.2fKB…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para um arquivo de texto no formato DOS... "
"(cont.)"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr "Estamos convertendo o arquivo %s para a linguagem C++."

msgid "problems converting file %s\n"
msgstr "encontrou problemas ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O '%%c' não é um valor válido para a opção '-i' ou --info."

msgid "active code page: %d\n"
msgstr "A tarefa está em execução no terminal %s."

msgid "invalid %s conversion mode specified\n"
msgstr "O modo de conversão %s não é válido."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na análise do arquivo %s. Ocorreu um erro ao tentar ler o conteúdo "
"deste."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não é possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro de sintaxe inválida. Ocorreu um erro ao substituir o parâmetro."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro de sintaxe inválida. Ocorreu um erro ao substituir o parâmetro."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"
