msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "program error, invalid conversion mode %d\n"
msgstr "Erro de programa, modo de conversão %d inválido."

