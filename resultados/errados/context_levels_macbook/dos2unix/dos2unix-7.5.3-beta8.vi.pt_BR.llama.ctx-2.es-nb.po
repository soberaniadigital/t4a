msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código utilizado: %s [opções] [-n tabela_de_entrada entrada.txt ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"converter de codificação entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação Windows-1252 (Vestfália) para acessar os "
"arquivos do sistema operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código de códigos DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS-850 (Tây Árabe) para acessar os dados do sistema operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS860 (Bồ Đào Nha) para acessar e manipular arquivos em sistemas "
"operacionais Windows."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS863 (Ca Na Da Pháp) para acessar as opções de saída padrão."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o DOS 865 (Baía Sul) para acessar as configurações do sistema "
"operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "Converta os caracteres de entrada para o espaço de bits de 7 (8 bits)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpia o Byte Order Mark (BOM) se desejar, use a opção '-b' ou '--keep-bom'."
" Para obter mais informações, tente '%s --help'."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "giúpia o Byte Order Mark (mặc định) -b, --keep-bom        behold"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de converção:   ASCII, 7bit, "
"ISO e MAC (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      define a codificação de mensagens para ansi, unicode"
" ou utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicione um dói no final da linha se não houver "
"nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de conversão dos arquivos binários -f, --force           forçar a "
"convergência dos ficheiros binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo de entrada ..."
"            ficheiros a analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a Marca de Orden do Byte (por defeito em "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreve em um novo arquivo de entrada (tập tin gốc) no modo do arquivo original\n"
"tipo-de-arquivo_de_entrada   arquivo original no modo de tập tin mới\n"
"tipo-de-arquivo_de_saida  arquivo de saída em novo formato"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown não permite alteração de propriedade do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dóis em linha final se nenhum "
"delimitador de linha (padrão) estiver presente\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão) \n"
"   ficheiro ...            arquivos a serem convertidos para o modo de arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todas as avisões"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "Removendo o Byte Order Mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga a Marca de Orden do Byte (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignora arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le supõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be supõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  segue por símbolos e converta os destinos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca os links simbólicos por arquivos convertidos "
"(os arquivos originas não são alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha a relação simbólica e o destino não alterado"
" (por padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número de versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS do WATCOMC em 16 bits."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS de 16 bits (TURBOC)."

