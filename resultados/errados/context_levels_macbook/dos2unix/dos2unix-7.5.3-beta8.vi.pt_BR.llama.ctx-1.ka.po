msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [cácioes de seleção] [banco de dados ...] [-n bancos de dados "
"vinculados a este área...]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         cho phép thay đổi chủ sở hữu tập tin"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chave de conversão padrão para caracteres ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converte o conjunto de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando código de caracteres Windows 1252 (Tây Âu)"
" \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                Usando o código de caracteres DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                DOS utilizando codificação de caracteres 850 (Tây Ái)"
" \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando trens de controle DOS 860 (Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                Usando o Trantoma DOS 863 (Ca Na Da Fap) "
"Gerenciamento do Código ISO/IEC 863"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizando o Trângulo de DOS em 865 (Norte)   -865"
"                utilizando o Trângulo de DOS no modo Batalhão, com base na "
"codificação do sistema operacional DOS"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de entrada/saída para o formato"
" de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        GiúMENTE do ‘Marca de Ordem da Bits’ (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b --keep-bom        বাইতেবিস মিমদের নিশ্চয় পালন (নাগুলিস্খ্যামেবিজি)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão para modos de convergência\n"
"   modo de conversão:    ASCII, BIT7, ISO, MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--adicionar-eol   adicione um caractere de nova linha no final da linha se "
"não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           bússola obrigatória para a conversão de arquivos nº6 "
"separados"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         변환 từ UTF-16 sang GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            hiérnia a ajuda nesta tarefa"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o conjunto de dados\n"
"   conjuntos de dados …            conjuntos de dados que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        giúp nguyên ngày tháng tập tin đầu ra"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         hipervisor de licença móvel"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         bó cria novo dòng mới\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione ‘Byte Order Mark’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não é permitido alterar o proprietário do arquivo de "
"origem (padrão) tápico"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dónde (newline) ao final da linha se "
"nenhum for encontrado (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --stdout ghi vào đầu ra tiêu chuẩn\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập-tin …            các tập tin cần chuyển đổi trong chế độ tập-tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r, --remove-bom      Remove 'Byte Order Mark' (método padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ბინარული ფაილების გამოტოვება (ნაგულისხმები)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     GIU BÁZAR MÃ UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rəng ใปวิดิติติอสิน หรืสโตริต"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rəndi dʃinj daɾindn gəvaniqs əng UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatórios detalhados"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  სიმბმულების მიყოლა და სამიზნეების გადაყვანა"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay liên kết mềm bằng tập tin đã chuyển đổi\n"
"                   (các tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    ignorar links simbólicos e seus objetivos fixos "
"(padrão)"

