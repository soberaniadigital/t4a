msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [ficheiro ...] [-n ficheiro_entrada "
"ficheiro_saida …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modul de conversão para ASCII -ascii implicitamente"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre os sistemas de codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilize o código de codificação Windows 1252 (Europa do Sul) para acessar "
"arquivos no formato UTF-8."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "utilize o código de codificação PDC (DOS) 437 (padrão) para"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"utilize o código page DOS 850 (Europa do Sul) para trabalhar com arquivos de"
" texto no Windows."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilize o código de codificação DOS 860 (Português) do Windows para acessar "
"arquivos no sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"utilize o código de codificação DOS 863 (Français Canadien) para este "
"trabalho."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"utilize o código de codificação DOS 865 (Nordique) para acessar os arquivos "
"do sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para espaço de 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preserva a marca de ordem dos bytes (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva a marca de ordem dos bytes (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   chave ASCII, 7bit, ISO ou MAC "
"(padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      escolhe o código de codificare a fim de exibir mensagens textuais\n"
"   Codificação da tela:\n"
"   ânsi (padrão), unicode ou utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione uma quebra de linha no final da última linha se "
"não houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Forçar, --force           force a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            afiçae esse aviso\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FANION]   exibe as informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         afirma a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicione uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marca de ordem dos bytes (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva no novo arquivo\n"
"   fichier_entrée      ficheiro original neste modo \"novos ficheiros\"\n"
"   fichier_saida     ficheiro convertido neste modo \"novos ficheiros\""

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona uma quebra de linha no final se não houver um caractere de nova"
" linha (padrão) –"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreve no stdout a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặt chung) \n"
"   fi<NAME> ...        fi<NAME>"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modul silencio, suprimindo todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar a marca de ordem dos bytes (por defeito)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"gostaria de verificar se o arquivo está em um determinado formato. Se sim, "
"você pode usar a opção `--remove-bom` para remover os marcos de ordem dos "
"bytes."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignore files binary (default)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva o UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        emitir informações detalhadas sobre operações "
"realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Sempre que você encontrar um erro, por favor, informe o número de linhas do "
"arquivo (%d) e a mensagem associada para obter mais detalhes sobre esse "
"problema."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troque os links simbólicos por arquivos convertidos (ficheiros originais permanecem inalterados) \n"
"(arquivos de destino original não sofrerão alterações)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserte as ligações simbólicas e links não "
"modificados (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro de texto não encontrado."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficheiro de texto não encontrado."

