msgstr "Ficheiro de configuração do MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Ficheiro não encontrado."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficheiro de texto não encontrado."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficheiro de texto para o Windows em sistema operacional (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficheiro de texto para o Windows em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficheiro de texto não encontrado."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha de versão Windows para sistemas com base em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro de log do sistema operacional OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro de log %s.%d."

msgid "With Unicode UTF-16 support.\n"
msgstr "Com suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "O suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Ajuda para a língua nativa. \n"

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como o sistema de arquivos permite acessar e manter os direitos dos usuários"
" individuais e grupos. Para isso, é necessário que você forneça as "
"credenciais do administrador para continuar."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Não há suporte para a propriedade de usuário e grupo do arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estamos gerindo o BOM %s. \n"

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Suponha que este seja um arquivo codificado em UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Suponha que este seja um arquivo de texto codificado em UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"falha na verificação da ligação simbólica '`%s' devido a um erro de "
"permissão insuficiente."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilize '%s' como ficheiro temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar as permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador ou o grupo de proprietários do arquivo %s não podem ser "
"preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo deste link simbólico, “%s”, é obter o valor do campo 'nome' da "
"variável '%d'"

msgid "          output file remains in '%s'\n"
msgstr "a saída do arquivo de entrada permanece no “%s”."

msgid "Skipping binary file %s\n"
msgstr ""
"Fiquei com dificuldades para encontrar o caminho de entrada do arquivo %s."

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Ignore o ficheiro UTF-16 %s, dimensão dele wchar_t é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Fique em silêncio, pois o arquivo UTF-16 %s não pode ser convertido na linha"
" %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borracho, você não tem permissão para acessar o arquivo UTF-16 %s. A "
"conversão de UTF-16 nesta versão do programa '%s' é obsoleta."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho, não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Se omita '%s', o ficheiro de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Ocorreu um erro ao tentar ler o arquivo '%s'. O sistema não consegue "
"encontrá-lo."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Ocorreu um erro ao tentar ler o arquivo simbólico %s, pois ele não é um "
"ficheiro regular."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu um erro ao tentar abrir o arquivo %s. O caminho de entrada/saída "
"'%s' não é válido."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a representação Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato DOS... (cont.)"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Fazendo a conversão do arquivo %s (%d) para o formato Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s (%d) para o formato Unix (%<PRIuMAX>)..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s (%d) para o formato Mac..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s (%d) para o formato Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo %s (%d) para o formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s (%d) para o formato DOS..."

msgid "problems converting file %s to file %s\n"
msgstr "Estamos convertendo o arquivo %s para o ficheiro %s."

msgid "problems converting file %s\n"
msgstr "encontrado um erro ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do ficheiro de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "fanion erroneamente inserido “%c” para a opção '-i' ou ‘--info’"

msgid "active code page: %d\n"
msgstr "página de código ativa em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de modo %s inválido"

msgid "option '%s' requires an argument\n"
msgstr "A opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na análise do arquivo %s, não foi possível obter o estado (stat) "
"deste."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Código inválido. O semi-código inferior está faltando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: Código inválido. O semi-código superior está faltando."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
