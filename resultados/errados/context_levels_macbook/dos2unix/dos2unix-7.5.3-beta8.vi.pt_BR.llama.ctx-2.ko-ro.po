msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Cómo usar: %s [opções] [-n input_file output_file ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modo -ascii                caminho de conversão implícita"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilizează pagina de codigo Windows 1252 (Europa do Sul) para o seu projeto."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "utilizează pagina de cod DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"utilizează pagina de cod DOS 850 (Europa do Sul)  # This is the original "
"text with a mistake in capitalization and incorrect term 'Europa' instead of"
" 'Sul'. The correct translation should be 'Europa Meridional', which refers "
"to Southern Europe. Also, I noticed that there are no variables or "
"placeholders like %s or %d present in this input string for me to translate."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilizează pagina de cod DOS 860 (Portugal) empregando o sistema operacional"
" do Windows."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "utilizează pagina de cod DOS 863 (França Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"utilizează pagina de cod DOS 865 (Brasil) utilizando o sistema operacional "
"Windows."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits em 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        保留 바이트 순서 표시(BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        giữ nguyên “Byte Order Mark” (mặc định)\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC, mínimo "
"definido como ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      defina o código de codificação utilizada para mensagens na tela\n"
"    Codificação da Tabela Máquina:\n"
"        ansi, unicode, utf8 (por padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não houver nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "forçar conversão de arquivos binários -f, --force\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help             Mostra este mensagem de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        hiển thị tính tin cập tại một số lượng chuyên gia "
"trong khuông viên"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate         preserva o nome do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license          Licença do programa\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marcação de byte order mark (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreve no novo arquivo\n"
"   fi<NAME>_intrare      fi<NAME>\n"
"   fi<NAME>"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração de propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona um caractere de nova linha no final da "
"última linha se não houver delimitador (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva no padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặt chung) \n"
"   fi<NAME> ...            các tập tin cũ được chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprime todas as mensagens de "
"aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      eliminar o “Byte Order Mark” (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      eliminar o “Byte Order Mark” (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             ignorar linhas de texto (método padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 codificação de maneira a ser mantida"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        exibe informações detalhadas sobre as operações "
"realizadas."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  심볼릭 링크를 따르며 대상을 변환합니다"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações simbólicas e links sem alteração"
" (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         hiçom số versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de versão DOS 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS 32 bits (Watcom C)."

