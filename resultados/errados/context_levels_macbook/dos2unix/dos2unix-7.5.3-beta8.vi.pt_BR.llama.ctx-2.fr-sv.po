msgstr "Remova o arquivo UTF-16 %s, a tamanho do wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr "Ocorreu um erro de conversão UTF-16 no ficheiro %s, na linha %u."

