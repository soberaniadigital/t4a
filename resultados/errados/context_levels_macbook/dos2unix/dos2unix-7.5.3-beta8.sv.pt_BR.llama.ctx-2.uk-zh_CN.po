msgstr ""
" --no-add-eol          não adicionar uma linha em branco após a última "
"linha, mesmo que ela esteja vazia (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro ...             os campos do arquivo que deseja converter\n"

