msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe             saltar sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar o UTF-16 codificação de caracteres"

