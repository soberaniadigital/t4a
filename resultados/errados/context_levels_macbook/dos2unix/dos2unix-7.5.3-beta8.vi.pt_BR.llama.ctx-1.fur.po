msgstr "Borrando o arquivo UTF-16 %s, a dimensão do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, se verificou um erro de conversão do formato "
"UTF-16 na linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para a versão não suportada deste "
"aplicativo. A conversão do formato UTF-16 neste caso é incompatível com esta"
" implementação."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra {%s}, aqui não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, pois ele é um link simbólico comum para a saída do "
"processo."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link fino %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Quando ocorre uma falha no link fino %s, seu objetivo não é simplesmente um "
"arquivo regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Seja removido o link curto %s, a destinação simbólica do link curto %s não é"
" um arquivo regular. \n"

