msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách de uso: %s [opções] [arquivo(s) ...] [-n nome_do_arq[voulação "
"file1.jentrade,file2.jessude]]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a modificação do proprietário (chown) da pasta"
" de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modalidade de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "-iso converte caracteres entre sistemas DOS e ISO-8859-1."

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando código de página Windows 1252 (Tây Âu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando código de caracteres DOS 437 (US) (definido "
"por padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando máquina de faturamento DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"-860                utilizando interface gráfica do sistema operacional DOS "
"860 (Brasil)   \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizando o sistema operacional DOS 863 (Sistema "
"Operacional Canadês francês)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizando o sistema operacional DOS 865 (Nordic)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte i caracteres de 8 bit para espaços de 7 bit"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o sinal de Byte Order Mark (marca do byte para"
" ordem)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b --manter o Byte Order Mark (mandatório)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:\n"
"acii, 7bit, iso, mac, mặc định là ascii\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens de teste\n"
"   codificações possíveis:\n"
"     ansi,\n"
"     unicode,\n"
"     utf8 (padrão: ansi),\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar ponto e virgula ao final da linha se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           bússola conversão dos arquivos binários nº de faixa\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030         converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            mostre chest test di jutori."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações do táp-tin\n"
"   de análise ...            dos cÁÇOs a serem processados."

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        manten a data original do arquivo de jessude\n"

msgid " -L, --license         display software license\n"
msgstr "-L --license         Mostre a licença do software aplicável."

msgid " -l, --newline         add additional newline\n"
msgstr "-l --novo.linha         Adicione uma nova linha."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione ‘Byte Order Mark’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a modificação do proprietário (padrão "
"definido) da pasta de arquivo."

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona o caractere de nova linha no final da "
"linha se nenhum for encontrado (padrão definido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to stdout       escrever no padrão de saída da tarefa\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tâp-tin …            các tập tin cần chuyển đổi trong chế độ tây-tín"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, desativando alertas e avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"-r --remover-bom      gelo bô ing sêgn do Bởi Ordem de Binário (Byte Order "
"Mark) (predefinît)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gelo bôn"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --seguro            exclua linhas do conjunto de dados (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     manten a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le com base na suposição de que o formato do input é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na suposição de que o formato do input é "
"UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        registração detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "-F, --follow-symlink o teo liên kết mềm và chuyển đổi đích."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink que substitui links simbólicos por arquivos reais e mantém os caminho originais inalterados\n"
"                   (arqüivos de destino permanecem não modificáveis)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    mantenha o link simbólico e as listagens invariáveis "
"(predefinido)"

