msgstr "O arquivo de saída ainda está presente em \"%s\"."

msgid "Skipping binary file %s\n"
msgstr "Borrando o conjunto de dados dividido em dois arquivos %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o conjunto de dados UTF-16 %s, cujo tamanho do wchar_t não é "
"necessariamente %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que causou um erro na conversão de UTF-16 no "
"registro %u. Para mais informações, tente 'borrar' com a opção --help."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, converte a codificação UTF-16 que não é suportada"
" nesta versão do %s. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra %s, aqui não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra {%s} e o arquivo de saída %s é um simboloico link."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação macia %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o símbolo de ligação pequeno %s, pois seu objetivo não é um arquivo "
"típico. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link curto %s, porque seu destino para um arquivo simbólico não é "
"normal. O objetivo do shortcut pequeno '%s' não pode ser uma pasta regular."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Ao converter o arquivo %s para a pasta “%s” no formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "A conversão do arquivo “%s” para o formato Unix está em andamento…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo “%s” para o formato Mac do Arquivos de um Disco, você"
" está recebendo a mensagem ‘JA’. Para obter mais informações sobre este "
"processo, tente executar 'konverterer fila %s til %s Mac-format …'."

msgid "converting file %s to Mac format...\n"
msgstr "A conversão do arquivo “%s” para o formato Mac está em andamento…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Acontece a conversão do arquivo “%s” para o formato de arquivo DOS, com base"
" no conteúdo deste mesmo arquivo…"

msgid "converting file %s to DOS format...\n"
msgstr "A conversão do arquivo “%s” para o formato DOS está em andamento…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s” no formato Unix está em "
"processo..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Unix %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato Mac do tipo de dados binários,"
" ..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s”, no formato DOS, está em "
"andamento..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "A conversão do arquivo %s “%s” para o formato DOS está em andamento…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"A conversão do arquivo %s para o arquivo %s foi iniciada. Se houver "
"problemas durante a conversão, por favor informe."

msgid "problems converting file %s\n"
msgstr "Encontrou trunfo ao converter tabela %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O flag '%c' para a opção '-i' ou '--info' foi utilizado incorretamente."

msgid "active code page: %d\n"
msgstr "A interface gráfica está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já foi enviado um modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” yêu cầu một đối số"

msgid "invalid %s display encoding specified\n"
msgstr "Já enviou uma tabela de visualização inválida %s."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no novo modo de abertura do "
"arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

