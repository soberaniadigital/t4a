msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite alterar proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converter de caracteres entre DOS e ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando página de codificação Windows 1252 (Tây "
"Ái) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa página de código DOS 437 (EUA) (por defecto)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar trens de codificação DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                usa trângulo DOS 860 (Bồ Đào Nha)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa trângulo de código DOS 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizar página de código DOS 865 (nao anglófona)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        manter o sinal de byte ordenação (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        manter o “Byte Order Mark” (padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão de caracteres\n"
"   modo de conversão de caracteres:\n"
"acii, 7bit, iso, mac, padrão é acii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir codificação para exibição dos avisos\n"
"   codificação:\tansi (padrão), unicode ou utf8\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar quebra de linha no final da linha se não houver"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos binários em "
"formatos separados por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16308        converter UTF-16 para GB16308\n"

msgid " -h, --help            display this help text\n"
msgstr "Ajuda - mostrar o texto desta ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do arquivo de texto\n"
"   ficheiro ...            ficheiros a analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        mantenha a data de criação do arquivo para o "
"resultado"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marca de Ordem dos Bits’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar a propriedade do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dente de amendoim ao final do último "
"carro se ele não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to_stdout       gerar saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão definido) \n"
"   arquivos ...            arquivos que precisam ser convertidos para o modo de arquivo antigo."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet\n"
"    modo silencioso, sem mensagens de aviso."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      excluir o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            borrar linhas separadas por ponto e virgula (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     manter a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régando que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi régando que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        registro detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o link simbólico e fazendo a conversão do "
"objetivo\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink que substitui links simbólicos por arquivos convertidos\n"
"                         (arquivos originais não serão modificados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha o link simbólico e não altere a relação "
"mútua (padrão) entre objetos"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão do software"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Fenômeno DOS 16 bits (WATCOM C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenômeno DOS 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenômeno DOS de 32 bits (WATCOM C)."

