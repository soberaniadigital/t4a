msgstr "Ficheiro não encontrado."

msgid "Cygwin version.\n"
msgstr "Ficheiro de origem do Cygwin. \n"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenômeno de Windows, versão em 64 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenômeno Windows, versão de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenômeno Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenômeno do Windows, versão de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenômeno de Windows, versão em 64 bits (MSVC %d).\n"

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficheiro de origem não encontrado."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro de origem para a versão OS/2 (WATCOMC).\n"

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro não encontrado."

msgid "%s version.\n"
msgstr "%s versão."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có hỗ trợ Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Suporte ao nome de arquivo em Unicode."

msgid "Without Unicode file name support.\n"
msgstr ""
"Senhoras e senhores, não há suporte para nomes de arquivos em formato "
"Unicode. Por favor, certifiquem-se de que os nomes dos seus arquivos estejam"
" no padrão ASCII."

msgid "With native language support.\n"
msgstr "Não há suporte para a língua nativa. Ajudar na localização."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao conservar a identidade e propriedade de grupo dos arquivos "
"para usuários originais."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o usuário original e a comunidade proprietária do"
" arquivo. \n"

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída excessivamente longo:"

msgid "Writing %s BOM.\n"
msgstr "Está escrevendo %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O ficheiro de entrada %s tem BOM %s. \n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Assumo a codificação UTF-16LE da tabela de caracteres."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução do link simbólico '\\"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporal: %s"

msgid "using %s as temporary file\n"
msgstr "está a utilizar %s como ficheiro temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gặp lỗi khi thay đổi quyền hạn của tập tin đầu ra tạm %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e o grupo de propriedade do arquivo %s não podem ser preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao converter o nome “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          cáio é o propósito do link fino simbólico «%s»\n"

msgid "          output file remains in '%s'\n"
msgstr "tápia de saída ainda está presente no arquivo \"%s\""

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo de dados separados por linha %s\n"

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para a página de código %d. Por favor, entre em contato com o"
" suporte técnico."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Borrando o arquivo UTF-16 %s, a medida do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, houve um erro ao converter dados UTF-16 na "
"linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a conversão para UTF-16 não é suportada "
"nesta versão deste software. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o %s, isso não é um arquivo normal. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Exclua o %s, o arquivo de saída inicial %s é um link fino. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando o link macio %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borrando o link macio %s, seu objetivo não é um arquivo padrão. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o vínculo fino %s, objetivo %s do vínculo fino que não é um arquivo "
"padrão. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Ao converter o arquivo %s para o arquivo \"%s\" no formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Ao converter o arquivo “%s” para o arquivo “%s”, em formato Mac...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Estamos convertendo o arquivo “%s” para o formato Mac...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Ao converter o arquivo “%s” para o arquivo “%s”, em formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo “%s” para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato do arquivo Unix "
"%s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Mac..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato do sistema de ficheiros DOS, "
"você pode utilizar a opção ‘--dos’. Para mais informações sobre como "
"realizar esta conversão, tente executar `%s --help'."

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato DOS %d está em processo...\n"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo %s, foram encontradas "
"problemas."

msgid "problems converting file %s\n"
msgstr "encontrado problemas ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O sinal de seleção do botão -i ou --info apresentou um erro. Por favor, "
"tente novamente."

msgid "active code page: %d\n"
msgstr "página de código ativa: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr "DEVELOPED an incorrect conversion mode for %s, which is not valid."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” yêu cầu một đối số"

msgid "invalid %s display encoding specified\n"
msgstr "Declarou uma tabela de exibição inválida %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi especificado no modo de arquivo novo."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o conteúdo do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível gastar dados no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: parâmetro inválido. Substituição faltando inferior."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"erro: parâmetro inválido. Permanecendo o valor anterior não permitido."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
