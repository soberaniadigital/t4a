msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cómo usar: %s [opções] [arquivos ...] [-n entrada_arq para salvar em arquivo"
" de saída ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento de caracteres padrão (modulo ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    conversão entre o conjunto de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilize a página de código Windows 1252 (Europa do "
"Leste)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                utilizează pagina de cod DOS 437 (SUA) (implicit)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizează pagina de cod DOS 860 (Portugal)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize a página de código DOS 863 (França Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize a página de código DOS 865 (Bacia do Danúbio)"
" \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits em 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        păstrează marcajul de ordine a octeților (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        păstrează marcajul de ordine a octeților (BOM) "
"(implicit)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão     ascii, 7bit, iso, mac (padrão"
" é ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de mensagens para exibição\n"
"   codificações possíveis: ansi, unicode, utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha final à última linha, se não houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           bússola ferramenta de conversão binária dos arquivos "
"divididos em duas partes"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            ajuda neste comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=COR]        exibe informações sobre o ficheiro de entrada ..."
"         Ficheiros para análise \n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva o dia de criação original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         afiça a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione uma linha nova suplementar"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marcação de Ordem” (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tái-tin_vào      tập tin gốc trong chế độ tập tin-mới\n"
"tái-tin_ra         tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite alteração do proprietário (por "
"padrão) da pasta de trabalho."

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma quebra de linha final se nenhuma "
"existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva o resultado para a saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gere o ficheiro antigo (por omissão) \n"
"   ficheiro ...            cadeia de comandos para converter em um arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprime todas as mensagens de "
"aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o “Byte Order Mark” (marcação de ordem dos "
"bytes) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM) do ficheiro."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva o código UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v --verbose        emitir aviso com detalhes sobre as operações "
"realizadas."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  a seguir os links simbólicos e converter o objetivo."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações simbólicas e a ordem de caminho "
"(método padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro de origem (%s) não foi encontrado."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficheiro de texto em modo DOS (16 bits) com Turbo C."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do Sistema Operacional DOS (32 bits) - Versão Watcom C."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficheiro de texto em Português (pt-BR)"

msgid "MSYS version.\n"
msgstr "Fenome de MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Fenome do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows para sistemas de 64 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome de base WATCOMC para Windows em 32 bits."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows em 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficheiro de texto para linguagem C# (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows para sistemas de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows de 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de referência %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr ""
"Hoje, o sistema suporta Unicode UTF-16. Para obter mais informações sobre "
"opções adicionais ou para solicitar ajuda, por favor, digite '--help'."

msgid "Without Unicode UTF-16 support.\n"
msgstr ""
"Não há suporte Unicode UTF-16. Para obter mais informações, tente '`%s "
"--help'."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode. \n"

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome do arquivo Unicode.fasta."

msgid "With native language support.\n"
msgstr "Não foi possível obter estado (stat) do arquivo %s."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como parte integrante do suporte ao usuário e proprietários de arquivos, o "
"sistema fornece assistência para a gestão dos direitos autorais."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Sem suporte para acesso e modificação de arquivos por usuários individuais "
"ou grupos. \n"

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Está gravando %s BOM. \n"

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"falha na divisão quando ocorre um erro ao processar a ligação simbólica mais"
" curta `"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como ficheiro temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gerou erro ao alterar a permissão do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e/ou grupo de proprietários do arquivo %s não podem possuí-lo. "
"Para obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Geralmente, ao converter o diretório de usuário e grupo do arquivo inicial "
"%s para outro local ou sistema operacional, podem surgir problemas com a "
"permissão dos campos da linha."

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o propósito especial do símbolo complexo “%s”."

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para o site %d. Para obter mais informações, tente `%s "
"--help'."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Borra o ficheiro UTF-16 %s, a dimensão do wchar_t não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão UTF-16 da linha %<PRIuMAX> devido a um erro de análise. "
"Linha %d."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o ficheiro UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho o arquivo %s, isso não é um ficheiro típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Remova o arquivo %s, ficheiro de saída é uma conexão simbólica. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borracho o vínculo curto %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o link mínimo %s, que não é um arquivo típico. A ligação sem esse "
"elemento pode levar a erros de execução."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Remova o link mínimo, que não é um arquivo regular. Se omito %s, as ligações"
" simbólicas menores demais podem causar problemas."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato Macintosh, você pode "
"usar a ferramenta 'Transfere' no menu Arquivos…"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo “%s” para o formato DOS, você pode usar a ferramenta "
"de conversão do Linux…"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Unix %s..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Unix (%s)..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Macintosh..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Mac (%s)..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estão convertendo o arquivo %s “%s” para o formato DOS (%d)...\n"

msgid "problems converting file %s to file %s\n"
msgstr "Está a traduzir o arquivo %s para o arquivo %s."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não é possível ler o arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "cógio o botão -i sau --info bị sair."

msgid "active code page: %d\n"
msgstr "página de atividade do código em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "option '%s' requires an argument\n"
msgstr "Para escolher a opção “%s”, é necessário um número inteiro."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi especificado no novo formato de ficheiro"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro de parâmetro inválido. O valor do argumento deve ser especificado."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cadeia de troca não é válida. Opção inválida -- parte superior."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
