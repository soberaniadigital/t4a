msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown permite o modificação de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modulo de conversão -ascii por padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre jogo de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilize a página de codificação Windows 1252 (Europa do Sul) para o seu "
"documento."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize a página de código DOS 437 (EUA) como padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"utilizează pagina de cod DOS 850 (Europa do Sul) para o processamento dos "
"dados."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "utilizează pagina de cod DOS 860 (Portugal)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "utilizează pagina de cod DOS 863 (França Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "utilize a página de código DOS 865 (Brasil) para o seu projeto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converter os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preserva o “marcação de ordem dos bytes” (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva o “Byte Order Mark” (marcação de ordem) "
"padrão (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   chave ASCII, 7bit, ISO, MAC, "
"por defeito para ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      establece a codificare utilizada para as mensagens "
"de erro e aviso\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"linha se não houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"forçar conversão de arquivos binários -f, --force           força converção "
"dos ficheiros binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra este mensagem de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        mostra as informações do arquivo ... c/n tápixe(s) a"
" analisar."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva a data de origem do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicione uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marca de ordem dos bytes (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva no novo arquivo\n"
"   táp-tin-vàu      fișier original numa versió nou\n"
"   táp-tin-ra           fișier de saída trong modul nou"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração da propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona um caractere de nova linha no final se "
"não houver nada a ser inserido (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva o resultado na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          adicione ao ficheiro antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, suprime tota aversões"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "eliminar o byte order mark (BOM) padrão por padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "eliminar o byte order mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            omet els fitxers binaris (per defecte)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assume que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assume que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        anuncia notificações detalhadas sobre operações "
"realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thiết kế chỉ lấy links simbólics (links symboliques) "
"de les que no tindrones originals. Les fitxers d'origen n'hanb ngay cầnà să "
"seanhnga được modificat."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e objetos (por padrão) \n"

