msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando `grep` para encontrar e exibir as linhas que contêm a "
"palavra 'error' em um arquivo de log. Se você não souber como usar este "
"comando, consulte os exemplos abaixo:"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "opção para conversão em ASCII - caminho padrão de convergência"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e setor de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (padrão europeu) para acessar os dados do "
"arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o codificador DOS 437 (padrão) para conversões de caracteres."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (padrão europeu) para acessar os dados do sistema "
"operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS-codetabel 860 (portugues) para acessar as pastas de trabalho."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS-codetabel 863 (français canadien)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-codetabel 865 (escandinavo) para acessar as informações do sistema"
" operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de 8 bits em espaços de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        păstreaja marca de ordem dos bytes (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preserva a marca de ordem dos bytes (Byte Order "
"Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        conversão de modulo   ascii, 7bit, iso ou mac, padrão"
" é 'ascii'"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stabilește codificarea utilizada para mensagens de "
"erro"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma linha em branco à última linha se não "
"houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "forçar conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "visar este ajuda texto"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformatie\n"
"   fi**sier(s) ...         fi**rmeiro(s) para analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção -k, --keepdate        păstrează marcajul de timp do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção --license         visa licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicione uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"adicionar marcação de ordem dos bytes (Byte Order Mark) para UTF-8 (padrão)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escreve em um novo arquivo\n"
"   infilar               o original no formato de entrada\n"
"   utfil                    o convertido no novo formato"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"Lembrem-se de que o argumento `--no-add-eol` não adiciona um newline à "
"última linha se nenhuma existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreve no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile         escrever no modo antigo (padrão) do arquivo %s"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silencio do sistema (tudo o que não é um erro), "
"suprima todas as avisas"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover marcação de ordem dos bytes (Byte Order Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      ta bort byteordningsmarkering (Byte Order Mark)\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     păstreaja UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        oferece informações detalhadas sobre as operações "
"realizadas."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   seguir links simbólicos e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzt symbolische links med convertidas (originais)"
" ficheiros sem alterar as origens\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e configurações de destino "
"modificadas (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr "versão -V, --version         mostra versão"

