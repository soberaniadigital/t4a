msgstr ""
"O ATOMICA DEFENSES, LLC (“Defensorias”) é uma empresa de defesa nuclear que "
"oferece serviços e produtos para avaliar riscos em sistemas críticos. O "
"objetivo deste documento é fornecer informações sobre as políticas "
"internacionais da Defense Advanced Technology Research and Development "
"Agency, Inc (“DART”) relacionadas ao uso de energia nuclear na defesa "
"nacional brasileira e no mundo todo."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [arquivos ...] [-n entrada/saída...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permesso para alterar o proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre os sinais de caráter DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilize o código de codificação do Windows 1252 (Tây Âu) para acessar os "
"arquivos."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código de codificação do DOS (US) -437 (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Utilize o código de codificação do DOS -850 (Tây Âu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilize o código de página DOS -860 (Português) do Windows em um ambiente "
"Unix/Linux."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o código de codificação do DOS -863 (Código Canadense Francês) para "
"acessar os dados em formato binário."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Utilize o código de codificação do DOS (Nordique) -865"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    convertei os caracteres de 8 bits para o espaço dos 7"
" bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"Opcion -b, --keep-bom         retenha o byte order mark original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        reteni bajtordo-markon (defaŭlto)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr " -c, --convmode         modo de conversão:   ASCII, 7bit, ISO ou mac\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      dá um modo para apresentar os avisos de texto "
"(ansi/unicode/utf8)   'ansi' por padrão"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha ao final da última linha se não houver nenhuma"
" existente, caso contrário, ocorre um erro."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"Perfil de usuário - Force a conversion of binary files to multiple formats "
"(--force)"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=INFO]        exiba as informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate         conserte a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license          mostra a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona linhas de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o byte order mark (por padrão com UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva no novo arquivo\n"
"   fichier_entrée      ficheiro original neste modo \"novos arquivos\"\n"
"   fichier_sortie     ficheiro de saída neste modo \"novos arquivos\""

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona uma quebra de linha no final se não houver um caractere de nova"
" linha (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       imprimir no stdout."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no ficheiro antigo (padrão) \n"
"   Ficheiro ...    dos arquivos a serem convertidos para o formato de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o sinal de ordem dos bytes (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      apagar o byte order mark (BOM) da linha de entrada"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             preterpasi duumajn dosierojn (defaŭlto)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte o UTF-16 em cache"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le supondo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção -F, --follow-symlink   para seguir links simbólicos e converter dados."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay từ liên kết mềm bặn (các tập tin dịch chuyển "
"hàng) sản xuất trong ilustracion được cung cấp, \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserve lienços simbólicos e alvos inalterados (por "
"padrão)"

