msgstr "O arquivo UTF-16 %s, o tamanho do 'wchar_t' não é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"O arquivo UTF-16 %s, teve um erro ao converter do formato UTF-16 na linha "
"%u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"O arquivo UTF-16 %s, a conversão para UTF-8 não é suportada nesta versão do "
"programa. Para obter mais informações, tente `%s --help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho, o arquivo %s não é um ficheiro regular. \n"

