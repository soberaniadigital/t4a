msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE USE: %s [opções] [arquivo ...] [-n arquivo_entrada arquivo_saida "
"...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite a modificação do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão \n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   conversão entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando código de caracteres Windows 1252 (Taiu)"
"    "

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizando código DOS 850 (Tây Âu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando interface gráfica do DOS 860 (Brasil) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando código DOS 863 (Português brasileiro) para"
" o sistema operacional MS-DOS em um ambiente de língua portuguesa no Brasil."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando código de ficheiro DOS 865 (Europa do "
"Norte)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para espaços de 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o sinal de byte ordenado (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        mantém o 'Byte Order Mark' (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de modo de conversão -c, --convmode         chave do modo de convergência\n"
"   modo de convergência:\n"
"ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens de alerta\n"
"   tabela de codificação:\n"
"ansi (padrão), unicode ou utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicione uma quebra de linha no final da linha se ela não "
"tiver um(a)\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           forçar conversão de arquivos binários em texto para "
"facilitar a análise e processamento subsequente."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16094         converte UTF-16 para GB16094\n"

msgid " -h, --help            display this help text\n"
msgstr "mostre chest test di jutori -h, --help"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações do táp-tin\n"
"   táp-tin …            os táp-tins que precisam de análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        manten a data original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         mostre a licença do software utilizável em formato de"
" papel"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar BOM (Byte Order Mark) padrão UTF-8 -m, --add-bom\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          cria novo arquivo de texto\n"
"   salva no formato original em um novo arquivo\n"
"   sai para o novo arquivo criado."

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (padrão) do "
"arquivo"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma quebra de linha no final do arquivo, "
"mesmo sem delimitadores (configuração padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       gera saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            os conjuntos de dados que precisam ser convertidos para o modo do arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave --quiet\n"
"    modo silencioso, sem apresentar avisos ou mensagens de erro."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      gelo o 'Byte Order Mark' (por padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gổ bỏ “BOM” (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            exclua linhas fracionadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     manten a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le com base na premissa de que o formato do arquivo "
"entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be com base na hipótese de que o formato do arquivo "
"entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        exibir detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o simbolo de ligação e convertendo a "
"localização alvo do arquivo"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca links simbolicas por arquivos convertidos. (os "
"originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha os simbolicos e links de símbolos sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versao         Mostre número da versão do software"

