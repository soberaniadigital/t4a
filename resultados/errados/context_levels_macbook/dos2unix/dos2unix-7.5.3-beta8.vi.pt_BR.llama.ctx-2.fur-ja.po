msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a modificação do proprietário (chmod u=) tápia"
" de dados"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  conversão completa de caracteres entre sistemas DOS e"
" ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar página de codificação Windows 1252 (Tây Dân "
"Thái) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de página DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizando o código page DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando interface gráfica do sistema DOS 860 (Bồ "
"Đào Nha)    "

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando página de código DOS 863 (frances "
"canadense) do Canadá Francês"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                Utilizar página de códigos DOS 865 (Europa do Norte) "
"para este sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de 8 bits para espaços de 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conservando o “Byte Order Mark” original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        manter o sinal do Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:    ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
"-D --display-enc      define a tabela de codificação para exibir mensagens\n"
"   table codec: ansi, unicode, utf8, default is ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"Adicionar uma quebra de linha no final da entrada se ela não já contiver, "
"opção --add-eol\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           obrigatório converter arquivos n-ais separados em "
"binário"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb --gb18030         converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            mostre o texto de ajuda neste comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações do táp-tin\n"
"   táp-tin ...            táp-tins que precisam de análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        manter a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exiba a licença do software gratuito"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione 'Byte Order Mark' (por padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite a alteração do proprietário do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona o caractere de nova linha no final da "
"linha se nenhum for encontrado (padrão definido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to stdout       ghi vào đầu ra tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi no arquivo antigo (padrão)\n"
"   tâp-tin ...            os campos que precisam ser convertidos neste modo de conversão para o formato do arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimindo todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      gelo o 'Marca de Ordem do Byte' (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            exclua linhas fracionadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     mantendo a tabela de codificação UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le com base na premissa de que o formato do input é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na premissa de que o formato do input é "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  シンボリックリンクを辿り、対象を変換する\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink quebra o simbolico e substitui por arquivo de texto convertido\n"
"                   (os arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    mantém a conexão macia e o objetivo fixo (método "
"padrão)"

msgid " -V, --version         display version number\n"
msgstr "--versao         Mostre versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS 16 bit (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS a versão de 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Phiên bản DOS a versão de 32 bits (DJGPP).\n"

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Fenômeno Cygwin. \n"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows a versão de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows a versão de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows a versão de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows a versão de 32 bits (MSVC %d).\n"

msgid "OS/2 version (Watcom C).\n"
msgstr "Fabricação do Phiên bản OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fabricação do Phiên bản OS/2 (EMX)."

msgid "%s version.\n"
msgstr "%s FUR. Version par %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Suporte Unicode para nome de arquivo."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte ao nome de arquivo em formato Unicode."

msgid "With native language support.\n"
msgstr "Có hỗ trợ bản địa hóa ngôn ngữ."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao proprietário original e grupo de propriedade do arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e grupo de segurança do "
"arquivo.txt."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo gerado é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s tem o BOM %s. Para mais informações, tente `%s "
"--help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrou um erro ao resolver o simbolico link pequeno '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Ocorreu um erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr ""
"estamos utilizando %s como arquivo temporário para armazenamento de dados."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar a permissão do arquivo de saída"
" temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "O proprietário do arquivo %s não tem permissão para modificá-lo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên “%s” thành “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "este é o propósito do pequeno símbolo de ligação '%s'"

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda contém dados no “%s”."

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados separados por linhas %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a largura do wchar_t não é necessariamente de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Bordem o arquivo UTF-16 %s, houve erro na conversão de UTF-16 no registro "
"%u. Para mais informações, tente `%s --help'. Se quiser cancelar a operação,"
" pressione _Cancelar."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do programa de %s. Para obter mais informações sobre a conversão "
"entre codificações e as opções disponíveis no seu sistema operacional, "
"consulte 'man localeconv'."

msgid "Skipping %s, not a regular file.\n"
msgstr "%s está sendo omitida. Não é um arquivo típico."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra {%s}, o arquivo de saída %s é um simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o simbolico link pequeno %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico %s, que não é um arquivo regular. Seu destino não "
"pode ser uma pasta típica."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link simbolico %s, que possui destino para um arquivo regular. O "
"destino do link simbolico mêm não é uma pasta típica."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo \"%s\", você está utilizando a "
"ferramenta Unix."

msgid "converting file %s to Unix format...\n"
msgstr "A conversão do arquivo “%s” para o formato Unix está em andamento…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo `%s` para o arquivo `%s`, no formato "
"Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "A conversão do arquivo “%s” para o formato Mac está em andamento…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo “%s” para o arquivo “%s”, no formato DOS, está em "
"andamento…"

msgid "converting file %s to DOS format...\n"
msgstr "A conversão do arquivo “%s” para o formato DOS está em andamento...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s” no formato Unix está em "
"processo...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para a representação Unix do tipo "
"%s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s” no formato Macintosh está"
" em andamento..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão Macintosh...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s” no formato DOS está em "
"processo...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato DOS de %s está em andamento…"

msgid "problems converting file %s to file %s\n"
msgstr "Ao converter o arquivo %s para o arquivo %s, houve problemas."

msgid "problems converting file %s\n"
msgstr "encontrou tricô ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O comando '%c' para a opção -i ou --info foi inserido incorretamente."

msgid "active code page: %d\n"
msgstr "A tela está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "já foi enviado o modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "Túm escolha a opção '%s' e solicite um número de exemplo."

msgid "invalid %s display encoding specified\n"
msgstr "Já foi enviado uma tabela de visualização inválida %s\n"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de criação novo do arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Cadeia de substituição inválida. Substituição incompleta."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"erro: Cadeia de substituição inválida. Falta uma sequência alternativa."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
