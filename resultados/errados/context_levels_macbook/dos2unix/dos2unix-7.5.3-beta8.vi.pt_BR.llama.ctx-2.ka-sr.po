msgstr "Estamos convertendo o arquivo %s para a estrutura de dados Unix..."

msgid "converting file %s to Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo de texto “%s” para a representação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo “%s” para a estrutura de dados do Mac OS X "
"(darwin) em formato JSON..."

msgid "converting file %s to Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo de texto “%s” para a versão Macintosh..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo “%s” para o formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo “%s” para o formato DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a estrutura de dados Unix '%s'..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a representação Unix do formato %s..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo '%s' para a foma de formato Mac no formato "
"'%s'. Para obter mais informações, tente `%s --help`."

msgid "converting %s file %s to %s Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a versão Macintosh do formato .m3u8, "
"por favor, aguarde..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo '%s' para a versão DOS do formato 'Dos2Csv', "
"mas não conseguimos encontrar um módulo de conversão adequado. Por favor, "
"informe-nos sobre como converter este documento."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para a formação DOS... (cont.)"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para tabela de dados (%d) atualizando a "
"entrada do campo '%s'."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

