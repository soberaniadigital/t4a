msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Borra o arquivo UTF-16 '%s', que não é um byte de tamanho %d."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão de UTF-16 para o dado '%s', chegou ao final do processo "
"%u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Remova o arquivo UTF-16 '%s', pois ele não é suportado nesta versão do "
"aplicativo 'УТФ-16'. Para obter mais informações, tente `%s --help'."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Este arquivo não é um ficheiro de texto padrão. Para obter mais informações,"
" tente `%s --help'."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico para a data de cadastro do "
"usuário '%s'."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova a conexão mútua. (English) - Remova a ligação mutua."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"A ligação entre %s e o arquivo não é uma conexão padrão. Para obter mais "
"informações, tente `%s --help'."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Obrigado, mas não consigo encontrar nenhuma tradução para o texto fornecido."
" Por favor, tente novamente."

