msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [-n tabela_de_dados...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"permite o chmod para a propriedade de um arquivo ou diretório, permitindo "
"que ele seja alterado por outros usuários."

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo ASCII baseado em texto"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando o código de status DOS/437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                DOS-ის კოდის გვერდის 850 (დასავლეთ-ევროპული) "
"გამოყენება"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o código DOS 860 (Bồ Đào Nha) para acessar este documento."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o código DOS 865 (Baía da Bósnia e Herzegovina) para acessar as "
"informações sobre os dados de entrada do usuário."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preservar o byte order mark (BOM) original do "
"arquivo"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom        preservar o byte order mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         режим претварања:   аскри, 7бита, "
"исо, мек, подразумева аскри"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir alertas\n"
"   bảng mã: ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adiciona dógrao de linha final ao fim do último "
"elemento se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"Use o parâmetro --force para forçar a conversão de arquivos binários em "
"diferentes formatos."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         변환 UTF-16를 GB18030로 전처리합니다."

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=ARQUIVOS]        apresenta informações sobre o arquivo ... "
"cópia de trabalho para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção --keepdate        preservar a data original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr "opção -L, --license         licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         thêm “Byte Order Mark” (mặc định UTF-8)\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         ახალი ფაილში შეჩენა დათმობილური პარკაZero საქა "
"translates to: {"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona o dói final se não houver um caractere de nova linha (padrão) "
"nesta linha."

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -O, --to-stdout       imprimir no stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập tin ...            các tập tin cần chuyển đổi trong chế độ tập tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem saída de mensagens"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção --remove-bom      apagar o byte order mark (padrão) do arquivo de "
"texto."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      apagar o byte order mark (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"opção segura -s, --safe            preserva o arquivo de entrada (mínimo) "
"como está."

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi rằng định dạng đầu vào ჩათვლა არიდებული UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rẽ định dạng đầu vào ჩათვლა ასოციქEventListener "
"დასხებულიანი UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anuncios de erro"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Sempre que você encontrar um erro, por favor, informe o número de linhas do "
"arquivo (%s) e a posição da mensagem para facilitar nossa identificação. Por"
" exemplo, se estiver em uma pasta com vários diretórios aninhados dentro "
"dela."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    ignorar links simbólicos e diretórios (mínimo) "
"(opcional)"

msgid " -V, --version         display version number\n"
msgstr ""
"opção -V, --version         apresenta o número de versões disponíinfls do "
"programa."

