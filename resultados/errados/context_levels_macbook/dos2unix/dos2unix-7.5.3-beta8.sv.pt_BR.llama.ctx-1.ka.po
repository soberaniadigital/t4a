msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n <nome do arquivo> ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterações no acesso ao proprietário para o "
"arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversor de caracteres"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converte entre DOS e ISO-8859-1 codificações de "
"caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar o Windows Code Page (1252) para caracteres "
"do Reino Unido"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tabela de codificação DOS do Windows (USA)"
" (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a tabela de codificação DOS 850 "
"(dos/europeu)    "

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar a tabela de sinalização DOS do Windows 860 "
"(portuguesa)    "

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize a tabela de sinalização DOS (DOS) com o "
"código 863 (franco-canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize a tabela de codificação DOS/Windows 865 "
"(nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o padrão "
"BITS/7\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservar marcação de byte (Byte Order Mark) do BOM"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        ბაიტების მიხედვების შენარჩუნება (Byte Order Mark) "
"(стандарт) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        convergência de modos\n"
"   modo de conversão     ASCII, Bits/7bit, ISO, MAC, padrões ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stável em codificação para textos multilíngues\n"
"   kodning             ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--adicionar-eol         adicione uma quebra de linha no final da última "
"linha, se não houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           tvinga konvertering av binära filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            verificar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa informar sobre o arquivo fil ...               "
"analisando o arquivo de entrada"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva o timestamp do arquivo de entrada"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         visa o programa para obter a licença do sistema "
"operacional\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         Adicionar linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marcação de byte ordenação (Byte Order "
"Mark) para UTF-8\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         ახალ ფაილში ჩაწერა\n"
"   შეყვპაილი              საწყისი ფაილი ახალ-ფაილის რეჟიმში\n"
"   გამოპატებული             გამოტანის ფაილი ახალ-ფაილის რეჟიმში"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterações no acesso ao arquivo (estado)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha na última linha se "
"ela já existir\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout -O, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"    file ...                     salvar os dados em um formato anterior\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           estado silencioso, desabilita todas as avisões de "
"erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção --remove-bom      remover marca de byte ordenação (Byte Order Mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      remover marcação de byte order (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            saltos sobre binárias (arquivos)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar UTF-16 codificação de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le fica assumido que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be fica assumido que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        realizar um fluxo de trabalho detalhado."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  följ symboliska länkar och konvertera målen"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(as originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservando símbolos de links e alterações (métodos) "
"do objetivo padrão"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versões número"

