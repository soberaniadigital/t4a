msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [opções] [arquivo ...] [-n input_file output_file "
"…]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "opção --allow-chown         alterar proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converter para o padrão ISO-8859-1 do DOS"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               utilizar codificação Windows 1252 (Tây Dong) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar codificação DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                dùng trang mã DOS 863 (Ca Na Đa Pháp)\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para base octal a partir dos "
"8 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        conserte o “Byte Order Mark” originalmente presente "
"(BOM) no arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        conserte o “Byte Order Mark” (marca de ordem de "
"bytes) padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ascii, 7bit, iso, mac, padrão é"
" 'ascii'"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8 (mặc dụ là ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar uma quebra de linha no final da última linha se "
"não estiver presente"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocar conversão de arquivos binários em formato "
"separado por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "opção --help             esta ajuda de texto"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=BR]        exibir informações sobre o arquivo\n"
"   ficheiro ...            tabelas de dados para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr "opção --license          software licença mostrar"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline          adicionar novo separador de linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom          adicionar o Byte Order Mark (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo\n"
"   tabela de entrada no modo do novo arquivo\n"
"   saída para o novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "opção não permitir alteração do proprietário de arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dógrau de quebra na última linha, se "
"ele não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          salvar no arquivo antigo (padrão) \n"
"   ficheiro ...            os ficheiros para converter em modo de backup-versao\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           silenciar todas as warnings\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      remover o “Byte Order Mark” (por padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom       remover o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             binaire bestanden overslaan (standaard)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rãn que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        relatório detalhado emitir"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   para seguir links simbólicos e converter objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substituir links simbólicos por arquivos convertidos "
"(as originais permanecerão inalterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha as ligações simbólicas e objetivos sem "
"alterações (por padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         apresentar versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha técnica do DOS 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de versão para DOS, 16 bits (TurboC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do DOS em versão para Windows, de 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do DOS 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Fenome do MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Fenome do Cygwin. \n"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows para 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha técnica do Windows para sistemas de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows para arquitetura de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows para 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome do Windows para 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro não encontrado."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro não encontrado."

msgid "%s version.\n"
msgstr "Ficha de modelo %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Forneça suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Có hospedar básico de localização. Para obter mais informações, tente '`%s "
"--help'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como suporte ao proprietário e grupo de arquivos."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o armazenamento de proprietário e grupo do arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de entrada para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Está gravando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s contém um BOM. Para obter mais informações, tente "
"`%s --help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de codificação é UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação é UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "gặp lỗi khi phân giải liên kết mềm “%s”\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utiliza o arquivo %s como ferramenta temporária."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo de arquivos %s não podem ser preservados no backup."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gerou erro ao alterar dono e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao renomear o arquivo '{}' para '{}':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo dessa ligação simbólica de curto alcance '%s' é o seguinte:"

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída permanece no local especificado em '%s'."

msgid "Skipping binary file %s\n"
msgstr "Remover o arquivo de dados binários %s."

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Remover o arquivo UTF-16 %s, tamanho do wchar_t não é igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Ocorreu erro ao converter UTF-16 do arquivo %s; ocorreu uma falha na "
"conversão de UTF-16 no registro %u. Para obter mais informações, tente `%s "
"--help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do software. Para obter mais informações sobre a conversão de "
"codificações, tente '`%s --help`'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o arquivo %s, isso não é um ficheiro regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Ocupação cancelada em %s, o arquivo de saída inicial %s é uma ligação "
"simbólica."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a conexão de símbolo %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a associação mínima %s, o objetivo dela não é um arquivo regular. "
"\n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu erro ao remover a ligação mínima %s, alvo da ligação mínima não é um"
" arquivo regular. Para obter mais informações, tente '`%s --help'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo o conversor de arquivo para a codificação Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Fazendo o conversor de arquivos, a tarefa envolve converter um arquivo "
"chamado `%s' para outro no formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo o conversor de arquivo para Mac...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo o conversor de arquivo para DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Fazendo o conversor de arquivo %s para o formato Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Unix (%s)..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Fazendo o conversor de arquivos %s para Mac, fica com a extensão .mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estão convertendo o arquivo %s “%s” para o formato Mac (%s)..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estão convertendo o arquivo %s “%s” para o formato DOS (%d)..."

msgid "problems converting file %s to file %s\n"
msgstr "Em processo de conversão do arquivo %s para o arquivo %s."

msgid "problems converting file %s\n"
msgstr "encontrar problemas ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "página de código ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falhou a conversão do %s para o modo de codificação especificado, pois esse "
"modo não é suportado."

msgid "option '%s' requires an argument\n"
msgstr "Para o parâmetro \"%s\" é necessário um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na análise de entrada (%s) opção inválida -- '%c' não permite argumento\n"
"Tente `%s --help' para mais informações.\n"
"Não foi possível obter estado (stat) do arquivo %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi definido no modo de novo arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "has %s BOM.\n"
msgstr "contém um BOM de Byte Order Mark (BOM)."

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"O arquivo UTF-16 %s não pode ser processado, pois a codificação atual da "
"região de linguagem é diferente do UTF-8."
