msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Método de uso: %s [opções] [-n tabela_de_dados ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar o proprietário de um arquivo ou "
"diretório."

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII -ascii                padrão de conversão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"ISO -iso                   converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o código de codificação Windows-1252 (Vestfália) para acessar as opções "
"do sistema."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação DOS 437 (US) como padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS-850 (Tây Árabe) para editar arquivos de texto."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS860 (Bồ Đào Nha) para editar arquivos de texto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o comando 'dúvida' para obter mais informações."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-865 (Bacau) para acessar as configurações do sistema."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para o código ASCII em base 8"
" bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservar o byte order mark (BOM) como parte do texto"
" de entrada."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preservar o byte order mark (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de converção:   ASCII, 7bit, "
"ISO, MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      endereça o código de exibição para as mensagens do log\n"
"   codificação: ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um dógrafo no final da linha se ele não existir\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia para o processo, ou seja, a força motriz que impulsiona "
"as atividades do sistema. A bateria é um componente essencial em sistemas "
"elétricos e eletrônicos devido à sua capacidade única de armazenar e liberar"
" energia rapidamente para alimentar dispositivos portáteis, como smartphones"
" ou tablets."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "Use --gb18030 para converter UTF-16 em GB18030."

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO]        exibe informações sobre o arquivo ...            "
"ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        preservar a data original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr "licença -L, --license         vis programvarelisens"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem do Bit” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adicionar dóis no final da linha se não houver delimitador de linha "
"(padrão) nesta última linha"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregue o arquivo de origem (padrão) \n"
"   ficheiro ...            os ficheiros que precisam ser convertidos no modo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem aviso de erros"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção para remover o byte order mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gỡ bỏ “Byte Order Mark”\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le anta atribui o formato de codificação UTF-16LE como "
"padrão."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção -F, --follow-symlink a seguir símbolos e converter links"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr "Não há informações suficientes para traduzir."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha o vínculo simbólico e a diretiva de "
"alteração (método padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         vis versjonsnummer"

