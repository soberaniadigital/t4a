msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando '%s' [opções] [-n diretório_entrada arquivo_saida ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         autoriza o alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre os sinais de caráter DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilize o código de codificação do Windows 1252 (Europa Ocidental) para "
"acessar as linhas da tabela."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando o código de página DOS (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "utilize o código page DOS 850 (padrão europeu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilize o código de página do DOS -860 (português)   -860                "
"utilize o código de paginação do DOS"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "utilize o código de página do DOS -863 (Código Canadense Francês)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Utilize o código de página do DOS (Nordique) -865."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres 8 bits para o espaço de 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        preserva o byte order mark (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preservar o sinal de byte order mark (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   modeo de converção: ascii, "
"7bit, iso, mac, mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      escolha o código de exibição para mostrar mensagens textuais (ansi, unicode, utf8) \n"
"                    codificação do painel de mensagens: ansi por padrão"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"linha se ele não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr "force a conversion of binary files"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            apresenta este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        hiển thị thông tin tập tin\n"
"   tập-tin …            các tập tin cần phân tích\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         affiche la licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona linhas de quebra de linha extras"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar o byte order mark (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona uma quebra de linha no final se não houver um caractere de nova"
" linha (padrão) nesta linha."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreve no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregue no ficheiro antigo (padrão) \n"
"   arquivo ...        arquivos para converter neste modo de conversor da versão anterior."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apaga o byte order mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga o byte order mark (BOM) do arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignorar arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte o UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suppose que o dado de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Sempre que você encontrar um erro, por favor informe o número de linhas do "
"arquivo (%s) e a mensagem associada para obter mais informações."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos (ficheiros originais permanecem inalterados) \n"
"                    (arquivos de entrada não sofrerão alterações)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserte links simbólicos e destaques (por padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número de versão"

