msgstr ""
"Ocorreu um erro ao tentar ler o arquivo '%s'. O caminho de entrada não é "
"válido."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu um erro ao tentar ler o arquivo '%s'. O caminho de entrada não é "
"válido."

