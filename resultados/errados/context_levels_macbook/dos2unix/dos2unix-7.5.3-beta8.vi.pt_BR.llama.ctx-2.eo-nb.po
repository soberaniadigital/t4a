msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso para o programa 'cachorro_mundo':\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permésses o acesso ao arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o código de codificação Windows-1252 (Vesteuropeisk) para acessar este "
"documento."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                dúvida DOS/DOS-kodpaĝo 437 (US) (máximo)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o código de fuso horário padrão do Brasil (BRT) - UTC/WET, que é a hora "
"local da cidade mais próxima ao norte. Para obter informações sobre as "
"opções disponíinflornece em português: 1234567890-01-01T00:00:00Z"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS860 (Bồ Đào Nha) para acessar seu sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                dùng trang mã DOS 863 (Ca Na Đa Pháp)\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Nordlandaj) para acessar os dados do sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o padrão "
"BINário/Decimal (B/D) usando a função `strtolower`."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"Opcion -b, --keep-bom        retenha o “marcação de byte ordenado” (BOM) "
"original\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        reteni bajtordo-markon (defaulto)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de converção:   ASCII, 7bit,"
" ISO ou 'mac' (defautas al ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adiciona banner para apresentação dos avisos\n"
"   codificação de texto padrão: 'ansi', 'unicode' ou 'utf8'\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final se não houver nenhuma presente "
"(--add-eol)"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia solar, também conhecida como painel fotovoltaico ou "
"célula solare é um componente essencial para a conversão eficiente da luz "
"solar em eletricidade. Ela converte radiação solar diretamente na superfície"
" do material sem necessitar de manutenção constante, oferecendo uma "
"alternativa sustentável ao combustível fóssil."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "Use o GB130216 para converter UTF-16 em GB18030."

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO]        exiba informações sobre o tipe de dados '%s' (%d) "
"dos fichiers %<PRIuMAX>."

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"Keep date        -k, --keepdate         conserte o dia de entrada do arquivo"

msgid " -L, --license         display software license\n"
msgstr "licença -L, --license         mostre a permissão do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “marca d’água de byte” (padrão UTF-8) "

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva no novo arquivo de entrada (tập tin gốc) e saída (tập tin ra) em um novo modo\n"
"   infile              input-data.txt         tập tin đầu vào trong chế độ tập tin mới\n"
"   outfile             output-data.txt       tập tin kết quả trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dóis vírgula na última linha se nenhum "
"delimitador de linha (padrão) estiver presente"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo de origem (máximo padrão) \n"
"   tabela ...            tabellen kutaniĝi en la dosiero ekzistanto"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem aviso de erros"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      remover o byte order mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"Remover o Byte Order Mark (BOM) -r, --remove-bom       forigi bẽtordo-markon"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "Saída em Português (pt-BR):"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16      retenha UTF-16-kodprezenton"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le traga o padrão UTF-16LE como dado de entrada."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   seguir símbolos e converter links"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr "EOF"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    giữ liên kết mềm và đích không thay đổi (mặc định)\n"

