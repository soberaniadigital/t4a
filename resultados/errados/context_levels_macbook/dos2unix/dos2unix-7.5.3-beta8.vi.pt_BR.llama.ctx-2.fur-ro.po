msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Códe de uso: %s [opções] [arquivos ...] [-n arquivo_entrada arquivo_saida "
"...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"conversão ISO para DOS -iso                   converte caracteres entre o "
"sistema de codificação dos ficheiros do MS-DOS e a codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilize a página de código do Windows 1252 (Europa "
"Ocidental)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilize a tabela de códigos DOS 432 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                dùng trang mã DOS 850 (Tây Âu)\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilize o trânslator de texto DOS 860 (Português do "
"Brasil) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize o trânsfere mãe DOS 863 (Canadês francês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize o trângulo de código DOS 865 (Bacia do "
"Danúbio) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits em espaço de 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preserva o sinal de Byte Order Mark original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva o “Byte Order Mark” (marcação de ordem dos "
"bytes) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC (padrão é"
" ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de exibição para mensagens do teste\n"
"   código de saída:\n"
"       ansi (padrão)\n"
"       unicode\n"
"       utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final da última linha, se não houver "
"nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           força a conversão dos arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda neste comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações sobre o arquivo de entrada\n"
"   ficheiro ...            dos campos desse tâp-tin para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exiba a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione marcação de ordem dos bytes (Byte Order "
"Mark) (definida por padrão como UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin rãi           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a modificação do proprietário "
"(padrão definido)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona uma quebra de linha final se nenhuma for "
"encontrada (padrão definido)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva no fluxo padrão de saída"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tâng tin cũ (mặc định) \n"
"   tâng-tin ...            fiixírs de converter em formato antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todas as advertências\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o “Byte Order Mark” (marcação de ordem dos "
"bytes) (predefinido)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            retire linhas de teste (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr ""
" -u, --keep-utf16     preserva a codificação UTF-16 do arquivo de texto."

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rã que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        emitir aviso com detalhes das operações realizadas."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  acompanha as ligações simbólicas e converte os "
"destinos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos\n"
"                   (arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações simbólicas e a relação fixa "
"(padrão) entre campos\n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍTON (WATCOM C)"

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenome do DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "FENDA DE PHÍNCE ANTIGO (WATCOM C) DOSSIER."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "FENDA DE PHÍNCE ANTIGO (DJGPP). Versiunea DOS pe 32 biți."

msgid "MSYS version.\n"
msgstr "Fenome de base MSYS."

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome de base do Windows para 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome de Versão a 32 bits do Windows (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome de base do Windows em 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "FENDA DE PHÍNCE ANTES DA CONFIGURAÇÃO DO SOCKET (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenome de Versão OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenome da Versão OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Fenome de %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Có suportar Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Có horação para o suporte de tamanho máximo (%<PRIuMAX>) do arquivo Unicode "
"'%s'."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nome de arquivo Unicode."

msgid "With native language support.\n"
msgstr "Olá! O suporte para a língua materna é 'FUR'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao usuário e grupo de proprietários para o arquivo original. "
"Para obter mais informações, tente '`%s --help'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para a propriedade de arquivos por parte do usuário e grupo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Fazendo o upload do BOM para %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"encontrou erro ao tentar resolver as ligações simbólicas do módulo '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Ocorreu um erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como ficheiro temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Encontrado erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e/ou grupo proprietário do arquivo %s não podem alterar o "
"conteúdo. Para obter mais informações, tente '`%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gerou erro ao alterar o proprietário e grupo do arquivo de saída temporária "
"%s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao alterar o nome do usuário para “%s” em vez de “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o objetivo da relação simbólica “%s”."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está no diretório “%s”."

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para a página %d. Para obter mais informações, tente '`%s "
"--help'."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Se o arquivo UTF-16 %s for removido, a dimensão do tipo wchar_t não é de %d "
"bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Se o arquivo UTF-16 %s for ignorado, é apresentado um erro de conversão "
"UTF-16 na linha %u. Para mais informações, tente `%s --help'. Se você quiser"
" cancelar a operação, pressione _Cancelar."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Se o arquivo UTF-16 %s for excluído, a conversão para UTF-8 não é suportada "
"nesta versão do programa."

msgid "Skipping %s, not a regular file.\n"
msgstr "Se omite %s, nu este um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Se omite a opção --%s, o arquivo de saída %s é uma conexão simbólica. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Remova a ligação fraca %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Se ocorrer uma falha na ligação fraca, a intenção não é um arquivo regular. "
"\n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Se ocorrer falha na conexão, a solução alternativa %s não é um arquivo "
"padrão. A causa pode ser que você tenha digitado erroneamente seu nome de "
"usuário e senha."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Está convertendo o arquivo %s para o formato de arquivo Unix chamado "
"'%s'...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Está convertendo o arquivo `%s' para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Macintosh..."

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de tabela ASCII no "
"estilo Unix...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Está a converter o arquivo %s “%s” para o formato Unix (%d)...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Macintosh..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Está a converter o arquivo %s para o formato Mac (%d)...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de ficheiro DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Está convertendo o arquivo %s para a versão DOS do formato... (continuação "
"necessária)"

msgid "problems converting file %s to file %s\n"
msgstr "Fazendo a conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrar trágem em processamento de dados ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O 'código' do comando '-i' ou '--info' foi interpretado incorretamente."

msgid "active code page: %d\n"
msgstr "Página de codificador ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Falha na conversão de %s, não é válido."

msgid "option '%s' requires an argument\n"
msgstr "Fora de opção '%s' é necessário um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr "o objetivo do arquivo %s não foi definido no novo formato de ficheiro"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o conteúdo do arquivo %s\n"

msgid "can not write to output file: %s\n"
msgstr "não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Cadeia de bytes não é válida. Substitua por baixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro de parâmetro inválido. O valor do argumento deve ser um número inteiro."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
