msgstr "Borra o arquivo binário %s\n"

msgid "code page %d is not supported.\n"
msgstr "Não há suporte para o código de erro %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s; a medida do 'wchar_t' não é igual ao tamanho de "
"um byte, que é %d."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Houve um erro ao apagar o arquivo UTF-16 %s; ocorreu uma falha na conversão "
"de UTF-16 no dado linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra qua távolo UTF-16 %s, converte o UTF-16 không subteniado nesta versió "
"de %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho o %s, isso não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borracho o %s, tabela de saída inicial é um link simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Borracho o laço mínimo %s. Para obter mais informações, tente `%s --help'."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borracho o link mínimo, %s; não é um documento típico. Aceitar a conexão sem"
" este tipo de ligação pode levar ao risco de segurança."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Remova o link mínimo, que é um elemento de ligação pequeno e não deve ser "
"considerado como uma pasta típica. A função deste tipo de arquivo é apenas "
"para conexão."

