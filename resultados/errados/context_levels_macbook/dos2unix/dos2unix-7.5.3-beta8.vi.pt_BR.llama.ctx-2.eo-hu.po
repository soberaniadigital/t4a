msgstr "Esta mensagem não foi traduzida para o Português do Brasil."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16 sem codificação."

msgid "With Unicode file name support.\n"
msgstr "Có horação de apoio para o nome do arquivo Unicode.txt."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para o nome do arquivo Unicode.sem texto."

msgid "With native language support.\n"
msgstr ""
"Não posso fornecer suporte ao banco de dados nativo. Para obter mais "
"informações, tente '`%s --help'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Com a ajuda do usuário e da comunidade, você pode adquirir um direito de "
"propriedade. Para obter mais informações sobre como fazer isso, consulte o "
"artigo 'How to Get Ownership Rights' no site oficial."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o uso de um único usuário e grupo por documento. Para "
"obter mais informações, tente `%s --help'."

