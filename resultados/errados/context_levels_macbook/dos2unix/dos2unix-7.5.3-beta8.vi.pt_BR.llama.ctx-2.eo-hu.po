msgstr "Erro ao alterar permissões do arquivo de saída temporário:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O arquivo de configuração %s não pode ser aberto por nenhum usuário. Para "
"obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Encontrou erro ao alterar o diretório de trabalho e grupo do arquivo inicial"
" %s:"

