msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Unix... (cont.)"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Mac OS X (DOS)…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Mac OS X…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato DOS está em "
"andamento...\n"

