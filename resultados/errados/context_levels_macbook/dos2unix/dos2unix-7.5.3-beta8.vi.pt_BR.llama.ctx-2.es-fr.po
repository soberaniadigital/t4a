msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [parâmetros] [arquivos ...] [-n arquivo_de_entrada "
"arquivo_saida ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         autoriza o alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "utilize a página de códigos Windows 1252 (Europa Ocidental)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código de página DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"utilize o código page DOS 850 (Tây Ásia) para acessar os arquivos de texto "
"do Windows."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "utilize o código de página DOS -860 (Português)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"utilize o código de página DOS 863 (Ca Na Đa Pháp) para acessar os arquivos "
"em um sistema operacional Windows."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "utilize o código de página DOS 865 (Nórdico) do Windows"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converteria os caracteres de 8 bits para espaço de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conserva a Marca de Orden do Byte (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom         conserva a Marca de Orden do Byte (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC, padrão é"
" ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      escolha o código de exibição para mostrar mensagens "
"textuais (ansi, unicode ou utf8; padrão ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   thêm dấu ngắt dòng vào dòng cuối cùng nếu không chưa có\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Forçar a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            apresenta esta ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỜ]        exibe as informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr ""
"bem-vindo ao terminal de comando do Linux, este documento fornece instruções"
" para o uso da ferramenta 'grep' no ambiente Unix/Linux. O objetivo é "
"traduzir as mensagens em inglês que explicam como utilizar a opção "
"`--newline` e `sed`, bem como quaisquer erros ou avisos potenciais ao usá-"
"los."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a Marca de Orden do Byte (por defeito em "
"UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreve em um novo arquivo\n"
"   fichier_de_entrada      ficheiro original no modo de criação do novo ficheiro\n"
"   fichier_saida       ficheiro de saída no modo de criação"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona uma quebra de linha no final se não houver um caractere de nova"
" linha (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       imprimir no stdout."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão) \n"
"   ficheiro ...         os ficheiros a serem convertidos para o modo de arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, suprime todas as advertências"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apaga a Marca de Orden do Byte (por defeito)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga a Marca de Orden do Byte (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignora arquivos binários (por defeito)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le supõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be supõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "Sua tradução aqui"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os links simbólicos por arquivos "
"convertidos (os arquivos originas permanecem inalterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserte os links simbólicos e seus destinos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         exibe o número de versão"

