msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [ficheiro …] [-n infile outfile …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         autoriza alterações no proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre sistemas de codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Utilize o código de codificação do Windows 1252 (EUA) para usar."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilize a codificação DOS (US) padrão (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "utilize a codificação DOS (codigo padrão) 850 europeu (Oeste)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use a tabela de codificação DOS 860 (português) para o Windows."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use a code page 863 do DOS (français canadien) para uso."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o código de página DOS 865 (nordique) para utilizar."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de 8 bits para o modo 7-bit."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom         guardar marca de ordem dos bytes (Marca de Ordem do"
" Byte)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom         marque byte order (byte order mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão   como ascii, 7bit, iso, mac, "
"padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     escolha o código de codificação para exibir mensagens"
" textuais (ansi, unicode ou utf8 [padrão é ansi])"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma quebra de linha ao final da última linha"
" se não houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Forçar, --force           força a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        convertem UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Visar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filenotas para mostrar informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserve a data da ficheiro de saída"

msgid " -L, --license         display software license\n"
msgstr "Visão geral do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline          adicionar linhas extras\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marca de byte ordenação (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever no novo arquivo\n"
"   infil       original_arquivo em um novo ficheiro\n"
"   outfil      saída de texto em um novo ficheiro"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não permite a alteração do proprietário de arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona uma quebra de linha na última linha se não houver nenhuma "
"(padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   fichier ...             os campos deste modo converterá"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar a marca de ordem dos bytes (Byte Order Mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover a marca de ordem dos bytes (Byte Order "
"Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             ignorar arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr ""
" -u, --keep-utf16     UTF-16 codificação de caracteres a ser preservada"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suponha que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        verbalizações"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  シンボリックリンクを辿る、対象を変換する"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui símbolos de links por arquivos convertidos "
"(ficheiros originais permanecem inalterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink     conservando links simbólicos e alterações de "
"destino (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão número"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Versão DOS 16 bits (WATCOM C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Versão DOS 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Versão DOS 32 bits (WATCOM C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Versão DOS 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Versão MSYS."

msgid "Cygwin version.\n"
msgstr "Versão Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Versão Windows 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Versão Windows 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Versão Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Versão Windows 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Versão Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Versão Windows 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Versão OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Versão OS/2 (EMX)."

msgid "%s version.\n"
msgstr "%s versão."

msgid "With Unicode UTF-16 support.\n"
msgstr "Apoio para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Sem suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Ajuda para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Sem suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Suporte para o idioma nativo. \n"

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Med suporte para preservar o proprietário e grupo do arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Sem suporte para preservar o proprietário e grupo do arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Escrita do %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"No arquivo de entrada %s contém um BOM. O número máximo permitido é %d."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Fora de UTF-16LE codificação utilizada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Fora de UTF-16BE codificação utilizada."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"falha na resolução do símbolo de ligação '%s' durante a solucionar o link "
"simbólico\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "falha na abertura do arquivo temporário de saída: %s"

msgid "using %s as temporary file\n"
msgstr "utilize %s como ficheiro temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na verificação da permissão do arquivo temporário de saída %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O arquivo '%s' não possui o usuário ou grupo proprietário definidos. Para "
"verificar, execute 'ls -l'. Se você deseja alterá-los, use os comandos "
"`chown` e `chgrp`."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"falha na verificação da alteração do proprietário e grupo para o arquivo "
"temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "falha na verificação da alteração do nome para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "qual é o alvo do símbolo de ligação '%s'?"

msgid "          output file remains in '%s'\n"
msgstr "a saída de texto permanece no arquivo '%s'."

msgid "Skipping binary file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Fiquei de mãos atrás, pois o tamanho do arquivo UTF-16 %s é inferior a %d "
"bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"falha na conversão UTF-16 da linha %<PRIuMAX> do arquivo %s, um erro de "
"codificação UTF-16 ocorreu em linha %d."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping %s, not a regular file.\n"
msgstr "Hoje em dia, %s não é um arquivo regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Fiquei em dúvida se o arquivo de saída %s é um link simbólico. O ficheiro de"
" saída %s é um símbolico."

msgid "Skipping symbolic link %s.\n"
msgstr "Fiquei de mãos atrás do símbolo lógico %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "converter o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "converter o arquivo %s para o formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "converter o arquivo %s para o formato Mac, por favor."

msgid "converting file %s to Mac format...\n"
msgstr "converter o arquivo %s para o formato Macintosh\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "converter o arquivo %s para o formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "converter o arquivo %s para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Convergir %s arquivo %s para o formato Unix..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "converterão o arquivo %s para o formato Unix '%d'..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Converting file %s to a Mac format..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "converterão o arquivo %s para o formato Mac %.2f"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "converterão o arquivo %s para o formato DOS..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "converterão o arquivo %s para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"falha na conversão do arquivo %s para o arquivo %s durante a operação de "
"conversão. Por favor, verifique se os campos estão corretamente formatados."

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O flago inválido '%c' para a opção '-i' ou --info"

msgid "active code page: %d\n"
msgstr "código de paginação ativo: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falha na verificação da conversão do modo %<PRIuMAX> para o formato de "
"entrada/saída padrão (stdin/stdout) devido a um erro no parâmetro '%s'"

msgid "option '%s' requires an argument\n"
msgstr "A opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr "O arquivo de entrada %s não foi especificado no modo novo ficheiro."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"
