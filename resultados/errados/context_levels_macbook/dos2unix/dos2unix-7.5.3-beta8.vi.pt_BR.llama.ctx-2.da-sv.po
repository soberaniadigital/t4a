msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [-n tabela_de_entrada ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para o padrão ISO-8859-1 entre DOS e UTF-8"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (Vesteuropa) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Use o codificador DOS 437 (padrão) para converter caracteres não ASCII em "
"UTF-8."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS850 (Tây Árabe) para converter um arquivo de texto em formato "
"ASCII."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS860 (Bồ Đào Nha) para acessar os dados do sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS863 (Ca Na Da) para acessar as informações do sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS865 (Baía Sul) para acessar os dados do sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterão os caracteres de bits 8 para 7, usando o comando 'sed'."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpia byteordermarkering (Byte Order Mark) -b, --keep-bom        behold "
"byte-rækkefølge-markering (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantenha o byte order mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chave de convergência:   ASCII, 7bit, "
"ISO, MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adiciona banner para exibir avisos de mensagens em "
"texto com codificação ansi/utf8 (padrão), unicode e utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicione um caractere de nova linha no final da última"
" linha se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia solar -f, --force           gennemtving omdannelse af "
"binære filer\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            visar denne hjælpetekst"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        visa informar t/c filtrado por %s e analisador de "
"campos câmeras (fil) para avaliar o impacto do fatores ambientais no "
"desempenho da rede. O objetivo é identificar se há diferenças significativas"
" entre as métricas em diferentes ambientes, como áreas urbanas versus rurais"
" e condições climáticas variadas."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        behold outputfils dato"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa o software licenciamento"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marcação de byte order mark (byteordermark)"
" (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          skriv til ny fil\n"
"   táp-tin-vào      táp tin gốc i nhiều lầm trong chế độ táp-tin mới\n"
"   táp-tin-ra           táp tin đầu ra i nhiều lầm trong chế độ táp-tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dado ao final de uma linha se nenhum "
"delimitador (padrão) não for encontrado."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"   file ...                    filtrar para o estado do arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           silêncio, tímea tilbagehold alle advarsler\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o byte order mark (byteordermarkering) padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o byte order mark (byteordermark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16-kodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi rão que o formato de entrada deve ser UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise/analisando"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink theo liên kết mềm và chuyển đổi đích"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar o link simbólico mínimo e as alterações não"
" permitidas (padrão) \n"

