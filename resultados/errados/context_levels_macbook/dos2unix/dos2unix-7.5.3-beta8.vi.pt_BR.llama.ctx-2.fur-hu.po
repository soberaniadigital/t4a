"Olá! O software FUR é uma ferramenta de análise que permite a você verificar"
" se um arquivo está corrompido. Para iniciar o processo, execute 'FUR "
"--check' para executar automaticamente essa função."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópias de segurança para %s [opções] [arquivos ...] [-n t_fich_entrada "
"f_chambre-junta ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "opção --allow-chown permite a modificação do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão -iso                   de caracteres entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação Windows 1252 (Tây Dương) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizando código de página DOS 850 (Tây Ásia)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando o terminal de comando DOS 860 (Português "
"Brasileiro)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                DOS 863 (Ca Na Đa Pháp) usando o trânslator de código"
" francês para a língua portuguesa."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando o código de página DOS 865 (Nordic)    \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o formato de 7 "
"bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o segn de ordem original do Byte (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        manten segn di ordin dal Byte Order Mark (mặc định) "
"\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão: ascii, 7bit, iso, mac, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de mensagens para exibição dos "
"avisos     opções de codificação: ansi, unicode, utf8, padrão (ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"Adicionar uma quebra de linha no final do último caractere se não houver "
"(\"%s\") ou (\"--add-eol\"))."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           bússola de força para conversão dos arquivos binários"
" em formato ficheiro"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostre ajuda nesta ação"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CAMINHO]        exiba informações do caminho para o ficheiro de"
" entrada ...            mostre as informações dos arquivos que precisam ser "
"analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha a data original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar o Byte Order Mark (marca de ordem do byte) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin vào          tập tin gốc trong chế độ tập tin-mới\n"
"tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a modificação do proprietário "
"(predefinido) da pasta de trabalho\n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dóisng final (não inclui trailer newline "
"se nenhum for presente) (definição padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo padrão de saída\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi em tânga cũ (mặc định) \n"
"   tâng-tin ...            fông khác nhau trong chế độ tâng-tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimindo avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o sinal de byte ordenação (byte order mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      gelo bônus da ordem do byte (Marca de Ordem dos Bits)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguimento de símbolos e a conversão dos "
"objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos reais (substituindo os caminhos relativamente à origem) \n"
"                   (arquivos de destino permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha o link simbólico e as listagens invariantes "
"(predefinido) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Fenômeno do DOS em 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenome do Sistema Operacional DOS (16 bits) - TURBOC."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do DOS em 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "FENDA DE PHÍNCEANDO DO DOS 32 BITS (DJGPP)."

msgid "MSYS version.\n"
msgstr "FUR"

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenômeno do Windows a 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome do Windows a 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome do Windows a versão de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows a versão de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base do Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Fenome de %s. \n"

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr ""
"Não há suporte para Unicode UTF-16. Para obter mais informações, tente `%s "
"--help'."

msgid "With Unicode file name support.\n"
msgstr "Có horação de suporte para o nome do arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr ""
"Não há suporte para o nome do arquivo no formato Unicode. Para obter mais "
"informações, tente '`%s --help'."

msgid "With native language support.\n"
msgstr ""
"Có hospedar básico de dados. Para obter mais informações, tente `%s --help'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como parte do suporte ao usuário e à comunidade, o ficheiro é protegido por "
"direitos autorais. Para obter mais informações sobre como utilizar este "
"software ou para solicitar permissões de acesso, consulte as opções "
"disponíinflor 'Opções' no menu principal."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o acesso de usuários individuais e grupos proprietários "
"aos arquivos. Para obter mais informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de entrada para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Fazendo o upload do BOM para %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s possui BOM %s. Para obter mais informações, tente "
"`%s --help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação é UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da ligação simbólica mẽe %s\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como ferramenta para acessar o arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e/ou o grupo que possui a pasta %s não podem adquiri-la. Acesso"
" negado."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo de entrada inicial tâm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao alterar o nome do arquivo para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Este é o objetivo do link simbólico '%s'."

msgid "          output file remains in '%s'\n"
msgstr "tápia de entrada ainda está presente no arquivo “%s”"

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o site %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a dimensão do tipo wchar_t não é igual ao número "
"de bytes (%d).\n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Seja removido o arquivo UTF-16 %s, foi detectado um erro de conversão UTF-16"
" na linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra seu arquivo, pois este não é um típico ficheiro de texto."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link simbólico para o ficheiro de saída final."
" Aqui está mais informação sobre como utilizá-lo."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova o link simbólico mínimo %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borracho o link mínimo %s, a sua finalidade não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Seja removido o link curto, a destinação simbólica do link longo não é um "
"arquivo regular. A opção '--help' fornece mais informações.\n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Está convertendo o arquivo %s para o formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Está convertendo o arquivo `%s' para o formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Está convertendo o arquivo `%s' para o formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Está a convertendo o arquivo %s “%s” para formato de tabela Unix…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Está a convertendo o arquivo %s para o formato Unix do código fonte...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Está a convertendo o arquivo %s para um formato compatível com Mac, por "
"favor espere…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr ""
"Está convertendo o arquivo %s para a versão Macintosh do formato %s...\n"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Está a convertendo o arquivo %s “%s” para formato DOS %s…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Está a convertendo o arquivo %s para o formato DOS %s...\n"

msgid "problems converting file %s to file %s\n"
msgstr "Fazendo a conversão do arquivo %s para o arquivo %s."

msgid "problems converting file %s\n"
msgstr "encontrar tráfego de rede quando fazer conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O 'código' escolhido -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "A tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s não é válida."

msgid "option '%s' requires an argument\n"
msgstr "Fora de opção '%s' é necessário um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"Falha na análise de entrada/saída padrão do sistema operacional. O arquivo "
"%s não foi encontrado."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Cadeia de troca não é válida. Substitua por baixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: Cadeia de troca não é válida. Troca anteriormente especificada."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
