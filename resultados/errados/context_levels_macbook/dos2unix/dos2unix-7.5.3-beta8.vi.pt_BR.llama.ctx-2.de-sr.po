msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Caminho de uso: %s [seleções] [arquivos …] [-n arquivo_entrada para o "
"arquivo_saída …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a alteração do proprietário de um arquivo\n"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão para texto ASCII\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte o padrão de caracteres entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               usa página de codificação do Windows em 1252 (tây vui)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando página de codificação DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"-850                utilizando trângulo de codificação DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                usa tabela de caracteres DOS 860 (Bohio da Nobreza) "
"\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa tabela de códigos DOS 863 (francesco canadese) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                usa tabela de caracteres DOS 865 (Nordeste) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte c%<PRIuMAX> caracteres de %d bits para o "
"espaço de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        задржава назнаку поретка бајта"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o “Byte Order Mark” original (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode   modo de convergência: ascii, 7bit, iso, mac,"
" padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir codificação de exibição para mensagens visuais\n"
"   codificações possíveis: ansi, unicode, utf8, por padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar quebra de linha no final da linha se não tiver "
"ainda\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obriga a conversão de arquivos binários em formatos "
"separados por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         변환 UTF-16를 GB18030로 변경합니다."

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra esta ajuda para você."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações da tabela de dados (table of data)"
" para análise dos conjuntos de dados especificados em 'tabela-de-dados.txt'"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        conserva o dia de entrada da tabela de saída do "
"arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença para uso da interface gráfica"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona novo fim de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem da Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập tin ra             tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário de arquivos "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar quebra de linha no final da linha se ela"
" já não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave de impressão -q, --quiet           modo silencioso, suprimindo todas "
"as mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "gổ bỏ “Marca de Ordem da Bits” (mặc định) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            exclui linhas fracionadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     conserva tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le considera que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        mensagem detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  seguir links simbólicos e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos modificados "
"(as origens permanecem inalteradas)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva relação macia e objetivos fixos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra số hiệu da versão do software"

