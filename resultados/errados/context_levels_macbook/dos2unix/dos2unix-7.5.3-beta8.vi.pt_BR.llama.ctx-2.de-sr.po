msgstr "Ficheiro de origem (%s) não foi encontrado."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro de origem para o processamento do arquivo %s.%d (Watcom C).\n"

msgid "OS/2 version (EMX).\n"
