msgstr "tápia de saída com dados ainda restantes em »%s«"

msgid "Skipping binary file %s\n"
msgstr "Borramos o conjunto de dados divididos em dois arquivos %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, pois a largura do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que apresentou erro de conversão no dado da linha"
" %u. Ready."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para outro formato que este programa "
"não suporta nesta edição de %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, pois não é uma pasta típica. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Borrando o arquivo %s, a saída de texto inicial %s é uma ligação macia."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a associação macia de %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borra o vínculo mole %s, pois seu objetivo não é uma pasta regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o vínculo fino %s, objetivo %s do vínculo fino m%e não é uma pasta "
"regular. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo “%s” no formato "
"Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo “%s” para a representação Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Fazendo a conversão do arquivo de texto “%s” para o formato Mac, criando "
"assim o arquivo “%s”.\n"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo “%s” para o formato Mac…"

