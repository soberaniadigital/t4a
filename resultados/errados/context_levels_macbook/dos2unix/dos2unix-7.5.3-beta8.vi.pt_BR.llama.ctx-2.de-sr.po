msgstr "Erro: Parâmetro inválido. O valor necessário está faltando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Ocorreu falta na sequência superior."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
