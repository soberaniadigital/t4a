msgstr ""
"Fazendo a conversão da tabela de dados %s “%s” para o formato Unix %d…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Fazendo a conversão do arquivo de texto %s “%s” para o formato Mac, "
"representando o nome da data e hora como '%c'…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo a conversão da tabela de dados %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo de texto %s “%s” para o formato do sistema DOS '%s'…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Fazendo a conversão da tabela de dados %s “%s” para o formato DOS %d…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, foram encontrados problemas."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "o custo com a opção -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "página de trens atualmente em operação: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ja diri a configuração de conversão %s não é válida"

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn \"%s\" yêu cầu một đối số"

msgid "invalid %s display encoding specified\n"
msgstr "наведено је неисправно кодирање „%s“ приказа"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo da pasta %s não foi especificado no novo modo de datelimite."

