msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [flags] [files] [-n infile utfile …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         tilatar alteração do acesso ao arquivo para o "
"proprietário"

msgid " -ascii                default conversion mode\n"
msgstr "-ASCII -conversor de caracteres padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converteção entre codificações DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizar o código de caracteres Windows 1252 "
"(vesteuropeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizar o código de conversão DOS para a tabela do "
"Windows (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilize o tabuor DOS de codificação do padrão europeu"
" (vesteuropeisk) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizar o tabuor DOS de 860 (portugues) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize o tabuor DOS para a linha de código da versão"
" fransk-canadense 863\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar a tabela de sinalização DOS do sistema "
"operacional Nordisk\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converterá os sinais de bits para o padrão de bit a "
"menos (64)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --manter-byteorder\n"
"    behold byte order mark (BOM) �"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b --keep_bom        preserva o byte order mark (marca de ordem do byte) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        converte modos\n"
"   converterias os seguintes:\n"
"ascii (ASCII), 7bit (ISO 646), ISO e mac (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     endereça para codificação de mensagens textuais. "
"Codificações aceitas são ansi, unicode e utf8 (ansi é padrão).\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar uma quebra de linha no final da última "
"linha se nenhum for encontrado."

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           tvinga conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converterá UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            ver virar este auxílio texto"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGG]    visar informações sobre os arquivos a serem analisados\n"
"   fil ...               filas para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        mantenha o dado de data para arquivo de entrada"

msgid " -L, --license         display software license\n"
msgstr " -L --license         visa programvarulicensível"

msgid " -l, --newline         add additional newline\n"
msgstr "-l --novo_linha         adicionar uma linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"-m, --add-bom         adicione marcador de byte ordenação (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skriv til ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil               utmatningsfil i nyfilsläge\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permitir alteração de permissões do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicione linha final (EOL) se ela não estiver "
"presente\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   file …               os arquivos para serem convertidos em modo de leitura do arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"-r, --remove-bom      apagar marcação de byte order (marcação do Byte Order)"
" (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"-r, --remove-bom      apagar marcação de byte ordem (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            pular sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 teckenskodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le para supor que o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        utensário detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  seguir símbolos de ligação e converter módulos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui símbolos de ligação simbólica por arquivos "
"convertidos. (originais arquivos objetivo permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    mantém tanto sinais simbólicos quanto objetivos "
"alterados (padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V, --versão         visa versõesnumerais"

