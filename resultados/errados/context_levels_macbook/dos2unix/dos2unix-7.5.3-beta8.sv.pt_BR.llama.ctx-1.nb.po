msgstr "converterá a fila %s para o formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "converterá a %s-fila %s para %s-fila %s no formato Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "converterá a fila %s para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "converterá a %s-fila %s para %s-fila %s no formato DOS…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "converterá a fila %s para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr "falha na conversão de fila %s para %s"

msgid "problems converting file %s\n"
msgstr "falha na conversão da fila %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"A opção -i ou --info não é uma etiqueta válida para flags. Para obter mais "
"informações, tente 'NB'."

msgid "active code page: %d\n"
msgstr "activação do código de tabulação: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "modo de conversão inválido %s especificado"

msgid "option '%s' requires an argument\n"
msgstr "o flag '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "ogitiga codificação de %s anexada"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo para a fila %s não foi especificado em um novo layout de fileira."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever para o arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "feil: Ogiltigt surrogatpar. Den lägre delen av surrogatparet saknas."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "feil: Surrogatpar. O parâmetro surrogat está inválido.\n"
