msgstr "Forecê paraUTF-16LE encoding. \n"

msgid "Assuming UTF-16BE encoding.\n"
msgstr ""
"Forecêr UTF-16BE codificação. Para mais informações, tente `%s --help'."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução da ligação simbólica »%s«"

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"Não foi possível abrir o arquivo temporário de entrada/saída padrão: %s"

msgid "using %s as temporary file\n"
msgstr "utiliza %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Não foi possível alterar as permissões temporárias do arquivo de entrada %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"Ocupação de usuário/ou grupo para o arquivo %s não é preservada. Para obter "
"mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Não consegui alterar os administradores e grupos para o arquivo temporário "
"de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "quando '%s' trocou o nome para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Qual é o alvo para a ligação simbólica da '\\"

msgid "          output file remains in '%s'\n"
msgstr "utfil para ficar no lugar de '\"%s'."

msgid "Skipping binary file %s\n"
msgstr "Hoppar sobre o arquivo binário %s\n"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Hopper sobre o arquivo UTF-16-%s, tamanho do wchar_t é de %d bytes. \n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Hoppar över UTF-16-fil %s, en UTF-16-konverteringsfel inträffade på linje "
"%u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hoppar sobre o arquivo UTF-16 %s, a conversão de codificação UTF-16 não é "
"suportada nesta versão do programa."

msgid "Skipping %s, not a regular file.\n"
msgstr "Hopper sobre %s, não é um arquivo comum."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Hoppar sobre %s, o arquivo utfil %s é um símbolo de ligação. Para obter mais"
" informações, tente `%s --help'."

msgid "Skipping symbolic link %s.\n"
msgstr "Hoppar sobre o link simbólico %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Hopper sobre o link simbólico %s, o objetivo não é um arquivo regular. Para "
"obter mais informações, tente `%s --help'."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Hoppar sobre %s, o alvo para a referência simbólica %s não é um arquivo "
"comum. Para obter mais informações, tente `%s --help'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "converter fila %s para arquivo de texto no formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "converter fila %s para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "converter fila %s para o formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "converter fila %s para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "converter fila %s para arquivo em DOS format...\n"

msgid "converting file %s to DOS format...\n"
msgstr "converter a fila %s para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "converterá a %s-fila %s para %s-fila %s no formato Unix…"

