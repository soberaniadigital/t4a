msgstr ""
"Use o DOS865 (Baixo/Áustria) para acessar as informações sobre os campos da "
"linha %s."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para oito bits em sete bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        ჯერების მიხეთარ შეტანდzenით შევenta"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom         -b, --keep-bom        mantém o Byte Order Mark "
"(método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão:   modo de convergência ASCII, "
"'7bit', ISO ou MAC (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibição de mensagens (ansi, "
"unicode, utf8) (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar um dógrau de nova linha no final caso não "
"esteja presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"opção forçar           conversão de arquivos binários para o formato .npy "
"(NPY)"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Đioma GB18030 converter para UTF-16\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=ARQUIVOS]    informações sobre o arquivo ..."
"                     ARQUIVO...           analisar ficheiro(s) (arquivos)"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        mantenha o timestamp original do arquivo de entrada\n"

msgid " -L, --license         display software license\n"
msgstr "licença -L, --license         hiêng thị giấy phép dùng phần mềm"

msgid " -l, --newline         add additional newline\n"
msgstr ""
"opção -l, --newline         adicionar uma linha nova ao final do arquivo"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         thêm “Byte Order Mark” (mặc định UTF-8)\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "opção não permite chaveamento de diretório (chaves) para o arquivo %s"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr "--no-add-eol          không thêm dây ngắt trong cuốn sách (mặc định)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặt)           te converter em "
"formato de arquivo antigo-modus"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"opção silenciosa -q, --quiet           reduzir o ruído de mensagens não "
"importantes."

