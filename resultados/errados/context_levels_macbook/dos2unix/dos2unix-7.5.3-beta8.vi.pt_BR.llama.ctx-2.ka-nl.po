msgstr "opção --remove-bom      remover o Byte Order Mark (máscara padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      remover o Byte Order Mark (BOM) do arquivo"

