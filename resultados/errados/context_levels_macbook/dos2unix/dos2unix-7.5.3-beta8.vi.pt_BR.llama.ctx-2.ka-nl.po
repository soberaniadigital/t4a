msgstr ""
"opção segura -s, --safe            ბინარული ფაილების გამოტოვება "
"(ნაგულისხმები)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 codificação mantida"

