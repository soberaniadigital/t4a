msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dúvida: %s [cópias] [ficheiro …] [-n ficheiro-entrada saída-"
"departamento …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a alteração do proprietário do arquivo de "
"texto"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento de conversão padrão para caracteres "
"ASCII, sem transformações adicionais em linhas\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                    converte entre o sinal de DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizando página de codificação do Windows 1252 (Tây "
"Ái) para o sistema operacional Microsoft Windows."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                usa trama de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                DOS Codepage 850 (Tây Ái) utilizada\n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                usa trama de código DOS 860 (Brasileiro)    "

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa trângulo de código DOS 863 (Ca Na Đa Pháp)    \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando trângulo de código DOS 865 (Bacia "
"Amazônica) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte c%<PRIuMAX> caracteres de 8 bits para o "
"espaço dos 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b,--keep-bom        mantém o Byte Order Mark original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preserva o “Byte Order Mark” (padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de convergência chave. Conversor "
"ASCII, Bits 7, ISO/IEC 8859-1 (Latin-1), Macintosh e padrão é o ASCII."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação de mensagens para exibição\n"
"   bárragem mãe:\n"
"ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se necessário complementar\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório para converter arquivos de dados nº6\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra este mensageiro de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações da tabela de dados (table of "
"contents) dos arquivos para análise. Os campos a serem analisados devem "
"conter um número máximo especificado por %<PRIuMAX>."

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        mantém o dia da semana original no arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença de software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione ‘Byte Order Mark’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin vào         tập tin gốc trong chế độ tập-tin-mới\n"
"tập tin ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite a alteração do proprietário (padrão) do "
"arquivo"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dógrafo final se nenhum caractere de "
"nova linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"táp-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, suprimindo todas as mensagens "
"de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      remove o “Byte Order Mark” (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r, --remove-bom      apaga o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            bór qua tabela de classes (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     preserva a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le considera o formato de entrada como UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be considera o formato de entrada como UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   seguir símbolos de ligação macios e converter o "
"objetivo\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preserva links simbólicos e seus objetivos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS 16 bit (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Phiên bản DOS 32 bit (DJGPP)."

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bit (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro não encontrado."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro não encontrado."

msgid "%s version.\n"
msgstr "%s Versão."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có hỗ trợ Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Có hỗ trợ a localização geográfica do idioma. Para obter mais informações, "
"tente `%s --help'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como suporte ao proprietário original e grupo de propriedade da pasta."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e a associação de grupo "
"da pasta. \n"

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "%s BOM está sendo gravado."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s possui um BOM %s. Para mais informações, tente `%s "
"--help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "Gerou erro ao resolver a ligação simbólica pequena '\\"

msgid "Failed to open temporary output file: %s\n"
msgstr "Gerou erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "%s é utilizado como arquivo temporário para armazenar dados."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gerou erro ao alterar as permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O proprietário ou grupo de segurança da pasta %s não pode ser obtido. Para "
"obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar o proprietário e grupo da pasta"
" temporária de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên \"%s\" thành \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"O objetivo deste link simbólico '%s' é facilitar o acesso ao seu conteúdo."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está presente no diretório '%s'."

msgid "Skipping binary file %s\n"
msgstr "Bora sair da tabela de dados separada por linhas %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o código de paginação %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Bora delevar o arquivo UTF-16 %s, pois a largura do wchar_t não é igual ao "
"tamanho especificado em bytes (%d).\n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borreiros a tabela UTF-16 %s, havendo ocorrido um erro na conversão de "
"UTF-16 da linha %u. Para mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para ISO-8859-1 não é suportado nesta"
" versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"%s está sendo ignorada, pois não é um arquivo regular. Este não é o tipo de "
"tarefa esperado."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra %s, o arquivo de saída %s é um simbólico link."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Borra o link simbólico %s. Por favor, note que a exclusão de um símbolico "
"pode afetar outros arquivos ou diretórios se ele estiver em uso."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico mêm %s, pois seu objetivo não é uma pasta regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link curto %s, pois seu destino não é uma pasta regular. A ligação "
"simbólica %s não aponta para um arquivo comum."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s para o formato de texto plano, chamado "
"'plaintext', no Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo de texto “%s” para o formato do Mac, você receberá um"
" erro se a permissão for negada…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo “%s” para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo “%s” para o formato DOS, resultando no "
"arquivo “%s”.\n"

msgid "converting file %s to DOS format...\n"
msgstr "Ao converter o arquivo “%s” para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de arquivo Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Unix %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Mac do tipo %s, ..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato de arquivo DOS é realizada..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, problemas foram detectados."

msgid "problems converting file %s\n"
msgstr "Encontrado problema ao converter o arquivo %s."

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O comando \"%c\" selecionado para a opção -i ou --info contém um parâmetro "
"inválido."

msgid "active code page: %d\n"
msgstr "A interface de transferência está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já foi indicado um modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "Selecione a opção '%s' que requer um número de entrada."

msgid "invalid %s display encoding specified\n"
msgstr ""
"Falha na verificação da codificação de exibição %s. A codificação não é "
"válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo da pasta de dados %s não foi definido no modo novo do arquivo de "
"texto"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Falta um pares surrogado abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Ocorreu um erro ao processar a linha."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
