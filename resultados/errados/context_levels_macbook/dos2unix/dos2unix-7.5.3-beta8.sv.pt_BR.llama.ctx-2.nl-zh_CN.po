msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando `grep` para encontrar e exibir as linhas que contêm a "
"palavra 'error' em um arquivo. Se você quiser ver todas as linhas onde essa "
"palavra aparece, use: grep -rnEi error *file*."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                standardkonverteringsläge\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"converter para entre em português (Brazilian Portuguese) usando o comando "
"'iconv' no Linux, você pode usar a seguinte instrução shell. Se estiver "
"utilizando um sistema operacional que suporta Bash e Python3:"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Code Page 437 (USA) [padrão]."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS Code Page 850 (padrão europeu) para acessar os dados do sistema "
"operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Code Page 860 (português) para acessar os dados do sistema "
"operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS-codetabel 863 (idioma fransk-kanadensisk) para acessar os dados de"
" entrada/saída padrão."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-codetabel 865 (escandinavo) para acessar as linhas de texto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom          preservar o byte order mark (BOM) de codificação "
"UTF-8\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom         mantenha o byte order mark (BOM) padrão (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão   ascii、7bit、iso、mac, padrão é "
"'ascii'"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     escolha o codificação para mostrar mensagens de erro "
"(ansi, unicode ou utf8; padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um caractere de nova linha no final da "
"última linha se ela não tiver uma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"converter de binários -f, --force            conversão forçada de arquivos "
"binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        convertemo UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "visar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] visa informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção -k, --keepdate         mantenha o timestamp do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         visa o licenciamento do software."

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha em branco extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         adicionar marcador de ordem dos bytes (Byte "
"Order Mark) (padrão UTF-8)\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe naar een nieuw bestand schrijven\n"
"   infil               originele bestand in nieuwe filsläge\n"
"   utfil              uitmatingsbestand in nieuwe filsläge"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar um caractere de nova linha no final da "
"última linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no modo de backup (padrão) \n"
"   ficheiro ...             converter os arquivos para o formato original\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, não exibir todas as advertências"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção -r, --remove-bom      remover byte order mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção '-r' ou '--remove-bom', remover marca de byte ordenação (Byte Order "
"Mark) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            hoppa över binära filer (standard)\n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     beholda UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le aannemt att inmatningsformatet är UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be fica a crença de que o formato do input é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        executa o programa com verbosidade aumentada."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção --follow-symlink   seguir links simbólicos e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzen symbolische links por arquivos convertidos "
"(os originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    preservar links simbólicos e alterações no destino "
"(padrão)"

