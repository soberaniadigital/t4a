msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào fichier_entrée "
"fichier_sortie …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         autoriza o alteração do proprietário do arquivo tápico"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                mode de conversion por padrão\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    conversão entre os conjuntos de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilize o código de caracteres Windows 1252 (Tây Ái) "
"\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilize o código de caracteres DOS 437 (US) como "
"padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilize o código de caracteres DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilize o código de caracteres DOS 860 (Boha Doanh) "
"para a língua Bồ Đào Nha."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilize o código page DOS 863 (Ca Na Đa Pháp) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize o código de caracteres DOS 865 (Europa do "
"Norte) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    convertei os caracteres de códigos 8 bits para espaço "
"7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        mantém o byte order mark original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        guardar a marca d'ordernha dos bytes (por defeito) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão chaveamento\n"
"   modo de conversão:\n"
"      ascii, 7bit, iso, mac, mínimo é o formato ASCII por padrão"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     configura a tabela de codificação para exibir mensagens textuais\n"
"   table codec:            ansi, unicode or utf8 (ansi default)\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"linha se não houver"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           forçar a conversão de arquivos binários em tabelas n/a"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb --gb18030         converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            hiérnia sobre a necessidade desta ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
"-i, --info[=CỜ]        exibe as informações do arquivo\n"
"   tập tin …            os arquivos a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        conservar a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adiciona o “Marca de Ordem dos Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não permite o alteração do proprietário (por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem-eol          não adiciona uma quebra de linha na última linha se ela "
"não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr ""
"-O --stdout       gera saída padrão conforme a norma internacional de nomes "
"de arquivo e diretórios (ISO/IEC 9995-2)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi no arquivo antigo (padrão) \n"
"   tape-tin ...            os arquivos a serem convertidos para o modo do 'arquivo antigo'"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet   modo silencioso, suprimir todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            excluir linhas de separação (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     conservar a tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink para links simbólicos e conversão de objetivos"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos\n"
"                   (arquivos originais de destino permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    conservar links simbólicos e alvos inalterados "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão do software"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS 16 bit (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Phiên bản DOS 32 bit (DJGPP)."

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bit (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro não encontrado."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro não encontrado."

msgid "%s version.\n"
msgstr "%s Fase."

msgid "With Unicode UTF-16 support.\n"
msgstr "Este software oferece suporte ao Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Este programa oferece suporte ao nome de arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Nós oferecemos suporte ao localizador de linguagem nativa."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Com o suporte para manter os proprietários originais do arquivo e seu grupo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e grupo do arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s tem BOM %s. Para mais informações, tente `%s "
"--help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrado problema ao resolver o link simbólico \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"Gabriel, você encontrou um erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "Utilizando %s como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar as permissões do arquivo "
"temporário de saída %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador e o grupo de propriedade do arquivo %s não podem manter a posse"
" original. Para obter mais informações, tente 'git checkout -- <filename>'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, você encontrou um erro ao alterar o proprietário e grupo do arquivo"
" temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Problema ao alterar o nome do arquivo de '%s' para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o objetivo deste link simbólico '%s' é referenciar o arquivo específico."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída ainda está presente em \"%s\"."

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados separados por linha %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de códigos %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a tamanho de wchar_t não é necessariamente %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, houve um erro na conversão de UTF-16 no "
"registro %u. Para mais informações, tente `%s --help'. Se você quiser "
"cancelar a operação atual, pressione _Cancelar."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a conversão de UTF-16 não é suportada nesta "
"versão do programa %s. Para obter mais informações sobre as opções "
"disponíveis para este aplicativo em português, consulte 'Opções' no menu."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra %s, aqui não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra {%s}, o arquivo de saída %s é um simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando o link simbólico %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico %s, pois seu objetivo não é um arquivo regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link simbólico pequeno %s, pois seu alvo do link simbólico pequeno "
"(%s) não é um arquivo regular. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s para o arquivo \"%s\" no formato Unix está em "
"andamento…"

msgid "converting file %s to Unix format...\n"
msgstr "A conversão do arquivo %s para o formato Unix está em andamento…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo %s para o arquivo %s no formato Mac está em "
"andamento."

msgid "converting file %s to Mac format...\n"
msgstr "A conversão do arquivo %s para o formato Mac está em andamento…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s para o arquivo %s no formato DOS está em "
"andamento…"

msgid "converting file %s to DOS format...\n"
msgstr "A conversão do arquivo %s para o formato DOS está em andamento…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s” no formato Unix está em "
"processo...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"A conversão do ficheiro %s \"%s\" para o formato Unix %s está a "
"processar...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "A conversão do arquivo %s “%s” para o arquivo “%s” no formato Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s” no formato DOS %s está em"
" andamento...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"A conversão do ficheiro %s “%s” para o formato DOS está a ser realizada…"

msgid "problems converting file %s to file %s\n"
msgstr "Em processo de conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler desde o fichier de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O símbolo '\\u00ab%c\\u00bb' para a opção -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "a tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s inválido"

msgid "option '%s' requires an argument\n"
msgstr "o campo '%s' requer um número inteiro."

msgid "invalid %s display encoding specified\n"
msgstr ""
"Já foi enviado um aviso de que a codificação %s para exibição não é válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de abertura novo ficheiro"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Cadeia de substituição inválida. Substituição inferior ausente."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "erro: Cadeia de substituição inválida. Substituição superior ausente."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a codificação da tabela de símbolos locais atual "
"não é UTF-8."
