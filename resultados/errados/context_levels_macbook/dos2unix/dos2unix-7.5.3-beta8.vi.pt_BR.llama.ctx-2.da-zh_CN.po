msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cómo usar: %s [opções] [arquivos …] [-n entrada_e_saída_de_arquivo ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite alterar o proprietário do arquivo de "
"texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão para texto em ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar codificação de caracteres Windows 1252 "
"(Taiu)    "

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar código de carácter DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando código de ficheiro DOS 860 (Boha Dao Nha)"
"    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizando código de carácter DOS 863 (China) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar código de caracteres DOS 865 (países "
"nórdicos)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de códigos 8 bits para espaços"
" reservados 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "--keep-bom        mantém o 'Byte Order Mark' (BOM) original"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        preserva o “Byte Order Mark” (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de modo de conversão --convmode\n"
"   modo de conversão: ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define o código de exibição para apresentar mensagens de status\n"
"   códigos de exibição:\n"
"ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da linha se "
"não houver nenhum presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos binários em texto"
" separados por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            hiérnia a assistência deste auxílio"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo de entrada\n"
"   tập tin …            os conjuntos de dados a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantenha o tempo original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibir contrato de uso do software em computador"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo caractere de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “BOM” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin trong chế độ tập-tin-mới\n"
"   tập tin ra             tập tin khác trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (opção "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona nova linha fim de documento, mesmo que o "
"final do arquivo não contenha caracteres de nova linha (padrão por defeito)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi vào saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela ...              as tabelas que precisam ser convertidas neste modo de armazenamento\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chée -q, --quiet chéio modo silencioso, muda tudo os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar “Marca de Ordem do Byte” (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            excluir linhas fracionadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato do arquivo de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato do arquivo de entrada é "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o link simbólico fino e convertendo a metade"
" do objetivo."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca links simbólicos por arquivos convertidos "
"durante a transformação de dados. (Arquivos originais permanecem "
"inalterados.)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha a ligação simbólica e seu objetivo "
"inalterado (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra versão do programa"

