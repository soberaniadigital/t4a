msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do %s. Para obter mais informações sobre a conversão de codificações,"
" tente 'utf16to8 <arquivo>'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este arquivo %s, que não é um típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o %s, ficheiro de saída %s é um link curto e denso."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a ligação macia %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borra o sinal pequeno em %s, objetivo dele não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borraremos a ligação fina %s, objetivo %s da ligação fininha não é um "
"arquivo comum. \n"

