msgstr "o sinal '%c' para o opção -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "tela de trabalho ativa: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o estilo de conversão %s, que não é válido."

