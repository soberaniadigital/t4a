msgstr ""
"DENNA MJUKVARA TILLHANDA HÅLLAS AV UPPHOVSRÄTTSINNEHAVAREN I ”BEFINTLIGT "
"SKICK” (AS IS) OCH ANSVAR FÖR UTTRYCKLIGA ELLER UNDERFÖRSTÅDDA, INCLUSIVE, "
"MEN INTE BEGRÄNDE AT TILLUMPROV DETTA GARANTIER VID KÖP. "
"UPPHOVSRÄTTSINNEHAVARNET SHAHLJA HVERF ÄNDAMÅL AVVISAS ELLER FÖRLUST OM "
"ANVÄNDNING, DATA ELLER FÖRTJÄNST; INTE I NÅGOND FALL SKAL "
"UPPHOVSRÄTTSINNEHAVARNET VARA KRYSSIG UTGE ERSÄTTNINGFÖR DIREKTA, INDIREKTA,"
" OFÖRUTSEDD, SPECIELL, EXEMPLARISK OM FÖRLUST AV DENNA MJUKVARA. Ett VISST "
"ÄNDAMÅL ERSÄTTNINGFÖR TYKSATT KONTRAKTA, STRIKT SKRYDHET ELLER FORSEELSE."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [-n entrada/saída...]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         permite alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de convergência ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converteção entre codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando tabuada de caracteres Windows 1252 (Tây "
"Âu)    "

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar tabuada de conversão DOS 437 (USA) "
"(padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando tabuada de conversão DOS 850 "
"(tâmiluropeisk) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando o trângulo de menus DOS 860 (português "
"brasileiro)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando tabuada de conversão DOS/74 (franco-"
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando a tabela de sinalização DOS 865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converterá os caracteres de códigos ASCII para base 8 "
"bits em uma representação com apenas 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        behåll byteordningsmarkering (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b,--keep_bom        mantenha o byte order mark (marca de ordem de bytes) "
"padrão\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modos de conversão    ascii, 7bit, ISO, mac, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     selecione a codificação para exibir mensagens de erro\n"
"   codificação             ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma quebra de linha no final da última linha"
" se não houver nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           bắt buộc chuyển đổi các tập tin nhị phân"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converteria UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            verificar esta ajuda texto"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR]   visa informação sobre o arquivo fil ... ficheiro "
"para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        beholda o dia de criação do arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa programa de licença"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o Byte Order Mark (marca de ordem de bytes) "
"padrão para UTF-8\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skrivar no novo arquivo §originalfil i nyfilsláge\n"
"   infil               originalfil i nyfil sláguem\n"
"   utfil               utmatningsfil i nyfilsláge"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração de propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dóis finais em linha de texto (padrão) "
"\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   ficheiro …                    para converter os arquivos do formato anterior\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           estado silencioso, desligado todos os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o byte order mark (marca de ordem do byte) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o byte order mark (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            saltar sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 encoding kept."

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le fica a suposição de que o formato de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be fica a suposição de que o formato de entrada é "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utlização detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  seguir links simbólicos e converter o destino"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink erset a links simbólicas com arquivos convertidos (os"
" originais permanecerão inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preservar símbolos de ligação e links não modificados "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visão das versões número"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Fenótipo DOS em 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenótipo DOS em 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenótipo DOS em 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenótipo DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Fenômeno de interrupção do sistema operacional MSYS."

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin. \n"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Versão Windows para 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenótipo Windows de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Versão Windows em 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Versão Windows em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Versão Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Versão Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fenômeno de interrupção do sistema operacional (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenômeno EMX (OS/2) - Versão do sistema operacional."

msgid "%s version.\n"
msgstr "versão do sistema operacional %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Med suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Sem suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Med suporte Unicode para arquivos de texto."

msgid "Without Unicode file name support.\n"
msgstr "Sem suporte ao nome do arquivo Unicode."

msgid "With native language support.\n"
msgstr ""
"Suporte ao idioma de entrada. Para obter mais informações, tente 'Med "
"modersmålsstöd'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Med suporte para manter o estado do usuário e grupo de trabalho dos "
"arquivos."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Sem suporte para manter a privacidade do usuário e da rede. Para obter mais "
"informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr ""
"Diretório de temporariamente armazenados para o processamento é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Escrever BOM. \n"

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "Em fila de entrada %s tem BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr ""
"Foi utilizado o UTF-16LE como codificação de caracteres. Aqui está um "
"exemplo da tabela ASCII para comparação."

msgid "Assuming UTF-16BE encoding.\n"
msgstr ""
"Foi detectado que o código UTF-16BE é utilizado. Para obter mais "
"informações, tente 'vi --help'."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na análise de ligação simbólica chamada '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "using %s as temporary file\n"
msgstr "utiliza '%s' como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na verificação de permissões para o arquivo temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O arquivo de entrada %s não pode ser aberto por nenhum usuário ou grupo. "
"Para obter mais informações, tente 'vi --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên `%s' de para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "Qual é o objetivo do link simbólico '%s'?"

msgid "          output file remains in '%s'\n"
msgstr "o arquivo '%s' permanece no diretório 'tập tin đầu ra còn trong'"

msgid "Skipping binary file %s\n"
msgstr "Passear sobre o arquivo binário %s\n"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Hoje em dia, a tabela de caracteres UTF-16 do arquivo %s possui um "
"comprimento que não é igual ao byte da wchar_t, que deve ser %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Houve um erro ao converter o arquivo UTF-16 %s, causado por uma falha de "
"conversão no bytecode do ponto %u. Para obter mais informações, tente `%s "
"--help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hoje em dia, a conversão UTF-16 do arquivo %s não é suportada nesta versão "
"de %s. Para obter mais informações sobre o uso deste programa e as opções "
"disponíinfláveis para este tipo de ficheiro, consulte '--help'."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Hoje em dia, não é um arquivo típico de %s. Para obter mais informações "
"sobre como utilizar este comando especializado, digite `hoppar` para "
"verificar se o caminho específico existe."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Hoppar över %s, utfil %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Passar sobre o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Hoppar sobre o link simbólico %s, a metade não é um arquivo normal. Aqui "
"está uma explicação detalhada para esclarecer essa diferença."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Hoppar sobre %s, o objetivo do link simbólico para a pasta não é um arquivo "
"típico. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Converta o arquivo %s para o formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Conversão do arquivo %s para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Converting file %s to Mac format…"

msgid "converting file %s to Mac format...\n"
msgstr "Conversão do arquivo %s para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Converte o arquivo %s para o formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Conversão do arquivo %s para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Converting file %s to Unix format…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Converting file %s to Unix format…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Converting file %s to Mac format…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Converting file %s to Mac format…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Converting file %s to DOS format…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Converting file %s to DOS format…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Felizmente, a conversão do arquivo %s para o formato de texto plano está em "
"andamento. O novo nome do arquivo será `%s'."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não foi possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "tabuleiro de atividades do sistema operacional: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "option '%s' requires an argument\n"
msgstr "O comando '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi especificado na nova versão de formato."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"
