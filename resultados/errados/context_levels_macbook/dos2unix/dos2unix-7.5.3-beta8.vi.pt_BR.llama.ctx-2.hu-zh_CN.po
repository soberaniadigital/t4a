msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown permite alterar o proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento padrão de conversão textual para binário "
"e vice-versa\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   troca de caracteres entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação de caracteres Windows 1252 "
"(Tây Dân Viên)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando código de carácter DOS 850 (Tây Ásia)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando código de carácter DOS 860 (Boha Dao Nha)"
"    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando código de carácter DOS 863 (China/Canadá)"
"    \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar código de carácter DOS 865 (países nórdicos)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o “Marca de Ordem do Byte” original (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b, --keep-bom        mantém o “Marca de Ordem do Byte” (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão: ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     defina o código de exibição para mensagens avançadas\n"
"   códigos de exibição:\n"
"ansi, unicode, utf8, padrão ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da linha se "
"não houver nenhum presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos binários de "
"tabelas separadas por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb160 --> GB160\n"

msgid " -h, --help            display this help text\n"
msgstr ""
"-h, --help            exibição deste suporte de ajuda neste aplicativo"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=COR]        exibe informações do arquivo de entrada\n"
"   tabela ...            assegurar que todos os campos necessários estão presentes e corretos"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        conserte o dia e a data original do arquivo de "
"saída\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibição do aviso legal para uso de aplicativos em "
"tempo real"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adição de uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         cria novo arquivo\n"
"   nome_do_arquivo_de_entrada          nome do arquivo de entrada no modo criar-novos\n"
"   nome_do_arquivo_saida               nome do arquivo de saída no modo criar-novos"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "sem opção para alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona quebra de linha no final do arquivo, "
"mesmo sem a existência dela (configuração padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi vào saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            os conjuntos de dados que precisam ser convertidos para o formato do banco de dados antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, opção --quiet           modo silencioso, sem exibir avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Marca de Ordem do Byte” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            exclusão de arquivos binários por linha (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     giúmar bảng mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato do arquivo de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato do arquivo de entrada é "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        exibir detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o símbolo de ligação móvel e conversão do "
"objetivo"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos em texto\n"
"                   (arquivos de destino permanecem não modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e alteração de destino não "
"permitida (padrão)\n"

