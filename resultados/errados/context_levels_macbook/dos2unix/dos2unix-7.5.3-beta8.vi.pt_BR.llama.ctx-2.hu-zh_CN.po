msgstr ""
"Borra este tabela UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do %s. Para obter mais informações sobre o processo de conversão e as"
" implicações da codificação UTF-16 em sistemas Linux, consulte a "
"documentação oficial."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aqui não é um arquivo típico."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando o %s, a saída do arquivo %s é um link simbólico. ."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico de mínimo %s, pois seu objetivo não é um arquivo "
"comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra qua ligação fina %s, destino %s da ligação finita não é um arquivo "
"comum. \n"

