msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar o proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento padrão de conversão do modo texto básico "
"(ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converter de caracteres entre o conjunto DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               Windows コードページ 1252 (Tây Âu) を使用する\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando tabela de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar página de código DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar tabela de códigos DOS 860 (Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar tabela de códigos DOS 863 (Ca Na Đa Pháp) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar página de código DOS 865 (Baía da Bussola) "
"\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converter de caracteres octais para binários de sete "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --keep-bom         mantendo o Byte Order Mark originalmente inserido."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b --keep-bom         Giúmar o “Byte Order Mark” (por padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:\n"
"      ascii, 7bit, iso, mac (padrão é 'ascii')"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
"-D --display-enc      define a tabela de codificação para exibir mensagens\n"
"   table codec: ansi, unicode, utf8 (default is 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"Adicionar uma quebra de linha e finalizar a linha se não houver nenhuma "
"atualmente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           forçar a conversão de arquivos binários em tabelas n/d"
" separadas por linhas."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Este comando exibe a mensagem de ajuda atual."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
"-i, --info[=CỜ]        hiển thị tính toán các dữ liệu trong tập tin\n"
"táp-tin...            khiến cho người sẽ phân tích nhiều tập tin"

msgid " -k, --keepdate        keep output file date\n"
msgstr "-k, --keepdate        giúp mãi nguyên ngày tháng tập tin đầu ra"

msgid " -L, --license         display software license\n"
msgstr ""
"-L --license         Exibir licença gratuita para uso do software em "
"execução."

msgid " -l, --newline         add additional newline\n"
msgstr "-l, --newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "-m, --add-bom         adicione 'Byte Order Mark' (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar o proprietário do arquivo "
"(padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona o caractere de quebra de linha ao final "
"da última linha se ele não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi para saída padrão conforme a norma\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"táp-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimir todas as alertas de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r --remove-bom      apagar o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"-s, --safe            Oubrir qua tabela de dados separada por linhas "
"(padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     giúmar bảng mã UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado gerar"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink   o seguir sinais simbólicos e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos em binários\n"
"                   (arquivos de destino permanecem não modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    evitar links simbólicos e manter o estado original "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         Mostrar versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica DOS 16 bits (TurboC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome DOS 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficheiro não encontrado."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenome de Windows 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome do Windows 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenome de Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bit (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr ""
"Ficheiro de origem para a tradução do texto 'Phiên bản OS/2 (WATCOMC).' é o "
"arquivo .po localizado em '/home/user/traducoes/osx_to_pt-br.po'. O conteúdo"
" traduzido está no caminho de saída: '/home/user/traducoes/osx_to_pt-br.mo'."

msgid "OS/2 version (EMX).\n"
msgstr ""
"Ficheiro de origem para a tradução do texto 'Phiên bản OS/2 (EMX).' é "
"desconhecido."

msgid "%s version.\n"
msgstr "%s Fase."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có hỗ trợ Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Có hỗ trợ bản địa hóa ngôn ngữ."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Com suporte ao manter o proprietário original e grupo do arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o proprietário original e grupo de um arquivo."

msgid "Path for temporary output file is too long:"
msgstr "Caminho de saída para arquivo temporário excessivamente longo:"

msgid "Writing %s BOM.\n"
msgstr "Gravando BOM do %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s contém um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrado problema ao resolver ligação simbólica '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"Gabriel, você encontrou um erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "%s está sendo utilizado como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabriel, você não tem permissão para alterar as credenciais de acesso do "
"arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O proprietário e/ou grupo do arquivo %s não podem manter o conteúdo "
"original. Para obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel, não foi possível alterar o proprietário e grupo do arquivo "
"temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên `%s` thành `%s`:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o propósito da ligação simbólica pequena '%s' é conectar diretórios."

msgid "          output file remains in '%s'\n"
msgstr "tápico de saída ainda está presente no arquivo '%s'"

msgid "Skipping binary file %s\n"
msgstr "Bora delevar o arquivo separado por linhas %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a largura do 'wchar_t' não é necessariamente de "
"%d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borquei o arquivo UTF-16 %s, e houve um erro na conversão de UTF-16 da linha"
" %u. Para obter mais informações, tente `%s --help'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do programa de %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "%s está sendo omitida, pois não é um arquivo regular."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra %s, o arquivo de saída %s é um simbolico link."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link simbólico %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o link simbólico mínimo %s, pois seu objetivo não é um arquivo "
"regular. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Bora sair da associação fina %s, porque o objetivo final de tal associação "
"fininha não é um arquivo regular. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Đang chuyển đổi tập tin %s thành tập tin “%s” theo định dạng Unix…\n"

msgid "converting file %s to Unix format...\n"
msgstr "A conversão do arquivo “%s” para o formato Unix está em andamento…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo “%s” para o arquivo “%s”, no formato Mac, está em "
"andamento…"

msgid "converting file %s to Mac format...\n"
msgstr "Conversando o arquivo de texto “%s” para a versão Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo “%s” para o arquivo “%s”, no formato DOS, está em "
"andamento...\n"

msgid "converting file %s to DOS format...\n"
msgstr "A conversão do arquivo “%s” para o formato DOS está em andamento...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato de arquivo Unix "
"%s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para a estrutura Unix de "
"entrada/saída...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Mac, tendo como "
"saída o arquivo %s…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Conversando o arquivo %s “%s” para a codificação Mac (%s)..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o arquivo “%s” no formato DOS está em "
"andamento..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato DOS está em andamento...\n"

msgid "problems converting file %s to file %s\n"
msgstr ""
"A conversão do arquivo %s para o arquivo %s foi iniciada. Em caso de "
"problemas, consulte a mensagem abaixo."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter ficheiro %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O comando '%c' para a opção '-i' ou '--info' foi inserido incorretamente."

msgid "active code page: %d\n"
msgstr "a tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s como inválido."

msgid "option '%s' requires an argument\n"
msgstr "Opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"Já foi enviado um aviso de que a codificação %s para exibição não é válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi especificado no modo de criação novo do "
"sistema operacional"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Cadeia de substituição inválida. Substituição inferior ausente."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Substituição superior não foi "
"fornecida."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a codificação atual da região linguística "
"não é UTF-8. Apresente um relatório para mais informações."
