msgstr ""
"encontrou erro ao resolver o símbolico link '%s' durante a análise do seu "
"caminho relativo."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gặp lỗi khi thay đổi quyền hạn của tập tin đầu ra tạm %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O proprietário ou grupo de propriedade do arquivo %s não tem permissão para "
