msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Unix %s..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato Mac está em andamento...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato de texto simples DOS é "
"realizada...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para a versão DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"A conversão do arquivo %s para o arquivo %s está em processo. Se surgirem "
"problemas durante a etapa de convergência, por favor informe."

msgid "problems converting file %s\n"
msgstr ""
"Encontrado problema ao converter o arquivo %s durante a conversão do "
"arquivo."

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O comando '%c' para a opção '-i' ou '--info' foi inválido."

msgid "active code page: %d\n"
msgstr "A interface gráfica está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "já foi enviado o modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "Selecione a opção '%s' que requer um número de entrada."

msgid "invalid %s display encoding specified\n"
msgstr "Já enviou uma tabela de visualização inválida %s\n"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não pode ser definido no modo de abertura novo para"
" o sistema de arquivos"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível salvar no arquivo de saída: %s"

