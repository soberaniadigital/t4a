msgstr "O arquivo de saída ainda está presente no diretório '%s'."

msgid "Skipping binary file %s\n"
msgstr "Borra o conjunto de dados divididos em dois ficheiros (%s)"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Bordem o arquivo UTF-16 %s, cuja dimensão do wchar_t não é igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borrando o arquivo UTF-16 %s, houve um erro na conversão de UTF-16 no "
"registro da linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para ISO-8859-1 não é suportado nesta"
" versão do programa de conversão."

msgid "Skipping %s, not a regular file.\n"
msgstr "%s をスキップしています。通常ファイルではありません。"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Bordem o %s, ficheiro de saída %s é um simbolico link."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link simples %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o símbolo de ligação mínima %s, objetivo do seu não é um arquivo "
"típico. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link curto %s, destino do link curto não é um arquivo regular. A "
"distância até a localização de `%s' parece ser pequena."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Já está convertendo o arquivo %s para a pasta “%s” no formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Ao converter o arquivo “%s” para a estrutura Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Mac..."

