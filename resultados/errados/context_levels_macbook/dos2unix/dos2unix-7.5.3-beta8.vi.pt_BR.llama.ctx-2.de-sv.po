msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso para o programa 'cachorro' é '%s'. Para obter mais "
"informações, tente `%s --help`."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "chave de conversão ASCII -ascii                padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows Codepage 1252 (Tây Âu) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o CodePage 437 do DOS (US) como padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o CodePage 850 (Tây Árabe) para acessar os arquivos de texto do "
"Windows."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS Codepage 860 (Português) para acessar os arquivos de texto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS Codepage 863 (Ca Na Da Pháp) para acessar os arquivos de texto"
" em formato do Windows."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o DOS Codepage 865 (Baía da Bósnia e Herzegovina) para acessar os "
"dados de entrada/saída padrão."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o espaço dos "
"bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preserva a marcação de byte order (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva a marcação de byte order (marca da ordem dos"
" bytes) padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chave de convergência:   ascii, 7bit, "
"iso, mac, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      defina a codificação de exibição para as mensagens mostradas\n"
"   código de saída: ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           obriga a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          convertem o UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        mostra informações sobre a tabela de dados (tập tin)"
" cadastrada no sistema."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantém o dia da data de criação do arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa a liberação da licença"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar “Byte Order Mark” (marca de ordem das "
"bytes) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          gera uma nova pasta de entrada e saída para o "
"arquivo original (input file) no modo novo. Arquivos gerados serão salvos em"
" um formato que podem ser lidos por `less`."

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dáfsa em linha final se nenhum "
"delimitador de bloco (padrão) presente"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão) \n"
"    salvar os dados em um formato anterior ao padrão atual\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, suprimindo todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apaga o byte order mark (byteordermarkierung) padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção --remove-bom      apaga o Byte Order Mark (BOM) da linha de texto."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salta sobre arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva UTF-16 codificação."

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be implica que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink fold theo lienh de conexão mêm và transforma os "
"destinos"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    permite que symbolic links sejam ignoradas (padrão) "
"\n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versão (%s)"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS em 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de referência para o Phiên bản DOS em versão 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS em 32 bits (Watcom C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha de versão DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha de versão do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha de versão do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr ""
"Ficha de referência do Windows para sistemas operacionais em 64 bits "
"(MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de versão Windows em 32 bits (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows para sistemas de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha técnica do Windows XP em sistema de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas em execução no modo gráfico (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr ""
"Ficha técnica do Sistema Operacional/Sistemas Operacionais (WATCOM C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do Sistema Operacional/Sistemas operacionais (EMX)."

msgid "%s version.\n"
msgstr "Ficha de referência %s."

msgid "With Unicode UTF-16 support.\n"
msgstr ""
"Olá! O objetivo deste documento é fornecer uma tradução para o português "
"brasileiro (pt-BR) de um trecho em inglês que descreve como a função "
"`parse_args` do programa 'argp' lida com argumentos. Aqui está a versão "
"traduzida:  "

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Olá! O objetivo deste documento é fornecer orientações sobre como utilizar o"
" comando `grep` para pesquisa de textos em arquivos no Linux, que podem ser "
"úteis ao trabalhar com sistemas operacionais baseados na linguagem C. Para "
"iniciantes e experientes além da linha de comando (CLI), este guia irá "
"orientar você sobre como utilizar o `grep` para buscar palavras-chave em "
"arquivos, bem como exemplos práticos que podem ser aplicados no seu "
"ambiente. Por favor, note que as instruções a seguir são baseadas na versão "
"do Linux 16.04 e nas ferramentas disponísis para o sistema operacional "
"Ubuntu."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Olá! O programa 'GNU Make' é um utilitário de linha de comando que ajuda a "
"gerir o processo de compilação em sistemas Unix. Ele permite ao usuário "
"especificar uma lista de tarefas para serem executadas, cada uma das quais "
"pode conter várias opções e parâmetros personalizados."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Với hỗ trợ giữ nguyên người và nhóm sở hữu tập tin.\n"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter a identidade e o grupo de usuários associados aos"
" arquivos. Para obter mais informações, tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estamos gravando o BOM. %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de caracteres UTF-16LE é utilizada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr ""
"A tabela de caracteres UTF-16BE é utilizada. Para obter mais informações, "
"consulte a documentação."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da opção inválida --%s\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "Ocorreu um erro ao abrir o arquivo temporário de saída: %s"

msgid "using %s as temporary file\n"
msgstr "utiliza o comando '%s' como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar as permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "O arquivo de entrada %s não pode ser aberto. Acesso negado."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gerou erro ao alterar o proprietário e agrupamento da pasta de saída "
"temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Ocorreu um erro ao alterar o nome para 'Arquivo':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo da ligação simbólica '%s' é"

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr "falha na verificação da linha %s possui %s campos (esperado %d)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Falha na verificação da entrada UTF-16 %s, o tamanho do campo wchar_t não é "
"igual a %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão UTF-16 da tabela de caracteres %s, ocorreu um erro ao "
"converter a linha %u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Bem-vindo ao terminal de comando do Linux, %s. Para obter mais informações "
"sobre o uso desse programa, consulte a documentação oficial."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Falha na conexão com o servidor %s. Para obter mais informações, tente 'git "
"checkout'."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Falha na conexão com o servidor %s, pois este não é um arquivo regular."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para acesso ao sistema operacional Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo “%s” para o formato Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Fazendo a conversão da pasta de entrada “%s” para o formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão da tabela de dados %s para o formato Unix do tipo '%s'…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo a tabela de dados %s para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão da tabela de dados %s para o formato Mac, ..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr ""
"Estamos convertendo a tabela de dados %s para o formato Mac, por favor, siga"
" as etapas abaixo. Primeiro, copie e cole este texto em um editor de texto "
"ou IDE que suporte JSON: '{\"translation\": \"%s-Datei %s é convertida no "
"formato Mac...\\"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Fazendo a conversão da tabela de dados %s para o formato DOS, você pode "
"utilizar as seguintes opções:"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"Estamos convertendo a pasta de dados %s para o formato DOS, que é compatível"
" com os sistemas antigos do Windows. O tamanho máximo permitido da chave "
"'name' no arquivo '%s' não pode exceder %d bytes."

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato .csv, mas encontramos "
"problemas ao tentar ler a entrada do usuário. Por favor, verifique se você "
"está utilizando uma ferramenta compatível com este programa."

msgid "problems converting file %s\n"
msgstr "Ao converter o arquivo %s, encontramos problemas."

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "A tarefa está em execução no terminal %s."

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s não é permitida."

msgid "option '%s' requires an argument\n"
msgstr ""
"O arquivo '%s' não pode ser aberto porque o caminho especificado para ele é "
"inválido."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na análise do arquivo %s. Ocorreu um erro ao tentar ler o conteúdo "
"deste."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo desta mensagem é fornecer uma tradução para o português "
"brasileiro, mantendo a integridade técnica e terminologia do texto original."
" Por favor, note que as variásgos (%s, %d, %<PRIuMAX>, etc.) devem ser "
"preservadas exatamente como estão no input."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída inicial: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: O parâmetro de entrada não é válido. Escolha outro."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: O parâmetro de entrada não é válido. Por favor, tente novamente."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
