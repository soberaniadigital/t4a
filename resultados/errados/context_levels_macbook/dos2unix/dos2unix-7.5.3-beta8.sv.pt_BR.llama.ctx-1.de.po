msgstr "Escreve BOM. %s"

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "No arquivo de entrada %s possui um BOM. O tipo do bombinho é %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Foi adicionado que UTF-16LE codificação é utilizada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Foi adicionado que UTF-16BE codificação é utilizada."

msgid "problems resolving symbolic link '%s'\n"
msgstr "fel uppstod vid upplösning av symbolisk länk ”%s”\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "falha na abertura da pasta temporária de saída do usuário: %s"

msgid "using %s as temporary file\n"
msgstr "%s é utilizado como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na verificação de permissões temporárias para o arquivo %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"Acesso às credenciais de usuário/grupo para o arquivo %s não é possível. A "
"causa provável pode ser que as permissões do sistema estejam incorretas ou a"
" conta necessária não tenha sido configurada corretamente."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"falha na verificação da alteração do proprietário e grupo para o arquivo "
"temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr ""
"Durante a substituição de nome para o arquivo '%s' por '`%s`' foram "
"encontrados problemas:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "qual é o objetivo da ligação simbólica '\\"

msgid "          output file remains in '%s'\n"
msgstr "a saída do utfil permanece no diretório '\\"

msgid "Skipping binary file %s\n"
msgstr "Hoppar sobre binário %s\n"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação de código-fonte para o codepage %d. A linha %<PRIuMAX> "
"possui %<PRIuMAX> campos (esperado %<PRIuMAX>)."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Hopar sobre o arquivo UTF-16-%s, tamanho do wchar_t é de %d bytes. \n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Hopping over UTF-16 file %s, an error occurred during the conversion on line"
" %u. Please check for any issues with encoding or formatting."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hopar sobre a %s UTF-16, pois não há suporte para conversão de UTF-16 nesta "
"versão do programa. A data e hora UTC atual são {current_utc}."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"%s é um arquivo não padrão, portanto nenhum passo será tomado sobre ele."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"%s wird übersprungen, Ausgabedatei %s ist eine symbolische Verknüpfung."

msgid "Skipping symbolic link %s.\n"
msgstr "Hoppar över symbolisk länk %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Hoppar över symbolisk länk %s, målet är inte en vanlig fil."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr "%s é saltada, o alvo da ligação simbólica %s não é um arquivo comum."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "converter a pasta %s para o arquivo %s no formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "converter a pasta %s para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "converter a pasta %s para o MacOS formatado…"

msgid "converting file %s to Mac format...\n"
msgstr "converter a pasta %s para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "converter a pasta %s para o arquivo %s no formato DOS…"

msgid "converting file %s to DOS format...\n"
msgstr "converter a pasta %s para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "converterão a %s-fil%d para %s-fil%<PRIuMAX> no formato Unix…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "%s-Data %s será convertida para o formato Unix…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Converter a %s-fila de dados %s para o Macintosh format…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "%s-Data %s será convertida para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "converterão a %s-fil%d para o formato DOS da %s-fil%<PRIuMAX>…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "%s-Datei %s será convertida para o formato DOS…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Durante o processo de conversão do arquivo %s para o arquivo %s, foram "
"encontrados problemas."

msgid "problems converting file %s\n"
msgstr ""
"Durante o processo de conversão do arquivo %s, foram encontrados problemas."

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "falha ao usar o flag '%c' para a opção '-i' ou '--info'"

msgid "active code page: %d\n"
msgstr "Aktivação da tabela de códigos do terminal: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "O modo de conversão %s especificado é inválido."

msgid "option '%s' requires an argument\n"
msgstr "O comando \"%s\" requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "A codificação %s especificada é inválida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo da ferramenta para o arquivo %s não foi especificado no modo de "
"criação do novo arquivo."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "In die Ausgabedatei não pode ser escrito: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Pair surrogate inválido. O par de substituição inferior não está "
"presente."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Pair surrogate inválido. O par de supergolfe está ausente."
