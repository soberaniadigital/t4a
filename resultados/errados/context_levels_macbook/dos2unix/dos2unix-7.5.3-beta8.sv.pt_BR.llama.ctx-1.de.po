msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [flags] [arquivos] [-n infile outfile …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite a alteração do esquema de propriedade (chmod)"
" para arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modos de converção padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converte entre Sistema DOS e codificação ISO-8859-1 "
"de caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               usado Windows codificação tabuletas 1252 (vesteuropeu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                usado o código de caracteres DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usado o DOS codepage 850 (Westeuropeisk)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                verwendet DOS Codepage 860 (portuguesa)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                usado o DOS codepage 863 (français canadien)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                usado o tabuleiro de códigos DOS 865 (nordestino)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte caracteres de 8 bits para o espaço dos 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --keeppromarkering byteorder mark (Byte Order Mark) -mantendo a ordem dos"
" bytes e marcando o Byte Order Mark."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b --mantém-a-marcação-de-byteorder (Byte Order Mark) - padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        convertemoda de conversão\n"
"   convertemoda    ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     defina a codificação para mensagens visuais\n"
"   kodning             ansi, unicode, utf8, padrão é ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione um retorno de carro na última linha se "
"necessário complementar"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           tvinga a conversão de arquivos binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h --help            visar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] visa informações da ficheira para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantém o dia da saída do arquivo de entrada"

msgid " -L, --license         display software license\n"
msgstr " -L --license         visa a divulgação da licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr "-l --newline         adiciona um caractere de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar uma marcação de byteorder (Byte Order Mark)"
" para UTF-8 padrão\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         cria um novo arquivo\n"
"   entrada               original_arquivo no modo de nova linha/esquina do arquivo\n"
"   saída                salvar em disco como novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite a alteração do esquema de propriedade "
"(direitos) para o arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha na última linha "
"(padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O --to stdout       escrever na saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreve no arquivo antigo (padrão) \n"
"   files ...               os que serão convertidos para a versão antiga"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimindo todas as avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      remove a marca de byte order (Byte Order Mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      remove a marca de byte order (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            salte sobre arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     preserva UTF-16 codificação de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le pretende que o formato de entrada seja UTF-16LE."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be pressa UTF-16BE como formato de entrada padrão."

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        realização detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  segue links simbólicos e converte os campos de origem"
" para o destino especificado."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(originais objetos de destino permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preserva símbolos de ligação e seus alvos inalterados "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         visa versão número"

