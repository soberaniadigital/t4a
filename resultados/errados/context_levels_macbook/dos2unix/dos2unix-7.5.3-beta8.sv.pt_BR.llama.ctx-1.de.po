msgstr "Versão do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Versão Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Versão em 32 bits do Windows (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Versão de 32 bits do Windows (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Versão de 32 bits do Windows (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Versão Windows de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Versão de 32 bits do Windows (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Versão do OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Versão do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "%s versão."

msgid "With Unicode UTF-16 support.\n"
msgstr "Med suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Sem suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Med suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Sem suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Suporte para idiomas nacionais. (DE)"

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Mit suporte para manter a associação de usuários e grupos com arquivos."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Sem suporte para manter a associação de usuários e grupos com arquivos."

msgid "Path for temporary output file is too long:"
msgstr "A origem de pesquisa para o arquivo temporário é muito longo:"

