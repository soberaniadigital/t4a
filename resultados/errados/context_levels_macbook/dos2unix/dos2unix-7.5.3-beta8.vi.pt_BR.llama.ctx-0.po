msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópias de segurança utilizando o comando %s [categorias] [arquivos ...] [-n "
"arquivo para backup do diretório ra...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alterar proprietário do arquivo de texto\n"

msgid " -ascii                default conversion mode\n"
msgstr " - ASCII                 chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converte o caráter de codificação entre DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando codificação de caracteres Windows-1252 "
"(Tây Âu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizando código de caracteres DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando ferramenta de conversão DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando interface gráfica do sistema operacional "
"DOS em modo de codificação 860 (Bồ Đào Nha)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando interface gráfica do sistema operacional "
"DOS com codificação de caracteres em 863 (Ca Na Da França)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando interface gráfica do sistema operacional "
"DOS 865 (Baía de São Francisco)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converte os caracteres de base 8 para base 7\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        giúme nguyên 'Byte Order Mark' (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "-b --keep-bom        giúria o “Byte Order Mark” (mặc định) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave -c, --convmode         modo de conversão de caracteres\n"
"   modos de conversão de caracteres:\n"
"ascii (padrão), 7bit, ISO e mac"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-encoding     define a tabela de codificação para exibição\n"
"   Tabelas de codificação:\n"
"ansi, unicode, utf8 (padrão ansi)\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--add-eol   adicionar ponto e vírgula ao final do último caractere se não "
"houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force           obrigatório para converter arquivos de múltiplas "
"extensões\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr ""
"--gb18030         §, --GB18030          § converti do UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h --ajuda            Ajuda deste comando\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo de entrada\n"
"   processa tabelas ...            para fins estatísticos em vários conjuntos de dados"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"-k, --keepdate        preserva o dia de criação original do arquivo gerado\n"

msgid " -L, --license         display software license\n"
msgstr ""
"-L ou --license         licença de uso do software em aplicativo gráfico"

msgid " -l, --newline         add additional newline\n"
msgstr ""
"-l ou --novo\n"
"linha         Adicionar uma nova linha."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"--byte-order-mark (BOM) -m, --add-bom         adicionar o Byte Order Mark "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
"--novoarquivo          ghi ra tập tin mới\n"
"tapetin-vao          tapetin gốc trong chế độ tapetin-mới\n"
"tapetin-ra           tapetin đầu ra trong chế độ tapetin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--não-permitir-chmod      não permite alterar o proprietário do arquivo "
"(padrão) de um diretório"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona dítiao ao final do último caractere se "
"não houver um, conforme padrão definido."

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
"--oldfile --input-files \n"
"   Arquivos antigos ...\n"
"    Os arquivos a serem convertidos no formato anterior."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "-q --quiet, modo silencioso, desligado todos os avisos de erro."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "-r --remover-bom      gelo com o Byte Order Mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r, --remove-bom      geloar BOM (Byte Order Mark) remover"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"-s, --safe            \n"
"                    bora remover linhas de separação (método padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr "-u, --keep-utf16     giúmar bảng mã UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "-ul, --assume-utf16le coi rã que o formato de entrada seja UTF-16LE."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be coi régula útribuir o formato de entrada como "
"UTF-16BE."

msgid " -v,  --verbose        verbose operation\n"
msgstr "-v --verbose, opção de detalhes\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink o seguimento de links simbólicos e conversão do "
"objetivo\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"--replace-symlink, substitui links simbólicos por arquivos reais (arquivos originais não são alterados)\n"
"(Arquivos de origem permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr "--skip-symlink    giúp mềm và dự kiến không thay đổi (mặc định)"

