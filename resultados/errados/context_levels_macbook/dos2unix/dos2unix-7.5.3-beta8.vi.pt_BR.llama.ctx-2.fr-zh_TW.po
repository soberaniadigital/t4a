msgstr "Ficha de testeio %s."

msgid "With Unicode UTF-16 support.\n"
msgstr ""
"Olá! Obrigado pela sua solicitação. Por favor, me dê o nome do arquivo que "
"deseja analisar."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

