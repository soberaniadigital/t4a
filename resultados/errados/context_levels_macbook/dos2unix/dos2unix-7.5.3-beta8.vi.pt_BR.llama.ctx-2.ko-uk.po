msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite alteração do proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr ""
"chave -ascii                modo de conversão padrão para caracteres ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converter de caracteres entre DOS e ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando a tabela de caracteres do Windows 1252 "
"(Tây Ái) para codificação dos símbolos da língua Vietnamita."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tela de código DOS 437 (EUA) como padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a página de código DOS 850 (Tây Ái) para o "
"idioma tailandês."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar a página DOS 860 (português) para o código "
"em Bồ Đào Nha."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a página DOS 863 (Inglês Canadense) para o "
"código C da Coreia do Sul."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizar a página de código DOS 865 (língua britânica) "
"do sistema operacional MS-DOS para o desenvolvimento em linguagem C/C++."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converterão os caracteres de KO para o espaço "
"reservado em um campo de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        manter o sinal de byte order mark (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        manter o “Marca de Ordem dos Bits” (método padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:   ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar caractere de quebra de linha ao final da linha se"
" ele não estiver presente"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório para converter arquivos de tabela separada"
" por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            apresentação deste ajuda textual"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CÓDIGO]        exibir informações do arquivo\n"
"   nome_do_arquivo ...            nomes dos arquivos para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr "giúpá -k, --keepdate        giúp nguyên ngày tháng tập tin đầu ra"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibir licença para uso de aplicativo interativo"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo caractere de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem dos Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar o proprietário do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar o caractere de quebra de linha no final"
" da linha se ele não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       ghi vào padrão de saída"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gerenciamento de arquivo antigo (padrão) \n"
"   tabela-de-tabelas ...            listagens que precisam ser convertidas para o modo do banco de dados antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet   modo silencioso, sem mensagens de aviso. Silencia todos "
"os alertas."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "gỡ bỏ “Byte Order Mark” (mặc định)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gỡ bỏ “Marca de Ordem dos Bits” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            exclusão de tabela binária (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régando que o formato do dado de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        registro detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  심볼릭 링크를 따르며 대상을 변환합니다"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink trocar links simbólicos por arquivos convertidos\n"
"                   (arquivos originais não serão alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera a ligação maciça e o objetivo (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         apresentar símbolo de versão"

