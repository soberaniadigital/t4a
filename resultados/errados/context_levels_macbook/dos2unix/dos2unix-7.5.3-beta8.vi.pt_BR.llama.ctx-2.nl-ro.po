msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando 'utilizar' para %s [opções] [ficheiro ...] [-n "
"ficheiro_entrada ficheiro_saida]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "converter para ASCII (standaard)    modul de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre o DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize a codificação Windows-1252 (codificação de caracteres do padrão "
"europeu) para o seu documento."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Utilize a página de codificação DOS 437 (padrão) para o sistema operacional "
"Windows."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS-850 (Tây Árabe) para acessar os dados do sistema operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o transtorno DOS 860 (Portugal) para acessar as informações do "
"sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize a página de código DOS 863 (Canadees Frans)   -863                "
"utilizează pagina de codigo DOS 863 (Canadá Francês)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o DOS-codetabel 865 (Baixada) para conversão de texto em Codificação"
" Padrão do Brasil."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits em 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        păstreaja marcajul de ordens (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        păstreaja marcajul de ordine a octeților (BOM) "
"(implícito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr "chave de conversão: modo ASCII, '7bit', ISO ou MAC (padrão é 'ascii')"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificare de caracteres para a apresentação dos avisos\n"
"   Codificarea:\n"
"    'ansi', 'unicode' ou 'utf8' (standażând cafezinho estevaeja ansi)\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não houver uma caso contrário."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"forçar conversão de arquivos binários -f, --force           força a "
"transformação dos ficheiros binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO]        mostra informações sobre o tamanho e a data de "
"criação do fişier ...         ficheiro %s\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        põe a marca de data original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr "opção --license         afiça a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicione uma linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marcação de ordem dos bytes (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          schrijf naar een nieuw bestand in nieuwebestandsmodus\n"
"   INVOERBESTAND        het originele bestand in de nieuwe versie van het bestand"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicione um caractere de nova linha no final da "
"última linha se não houver uma (implicit) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr ""
"Opcionais -O, --to-stdout       escreve o resultado para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (método padrão) \n"
"   tập tin ...         fiúz(e) de conversão em formato-fiúz_cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silencioso/silente, suprimindo todas as avisões"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      eliminar a marca de ordem dos bytes (mandatório)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gỡ bỏ “Byte Order Mark”\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            retire o arquivo de entrada (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     păstreaja codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        oferă informações detalhadas sobre as operações "
"realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "Opcion --follow-symlink   seguir as ligações simbólicas e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bặn (các tập tin đích nguyên "
"gốc rỗng) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    păstrează liên kết mềm và nhất thịnh (mặc định)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         afieixa do número da versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr ""
"Ficha de referência do sistema operacional DOS em versão 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de referência do sistema operacional DOS (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr ""
"Ficha de referência para o sistema operacional DOS em versão 32 bits (Watcom"
" C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha de referência do sistema operacional DOS (DJGPP) em 32 bits."

msgid "MSYS version.\n"
msgstr "Ficheiro de entrada não encontrado."

msgid "Cygwin version.\n"
msgstr "Ficha de referência do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficha de referência do Windows para a versão em 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de referência para o Windows em 32 bits (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha de referência do Windows para sistemas em 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha de referência do Windows para sistemas em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows para sistemas de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows para sistemas de 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro não encontrado."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có houver suporte Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có horação de apoio para o nome do arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr ""
"Có suporte para linguagem regional. Para obter mais informações, tente `%s "
"--help'."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o usuário e grupo. Para obter mais informações, tente "
"`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estou gravando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de caracteres UTF-16LE é adotada."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de codificação UTF-16BE é utilizada."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na verificação da ligação simbólica '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como ficheiro temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gerou um erro ao alterar as permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador ou grupo de usuários que possui o arquivo %s não pode ser "
"preservado."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gerou um erro ao alterar o diretório de trabalho do usuário e a pasta da "
"família %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"o propósito da ligação simbólica '%s' é obter o valor de uma variável."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída permanece no diretório “%s”."

msgid "Skipping binary file %s\n"
msgstr ""
"Falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)."

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"O arquivo UTF-16 %s não pode ser ignorado; a dimensão de 'wchar_t' é de %d "
"octetos."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Se omite %s, isso não é um arquivo regular. Para obter mais informações, "
"tente '`%s --help'."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Se omite a opção %s, o fio de entrada é uma ligação simbólica. O arquivo de "
"saída '%s' não pode ser ignorado."

msgid "Skipping symbolic link %s.\n"
msgstr "Falha na conexão com o servidor. Acesso ao socket bloqueado."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"A ligação mínima entre %s e o objetivo não é um arquivo regular. O caminho "
"para acessar este recurso está ausente."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Ocorreu uma falha na conexão com o servidor. O arquivo %s não é um diretório"
" válido."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a representação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo de entrada '%s' para um formato compatível com"
" Mac..."

msgid "converting file %s to Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo de entrada `%s' para a representação Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo de entrada '%s' para um formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para a versão DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s (%d) para o formato Unix %s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s (%d) para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo %s “%s” para o formato Mac %s…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s (%d) para o formato Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Estamos convertendo o arquivo %s (%d) para o formato DOS de `%PRIuMAX'...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s (%d) para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para o formato de texto plano (plaintext)."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "falha na verificação da opção '-i' ou '--info'"

msgid "active code page: %d\n"
msgstr "página de codificação ativa em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s não é permitida."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não é possível ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não é possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro de sintaxe inválida. Ocorreu um erro ao substituir o parâmetro '--"
"help'."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro de sintaxe inválida. A opção %s não é válida."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
