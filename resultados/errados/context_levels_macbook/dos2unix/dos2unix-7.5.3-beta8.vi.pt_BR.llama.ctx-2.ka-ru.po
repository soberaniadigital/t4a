msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         разрешить смену владельца файла"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                режим преобразования по умолчанию"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                  converter de codificação DOS para ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar codificação DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar a codificação DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a codificação DOS 863 (Ca Na Da França) PT-"
"BR"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para base 7 bit a partir dos "
"8 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservar o “Marca de Ordem dos Bits” (BOM) como "
"está\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preservar o “Marca de Ordem dos Bits” (método padrão)"
" \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         режим преобразоваção de texto:   ASCII, 7bit, ISO, "
"MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocando o processamento de arquivos binários em "
"formato fracionado"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         đổi từ UTF-16 sang GB18030"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            apresentação de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỌ]        exibir informações sobre o arquivo de entrada\n"
"    ficheiro ...            dos ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preservar a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         hipertexto de licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline          Додаar novo delimitador de linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “Marca de Ordem do Byte” (padrão UTF-8) \n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          записати em novo arquivo\n"
"    tabela de entrada         tabela de origem no modo do novo arquivo\n"
"    saída da tabela        tabela de saída para o novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "opção não permitir alteração do proprietário de arquivo (por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"opção --no-add-eol          não adicionar dógrafo no final da linha, se ele "
"não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          записати no arquivo antigo (por padrão) \n"
"    arquivo ...             arquivos para conversão em modo de arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"opção silenciosa -q, --quiet            \n"
"    Silente\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      remover o marcador de ordem dos bytes (BOM) padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      remover o “marca dados” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ბინარული შესყვამდЗа"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 კოდირების შენარჩუნება"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le ჩათვლა, რომ შედგინარს კოდირებაა UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        modo detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  სიმბურ Georgiadis (Greek) and the Greek Parliament's "
"role in promoting democracy through education. In a recent article published"
" by The New York Times on May 15th, it was reported that despite significant"
" progress made since its establishment as an independent nation-state after "
"World War II, Greece continues to face challenges with corruption within "
"political parties and the judiciary system which hampers democratic "
"processes. Georgiadis argues for a comprehensive reform of these "
"institutions while emphasizing on education's role in fostering transparency"
" and accountability among citizens."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substituir links simbólicos por arquivos transformados\n"
"                   (arquivos originais não serão alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    оставить символические ссылки и цели без изменений "
"(по умолчанию) \n"

