msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE USE: %s [seleções] [ficheiros ...] [-n ficheiro_entrada "
"ficheiro_saida]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown permite alterar o proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                режим ASCII по умороженне"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   troca de sinal entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizando página de código Windows 1252 (tây rỉ "
"thuật) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizando código de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando código de carácter DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizando código de caráter DOS 860 (Boha Da Nova)"
"    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando código de caráter DOS 863 (cafranga "
"francês) para o Canadá Francês"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizando código de caráter DOS 865 (Europa do "
"Norte)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conservador do “Marca de Ordem da Bits” (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b, --keep-bom        забезпечувати оригінальний \"Байт Ordem Марку\" (по "
"умороженню)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:   ASCII, BIT7, ISO, MAC, por padrão é o ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens dos alertas\n"
"   tabela de codificação:\n"
"     ansi (ansi), unicode, utf8 (utf-8), por padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adiciona um caractere de nova linha no final da linha se "
"ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos binários de "
"tabelas separadas por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16308         converte UTF-16 para GB16308\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            hiérnia a assistência desta vez"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o conjunto de dados (tabela)"
" a ser analisado. Tabelas ...            as tabelas que precisam da análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        conservador da data de origem no arquivo gerado"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibe aviso legal para uso de aplicativo em linha de "
"comando"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adiciona o ponto de sequência BOM (por padrão, UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin cơ sở trong chế độ tập tin mới\n"
"   tập tin ra           tập tin xuất ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não permite a alteração do proprietário (padrão) da pasta de arquivo"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"opção --no-add-eol          não adiciona nova linha no final do arquivo, "
"mesmo que o arquivo original não tenha uma (configuração padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       gera saída padrão (STDOUT)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   arquivos ...            os arquivos que precisam ser convertidos para o modo de armazenamento mais antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção `--remove-bom`  ôrdem remover o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “BOM” (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            excluir linhas em ordem de processamento (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     conservando a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato do carregamento é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato do carregamento é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        exibir detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguindo o link simbólico e convertendo a função de "
"destino"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos transformados em texto\n"
"                   (arquivos de origem permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva a ligação simbólica e seu destino sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr "--versao         Mostra versão do software"

