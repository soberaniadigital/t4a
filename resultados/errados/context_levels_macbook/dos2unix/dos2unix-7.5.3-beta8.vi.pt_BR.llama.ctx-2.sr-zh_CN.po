msgstr "Fenótipo do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficheiro de origem do projeto Phiên bản Windows 64 bit (MinGW-w64).\n"

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficheiro de origem não encontrado."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficheiro de origem (%s) não foi encontrado."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenômeno Windows 64 bits (MSVC %d)."

