msgstr ""
"Ignorando arquivo UTF-16 %s, a conversão para UTF-16 não está suportada "
"nesta versão do programa."

msgid "Skipping %s, not a regular file.\n"
msgstr "Hoppar sobre %s, não é um arquivo regular."

