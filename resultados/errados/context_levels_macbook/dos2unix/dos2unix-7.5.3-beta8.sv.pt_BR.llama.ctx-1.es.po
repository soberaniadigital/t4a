msgstr "Hoje em dia, %s, o arquivo de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Ignorando enlace simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
