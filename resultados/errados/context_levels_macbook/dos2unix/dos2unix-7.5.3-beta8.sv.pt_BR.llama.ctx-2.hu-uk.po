msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [parâmetro] [arquivo ...] [-n in_file input.txt]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite a mudança de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                apenas conversores de codificação padrão"

