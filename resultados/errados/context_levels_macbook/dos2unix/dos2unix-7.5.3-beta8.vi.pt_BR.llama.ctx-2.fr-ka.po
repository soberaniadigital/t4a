msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de uso: %s [opções] [-n fichier_entrée fichier_saida …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite o alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão de codificação entre os sistemas DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação do Windows 1252 (Tây Âu) para processar "
"arquivos."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código de caracteres DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Utilize o código de codificação do DOS -850 (Tây Árabe) para Windows"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Utilize o código de página do DOS (860) da Bônus (Português)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o código de página do DOS (863) da versão Cingapura, também "
"conhecido como Code Page 863."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o código de página do DOS (865) da Bacia Amazônica\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o espaço dos 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        guarda a marca de ordem dos bytes"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "opção --keep-bom        garde a marca de ordem dos bytes (por padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão:   modo de converção: ascii, "
"7bit, iso, mac, padrão é ASCII por defeito"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir os avisos textuais (ansi, "
"unicode, utf8) \n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha ao final da última linha se não houver nenhuma"
" presente, caso contrário, ocorre um erro."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bater o comando 'git diff' para ver as diferenças entre dois commits no "
"GitLab, você pode usar a opção --stateless. Se um arquivo não for encontrado"
" em uma determinada linha do git-difftool, ele é ignorado e somente os que "
"foram alterados são mostrados."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "opção -h, --help            affiche este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=ARQUIVOS]        exibe as informações do arquivo ... ficheiros "
"para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        conserve a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr "opção --newline         adiciona linhas de quebra de linha extras"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "thêm “Marca de Ordem do Byte” (máscara padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         ახალ ფაილში ჩაწერა პასური ფაილი ახალი-ფაილის "
"რეჟიმში\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adiciona uma quebra de linha no final se não houver um caractere de nova"
" linha (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion -o, --to-stdout       escrever no stdout."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gera o arquivo de saída no formato do antigo (padrão) ficheiro\n"
"    tângtin …            dos ficheiros a serem convertidos para o modo \"antigo fichier\""

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, suprime todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção --remove-bom      apaga o byte order mark (marca de ordem dos bytes) "
"padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção --remove-bom      apague o byte order mark (BOM) da linha de entrada."

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            ignorar arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte o encoding UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anuncios verbosos"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Sempre que você encontrar um erro, por favor informe o número de linhas do "
"arquivo (%s) e a posição da mesma para ajudá-lo com mais precisão."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troque os links simbólicos por arquivos convertidos "
"(ficheiros originaires permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    conserve os links simbólicos e as cargas inalteradas"
" (padrão)"

