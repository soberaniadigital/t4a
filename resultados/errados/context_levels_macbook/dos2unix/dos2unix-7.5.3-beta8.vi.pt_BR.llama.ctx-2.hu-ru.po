msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar codificação DOS 863 (Franco-Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utilizar codificação DOS 865 (Sudeste) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converterá 8 bits de caracteres em 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b, --keep-bom        preservar o “Marca de Ordem dos Bits” (BOM) na saída "
"do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preservar o “Marca de Ordem dos Bits” (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão de caracteres\n"
"   modo de conversão de caracteres:\n"
"acii, 7bit, iso, mac, padrão é acii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      definir a codificação para exibição de mensagens gráficas\n"
"   básica: ansi; opções adicionais: unicode, utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não estiver presente"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           blocar a conversão de arquivos binários em tabelas "
"n/n+1 fatores polinomiais."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            apresentar ajuda para este comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CÓDIGO]        exibir informações do arquivo de código fonte [obsoleto]\n"
"   codigo-fonte …            conjuntos de códigos para análise\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conservador da data de origem do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibição da licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione novo separador de linhas\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          criar novo arquivo de texto\n"
"   tabela-de-entrada em modo de entrada para o novo arquivo\n"
"   saída no novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (por "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dítio de linha final em caso de ausência"
" (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          gere as pastas antigas (por padrão) \n"
"   diretório ...            os diretórios para conversão no modo de arquivos antigos\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           modo silencioso, ocultação de mensagens não "
"exibidas\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o “Marca de Ordem dos Bits” (por padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"-r, --remove-bom      gostar de remover o 'Marcação do Ordem dos Bits' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     manter a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        registro detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  para símbolos efêmeros (links simbólicos) e "
"transformar objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"em tábuas de caracteres (arquivos originais permanecem inalterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha as ligações simbólicas e metas sem "
"alterações (padrão) \n"

