msgstr ""
"Remover o arquivo UTF-16 %s, tamanho do wchar_t não é necessariamente de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, que causou um erro ao converter UTF-16 na linha "
"%u. A causa do problema é a conversão de UTF-16."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, transforme para ISO-8859-1 não suportado nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borrando o arquivo %s, isso não é um típico ficheiro de texto. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Borrando o %s, ficheiro de saída inicial %s é uma referência simbólica."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a associação rígida %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a associação fraca %s, o objetivo dele não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Cancelar a conexão com o link pequeno, alvo da saída do link pequeno não é "
"um arquivo típico."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Ao converter o arquivo %s para o arquivo \"%s\" no formato Unix…"

