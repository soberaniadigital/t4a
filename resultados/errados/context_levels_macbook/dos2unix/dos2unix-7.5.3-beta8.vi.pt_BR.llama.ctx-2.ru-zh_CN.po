msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a troca do proprietário de arquivo/banco de "
"dados\n"

msgid " -ascii                default conversion mode\n"
msgstr ""
"chave -ascii                modo de conversão padrão para texto sem "
"acentuação"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converter entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a codificação Windows 1252 (Tây Âu)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar trânslitcão DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizar a codificação DOS 850 (Tây Ái) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar trânscrição de código DOS 860 (Bồ Đào Nha) "
"\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar trânslitura mãe DOS 863 (Ca Na Đa Pháp) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar trânsferência de dados DOS 865 (Bacau) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para o espaço reservado a 7 "
"bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "giúpado o “Marca de Ordem dos Bits” (BOM) sem alteração."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"--keep-bom        manter o 'Byte Order Mark' (marca de ordem de bytes) "
"padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:   ascii, 7bit, iso, mac, por padrão em ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     setar a codificação para exibir mensagens de texto\n"
"   encoding:            ansi, unicode, utf8 (defaults to ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se não estiver presente"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos binários de "
"tabelas separadas por linhas"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16094       converte UTF-16 para SJIS X'950"

msgid " -h, --help            display this help text\n"
msgstr "opção --help            exibe esta mensagem de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do arquivo \n"
"   tập tin ...              os arquivos para análise\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        guarde a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibir contrato de uso para o software em computador"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione linha nova\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem dos Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         ghi ra tập tin mới\n"
"   tập tin vào          tập tin trong chế độ tập tin mới\n"
"   tập tin ra             tập tin khác trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (padrão) do "
"arquivo de texto"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar quebra de linha no final da última "
"linha, mesmo sem a existência do caractere de quebra de linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào padrão de saída"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão)\n"
"   tabela-de-dados ...            os conjuntos de dados que precisam ser convertidos para o modo do arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem mensagens de aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "gỡ bỏ “Marca de Ordem dos Bits” (mặc định)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            exclua o conjunto de dados divididos em dois (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     guarde a tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régando que o formato do arquivo de entrada seja "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi régulo de que o formato do arquivo inicial seja "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink para seguir sinais e converter objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca links simbólicas por arquivos convertidos. "
"(Arquivos de destino originais permanecem inalterados.)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserte a ligação simbólica e o objetivo sem "
"alterações (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         Mostrar número da versão do software"

