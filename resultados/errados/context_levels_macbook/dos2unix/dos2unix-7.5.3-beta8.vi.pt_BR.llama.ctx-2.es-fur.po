msgstr ""
"Remova o arquivo %s, pois ele é um link simbólico. O arquivo de saída %s é "
"muito pequeno."

msgid "Skipping symbolic link %s.\n"
msgstr "Remova o link simbólico mínimo %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Separando o link mínimo %s, não é um arquivo regular. O destino dessa "
"conexão não pode ser uma pasta."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Separando a ligação mínima %s, o objetivo da ligação mínima não é um arquivo"
" regular. \n"

