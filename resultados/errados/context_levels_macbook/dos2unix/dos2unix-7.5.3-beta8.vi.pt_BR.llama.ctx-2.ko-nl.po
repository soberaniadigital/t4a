msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Método de uso: %s [opções] [arquivo ...] [-n input.txt output.csv...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                converter padrão de codificação ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre os conjuntos de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o Windows Code Page (1252) para codificação de caracteres no sistema"
" operacional Microsoft."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código DOS 437 (US) padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS-codetabel 850 (Tây Árabe) para acessar as pastas de trabalho."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS-codetabel 860 (Português) para acessar as informações do "
"sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS-codetabel 863 (Canadees Frans) para acessar as informações do "
"sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize o DOS-codetabel 865 (Baixo/Médio Nível) para acessar as informações "
"do sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        giúpia o “Byte Order Mark” (BOM) em §<PRIuMAX>"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        giúpia o “Byte Order Mark” (método padrão) \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de conversão:   ascii, 7bit,"
" iso, mac\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para a exibição dos avisos\n"
"   Codificação da tela de mensagens do log:\n"
"    'ansi', 'unicode' ou 'utf8' (padrão: ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se ele não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn, --force           forçar conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          UTF-16 인코딩을 GB18030로 변환합니다."

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            este comando ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        hiển thị tính tin cập para ficheiro(s) a ser "
"analisado\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        keep the date of output file"

msgid " -L, --license         display software license\n"
msgstr "licença -L, --license         licenças"

msgid " -l, --newline         add additional newline\n"
msgstr ""
" -l,--newline         adicionar uma linha em branco ao final da entrada\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m' ou '--add-bom', adicionar “Byte Order Mark” (padrão UTF-8) à "
"saída."

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tape nao criar um novo arquivo no modo de entrada/saída do script (tính toán hệ thống) \n"
"   INVOERBESTAND        het originele bestand in een nieuw bestand schrijven\n"
"   UITVOERBESTAND       het geconverteerd bestand opschieten naar de nieuwe versie"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dây trong cuốn từ (màu mặt trời) vào chúng"
" tôi, nếu không có dấu ngắt dòng"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       para escrever em saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          adicionar ao távola de trabalho (método padrão) \n"
"   távola ...            converter os arquivos para o modo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, mudo todas as warnings\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção -r, --remove-bom      remover o “Byte Order Mark” (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gỡ bỏ “Byte Order Mark”\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 codificação mantida"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng định dạng início é UTF-16LE."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rằng định dạng início é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes do processo de tratamento"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "Opção -F, --follow-symlink  변환을 따르는 대상을 출현합니다."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay tập tin mềm bằng tập tin chuyển đổi (các tập tin"
" dựa trải không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ignore links simbólicos e não as altere (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         apresenta o número da versão do programa"

