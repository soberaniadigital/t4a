msgstr ""
"falha na verificação da ligação simbólica '%s' com base no número de campos "
"(esperado %<PRIuMAX>)"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "Estou utilizando o %s como um arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Erro ao alterar os permissões temporárias do arquivo de saída intermediária "
"%s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "O arquivo de texto %s não pode ser salvo. Acesso negado."

