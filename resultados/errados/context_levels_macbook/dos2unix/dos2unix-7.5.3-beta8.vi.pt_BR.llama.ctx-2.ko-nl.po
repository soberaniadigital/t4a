msgstr "Estamos convertendo o arquivo %s para um arquivo no formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo a conversão do arquivo “%s” para o formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo `%s' para um arquivo do Mac em formato '%s'. "
"Para obter mais informações, tente '`%s --help'"

msgid "converting file %s to Mac format...\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Đang chuyển đổi tập tin “%s” thành tập tin “%s” theo định dạng DOS…\n"

msgid "converting file %s to DOS format...\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Estamos convertendo o arquivo %s para a versão Unix do formato '%s'...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para a versão Unix do formato (%d)…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para o formato Mac, por favor, espere…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Estamos convertendo o arquivo %s para a versão Mac do formato (%d)…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para a versão DOS do formato de `%s"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para a versão DOS do formato (%d)…"

msgid "problems converting file %s to file %s\n"
msgstr "Estamos convertendo o arquivo %s para o formato de texto padrão."

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não é possível ler o arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "A tela está em execu endouro de %s."

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %s possui %d campos (esperado %<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo de entrada '%s': não é permitido."

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Par de parâmetros inválidos. Ocorreu um erro ao substituir o valor do "
"campo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: O parâmetro de substituição não é válido. Por favor, tente novamente."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
