msgstr "Phiên bản Windows 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de referência para o Windows XP em versão 32 bits (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha de referência para o Windows XP em versão 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha técnica do Windows para sistemas de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bit (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha de referência para o sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro de texto para o Windows XP (EMX)."

msgid "%s version.\n"
msgstr "Ficha de testeio %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Ocupação de Unicode UTF-16. "

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có homenagem para o suporte Unicode de nomes de arquivos."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Có hora de apoio para linguagens nativas."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Para o suporte ao usuário e às suas informações de grupo. Para obter mais "
"detalhes, tente 'git help'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o usuário e grupo de proprietários. Para obter mais "
"informações, tente '`%s --help'."

