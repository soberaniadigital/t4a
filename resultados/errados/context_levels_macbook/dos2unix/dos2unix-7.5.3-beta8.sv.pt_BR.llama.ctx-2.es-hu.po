msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [parâmetros] [-n infile input.txt output.txt]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         alteração de permissões para arquivos"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                apenas converte os saltos de linha (padrão)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               usa o código de ponto e vírgula Windows "
"(Windows-1252) para a Europa Ocidental."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa a tabela de códigos DOS 437 (Estados Unidos) "
"(padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS850 (página de códigos do sistema operacional) para acessar as "
"configurações avançadas."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tecnologia de Codificação Tabu (DOST) -860 para acessar as "
"configurações do sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS teckentabell 863 (français canadien)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS 865 (nórdico) para acessar as páginas de código."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção -b, --keep-bom        conserva a marca de ordem do byte (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom         conserva a marca de ordem do byte (Byte Order Mark)"
" (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão       ascii, 7bit, iso, mac, padrão"
" é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação dos mensagens de texto que serão"
" exibidas em terminal\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr "opção --add-eol adicionar uma linha ao final do arquivo"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"Forçar a conversão de arquivos binários -f, --force           força a "
"converção dos ficheiros binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            visualiza este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR] visa informação dos arquivos a serem analisados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adiciona a marca de ordem do byte (Byte Order Mark) "
"padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile         escreve em um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais -o, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreve no arquivo antigo (padrão) \n"
"                    ficheiro ...               arquivos para converter em formato de arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todas as advertências"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      elimina a marca de ordem do byte (Byte Order "
"Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      elimina a marca de ordem do byte (Byte Order "
"Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salta sobre ficheiros binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantém a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suponha que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be pressa que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utmárias detalhadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguir links simbólicos e converter os destinos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetze symbolische links mit convertidos arquivos "
"(die Originaldateien bleiben unverändert)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos nem seus destinos "
"(padrão)"

