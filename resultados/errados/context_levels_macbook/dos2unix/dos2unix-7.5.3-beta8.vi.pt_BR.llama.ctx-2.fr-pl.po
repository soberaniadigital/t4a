msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [arquivos ...] [-n entrada_ficheiro "
"saída_ficheiro …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         autorização para alterar o proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                domyślny tryb konwersji ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre os sinais de caráter DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Utilize o código de codificação padrão do Windows (1252) para Tâmil."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Utilize o código de caracteres DOS 437 (US) padrão (-437). Para obter mais "
"informações, tente `%s --help'."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o código de codificação do DOS 850 (Tây Anh) para acessar os "
"arquivos."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilize o código de codificação DOS 860 (português) do Windows para acessar "
"arquivos no sistema operacional Microsoft Windows."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o código de codificação POSIX (DOS) 863 para acessar os arquivos no "
"sistema operacional Windows XP."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Utilize o código de codificação POSIX (DOS) 865 (nordestina)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres 8 bits para a faixa de bits 7"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        conservando o marcador de ordem dos bytes (byte order"
" mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        giữ nguyên “Byte Order Mark” (mặc định)\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   chave ASCII, 7bit, ISO, MAC; "
"padrão é ASCII por defeito"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      escolha o código de exibição para mostrar mensagens "
"textuais (ansi, unicode ou utf8; padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar um caractere de nova linha ao final da "
"última linha se ele não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "force a conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            affiche este opção de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=INFO]    exibir as informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conservar a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         bổ xung thêm dòng mới\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o indicador de byte order mark (por padrão "
"com UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào         tập tin gốc trong chế độ tập tin mới\n"
"   tập tin ra           tập tin đầu tiên trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dấu ngắt dòng vào dòng cuối cùng nếu không"
" có dấu ngắt dòng (mặc định)\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no stdout (saída padrão)"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregar no arquivo antigo (padrão) \n"
"   ficheiro ...            fichas a converter neste formato de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      remover o sinal de byte order mark (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"gostaria de traduzir o seguinte trecho em português, preservando a "
"formatação original e mantendo as variáveis como elas aparecem. Por favor, "
"transforme-o no idioma brasileiro sem alterações."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            ignorar arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conservar o codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suponha que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise verbal"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Sempre que você encontrar um erro, por favor, entre em contato com o suporte"
" técnico para obter assistência."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin dựa trải lên các phần tử nào) (các file source original thì để "
"không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserte as ligações simbólicas e os campos "
"inalterados (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão"

