msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópias de segurança para %s [opções] [arquivos ...] [-n "
"entrada/saída_de_dados ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite alterar o proprietário de um arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                csak sortörések átalakítása (chaveamento de formato)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converter entre codificação DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               dùng trang mã Windows 1252 (Tây Âu)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizar código DOS 437 (US) (padrão definido)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                DOS 850 utilizar (Nyugat-európai) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                DOS 860 utilizar (Português do Brasil)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                DOS 863 utilizar (Canadees Frans)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                DOS 865 (Baixo/Alto) usado para codificação de "
"caracteres"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de caracteres para base octal (chaveamento)"
" 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantém o “Byte Order Mark” original (Máx. %<PRIuMAX> "
"bytes)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chaveamento de caracteres:   ascii, 7bit, iso, mac, "
"padrão é 'ascii'"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adicionar codificação de mensagens para exibir alertas\n"
"   CODERING             'ansi', 'unicode', of 'utf8' (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar um caractere de nova linha no final da última "
"linha se ele ainda não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn chuyển đổi các tập tin nhị phân"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            hiçen thívekészítmény megjelenítése"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=COR]        exibir informações sobre o ficheiro ...            "
"analisar conjuntos de dados para obter detalhes"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        kimeneti fájl dátumának megtartás\n"

msgid " -L, --license         display software license\n"
msgstr "opção --license         licença de software tonen\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline          adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Marca de Ordem do Bit” (por padrão UTF-8) "
"\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin vào         tập tin gốc trong chế độ tập tin mới\n"
"tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown       não permite a alteração de propriedade do "
"arquivo (padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          không thêm dấu ngắt (newline) trong cuối cùng của "
"danh sách reguler (default)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào đầu ra tiêu chuẩn\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi em ficheiro antigo (método padrão) \n"
"   arquivo(s)...            os campos destes campos precisam ser convertidos no modo de backup"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           silêncio do sistema de saída/entrada\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      gỡ bỏ “Byte Order Mark” (mặc định)\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "bỏ qua tập tin nhị phân (mặc định) -s, --safe"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 kódolás megtartása"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le acreditando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be acredite que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        thông báo detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   seguir links simbólicos e converter para o formato "
"desejado."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ignore links mínimos (método de skip) para caminhos "
"simbólicos que não devem ser alterados (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr ""
"Ficheiro de texto para o sistema operacional DOS em modo de 16 bits (Watcom "
"C).\n"

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Phiên bản DOS 16 bit (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do DOS em 32 bits (Watcom C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenome do DOS em modo de 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Fenome do MSYS. \n"

msgid "Cygwin version.\n"
msgstr "Fenome Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenômeno Windows de 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Fenome do Windows em 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenômeno Windows de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Fenome do Windows em 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenômeno Phiên Bảo Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenômeno Phiên Bảo Windows de 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Fenome do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "%s versão."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có homenagear Unicode UTF-16. \n"

msgid "Without Unicode UTF-16 support.\n"
msgstr ""
"Não há suporte para Unicode UTF-16. Para obter mais informações, tente `%s "
"--help'."

msgid "With Unicode file name support.\n"
msgstr "Có homenagear o nome do arquivo Unicode."

msgid "Without Unicode file name support.\n"
msgstr ""
"Não há suporte para tamanho de entrada Unicode sem ajuste. Para mais "
"informações, tente '`%s --help'."

msgid "With native language support.\n"
msgstr "Có horação de apoio para a localização geográfica do idioma."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Com a ajuda do suporte ao usuário e da comunidade, você pode manter seu "
"arquivo de texto. Para obter mais informações, tente '`%s --help'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Sem suporte à manutenção de usuários e grupos. Para obter mais informações, "
"tente '`%s --help'."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de entrada para o arquivo temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Está gerando o BOM para %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM '%c'.\n"

