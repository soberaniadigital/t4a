msgstr ""
"Erro de conexão com o servidor. Ocorreu um erro ao substituir a chave."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"erro de conexão com o servidor. Ocorreu um erro ao substituir a camada "
