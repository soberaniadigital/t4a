msgstr "Ficha de referência do Windows para a versão em 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Ficha de referência do Windows em 32 bits (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows, versão de 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Ficha de referência do Windows, versão em 32 bits (MinGW)"

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Ficha de Windows para sistemas de 64 bits (MSVC %d)."

