msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso para o programa 'cachorro' é a seguir. Para iniciar, você deve"
" digitar `cd` e pressionar Enter."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"ISO -iso                    converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Utilize a tabela de codificação do Windows (1252) para o Vietnã."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize a tela de linha DOS 437 (EUA) como padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize a tela de linha DOS 850 (Tây Anh) para o processamento do seu "
"documento."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use a linha de comando DOS 860 (português brasileiro)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use a linha de comando DOS 863 (Ca Na Da) para utilizar o programa francês "
"do Linux."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use a linha de comando DOS 865 (Bacau) para o seu projeto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservar o “Byte Order Mark” (BOM) originalmente "
"inserido no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preservar o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de converção:   modo de "
"conversão: ASCII, 7bit, ISO, MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      endereça o código de exibição para textos em "
"ansi/unicode/utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"linha se ele não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de conversão dos arquivos binários -f, --force           obrigatório"
" para converter os ficheiros binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "Use o flag `--gb18030` para converter UTF-16 em GB18030."

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=INFO] mostrar dados sobre o arquivo %s%s%s.txt            "
"Arquivos que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        preservar a data de criação do arquivo para o "
"resultado"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         apresentar licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione o sinal BOM (marca de ordem) ao UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever no novo arquivo\n"
"   para o início do tamanho máximo de um bloco (max_blocksize)\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dado de nova linha no final se o arquivo"
" estiver vazio (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão) \n"
"   ficheiro ...            arquivos que precisam ser convertidos para o formato do novo sistema de dumps"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem mensagens de erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o byte order mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o Byte Order Mark (BOM) -r, --remove-bom      вилучити "
"позначку порядку байтів (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            apagar linhas duplicadas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assumindo que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rá que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  para seguir links simbólicos e converter dados"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr "Não há informações suficientes para traduzir."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos e arquivos de origem "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         apresentar versão"

