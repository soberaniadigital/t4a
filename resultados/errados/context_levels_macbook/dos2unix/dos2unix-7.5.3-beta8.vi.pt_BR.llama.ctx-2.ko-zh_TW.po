msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Método de uso: %s [opções] [-n <input_file> <output_file> ...]}"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converte o conjunto de caracteres DOS e ISO-8859-1 "
"entre si."

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize a página de código Windows 1252 (Tây Âu) para o processamento do "
"arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Utilize o código DOS 437 (US) padrão, que é a codificação de caracteres EUC "
"da língua portuguesa."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Utilize a página DOS 850 (Tây Árabe) para o seu projeto."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS 860 (Bồ Đào Nha) para acessar os arquivos de textura em um "
"sistema operacional Windows."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o código DOS 863 (Ca Na Da Pháp) para acessar as linhas de texto."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize a página DOS 865 (Europa do Norte) para o seu projeto de "
"desenvolvimento web."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de entrada para o espaço de "
"bits de 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "giúpia o BOM (Byte Order Mark) para a ordem original dos bytes."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"giúpia o arquivo '%s' com a opção '-b', para manter o BOM (Byte Order Mark) "
"na ordem de bytes."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão   chave de convergência: ascii, "
"7bit, iso, mac (padrão: ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir các thông báo\n"
"   bảng mã: ansi, unicode, utf8. O valor padrão é ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"coluna se ela não tiver nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "bateria de energia para o processo, %s%d.txt"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help             Mostra este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações do arquivo ...             dados "
"dos campos de entrada"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preservar o dia de criação do arquivo original\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         hiêrên thị giấy phép dùng phần mềm"

msgid " -l, --newline         add additional newline\n"
msgstr ""
" -l, --newline          adiciona uma linha em branco ao final da entrada de "
"texto\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção --add-bom         adicionar “Byte Order Mark” (máscara de ordem de "
"bytes) (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         寫入新檔\n"
"   tập tin gốc trong chế độ tập tin-mới\n"
"   tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar os direitos de propriedade do "
"arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          Não adiciona dáfima (dígito final) se não houver "
"nenhum no final da linha, caso contrário. (Padrão)\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no stdout padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile         寫入原檔 (預設) 檔案 ...            旧檔案模式中要轉換的檔案"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, sem nenhum aviso de erro ou "
"alerta."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção -r, --remove-bom      apagar o “Byte Order Mark” (BOM) padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            輸入/出入檔案 (預設) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     UTF-16 codificação mantida"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rằng o formato de entrada é UTF-16BE."

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciação detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tin đã chuyển đổi (các"
" tập tin đích nguyên gốc thì để nguyên không thay đổi)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar links simbólicos e seus alvos sem alteração"
" (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         apresenta o número de versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha de versão DOS 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha de versão DOS 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficheiro de texto não encontrado."

