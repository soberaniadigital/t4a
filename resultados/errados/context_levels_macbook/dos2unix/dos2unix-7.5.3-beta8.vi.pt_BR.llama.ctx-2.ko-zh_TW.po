msgstr "Ficha de referência para o Phiên bản DOS 32 bit (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha de versão MSYS."

msgid "Cygwin version.\n"
msgstr "Ficha de modelo Cygwin. \n"

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (Watcom C)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Ficha técnica do Windows 32 bits (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bit (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bit (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do sistema operacional OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de versão %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Ocupação de Unicode UTF-16 suportada."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode.\n"

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivo Unicode."

msgid "With native language support.\n"
msgstr ""
"Olá! O programa `glibc` não é suportado nesta versão do Linux. Para obter "
"mais informações, consulte a documentação oficial."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como você está se sentindo hoje?"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o usuário original e grupo de proprietários do arquivo."

msgid "Path for temporary output file is too long:"
msgstr "O caminho de saída temporário do arquivo está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Estamos gravando %s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "%s possui BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Assumindo que a tabela de caracteres é codificada em UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Seja uma tabela codificada em UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "está utilizando %s como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na alteração de permissões do arquivo temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário ou grupo de proprietários do arquivo %s não tem permissão para "
"acessá-lo."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "falha na verificação da alteração do proprietário e grupo de %s:"

msgid "problems renaming '%s' to '%s':"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "O objetivo deste link é o %s."

msgid "          output file remains in '%s'\n"
msgstr "O arquivo de saída '%s' não foi alterado."

msgid "Skipping binary file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Fiquei com dificuldade em encontrar o arquivo %s UTF-16, tamanho do wchar_t "
"não é permitido. O tamanho de um wchar_t deve ser fixo."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Falha na conversão UTF-16 do arquivo %s, no dado da linha %u. Erro de "
"conversão UTF-16."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Fique em dia com o arquivo UTF-16 %s, que não suporta conversão para UTF-16 "
"nesta versão. Para obter mais informações, tente `%s --help'."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho em %s, isso não é um arquivo típico."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Remova o arquivo %s, que é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Fiquei com dificuldades para encontrar a ligação de máquina virtual %s. Por "
"favor, informe o número do seu IPv4."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Falha na conexão de sinal %s, o objetivo não é um arquivo típico."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Falha na conexão de ligação mínima, o link %s não é um arquivo típico."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para um arquivo de texto Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um arquivo no formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo `%s' para um arquivo DOS no formato..."

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo a conversão do arquivo `%s' para o formato DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Estamos convertendo o arquivo %s para um arquivo Unix formatado..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Está convertendo o arquivo %s para a versão Unix do formato %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Estamos convertendo o arquivo %s “%s” para o formato Mac, por favor "
"espere..."

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Está convertendo o arquivo %s para a versão Mac do formato..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Estamos convertendo o arquivo %s para um arquivo DOS formatado..."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Está convertendo o arquivo %s para a versão DOS do formato..."

msgid "problems converting file %s to file %s\n"
msgstr ""
"Estamos convertendo o arquivo %s para um arquivo de texto separado por "
"linha."

msgid "problems converting file %s\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "active code page: %d\n"
msgstr "A tarefa está em execu endouro: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s para o modo '%d' não é permitida."

msgid "option '%s' requires an argument\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro de sintonia do proxy. Ocorreu um erro ao substituir o valor."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Código de erro. Ocorreu um erro ao substituir o proxy."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
