msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [cópias] [arquivos …] [-n arquivo_entrada arquivo_saída …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"opção --allow-chown         permite a alteração do proprietário de arquivos "
"em texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento padrão de conversão textual"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   converte entre o sinalo DOS e ISO-8859-1 \n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               usa codificação Windows 1252 (Taiu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                usa trama de caracteres DOS 437 (US) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usa codificação DOS 850 (Tây Ático)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                usa codificação DOS 860 (Brasil)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                usa tabela de caracteres DOS 863 (Ca Na Đa Pháp) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utiliza trângulo de codificação DOS 865 (Bacau) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte c/d caracteres de 8 bits para espaços do 7 "
"bit"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém o “Marcação de Ordem dos Bits” (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        mantém o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de modo de conversão --convmode\n"
"   modo de conversão: ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     setar a codificação de mensagens para exibição\n"
"   codificações possíveis: ansi, unicode, utf8; padrão é ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de quebra de linha no final da última"
" linha se não tiver"

msgid " -f, --force           force conversion of binary files\n"
msgstr " -f, --force           obrigatório converter arquivos n-ais separados"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb160949382d         converte UTF-16 para GB160949382d"

msgid " -h, --help            display this help text\n"
msgstr "opção --help            exibe esta ajuda atualizada."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=ZH_CN]        exibe informações da tabela de dados (table of "
"contents) para os arquivos a serem analisados. Arquivo(s)..."

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        preserva o dia e a data do arquivo de origem na saída"
" da tabela"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibe a licença para uso de aplicativo em linha de "
"comando"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem de Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         gera um novo arquivo de texto\n"
"   nome_de_origem          origem do arquivo no modo 'nome' (novos)\n"
"   nome_do_salvamento       salva o arquivo em uma nova localização"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite alterar o proprietário do arquivo (opção "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar quebra de linha no final da linha, mesmo"
" sem a presença do caractere de nova linha (configuração padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (padrão)\n"
"   tabela ...            as tabelas que precisam ser convertidas neste modo de conversor\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"chave -q, --quiet           modo silencioso, oculta todas as mensagens de "
"aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apaga o “Byte Order Mark” (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "gỗ bỏ ‘BOM’ (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            excluir linhas em segundo plano (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considera o padrão de codificação como UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be implica que o formato do arquivo de entrada é "
"UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        exibição detalhada das mensagens"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  para o caminho simbólico móvel e a conversão do "
"objetivo"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca links simbólicos por arquivos convertidos (as "
"origens permanecem inalteradas)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantém o link simbólico e seu alvo inalterados "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do software"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficha técnica DOS 16 bits (Watcom C)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica DOS 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficha técnica DOS em 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Ficha técnica do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficheiro de origem não encontrado."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 64 bit (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenômeno Windows 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome de base Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do Phiên bản OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro não encontrado."

msgid "With Unicode UTF-16 support.\n"
msgstr "São suportados Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Có hỗ trợ bản địa hóa ngôn ngữ."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como parte do suporte de proteção, mantenha o proprietário original e a "
"associação da grupo para cada arquivo."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para o armazenamento de arquivos por usuários individuais e "
"grupos. \n"

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo temporário de saída está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Gravando BOM para %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O arquivo de entrada %s possui um BOM %s."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "gab um problema ao tentar resolver a ligação simbólica fraca »%s«."

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando o %s como arquivo temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabriel encontrou um erro ao alterar as permissões do arquivo de saída "
"temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "O usuário e/ou grupo que possui a pasta %s não podem ser preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Gabriel encontrou um erro ao alterar o proprietário e grupo da pasta de "
"saída temporária %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao renomear o arquivo “%s” para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o objetivo dessa conexão simbólica '%s'"

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída ainda contém o conteúdo original da pasta %s"

msgid "Skipping binary file %s\n"
msgstr "Bora deparar a tabela binária %s"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o código de caracteres %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra a tabela de caracteres UTF-16 %s, pois o comprimento do wchar_t não é "
"necessariamente %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra a tabela de texto UTF-16 %s, pois ocorreu um erro na conversão do "
"UTF-16 no registro %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a conversão de UTF-16 não é suportada nesta "
"versão do software. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borraremos o arquivo %s, pois ele não é um típico arquivo de texto. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra o %s, ficheiro de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borra o símbolo de ligação %s, pois seu alvo não é uma pasta comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o link simbólico móvel %s, alvo da ligação simbólica em movimento %s "
"não é uma pasta regular. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo \"%s\" no formato "
"Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato Mac está em "
"andamento...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Mac..."

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato DOS está em andamento, "
"resultando no novo arquivo “%s”.\n"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato de arquivo Unix %s"
" com a extensão %s está em andamento...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato Mac está em "
"andamento…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"O processo de conversão do arquivo %s “%s” para o formato do sistema "
"operacional DOS é concluído com sucesso…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr ""
"A conversão do arquivo %s “%s” para o formato DOS está em andamento..."

msgid "problems converting file %s to file %s\n"
msgstr "Ao converter o arquivo %s para o arquivo %s, foram encontrados erros."

msgid "problems converting file %s\n"
msgstr "Encontrado erro ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "o sinal '%c' para o índice -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "A interface de tradução está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu erro ao definir o modo de conversão %s, que não é permitido"

msgid "option '%s' requires an argument\n"
msgstr "Opção \"%s\" requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "Já enviou uma tabela de exibição inválida %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo da pasta %s não foi especificado no novo modo de criar arquivos "
"em lote."

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Falta o elemento inferior da troca."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Falta o High-Surrogate no lugar."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
