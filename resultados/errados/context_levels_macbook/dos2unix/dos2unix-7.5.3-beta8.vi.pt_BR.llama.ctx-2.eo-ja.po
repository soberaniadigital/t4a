msgstr ""
"O arquivo de entrada %s possui BOM %s. Para mais informações, tente `%s "
"--help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrou um erro ao resolver o link simbólico '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"Gabriel, você encontrou um erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr ""
"%s está sendo utilizado como um arquivo temporário para armazenar dados."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Gabbilement ao tentar alterar as permissões do arquivo de saída temporário "
"%s, ocorreu um erro:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e o grupo de proprietários do arquivo %s não possuem permissão "
"para manter a privacidade. A propriedade ou grupos que pertencem ao arquivo "
"são desconhecidos."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "falha na alteração do nome de usuário ‘%s’ para ‘%s’:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "este é o propósito deste link simbólico '%s'"

msgid "          output file remains in '%s'\n"
msgstr "Obtido arquivo de saída residual em '%s'."

msgid "Skipping binary file %s\n"
msgstr "Borra o conjunto de dados dividido em dois ficheiros %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para a página de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Borra o arquivo UTF-16 %s, a largura do 'wchar_t' não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borquei o arquivo UTF-16 %s, e houve um erro na conversão de UTF-16 no "
"registro do dado. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para ISO-8859-1 não é suportado nesta"
" versão do programa.UTF-16 conversão também não está disponível."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra {%s}, aí não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borra {%s}, o arquivo de saída %s é um simboloico link."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o simbolo de ligação macia %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borra o símbolo de ligação pequena %s, pois seu objetivo não é um arquivo "
"típico. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borra o símbolo de ligação pequeno %s, objetivo do link simbólico %s não é "
"um arquivo normal. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"A conversão do arquivo %s para o arquivo \"%s\" no formato Unix está em "
"andamento..."

msgid "converting file %s to Unix format...\n"
msgstr "Convergindo ficheiro “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato Mac está em andamento…"

msgid "converting file %s to Mac format...\n"
msgstr "Convergindo ficheiro “%s” para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"A conversão do arquivo de texto “%s” para o formato DOS está em andamento..."

msgid "converting file %s to DOS format...\n"
msgstr "Convergindo o arquivo “%s” para a versão DOS..."

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Fazendo a conversão do arquivo %s “%s” para o formato de arquivo Unix "
"%s...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Convergindo o arquivo %s “%s” para a versão Unix do tipo %s...\n"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Macintosh...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Fazendo a conversão do arquivo %s “%s” para o formato Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Converting file %s “%s” to a DOS format (%d)…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Converting file %s “%s” to DOS format (%<PRIuMAX>)..."

msgid "problems converting file %s to file %s\n"
msgstr "Em processo de conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "Encontrado problema ao converter arquivo %s."

msgid "can not read from input file %s:"
msgstr "não é possível ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"O comando '%c' para a opção '-i' ou '--info' foi inserido incorretamente."

msgid "active code page: %d\n"
msgstr "a tela está em execução atualmente: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "Já foi indicado um modo de conversão %s inválido."

msgid "option '%s' requires an argument\n"
msgstr "Túm escolha \"%s\" requer um número de opção."

msgid "invalid %s display encoding specified\n"
msgstr ""
"Já foi enviado um aviso de que a apresentação gráfica %s não é válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no modo de criação de novos "
"arquivos"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível salvar no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "erro: Cadeia de substituição inválida. Substituição incompleta."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de substituição inválida. Falta cadeia superior para a troca."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, pois a codificação atual do local não é UTF-8. "
"Apresente mais informações."
