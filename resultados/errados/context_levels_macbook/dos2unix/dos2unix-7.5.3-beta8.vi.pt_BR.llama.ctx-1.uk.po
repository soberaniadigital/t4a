msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Cách dùng: %s [các tùy chọn] [tập tin …] [-n tập tin vào tập tin ra]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite alteração do proprietário de arquivo táp tin"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo padrão de conversão para caracteres ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a tabela de caracteres do Windows 1252 (Tây "
"Âu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tela de linha DOS 437 (EUA) (padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a tela de comando DOS 850 (línguas do Reino "
"Unido) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar a tela DOS no modo de código (Bồ Đào Nha) "
"PT-BR"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                dùng trang mã DOS 863 (Ca Na Đa Pháp)\n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                dùng trang mã DOS 865 (Bắc Âu)\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converter de caracteres para base octal a binária"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --keep-bom        zerar o “Byte Order Mark” (BOM) sem manter a ordem dos "
"bytes."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        preservar o “Byte Order Mark” (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão de caracteres\n"
"   modo de conversão de caracteres:\n"
"acii, 7bit, iso, mac, mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     adiptando a tela para exibir mensagens de erro em texto\n"
"   código ansi padrão:        ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar quebra de linha no final da linha se não houver"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           necessita de forçar a conversão dos arquivos binários "
"nº2\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030         Converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            apresentar esta ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo\n"
"   nome do arquivo ...            nomes dos arquivos que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"-k, --keepdate        mantém a data de criação do arquivo para o resultado"

msgid " -L, --license         display software license\n"
msgstr "licença -L -- licenças para uso de aplicativos interativos\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         inserir novo caractere de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione o “Byte Order Mark” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permitirá a mudança do proprietário de arquivo "
"(efeito padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem-adicionar-eol          não adiciona quebra de linha no final da linha "
"se ela não existir (tipo)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       ghi vào đầu ra tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      excluir o “Byte Order Mark” (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --remover-bom      geloiar o “Marca de Ordem dos Bits” (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --seguro            exclusão de dados duplicatas (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar tabela de codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "-ul, --assume-utf16le coi rã que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coi régando que o formato do dado de entrada é "
"UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        modo de mensagens detalhadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink o efeito de seguir links simbólicos e converter "
"objetivos."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay liên kết mềm bằng tập tin đã chuyển đổi\n"
"                   (các tập tin đích nguyên gốc thì để nguyên không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos e objetivos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         apresentar símbolo de versão"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenótipo DOS, versão de 16 bits (TURBOC).\n"

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 32 bit (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Fenômeno dos sistemas operacionais DOS, versão de 32 bits (DJGPP).\n"

msgid "MSYS version.\n"
msgstr "Phiên bản MSYS."

msgid "Cygwin version.\n"
msgstr "Phiên bản Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows, versão de 64 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows, versão de 32 bits (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows, versão em 32 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows, versão de 32 bits (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows, versão de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows, versão de 32 bits (MSVC %d).\n"

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficheiro de origem para a versão do OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro de origem para a versão do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficheiro de origem %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "com homenização Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Sem suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Sem suporte ao Unicode nas nomenclaturas de arquivos."

msgid "With native language support.\n"
msgstr "Có hỗ trợ bản địa hóa ngôn ngữ."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como parte da homenagem pela colaboração contínua dos usuários e do grupo de"
" proprietários, você pode solicitar acesso aos seus arquivos."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter os parâmetros do usuário e grupo de proprietários"
" dos arquivos."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída do trabalho excessivamente longo:"

msgid "Writing %s BOM.\n"
msgstr "Gravando BOM para %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "Arquivo de entrada %s possui BOM UTF-8. \n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrou erro ao analisar o link curto m%s"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporária: %s"

msgid "using %s as temporary file\n"
msgstr "estamos utilizando %s como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr ""
"Erro ao alterar permissão de acesso ao arquivo de saída do relatório %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e o grupo que possuem %s não podem manter seus direitos originais."
" Para obter mais informações, tente `%s --help'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e agrupamento do arquivo de saída parcial %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên \"%s\" thành \"%s\":"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o propósito dessa ligação fina é transmitir o símbolo '\\u%s'."

msgid "          output file remains in '%s'\n"
msgstr "tápia de resultados cổn hay và trong “%s”\n"

msgid "Skipping binary file %s\n"
msgstr "Borraremos o arquivo de duas partes %s"

msgid "code page %d is not supported.\n"
msgstr ""
"não há suporte para a linha de código %d. Aqui está o que você precisa "
"saber."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, cujo tamanho do caractere wchar_t não é de %d "
"byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borremos o arquivo UTF-16 %s, que apresentou erro ao converter dados UTF-16 "
"no bytecode da linha %u. Para mais informações sobre como lidar com tais "
"problemas em nosso sistema de codificação, consulte a documentação."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, converte para a versão não suportada nesta edição"
" de %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borraremos %s, pois não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borraremos %s, o arquivo de resultado é um link curto."

msgid "Skipping symbolic link %s.\n"
msgstr "Borraremos o link curto %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borraremos o link curto %s, pois seu objetivo não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borraremos o link curto %s, objeto no qual é armazenado um símbolo de "
"referência pequena que não seja um arquivo típico. A distância entre eles em"
" metros é igual ao valor do parâmetro '%<PRIuMAX>'."

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo \"%s\" no formato "
"Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Mac...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Mac...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo “%s” para o formato DOS, criando um novo"
" arquivo “%s”.\n"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Macintosh %s…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Macintosh…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato DOS, tendo como "
"saída o arquivo codificado em base64 no formato JSON...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Enquanto fazia a conversão do arquivo %s para o arquivo %s, foram "
"encontradas problemas"

msgid "problems converting file %s\n"
msgstr "encontrou problemas durante a conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "custo “%c” do parâmetro -i ou --info está incorreto."

msgid "active code page: %d\n"
msgstr "a tela ativa possui a linha %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr "ocorreu um erro ao definir o modo de conversão %s inadequado."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” yêu cầu một đối số"

msgid "invalid %s display encoding specified\n"
msgstr ""
"o código apresentado para a visualização da tabela de sinal não é correto %s"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi definido no novo modo de criar arquivos"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível gastar o registro para o arquivo de resultado: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro de comunicação entre os dispositivos conectados. Ocorreu uma falha na "
"troca do par inferior."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro de comunicação entre componentes. Ocorreu uma falha na troca do "
"componente superior."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, banco de dados ASCII não é compatível com a "
"codificação local UTF-8. Para obter mais informações sobre as diferenças "
"entre essas codificações e como lidar com elas em nosso sistema, consulte "
"'Compreendendo o tratamento das diferentes codificações no Linux'."
