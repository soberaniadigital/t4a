msgid "problems resolving symbolic link '%s'\n"
msgstr "gặp lỗi khi phân giải liên kết mềm “%s”\n"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilizando o %s como arquivo temporário"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na alteração dos permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O usuário e/ou grupo de proprietários do arquivo %s não podem ser "
"preservados. Para obter mais informações, tente '`%s --help`'."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Erro ao alterar dono e grupo do arquivo de saída temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "gặp lỗi khi đổi tên “%s” thành “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          '%s' é o objetivo da ligação simbólica demais “%s”"

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída ainda está no local “%s”"

msgid "Skipping binary file %s\n"
msgstr "Borrando o arquivo de dados %s"

msgid "code page %d is not supported.\n"
msgstr "não é suportado o painel de código %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Cancelar o arquivo %s UTF-16, tamanho do wchar_t não é igual a %d byte. Por "
"favor, verifique se você está lendo um arquivo de texto simples e não uma "
"sequência Unicode."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Cancelar o arquivo %s, foi gerada uma exceção ao converter UTF-16 na linha "
"%u."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-8 não é suportado nesta "
"versão do software. A conversão de UTF-16 não está disponível na atualização"
" %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho, %s não é um arquivo comum. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Remova o arquivo %s, ficheiro de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a conexão fracassada. %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Borracho o link curto %s, destino não é um arquivo comum. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borracho o link curto de %s, alvo da ligação curta não é um arquivo comum. "
"\n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Ao converter o arquivo %s para um arquivo no formato Unix, você recebeu a "
"mensagem de erro 'Arquivo não encontrado'. Ocorreu uma falha na análise do "
"caminho. Por favor, verifique se o nome e extensão do arquivo estão "
"corretos."

msgid "converting file %s to Unix format...\n"
msgstr "Fazendo o conversor de arquivo “%s” para a fomação Unix..."

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Fazendo o conversor de arquivo para Mac…"

msgid "converting file %s to Mac format...\n"
msgstr "Fazendo o conversor de arquivo para Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato DOS..."

msgid "converting file %s to DOS format...\n"
msgstr "Fazendo o conversor de arquivo para DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s..."

