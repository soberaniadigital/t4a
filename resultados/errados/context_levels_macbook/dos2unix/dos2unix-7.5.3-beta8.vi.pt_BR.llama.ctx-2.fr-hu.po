"essenciais na comunicação entre processos em sistemas distribuídos."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópias de segurança para %s [opções] [arquivos ...] [-n ficheiro_entrada "
"ficheiro_saida …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         autorise o acesso ao ficheiro para outros usuários e "
"grupos (máx. %PRIuMAX) \n"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    conversão entre os conjuntos de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilize o código de caracteres Windows 1252 (Europa "
"do Leste) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilize o código de caracteres DOS 437 (US) "
"(padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilize o código de caracteres DOS 850 (Europa do "
"Leste)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                dùng trang mã DOS 860 (Bồ Đào Nha)\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize o código de caracteres DOS 863 (Francês "
"Canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize o código de caracteres DOS 865 (Nordique) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o espaço dos 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantenha o “Marca de Ordem dos Bits” (BOM) original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        garde la marque d'ordre des octets (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão:   ASCII, 7bit, ISO, MAC, módulo "
"padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define o código de exibição para mensagens textuais\n"
"   codificação da tabela de símbolos:\n"
"ansi (padrão), unicode ou utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr "adicionar uma quebra de linha no final da última linha se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           force a conversão de arquivos binários em formato "
"ficheiro/arquivo separado por linhas (CSV)"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         conversão UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "opção -h, --help            affiche ce texto de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=COR]        exibe as informações do arquivo de entrada "
"[arquivos para análise]\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserte a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibir a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione linhas extras ao final do arquivo"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o “marcação de ordem dos bytes” (por padrão "
"com UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          cria um novo arquivo de entrada e saída no modo 'novos ficheiros' \n"
"   tápi-tin-vào      fichier original neste modo\n"
"   tápi-tin-ra           fichier de saída neste modo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown       não permite alterar o proprietário do arquivo "
"(por padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem-eol          não adiciona uma nova linha no final se nenhuma for "
"inserida (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever no fluxo de saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregar o arquivo antigo (por padrão) \n"
"   ficheiro …            os ficheiros a serem convertidos no modo \"arquivo antigo\"\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, suprime todos os avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o Byte Order Mark (por padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o Byte Order Mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção -s, --safe            apagar linhas de um arquivo (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     conserte o encoding UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suponha que o formato de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suponha que o formato de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguimento de símbolos e a conversão dos "
"objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(ficheiros originais permanecem inalterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    conserte links simbólicos e alterações nas cargas "
"inalteradas (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número da versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficha técnica do DOS em 16 bits (Turbo C)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Ficha técnica do DOS em 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficheiro não encontrado."

msgid "MSYS version.\n"
msgstr "Ficha técnica MSYS."

msgid "Cygwin version.\n"
msgstr "Ficheiro não encontrado."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Ficheiro de texto para o arquivo 'arquivos/teste.txt'."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Phiên bản Windows 32 bit (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Phiên bản Windows 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Ficha técnica do OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficha técnica do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "Ficha de versão %s."

msgid "With Unicode UTF-16 support.\n"
msgstr "Há suporte para Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Não há suporte para Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Há suporte para nomes de arquivos Unicode."

msgid "Without Unicode file name support.\n"
msgstr ""
"Não há suporte para nomes de arquivos Unicode. Para obter mais informações, "
"tente '`%s --help'."

msgid "With native language support.\n"
msgstr "Não foi possível obter estado (stat) do arquivo %s."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr ""
"Como parte do suporte ao usuário e grupo de propriedade dos arquivos, o "
"sistema permite a preservação das credenciais originas. Para obter mais "
"informações sobre como configurar essa opção, digite 'help'."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Sem suporte para preservar os direitos de propriedade do usuário e grupo. "
"Acesso não autorizado."

msgid "Path for temporary output file is too long:"
msgstr "O caminho para o arquivo de saída está muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Está gerando o BOM %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr ""
"O arquivo de entrada %s possui BOM %s. Para obter mais informações, tente "
"`%s --help'."

msgid "Assuming UTF-16LE encoding.\n"
msgstr "A tabela de código UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "A tabela de código UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "falha na resolução do link simbólico \"%s\""

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "utilize o arquivo %s como fonte temporária\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Erro ao alterar as permissões do arquivo de saída temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"O utilizador ou o grupo de propriedade do arquivo %s não podem ser "
"preservados."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"Erro ao alterar o proprietário e grupo do arquivo temporário de saída %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "Erro ao alterar o nome do arquivo para “%s”:"

msgid "          which is the target of symbolic link '%s'\n"
msgstr ""
"O objetivo do link simbólico 'ami a(z) „%s” szimbolikus' é desconhecido."

msgid "          output file remains in '%s'\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping binary file %s\n"
msgstr "Remova o arquivo binário %s do diretório de trabalho atual."

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o código de fonte %d."

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr "Borra o ficheiro UTF-16 %s, a medida do wchar_t não é de %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, uma falha de conversão UTF-16 teve lugar na linha"
" %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a conversão para UTF-16 não é suportada nesta "
"versão do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borracho o arquivo %s, isso não é um ficheiro regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Borrando a linha %s, o arquivo de saída %s é um link simbólico."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando o link simbólico mínimo %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando o link simbólico mínimo %s, não é um arquivo regular. O objetivo "
"deste tipo de ligação não pode ser alcançado."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Remova o link simbólico mínimo, pois seu destino %s não é um caminho de "
"arquivo regular. O objetivo do link simbólico pequeno (%d) n't é atingir "
"acesso direto ao conteúdo."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s para o formato Unix…"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo `%s' para o formato Mac, você pode usar a ferramenta "
"'Transfere de Formatos'. Para obter mais informações sobre como executar "
"esta tarefa ou quaisquer problemas que possam surgir durante o "
"processamento, consulte as seções `Trabalhando com Arquivos' e `Problemas "
"Comuns', respectivamente."

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Ao converter o arquivo `%s' para o formato DOS, você pode usar a ferramenta "
"'dos2unix'. Para mais informações sobre como utilizar esta ferramenta e suas"
" opções de configuração, consulte: `man dos2unix`."

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo `%s' para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Ao converter o arquivo %s “%s” para o formato Macintosh, você pode usar a ferramenta de conversão do terminal com as seguintes opções:\n"
"\t-d diretório [dir] -i input_file.txt -o output_file.mac \n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "A conversão do arquivo %s “%s” para o formato DOS está em andamento…"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, você pode encontrar problemas."

msgid "problems converting file %s\n"
msgstr "falha na conversão do ficheiro %s"

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "cão “%s” para escolher a opção -i ou --info bateu um erro."

msgid "active code page: %d\n"
msgstr "o programa está em execução: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"não foi possível converter o arquivo %s de acordo com o modo %<PRIuMAX> "
"especificado, que é inválido."

msgid "option '%s' requires an argument\n"
msgstr "a opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o arquivo de entrada %s não possui um caminho especificado no modo do novo "
"arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo %s desde a entrada do ficheiro\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"Erro: Cadeia de entrada inválida. O semi-codeto inferior está faltando."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"Erro: Cadeia de entrada inválida. O semi-codeto superior está faltando."

msgid "has %s BOM.\n"
msgstr "có %s BOM.\n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Bỏ qua tập tin UTF-16 %s, bảng mã ký tự địa phương hiện tại không phải là "
"UTF-8.\n"
