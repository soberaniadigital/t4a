msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Cácioque utilizar: %s [opções] [arquivo ...] [-n entrada-saída ...]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite alteração do proprietário de arquivo tátil\n"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento de conversão padrão para texto simples "
"(ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converter entre conjuntos de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizar tabela de codificação Windows 1252 (Tây Âu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"-437                utilizar tabela de caracteres DOS 437 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"-850                utilizar tabuada de caracteres DOS 850 (Tây Ái)   -1234"
"                 dùng trang mã DOS 1234 (Mỹ Thuật)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "-860                 DOS-codetabel 860 (Bồ Đào Nha) utilizar"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilizar tabela de códigos DOS 863 (Ca Na Đa Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                 Trigramas DOS 865 (Norte da Europa)    "

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converter de caracteres com oito bits para sete bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantenha o nativo “Marca de Ordem do Byte” (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantenha o “Byte Order Mark” original (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave -c, --convmode         modo de conversão\n"
"   modos de conversão:\n"
"ascii, 7bit, iso, mac (padrão é ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para exibir mensagens de erro\n"
"   Codificação:\t'ansi', 'unicode', ou 'utf8' (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"-e, --add-eol   adicionar o caractere de quebra de linha no final da última "
"linha se ele ainda não estiver presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "conversão forçada de tabelas binárias divididas em duas partes\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         UTF-16 para GB18030 convertem"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            Ajuda desta opção\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        hiển thị tính tin mã tập tin\n"
"   tập-tin …            các tập tin cần phân tích\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        giúp mua nguyên ngày tháng tập tin đầu ra\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         hipervisor de licença tonen"

msgid " -l, --newline         add additional newline\n"
msgstr " -l --newline         adicionar uma linha nova"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marca de Ordem de Bits’ (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona o caractere de quebra de linha no final "
"da última linha se nenhum for presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       ghi para saída padrão conforme a norma\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"tập-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimindo todas as avisões"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (BOM) do arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --safe            binária blocos de dados (padrão) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     giúmar bảng mã UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng định dạng đầu vào là UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be coi réu que o formato do dado de entrada é UTF-16BE."

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        emitir mensagens detalhadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"-F, --follow-symlink   simbolicamente ligado seguir e converter diretrizes"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por cópias convertidas do arquivo original\n"
"                   (arquivos de destino permanecem não modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr "-S, --skip-symlink    giúp mềm và không thay đổi liên kết (standaard)"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         apresentar versão do programa"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Phiên bản DOS 16 bit (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Ficheiro de origem não encontrado."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenômeno DOS em 32 bits (WATCOM C)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Ficheiro de origem não encontrado."

msgid "MSYS version.\n"
msgstr "Fenome do MSYS."

msgid "Cygwin version.\n"
msgstr "Ficheiro de origem do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Fenótipo Windows para arquitetura de 64 bits (MinGW-w64).\n"

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Phiên bản Windows 32 bit (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Fenômeno Windows 32 bits (MinGW-w64)"

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Phiên bản Windows 32 bit (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Fenome de base Windows para 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Fenome do Windows em 32 bits (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Fonte do OS/2 (Watcom C)."

msgid "OS/2 version (EMX).\n"
msgstr "Ficheiro não encontrado."

msgid "%s version.\n"
msgstr "%s versão."

msgid "With Unicode UTF-16 support.\n"
msgstr "Có hỗ trợ Unicode UTF-16."

msgid "Without Unicode UTF-16 support.\n"
msgstr "Sem suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr "Có hỗ trợ tên tập tin dạng Unicode."

msgid "Without Unicode file name support.\n"
msgstr "Não há suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Có hỗ trợ bản địa hóa ngôn ngữ."

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Como suporte ao manter o usuário original e a coleção de arquivos."

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr ""
"Não há suporte para manter o usuário original e a coleção de arquivos. Para "
"obter mais informações, tente '`%s --help''.\n"

msgid "Path for temporary output file is too long:"
msgstr "Caminho de verificação para arquivo temporário muito longo:"

msgid "Writing %s BOM.\n"
msgstr "Gravando BOM do %s."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "O conjunto de dados de entrada %s possui um BOM %s. \n"

msgid "Assuming UTF-16LE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16LE."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Esta é a tabela de codificação UTF-16BE."

msgid "problems resolving symbolic link '%s'\n"
msgstr "encontrou erro ao resolver a associação simbólica '%s'"

msgid "Failed to open temporary output file: %s\n"
msgstr "Erro ao abrir o arquivo de saída temporário: %s"

msgid "using %s as temporary file\n"
msgstr "%s é utilizado como arquivo temporário."

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "Gặp lỗi khi thay đổi quyền hạn của tập tin đầu ra tạm %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr "Người dùng và nhóm sở hữu của tập tin %s không được giữ nguyên."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr "Gặp lỗi khi đổi chủ sở hữu và nhóm của tập tin đầu ra tạm %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "erro ao converter o nome '\\u0027%s\\' para \\u0027%s\\':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "o propósito do vinculo simbólico '%s' é desconhecido."

msgid "          output file remains in '%s'\n"
msgstr "teto de saída permanece no arquivo '%s'"

msgid "Skipping binary file %s\n"
msgstr "Bora descartar o arquivo de dados separados por linha %s\n"

msgid "code page %d is not supported.\n"
msgstr "não há suporte para o navegador %d. \n"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Borrando o conjunto de dados UTF-16 %s, a largura do wchar_t não é "
"necessariamente %d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Após a exclusão do arquivo UTF-16 %s, ocorreu um erro de conversão para "
"UTF-16 na linha %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para UTF-16 não é suportado nesta "
"versão do programa. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, pois não é um arquivo regular. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Borrando o arquivo %s, o fluxo de saída do banco de dados é uma conexão "
"fina. Aqui está mais informação sobre como fazer isso em um ambiente Linux "
"com CLI."

msgid "Skipping symbolic link %s.\n"
msgstr "Borrando a associação fraca %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Borrando a associação delicada %s, o objetivo dele não é um arquivo regular. \n"
"\tOBS.: Ao remover essa ligação fraca, pode haver consequências indesejadas em sistemas complexos."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Borrando a associação fraca, o objetivo %s da associação forte não pode ser "
"um arquivo regular. \n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s para o arquivo \"%s\" no formato "
"Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "Em processo de conversão do arquivo “%s” para a estrutura Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Em processo de conversão do arquivo `%s` para o formato Mac...\n"

msgid "converting file %s to Mac format...\n"
msgstr "Em processo de conversão do arquivo “%s” para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo “%s” para o formato DOS, criando um novo"
" arquivo “%s”.\n"

msgid "converting file %s to DOS format...\n"
msgstr "Em processo de conversão do arquivo “%s” para a versão DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Unix %s, "
"resultando no arquivo “%s”..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para a estrutura Unix %s…"

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato Macintosh, "
"criando um novo arquivo com nome especificado...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato Mac %s…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Em processo de conversão do arquivo %s “%s” para o formato DOS, criando um "
"novo arquivo com nome especificado...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para formato DOS %s…"

msgid "problems converting file %s to file %s\n"
msgstr "Ao converter o arquivo %s para o arquivo %s, foi encontrado um erro."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao converter o arquivo %s"

msgid "can not read from input file %s:"
msgstr "não foi possível obter estado (stat) do arquivo %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "custo de '\\%c' para a opção '-i' ou '--info' está incorreto."

msgid "active code page: %d\n"
msgstr "tela ativa: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr "opção inválida -- '%c'"

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” requer um argumento\n"

msgid "invalid %s display encoding specified\n"
msgstr "a saída apresentada %s não é aceitável para exibição gráfica."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo do arquivo %s não foi especificado no modo de criação novo do "
"arquivo"

msgid "can not read from input file: %s\n"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr "Erro: Cáp de substituição inadequado. Substitua abaixo."

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr "Erro: Cadeia de substituição inválida. Falha na troca anterior."

msgid "has %s BOM.\n"
msgstr "tem um BOM %s. \n"

msgid "WINVER 0x%X\n"
msgstr "WINVER 0x%X\n"

msgid ""
"Skipping UTF-16 file %s, the current locale character encoding is not "
"UTF-8.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, a codificação atual da região linguística não é "
"UTF-8. A tabela de símbolos locais não reflete essa mudança."
