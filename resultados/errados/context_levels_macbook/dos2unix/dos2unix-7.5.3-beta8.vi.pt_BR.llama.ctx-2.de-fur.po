msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso: %s [opções] [arquivos ...] [-n entrada_arq.txt saída_arq.txt]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "opção --allow-chown permite a alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converte entre o código de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               utilizado Windows Codepage 1252 (Tây Dân Bản) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usado com a codificação DOS 437 (US) (padrão "
"definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usado para o DOS 850 (Tây Átôn) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizado para DOS Codepage 860 (Português)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizado para DOS Codepage 863 (Codificação de "
"caracteres do Canadês francês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                usado DOS Codepage 865 (Nordic)    \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de 8 bits para o espaço dos 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        mantém a marcação de byte order mark (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        mantém o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         modo de converção para ascii, 7bit, iso, mac\n"
"   padrão é ASCII."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a codificação de exibição para mensagens visuais utilizando as seguintinhas opções:\n"
"   básica (ansi), unicode ou utf8. A escolha padrão é ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se necessário\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório converter arquivos binários em formato de"
" texto\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            mostra a ajuda deste comando"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exiba informações do arquivo\n"
"   ficheiro …            dos ficheiros a serem analisados."

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantém a data original da entrada\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar “Marca de Ordem do Byte” (byte order mark) "
"(definição padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          gera um novo arquivo de texto\n"
"   tápi-tin-vào      entrada original no modo do novo arquivo\n"
"   tápi-tin-ra         saída para o novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      não permite a alteração do proprietário (padrão)"
" do arquivo"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dónde ao final da última linha se "
"nenhum delimitador de linha (padrão) fornecido"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          insere no arquivo antigo (padrão) \n"
"   ficheiro …            os ficheiros que precisam ser convertidos para o modo de ficheiro-antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimindo todas as avisos\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apaga o Byte Order Mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apaga o Byte Order Mark (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte binárias (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantém a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assume o formato UTF-16LE como padrão\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        anunciar detalhes do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  segue links simbólicos e converte os destinos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(as originais permanecem inalteradas) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e suas referências "
"inalteradas (padrão definido)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra a versão do programa\n"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr ""
"FENDA DE PHÍSiN BAZÃO DOS SISTEMAS DOSSIÉ (WATCOMC) - Versão de 16 bits."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "FENDA DE PHÍNCEANDO DOS (TURBOC) VERSÃO DO SISTEMA OPERATÓRIA."

