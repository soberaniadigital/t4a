msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [flags] [arquivos ...] [-n infile outfile …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         Permitir alterações no proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversor de caracteres (ASCII)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    convertere entre DOS e codificação ISO-8859-1 para "
"texto"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar Windows Code Page 1252 (padrão europeu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "-437                utilizar DOS Code Page 437 (USA) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar página DOS de codificação 850 (europeia) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar a tabela de sinalização DOS 860 (português) "
"を使用する"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar DOS Tabellen 863 (français canadien) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar a tabela de códigos DOS 865 (nordeste) © "
"usada no Brasil\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converterá os caracteres de 8 bits para o modo binário"
" de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservando marca de byte ordenação (Byte Order Mark)"
" \n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"--keep-bom        preservar byte order mark (byte order mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         converte modos\n"
"   modo de conversão    ASCII, Bits/7bit, ISO, MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir a codificação de texto exibida\n"
"   kodning             ansi, unicode, utf8, padrão é ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr "adicionar uma linha de erro ao final sem nenhum conteúdo\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "--force           converter de binário para texto forçado"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            visualize este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa exibir informações do arquivo para análise\n"
"   file ...               analisar o arquivo fil"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preservar a data de criação do arquivo"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa mostrar o licenciamento do software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar byte ordning markering (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever em um novo arquivo\n"
"   infil               original_arquivo no novo formato de entrada\n"
"   utfil              saída para o novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
" --no-allow-chown      não permite a alteração do proprietário de arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha na última linha se "
"ela já existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout -O, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   file ...             para ler e converter o formato do arquivo existente."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimindo todas as avisas"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "--remove-bom      Remove Byte Order Mark (BOM) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "--remove-bom      Remove Byte Order Mark (byte order mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            saltos sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep_utf16     preservar UTF-16 codificação de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le para supor que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
"--verbose        -v, --verbose         realizar fluxo excessivo de saída"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   seguir símbolicamente links e converter o caminho."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"--replace-symlink, substitui símbolos de ligação com arquivos convertidos\n"
"(Os arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preservando símbolos de links e objetivos não "
"modificados (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versão número"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Versão DOS 16 bits (WATCOMC)."

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Versão DOS 16 bits (TURBOC)."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Versão de 32 bits (WATCOMC)."

msgid "DOS 32 bit version (DJGPP).\n"
msgstr "Versão DOS 32 bits (DJGPP)."

msgid "MSYS version.\n"
msgstr "Versão do MSYS."

msgid "Cygwin version.\n"
msgstr "Versão do Cygwin."

msgid "Windows 64 bit version (MinGW-w64).\n"
msgstr "Versão Windows para 64 bits (MinGW-w64)."

msgid "Windows 32 bit version (Watcom C).\n"
msgstr "Versão de 32 bits do Windows (WATCOMC)."

msgid "Windows 32 bit version (MinGW-w64).\n"
msgstr "Versão de 32 bits do Windows (MinGW-w64)."

msgid "Windows 32 bit version (MinGW).\n"
msgstr "Versão de 32 bits do Windows (MinGW)."

msgid "Windows 64 bit version (MSVC %d).\n"
msgstr "Versão Windows de 64 bits (MSVC %d)."

msgid "Windows 32 bit version (MSVC %d).\n"
msgstr "Versão de 32 bits do Windows (MSVC %d)."

msgid "OS/2 version (Watcom C).\n"
msgstr "Versão do OS/2 (WATCOMC)."

msgid "OS/2 version (EMX).\n"
msgstr "Versão do OS/2 (EMX)."

msgid "%s version.\n"
msgstr "%s versão."

msgid "With Unicode UTF-16 support.\n"
msgstr "Suporte ao Unicode UTF-16. \n"

msgid "Without Unicode UTF-16 support.\n"
msgstr "Sem suporte ao Unicode UTF-16."

msgid "With Unicode file name support.\n"
msgstr ""
"Suporte para nomes de arquivos Unicode. Para obter mais informações, tente "
"`%s --help'."

msgid "Without Unicode file name support.\n"
msgstr "Sem suporte para nomes de arquivos Unicode."

msgid "With native language support.\n"
msgstr "Suporte ao idioma nativo. \n"

msgid "With support to preserve the user and group ownership of files.\n"
msgstr "Suporte para preservar o proprietário e grupo de um arquivo. \n"

msgid "Without support to preserve the user and group ownership of files.\n"
msgstr "Sem suporte para preservar o proprietário e grupo de um arquivo."

msgid "Path for temporary output file is too long:"
msgstr "Caminho para o arquivo de saída temporário é muito longo:"

msgid "Writing %s BOM.\n"
msgstr "%s BOM."

msgid "UTF-16LE"
msgstr "UTF-16LE"

msgid "UTF-16BE"
msgstr "UTF-16BE"

msgid "GB18030"
msgstr "GB18030"

msgid "UTF-8"
msgstr "UTF-8"

msgid "Input file %s has %s BOM.\n"
msgstr "No arquivo de entrada %s há um BOM (Byte Order Mark)."

msgid "Assuming UTF-16LE encoding.\n"
msgstr ""
"Foi utilizada a codificação UTF-16LE para o texto. Aqui estão as informações"
" sobre essa escolha de codificação."

msgid "Assuming UTF-16BE encoding.\n"
msgstr "Foi observado que o UTF-16BE codificação é utilizada."

msgid "problems resolving symbolic link '%s'\n"
msgstr "Ocorreu um problema durante a resolução do símbolico link '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr ""
"falha na abertura do arquivo temporário de saída (temporary output file): %s"

msgid "using %s as temporary file\n"
msgstr "anunciar '%s' como arquivo temporário\n"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "falha na alteração de permissões para o arquivo temporário %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"Ocupação de usuário ou grupo, incluindo o do proprietário, não é preservada "
"para arquivo %s."

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"falha na alteração do proprietário e grupo para o arquivo temporário %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "falha na alteração do nome para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "qual é o alvo desse símbolo de ligação simbólica '%s'?"

msgid "          output file remains in '%s'\n"
msgstr "o arquivo de saída permanece no local '%s'."

msgid "Skipping binary file %s\n"
msgstr ""
"Falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "code page %d is not supported.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Hoje em dia, o arquivo UTF-16 '%s' está sendo ignorado. O tamanho do wchar_t"
" é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Hoje em dia, estamos ignorando o arquivo UTF-16 %s devido a um erro de "
"conversão para UTF-16 na linha %u. Para obter mais informações, tente '`%s "
"--help`'."

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hoje em dia, estamos ignorando o arquivo UTF-16 %s. A conversão para UTF-16 "
"não é suportada nesta versão do programa."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Hoje em dia, %s não é um arquivo típico. Normalmente, ele não possui campos."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Hoje em dia, %s está a trabalhar no projeto. O arquivo de saída '%s' é um "
"simbolico link."

msgid "Skipping symbolic link %s.\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Hoje em dia, estamos ignorando o símbolico link %s porque não é um arquivo "
"normal. Para obter mais informações, tente `%s --help'."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Hoje em dia, %s está por aí. O destino para o símbolico link %s não é um "
"arquivo normal."

msgid "converting file %s to file %s in Unix format...\n"
msgstr "Convertemos o arquivo %s para o formato Unix..."

msgid "converting file %s to Unix format...\n"
msgstr "Conversor de arquivo %s para o formato Unix…"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "Converting file %s to Mac format…"

msgid "converting file %s to Mac format...\n"
msgstr "Conversor de arquivo %s para o formato Mac…"

msgid "converting file %s to file %s in DOS format...\n"
msgstr ""
"Convertemos o arquivo %s para o formato DOS a partir do caminho especificado"
" em '%s'."

msgid "converting file %s to DOS format...\n"
msgstr "Conversor de arquivo %s para o formato DOS…"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr "Converting file %s to a Unix format..."

msgid "converting %s file %s to %s Unix format...\n"
msgstr "Converte o arquivo %s para o formato Unix..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr "Converting '%s-file %s' to 'Mac OS X format'...\n"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "Converte o arquivo %s para o formato Mac."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"Converte o arquivo %s para o formato DOS a partir do arquivo de entrada "
"%s...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Converte o arquivo %s para o formato DOS em português."

msgid "problems converting file %s to file %s\n"
msgstr ""
"falha na conversão do arquivo %s para o arquivo %s durante a operação de "
"conversão. Por favor, verifique se os campos são corretos e tente novamente."

msgid "problems converting file %s\n"
msgstr "Falha na conversão do arquivo %s\n"

msgid "can not read from input file %s:"
msgstr "não foi possível ler o arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "opção inválida -- '%c'"

msgid "active code page: %d\n"
msgstr "codificação eficaz para tabuleiro de jogo: %d"

msgid "invalid %s conversion mode specified\n"
msgstr "falha na conversão de %s para o modo '%c' (opção inválida)"

msgid "option '%s' requires an argument\n"
msgstr "O 'flaggan' opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "A codificação de %s-kodning especificada é inválida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"O objetivo do arquivo %s não foi especificado em um novo modo de acesso ao "
"sistema de ficheiros."

msgid "can not read from input file: %s\n"
msgstr "não foi possível ler o arquivo de entrada %s\n"

msgid "can not write to output file: %s\n"
msgstr "não foi possível escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"
