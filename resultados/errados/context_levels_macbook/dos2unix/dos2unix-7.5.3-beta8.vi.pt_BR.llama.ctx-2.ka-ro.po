"'Getting Started' no manual do programa."

msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de utilização: %s [opções] [-n tabela_entrada entrar...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"permite o acesso ao proprietário do arquivo para modificação de permissões."

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modul de conversão implícita"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Use o código Windows 1252 (Tây Âu) para codificar a linha de entrada."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Utilize a página de código DOS -437 (US) como referência padroa por "
"implicação"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Utilize a página de código DOS 850 (Tây Âu) para o seu trabalho."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o utilitário DOS 860 (Portugal) para acessar e manipular arquivos de"
" texto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize a pasta de código DOS 865 (Bacia do Norte) para o seu projeto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preserva o sinal de Byte Order Mark (BOM) dos "
"octetos."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preserva o sinal de Byte Order Mark (BOM) padrão."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão:   ASCII, 7bit, ISO, MAC, moldura"
" padrão é ASCII (implicitmente “ascii”)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir các bái thông báo\n"
"   bảng mã: ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma linha de terminação à última linha, se não houver nenhuma "
"presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "forçar, --force           para forçar conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỌ]        hiển thị tập tin ... các tập tin cần phân tích\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"opção --keepdate        preserva a data de criação do arquivo original (no "
"formato ISO8601)"

msgid " -L, --license         display software license\n"
msgstr "opção -L, --license         afiça a licença do software."

msgid " -l, --newline         add additional newline\n"
msgstr "Use --newline para adicionar uma linha nova."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"adicionar marcação de ordem dos bytes (BOM) UTF-8 implicitamente definida."

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "opção não permite alterar o proprietário do arquivo (implicit)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha no final se não "
"houver um caractere de nova linha (padrão) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion --to-stdout       escreve o resultado para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          ghi vào tập tin cũ (mặt chữa mạnh) fi<NAME>."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
"opção silenciosa, --quiet           modul de redução do somorro. Ou seja, "
"não exibe nenhuma mensagem ao usuário."

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção --remove-bom      eliminar o “Byte Order Mark” (marca de ordem dos "
"bytes) implicitamente"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção --remove-bom      eliminar o “Byte Order Mark” (BOM) da linha de "
"entrada."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            omita fișieres binários (implicit)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr ""
" -u, --keep-utf16     preserva o código UTF-16 dos caracteres de "
"entrada/saída padrão."

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        thông báo detalhado sobre operações realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  სიმბურジობლების მიყოლა და სამიზნეების გადაყვანა"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bặn tập tin chuyển đổi (các tập"
" tin đích nguyên gốc thì để nguyên không thay đổi) "

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    preserva as ligações simbólicas e links de diretório"
" (implicit)"

msgid " -V, --version         display version number\n"
msgstr "opção --version         afiça o número da versão"

