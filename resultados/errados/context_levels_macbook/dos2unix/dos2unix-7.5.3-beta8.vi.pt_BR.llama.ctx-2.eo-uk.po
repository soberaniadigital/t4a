msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cómo usar: %s [opções] [arquivos …] [-n arquivo_de_entrada "
"resultado_de_saida …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown permissão para alterar proprietário do arquivo de texto"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento padrão de caracteres"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converter de caracteres entre DOS e ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a tabela de caracteres Windows 1252 (Tây Âu)"
" \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tabela de caracteres DOS 437 (EUA) "
"(padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "-850                utilizar a tela de DOS 850 (Tây Ái)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizar a tela do DOS 860 (português) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "-863                utilizar a tela DOS 863 (canaãsita francesa)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"-865                utilizar a tela do sistema DOS 865 (línguas nórdicas)   "
"-865                utilizar a janela de aplicação DOS 865 (idiomas "
"escandinavos)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"--keep-bom        preservar o Byte Order Mark (BOM) originalmente inserido "
"no início do arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        reteni nguyên “Marca de Ordem dos Bits” (defaul)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo de conversão:    ascii, 7bit, iso, mac, padrão é ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      adicionar código de exibição para apresentação dos avisos\n"
"   códigos de exibição:\n"
"     ansi (defaul), unicode ou utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"Adicionar uma quebra de linha no final da linha se ela não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos de tabela dupla "
"separada por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb16308         converte UTF-16 para GB16308\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            apresentar esta ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=COR]        exibir informações sobre o arquivo\n"
"   ficheiro ...            ficheiros que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        guardando a data de criação do arquivo gerado"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibir a licença do software em formato de papel"

msgid " -l, --newline         add additional newline\n"
msgstr "bổ xung thêm dòng mới"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          tập tin vào          tập tin gốc trong chế độ tập tin mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (método "
"padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem adição de nova linha         não acrescentar quebra de linha no final "
"do texto se ela não existir (tipicamente)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       ghi vào đầu ra tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định) \n"
"   tập-tin …            các tập tin cần chuyển đổi trong chế độ tập-tin-cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "modo silencioso, sem mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      excluir o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "--safe            exclusão de arquivos por padrão (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     mantenha a tabela de caracteres UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coi régulo de que o formato do dado de entrada seja "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na hipótese de que o formato do dado de "
"entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        modo de mensagens detalhadas\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   sekvi liên kết mềm và chuyển đổi đích"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink trocar links simbólicos por arquivos convertidos\n"
"                   (arquivos originais não serão alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não alterar links simbólicos e objetivos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         apresentar versão do programa"

