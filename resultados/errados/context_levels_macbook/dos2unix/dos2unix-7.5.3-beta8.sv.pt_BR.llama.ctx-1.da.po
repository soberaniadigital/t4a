msgstr ""
"Hoje, o UTF-16-fil %s foi passado. O tamanho do wchar_t é de %d bytes."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
