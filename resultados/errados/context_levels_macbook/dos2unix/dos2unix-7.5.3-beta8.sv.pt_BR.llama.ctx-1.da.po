msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [flagg] [fil ...] [-n infile utfil ...]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         tilatar o ajuste do esquema de propriedade para "
"arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversor (de ASCII para não) \n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e ISO-8859-1 codificações de caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar o código de caracteres Windows 1252 "
"(vizigano) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar o código de conversão DOS para a tabela do "
"sistema operacional Windows (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilize o DOS Tabellen 850 (Vesteuropa)    \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilize a tabela DOS de códigos de teclado 860 "
"(português)    \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize a tabela de conversão DOS para o código "
"Unix/Linux (franco-canadense) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize a tabela DOS para o sistema operacional do "
"Windows 865 (nordisk) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits para o espaço em "
"branco de 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        behold byte-rækkefølge-markering (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b --keep_bom        preserva byte order mark (byte order) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverterias estilos de conversão\n"
"   estilo convergência     ASCII, BIT7, ISO, MAC, padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     defina a codificação para textos visuais\n"
"   codificação             ansi, unicode, utf8, padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"--adicionar_EOL         adicione uma quebra de linha na última linha se "
"nenhum for encontrado."

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           tvinga a conversão de arquivos binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converterá UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            ver virar este texto de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa informação do arquivo para análise\n"
"   fil ...               filer at analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva o dado para arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr ""
" -L --license         visa o programa para usar a licença do software."

msgid " -l, --newline         add additional newline\n"
msgstr "-l --newline         adicionar linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione byte ordre markering (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skriv til ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil               utmatningsfil i nyfilsläge\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      até não permitir alterações no acesso ao arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha na última linha se "
"nenhuma (padrão) existir."

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever para o arquivo antigo (padrão) \n"
"   file ...               filas que serão convertidas em um estado de ficheiro antigo."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           tílbilação, desabilitar todas as mensagens"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar marcação de byte ordenação (Byte Order Mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --remove-bom      apagar byte ordnungsmarkering (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s --safe            salto sobre binários de arquivos (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     behold UTF-16 teckenskodning\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le fica com base na suposição de que o formato de "
"entrada é UTF-16LE."

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be fica de acordo que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        utmolda de execução"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  seguir sinais simbólicos e converter o destino"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetas símbolos de ligação com arquivos convertidos \n"
"                         (originais objetivos permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preservar símbolos de ligação e destinos não "
"modificados (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V --versão         visa versões número"

