msgstr ""
"Hoppar över UTF-16-fil %s, UTF-16-konvertering saknar stöd i denna version av %s. \n"
"\tOBS.: Acontecimento registrado em log."

msgid "Skipping %s, not a regular file.\n"
msgstr "Hoppar sobre %s, não é um arquivo comum."

