msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilize o comando '%s' [opções] [-n entrada tabela de dados ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                converter padrão de caracteres"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre os conjuntos de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Utilize o Windows-1252 para codificação (Tây Dong) do texto."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS-850 para codificação do Tâmil (Tâmil) em %s, com base nas "
"informações fornecidas."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Utilize o DOS 860 (Bồ Đào Nha) para codificar em Blocos de Texto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS-863 para codificação de texto (Canadees Francês)   -863"
"                utilizar trânscrição mãe DOS 863 (Ca Na Da Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS 865 (Baixo/Médio fuso horário) para codificar arquivos."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantenha o “Marca de Ordem dos Bits” (BOM) no "
"arquivo."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        guarde o “Marca de Ordem dos Bits” (byte order mark) "
"padrão"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de modo de converção:   "
"ascii, 7bit, iso, mac, padrão é 'ascii'."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para exibir mensagens de erro\n"
"    Codificação da tela:\n"
"        ansi,\n"
"unico,\tutf8 (padrão é 'ansi')"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"coluna se ele não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia solar - A bateria é um componente essencial para o "
"funcionamento dos dispositivos solares, pois ela armazena a eletricidade "
"produzida pela célula fotovoltaica. Ela pode ser instalada em vários "
"formatos e tamanhos, como pára-sol com painéis ou baterias secundárias para "
"aplicações de energia solar residencial."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         轉換 UTF-16 至 GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            hiêrên thị trợ giúp này"

