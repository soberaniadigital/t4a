msgstr " -O, --to-stdout       escrever no fluxo de saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          herde ou o arquivo antigo (padrão) \n"
"    Arquivo ...             O arquivo que precisa ser convertido para formato de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, ocultar todas as avisões"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção -r, --remove-bom      apagar o “Byte Order Mark” (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover o “Byte Order Mark” (BOM) do arquivo."

