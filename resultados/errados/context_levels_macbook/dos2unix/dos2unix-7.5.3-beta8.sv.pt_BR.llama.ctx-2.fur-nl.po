msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "opção --remove-bom      remover byte order mark (Byte Order Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salte i file binaris (standaard)"

