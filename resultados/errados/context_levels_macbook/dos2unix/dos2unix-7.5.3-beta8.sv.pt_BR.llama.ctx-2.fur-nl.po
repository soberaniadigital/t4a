msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando `grep` para encontrar e exibir as linhas que contêm a "
"palavra 'error' em um arquivo de log. Se você não tiver certeza do nome da "
"pasta, use `--help`. Para obter mais informações sobre como usar este "
"script, digite: `%s --help`."

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a modificação do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "opção não permitida --%c"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre as codificações de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Codepage 1252 (padrão europeu ocidental) para acessar os dados"
" do arquivo."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código tabular DOS -437 (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o Sistema de Codificação DOS (DOS) Tabellen 850 (padrão europeu "
"ocidental)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tabellen 860 (português) para acessar as opções de formatação do "
"sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS Tabellen 863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-codetabel 865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converterá os caracteres de 8 bits em espaços para o formato de 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        mantenha o segn de ordem do byte (Byte Order Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        mantenha o byte order mark (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr " -c, --convmode        conversão de modo"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     utilizar codificação para mostrar mensagens de teste"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar uma linha em branco à última linha do "
"arquivo\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Opção -f, --force           conversão de ficheiros binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr ""
"esse comando não é reconhecido. Por favor, use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGGOR]   mostra informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        mantenha a data do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license mostra a licença do software."

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma nova linha\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         adicionar marca de byte (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe til ny fil\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil              utmatningsfil i nyfilsläge"

