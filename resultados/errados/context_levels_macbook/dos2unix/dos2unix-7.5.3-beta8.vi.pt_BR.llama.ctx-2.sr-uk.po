msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách de uso: %s [seleções] [arquivos …] [-n arquivo_de_entrada "
"resultado_de_saída …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite alteração da propriedade do arquivo tápia\n"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                режим ASCII по умороженню"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                  converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar trângulo de codificação Windows 1252 (Tây "
"Ái)    \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar trama de caracteres DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar trângulo de código DOS 850 (tây và có cũng "
"thích tôi)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar a página DOS 860 (português do Brasil)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "   -863                utilizar a página DOS 863 (Canadá Francês) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utilizar trama de vídeo DOS 865 (Inglês) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converte os caracteres de 8 bits para 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpate na manutenção do “Byte Order Mark” (BOM) como está, para preservação"
" da ordem dos bytes."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"giúpado com o sinal de byte order mark (mandatório) ou mantido sem "
"alterações no formato original."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de convergência chave de "
"conversão.   modo de converter ascii, 7bit, iso, mac, padrão é ascii."

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir codificação de texto para exibição dos avisos\n"
"   codificações:\n"
"ansi, unicode, utf8, por padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr " -e, --add-eol   adicionar ponto final ao fim do texto se não houver\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos de dados binários"
" em parquet/orc\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         діротити UTF-16 на GB18030"

msgid " -h, --help            display this help text\n"
msgstr "hi o uso deste comando ajuda você?"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=VIS]        exibe informações sobre o arquivo de entrada ..."
"            arquivos que precisam ser analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        задржава датум излазне датотеке\n"

msgid " -L, --license         display software license\n"
msgstr "licença para uso - hipertexto interativo"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar novo caractere de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem do Byte” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a mudança do proprietário de arquivo "
"(padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar quebra de linha no final do texto se ela"
" ainda não estiver presente (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to_stdout       gerar saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          вave no arquivo antigo (padrão) \n"
"   arquivo ...            os arquivos que precisam ser convertidos para o modo do armazenamento de arquivos antigos"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, sem mensagens de aviso\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o 'Byte Order Mark' (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      excluir 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
" -s, --safe            exclusão de arquivos divididos em duas partes "
"(padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     забери таблицу кодирування UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le coisa que implica que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be coisa que diz que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v,  --verbose        modo de mensagens detalhadas\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  para links simbólicos e conversão de "
"diretório/arquivo"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca links simbólicos por arquivos transformados\n"
"(arquivos originais não serão modificados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr " -S, --skip-symlink    não altera likenesses e objetivos (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         hiereje s/n. versao do software"

