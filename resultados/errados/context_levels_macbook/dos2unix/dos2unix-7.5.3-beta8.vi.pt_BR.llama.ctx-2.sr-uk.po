msgstr ""
"Borra o arquivo UTF-16 %s, cujo tamanho da wchar_t não é necessariamente de "
"%d byte."

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Borraram o arquivo UTF-16 %s, que causou um erro ao converter dados UTF-16 "
"no registro %u. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Borra o arquivo UTF-16 %s, convertendo para outro formato que não é "
"suportado nesta edição do %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Borra este %s, aí não é um arquivo típico. \n"

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr ""
"Remova o arquivo %s, que é um link curto para o resultado do trabalho em "
"progresso no diretório de saída."

msgid "Skipping symbolic link %s.\n"
msgstr "Borra o link fino %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Remova o link curto %s, que não tem como objetivo comum de um arquivo "
"regular."

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Remova o vínculo fino %s, objetivo %s do vínculo fino móvel que não é um "
"arquivo padrão. \n"

