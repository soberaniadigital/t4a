msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Método de uso: %s [opções] [-n entrada/saída ...]}</|endoftext|> ### "
"Solution I'm sorry, but it seems there has been a misunderstanding. The task"
" you provided is asking for translations of specific strings within the "
"context given and not to create an entire document or script based on that "
"information alone. However, here are two similar instructions with increased"
" difficulty: 1) Translate this text into Portuguese while maintaining "
"technical accuracy but without using any direct translation tools; instead, "
"rely solesly on your internal knowledge base for translating the terms "
"related to programming and software development concepts within it. The "
"document should be formatted as a JSON object containing an array of objects"
" with each line representing one sentence or phrase from the original text "
"along with its Portuguese equivalent in quotation marks: 1) "

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversão ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter mellom tegnsettene DOS và ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação Windows-1252 (Vestfália) para acessar os "
"arquivos do sistema operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o codificador DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS-850 (Tây Árabe) para codificação de texto."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS860 (Bồ Đào Nha) para editar arquivos em formato de texto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS863 (Ca Na Da Pháp) para codificação de texto em formato do Brasil."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS 865 (Bacia) para codificação de caracteres."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"giúpia o Byte Order Mark (BOM) para manter a ordem original dos bytes."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        giữ nguyên “Byte Order Mark” (mặc định)\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de convergência: ascii, 7bit,"
" iso, mac (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr " -D, --display-enc     定義顯示方式: ansi, unicode, utf8 (預設是 ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"coluna se ele não existir."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia solar, também conhecida como painel fotovoltaico ou "
"célula solare é um componente essencial para a conversão eficiente do sinal "
"elétrico em eletricidade. Ela converte luz natural da superfície dos raios "
"UV-A (Ultraviolet A) na forma de energia solar, que pode ser utilizada "
"diretamente ou armazenada para uso posterior."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use --help para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibir informações sobre o arquivo ...         "
"desejar analisar os campos do arquivo %s"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"Keep date        -k, --keepdate         preservar a data original do arquivo"

msgid " -L, --license         display software license\n"
msgstr "licença -L, --license         vis programvarelisens"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline          adicionar uma linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Byte Order Mark” (marca de ordem) (por "
"padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo\n"
"   táp-tin-vào         táp tin gốc trong chế độ táp-tin mới\n"
"   táp-tin-ra           táp tin đầu ra trong chế độ táp-tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar dóis em linha final se nenhum "
"delimitador de linha (padrão) estiver presente\n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escrever no arquivo antigo (padrão) \n"
"    Arquivo ...         O arquivo que precisa ser convertido para o formato de origem\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           modo silencioso, ocultar todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o “Byte Order Mark” (padrão) (opção padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"Remover o Byte Order Mark (BOM) -r, --remove-bom      gỡ bora 'Byte Order "
"Mark'"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"opção segura -s, --safe             bổn qua táp tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rằng o formato de entrada é UTF-16LE"

