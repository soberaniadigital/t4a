msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópias de segurança do sistema operacional são criptografadas para proteger "
"os dados. Para restaurar uma cópia, você deve usar o comando 'cp' seguido "
"pelo nome da pasta e a localização desejada."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração do proprietário de arquivo"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento ASCII de linha padrão (modo default)"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a tabela de códigos do Windows 1252 (para as"
" línguas ocidentais europeias)\n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar a tabela de códigos DOS 432 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizar a linha de código DOS 850 (máquinas "
"virtuais) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                utilizar a linha de comando DOS 860 (português "
"brasileiro)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizar a linha de comando DOS 863 (canadense "
"francês)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilizar a linha de comando DOS 865 (máquinas "
"virtuais) \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converter de caracteres para base 7 (chuteio)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        zerar o “Byte Order Mark” (BOM) origem\n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preservar o Byte Order Mark (marca de ordem de bytes)"
" padrão."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão chaveado:   ASCII, 7bit, ISO, MAC,"
" padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã để hiển thị các thông báo\n"
"   bảng mã:            ansi, unicode, utf8, mặc định là ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final se não houver, como indicado pela "
"opção --add-eol."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bắt buôn chuyển đổi các tập tin nhị phân, utilizando o comando 'convert' do "
"GNU Parallel. Para iniciar a conversão de um arquivo binário para texto "
"usando este script em um ambiente Linux/Unix-like:"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         Converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            exibir a mensagem de ajuda para este comando."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=COR]        exibir informações do arquivo ...            "
"ficheiros que precisam de análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantendo a data original do arquivo\n"

msgid " -L, --license         display software license\n"
msgstr ""
" -L, --license         exibir licenças dos softwares ferramentas de "
"desenvolvimento\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar um novo caractere de quebra de linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar o sinal de byte ordem (ordem de bytes "
"padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          adicionar ao novo arquivo\n"
"   entrada_de_origem         ficheiro de origem no modo criação do novo arquivo\n"
"   saída                      ficheiro de destino no modo criação do novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração de proprietário do arquivo "
"(efeito padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem_adicionar_eol          não adiciona quebra de linha no final se o "
"campo (tipicamente) estiver vazio"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       вивести дані до стандартного виведення"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregar no arquivo antigo (padrão) \n"
"   ficheiro ...            os ficheiros que precisam ser convertidos para o formato anterior\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem mensagens de erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o byte order mark (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      apagar o “Byte Order Mark” (BOM) do arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            apagar linhas de um arquivo (padrão) \n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assuma que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be pressa que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        relatório detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  o seguir links simbólicos e converter objetivos\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substituir links simbólicos por arquivos reais "
"(arquivos originais não serão alterados)\n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera links simbólicos e caminhos (método "
"padrão) \n"

