msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opção] [-n input_file output_file]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         tillad ændring af ägarskap for fil"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                standardkonverteringsläge\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre o DOS e a codificação ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utilizar a tabela de codificação Windows 1252 "
"(vesteuropeiska)    "

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use a tabela de codificação DOS -437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use a tabela de codificação DOS 850 (vosteuropeisk) para o seu sistema "
"operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use a tabela DOS -860 (portuguesa)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use a linha de comando DOS -863 (canadense) para obter mais informações."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use a tabela de sinalização DOS -865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "preservar o byte order mark (BOM) na ordem de bytes"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        behold byte order mark (byte-rækkefølge-markering) "
"(standart)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão   ASCII, 7bit, ISO, MAC, padrão é "
"ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stável em kodning para textos visuais, ansi, unicode,"
" utf8, padrão é ansi\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar uma linha em branco após a última linha do "
"arquivo\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "opção --force           realizar conversão de binários em arquivos"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "visar denna hjälptext"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformation\n"
"   file ...               files para analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        behold outputfils dato para o arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa licença para o software"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar um caractere de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar marcação de byte ordre (Byte Order Mark) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile         escrever para um novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adicionar uma linha de quebra em último lugar se "
"ela não existir (tipo) \n"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever para o arquivo antigo (padrão) \n"
"   file ...              filtrar os campos do arquivo antigo\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           tyst läge, tilbagehold alle advarsler\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção para remover marca de byte ordenação (Byte Order Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover a marca de byte order mark (BOM) -r, --remove-bom      "
"fjern byteordningsmarkering (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            hoppa över binära filer (standard)\n"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16-kodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le para supor que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink seguir símbolos e converter para o formato desejado."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr "Erro ao ler o arquivo de entrada 'file.txt'."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    não altera símbolos de ligação e destinações "
"alteradas (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versões número"

