msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cópi para usar o programa %s [opções] [arquivos ...] [-n arquivo de entrada,"
" arquivo de saída …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"--allow-chown         permite a alteração do proprietário de um arquivo\n"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento de modo padrão para conversões em tempo "
"real"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                   converte o sinal de interlingua DOS para "
"ISO-8859-1\n"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "   -1252               verwendet Windows Codepage 1252 (Tây Âu) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                usa codificação DOS 437 (US) (padrão definido)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                usa tampok mã DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                usa tabela de caracteres DOS Codepage 860 "
"(Brasileiro)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "-863                usa tampa de trens DOS 863 (Ca Na Da Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "   -865                utiliza tela de comando DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de 8 bits para o espaço dos 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        reteni bajtordo-markon"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr "--keep-bom        mantém o Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de opção --convmode         modo de conversão do código fonte\n"
"   modo de conversão do código fonte:\n"
"ascii, 7bit, iso, mac (padrão é ascii)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação de texto para exibir mensagens\n"
"   codificações possíveis: ansi, unicode, utf8; padrão é 'ansi'\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha no final da última "
"linha se necessário complementar"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
" -f, --force           obrigatório para converter arquivos de múltiplas "
"partes binárias"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         đổi từ UTF-16 sang GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "montri esta ajuda para você"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỸ]        exibe informações da tabela de dados (tabela) dos arquivos a serem analisados\n"
"   ficheiro(s)...            filhos do ficheiro principal para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva o dia e mês da entrada original\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença da ferramenta digital"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona uma nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar “Marca de Ordem da Bits” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập tin vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập tin ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (arquivo) por "
"padrão"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dáfine de nova linha no final da última "
"linha, se nenhuma existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định)\n"
"tập-tin …            các tập tin cần chuyển đổi trong chế độ tập tin cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, oculta todas as avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      remove o 'Byte Order Mark' (padrão) \n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      remove o 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"-s, --safe            borra o conjunto de dados divididos em dois (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantém a codificação UTF-16 para o arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "-ul, --assume-utf16le com isso o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be com base na premissa de que o formato do dado de "
"entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose        relatório detalhado\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   sekvi liên kết mềm và chuyển đổi cái"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink troca as ligações simbólicas por arquivos convertidos"
" (os originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    preserva links macios e objetivos não alteráveis "
"(padrão)"

msgid " -V, --version         display version number\n"
msgstr "--versao         Mostre versão do programa\n"

