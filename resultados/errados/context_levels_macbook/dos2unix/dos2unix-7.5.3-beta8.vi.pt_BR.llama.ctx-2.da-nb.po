msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Utilize o comando 'grep' para encontrar e exibir as linhas que contêm a "
"palavra chave `error` em um arquivo de log. Se você não tiver certeza do "
"nome da pasta, use `--help`."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         tillad ændring af filejerskab"

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"chave -iso                   converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "Use o Windows-1252 (Tây Âu) para codificação de caracteres."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código padrão DOS 437 (US) para conversor de caracteres."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-850 (Tây Árabe) para acessar os dados do sistema operacional."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS860 (Bồ Đào Nha) para acessar e manipular arquivos em um sistema "
"operacional baseado no MS-DOS."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS863 (Ca Na Da) para acessar as informações sobre os campos do "
"arquivo."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Baía da Bolsa) para acessar as informações sobre os dados de "
"entrada e saída do sistema."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converter os caracteres de entrada para o plano de bits 7 (8-bit) a partir "
"do plano de bits 8."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        behold byte order mark (BOM) \n"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        behold byte order mark (mặc định)\n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de conversão ASCII, 7bit, "
"ISO e MAC (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      endereça a tabela de mensagens para exibição\n"
"   codificação: ansi, unicode, utf8 (ansi é o padrão)\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicione um dóis no final da linha se não houver "
"nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia para o processo, ou seja, a força necessária para quebrar"
" um sinal em uma linha."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        vis informações sobre o távolaço de entrada (input) "
"e saída (output)"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"Use o parâmetro `--keepdate` para manter a data original do arquivo de "
"entrada."

msgid " -L, --license         display software license\n"
msgstr " -L, --license         vis software license"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         thêm “Byte Order Mark” (mặc định UTF-8)\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo\n"
"   táp-tin-vào         táp tin gốc trong chế độ táp-tin mới\n"
"   táp-tin-ra           táp tin ra no chế độ táp-tin mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dóis em linha final se nenhum "
"delimitador de linha (padrão) for inserido."

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais -O, --to-stdout       escrever para saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"   ficheiro …            filho que precisa ser convertido para o formato de texto-básico\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silencioso/stillemodus, tilbagehold alle advarsler\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o byte order mark (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gỡ bỏ “Byte Order Mark”\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16-kodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le anta at inndata-formatet er UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink theo liên kết mềm và chuyển đổi chevauchée"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"Não há informações suficientes para traduzir este texto. Por favor, forneça "
"uma frase ou parágrafo completo em inglês que exija tradução."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha a conexão com os símbolos e o destino "
"desviado (padrão) \n"

