msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Användning: %s [flaggor] [fil …] [-n infil utfil …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr "opção padrão para conversor de caracteres (ASCII) \n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre as codificações DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (Vestfinnsk) para acessar os dados do sistema "
"operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Codepage 437 (US) como padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS-codetabel 850 (vesteuropeisk) para continuar."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS-codetabel 860 (portugues) para continuar."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS-codetabel 863 (fransk-kanadensisk)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS-kodesystem 865 (nordisk)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converterá os caracteres de bits para o padrão binário (7-bit)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preservar o Byte Order Mark (Byte Order Mark) [pt-"
"BR]"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        behold Byte Order Mark (Byte Order Mark) (standard)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr " -c, --convmode        conversor de modo"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr " -D, --display-enc     staja em código para mostrar textos"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicionar um newline à última linha se não houver "
"nada a ser printet\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Opção -f, --force           tvinga conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "visar denna hjälptext"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAGG]    vis informações sobre o arquivo ... fil"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        mantenha o timestamp do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         visa programvarelisens"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção '-m', --add-bom         adicionar marca de byte ordenação (Byte Order "
"Mark) (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever em um novo arquivo (fil) no modo de cópia\n"
"   infile               origem-arquivo original içando fil no modo copiar\n"
"   utdata-fil        saída-arquivo no modo de cópia"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o acesso ao arquivo (standard)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"Não adicione um newline à última linha se não houver nada a ser acrescentado"
" (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever para o arquivo antigo (padrão) \n"
"   ficheiro ...               ficheiros que serão convertidos em formato de texto-básico"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, sem avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover o Byte Order Mark (BOM) -r, --remove-bom      retirar "
"'Byte Order Mark' (byte order mark)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o Byte Order Mark (BOM) -r, --remove-bom      retirar "
"byte ordre de bytes (Byte Order Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            salto sobre binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 teckenskodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le para assumir que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be para assumir que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "--verbose, -v        utente detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção --follow-symlink seguir links simbólicos e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos com arquivos convertidos "
"(originais deverão permanecer inalterados) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    mantenha as ligações simbólicas e alterações de "
"linha (padrão)"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         visa versões número"

