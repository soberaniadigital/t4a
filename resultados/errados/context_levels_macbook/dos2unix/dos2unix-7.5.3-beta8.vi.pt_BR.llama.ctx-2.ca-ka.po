msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Código de utilização: %s [opções] [-n fitxer_de_saida ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "permite o canteiro de comandos para alteração do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modo de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação Windows 1252 (Tây Âu) para acessar os "
"arquivos do sistema operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa página de codificação DOS 437 (EUA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o sistema de codificação DOS 850 (Tây Árabe) para processar "
"documentos em papel."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Utilize o DOS860 (Bồ Đào Nha) para acessar e manipular arquivos em um "
"sistema operacional Windows."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Baía da Bósnia e Herzegovina) para acessar as informações "
"sobre os campos de entrada do arquivo."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr " -7                    converte os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        manté a marca d'ordem de bytes originais."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        mantém o byte order mark (método de ordem padrão) "
"(defecto)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chave de conversão:   ASCII, 7bit, ISO, MAC, padrão "
"por defeito é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir os avisos mostrados\n"
"   codificação: ansi, unicode, utf8, por padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha ao final se não houver nenhuma no momento "
"atual, caso contrário, ocorre um erro."

msgid " -f, --force           force conversion of binary files\n"
msgstr "força conversão de arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỌ]        mostra a informação do arquivo\n"
"   ficheiro ...          Ficheiros para analisar"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra a licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr "Use -l, --newline para adicionar uma linha nova."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicione a marca de ordem dos bytes (definição "
"padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"   tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"   tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona dóis a última linha se nenhum delimitador"
" de linha (máximo) estiver presente"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcion --to-stdout       imprime na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          ghi vào tập tin cũ (mặt định thức)   "

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "opção silenciosa, muda a saída para nenhum aviso"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      apaga o sinal de byte order mark (marca d'ordem)"
" (por defeito)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção --remove-bom      apaga o byte order mark (BOM) da linha de entrada."

msgid " -s, --safe            skip binary files (default)\n"
msgstr ""
"opção segura -s, --safe            omet els fitxers binaris (per defecte)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preservar a codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽ que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        análise detalhada"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink segueix els enllaços simbòlics i converteix les "
"connexions"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os links simbólicos por arquivos reais (não"
" permite que eles sejam modificados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    ignorar links simbólicos e objetos (por padrão) do "
"diretório de origem para o destino."

