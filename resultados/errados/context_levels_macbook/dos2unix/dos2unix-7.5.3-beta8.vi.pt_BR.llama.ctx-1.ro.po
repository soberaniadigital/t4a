msgstr "Em processo de conversão do arquivo %s “%s” para o formato Mac…"

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr "Em processo de conversão do arquivo %s “%s” para o formato DOS...\n"

msgid "converting %s file %s to %s DOS format...\n"
msgstr "Ao converter o arquivo %s “%s” para o formato DOS (%s)..."

msgid "problems converting file %s to file %s\n"
msgstr ""
"Ao converter o arquivo %s para o arquivo %s, certifique-se de que todos os "
"dados estejam corretamente alinhados e sem erros."

msgid "problems converting file %s\n"
msgstr "encontrado problema ao transferir dados do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não se pode citar do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr "O fanion '%c' para a opção '-i' ou '--info' está errado."

msgid "active code page: %d\n"
msgstr "página de código ativa: %d\n"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"o módulo de conversão especificado %s, no entanto, não é válido atualmente."

msgid "option '%s' requires an argument\n"
msgstr "tùy chọn “%s” yêu cầu một đối số\n"

