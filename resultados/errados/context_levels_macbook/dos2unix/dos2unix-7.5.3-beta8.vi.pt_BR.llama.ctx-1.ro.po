msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         permite a alteração do proprietário de tabela de "
"dados"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chaveamento de conversão mínima implicada"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr " -iso                   conversão entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilizează trâng pagina de cod Windows 1252 (Tây Âu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizează pagina de cod DOS 437 (US) (mặc định)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "   -850                utilizează pagina de cod DOS 850 (Tây Âu) \n"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizează pagina de cod DOS 860 (Bồ Đào Nha) \n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"-863                utilize a página de código DOS 863 (Canadá Francês)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                utilizează pagina de cod DOS 865 (Bacau)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "-7                    converte 8 bits em 7 bits."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "-b --keep-bom        mantém a marcajul de ordine a octeților (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --manterBOM        mantém o Byte Order Mark (marcajul de orden a "
"octeților) păstreată por implicidade."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         chévere modo de conversão\n"
"   chéere modo de conversão:\n"
"    ascii, 7bit, iso, mac (implicit este \"ascii\")\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens\n"
"   tabela de codificação:\n"
"       ansi (padrão), unicode ou utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione uma quebra de linha no final da última linha se "
"não houver nenhuma presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f, --force           obrigatório para converter arquivos binários de "
"tabelas separadas por linhas\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030         converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            Ajuda disponível nesta mensagem de ajúdos"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo de entrada\n"
"   táp-tin …            para análise dos dados contidos nos campos"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preserva o dia e mês do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         exibe a licença do software\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicione uma linha nova suplementar"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione ‘Marcação de Ordem’ (BOM) (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "--no-allow-chown      não permite alteração do proprietário (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adiciona um caractere de nova linha no final da "
"linha se não houver nenhum (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       ghi vào đầu ra tiêu chuẩn"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          ghi vào tập tin cũ (mặc định)\n"
"táp-tin ...            các tập tin cần chuyển đổi trong chế độ tập tin_cũ"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimindo todas as alertas\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"-r --eliminar-bom      elimina a marcação de ordem dos bytes (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr "-r --eliminar-bom      elimina a marcação de 'Byte Order Mark' (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --seguro            exclui linhas de dados (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     preserva a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le coi rã que o formato de entrada óbjeto é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be coi régando que o dânose de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        emit um aviso com detalhes sobre as operações "
"realizadas."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink   para o seguimento de ligações finas e a conversão do"
" objetivo\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui as ligações simbólicas pelas versões "
"convertidas (os arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações macios e a tabela de dados sem "
"alterações (padrão implícito)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         exibe número da versão do software"

