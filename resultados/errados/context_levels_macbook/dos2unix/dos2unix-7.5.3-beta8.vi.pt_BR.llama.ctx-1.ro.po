msgstr ""
"Borra o arquivo UTF-16 %s, conversão de UTF-16 não é suportada nesta versão "
"do programa para %s. \n"

msgid "Skipping %s, not a regular file.\n"
msgstr "Se omite %s, neste é um arquivo obrigatório. \n"

