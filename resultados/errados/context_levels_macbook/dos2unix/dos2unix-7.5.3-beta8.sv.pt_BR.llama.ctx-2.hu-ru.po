msgstr ""
" -ub, --assume-utf16be pressupostar que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utmárias"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção --follow-symlink  seguir símbolos de links e converter para caminho "
"absoluto."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetze symbolische Verknüpfungen mit konvertierten "
