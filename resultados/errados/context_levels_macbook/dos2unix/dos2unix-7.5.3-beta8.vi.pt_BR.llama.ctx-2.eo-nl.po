msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilize o comando 'cachorro' para iniciar a análise de um arquivo."

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr "converter somente em ASCII -ascii"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para o codificação ISO-8859-1 entre DOS e UTF-8"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows-1252 (codificação do ponto de vista ocidental) para codificar "
"a linha %s."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação DOS 437 (US) como padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS-850 (Tây Âu) para acessar os dados do arquivo."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS860 (Bồ Đào Nha) para acessar os dados de saída do sistema "
"operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS863 (Canadees Frans) para acessar os dados do sistema de arquivos."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS865 (Baía da Busselton) para acessar os dados do sistema "
"operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converter de letras para espaços em branco (ASCII)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        retenha o “marca de ordem dos bytes” (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        reteni bajtordo-markon (defaulto)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão --convmode         chéche modo de codificação: ascii, "
"7bit, iso ou mac (defautas al 'ascii')"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      utilizar codificação para apresentação dos boletos"
" de mensagem"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar um dólar de fim de linha ao final da última "
"linha se ele não estiver presente."

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia solar -f, --force           converte cadeias binárias "
"afastar\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        hiển thị tính toán informações do tập tin ... các "
"tập tin cần phân tích\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
"Keep date of creation (--keepdate)        keep the timestamp of output "
"file\n"

msgid " -L, --license         display software license\n"
msgstr "licença -L, --license         hiển thị giấy phép dùng mềm"

msgid " -l, --newline         add additional newline\n"
msgstr ""
" -l, --newline         adicionar uma linha em branco após cada entrada de "
"texto\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
"opção -m, --add-bom         adicionar o Byte Order Mark (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          skribi al novo arquivo\n"
"   tapeiro tin início em um novo documento dentro do modo de scripting.\n"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr "--no-add-eol          không thêm dâng gói trong cuốn sách (mặt chung)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       saída padrão escrever"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          adicione ao távola de trabalho (método padrão) \n"
"   ficheiro ...            converter os arquivos no estado atual para o formato do antigo sistema"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silencioso ou em silêncio, suprimindo avisos e "
"mensagens de erro"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção -r, --remove-bom      remover o básico 'Byte Order Mark' (defaul)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover o bumper de byte (byte order mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     retenha UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le coi rẽnge que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be coi rẽnte que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anunciar detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"Opção -F, --follow-symlink   para seguir símbolos e converter os dados."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay từ mềm bặt tinh sống (các dosieroj nguyên không "
"thay đổi) \n"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    ignorar símbolos de ligação (links simbólicas) não "
"alterados (padrão)"

