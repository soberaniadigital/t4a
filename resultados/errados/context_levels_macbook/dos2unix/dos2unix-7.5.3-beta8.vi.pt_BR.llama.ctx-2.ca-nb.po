msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de utilização para o programa 'cachorro' é acessível em "
"https://github.com/johndoe/cachorro-cli."

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite o alteração do arquivo de propriedade."

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII -ascii                padrão de conversão por defeito"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter de codificação entre DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize o código de codificação Windows-1252 (Vietnamita) para processar "
"arquivos no formato .csv."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize o código de codificação DOS 437 (US) padrão\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize o DOS850 (Tây Árabe) para acessar e editar arquivos em texto "
"simples."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Utilize o DOS860 (Bồ Đào Nha) para análise de textos em português."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize o DOS863 (Ca Na Da Phat) para acessar e manipular arquivos de texto."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use o DOS865 (Baía Sul) para acessar os dados do sistema operacional."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr "converter os caracteres de 8 bits para 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        preservar o “marca d'ordem de bytes” (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        mantenha o “marca d'ordem de bytes” (padrão) ou \n"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         modo de converção:   ASCII, 7bit, "
"ISO e MAC, padrão é o ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      endereça o código de caracteres para exibir os "
"avisos mostrados na tela. Codificação padrão é ansi."

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicione um caractere de nova linha ao final da última "
"linha se não houver nenhum\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"bateria de energia para o processo, ou seja, a força necessária para "
"converter arquivos binários."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter mais informações."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=CỌ]        mostra a informação do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        preservar a data original do arquivo de saída"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         mostra licença do programa"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adicionar uma linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione a marca d'ordem de bytes (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr " -n, --newfile          escreva no novo arquivo"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar a propriedade do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar dónde a linha final se ocorrer sem "
"delimitador de linha (padrão) se nenhum for encontrado."

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreva na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no ficheiro antigo (padrão) \n"
"   Ficheiro ...            Fichas a converter em formato de arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "Remover o Byte Order Mark (BOM) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"Remover o Byte Order Mark (BOM) -r, --remove-bom      gỗes untă de bytes"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     mantenha codificação UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le assume que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be assume que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anuncio detalhado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
"opção -F, --follow-symlink seguir links simbólicos e converter objetivos"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr "Não há informações suficientes para traduzir este texto em português."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha a relação simbólica e os objetos (por "
"padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra o número de versão"

