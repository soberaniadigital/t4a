msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilize: %s [opções] [arquivo ...] [-n infile outfile …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de conversor"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter entre as codificações de caracteres DOS e ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Code Page 1252 (padrão europeu) para acessar este documento."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o DOS Codepage 437 (USA) como padrão."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS-codetabel 850 (padrão europeu ocidental) para acessar esta página."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS-codetabel 860 (portugues) para acessar as configurações do sistema"
" operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS-codetabel 863 (canadense francês) para acessar as informações de "
"status do sistema operacional."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-codetabel 865 (norsk) para acessar as linhas de texto em um "
"arquivo."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converterá os caracteres de sete bits para o padrão BCD (Binary Coded "
"Decimal) usando a função `to_bcd`."

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preservar byte order mark (Byte Order Mark) [pt-BR]"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        preservar byte order mark (Byte Order Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        конверtersläge   аскри, 7бита, исо, мек, стандартär "
"är ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     utilizar codificação para mostrar mensagens de erro"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma quebra de linha no final da última linha"
" se não houver nada a ser printnão."

msgid " -f, --force           force conversion of binary files\n"
msgstr "Opção -f, --force           converte arquivos binários"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        convertem o UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Visar denna hjälptext"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR] visa filinformation\n"
"fil ...            para analisar arquivo(s)"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate        mantenha a data de criação do arquivo"

msgid " -L, --license         display software license\n"
msgstr "Opção -L, --license         visa o licenciamento do software."

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar linha extra\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr " -m, --add-bom         adicione Byte Order Mark (BOM) para UTF-8\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         skribe uten fil i nyfilsläge\n"
"   infil               originalfil i nyfilsläge\n"
"   utfil              utmatningsfil i nyfilsläge"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma quebra de linha no final da última "
"linha (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
"opção -o, --oldfile         escrever no modo antigo (padrão) \n"
"   arquivo ... converter o(s) arquivo(s) em formato de dados temporários\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimir avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção '-r' ou '--remove-bom', remover marca de byte ordenação (Byte Order "
"Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      apagar marca de byte order mark (Byte Order "
"Mark) do arquivo"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            saltar sobre arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     beholda UTF-16 codificação"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le a assumir que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be для de assumo que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utmãe razoável"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "opção -F, --follow-symlink  seguir links simbólicos e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetzt symbolische links med convertidas imagens com"
" arquivos de origem (os arquivos originais permanecerão inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    ignorar links simbólicos e caminhos de destino "
"alterados (padrão)"

