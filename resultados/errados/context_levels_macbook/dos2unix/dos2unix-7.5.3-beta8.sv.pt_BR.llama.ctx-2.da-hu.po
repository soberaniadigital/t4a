msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Användning: %s [flaggor] [fil …] [-n infil utfil …]\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         tillad ændring af ägarskap för fil"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                standardkonverteringsläge\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"converter para conversão entre DOS e ISO-8859-1 codificação de caracteres."

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               Windows Code Page (Windows-1252) usado para análise "
"de texto em português."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilizar DOS tabuada de caracteres (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Use o DOS Tecnologias de Sinalização (DTS) para acessar as informações do "
"sistema operacional. Para obter mais detalhes, consulte 'Getting Started "
"with the Windows System Information Toolkit'."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"Use o DOS Tecnologias de Informação e Comunicação (DOS) para acessar as "
"tabelas do sistema operacional. Para obter mais informações, consulte "
"'Getting Started with the Windows Command Line'."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Use o DOS Tecnológico de Estatísticas (DTE) para acessar as estatísticas do "
"sistema operacional. Ou seja, ele é um programa que permite ao usuário "
"visualizar e gerenciar os dados relacionados às suas contas bancárias."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "Use a tabela de sinalização DOS (DOS) -865 para o seu computador."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr "opção --keep-bom        behold byte order mark (BOM) sequenciamento"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom        behold byte order mark (byte order mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        konverteringsläge   ascii, 7bit, iso, mac, padrão "
"árabe"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     kodning para texto em formato de mensagem "
"(megjelenítés) a hozzá tartozó szöveget. Kódok ansi, unicode, utf8, standard"
" er ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr "opção --add-eol adicionar uma linha ao final do arquivo"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Opção -f, --force           tvinga konvertering af binære filer"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "visar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FLAG]   visa filinformation\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        behold outputfils dato"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa programvarulicensas"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar mais linhas ao final do arquivo"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicionar byte-rækkefølge-markering (Byte Order Mark)"
" (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever em um novo arquivo (inicial) i ficheiro original i nyfilsläge\n"
"i infil               origem-ficheiro i nyfil slås\n"
"o utfil              utlanslag i nyfil möjligen"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "Opcionais - OU, --to-stdout       escrever para a saída padrão."

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) \n"
"   file ...              filtrar para o estado do arquivo velho\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           tela de linha de comando, silenciar todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"opção para remover byte order mark (BOM) -r, --remove-bom      elimina a "
"marca de ordem dos bytes (Byte Order Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      apagar byte ordningsteksten (Byte Order Mark) do"
" arquivo."

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            saltar sobre binárias (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16-kodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le feltételezze para assumir que o formato de entrada é "
"UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be para supor que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utlolvasó munkasági"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink  seguir símbolos de ligação e converter para o idioma "
"padrão."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink ersetel symlink med konverterede filer (de urspr. "
"målfiler forbliver uændrede)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    behold symbolske henvisninger og deres mål "
"oförändrade (standard) \n"

