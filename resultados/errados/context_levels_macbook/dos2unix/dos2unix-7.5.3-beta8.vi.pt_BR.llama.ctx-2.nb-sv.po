msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Código de uso para o programa 'cachorro' é a seguir. Para obter mais "
"informações, consulte as seções `Documentação` e `Exemplo`.\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         tillåt ändring av ägarskap för fil"

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII -ascii                chave de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "converter para o codificação ISO-8859-1 entre DOS e UTF-8"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Use o Windows Codepage 1252 (Tây Âu) para acessar os dados do sistema "
"operacional."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"Use o código de codificação do DOS -437 para trabalhar com textos em "
"português (padrão) no Windows."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "Use o DOS850 (Tây Âu) para acessar seu diretório de trabalho."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Use o DOS860 (Bồ Đào Nha) para acessar seu sistema operacional."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o DOS863 (Ca Na Da Pháp) para acessar seu diretório de trabalho."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Use o DOS-kodeside 865 (nordisk) para acessar seu arquivo de configuração."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"Falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        behold Byte Order Mark (BOM) marking"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr " -b, --keep-bom        behold Byte Order Mark (método padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão -c, --convmode         chave de convergência: ASCII, "
"7bit, ISO e MAC (padrão é ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc      endereça a tela para mostrar mensagens de erro"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"opção -e, --add-eol   adicionar uma quebra de linha no final da última linha"
" se não houver nenhuma previamente presente\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "bateria de energia solar - Atenção! O arquivo %s não foi encontrado!"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converter UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "visar denna hjälptext"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        visar informações sobre o tập tin ... c/cá filenames"
" que serão analisados"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        behold utdata-filen dato"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         visa programvarulicensel"

msgid " -l, --newline         add additional newline\n"
msgstr " -l,--newline         adicionar uma linha extra"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione “Byte Order Mark” (marcação de byte order) "
"(padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escrever em um novo arquivo de entrada (tập tin gốc) no modo dobrado\n"
"   infil               original-filé origem\n"
"   utfil              saída filé resultante"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          không thêm dây ngắt trong số lượng của mình (mặc định)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreva no arquivo antigo (padrão) \n"
"   campos que precisam ser convertidos para o formato de tabela dinâmica\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "opção silenciosa, sem aviso de erro"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      apagar o byte order mark (marca de ordem do byte) "
"padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      gỡ bỏ “Byte Order Mark”\n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     behold UTF-16 teckenskodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        anuncio detalhes"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink theo liên kết mềm và chuyển đổi đích\n"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr "Não há informações suficientes para traduzir."

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    mantenha a conexão e o caminho de entrada (padrão) \n"

