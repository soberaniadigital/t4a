msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilize o comando `%s --help' para obter mais informações.\n"

msgid " --allow-chown         allow file ownership change\n"
msgstr ""
" --allow-chown         autorização para alteração de propriedade do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr "modo ASCII --------------------------------\n"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
"converter para a conversão entre as codificações de caracteres DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"utilize o código de codificação do Windows (1252) para a Europa Ocidental "
"-1252 utilizar"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Use o código de codificação do DOS -437 (USA) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "utilize o código de codificação do DOS -850 (padrão europeu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"utilize o código de página do DOS -860 (português) utilizar o code page 860 "
"(português)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "Use o código de página DOS -863 (francês canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "utilize o código de página do DOS (865) Nordique\n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"converterá os caracteres de oito bits para espaços em branco no sete bit"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom         mantenha o Byte Order Mark (BOM) na marca de bytes"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção --keep-bom         behålla Byte Order Mark (Byte Order Mark) (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modo de conversão   ascii, 7bit, iso ou mac (padrão é"
" 'ascii')"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     escolha o codificação para exibir mensagens de texto "
"(ansi, unicode ou utf8 [default])"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione um retorno de linha à última linha se não "
"houver nenhuma\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "Forçar                          | Forçar"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "converterá UTF-16 para GB18030"

msgid " -h, --help            display this help text\n"
msgstr "Visar este texto de ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr " -i, --info[=FANIONS]   mostra as informações do arquivo"

msgid " -k, --keepdate        keep output file date\n"
msgstr "opção --keepdate         tijdsstempel van uitvoerbestand behouden"

msgid " -L, --license         display software license\n"
msgstr "visa programar o software com licença"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline          adicionar linhas extras"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione o byte order mark (BOM) para UTF-8 padrão"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escrever em um novo arquivo\n"
"   infil               original_arquivo no modo de entrada\n"
"   utfil              saída do programa"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr "não é permitido alterar o proprietário do arquivo (padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"não adicionar uma quebra de linha na última linha se não houver nenhuma "
"(padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escrever para a saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escrever no arquivo antigo (padrão) BESTAND..."
"           converter os ficheiros para o modo de backup-backup"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprimir todos os avisos"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"--remove-bom      remover a marca de ordem dos bytes (Byte Order Mark) "
"(padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção -r, --remove-bom      remover marca de ordem dos bytes (Byte Order "
"Mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe             overeer binär bestanden (standaard)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     beholda UTF-16 teckenkodning"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le suppose que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be suppose que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v, --verbose        utente verboisado"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink   seguir links simbólicos e converter"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
"R -s, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"opção --skip-symlink    conserve os links simbólicos e as cargas inalteradas"
" (padrão)"

