msgid "problems resolving symbolic link '%s'\n"
msgstr "Problema ocorreu na resolução do link simbólico '%s'."

msgid "Failed to open temporary output file: %s\n"
msgstr "falha na abertura do arquivo de entrada temporário: %s"

msgid "using %s as temporary file\n"
msgstr "använder %s som temporârio ficheiro"

msgid "Failed to change the permissions of temporary output file %s:"
msgstr "A eșuat schimbarea permisiunilor fișierului de ieșire temporar %s:"

msgid "The user and/or group ownership of file %s is not preserved.\n"
msgstr ""
"Utilizador- e/ou grupo de proprietários para o arquivo %s não está sendo "
"preservado. \n"

msgid "Failed to change the owner and group of temporary output file %s:"
msgstr ""
"A eșuat schimbarea utilizatorului și grup proprietar al fișierului de ieșire"
" temporar %s:"

msgid "problems renaming '%s' to '%s':"
msgstr "fel quando '%s' trocou de nome para '%s':"

msgid "          which is the target of symbolic link '%s'\n"
msgstr "          vilken är målet för den symboliska länken ”%s”\n"

msgid "          output file remains in '%s'\n"
msgstr "fiŧierul de ieșire rămâne în \"%s\"."

msgid "Skipping binary file %s\n"
msgstr "Pular sobre o arquivo binário %s\n"

msgid "code page %d is not supported.\n"
msgstr "falha na verificação da opção --'%c'.\n"

msgid "Skipping UTF-16 file %s, the size of wchar_t is %d bytes.\n"
msgstr ""
"Passear sobre o arquivo UTF-16 %s, tamanho do tipo wchar_t é de %d bytes. \n"

msgid ""
"Skipping UTF-16 file %s, an UTF-16 conversion error occurred on line %u.\n"
msgstr ""
"Passear sobre o arquivo UTF-16 %s, um erro de conversão para UTF-8 na linha "
"%u intrópico. \n"

msgid ""
"Skipping UTF-16 file %s, UTF-16 conversion is not supported in this version "
"of %s.\n"
msgstr ""
"Hopar sobre o arquivo UTF-16 %s, a conversão para UTF-16 não é suportada "
"nesta versão do programa. A opção '%c' está inválida porque ela não permite "
"argumentos."

msgid "Skipping %s, not a regular file.\n"
msgstr ""
"Pular sobre '%s', é um arquivo raro. Se omite %s, nu este un fișier "
"obișnuit."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Pular sobre '%s', o link simbólico do diretório de saída é `%s'.\n"

msgid "Skipping symbolic link %s.\n"
msgstr "Pular sobre o símbolico link %s. \n"

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr ""
"Se omite legătura simbolică %s, tinta nu este un fișier obișnuit. ¡Tente `%s"
" --help' para mais informações.\n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Pular sobre '%s', a linha simbólica para o link %s não é um arquivo normal. "
"\n"

msgid "converting file %s to file %s in Unix format...\n"
msgstr "converterá o arquivo %s para o arquivo %s no formato Unix...\n"

msgid "converting file %s to Unix format...\n"
msgstr "converterá o arquivo %s para o formato Unix...\n"

msgid "converting file %s to file %s in Mac format...\n"
msgstr "converterá o arquivo %s para o formato Mac..."

msgid "converting file %s to Mac format...\n"
msgstr "converterá o arquivo %s para o formato Mac...\n"

msgid "converting file %s to file %s in DOS format...\n"
msgstr "converterá o arquivo %s para o formato DOS...\n"

msgid "converting file %s to DOS format...\n"
msgstr "converterá o arquivo %s para o formato DOS...\n"

msgid "converting %s file %s to %s file %s in Unix format...\n"
msgstr ""
"converterá o arquivo %s (%d) para o arquivo %s (%<PRIuMAX>) no formato "
"Unix...\n"

msgid "converting %s file %s to %s Unix format...\n"
msgstr "converterá o arquivo %s para o formato Unix (%3$s)..."

msgid "converting %s file %s to %s file %s in Mac format...\n"
msgstr ""
"converterá o arquivo %s (%d) para o arquivo %s (Macintosh) no formato Mac…"

msgid "converting %s file %s to %s Mac format...\n"
msgstr "converterá o arquivo %s para o formato Mac (%s)..."

msgid "converting %s file %s to %s file %s in DOS format...\n"
msgstr ""
"converterá o arquivo %s (%d) para o arquivo %s (DOS...) conforme solicitado."

msgid "converting %s file %s to %s DOS format...\n"
msgstr "converterá o arquivo %s para o formato DOS (%s)..."

msgid "problems converting file %s to file %s\n"
msgstr "falha na conversão do arquivo %s para o arquivo %s\n"

msgid "problems converting file %s\n"
msgstr "falha na conversão do arquivo %s"

msgid "can not read from input file %s:"
msgstr "não se pode ler do arquivo de entrada %s:"

msgid "wrong flag '%c' for option -i or --info\n"
msgstr ""
"falha na interpretação do flag `--%c` para o argumento `-i` ou `--info"

msgid "active code page: %d\n"
msgstr "pagina de cod activă: %d"

msgid "invalid %s conversion mode specified\n"
msgstr ""
"falha na conversão especificada %s, não foi possível obter estado (stat) do "
"arquivo %s"

msgid "option '%s' requires an argument\n"
msgstr "opção '%s' requer um argumento."

msgid "invalid %s display encoding specified\n"
msgstr "codificarea específica para afișare %s, não é válida."

msgid "target of file %s not specified in new-file mode\n"
msgstr ""
"o objetivo para o arquivo %s não foi especificado no novo formato de arquivo"

msgid "can not read from input file: %s\n"
msgstr "não se pode ler do arquivo de entrada: %s"

msgid "can not write to output file: %s\n"
msgstr "não se pode escrever no arquivo de saída: %s"

msgid "error: Invalid surrogate pair. Missing low surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "error: Invalid surrogate pair. Missing high surrogate.\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"
