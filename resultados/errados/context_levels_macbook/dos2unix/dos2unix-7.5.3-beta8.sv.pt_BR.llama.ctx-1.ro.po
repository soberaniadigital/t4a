msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr "Utilização: %s [opções] [ficheiro ...] [-n infil utfile …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr " --allow-chown         permite alteração de propriedade para arquivo\n"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                padrão de convergência ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão -iso entre sistemas DOS e ISO-8859-1 de caracteres"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"-1252               utilize a tabela de codificação Windows 1252 (Europa do "
"Leste)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                utilize a tabela de codificação DOS 437 (SUA) "
"(padrão)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilize a tabela de codificação DOS 850 (Europa do "
"Leste)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                utilizează pagina de cod DOS 860 (portuguesa)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilize a tabulação de código DOS 863 (franco-"
"canadense)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                utilize a tabela de codificação DOS 865 (escandinavo)"
" \n"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte os caracteres de 8 bits em espaço de 7 bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"-b --keep-bom        preserva a marcação de ordem dos bytes (Byte Order "
"Mark)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"-b --keep-bom        preserva marcação de ordem dos bytes (Byte Order Mark) "
"(padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode        modul de conversão de utilizat\n"
"   mod_conversao    ASCII, 7bit, ISO, MAC (implicit este é o mesmo que “ASCII”)\n"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     stabilește kodificarea utilizată para textos visuais\n"
"   kodering             ansi, unicode, utf8 (standard é ansi)\n"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol         adicione uma linha de terminação à última linha se "
"nenhuma existir\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "-f, --force           força a conversão de arquivos binários\n"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030        converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "-h, --help            ver por este texto de ajuda\n"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=FLAGGOR]   visa informações sobre o arquivo de análise \n"
"\tarquiv...\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        păstrează datum de criação do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr "-L, --license         visa a licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr "-l --newline         adicione uma linha nova suplementar\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adicione marcação de byte (Byte Order Mark) para "
"UTF-8 padrão\n"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile         escreve em um novo arquivo\n"
"   infil       original_arquivo para o formato de entrada\n"
"   utfil      arquivo convertido no formato de saída"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alteração de propriedade do arquivo "
"(padrão)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          não adicionar uma nova linha no final da última seção "
"quando ela não existir (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "-O, --to-stdout       escreve para saída padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile         escreva no arquivo antigo (padrão) \n"
"   file ...               os arquivos que serão convertidos para o formato do arquivo velho."

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           muda o nível de silêncio, suprime todas as "
"mensagens\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
"-r, --remove-bom      eliminada marcação de ordem dos bytes (Byte Order "
"Mark) (padrão)"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"-r --eliminar-bom      elimina a marcação de ordem dos bytes (Byte Order "
"Mark) \n"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s, --safe            salte sobre os arquivos binários (padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva UTF-16 codificação de caracteres"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr "-ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE\n"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr "-ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE\n"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        oferece informações detalhadas sobre as operações "
"realizadas."

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr ""
" -F, --follow-symlink segue links simbólicos e converte o formato do "
"arquivo."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui links simbólicos por arquivos convertidos "
"(arquivos originais permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos e referências não alteradas"
" (implícitas) \n"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         visa versõesnumero"

