msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Método de uso: %s [opções] [arquivo ...] [-n fi<NAME>_entrada arquivo_saida]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                modul de conversão padrão"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr "conversão entre DOS e o conjunto de caracteres ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"Utilize a página de codificação Windows 1252 (Europa do Sul) para o seu "
"projeto."

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "Utilize a página de codificação DOS 437 (padrão) para o Windows."

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"Utilize a página de codificação DOS 850 (Europa do Sul) para o seu "
"documento."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "Utilize a página de código DOS 860 (Portugal) para o seu projeto."

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"Utilize a página de código DOS 863 (Canadá Francês) para o seu projeto."

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"Utilize a página de código DOS 865 (Europa do Norte) para o seu projeto."

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte os caracteres de 8 bits em espaço de 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
"opção --keep-bom        preserva o sinal de byte order mark (BOM) na ordem "
"original dos bytes."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
"opção -b, --keep-bom        preserva o sinal de byte order mark (BOM) "
"padrão."

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
"chave de conversão:   modo de convergência ASCII, BCD, ISO e MAC (padrão é "
"ASCII)"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     đặt bảng mã para exibir avisos\n"
"   codificação da tela:\n"
"aNSI, unicode ou utf8 (padrão é ansi)"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha ao final da última coluna se não houver "
"nenhum, caso contrário"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"forçar conversão de arquivos binários em base64, preservando todos os "
"caracteres especiais e mantendo a sintaxe original."

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr "Use '--help' para obter ajuda."

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações sobre o arquivo ...         "
"ficheiro de entrada ...            para análise detalhada"

msgid " -k, --keepdate        keep output file date\n"
msgstr ""
" -k, --keepdate        preserva o timestamp original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         afirma licença do software"

msgid " -l, --newline         add additional newline\n"
msgstr "Use '--newline' para adicionar uma linha nova."

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr "adicionar marcação de ordem dos bytes (BOM) padrão UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          escreva no novo arquivo\n"
"   tápia-tin-vàu         fi<|end_of_document|>  I'm sorry for the confusion earlier. It seems there was a misunderstanding in your request as it appears you are asking to translate text into Portuguese, but then suddenly switch languages and provide translations without any specific input provided after "

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite a alteração do proprietário (método "
"implícito)"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
" --no-add-eol          não adiciona uma quebra de linha na última coluna se "
"não houver um delimitador (valor padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       escreve o resultado na saída padrão"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr " -o, --oldfile          escreva no arquivo antigo (padrão)"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr "chave -q, --quiet           silencioso, sem aviso de erros"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr "opção -r, --remove-bom      eliminar o “Byte Order Mark” (BOM) padrão"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
"opção para remover o BOM (Byte Order Mark) -r, --remove-bom      eliminar a "
"marca de ordem dos bytes (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "opção segura -s, --safe            omita fișieres binários (implicit)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     preserva o código UTF-16"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr " -ul, --assume-utf16le presupõe que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr " -ub, --assume-utf16be presupõe que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr ""
" -v, --verbose        oferê informações detalhadas sobre as operações "
"realizadas"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  依循符號連結轉換目標檔案"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink thay thế liên kết mềm bằng tập tinhãnh chuyển đổi "
"(các tập tin dựa trải nguyên gốc thì để cung cấp) (fișierele convertite rồi "
"để không thay đổi)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva as ligações simbólicas e a relação de "
"diretório (padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         mostra versão do programa"

