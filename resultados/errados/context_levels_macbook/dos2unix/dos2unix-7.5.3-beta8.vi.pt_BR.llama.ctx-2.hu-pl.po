msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"CÓDIGO DE UTILIZAÇÃO: %s [selecções] [arquivos ...] [-n arquivo_entrada "
"página_saida ...]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         permite alteração de proprietário do arquivo"

msgid " -ascii                default conversion mode\n"
msgstr " -ascii                chave ASCII"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                    conversoes de caracteres entre o conjunto DOS e "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr ""
"   -1252               utiúzás a Windows 1252 kódlap használatával (Európai "
"nyugati) \n"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr "   -437                utilizando codificação DOS 432 (US) (padrão)"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr ""
"   -850                utilizando a tela de codificação DOS 850 (Tây Bình) "
"do Windows XP em português brasileiro."

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr ""
"   -860                Uso da ferramenta de conversão DOS 860 (Bồ Đào Nha) "
"\n"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr ""
"   -863                utilizando a interface gráfica do sistema operacional"
" DOS 863 (da França) \n"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr ""
"   -865                Uso da ferramenta de conversão DOS 865 (Bacia do "
"Danúbio) para Windows"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
" -7                    converte caracteres de 8 bits para o espaço de 7 "
"bits\n"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr ""
" -b, --keep-bom        mantendo o “Marcador de Ordem do Byte” (BOM) "
"original."

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        preserva o “Marca de Ordem do Byte” (byte order mark)"
" (padrão)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão chaveado:   ASCII, 7bit, ISO, MAC;"
" padrão é ASCII"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     definir o código de exibição para a mensagem do status\n"
"   kódos bảng mã: ansi, unicode, utf8; definição padrão é ansi"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
"adicionar uma quebra de linha no final da última linha se não houver (%s, "
"%d) campos esperados\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr "bắt buôn chuyển đổi các tập tin nhị phân"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr " -gb, --gb18030         conversão UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            ajuda nesta ação"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibição de informações sobre o arquivo ... "
"ficheiros para análise"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        mantendo a data original do arquivo de saída\n"

msgid " -L, --license         display software license\n"
msgstr " -L, --license         hiển thị giấy phép dùng phần mềm\n"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adição de novo dólar\n"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adição de “Marcação do Byte Ordem” (padrão UTF-8)"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập tin vào         tập tin gốc trong chế độ tập tin-mới\n"
"tập tin ra           tập tin đầu ra trong chế độ tập tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"opção --no-allow-chown      sem permissão para alterar o proprietário do "
"arquivo (padrão) \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--sem adição de nova linha --não acrescenta um caractere de quebra de linha "
"no final se nenhum for encontrado (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr " -O, --to-stdout       ghi vào stdout padrão\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          carregar o arquivo antigo (padrão) \n"
"   ficheiro ...            cadeias de caracteres para converter no formato do sistema operacional atual\n"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr ""
" -q, --quiet           silêncio do usuário, suprimir todas as mensagens de "
"erro\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr " -r, --remove-bom      apagar o sinal BOM (Byte Order Mark) padrão\n"

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr ""
" -r, --remove-bom      apagar o “Byte Order Mark” (BOM) (byte order mark)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr " -s, --safe            bỏ qua tập tin nhị phân (mặc định)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u, --keep-utf16     manter a codificação UTF-16 do arquivo"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
" -ul, --assume-utf16le considerando que o formato de entrada é UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
" -ub, --assume-utf16be considerando que o formato de entrada é UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr " -v --verbose        análise detalhada do processo"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr " -F, --follow-symlink  o seguimento e a conversão de objetivos"

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substituição de links simbólicos por arquivos reais (apenas para os caminhos originais) \n"
"                   (as pastas e diretórios originales permanecem inalterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
" -S, --skip-symlink    preserva links simbólicos mínimos e não altera "
"(padrão) \n"

msgid " -V, --version         display version number\n"
msgstr " -V, --version         verión do software"

msgid "DOS 16 bit version (Watcom C).\n"
msgstr "Ficheiro de texto para linguagem C (Watcom C).\n"

msgid "DOS 16 bit version (Turbo C).\n"
msgstr "Fenome do Sistema Operacional DOS (TURBOC) - Versão de 16 bits."

msgid "DOS 32 bit version (Watcom C).\n"
msgstr "Fenome do Sistema Operacional DOS (32 bits) - WATCOM C."

