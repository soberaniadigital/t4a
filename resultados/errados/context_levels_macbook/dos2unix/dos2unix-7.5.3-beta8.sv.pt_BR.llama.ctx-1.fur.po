msgstr ""
"Falha na conversão UTF-16 do arquivo %s, a convergência para o formato "
"UTF-16 não é suportada nesta versão de %s."

msgid "Skipping %s, not a regular file.\n"
msgstr "Falhar ao acessar %s, não é um arquivo comum."

msgid "Skipping %s, output file %s is a symbolic link.\n"
msgstr "Fora sobre %s, o link '%s' é um simbólico. \n"

msgid "Skipping symbolic link %s.\n"
msgstr "Pular sobre o link simbólico %s."

msgid "Skipping symbolic link %s, target is not a regular file.\n"
msgstr "Fora de um link simbólico %s, o objetivo não é um arquivo normal. \n"

msgid "Skipping %s, target of symbolic link %s is not a regular file.\n"
msgstr ""
"Fora de %s, a destinação simbólica do link para o diretório não é um arquivo"
" regular. A opção `--help` fornece mais informações.\n"

