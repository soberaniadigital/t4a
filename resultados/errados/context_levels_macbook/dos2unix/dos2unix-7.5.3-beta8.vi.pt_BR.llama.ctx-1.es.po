msgid "Usage: %s [options] [file ...] [-n infile outfile ...]\n"
msgstr ""
"Cách dùng: %s [các-tùy-chọn] [tập-tin …] [-n tập-tin-vào tập-tin-ra …]"

msgid " --allow-chown         allow file ownership change\n"
msgstr "--allow-chown         chg_owner phq tb %s\n"

msgid " -ascii                default conversion mode\n"
msgstr ""
" -ascii                chaveamento padrão de conversão dos saltos de linha"

msgid ""
" -iso                  conversion between DOS and ISO-8859-1 character set\n"
msgstr ""
" -iso                 conversão entre DOS e o conjunto de caracteres "
"ISO-8859-1"

msgid "   -1252               use Windows code page 1252 (Western European)\n"
msgstr "-1252               usa trâng mã Windows 1252 (Tây Âu)"

msgid "   -437                use DOS code page 437 (US) (default)\n"
msgstr ""
"   -437                usa a página de códigos DOS 437 (US) (por defeito)\n"

msgid "   -850                use DOS code page 850 (Western European)\n"
msgstr "-850                usa trâng mã DOS 850 (Tây Âu)"

msgid "   -860                use DOS code page 860 (Portuguese)\n"
msgstr "   -860                usa a página de códigos DOS 860 (Português)"

msgid "   -863                use DOS code page 863 (French Canadian)\n"
msgstr "-863                usa trâng mã DOS 863 (Ca Na Đa Pháp)"

msgid "   -865                use DOS code page 865 (Nordic)\n"
msgstr "-865                usa trâng mã DOS 865 (Bắc Âu)"

msgid " -7                    convert 8 bit characters to 7 bit space\n"
msgstr ""
"-7                    converte caracteres de 8 bits para espaço de 7 bits"

msgid " -b, --keep-bom        keep Byte Order Mark\n"
msgstr " -b, --keep-bom        conserva a Marca de Orden del Byte (BOM)"

msgid " -b, --keep-bom        keep Byte Order Mark (default)\n"
msgstr ""
" -b, --keep-bom        conserva a Marca de Orden del Byte (por defeito)"

msgid ""
" -c, --convmode        conversion mode\n"
"   convmode            ascii, 7bit, iso, mac, default to ascii\n"
msgstr ""
" -c, --convmode         modo de conversão\n"
"   modo_de_conversão:\n"
"ascii, 7bit, iso, mac, mặc định là ascii"

msgid ""
" -D, --display-enc     set encoding of displayed text messages\n"
"   encoding            ansi, unicode, utf8, default to ansi\n"
msgstr ""
" -D, --display-enc     define a tabela de codificação para exibir mensagens de texto\n"
"   tabela de codificação:\n"
"ansi (padrão), unicode ou utf8"

msgid ""
" -e, --add-eol         add a line break to the last line if there isn't "
"one\n"
msgstr ""
" -e, --add-eol   adicionar dít ngắt dòng vào dòng cuối cùng nếu không có "
"chứa già\n"

msgid " -f, --force           force conversion of binary files\n"
msgstr ""
"-f --force   obrigatório converter arquivos binários em tabelas n-afiladas"

msgid " -gb, --gb18030        convert UTF-16 to GB18030\n"
msgstr "-gb, --gb18030          converte UTF-16 para GB18030\n"

msgid " -h, --help            display this help text\n"
msgstr " -h, --help            exibe esta ajuda"

msgid ""
" -i, --info[=FLAGS]    display file information\n"
"   file ...            files to analyze\n"
msgstr ""
" -i, --info[=CỜ]        exibe informações do arquivo \n"
"   tập tin ...            para análise de múltiplos conjuntos de dados\n"

msgid " -k, --keepdate        keep output file date\n"
msgstr " -k, --keepdate        conserva la fecha en el archivo de salida\n"

msgid " -L, --license         display software license\n"
msgstr " -L --license         mostra a licença do programa ES"

msgid " -l, --newline         add additional newline\n"
msgstr " -l, --newline         adiciona novo caráter de nova linha"

msgid " -m, --add-bom         add Byte Order Mark (default UTF-8)\n"
msgstr ""
" -m, --add-bom         adiciona o Byte Order Mark (BOM) padrão do UTF-8"

msgid ""
" -n, --newfile         write to new file\n"
"   infile              original file in new-file mode\n"
"   outfile             output file in new-file mode\n"
msgstr ""
" -n, --newfile          ghi ra tập tin mới\n"
"tập-tin-vào          tập tin gốc trong chế độ tập-tin-mới\n"
"tập-tin-ra           tập tin đầu ra trong chế độ tập-tin-mới"

msgid " --no-allow-chown      don't allow file ownership change (default)\n"
msgstr ""
"--no-allow-chown      não permite alterar o proprietário do arquivo (padrão)"
" \n"

msgid ""
" --no-add-eol          don't add a line break to the last line if there "
"isn't one (default)\n"
msgstr ""
"--no-add-eol          Não adiciona dáfines ao final do último caractere se "
"não houver delimitadores (padrão)"

msgid " -O, --to-stdout       write to standard output\n"
msgstr "--stdout --to-stdout\n"

msgid ""
" -o, --oldfile         write to old file (default)\n"
"   file ...            files to convert in old-file mode\n"
msgstr ""
" -o, --oldfile          escreve no arquivo antigo (por padrão) \n"
"   tape-tin ...            os arquivos a converter para o modo de armazenamento do arquivo antigo"

msgid " -q, --quiet           quiet mode, suppress all warnings\n"
msgstr " -q, --quiet           modo silencioso, suprime todas as avisões\n"

msgid " -r, --remove-bom      remove Byte Order Mark (default)\n"
msgstr ""
" -r, --remove-bom      elimina a Marca de Orden del Byte (BOM), por defeito."

msgid " -r, --remove-bom      remove Byte Order Mark\n"
msgstr " -r, --remove-bom      elimina a Marca de Orden del Byte (BOM)"

msgid " -s, --safe            skip binary files (default)\n"
msgstr "-s --seguro            ignora arquivos binários (por padrão)"

msgid " -u,  --keep-utf16     keep UTF-16 encoding\n"
msgstr " -u,  --keep-utf16     mantém a codificação UTF-16\n"

msgid " -ul, --assume-utf16le assume that the input format is UTF-16LE\n"
msgstr ""
"-ul, --assume-utf16le coi régando que o dânose de entrada seja UTF-16LE"

msgid " -ub, --assume-utf16be assume that the input format is UTF-16BE\n"
msgstr ""
"-ub, --assume-utf16be coi régando que o dênfase de entrada seja UTF-16BE"

msgid " -v,  --verbose        verbose operation\n"
msgstr "-v --verbose        operação detalhada\n"

msgid " -F, --follow-symlink  follow symbolic links and convert the targets\n"
msgstr "-F, --follow-symlink o teo liên kết mềm và chuyển đổi đích."

msgid ""
" -R, --replace-symlink replace symbolic links with converted files\n"
"                         (original target files remain unchanged)\n"
msgstr ""
" -R, --replace-symlink substitui os links simbólicos pelos arquivos "
"convertidos (os arquivos originais não são alterados)"

msgid ""
" -S, --skip-symlink    keep symbolic links and targets unchanged (default)\n"
msgstr ""
"-S, --skip-symlink    não altera links simbólicos nem seus destinos (por "
"defeito)"

msgid " -V, --version         display version number\n"
msgstr "-V --versão         exibe o número da versão do software"

