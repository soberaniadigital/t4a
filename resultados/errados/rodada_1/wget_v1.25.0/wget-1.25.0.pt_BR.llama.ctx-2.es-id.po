msgid "%s: unable to resolve bind address %s; disabling bind.\n"
msgstr "%s: não é possível resolver o endereço bind %s; desligando a conexão."

msgid "Connecting to %s:%d... "
msgstr "Menghubungi %s:%d... "

msgid "%s: unable to resolve host address %s\n"
msgstr "%s: não é possível resolver o endereço %s"

msgid "Cannot convert links in %s: %s\n"
msgstr "Не foi possível converter as referências em %s: %s\n"

msgid "Syntax error in Set-Cookie: %s at position %d.\n"
msgstr "Erro de sintaxe no Set-Cookie: %s na posição %d."

msgid "Cannot open cookies file %s: %s\n"
msgstr "não é possível abrir o arquivo de cookies %s: %s\n"

msgid "time unknown       "
msgstr "tempo desconhecido   "

msgid "File        "
msgstr "Arquivo    "

msgid ", %s (%s) remaining"
msgstr ", %s (%s) tersisa"

msgid "Write failed, closing control connection.\n"
msgstr "Erro de escrita, conexão controladora encerrada."

msgid "The server refuses login.\n"
msgstr "O servidor rejeitou o login."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a comando 'PROT %c'."

msgid "done.    "
msgstr "pronto."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não há diretório %s. \n"

msgid "Cannot parse PASV response.\n"
msgstr "Erro ao analisar a resposta PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível conectar ao %s porto %d:%s\n"

msgid "Bind error (%s).\n"
msgstr "Ошибка bind (%s)."

msgid "Invalid PORT.\n"
msgstr "PORT inválido."

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro REST, iniciar a partir do começo."

msgid "%s has sprung into existence.\n"
msgstr "%s se tornou realidade."

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado."

msgid "(try:%2d)"
msgstr "(tentativa:%2d)"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) - ditulis ke stdout %s[%s]"

msgid "Removing %s.\n"
msgstr "Menghapus %s."

msgid "Removed %s.\n"
msgstr "Dihapus %s."

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr "Arquivo remoto %s — carregando."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Размеры не совпадають (локальний размер %s) -- завантажується."

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome de link simbólico inválido, ignorado."

msgid "Skipping directory %s.\n"
msgstr "Omitindo o diretório %s."

msgid "Rejecting %s.\n"
msgstr "Menolak %s."

msgid "Error matching %s against %s: %s\n"
msgstr "falha na correspondência de %s com %s: %s"

msgid "No matches on pattern %s.\n"
msgstr "Não há nada que se ajuste ao padrão %s."

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ОШИБКА: Erro ao abrir certificado %s: (%d)."

msgid "Loaded CRL file '%s'\n"
msgstr "Carregado fichero CRL '%s'"

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr "%s: Sertifikat %s tak punya penerbit yang dikenal. \n"

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr ""
"%s: O certificado de assinatura %s não foi encontrado no Centro "
"Autoritativo."

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro na inicialização do certificado X509: %s"

msgid "No certificate found\n"
msgstr "Certificado não encontrado."

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não foi ativado."

msgid "The public key does not match pinned public key!\n"
msgstr ""
"Chave pública não corresponde à chave encadeada! Esse é um erro de "
"segurança."

msgid "Error in handling the address list.\n"
msgstr ""
"Erro ao processar a lista de endereços. Para obter mais informações, tente "
"'list --help'."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr ""
"%s: não é possível reconhecer uma URL parcialmente preenchida %s. Por favor,"
" verifique se a entrada está correta."

msgid "No headers, assuming HTTP/0.9"
msgstr "Tidão não há cabeçalhos, supondo-se HTTP/0.9"

msgid "Reusing existing connection to %s:%d.\n"
msgstr "Reutilização do socket %s:%d."

msgid "%s ERROR %d: %s.\n"
msgstr "%s ERRO %d: %s. (Assuming 'ОШИБКА' translates to 'ERRO')"

msgid "Proxy tunneling failed: %s"
msgstr "Erro na tunelização do proxy: %s"

msgid "Saving to: %s\n"
msgstr "Menyimpan ke: %s\n"

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar um arquivo temporário. Continuando a descarga da "
"assinatura."

msgid "%s request sent, awaiting response... "
msgstr "Permintação %s enviada, esperando resposta... "

msgid "No data received.\n"
msgstr "Não foram recebidos dados."

msgid "Read error (%s) in headers.\n"
msgstr "Erro de leitura (%s) nos cabeçalhos."

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr " [mengikuti]"

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr "Arquivo já foi totalmente carregado; não há nada a ser feito."

msgid "Length: "
msgstr "Panjang: "

msgid "ignored"
msgstr "ignorado"

msgid "Cannot write to temporary WARC file.\n"
msgstr "Não é possível escrever no arquivo WARC temporário."

msgid "Cannot unlink %s (%s).\n"
msgstr "Невозможно удалити %s (%s)."

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr "Заголовок Last-modified не é aceito -- marca de tempo ignorada."

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) - Conectado, posição %s. "

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: Não foi possível ler %s (%s)."

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %d."

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo wgetrc do sistema (env SYSTEM_WGETRC). Por "
"favor, verifique '\\n%s', ou especifique um arquivo diferente usando "
"--config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Aviso de Erro: wgetrc do sistema e usuário apontam para %s. Por favor, "
"revise as configurações.\n"

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando --execute inválido %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Boolean não válido %s; use 'on' ou 'off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: %s não é válido; use 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. (Número não é válido em português.)"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s\n"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão do %s para o %s não está suportada."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado %d"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "Redirecionando a saída para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; desligando a captura de logs. \n"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Penggunaan: %s [OPSI]... [URL]..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas também são necessários para as"
" opções curtas."

msgid "Startup:\n"
msgstr "Início do processo:"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      mostre esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para entrar no modo de"
" fundo."

msgid "Logging and input file:\n"
msgstr "Jogos e Entrada de Dados: Berkas masukan dan log:"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=%s\n"
"dopirizar mensagens no final do arquivo %s\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "--verbose                   verbose (por padrão)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=UNIDADES    determinar UNIDADEM. UNIDADE pode ser "
"bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr "  -i,  --input-file=FILE     carregue URLs conforme local ou externo\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "       --no-config           não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registre as causas para o rejeitamento de URL "
"no FILE\n"

msgid "Download:\n"
msgstr ""
"Unduh: ID=%s, ES=%d, %<PRIuMAX> campos (esperado %<PRIuMAX>) falha na "
"verificação."

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir ЧИСЛО tentativas\n"
"                                 (0 без ограничения) \n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    escrever documentos no arquivo FILE\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                  continuar a leitura de um arquivo "
"parcialmente carregado\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TYPE             seleccione tipo de indícer de progresso\n"

msgid "  -S,  --server-response           print server response\n"
msgstr ""
" -S, --server-response           Resposta do servidor enviada ao cliente."

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         fixar todos os valores de timeout igual ao"
" número SEGUNDOS\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEC         definir o tempo limite para a busca no DNS "
"em SEC\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"       --read-timeout=SEC        definição do tempo limite de leitura em "
"segundos\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDOS            pausa em SEGUNDOS entre transferências de URLs\n"
"                                 (aplica-se quando forem mais do que uma URL para serem baixadas)\n"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                  explicitamente desligue o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=%s              establecer a quantidade de quota da "
"transferência em %s"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED           limitar a velocidade de transferência "
"para SPEED\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only                conecta apenas a direções IPv6 saja"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "--no-iri                    desabilitar suporte IRI"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"       --unlink                    apagar arquivo antes de sobrescrever"

msgid "Directories:\n"
msgstr "Diretórios:\n"

msgid "HTTP options:\n"
msgstr "Opciones HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=POLIZOVATEL\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "--no-cache                      ignorar dados armazenados no servidor"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=STRING             inserir STRING entre cabeçalhos\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          máximo permitido de redirecionamentos para a "
"página\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLLE   instale PAROLLE como senha para proxy\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      mantenha e guarde cookies de sessão (não "
"permanentes)\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=СТРОКА      utilizar метод POST; envio de СТРОКИ в "
"качестве данных\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   принимати o header Content-Disposition ketika"
" se selecionar nomes para arquivos locais (EXPERIMENTAL)\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Opciones HTTPS (SSL/TLS):\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE          ficheiro de certificado do usuário\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--nonaktivo HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS (substituir"
" valor padrão)\n"

msgid "FTP options:\n"
msgstr ""
"Opsi FTP:\n"
"\"ID\": \"%s\",\n"
"\"ES\": \"%d\",\n"
"\"<PRIuMAX>\": %<PRIuMAX>"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "       --no-remove-listing         não remova o arquivo '.listing'"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"--no-passive-ftp            desligue o modo 'pasivo' de transferência."

msgid "FTPS options:\n"
msgstr "Параметры FTPS:\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                 antes de escrever o arquivo X, fazer backup até "
"N vezes\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"--backup-converted          se antes de converter o arquivo X, criar uma "
"cópia no formato X.orig\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LIST                 lista separada por vírgulas de "
"extensões rechazadas\n"

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclude-directories=LIST diretórios que serão ignorados."

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, sebuah program para baixar arquivos da internet de forma "
"autônoma. \n"

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr ""
"Erro de inicialização do objeto ação arquivo durante o spawn para use-"
"askpass: %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "falha na leitura da resposta da comando \"%s %s\": %s"

msgid "Locale: "
msgstr "Lokal: "

msgid "    %s (env)\n"
msgstr "    %s (ambiente) \n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later\n"
"<http://www.gnu.org/licenses/gpl.html>.\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior\n"
"<http://www.gnu.org/licenses/gpl.html>\n"
"Este é software livre:\n"
"it pode ser modificado e redistribuído sem qualquer garantia, até onde a lei permita.\n"

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações sobre os parâmetros adicionais, tente 'Coba '%s "
"--help'."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"Указаны сразу --no-clobber и --convert-file-only, будет использоваться "
"только --convert-file-only."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr "Не é possível especificar ao mesmo tempo --inet4-only e --inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é possível especificar simultaneamente -k ou --convert-file-only e -O, "
"se URLs múltiplas forem indicadas, ou em combinação com os parâmetros -p ou "
"-r. Consulte o manual para detalhes."

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"PREDÚPRAREJEDENCIA: trabalhar com marcadores de tempo não é possível quando "
"o parâmetro -O for especificado. Para detalhes, consulte o manual."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com o parâmetro --no-clobber, esse parâmetro será"
" desabilitado."

msgid "WARC output does not work with --spider.\n"
msgstr "Saída WARC não funciona com --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com --continue ou --start-pos; eles serão "
"desabilitados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório desativado; deduplicação WARC não encontrará registros duplicados."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente --ask-password e --password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"PREVÍDUPE DE PROCESSAMENTO DOS ARQUIVOS: NÃO FOI FORNECIDO O NOME DO "
"USUÁRIO, mas foi especificado --ask-password. Isso geralmente não é o que se"
" deseja fazer."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"Parâmetro -k ou -r pode ser utilizado juntamente com -O apenas se a saída "
"for para um arquivo regular. \n"

msgid "Failed to init c-ares channel\n"
msgstr "Erro ao inicializar o canal c-ares"

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Menorá o arquivo metalink. Nome não seguro."

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr "Menolak berkas metaurl %s. Nome que não é seguro."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro ao baixar %s. Ignorando metaurl."

msgid "Metaurls processing returned with error.\n"
msgstr ""
"Ocorreu uma falha na processamento do URL meta. Por favor, verifique o "
"formato e tente novamente."

msgid "Could not open downloaded file.\n"
msgstr "Не foi possível abrir o arquivo baixado."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "GPGME data_new_from_mem: %s\n"

msgid "GPGME op_verify: %s\n"
msgstr "GPGME op_verificar: %s"

msgid "No checksums found.\n"
msgstr "Cheques de verificação não encontrados."

msgid "File %s retrieved but signature does not match. \n"
msgstr "Arquivo %s obtido, mas a assinatura não corresponde. \n"

msgid "Continuing in background.\n"
msgstr "Através do processo continua em segundo plano."

msgid "%s: %s:%d: warning: %s token appears before any machine name\n"
msgstr ""
"%s: %s:%d: aviso: o símbolo '%c' aparece antes do nome de qualquer máquina\n"

msgid "WARNING: using a weak random seed.\n"
msgstr ""
"PRECEDENCIA: utiliza um fonte de dados aleatórios fraca. Por favor, "
"verifique se a semilla utilizada é forte o suficiente para garantir uma "
"geração confiável e imprevisível dos valores."

msgid "Your OpenSSL version is too old to support TLSv1.1\n"
msgstr "Versão do seu OpenSSL está muito antiga para suportar TLSv1.1."

msgid "OpenSSL: Failed to allocate verification param\n"
msgstr "OpenSSL: Não foi possível alocar o parâmetro de verificação"

msgid "WARNING: Could not seed PRNG. Consider using --random-file.\n"
msgstr ""
"PRECISÃO: não é possível semear o PRNG. Considere utilizar o parâmetro "
"--random-file."

msgid "  Self-signed certificate encountered.\n"
msgstr "Certificado auto-firmado encontrado."

msgid "  Issued certificate has expired.\n"
msgstr "Para o certificado solicitado, expirou o prazo de validade."

msgid "To connect to %s insecurely, use `--no-check-certificate'.\n"
msgstr ""
"Para conectar a %s de forma não segura, utilize o parâmetro '--no-check-"
"certificate'."

msgid "Invalid dot style specification %s; leaving unchanged.\n"
msgstr "Spesficicasi gaya dot %s inválida; se deixa sem modificar."

msgid "Invalid user name"
msgstr "Nome de usuário inválido"

msgid "Unconvertable multibyte sequence encountered\n"
msgstr "Обнаружено uma sequência multibyte inconvertível"

msgid "%s: aprintf: text buffer is too big (%d bytes), aborting.\n"
msgstr "%s: aprintf: buffer de texto muito grande (%d byte), interrompendo. \n"

msgid "File %s changed since the last check. Security check failed.\n"
msgstr ""
"Desde a última verificação, o arquivo %s sofreu alterações. A verificação de"
" segurança falhou."

msgid "Failed to stat file %s, error: %s\n"
msgstr "Erro ao executar o comando stat para arquivo %s, erro: %s\n"

msgid "Invalid regular expression %s, PCRE2 error %d\n"
msgstr "Regular expression '%s' é inválido, erro PCRE2 %d\n"

msgid "Invalid regular expression %s, %s\n"
msgstr "Não é permitido o uso do padrão regular %s, %s\n"

msgid "Error while matching %s: %d\n"
msgstr "falha ao comparar %s com valor %d\n"

msgid "Error setting WARC file position.\n"
msgstr "Erro ao mover posição no arquivo WARC."

msgid "Error opening GZIP stream to WARC file.\n"
msgstr "Erro ao abrir fluxo GZIP para o arquivo WARC."

msgid "Error writing warcinfo record to WARC file.\n"
