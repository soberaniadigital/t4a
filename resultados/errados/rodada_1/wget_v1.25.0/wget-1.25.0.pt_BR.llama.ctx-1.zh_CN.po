msgid "%s: unable to resolve bind address %s; disabling bind.\n"
msgstr ""
"%s: não é possível resolver o endereço bind %s; a ligação será desligada. "
"(bind off)"

msgid "Connecting to %s:%d... "
msgstr "Conectando ao %s:%d... "

msgid "%s: unable to resolve host address %s\n"
msgstr "%s: não é possível resolver o endereço %s"

msgid "Cannot convert links in %s: %s\n"
msgstr "Не удаётся преобразовать ссылки в %s: %s"

msgid "Syntax error in Set-Cookie: %s at position %d.\n"
msgstr "Erro de sintaxe no Set-Cookie: %s na posição %d."

msgid "Cannot open cookies file %s: %s\n"
msgstr "não é possível abrir o arquivo de cookies %s: %s"

msgid "time unknown       "
msgstr "tempo desconhecido         "

msgid "File        "
msgstr "Arquivo        "

msgid ", %s (%s) remaining"
msgstr ", %s (%s) restante."

msgid "Write failed, closing control connection.\n"
msgstr "Erro de escrita, conexão controladora está fechando."

msgid "The server refuses login.\n"
msgstr "O servidor negou o login."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a instrução 'PROT %c'."

msgid "done.    "
msgstr "Pronto."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"contador de diretórios ativos: %d\n"
"cwd_início: %d\n"
"cwd_fim: %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não há tal diretório: %s."

msgid "Cannot parse PASV response.\n"
msgstr "Erro ao analisar a resposta PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível conectar ao %s no porto %d: %s"

msgid "Bind error (%s).\n"
msgstr "Erro de vinculação (%s)."

msgid "Invalid PORT.\n"
msgstr "ENUM_ERROR - PORT não é válido."

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro de REST, iniciando o download novamente desde o início."

msgid "%s has sprung into existence.\n"
msgstr "%s surgiu de repente."

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado."

msgid "(try:%2d)"
msgstr "(tentativa:%2d)"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) - 已写入标准输出 %s[%s]"

msgid "Removing %s.\n"
msgstr "É removido o %s."

msgid "Removed %s.\n"
msgstr "Удалена %s."

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr "Arquivo remoto do novo local %s - carregado."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Размеры не совпадають (локальный размер %s) — загружается.\n"

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome inválido para a ligação simbólica, ignorado."

msgid "Skipping directory %s.\n"
msgstr "O diretório %s foi ignorado."

msgid "Rejecting %s.\n"
msgstr "Отклоняется %s."

msgid "Error matching %s against %s: %s\n"
msgstr ""
"%s e %s não podem ser associados corretamente, pois ocorreu um erro na "
"correspondência com a mensagem '%s'."

msgid "No matches on pattern %s.\n"
msgstr "Não há correspondências com o padrão %s."

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ERRO: Erro ao abrir certificado %s: (%d)."

msgid "Loaded CRL file '%s'\n"
msgstr "Загружен CRL-файл «%s»\n"

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr "%s: %s 的证书颁发者未知。"

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr ""
"%s: O certificado emitido pelo %s não é de uma Autoridade Certificadora "
"(CA).\n"

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro de inicialização do certificado X509: %s"

msgid "No certificate found\n"
msgstr "Certificado não encontrado"

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não foi ativado."

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública aberta não corresponde à chave pública fixa!"

msgid "Error in handling the address list.\n"
msgstr "Erro ao processar a lista de endereços."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr ""
"%s: não é possível reconhecer uma URL inválida %s. Por favor, verifique se a"
" URL está correta e tente novamente."

msgid "No headers, assuming HTTP/0.9"
msgstr "Os cabeçalhos HTTP estão ausentes, assumindo o protocolo HTTP/0.9."

msgid "Reusing existing connection to %s:%d.\n"
msgstr "uso repetido do soquete conectado a %s:%d.\n"

msgid "%s ERROR %d: %s.\n"
msgstr "%s ERRO %d: %s.\n"

msgid "Proxy tunneling failed: %s"
msgstr "Erro de túnel do proxy: %s"

msgid "Saving to: %s\n"
msgstr "Salvando em: %s\n"

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar um arquivo temporário. O download da assinatura é "
"permitido."

msgid "%s request sent, awaiting response... "
msgstr "Olá! %s-запрос отправлен. Ожидание ответа… "

msgid "No data received.\n"
msgstr "Não foram recebidos dados."

msgid "Read error (%s) in headers.\n"
msgstr "Erro de leitura (%s) nos cabeçalhos."

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr "[seguir para nova URL]"

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr ""
"Arquivo já carregado integralmente; não há ações adicionais necessárias."

msgid "Length: "
msgstr "Comprimento:"

msgid "ignored"
msgstr "ignorado"

msgid "Cannot write to temporary WARC file.\n"
msgstr "Não é possível escrever no arquivo temporário WARC."

msgid "Cannot unlink %s (%s).\n"
msgstr "Não é possível excluir %s (%s)."

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr ""
"Não é permitido o título 'Last-modified' -- os marcos de tempo são "
"ignorados."

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) - Conectar fechado na posição %s. "

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: não é possível ler %s (%s)."

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%1$s: Comando desconhecido %2$s na linha %4$d da coluna %3$s."

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro de processamento do arquivo wgetrc (env SYSTEM_WGETRC). Verifique o "
"conteúdo da variável '%s', ou especule um outro arquivo utilizando a opção "
"--config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Aviso: os arquivos wgetrc do sistema e do usuário indicam para %s. Por "
"favor, revise as configurações em ambos."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando --execute inválido %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Falha no valor lógico do switch %s; use 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: Inválido '%s'; utilize 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. \n"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O processo de conversão do %s para o %s não é suportado."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado %d"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O E/S padrão está redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr ""
"%s: a opção '%s' foi desabilitada. Ao utilizar esta função, o registro de "
"log será interrompido."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL]...\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas permanecem obrigatórios mesmo "
"quando se usam opções curtas."

msgid "Startup:\n"
msgstr "Iniciar:"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h, --help                       Mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa, inicie no modo de "
"fundo."

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada:\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr "  -a,  --append-output=FILE   adicionar mensagens ao final do FILE\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "  -v,  --verbose                    Verbose (default)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=тип    единицы измерения пропускной способности\n"
"                             определить тип. тип может быть равно битам\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo <ARQUIVO> \n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                    não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registrem os motivos de rejeição das URLs em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             configurar o número de tentativas (0 para "
"sem limite) \n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    salvar documentos no FILE\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr "  -c,  --continue                  断点续传下载文件\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIPO            escolher tipo de indicador de progresso\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         Resposta do servidor\n"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         configuração de todos os timeouts para o "
"número SEGUNDOS especificado\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SECS         configuração do timeout para busca no DNS "
"em SECS segundos\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"       --read-timeout=SEC        configuração do tempo limite de leitura em "
"segundos\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEGUNDOS               pausa de segundos entre as solicitações"
" para carregar mais de um URL\n"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "       --no-proxy                   Desligue o proxy explicitamente\n"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓDIGO             definir a quantidade de quota em CÓDIGO "
"bytes\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED            limitar a SPEED de transferência para "
"evitar sobrecarga do servidor"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only                 conectar apenas a endereços IPv6\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                     Desligue o suporte ao IRI\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"       --unlink                     Remover arquivo antes de desmontar"

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "HTTP options:\n"
msgstr ""
"HTTP 选项：\n"
"%s: %<PRIuMAX> 字段，请求头中必须提供。\n"
"%d: %<PRIuMAX> 字段，请求头中可选的。\n"
"%s: %d 字段，请求头中必须提供的非数值字段。"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=USUÁRIO_HTTP\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"--no-cache                   Não utilizar dados armazenados no servidor."

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=STRING          inserir STRING entre cabeçalhos\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          максимально допустимое число перенаправлений "
"на страницу\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PASSWORD   utilizar PASSWORD como a senha para o "
"proxy\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr "        --keep-session-cookies        读取并保存会话 (非永久) cookies。\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING utilizar método POST; envio de STRING como dados."

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   permitir Content-Disposition заголовок при выборе имен файлов локальных\n"
"                               (EXPERIMENTAL)\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE      Arquivo de certificado do usuário\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                    Desligue HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS "
"(sobreescreve o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "       --no-remove-listing         Não remova arquivos ‘.listing’"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp             Desligue o modo 'passivo' de "
"transferência FTP"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                   antes de escrever no arquivo X, fazer rotação "
"em N cópias do arquivo\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
" -K, --backup-converted           Antes de converter o arquivo X, faça uma "
"cópia de backup do formato original como X.orig."

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LISTA                Lista separada por vírgula de extensões"
" a serem rejeitadas."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclude-directories=LISTA DE CATALOGOS A SEREM EXCLUIDOS\n"

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, ferramenta para baixar arquivos da internet de forma não "
"interativa."

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr ""
"Erro na inicialização do objeto de ação dos arquivos para spawn usando use-"
"askpass: %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "Erro ao ler a resposta da comando \"%s %s\": %s"

msgid "Locale: "
msgstr "Localização: "

msgid "    %s (env)\n"
msgstr "    %s (ambiente) \n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later\n"
"<http://www.gnu.org/licenses/gpl.html>.\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou superior\n"
"<http://www.gnu.org/licenses/gpl.html>\n"
"Este é software livre: você pode modificá-lo e distribuí-lo sem limitações.\n"
"Nenhum direito de autor será violado, dentro dos limites legais."

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações sobre os parâmetros adicionais, tente usar a "
"comando ‘%s --help’."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"São indicados imediatamente --no-clobber e --convert-file-only, será "
"utilizado exclusivamente o último."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar simultaneamente --inet4-only e --inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é permitido especificar simultaneamente -k (ou --convert-file-only) e o "
"opcional -O, especialmente quando múltiplos URLs são fornecidos. Além disso,"
" essas flags não podem ser usadas em conjunto com as opções -p ou -r."

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"AVISO: trabalhar com marcações de tempo não tem efeito, se utilizar o "
"parâmetro -O. Para mais informações consulte o manual.\n"

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com o parâmetro --no-clobber, ele será "
"desabilitado."

msgid "WARC output does not work with --spider.\n"
msgstr "O output do WARC não funciona ao mesmo tempo que o --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O output do WARC não pode ser utilizado simultaneamente com o --continue ou "
"o --start-pos; eles serão desabilitados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Desculpe, mas o feed foi desativado. A duplicação WARC não encontrará "
"registros repetidos."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente --ask-password e --password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"AVISO: especificou `--ask-password' sem indicar o nome de usuário. Isso pode"
" não ser o que você deseja."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"O parâmetro -k ou -r só pode ser utilizado em conjunto com o -O, se a saída "
"for para um arquivo normal. \n"

msgid "Failed to init c-ares channel\n"
msgstr "Erro durante a inicialização do canal c-ares"

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Rejeitando o arquivo metalink. Nome de arquivo inseguro."

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr "Ignoramos o arquivo de metadados %s. Nome inseguro."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro ao baixar %s. Passando a metaurl."

msgid "Metaurls processing returned with error.\n"
msgstr "Ao processar o URL meta, foi gerada uma exceção."

msgid "Could not open downloaded file.\n"
msgstr "Não é possível abrir o arquivo baixado."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "GPGME data_new_from_mem: %s\n"

msgid "GPGME op_verify: %s\n"
msgstr "GPGME op_verificar: %s"

msgid "No checksums found.\n"
msgstr "As contas de verificação não foram encontradas."

msgid "File %s retrieved but signature does not match. \n"
msgstr "Arquivo %s recebido, mas a assinatura não corresponde."

msgid "Continuing in background.\n"
msgstr "Através do processo continua em segundo plano."

msgid "%s: %s:%d: warning: %s token appears before any machine name\n"
msgstr "%s: %s:%d: aviso: antes do nome de cada máquina há um marcador %s"

msgid "WARNING: using a weak random seed.\n"
msgstr ""
"AVISO: está utilizando uma fonte de entradas ruins para gerar dados "
"aleatórios."

msgid "Your OpenSSL version is too old to support TLSv1.1\n"
msgstr "Versão do seu OpenSSL muito antiga para suportar TLSv1.1."

msgid "OpenSSL: Failed to allocate verification param\n"
msgstr "OpenSSL: Falha ao alocar parâmetro de verificação"

msgid "WARNING: Could not seed PRNG. Consider using --random-file.\n"
msgstr ""
"AVISO: não é possível sementear PRNG; considera o uso do parâmetro --random-"
"file.\n"

msgid "  Self-signed certificate encountered.\n"
msgstr "Encontrado um certificado autoassinado."

msgid "  Issued certificate has expired.\n"
msgstr "Para o certificado solicitado, o prazo de validade expirou."

msgid "To connect to %s insecurely, use `--no-check-certificate'.\n"
msgstr ""
"Para conexões não seguras com %s, utilize o parâmetro '--no-check-"
"certificate'."

msgid "Invalid dot style specification %s; leaving unchanged.\n"
msgstr ""
"A especificação dot-style '%s' é inválida; permanecerá sem alterações."

msgid "Invalid user name"
msgstr "Nome de usuário inválido"

msgid "Unconvertable multibyte sequence encountered\n"
msgstr ""
"Encontrada uma sequência de bytes não convertível para o padrão desejado."

msgid "%s: aprintf: text buffer is too big (%d bytes), aborting.\n"
msgstr "%s: aprintf: o buffer de texto é muito grande (%d bytes), parando. \n"

msgid "File %s changed since the last check. Security check failed.\n"
msgstr ""
"Após a última verificação, o arquivo %s sofreu alterações. Falha na "
"verificação de segurança."

msgid "Failed to stat file %s, error: %s\n"
msgstr "falha ao executar stat para o arquivo %s, erro: %s\n"

msgid "Invalid regular expression %s, PCRE2 error %d\n"
msgstr "Regra de expressão regular %s inválida, erro PCRE2 com número %d\n"

msgid "Invalid regular expression %s, %s\n"
msgstr "Não é permitido o uso do padrão de expressão regular %s, %s"

msgid "Error while matching %s: %d\n"
