msgid "%s: unable to resolve bind address %s; disabling bind.\n"
msgstr ""
"%s: não é possível resolver o endereço bind %s; a ligação do bind é "
"desligada. \n"

msgid "Connecting to %s:%d... "
msgstr "Conectando ao %s:%d... "

msgid "%s: unable to resolve host address %s\n"
msgstr "%s: não é possível resolver endereço %s"

msgid "Cannot convert links in %s: %s\n"
msgstr "Не може-se converter links em %s: %s\n"

msgid "Syntax error in Set-Cookie: %s at position %d.\n"
msgstr "Erro de sintaxe no Set-Cookie: %s na posição %d. \n"

msgid "Cannot open cookies file %s: %s\n"
msgstr "não é possível abrir o arquivo cookies %s: %s\n"

msgid "time unknown       "
msgstr "tempo desconhecido"

msgid "File        "
msgstr "Arquivo        "

msgid ", %s (%s) remaining"
msgstr ", %s (%s) restante."

msgid "Write failed, closing control connection.\n"
msgstr "Erro de escrita, conexão controladora encerrada."

msgid "The server refuses login.\n"
msgstr "O servidor recusou o login."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a comando PROT %c."

msgid "done.    "
msgstr "pronto."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não há tal diretório: %s."

msgid "Cannot parse PASV response.\n"
msgstr "falha na análise da resposta PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível estabelecer conexão com o %s no porto %d: %s"

msgid "Bind error (%s).\n"
msgstr "Erro de ligação (%s)."

msgid "Invalid PORT.\n"
msgstr "Não é permitido o PORT."

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro REST; iniciar novamente desde o início."

msgid "%s has sprung into existence.\n"
msgstr "%s se tornou realidade. (Emergeu na vida real.)"

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado novamente."

msgid "(try:%2d)"
msgstr "(tentativa:%2d)"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) — ghi vào đầu ra tiêu chuẩn %s[%s]"

msgid "Removing %s.\n"
msgstr "Удаляється %s."

msgid "Removed %s.\n"
msgstr "Удалён %s."

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr "Arquivo remoto do %s -- carregado."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Размеры не совпадають (локальный размер %s) -- загружается. \n"

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome inválido para uma referência simbólica; ignorado."

msgid "Skipping directory %s.\n"
msgstr "O catálogo %s foi ignorado."

msgid "Rejecting %s.\n"
msgstr "Từ chối %s."

msgid "Error matching %s against %s: %s\n"
msgstr "Lỗi khớp %s với %s: %s"

msgid "No matches on pattern %s.\n"
msgstr "Не encontramos correspondências com o padrão %s. \n"

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ОШИБКА: Erro ao abrir certificado %s: (%d).\n"

msgid "Loaded CRL file '%s'\n"
msgstr "CRL-ficheiro carregado \"%s\""

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr ""
"%s: Não foi possível identificar o editor de certificação %s. Por favor, "
"verifique novamente ou informe ao suporte técnico."

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr "%s: O certificado assinado por %s não foi encontrado no UC."

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro na inicialização do certificado X509: %s"

msgid "No certificate found\n"
msgstr "O certificado não foi encontrado."

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não está ativado."

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública aberta não corresponde à chave pública fixa!"

msgid "Error in handling the address list.\n"
msgstr ""
"Erro ao processar a lista de endereços. Lembre-se, se você encontrar "
"problemas com listas de endereços em seu sistema, procure ajuda "
"imediatamente."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr ""
"%s: não é possível reconhecer uma referência incompleta %s. Por favor, "
"verifique se a URL está correta e completa."

msgid "No headers, assuming HTTP/0.9"
msgstr "Os cabeçotes não estão presentes, é provável que seja HTTP/0.9."

msgid "Reusing existing connection to %s:%d.\n"
msgstr "Dùng lại kết nối đã có tới %s:%d."

msgid "%s ERROR %d: %s.\n"
msgstr "%s ERRO %d: %s. (Assuming 'ОШИБКА' translates to 'ERRO')"

msgid "Proxy tunneling failed: %s"
msgstr "Erro de túnelização do proxy: %s"

msgid "Saving to: %s\n"
msgstr "Salvar em: %s\n"

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar o arquivo temporário. O download da assinatura é "
"permitido."

msgid "%s request sent, awaiting response... "
msgstr "Yêu cầu %s enviado, aguardando resposta… "

msgid "No data received.\n"
msgstr "Не отримано никого, nem dados recebidos."

msgid "Read error (%s) in headers.\n"
msgstr "Lỗi đọc (%s) trong phần đầu."

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr " [переход]"

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr "Arquivo já carregado integralmente; não há mais ação necessária."

msgid "Length: "
msgstr "Kíntese: "

msgid "ignored"
msgstr "ignorado"

msgid "Cannot write to temporary WARC file.\n"
msgstr "Не foi possível gravar no arquivo temporário WARC."

msgid "Cannot unlink %s (%s).\n"
msgstr "Невозможно удалити %s (%s)."

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr "Заголовок last-modified — ідентифікацію temporalmente ignorada. \n"

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) — Đóng kết nối tại byte %s. "

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: Não é possível ler %s (%s)."

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr ""
"%s: Comando desconhecido %s na linha %<PRIuMAX> do arquivo %s. Por favor, "
"verifique se o comando está correto.\n"

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo de configuração do sistema wgetrc (env "
"SYSTEM_WGETRC). Tente verificar “%s”, ou especifique outro arquivo "
"utilizando --config.\n"

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Cãovoredo: Cả wgetrc do sistema e do usuário indicam ambos em %s. \n"

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Expressão lógica inválida; use 'on' ou 'off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr ""
"%s: %s: %s không hợp lệ; dùng “on” (bật), “off” (tắt) hay “quiet” (im lặng)."

msgid "%s: %s: Invalid number %s.\n"
msgstr ""
"%s: %s: Número %d inválido. (Somente números inteiros entre 0 e 9 inclusive)"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Chu kỳ thời gian âm %s. \n"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O conversor de %s para %s não é suportado"

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado de código %d"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; desligamento do registro. (logging is disabled)"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "CÓPIA DE UTILIZAR: %s [PARÂMETRO]... [URL] ..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas são também necessários para as"
" opções curtas."

msgid "Startup:\n"
msgstr "Khởi động:"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      mostrar esta ajuda."

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do processamento para retornar ao "
"modo de fundo."

msgid "Logging and input file:\n"
msgstr "Jornalização e ficheiro de entrada:\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=%s     adicionar mensagens ao final do arquivo %s\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "  -v,  --verbose                   hipertexto detalhado (padrão)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                      não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registros das razões para a rejeição de URL no "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir ЧИСЛО tentativas (0 = sem limite)\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    escrever documentos no FILE\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                  continuar a carregamento parcialmente de "
"um arquivo já em processo. \n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIPO            escolher tipo de indicador de execução."

msgid "  -S,  --server-response           print server response\n"
msgstr ""
"  -S,  --server-response         Resposta do servidor para solicitações de "
"usuário."

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEKUNDOS         configuração de todos os tempos limite "
"igual ao número SEKUNDOS. \n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr "--dns-timeout=СЕК         установка тайм-аута поиска в DNS в СЕК\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=СЕК  define o timeout de leitura em сек"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEKUNDAS             espera SEKUNDAS entre os downloads (para "
"mais de uma URL) \n"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                    Não utilize proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=ЧИСЛО             установить величину квоты загрузки в "
"ЧИСЛО\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED         limitar a SPEED de transferência para "
"baixar arquivos até este ponto."

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr ""
"chave -6, --inet6-only                conectar apenas a endereços IPv6."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                    desligue a suporte para IRI. \n"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"       --unlink                    remover arquivo antes de sobrescrever."

msgid "Directories:\n"
msgstr "Thư mục:\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=ПОЛЬЗОВ.        utilizador http no utilizador POLEZOVATEL"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "       --no-cache              ignorar dados cacheados do servidor\n"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=%s              inserir CHUỖI entre os cabeçotes. \n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          максимально допустимое число перенаправлений "
"на страницу\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLLE   utilizar PARORLE como senha para o proxy\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      carregar e salvar cookies de sessão (não "
"permanentes) \n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=СТРОКА      использовать метод POST; отправка СТРОКИ в "
"качестве данных\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   considerar o cabeçalho Content-Disposition\n"
"                               ao escolher nomes para arquivos locais (EXPERIMENTAL)\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       arquivo de certificado do usuário\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                   desligar HSTS\n"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS (substitui "
"o valor padrão)"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "--no-remove-listing         não remova listagens (.listing)"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp            desligue o modo 'passivo' de "
"transferência (usar modos ativos)"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                 Antes de gravar o arquivo X, fazer backup em N "
"cópias."

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X fazer uma cópia "
"de backup no formato X.orig.\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LISTA_DE_EXTENSÕES             lista de extensões proibidas,"
" separadas por vírgula."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "  -X,  --exclude-directories=СПИСОК список каталогов для exclusão\n"

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, programa para download de arquivos da internet em modo "
"autônomo. \n"

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr ""
"Erro de inicialização do objeto com ações para arquivos ao usar use-askpass:"
" %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "Erro ao ler a resposta da comando \"%s %s\": %s"

msgid "Locale: "
msgstr "Miền địa phương: "

msgid "    %s (env)\n"
msgstr "    %s (ambiente) \n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later\n"
"<http://www.gnu.org/licenses/gpl.html>.\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior. Este é software livre; você "
"pode modificá-lo e distribuí-lo além do que o direito autoral permite, "
"conforme a lei."

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações sobre os parâmetros adicionais, tente executar a"
" comando ' %s --help'."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"Указаны сразу --no-clobber и --convert-file-only, будет использоваться "
"только --convert-file-only."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Немогла-se indicar iguais --inet4-only e --inet6-only simultaneamente."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Нельзя указать одновременно -k или --convert-file-only і -O, если указано "
"множество URL, або в комбінації з параметрами -p або -r. Подробности см. в "
"документации. \n"

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"PRELUDE PARA O PROCESSAMENTO DE MARKDOWN NO GNOME TERMINAL NESTE "
"BRAZILIANO\n"

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com o parâmetro --no-clobber, este parâmetro será "
"desligado."

msgid "WARC output does not work with --spider.\n"
msgstr "Saída WARC não funciona com o --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"Saída da WARC não funciona com --continue ou --start-pos; elas serão "
"desligadas."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório de desligamento; a deduplicação WARC não encontrará registros "
"duplicados."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Немоглаbilidade de utilizar simultaneamente as opções --ask-password e "
"--password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"PRELUDE PARA AVERIGUIDAÇÃO DE ERROS FÍTONICAS: Não foi especificado o nome "
"de usuário, mas há a opção --ask-password. Isso geralmente não é necessário."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"O parâmetro '-k' ou '-r' pode ser utilizado apenas em conjunto com o "
"parâmetro '-O', se a saída for para um arquivo normal."

msgid "Failed to init c-ares channel\n"
msgstr "Erro ao inicializar o canal c-ares"

msgid "Unable to parse metalink file %s.\n"
msgstr "Не foi possível processar o arquivo metalink %s."

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Отбраковываем файл metalink. Тенденência à insegurança do nome."

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr ""
"Отбраковываем файл metaurl %s. Небезопасное имя. (Отбравок файлу метаurl %s,"
" поскольку имя небезопасным)"

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro ao baixar %s. Metaurl será ignorado."

msgid "Metaurls processing returned with error.\n"
msgstr "Processamento de metaurols retornou erro."

msgid "Could not open downloaded file.\n"
msgstr "Не foi possível abrir o arquivo baixado."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "GPGME data_new_from_mem: %s\n"

msgid "GPGME op_verify: %s\n"
msgstr "GPGME op_verificar: %s"

msgid "No checksums found.\n"
msgstr "Conjuntos de controle não encontrados."

msgid "File %s retrieved but signature does not match. \n"
msgstr "Arquivo %s foi recebido, mas a assinatura não corresponde. \n"

msgid "Continuing in background.\n"
msgstr "Работа continua no modo de fundo."

msgid "%s: %s:%d: warning: %s token appears before any machine name\n"
msgstr "%s: %s:%d: cảnh báo: hiệu bài %s xuất hiện trước bất kỳ tên máy nào\n"

msgid "WARNING: using a weak random seed.\n"
msgstr "PRECEDENTE: utiliza um fonte de dados aleatórios enfraquecida. \n"

msgid "Your OpenSSL version is too old to support TLSv1.1\n"
msgstr "Phiên bản OpenSSL của bạn quá cũ để hỗ trợ TLSv1.1\n"

msgid "OpenSSL: Failed to allocate verification param\n"
msgstr "OpenSSL: Não foi possível alocar o parâmetro de verificação"

msgid "WARNING: Could not seed PRNG. Consider using --random-file.\n"
msgstr ""
"PRELUDE PARA O PROCESSO DE SEGURANÇA DOS SISTEMAS CRITICAS E NÃO INSTALADOS "
"NO SOFTWARE PRIMARIAMENTE (PCI): não é possível gerar um número aleatório de"
" acordo com o algoritmo do Generador Aleatório Pré-Estabelecido; considera a"
" utilização do parâmetro --random-file. \n"

msgid "  Self-signed certificate encountered.\n"
msgstr "Foi encontrado um certificado autofiscalizado."

msgid "  Issued certificate has expired.\n"
msgstr "Para o certificado solicitado, expirou seu prazo de validade."

msgid "To connect to %s insecurely, use `--no-check-certificate'.\n"
msgstr ""
"Для conexão não segura com %s, utilize o parâmetro '--no-check-"
"certificate'.\n"

msgid "Invalid dot style specification %s; leaving unchanged.\n"
msgstr "Não é permitida a especificação dot-style \"%s\", mantida sem alterações."

msgid "Invalid user name"
msgstr "Nome de usuário inválido"

msgid "Unconvertable multibyte sequence encountered\n"
msgstr "Обнаружено необработованной многобайтовой последовательности"

msgid "%s: aprintf: text buffer is too big (%d bytes), aborting.\n"
msgstr "%s: aprintf: buffer de texto muito grande (%d byte), interrompido."

msgid "File %s changed since the last check. Security check failed.\n"
msgstr ""
"Desde a última verificação, o arquivo %s sofreu alterações. A tentativa de "
"verificar segurança falhou."

msgid "Failed to stat file %s, error: %s\n"
msgstr ""
"Erro ao executar o comando 'stat' para acesso de estatísticas do arquivo "
"'%s', erro: %s\n"

msgid "Invalid regular expression %s, PCRE2 error %d\n"
msgstr "Недопустимое регулярное выражение %s, ошибка PCRE2 %d\n"

msgid "Invalid regular expression %s, %s\n"
msgstr "Недопустимое регулярное выражение %s, %s\n"

msgid "Error while matching %s: %d\n"
msgstr "Erro ao comparar %s com valor %d\n"

msgid "Error setting WARC file position.\n"
msgstr "Erro ao mover o arquivo WARC."

msgid "Error opening GZIP stream to WARC file.\n"
msgstr "Erro ao abrir fluxo GZIP para arquivo WARC."

msgid "Error writing warcinfo record to WARC file.\n"
msgstr "Erro ao salvar a carga de warcinfo no arquivo WARC."

msgid "CDX file does not list original urls. (Missing column 'a'.)\n"
msgstr "O arquivo CDX não contém URLs originais (a coluna 'a' está ausente)."

msgid "CDX file does not list checksums. (Missing column 'k'.)\n"
msgstr "Arquivo CDX não contém checksums (falta coluna 'k')."

msgid "Could not open temporary WARC log file.\n"
msgstr "Не foi possível abrir o arquivo de log WARC temporário."

msgid "Could not open CDX file for output.\n"
msgstr "Não é possível abrir o arquivo CDX para gravação de resultado."
