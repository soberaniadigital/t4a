"Content-Transfer-Encoding: 8bit\n"

msgid "%s: unable to resolve bind address %s; disabling bind.\n"
msgstr "O arquivo '%s' não pode ser aberto; o acesso é negado."

msgid "Connecting to %s:%d... "
msgstr "Conexão ao soquete %s:%d... "

msgid "%s: unable to resolve host address %s\n"
msgstr "falha ao resolver endereço %s\n"

msgid "Cannot convert links in %s: %s\n"
msgstr "Não é possível converter as referências para %s: %s"

msgid "Syntax error in Set-Cookie: %s at position %d.\n"
msgstr "Erro de sintaxe no cookie Set: %s na posição %d.\n"

msgid "Cannot open cookies file %s: %s\n"
msgstr "não foi possível abrir o arquivo cookies %s: %s"

msgid "time unknown       "
msgstr "o tempo é desconhecido."

msgid "File        "
msgstr "Arquivo        "

msgid ", %s (%s) remaining"
msgstr "O arquivo (%s) restante é %s."

msgid "Write failed, closing control connection.\n"
msgstr "Erro de escrita, conexão gerenciada encerrada. \n"

msgid "The server refuses login.\n"
msgstr "O login foi negado pelo servidor."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a comando PROT %c."

msgid "done.    "
msgstr "pronto."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"contador de diretórios ativos: %d\n"
"contador de entrada do diretório: %d\n"
"contador de saída do diretório: %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não existe tal diretório: %s."

msgid "Cannot parse PASV response.\n"
msgstr "Erro de análise da resposta PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível conectar ao %s porta %d: %s"

msgid "Bind error (%s).\n"
msgstr "Erro bind (%s)."

msgid "Invalid PORT.\n"
msgstr "Porto inválido"

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro REST, iniciando o serviço."

msgid "%s has sprung into existence.\n"
msgstr "%s se tornou realidade."

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado."

msgid "(try:%2d)"
msgstr "tentativa:%2d"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) - registro em stdout [%d]"

msgid "Removing %s.\n"
msgstr "O arquivo %s foi excluído."

msgid "Removed %s.\n"
msgstr "O arquivo '%s' não foi encontrado."

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr "Arquivo remoto do novo arquivo local %s - carregado."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Os tamanhos não são idênticos (tamanho local %s) — é carregada. \n"

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome inválido para a referência simbólica, ignorado."

msgid "Skipping directory %s.\n"
msgstr "O diretório %s foi ignorado."

msgid "Rejecting %s.\n"
msgstr "A solicitação %s foi negada."

msgid "Error matching %s against %s: %s\n"
msgstr "falha na correspondência de %s com %s: %s\n"

msgid "No matches on pattern %s.\n"
msgstr "Não há correspondências com o padrão %s."

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ERRO DE ACESSO À CERTIFICAÇÃO: Erro ao abrir o certificado %s (%d).\n"

msgid "Loaded CRL file '%s'\n"
msgstr "CRL-ficheiro carregado: \"%s\""

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr "%s: Editor de certificado desconhecido do %s. \n"

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr "%s: Certificado de assinatura %s não encontrado no UC."

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro de inicialização do certificado X509: %s\n"

msgid "No certificate found\n"
msgstr "Certificado não encontrado."

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não está ativado."

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública aberta não corresponde à chave privada associada!"

msgid "Error in handling the address list.\n"
msgstr "Erro ao processar a lista de endereços."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr ""
"O arquivo '%s': não é possível reconhecer uma referência incompleta. "
"'Arquivo' preserva as variáveis e adota o formalismo técnico necessário."

msgid "No headers, assuming HTTP/0.9"
msgstr "Os cabeçalhos estão ausentes, HTTP/0.9 implica"

msgid "Reusing existing connection to %s:%d.\n"
msgstr "uso repetido do soquete com %s:%d."

msgid "%s ERROR %d: %s.\n"
msgstr "%s ERRO %d: %s. \n"

msgid "Proxy tunneling failed: %s"
msgstr "Erro de túnel do proxy: %s"

msgid "Saving to: %s\n"
msgstr "Salvar no: %s"

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar um arquivo temporário. O download da assinatura é "
"permitido."

msgid "%s request sent, awaiting response... "
msgstr "%s solicitação enviada. Esperando resposta… "

msgid "No data received.\n"
msgstr "Não foram encontrados dados."

msgid "Read error (%s) in headers.\n"
msgstr "Erro de leitura (%s) nos cabeçalhos."

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr "avançar para a próxima etapa"

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr "Arquivo já totalmente carregado; não há ação necessária."

msgid "Length: "
msgstr "Comprimento: "

msgid "ignored"
msgstr "opção ignorada"

msgid "Cannot write to temporary WARC file.\n"
msgstr "Não é possível escrever no arquivo temporário WARC."

msgid "Cannot unlink %s (%s).\n"
msgstr "Não é possível excluir %s (%s)."

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr ""
"Não é permitido o título 'last-modified'. Os marcadores temporais são "
"ignorados."

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) - Conexão fechada, posição %s. "

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: não é possível ler o arquivo %s (%d).\n"

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %<PRIuMAX>%d. \n"

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro de processamento do arquivo wgetrc (env SYSTEM_WGETRC). Verifique '\\"

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"Opcionais de %s e wgetrc do sistema/do usuário indicam que o arquivo está em"
" uso. Para obter mais informações, tente 'wget --help'."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Expressão lógica inválida; use 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: Erro; use 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr ""
"%s: %s: Número inválido. Por favor, verifique seu input e tente novamente."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: O intervalo de tempo é negativo\n"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O conversor de %s para %s não é suportado."

msgid "Unhandled errno %d\n"
msgstr "Erro de código não tratado %d\n"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: a opção %s foi desabilitada. (Desligamento do registro.)\n"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL]...\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para parâmetros longos são obrigatórios e para os"
" curtos também. Para mais informações, tente 'comando --help'."

msgid "Startup:\n"
msgstr "Iniciando o processo...\n"

msgid "  -h,  --help                      print this help\n"
msgstr "-h, --help              Mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr "-b --background, após o término do programa, vá para o modo de fundo."

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada:\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"--append-output=arquivo\n"
"deletar mensagens no final do arquivo"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "-v, --verbose Mostrar informações detalhadas (padrão)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=UNITO    unidades de medida da velocidade do sinal\n"
"                             determinar UNIDADEM. A unidade pode ser igual a bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
" -i, --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config           não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registros das razões para o rejeito de URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento em progresso."

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"--tries=ЧИСЛО             definir QUANTIDADE de tentativas (0 sem limite)\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr ""
" -O, --output-document=FILE\n"
"    Escrever documentos no FILE."

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"--continue --continuação\n"
"                        Continue a carregar parcialmente um arquivo que já foi carregado em partes."

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr "--progress=TIP\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "--server-response         resposta do servidor\n"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"--timeout=SEGUNDOS         configuração de todos os tempos limites igual ao "
"número SEGUNDO\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"--dns-timeout=SEC instalação do timeout de pesquisa DNS em segundos (SEC)"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=SEC instalação do timeout de leitura em SEC\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"--wait=SEGUNDOS            pausa em segundos entre as chamadas\n"
"                 (quando carregar mais de um URL)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                explicitamente desligue o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"--quota=ЧИСЛО             -Q,  --quota=ЧИСЛО             установить величину"
" квоты загрузки в ЧИСЛО"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr "--limit-rate=LIMITE_RATE     limitar a velocidade de carga"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--ipv6 apenas\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "--no-iri                  desligar suporte ao IRI\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                     remover arquivo antes de apagar\n"

msgid "Directories:\n"
msgstr "Categorias:\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "--http-user=USUÁRIO HTTP\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "--sem-cache             ignorar dados armazenados no servidor\n"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr ""
"--header=%s\n"
"de inserir uma linha entre os cabeçalhos."

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"--max-redirect          máximo permitido de redirecionamentos para a página\n"
"                               na paginação da URL."

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"--proxy-password=PROXÍA\n"
"                   definir PROXÍA como a senha para o proxy."

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr "--keep-session-cookies (permanentes)\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"--post-data=STRINGA utilizar método POST; envio de STRINGA como dados."

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"--content-disposition   considerar o cabeçalho Content-Disposition ao "
"escolher os nomes para arquivos locais (Exemplificativo)"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "--certificado=ARQUIVO\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--no-hsts             desligar HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"--hsts-file             caminho para a base de dados HSTS (substitui o valor"
" padrão)"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr ""
"--não-remover-listação     não remover arquivos com extensão 'listing'"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"--no-passive-ftp\n"
"Desligue o modo 'passivo' do FTP."

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                   antes de escrever o arquivo X, fazer backup em N\n"
"        rotação dos backups"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
" -K, --backup-converted antes de converter o arquivo X fazer uma cópia de "
"segurança no formato X.orig."

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr "--rejeição=LISTA_DE_EXTENSÕES, separadas por vírgula. \n"

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "  -X,  --exclude-directories=СПИСОК список исключаемых каталогов\n"

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, programa para download de arquivos da internet em modo "
"autônomo."

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr ""
"Erro de inicialização do objeto ação de arquivo durante o spawn para use-"
"askpass: %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "Erro de leitura da resposta para a comando \"%s %s\": %s"

msgid "Locale: "
msgstr "Localização: "

msgid "    %s (env)\n"
msgstr "%s (ambiente)"

msgid ""
"License GPLv3+: GNU GPL version 3 or later\n"
"<http://www.gnu.org/licenses/gpl.html>.\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou superior. Este é software livre que pode"
" ser modificado e distribuído sem limitações, dentro das restrições da lei."

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter informações adicionais, digite a comando '\\u00ab %s --help "
"\\u00bb'."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"São especificados imediatamente --no-clobber e --convert-file-only, será "
"utilizado apenas o --convert-file-only."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr "Não é possível especificar e --inet4-only, e --inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é permitido especificar simultaneamente -k ou --convert-file-only e -O, "
"se forem indicados vários URLs, ou em combinação com parâmetros -p ou -r. "
"Detalhes estão disponíveis na documentação."

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"PRECARDAÇÃO DO PROCESSAMENTO DE MARKERS DE TIMESTAMPS NÂO É POSSÍVEL, SE "
"HAVER PARAMETRO -O. DETALHAMENTE CONTEMPLEMOS O RESOLUVO NO MANUELO."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com o parâmetro --no-clobber, esse parâmetro será"
" desabilitado."

msgid "WARC output does not work with --spider.\n"
msgstr "O output WARC não funciona com o --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com --continue ou --start-pos; eles serão "
"desabilitados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório de desligamento; a duplicação WARC não encontrará registros "
"repetidos."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente --ask-password e --password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"PRECARDAÇÃO: não foi especificado o nome do usuário, mas há a opção --ask-"
"password. Normalmente, isso não é necessário."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"O parâmetro '-k' ou '-r' pode ser utilizado somente em conjunto com o "
"parâmetro '-O', se a saída for produzida em um arquivo normal. \n"

msgid "Failed to init c-ares channel\n"
msgstr "Erro de inicialização do canal c-ares"

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Ocultando o arquivo metalink. Nome de entrada inseguro."

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr "Ocultando o arquivo metaurl %s. Nome inseguro."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro de download do arquivo %s. Ignoramos metaurl."

msgid "Metaurls processing returned with error.\n"
msgstr "A análise do metaupload retornou um erro."

msgid "Could not open downloaded file.\n"
msgstr "Não foi possível abrir o arquivo baixado."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "data_new_from_mem: %s\n"

msgid "GPGME op_verify: %s\n"
msgstr "op_verificar do GPGME: %s"

msgid "No checksums found.\n"
msgstr "As contas de caixa não foram encontradas."

msgid "File %s retrieved but signature does not match. \n"
msgstr "Arquivo '%s' recebido, mas a assinatura não corresponde."

msgid "Continuing in background.\n"
msgstr "Através do comando 'screen', a execução continua em segundo plano."

msgid "%s: %s:%d: warning: %s token appears before any machine name\n"
msgstr "%s: %s:%d: aviso prévio de cada veículo com o marcador %s"

msgid "WARNING: using a weak random seed.\n"
msgstr "PRECARDAÇÃO DE DADOS: utiliza-se um fonte de dados aleatórios ruim."

msgid "Your OpenSSL version is too old to support TLSv1.1\n"
msgstr ""
"A versão do OpenSSL que você está utilizando é muito antiga para suportar "
"TLSv1.1."

msgid "OpenSSL: Failed to allocate verification param\n"
msgstr "OpenSSL: Não foi possível alocar o parâmetro de verificação\n"

msgid "WARNING: Could not seed PRNG. Consider using --random-file.\n"
msgstr ""
"PRELUDE PARA O TESTE DE RANCIDO DOS SEEDS DA PRNG; É CONSIDERADO O USEMDOREI"
" DO PARAMETRO --random-file."

msgid "  Self-signed certificate encountered.\n"
msgstr "O certificado assinado automaticamente foi encontrado."

msgid "  Issued certificate has expired.\n"
msgstr "Para o certificado solicitado, expirou o prazo de validade."

msgid "To connect to %s insecurely, use `--no-check-certificate'.\n"
msgstr ""
"Para conexões não seguras ao %s, utilize o parâmetro '--no-check-"
"certificate'."

msgid "Invalid dot style specification %s; leaving unchanged.\n"
msgstr ""
"A especificação do estilo dot '%s' é inválida; permanecer sem alterações."

msgid "Invalid user name"
msgstr "Nome de usuário inválido"

msgid "Unconvertable multibyte sequence encountered\n"
msgstr "Uma sequência multibyte não convertível foi encontrada."

msgid "%s: aprintf: text buffer is too big (%d bytes), aborting.\n"
msgstr "%s: aprintf: o buffer de texto é muito grande (%d bytes), parada. \n"

msgid "File %s changed since the last check. Security check failed.\n"
msgstr ""
"Desde a última verificação, o arquivo %s foi alterado. Erro na verificação "
"de segurança.\n"

msgid "Failed to stat file %s, error: %s\n"
msgstr "Erro ao executar o comando stat para arquivo %s, erro: %s\n"

msgid "Invalid regular expression %s, PCRE2 error %d\n"
msgstr "Referência regular inválida %s, erro PCRE2 %d\n"

msgid "Invalid regular expression %s, %s\n"
msgstr "Regular expression '%s' is not allowed. Please use a valid pattern."

msgid "Error while matching %s: %d\n"
msgstr "Erro ao comparar %s com valor %d\n"

msgid "Error setting WARC file position.\n"
msgstr "Erro ao mover arquivo WARC."

msgid "Error opening GZIP stream to WARC file.\n"
msgstr "Erro ao abrir fluxo GZIP no arquivo WARC."

msgid "Error writing warcinfo record to WARC file.\n"
msgstr "Erro ao salvar a informação WARC.info no arquivo WARC."

msgid "CDX file does not list original urls. (Missing column 'a'.)\n"
msgstr "O arquivo CDX não contém URLs originais (ausente coluna 'a')."

msgid "CDX file does not list checksums. (Missing column 'k'.)\n"
msgstr "O arquivo CDX não contém checksums (falta coluna 'k')."

msgid "Could not open temporary WARC log file.\n"
msgstr "Não é possível abrir o arquivo temporário de log WARC."

msgid "Could not open CDX file for output.\n"
msgstr "Não é possível abrir o arquivo CDX para gravação dos resultados."
