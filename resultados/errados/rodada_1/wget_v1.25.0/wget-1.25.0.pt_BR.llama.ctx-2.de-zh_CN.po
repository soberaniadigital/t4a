msgid "%s: unable to resolve bind address %s; disabling bind.\n"
msgstr ""
"%s: não é possível resolver o endereço bind %s; a ligação será desabilitada."
" (OBS.: O termo 'bind' permanece em inglês para manter consistência com as "
"traduções anteriores.)"

msgid "Connecting to %s:%d... "
msgstr "Conexão em andamento para %s:%d... "

msgid "%s: unable to resolve host address %s\n"
msgstr "%s: não é possível resolver endereço %s"

msgid "Cannot convert links in %s: %s\n"
msgstr "Не foi possível converter as referências para %s: %s"

msgid "Syntax error in Set-Cookie: %s at position %d.\n"
msgstr "Erro de sintaxe no Set-Cookie: %s na posição %d. \n"

msgid "Cannot open cookies file %s: %s\n"
msgstr "não é possível abrir o arquivo cookies %s: %s\n"

msgid "time unknown       "
msgstr "tempo desconhecido"

msgid "File        "
msgstr "Arquivo       "

msgid ", %s (%s) remaining"
msgstr ", %s (%s) restante."

msgid "Write failed, closing control connection.\n"
msgstr "Erro ao escrever, conexão de controle foi encerrada."

msgid "The server refuses login.\n"
msgstr "O servidor recusou a entrada do usuário."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a comando 'PROT %c'."

msgid "done.    "
msgstr "Ftg."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não existe tal diretório: %s."

msgid "Cannot parse PASV response.\n"
msgstr "Erro ao analisar a resposta PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível estabelecer conexão com o %s no porto %d: %s"

msgid "Bind error (%s).\n"
msgstr "Erro de vinculação (%s)."

msgid "Invalid PORT.\n"
msgstr "Índice de Port Inválido."

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro de REST; o processo será reiniciado desde o início."

msgid "%s has sprung into existence.\n"
msgstr "%s se rompeu para a realidade. \n"

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado novamente."

msgid "(try:%2d)"
msgstr "(Tentativa:%2d)"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) - escrito na saída padrão [%s/%s]"

msgid "Removing %s.\n"
msgstr "O arquivo %s será excluído."

msgid "Removed %s.\n"
msgstr "O arquivo %s foi excluído."

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr ""
"Arquivo remoto do %s é mais recente que o arquivo local, -- Download em "
"andamento."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Os tamanhos não são os mesmos (tamanho local %s) -- novo download."

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome inválido para um link simbólico; ignorado."

msgid "Skipping directory %s.\n"
msgstr "O diretório %s foi pulado."

msgid "Rejecting %s.\n"
msgstr "O comando '%s' foi rejeitado."

msgid "Error matching %s against %s: %s\n"
msgstr "Erro ao comparar %s com %s: %s"

msgid "No matches on pattern %s.\n"
msgstr "Não há correspondências com o padrão %s."

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ОШИБКА: Erro ao abrir certificado %s: (%d)."

msgid "Loaded CRL file '%s'\n"
msgstr "CRL-arquivo 'DE' foi carregado"

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr "%s: O certificador do segredo %s é desconhecido."

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr ""
"%s: O certificado assinado por %s não possui uma Autoridade Certificadora "
"(CA).\n"

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro de inicialização do certificado X509: %s"

msgid "No certificate found\n"
msgstr "Certificado não encontrado."

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não está ativado."

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública aberta não corresponde à chave pública encaixada!"

msgid "Error in handling the address list.\n"
msgstr "Erro na processamento da lista de endereços."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr "%s: não é possível resolver uma referência parcialmente inválida %s."

msgid "No headers, assuming HTTP/0.9"
msgstr "Os cabeçotes estão ausentes, provavelmente é HTTP/0.9."

msgid "Reusing existing connection to %s:%d.\n"
msgstr "uso repetido da conexão existente com %s:%d."

msgid "%s ERROR %d: %s.\n"
msgstr "%s ERRO %d: %s. (Russian)"

msgid "Proxy tunneling failed: %s"
msgstr "Erro de túnelização do proxy: %s"

msgid "Saving to: %s\n"
msgstr "Será salvo no: %s\n"

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar o arquivo temporário. O download da assinatura é "
"ignorado."

msgid "%s request sent, awaiting response... "
msgstr "%s-pedido enviado. Esperando resposta... "

msgid "No data received.\n"
msgstr "Não foram recebidos dados."

msgid "Read error (%s) in headers.\n"
msgstr "Erro de leitura (%s) nos cabeçalhos."

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr " [seguir]"

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr "Arquivo já carregado integralmente; não há ação necessária."

msgid "Length: "
msgstr "Comprimento:"

msgid "ignored"
msgstr "ignorado"

msgid "Cannot write to temporary WARC file.\n"
msgstr "Não é possível escrever no arquivo temporário WARC."

msgid "Cannot unlink %s (%s).\n"
msgstr "Не foi possível remover %s (%s)."

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr ""
"Заголовок last-modified inválido -- temporariamente ignorado. Variaveis "
"mantidas em seu formato original."

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) - Conectar fechado, posição %s. "

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: não é possível ler %s (%s)."

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %d da fonte %s."

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo wgetrc do sistema (env SYSTEM_WGETRC). Por "
"favor, verifique '`%s`' ou especifique outro arquivo com a opção `--config'."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Aviso: os arquivos wgetrc do sistema e do usuário indicam %s. Por favor,"
" revise as configurações para evitar confusão."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Expressão lógica inválida %s; por favor, use 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr ""
"%s: %s: O valor do campo '%s' é inválido; utilize 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. Por favor, verifique novamente."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão de %s para %s não é suportada."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado de código %d"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O output é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; Protokollierung wird ausgeschaltet."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL] ..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas permanecem necessários mesmo "
"para as opções curtas."

msgid "Startup:\n"
msgstr "Beim Start:"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para entrar no modo de"
" fundo."

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada: \n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=FILE\n"
"dedepurar mensagens na extremidade do FILE."

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
"  -v,  --verbose                   mostrar informações detalhadas (padrão)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=UNIDADES_METRICAS    Unidades de medida para a velocidade do sinal. Tipo pode ser bits\n"
"                             determinar o tipo.\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                 nenhum arquivo de configuração utilizado"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registros das razões para a rejeição da URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             establecer NÚMERO de tentativas repetidas "
"(0 para sem limite) \n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O, --output-document=FILE    escrever documentos no FILE\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                   Continuar o download de um arquivo "
"parcialmente baixado\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIP            Escolher tipo de indicador de progresso"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response           Resposta do Servidor exibir"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         definir todos os timeouts como segundos\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr "--dns-timeout=SEK         установка тайм-аута поиска в DNS SEК"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=СЕК"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEGUNDAS             espera de SEGUNDAS segundos entre as transferências\n"
"                                 (para mais de uma URL para download)\n"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                   Não use proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr "  -Q,  --quota=CÓMO_SE_ESCREVE_NO_BRAZILILEO\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED           limitar a velocidade de download para "
"SPEED\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only              conectar apenas a adresses IPv6\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                     Desligue a suporte para IRI\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                    Apagar arquivo antes de sobrescrever\n"

msgid "Directories:\n"
msgstr "Verzeichnisse:"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=POLIZOVATEL\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"       --no-cache              ignorar dados armazenados em cache pelo "
"servidor\n"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=STRINGA inserir STRINGA entre cabeçalhos"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"--max-redirect          максимально допустимое число перенаправлений\n"
"                               на страницу\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLH   utilizar PAROLH como a senha para o proxy\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      (não permanentes) Cookies de sessão\n"
"                                      carregar e salvar."

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING    utilizar método POST; envio de STRING como "
"dados. \n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   принимати conteúdo-dissposta header ao "
"escolher nomes para arquivos locais (EXPERIMENTAL)\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE        Arquivo com certificado do usuário\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts               Desabilitar HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS (substitui "
"o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "--no-remove-listing         '.listing' não será removido."

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp        desligue o modo \"paciente\" de transferência"
" FTP\n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                   antes de gravar o arquivo X, fazer backup até "
"N vezes\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
" -K, --backup-converted   antes de converter o arquivo X fazer uma cópia de "
"segurança no formato X.orig."

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LISTA\n"
"                    lista de extensões a serem ignoradas, separadas por vírgula."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclude-directories=%s\n"

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, programa para download de arquivos da internet em modo "
"automático. \n"

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr "Erro de inicialização do objeto ação para use-askpass: %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "Erro ao ler a resposta do comando \"%s %s\": %s"

msgid "Locale: "
msgstr "Lokale: "

msgid "    %s (env)\n"
msgstr "    %s (ambiente) \n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later\n"
"<http://www.gnu.org/licenses/gpl.html>.\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior\n"
"<http://www.gnu.org/licenses/gpl.html>\n"
"Este é software livre; você pode modificá-lo e distribuí-lo além do que o direito autoral permite.\n"
"Nenhuma garantia será fornecida, exceto aquelas expressamente declaradas em esta licença ou no acordo de transferência."

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações sobre os parâmetros adicionais, tente executar a"
" comando '%%s --help'."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"São indicados imediatamente --no-clobber e --convert-file-only, será "
"utilizado apenas o último."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar simultaneamente as opções --inet4-only e "
"--inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Нельзя указать одновременно -k или --convert-file-only і -O, если указано "
"невелико число URL, або в комбінації з параметрами -p або -r. Подробності "
"можна визначити в документації. \n"

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"AVISO: trabalhar com marcações de tempo não é possível quando o parâmetro -O"
" for especificado. Para mais informações, consulte o manual."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com o parâmetro '--no-clobber', esse parâmetro será "
"desabilitado."

msgid "WARC output does not work with --spider.\n"
msgstr "Saída WARC não funciona com --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com --continue ou --start-pos; essas opções serão "
"desabilitadas."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório de desligamento; a deduplicação WARC não encontrará registros "
"duplicados. \n"

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente as opções --ask-password e "
"--password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"AVISO: Nome de usuário não especificado, mas --ask-password utilizado. Isso "
"geralmente não é o que se deve."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"O parâmetro '-k' ou '-r' pode ser utilizado somente em conjunto com o -O, se"
" a saída for para um arquivo normal."

msgid "Failed to init c-ares channel\n"
msgstr "Erro durante a inicialização do canal c-ares"

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr ""
"Ao tentar ler a 'metalink.txt', o sistema detecta um nome de arquivo "
"inseguro e, portanto, não permite seu uso."

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr "Ocultamos o arquivo metaurl %s. Nome inseguro."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Ocorreu uma falha ao baixar %s. Metaurl será ignorado."

msgid "Metaurls processing returned with error.\n"
msgstr "Processamento de metaurol retornou erro."

msgid "Could not open downloaded file.\n"
msgstr "Não foi possível abrir o arquivo baixado."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "GPGME data_new_from_mem: %s\n"

msgid "GPGME op_verify: %s\n"
msgstr "GPGME op_verificar: %s"

msgid "No checksums found.\n"
msgstr "As contas de verificação não foram encontradas."

msgid "File %s retrieved but signature does not match. \n"
msgstr "Arquivo %s foi recebido, mas a assinatura não corresponde."

msgid "Continuing in background.\n"
msgstr "Através do trabalho continua em segundo plano."

msgid "%s: %s:%d: warning: %s token appears before any machine name\n"
msgstr "%s: %s:%d: Aviso: o termo '%s' aparece antes de cada nome da máquina\n"

msgid "WARNING: using a weak random seed.\n"
msgstr ""
"AVISO: utiliza um fonte de dados aleatórios fraca. Por favor, atualize para "
"uma semente mais forte."

msgid "Your OpenSSL version is too old to support TLSv1.1\n"
msgstr ""
"Você está utilizando uma versão muito antiga do OpenSSL que não suporta o "
"TLSv1.1."

msgid "OpenSSL: Failed to allocate verification param\n"
msgstr "OpenSSL: Não foi possível alocar o parâmetro de verificação\n"

msgid "WARNING: Could not seed PRNG. Consider using --random-file.\n"
msgstr ""
"PRELUDE PARA O PROCESSAMENTO DE DADOS:\n"
"\n"
"AVISO: Não foi possível inicializar o gerador de números aleatórios (PRNG); considere utilizar a opção --random-file.\n"

msgid "  Self-signed certificate encountered.\n"
msgstr "Foi encontrado um certificado autoassinado."

msgid "  Issued certificate has expired.\n"
msgstr "Para o certificado solicitado, expirou seu prazo de validade."

msgid "To connect to %s insecurely, use `--no-check-certificate'.\n"
msgstr ""
"Para conexões não seguras com o servidor %s, utilize o parâmetro '--no-"
"check-certificate'."

msgid "Invalid dot style specification %s; leaving unchanged.\n"
msgstr ""
"Spesficificação inválida do estilo dot para o indicador de progresso %s; sem"
" alterações."

msgid "Invalid user name"
msgstr "Nome de usuário inválido"

msgid "Unconvertable multibyte sequence encountered\n"
msgstr "Обнаружено непереводимаюма multi-byte последовательність"

msgid "%s: aprintf: text buffer is too big (%d bytes), aborting.\n"
msgstr "%s: aprintf: O buffer de texto é muito grande (%d bytes), parada. \n"

msgid "File %s changed since the last check. Security check failed.\n"
msgstr ""
"Após a última verificação, o arquivo %s sofreu alterações. A tentativa de "
"verificar segurança falhou."

msgid "Failed to stat file %s, error: %s\n"
msgstr "Erro ao executar 'stat' no arquivo %s. Erro: %s\n"

msgid "Invalid regular expression %s, PCRE2 error %d\n"
msgstr "Regular expression '%s' is invalid, PCRE2 error %d\n"

msgid "Invalid regular expression %s, %s\n"
msgstr "Não é permitido o uso do regular expressivo %s, %s\n"

msgid "Error while matching %s: %d\n"
msgstr "Erro ao comparar %s com valor %d\n"

msgid "Error setting WARC file position.\n"
msgstr "Erro ao mover a posição da WARC. arquivo."

msgid "Error opening GZIP stream to WARC file.\n"
