msgid "%s: unable to resolve bind address %s; disabling bind.\n"
msgstr "%s: não é possível resolver o endereço bind %s; desativando bind."

msgid "Connecting to %s:%d... "
msgstr "Conectando ao %s:%d... "

msgid "%s: unable to resolve host address %s\n"
msgstr "%s: não é possível resolver o endereço %s"

msgid "Cannot convert links in %s: %s\n"
msgstr "Не foi possível converter as links em %s: %s\n"

msgid "Syntax error in Set-Cookie: %s at position %d.\n"
msgstr "Erro de sintaxe no Set-Cookie: %s na posição %d."

msgid "Cannot open cookies file %s: %s\n"
msgstr "não é possível abrir o arquivo cookies %s: %s\n"

msgid "time unknown       "
msgstr "o horário é desconhecido   "

msgid "File        "
msgstr "Arquivo        "

msgid ", %s (%s) remaining"
msgstr ", %s (%s) restante."

msgid "Write failed, closing control connection.\n"
msgstr "Erro de escrita, conexão gerenciada encerrando."

msgid "The server refuses login.\n"
msgstr "O servidor negou o acesso ao login."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a comando 'PROT %c'."

msgid "done.    "
msgstr "pronto."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não existe tal diretório: %s."

msgid "Cannot parse PASV response.\n"
msgstr "Erro de análise do comando PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível se conectar ao %s porta %d: %s"

msgid "Bind error (%s).\n"
msgstr "Erro de vinculação (%s)."

msgid "Invalid PORT.\n"
msgstr "Porto inválido."

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro REST, iniciar do começo."

msgid "%s has sprung into existence.\n"
msgstr "%s se tornou realidade."

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado."

msgid "(try:%2d)"
msgstr "(tentativa:%2d)"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) - gravado na saída padrão %s[%s]"

msgid "Removing %s.\n"
msgstr "Удаляється %s."

msgid "Removed %s.\n"
msgstr "Удалён %s. \n"

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr "Arquivo remoto mais recente do arquivo local %s - carregando."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Os tamanhos não concordam (tamanho local %s) — carregando. \n"

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome inválido de símbolo de ligação, ignorado."

msgid "Skipping directory %s.\n"
msgstr "Omitindo o diretório %s."

msgid "Rejecting %s.\n"
msgstr "Отклоняється %s."

msgid "Error matching %s against %s: %s\n"
msgstr "Erro de associação do campo %s com o valor %s: %s\n"

msgid "No matches on pattern %s.\n"
msgstr "Não há correspondências com o padrão %s."

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ERRO: Falha ao abrir certificado %s: (%d).\n"

msgid "Loaded CRL file '%s'\n"
msgstr "Cargado CRL-arquivo «%s»"

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr "%s: Desconhecido é o editor de certificado %s."

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr ""
"%s: O certificado emitido por %s não está presente no Centro de Certificação"
" (УЦ).\n"

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro na inicialização do certificado X509: %s"

msgid "No certificate found\n"
msgstr "Certificado não encontrado."

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não foi ativado."

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública não corresponde à chave encadeada!"

msgid "Error in handling the address list.\n"
msgstr "Erro ao processar a lista de endereços."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr ""
"%s: não é possível reconhecer uma URL parcialmente inválida %s. Por favor, "
"verifique se a URL está correta e tente novamente."

msgid "No headers, assuming HTTP/0.9"
msgstr "Os cabeçalhos não estão presentes, é assumido HTTP/0.9."

msgid "Reusing existing connection to %s:%d.\n"
msgstr "uso repetido do soquete com %s:%d."

msgid "%s ERROR %d: %s.\n"
msgstr "%s ОШИБКА %d: %s."

msgid "Proxy tunneling failed: %s"
msgstr "Erro na tunelização do proxy: %s"

msgid "Saving to: %s\n"
msgstr "Salvar em: %s\n"

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar o arquivo temporário. O download da assinatura é "
"permitido."

msgid "%s request sent, awaiting response... "
msgstr "%s-pedido enviado. Esperando resposta... "

msgid "No data received.\n"
msgstr "Não foram encontrados dados."

msgid "Read error (%s) in headers.\n"
msgstr "Erro de leitura (%s) nos cabeçalhos."

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr "[avançar]"

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr "Arquivo já foi totalmente carregado; não há nada a fazer."

msgid "Length: "
msgstr "Для a medição da posição, utilize o campo 'longitude'."

msgid "ignored"
msgstr "ignorado"

msgid "Cannot write to temporary WARC file.\n"
msgstr "Não é possível escrever no arquivo WARC temporário."

msgid "Cannot unlink %s (%s).\n"
msgstr "Не foi possível excluir %s (%s).\n"

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr ""
"Заголовок last-modified — временные отметки проигнорированы. (last modified "
"header is ignored due to invalid timestamp.)"

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) - Conectado, posição %s. "

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: Não foi possível ler %s (%s)."

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %d."

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro de processamento do arquivo wgetrc (env SYSTEM_WGETRC). Verifique o seguinte:\n"
"'%s'\n"
"or especule um outro arquivo usando --config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Aviso de Erro: o wgetrc do sistema e do usuário indicam %s. Por favor, "
"verifique as configurações para corrigir esse erro."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Falha lógica; use 'on' ou 'off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: Incorrecto; use 'on', 'off' ou 'quiet'."

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %d."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s\n"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O conversor de %s para %s não é suportado"

msgid "Unhandled errno %d\n"
msgstr "Erro de código não tratado %d"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; registro de log desligado. (logging disabled)."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL]...\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas e curtas são igualmente "
"necessários."

msgid "Startup:\n"
msgstr "Início do processo:"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help              Mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa iniciar em modo de "
"fundo\n"

msgid "Logging and input file:\n"
msgstr "Jornalização e arquivo de entrada:\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr "  -a,  --append-output=%s  adicionar mensagens ao final do arquivo %s\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "--verbose                   mostrar informações detalhadas (padrão)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregue URLs de acordo com o arquivo local ou "
"externo\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config                 não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registra as razões para rejeição de URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir ЧИСЛО tentativas adicionais\n"
"                                 (0 sem limite)\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr ""
"  -O,  --output-document=FILE    escrevendo documentos no arquivo FILE\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                continue a leitura parcial de um arquivo "
"parcialmente carregado\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TYPE            selecionar tipo de indicador de "
"progresso\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         resposta do servidor\n"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         configuração de todos os valores de tempo "
"igual ao número SEGUNDO\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEC         configuração de tempo limite para pesquisa "
"DNS em SEC\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=SEC     instalação do timeout de leitura em SEC\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDOS            pausa de tantos SEGUNDOS entre carregamentos\n"
"                                 (aplicável se forem mais do que um URL para serem baixados)\n"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                  explicitamente desligue o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=ЧИСЛО             establecer a quantia da quota de "
"transferência em ЧИСЛО\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr "       --limit-rate=СКОРОСТЬ     ограничить СКОРОСТЬ загрузки\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--ipv6 somente              conectar apenas a endereços IPv6\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                  desligue a suporte IRI\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                    remover arquivo antes de apagar"

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=ПОЛЬЗОВ.    estabelecer usuário http no usuário POLEZOV"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"       --no-cache              ignorar dados armazenados no servidor local\n"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=STRING         inserir STRING entre cabeçalhos\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          máximo permitido de redirecionamentos para a "
"página\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLHA   instale PAROLHA como a senha do proxy\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"--keep-session-cookies  carregar e salvar cookies de sessão (não "
"permanentes)"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=СТРОКА      utilizar método POST; envio de STRING como "
"dados\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   considere o cabeçalho Content-Disposition\n"
"                               ao escolher nomes para arquivos locais (EXPERIMENTAL)\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       arquivo de certificado do usuário\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--no-hsts               desligue o HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS (substitui "
"o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "       --no-remove-listing     não remova listagens de arquivo"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp        desligue o modo 'pasivo' de transferência"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N               antes de escrever o arquivo X, fazer backup até N\n"
"                        cópias do arquivo original."

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X, fazer uma cópia "
"de segurança no formato X.orig\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R, --reject=LIST               lista separada por vírgulas de extensões "
"rejeitadas\n"

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--excluir-diretórios=%s"

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, programa para baixar arquivos da internet de forma "
"independente. \n"

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr ""
"Erro de inicialização do objeto com ações de arquivo durante o spawn para "
"use-askpass: %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "falha na leitura da resposta da comando \"%s %s\": %s"

msgid "Locale: "
msgstr "LOCALE: "

msgid "    %s (env)\n"
msgstr "    %s (ambiente) \n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later\n"
"<http://www.gnu.org/licenses/gpl.html>.\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior\n"
"<http://www.gnu.org/licenses/gpl.html>\n"
"Este é software livre:\n"
"dele pode ser modificado e distribuído.\n"
"Nada está garantido, dentro das limitações da lei."

msgid "Try `%s --help' for more options.\n"
msgstr "Para obter mais informações, tente `cmd --help`."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"São especificados imediatamente --no-clobber e --convert-file-only, será "
"utilizado apenas o --convert-file-only."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar ao mesmo tempo --inet4-only e --inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é permitido especificar simultaneamente -k ou --convert-file-only e -O, "
"se URLs múltiplas forem indicadas, ou em combinação com os parâmetros -p ou "
"-r. Consulte a documentação para detalhes."

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"AVISO: a operação com marcações de tempo não é executada quando o parâmetro "
"-O for especificado. Para mais detalhes, consulte o manual."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com o parâmetro --no-clobber, esse parâmetro será "
"desabilitado."

msgid "WARC output does not work with --spider.\n"
msgstr "O output do WARC não funciona com --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com --continue ou --start-pos; eles serão "
"desligados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório desligado; a deduplicação WARC não encontrará registros "
"duplicados."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente as opções --ask-password e "
"--password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"AVISO de antecedência: não foi especificado o nome do usuário, mas houve a "
"solicitação --ask-password. Normalmente isso não é necessário."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"Parâmetro -k ou -r pode ser utilizado somente em conjunto com -O, se o "
"output for produzido em um arquivo regular."

msgid "Failed to init c-ares channel\n"
msgstr "Erro de inicialização do canal c-ares"

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Ignoramos o arquivo metalink. Nome de usuário inseguro."

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr ""
"Отбраковываем файл metaurl %s. Небезопасное имя. (без перевода переменных)."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro de download %s. Omitindo metaurl."

msgid "Metaurls processing returned with error.\n"
msgstr "A análise de metadados URL retornou com erro."

msgid "Could not open downloaded file.\n"
msgstr "Não foi possível abrir o arquivo baixado."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "GPGME data_new_from_mem: %s\n"

msgid "GPGME op_verify: %s\n"
msgstr "GPGME op_verificar: %s"

msgid "No checksums found.\n"
msgstr "As contas de controle não foram encontradas."

msgid "File %s retrieved but signature does not match. \n"
msgstr "Arquivo %s recebido, mas a assinatura não corresponde.  \n"

msgid "Continuing in background.\n"
msgstr "Através do comando 'screen', a execução continua em segundo plano."

msgid "%s: %s:%d: warning: %s token appears before any machine name\n"
msgstr ""
"%s: %s:%d: aviso: antes do nome de cada veículo encontramos o símbolo '%s'"

msgid "WARNING: using a weak random seed.\n"
msgstr "AVISO de pré-avanço: utiliza um fonte aleatória fraca."

msgid "Your OpenSSL version is too old to support TLSv1.1\n"
msgstr "Versão do seu OpenSSL é muito antiga para suportar TLSv1.1."

msgid "OpenSSL: Failed to allocate verification param\n"
msgstr "OpenSSL: Não foi possível alocar parâmetro de verificação"

msgid "WARNING: Could not seed PRNG. Consider using --random-file.\n"
msgstr ""
"AVISO DE ERRO: não foi possível sementar o PRNG; considera utilizar o "
"parâmetro --random-file. \n"

msgid "  Self-signed certificate encountered.\n"
msgstr "Certificado auto-firmado encontrado."

msgid "  Issued certificate has expired.\n"
msgstr "Para o certificado solicitado, expirou o prazo de validade."

msgid "To connect to %s insecurely, use `--no-check-certificate'.\n"
msgstr ""
"Para conectar de forma não segura ao %s, use o parâmetro '--no-check-"
"certificate'."

msgid "Invalid dot style specification %s; leaving unchanged.\n"
msgstr ""
"Não é aceito o estilo de ponto especificado como '%s'; mantido sem "
"alterações."

msgid "Invalid user name"
msgstr "Nome de usuário inválido"

msgid "Unconvertable multibyte sequence encountered\n"
msgstr "Encontrada uma sequência multibyte não convertível"

msgid "%s: aprintf: text buffer is too big (%d bytes), aborting.\n"
msgstr ""
"%s: aprintf: bufor tekstowy jest w bardzo duży stopniut (%d bajtów), wyłącz."
" \n"

msgid "File %s changed since the last check. Security check failed.\n"
msgstr ""
"Após a última verificação, o arquivo %s sofreu alterações. Houve uma falha "
"na verificação de segurança."

msgid "Failed to stat file %s, error: %s\n"
msgstr "Erro ao executar o comando stat para arquivo %s, erro: %s\n"

msgid "Invalid regular expression %s, PCRE2 error %d\n"
msgstr ""
"Não é permitido o uso do padrão de expressão regular %s, erro PCRE2 %d"

msgid "Invalid regular expression %s, %s\n"
msgstr "Não é permitido o uso do padrão de expressão regular %s, %s\n"

msgid "Error while matching %s: %d\n"
msgstr "falha ao comparar %s com valor %d\n"

msgid "Error setting WARC file position.\n"
msgstr "Erro ao mover posição no arquivo WARC."

msgid "Error opening GZIP stream to WARC file.\n"
msgstr "Erro ao abrir fluxo GZIP no arquivo WARC."

msgid "Error writing warcinfo record to WARC file.\n"
msgstr "Erro ao salvar registro warcinfo no arquivo WARC."

msgid "CDX file does not list original urls. (Missing column 'a'.)\n"
msgstr "Arquivo CDX não contém URLs originais (a coluna 'a' está ausente)."

