msgid "%s: unable to resolve bind address %s; disabling bind.\n"
msgstr ""
"%s: não é possível resolver o endereço vinculado %s; desligamento da ligação"
" (bind).\n"

msgid "Connecting to %s:%d... "
msgstr "Conexão ao %s:%d... "

msgid "%s: unable to resolve host address %s\n"
msgstr "%s: não é possível resolver o endereço %s"

msgid "Cannot convert links in %s: %s\n"
msgstr "Не foi possível converter as referências em %s : %s\n"

msgid "Syntax error in Set-Cookie: %s at position %d.\n"
msgstr "Erro de sintaxe no Set-Cookie: %s na posição %d. \n"

msgid "Cannot open cookies file %s: %s\n"
msgstr "não é possível abrir o arquivo cookies %s : %s"

msgid "time unknown       "
msgstr "tempo desconhecido"

msgid "File        "
msgstr "Arquivo        "

msgid ", %s (%s) remaining"
msgstr ", %s (%s) restante"

msgid "Write failed, closing control connection.\n"
msgstr "Erro de escrita, conexão de controle encerrada."

msgid "The server refuses login.\n"
msgstr "O servidor recusou o login."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a comando 'PROT %c'."

msgid "done.    "
msgstr "pronto."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não há tal diretório: %s."

msgid "Cannot parse PASV response.\n"
msgstr "Erro ao analisar a resposta PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível estabelecer a conexão com o %s no porto %d: %s"

msgid "Bind error (%s).\n"
msgstr "Erro de ligação (%s)."

msgid "Invalid PORT.\n"
msgstr "Porto inválido."

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro de REST, reinício desde o começo."

msgid "%s has sprung into existence.\n"
msgstr "%s se tornou realidade."

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado."

msgid "(try:%2d)"
msgstr "(tentativa :%2d)"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) — envoi sur a saída padrão %s[%s]"

msgid "Removing %s.\n"
msgstr "Destruição de %s."

msgid "Removed %s.\n"
msgstr "O arquivo %s foi removido."

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr "Arquivo remoto mais recente que o arquivo local %s — carregamento."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Os tamanhos não concordam (%s localmente) — carregamento."

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome inválido de símbolo de ligação, ignorado."

msgid "Skipping directory %s.\n"
msgstr "O diretório %s foi ignorado."

msgid "Rejecting %s.\n"
msgstr "Rejeitado %s."

msgid "Error matching %s against %s: %s\n"
msgstr "Erro — %s não corresponde a %s : %s\n"

msgid "No matches on pattern %s.\n"
msgstr "Não há concordância para o padrão %s."

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ОШИБКА: falha ao abrir certificado %s: (%d)."

msgid "Loaded CRL file '%s'\n"
msgstr "Arquivo de lista de revocações do certificado '\\u0425' carregado."

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr "%s: o certificado de %s não é emitido por um autor conhecido. \n"

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr ""
"%s: O certificado assinado por %s não foi emitido pela Autoridade "
"Certificadora (CA)."

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro de inicialização do certificado X.509 : %s"

msgid "No certificate found\n"
msgstr "Certificado não encontrado"

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não está ativado"

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública não corresponde à chave pública fixa!"

msgid "Error in handling the address list.\n"
msgstr "Erro ao processar a lista de endereços."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr ""
"%s: não é possível resolver uma referência de URL incompleta %s. Por favor, "
"verifique se a URL está correta e tente novamente."

msgid "No headers, assuming HTTP/0.9"
msgstr "Não há cabeçalhos, HTTP/0.9 presumido."

msgid "Reusing existing connection to %s:%d.\n"
msgstr "Réutilização da conexão existente com %s:%d."

msgid "%s ERROR %d: %s.\n"
msgstr "%s ERRO %d: %s."

msgid "Proxy tunneling failed: %s"
msgstr "Erro de túnel do proxy : %s"

msgid "Saving to: %s\n"
msgstr "Salvar em: %s\n"

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar o arquivo temporário. Continuar com a transferência "
"da assinatura."

msgid "%s request sent, awaiting response... "
msgstr "requête %s enviada, esperando a resposta... "

msgid "No data received.\n"
msgstr "Nenhuma informação recebida."

msgid "Read error (%s) in headers.\n"
msgstr "Erro de leitura (%s) nos cabeçalhos."

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr "[avançar]"

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr "Arquivo já totalmente carregado; nada a fazer."

msgid "Length: "
msgstr "Comprimento : "

msgid "ignored"
msgstr "ignorado"

msgid "Cannot write to temporary WARC file.\n"
msgstr "Não é possível escrever no arquivo WARC temporário."

msgid "Cannot unlink %s (%s).\n"
msgstr "Не foi possível excluir o arquivo %s (%s).\n"

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr "Não é permitido o título 'last-modified' — horários ignorados."

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) — Conectividade fechada, posição %s. "

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s: impossível ler %s (%s).\n"

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %d da fonte."

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro de processamento do arquivo sistema wgetrc (env SYSTEM_WGETRC). Por "
"favor, verifique '\\u041e\\u043d \\u0438\\u0437\\u0432\\u0435\\u0445c' ou "
"indique outro arquivo com o --config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Aviso: o wgetrc do sistema e de usuário apontam para %s. Por favor, "
"verifique as configurações em ambos os arquivos."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s : comando --execute %s inválido\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s : %s : valor lógico %s inválido ; utilize «on» ou «off»."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s : %s : %s incorreto ; utilize «on» ou «off»."

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s : %s : número %s inválido."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s : %s : período de tempo negativo %s"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão de %s para %s não é suportada."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado %d"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O E/S padrão é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; журналирование отключается.\n"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização : %s [PARAMETRO]… [URL]…\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções com formatos longos e curtos são "
"igualmente necessários."

msgid "Startup:\n"
msgstr "Démarrage :\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      Mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para retornar ao modo "
"de fundo."

msgid "Logging and input file:\n"
msgstr ""
"Jornalização e arquivo de entrada : \n"
"\t%s - %d. Linha %<PRIuMAX> com %<PRIuMAX> campos (esperado %<PRIuMAX>)\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=%s     adicionar mensagens ao final do arquivo %s\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
"  -v,  --verbose                   executar em modo detalhado (modo padrão)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE\n"
"        carregar URLs do FILE local ou externo."

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config                 não ler arquivos de configuração"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE\n"
"        registrar as razões de rejeição das URLs no FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir o NOMBRE de tentativas (0 indica a "
"ausência de limite) \n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=%s   escrever os documentos no arquivo %s\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                   para continuar o carregamento de um "
"arquivo parcialmente baixado\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=ТИП            selecionar o Tipo de indicador de "
"progresso\n"

msgid "  -S,  --server-response           print server response\n"
msgstr " -S, --server-response           Mostrar a resposta do servidor"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         definir todos os valores de timeout como o"
" número SEGUNDO\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"--dns-timeout=SEC         configurar o tempo de espera para a resolução DNS "
"em segundos SEC\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"--read-timeout=SEK\n"
"    Definir o tempo de espera para leitura em segundos (SEK)"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDAS              espera entre as tentativas de carregamento\n"
"                                 (utilizada se mais de uma URL forem solicitadas) \n"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                      desligue o proxy explicitamente"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓDIGO              definir a quantia de quota da rede em "
"CÓDIGO"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr "       --limit-rate=SPEED           limitar a SPEED de transferência"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only              conectar apenas a adresses IPv6\n"

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                    desligar a suporte aos IRIs\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"--unlink                    remover o arquivo antes de apagar (truncate)"

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=POLIZOVATEL\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"--no-cache              ignorar dados armazenados em cache do servidor"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=STRING\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"--max-redirect              nbre máximo de redirecionamentos permitidos por "
"página\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLHA        definir a PAROLHA como senha para o "
"proxy\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"--keep-session-cookies  carregar e salvar cookies de sessão (não "
"permanentes)"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING utilizar a método POST para enviar STRING como "
"dados; envio de STRING no formato do corpo da requisição."

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   considerar o cabeçalho Content-Disposition\n"
"                               ao escolher nomes para arquivos locais (experimental)\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       arquivo de certificado do usuário\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts               desligue o HSTS\n"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS "
"(sobreescreve o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP : \n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr ""
"--no-remove-listing         não remova listagens de arquivo '*.listing'"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp        desligue o modo de transferência passiva\n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS : \n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                 antes de escrever o arquivo X, fazer backup em N"
" cópias e manter no máximo N"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X fazer uma cópia "
"de backup no formato X.orig\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LISTA              lista de extensões rejeitadas, separadas "
"por vírgulas\n"

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclude-directories=%s\n"

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, ferramenta para baixar arquivos da internet de forma "
"independente."

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr ""
"Erro de inicialização do objeto com ações de arquivo para use-askpass : %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "Erro de leitura da resposta para a comando \"%s %s\": %s"

msgid "Locale: "
msgstr "Parametros regionais : "

msgid "    %s (env)\n"
msgstr "    %s (ambiente) \n"

msgid ""
"License GPLv3+: GNU GPL version 3 or later\n"
"<http://www.gnu.org/licenses/gpl.html>.\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+ : GNU GPL versão 3 ou posterior. "
"<http://www.gnu.org/licenses/gpl.html>. Software livre : você pode modificá-"
"lo e distribuí-lo sem restrições. Nenhuma garantia é fornecida, dentro das "
"limitações legais."

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações sobre os parâmetros adicionais, use a comando ' "
"%s --help'."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"Указаны сразу --no-clobber и --convert-file-only, будет использоваться "
"только --convert-file-only."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar --inet4-only e --inet6-only ao mesmo tempo."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é permitido especificar simultaneamente -k ou --convert-file-only e -O, "
"se URLs múltiplas forem indicadas, ou em combinação com os parâmetros -p ou "
"-r. Consulte a documentação para mais detalhes."

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"ATENÇÃO: o horário de marcação não é executado se combinado com o parâmetro "
"-O. Consulte o manual para mais detalhes."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com o parâmetro --no-clobber, que será desabilitado."

msgid "WARC output does not work with --spider.\n"
msgstr "Saída WARC não funciona com --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com --continue ou --start-pos; eles serão "
"desligados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório de desligamento; a função de redução dupla WARC não encontrará "
"registros repetidos."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar --ask-password e --password ao mesmo tempo."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"AVISO : não foi especificado o nome de usuário, mas a opção --ask-password "
"está presente. Isso geralmente não é necessário."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"O parâmetro '-k' ou '-r' pode ser utilizado somente em conjunto com o "
"parâmetro '-O', desde que a saída seja para um arquivo normal."

msgid "Failed to init c-ares channel\n"
msgstr "Erro na inicialização do canal c-ares"

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Rejeitamos o arquivo metalink. Nome não seguro."

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr "Rejeitando o arquivo metaurl %s. Nome inseguro."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro de download %s. Metaurl ignorado."

msgid "Metaurls processing returned with error.\n"
msgstr "Ocorreu uma falha na processamento de metaurols."

msgid "Could not open downloaded file.\n"
msgstr "Não é possível abrir o arquivo baixado."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "GPGME data_new_from_mem : %s"

msgid "GPGME op_verify: %s\n"
msgstr "GPGME op_verificar : %s"

msgid "No checksums found.\n"
msgstr "Somma de controle não encontrada."

msgid "File %s retrieved but signature does not match. \n"
msgstr "Arquivo %s recebido, mas a assinatura não corresponde."

msgid "Continuing in background.\n"
msgstr "A execução continua no modo de fundo."

msgid "%s: %s:%d: warning: %s token appears before any machine name\n"
msgstr "%s : %s:%d : aviso : o token %s aparece antes do nome da máquina\n"

msgid "WARNING: using a weak random seed.\n"
msgstr ""
"PRECARDAÇÃO DE DADOS SEM UTILIZAÇÃO DO SOQUETE PREPARATÓRIO RANDOMNESS "
"FÁVEL."

msgid "Your OpenSSL version is too old to support TLSv1.1\n"
msgstr ""
"A versão do OpenSSL que você está utilizando é muito antiga para suportar "
"TLSv1.1."

msgid "OpenSSL: Failed to allocate verification param\n"
msgstr "OpenSSL: Falha ao alocar o parâmetro de verificação"

msgid "WARNING: Could not seed PRNG. Consider using --random-file.\n"
msgstr ""
"AVISO : não é possível sementear a PRNG; considere o uso do parâmetro "
"--random-file."

msgid "  Self-signed certificate encountered.\n"
msgstr "Foi encontrado um certificado autossignado."

msgid "  Issued certificate has expired.\n"
msgstr "Para o certificado solicitado, expirou seu prazo de validade."

msgid "To connect to %s insecurely, use `--no-check-certificate'.\n"
msgstr ""
"Para conexões não seguras a %s, utilize o parâmetro '--no-check-"
"certificate'."

msgid "Invalid dot style specification %s; leaving unchanged.\n"
msgstr ""
"Não é permitida a especificação de estilo 'point' %s; deixada sem "
"alterações."

msgid "Invalid user name"
msgstr "Nome de usuário inválido"

msgid "Unconvertable multibyte sequence encountered\n"
msgstr "Encontrada uma sequência multiocteto não convertível"

msgid "%s: aprintf: text buffer is too big (%d bytes), aborting.\n"
msgstr "%s : aprintf : tampon de texto muito grande (%d bytes), parada."

msgid "File %s changed since the last check. Security check failed.\n"
msgstr ""
"Após a última verificação, o arquivo %s sofreu alterações. Falha na "
"verificação de segurança."

msgid "Failed to stat file %s, error: %s\n"
msgstr "falha na execução de stat para o arquivo %s, erro : %s"

msgid "Invalid regular expression %s, PCRE2 error %d\n"
msgstr ""
"Não é permitido o uso do padrão regular %s, erro PCRE2 com número de linha "
"%d\n"

msgid "Invalid regular expression %s, %s\n"
msgstr "Expres%C3%A3o regular %s inaceitavel, %s"

msgid "Error while matching %s: %d\n"
msgstr "Erro de correspondência do campo %s com valor %d\n"

msgid "Error setting WARC file position.\n"
msgstr "Erro ao mover arquivo WARC."

msgid "Error opening GZIP stream to WARC file.\n"
msgstr "Erro ao abrir fluxo GZIP para o arquivo WARC."

msgid "Error writing warcinfo record to WARC file.\n"
