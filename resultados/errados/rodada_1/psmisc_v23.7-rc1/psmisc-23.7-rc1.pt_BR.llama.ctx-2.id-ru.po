msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "O nome do espaço de nomes requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome de domínio inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'original_text': '-e,--exact', 'translated_text': '-e, --exato'}, "
"{'original_text': '-I,--ignore-case', 'translated_text': '-i, --ignorar-"
"caso'}, {\"original0: 'The provided document does not contain any code or "
"programming language examples to translate. It appears you're asking for a "
"task that involves translating text from English into Brazilian Portuguese "
"while adhering to specific constraints and formatting rules, including the "
"preservation of certain format specifiers within strings (e.g., `%s`, `%d`)."
" However, since there is no code provided in your request, I will instead "
"translate the given command-line options for a hypothetical software tool "
"into Brazilian Portuguese while adhering to the constraints you've outlined:"
" 1) Preserve all format specifiers exactly as they appear; 2) Maintain "
"formal tone and style consistent with technical documentation in Brazilian "
"Portuguese. Here is how these command-line options would be translated, "
"following your instructions for formatting rules (e.g., preserving the exact"
" form of `%s`):\": '\\n    '}, {'original_text': '-e,--exact', "
"'translated_text': '-e, --exato'}, {'original_text': '-I,--ignore-case', "
"'translated_text': '-i, --ignorar-caso'}]"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP apenas interrompa processos que tenham contexto "
"(mandatório antes de outros argumentos)\n"

msgid "Invalid time format"
msgstr "Formato de tempo inválido"

msgid "Cannot find user %s\n"
msgstr "Usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "PID inválido para o espaço de nomes"

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2024 Craig Small"

msgid "running"
msgstr "funciona"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Planejamento de processos\n"
" Política: %s\n"
"Uso prioritário RT: %ld \tPrioridade real: %ld %s"

msgid "Invalid option"
msgstr "opção inválida -- '%s'"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr "  -h, --highlight-all destacar o processo atual e seus antecessores\n"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID     iniciar processo com esta PID; valor padrão é 1 (init)\n"
"\tPENGUNA mostrar apenas árvore de processos que pertencem a este utilizador."

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Nome desconhecido de usuário: %s"

msgid "Press return to close\n"
msgstr "Pressione Enter para sair"
