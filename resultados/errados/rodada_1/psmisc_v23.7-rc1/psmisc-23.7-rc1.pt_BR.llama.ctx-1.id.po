msgid "Specified filename %s does not exist.\n"
msgstr "Nome do arquivo %s não foi especificado."

msgid "Namespace option requires an argument."
msgstr "A opção de nome do espaço requer um argumento."

msgid "Invalid namespace name"
msgstr "Nama ruang inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"--exact          necessita coincidência exata para nomes longos\n"
"-I,--ignore-case    comparação de nomes sem diferenciar maiúsculas e minúsculas\n"
"-g,--process-group  encerra processo grupo em vez de único processo\n"
"-y,--younger-than   encerra processos mais novos do que o tempo especificado\n"
"-o,--older-than     encerra processos mais antigos do que o tempo especificados\n"
"-i,--interactive    solicita confirmação antes de interromper um processo\n"
"-l,--list           lista todos os nomes sinalizadores conhecidos\n"
"-q,--quiet          sem mensagens ou avisos\n"
"-r,--regexp         interpreta o nome como uma expressão regular expandida\n"
"-s,--signal SIGNAL  envia um sinal personalizado em vez de SIGTERM\n"
"-u,--user USER      encerra apenas processos executados pelo usuário especificado\n"
"-v,--verbose        notifica quando o sinal foi enviado com sucesso\n"
"-V,--version        exibe a versão do utilitário killall\n"
"-w,--wait           aguarda que os processos terminem antes de sair\n"
"-n,--ns PID         considera apenas processos no mesmo espaço nominal (NS) que o ID especificado"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP somente interromper processos que tenham contexto\n"
"                      (deve vir antes de outros argumentos)"

msgid "Invalid time format"
msgstr "Fechamento de tempo inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "ID de nome espaço não válido"

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Privilégio de cópia (C) 2009–2024 Craig Small"

msgid "running"
msgstr "executa"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Política de Agendamento\n"
"  Política:\n"
"    Nome da Relação: %s\n"
"    Nice:      %ld \tPrioridade do Tempo Real (RT): %ld \t%s"

msgid "Invalid option"
msgstr "opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
"{-h, --highlight-all aktuellen Prozess und Vorgänger hervorheben\n"
" -H PID, --highlight-pid=PID\n"
"                      angegebenen Prozess und Vorgänger hervorheben\n"
" -l, --long          jangan potong baris panjang"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID      iniciar processo com este PID; valor padrão é 1 (init)\n"
"NUTZER   exibir apenas árvores de processos que têm raízes em processos deste usuário"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Kein Benutzer mit dem Namen »%s«\n"

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
