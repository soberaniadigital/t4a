msgid "Specified filename %s does not exist.\n"
msgstr "O nome do arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço de nomes inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          requer coincidencia exacta para nomes muy largos\n"
"  -I,--ignore-case    MAYÚS/minux indistinguibles para coincidencia de nombre del proceso\n"
"  -g,--process-group   mata grupo de processos de vez, en lugar de un solo proceso\n"
"  -y,--younger-than   mata processos jovens que são menores do que a HORA especificada\n"
"  -o,--older-than     mata processos mais velhos que são maiores do que a HORA especificada\n"
"  -i,--interactive    solicita confirmação antes de matar um processo\n"
"  -l,--list           lista todos os nombres conhecidos dos sinais disponíveis\n"
"  -q,--quiet          silencia qualquer mensagem ou aviso que possa ser gerado durante a execução do comando\n"
"  -r,--regexp         interpreta NOMBRE como um ereg extendido, permitindo expressões regulares mais complexas para filtragem de processos\n"
"  -s,--signal SIGNAL   envia esta SEÑAL específica ao(s) processo(s), em vez da padrão SIGTERM\n"
"  -u,--user USER      mata apenas o processo que está executando como este usuário, excluindo outros do mesmo espaço de nomes\n"
"  -v,--verbose        fornece uma mensagem confirmativa se a SEÑAL foi enviada com sucesso ao(s) processo(s)\n"
"  -V,--version        mostra informações sobre a versão deste utilitário\n"
"  -w,--wait           aguarda o término dos processos antes de sair do terminal ou continuar sua execução normalmente\n"
"  -n,--ns PID         filtra os processos que pertencem ao mesmo espaço de nomes que este ID específico da máquina"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP interrompa processos que possuem contexto\n"
"                        (deve preceder a outros argumentos)"

msgid "Invalid time format"
msgstr "Formato de hora inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado"

msgid "Invalid namespace PID"
msgstr "PID de nome espaço inválido"

msgid "Bad regular expression: %s\n"
msgstr "Expresão regular mal formada: %s"

msgid ""
