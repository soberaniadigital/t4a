msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não foi encontrado."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome de espaço inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"      -e,--exact          exatamente coincidência para nomes longos necessitam\n"
"      -I,--ignore-case    diferenciação entre maiúsculas e minúsculas não é feita\n"
"      -g,--process-group  interromper a process group em vez de um único processo\n"
"      -y,--younger-than   interromper os processos mais jovens que uma determinada data/hora específica\n"
"      -o,--older-than     interromper os processos mais velhos que uma determinada data/hora específica\n"
"      -i,--interactive    pedir confirmação ao usu0r antes de abortar o comando\n"
"      -l,--list           listagem dos nomes das sinais conhecidos disponíveis\n"
"      -q,--quiet          sem mensagens ou aviso, apenas erros são apresentados se houver algum\n"
"      -r,--regexp         nome é um padrão de expressões regular expandido (ereg)\n"
"      -s,--signal SIGNAL  enviar uma sinal personalizada ao invés do comando por default\n"
"      -u,--user USER      interromper apenas os processos que pertencem a usuário especificado\n"
"      -v,--verbose        notificação se o signal foi bem-sucedido em ser enviado\n"
"      -V,--version        exibir versão do comando killall\n"
"      -w,--wait           aguardar até que os processos terminem antes de continuar a execução da linha de comandos\n"
"      -n,--ns PID         considerar apenas aqueles processos no mesmo espaço de nomes (NS) do identificador de Processo/PID especificado"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"--context REGEXP --abort Processos com contexto\n"
"(deve preceder outros argumentos)"

msgid "Invalid time format"
msgstr "Fechamento do tempo inválido."

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "PID inválido para o espaço de nomes"

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2024 Craig Small"

msgid "running"
msgstr "o processo está rodando"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Política de Agendamento do Processo\n"
"Relação:\n"
"Nice:   %ld \tRT Prioridade: %ld \t%s\n"

msgid "Invalid option"
msgstr "opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all destacar o processo atual e seus antecessores\n"
" -H PID, --highlight-pid=PID\n"
"                    destaque do processo especificado e de seus predecessores\n"
" -l, --long          não cortar linhas longas"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID     com esta PID iniciar; valor padrão é 1 (init)\n"
"NUTZER   mostrar apenas árvores de processos cujas raízes sejam processos deste usuário\n"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s\n"

msgid "No such user name: %s\n"
msgstr "Kein Benutzer mit dem Namen »%s«\n"

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
