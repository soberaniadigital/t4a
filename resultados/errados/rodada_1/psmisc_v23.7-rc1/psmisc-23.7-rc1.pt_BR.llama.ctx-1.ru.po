msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr "  -h, --highlight-all destacar o processo atual e seus antecessores\n"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID                 iniciar processo a partir deste PID; padrão é 1 (init)\n"
"\tPOÚLZOVATEL EL          mostrar apenas o árvore de processos do usuário especificado"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Nome desconhecido de usuário: %s"

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
