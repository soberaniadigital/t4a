msgid "Specified filename %s does not exist.\n"
msgstr "O nome do arquivo %s não foi encontrado."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome de espaço inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'command': 'killall -l, --list', 'description': 'list all known signal "
"names'}, {'command': 'killall -V, --version', 'description': 'display "
"version information'}, {'option': '-e,--exact', 'translation': 'require "
"exact match for very long process names'}, {'option': '-I,--ignore-case', "
"'translation': 'not differentiate between upper and lower case in process "
"names'}, {'option': '-g,--process-group', 'translation': 'terminate the "
"entire process group instead of a single process'}, {'option': '-y,--"
"younger-than', 'translation': 'kill processes younger than specified time'},"
" {'option': '-o,--older-than', 'translation': 'kill processes older than the"
" given time'}, {'option': '-i,--interactive', 'translation': 'ask for user "
"confirmation before terminating processes'}, {'command': '-l,--list', "
"'description': 'display a list of all possible signal names'}, {'option': "
"'-q,--quiet', 'translation': 'suppress detailed messages and errors'}, "
"{'option': '-r,--regexp', 'translation': 'treat NAME as an extended regular "
"expression'}, {'option': '-s,--signal SIGNAL', 'translation': 'send custom "
"signal instead of default (SIGTERM)'}, {'option': '-u,--user USER', "
"'translation': 'terminate processes only belonging to the specified user'}, "
"{'option': '-v,--verbose', 'translation': 'notify upon successful signal "
"delivery, if applicable'}, {'command': '-V,--version', 'description': 'show "
"version information for killall utility'}, {'option': '-w,--wait', "
"'translation': 'wait until processes have finished before continuing'}, "
"{'option': '-n,--ns PID', 'translation': 'consider only the process with a "
"matching namespace to PID provided'}]"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP interromper processos que possuam contexto\n"
"                        (deve ser especificado antes de outros parâmetros)\n"

msgid "Invalid time format"
msgstr "Fechamento do processo sem ajustar o tempo de execução."

msgid "Cannot find user %s\n"
msgstr "Usuário %s não foi encontrado"

msgid "Invalid namespace PID"
msgstr "PID inválido para o espaço de nomes"

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

