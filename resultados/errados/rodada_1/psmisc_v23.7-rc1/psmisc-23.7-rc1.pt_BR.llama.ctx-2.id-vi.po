msgid "Specified filename %s does not exist.\n"
msgstr "Nome do arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção de nome do espaço requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço não é válido."

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"{'command_listing': '-l,--list           liệt kê mọi tên sinh viên đang biến"
" dịch', 'exact_match': '-e,--exact          membutuhkan pencocokan tepat "
"untuk setiap nama panjang', 'ignore_case': '-I,--ignore-case    pencocokan "
"nama proses tidak memperhatikan besar huruf', 'process_group': '-g,--"
"process-group  hentikan grup daripada proses, buộc kết thúc tiến trình của "
"mỗi process grup', 'younger_than': '-y,--younger-than   hentikan proses "
"lebih mua dari WAKTU (mức độ tối)', 'older_than': '-o,--older-than     "
"hentikan proses lebih tua dari WAKTU', 'interactive': '-i,--interactive   "
"xin xác nhận trước khi buộc kết thúc, mỗi tiến trình cần đồng nghiên thức "
"với user', 'list_signals': '-l,--list           daftar seluruh nama sinyal "
"yang diketahui', 'quiet': '-q,--quiet          jangan tampilkan komlain, "
"không hiển thị lời than phiền (_im_)', 'regexp_signal': '-r,--regexp"
"         interpretasikan NAMA sebagai sebuah ekstensi ekpresi regular (giải "
"thích TÊN là biểu thức chính quy mở rộng)', 'custom_signal': '-s,--signal "
"SINYAL  kirim sinyal ini daripada SIGTERM, buộc kết thúc tiến trình của "
"proses', 'user_specific': '-u,--user PENGGUNA   hentikan hanya proses yang "
"berjalan sebagai user (người dùng) này, không mất đến tiếp cảm sự hiển thị',"
" 'verbose': '-v,--verbose        laporkan jika sinyal telah secara sukses "
"dikirimkan (thông báo), truy vất khi gửi tín hiệu SIGTERM'}"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
" -Z,--context REGEXP somente encerra processos que tenham contexto (deve vir"
" antes de outros argumentos)"

msgid "Invalid time format"
msgstr "Formato de tempo inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "ID inválida"

msgid "Bad regular expression: %s\n"
msgstr "Biểu thức regular não é válido: %s"

