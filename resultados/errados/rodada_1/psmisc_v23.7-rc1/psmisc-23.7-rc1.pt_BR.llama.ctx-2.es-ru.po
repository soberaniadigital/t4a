msgid "Specified filename %s does not exist.\n"
msgstr "O nome de arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço de nomes inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"--exact          requer coincidencia exata para nomes muito longos\n"
"-I,--ignore-case    ignorar diferenças entre MAYÚS e minúsculas em nomes de processo\n"
"-g,--process-group  matar grupo de processos ao invés de um único processo\n"
"-y,--younger-than   matar processos mais recentes que HORA\n"
"-o,--older-than     matar processos mais antigos que HORA\n"
"-i,--interactive    pedir confirmação antes de matar os processos\n"
"-l,--list           listar todos os nomes conhecendo dos sinais disponíveis\n"
"-q,--quiet          não exibir mensagens nem aviso\n"
"-r,--regexp         interpretar NOMBRE como uma expressão regular estendida\n"
"-s,--signal SIGALARM   enviar este sinal em vez de SIGTERM (substitua o texto 'SIGALARM' por um sinal específico que seja apropriado no contexto)\n"
"-u,--user USUÁRIO   matar apenas processos executados como USUÁRIO\n"
"-v,--verbose        informar sobre sucesso na envio da mensagem de alerta (substitua 'alerta' por uma ação que indique o status do sinal enviado)\n"
"-V,--version         exibir informações sobre versão\n"
"-w,--wait           esperar ao término dos processos ativos\n"
"-n,--ns PID          considerar apenas os processos pertencentes ao mesmo namespace que PID (substitua 'namespace' por um termo apropriado no contexto)\n"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP interromper processos que possuem contexto (deve "
"preceder outros argumentos)"

msgid "Invalid time format"
msgstr "Formato de hora inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "PID inválido para o espaço de nomes"

msgid "Bad regular expression: %s\n"
msgstr "Expresão regular mal formada: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2024 Craig Small\n"

msgid "running"
msgstr "executando"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Planejamento de Processos\n"
"Política: %s\n"
"Consideração para a prioridade RT: %ld \n"
"Prioridade do processo (nice): %ld"

msgid "Invalid option"
msgstr "opção inválida -- '%s'"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all resalta o processo atual e seus antecessores\n"
" -H PID, --highlight-pid=PID resalta este processo com seu ID de PID e seus antecessores\n"
" -l, --long          não trunca as linhas longas"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID     iniciar com este PID; valor padrão é 1 (init)\n"
"USUARIO mostrar apenas árvores de processos que tenham raízes nos processos deste usuário"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s\n"

msgid "No such user name: %s\n"
msgstr "Não há usuário com o nome 'Es'."

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
