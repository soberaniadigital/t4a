msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não foi encontrado."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer argumento."

msgid "Invalid namespace name"
msgstr "Nome no espaço de nomes inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"{'-e,--exact          requer coincidencia exata para nomes muy largos\\n': "
"'', '-I,--ignore-case   MAYÚS/minux indistinguibles para coincidencia de "
"nombre del proceso\\n': '', '-g,--process-group  mata grupo de processos de "
"vez em vez do único proce': '', '-y,--younger-than   matar processos mais "
"recientes que HORA (placeholder)\\n': '', '-o,--older-than     matar "
"processos más antiguos que HORA (placeholder)\\n': '', '': '', '-i,--"
"interactive    antes de matar, pede confirmação do usuenero\\n': '', '-l,--"
"list           lista todos os nomes das señales conocidas\\n': '', '-q,--"
"quiet          no escreve quejas (placeholder)\\n': '', '-r,--regexp"
"         interpreta NOMBRE como uma expressão regular estendida\\n': '', "
"'-s,--signal SIGNAL   envia esta señal em vez de SIGTERM (placeholder)\\n': "
"'', '-u,--user USER      mata apenas processos que estão executando como o "
"usuario especificado\\n': '', '-v,--verbose        informa se a señal foi "
"enviada corretamente (placeholder)\\n': '', '-V,--version         muestra "
"información sobre la versión del comando killall\\n': '', '-w,--wait"
"           espera o término dos processos antes de continuar\\n': '', '-n,--"
"ns PID         filtra os processos que pertencem ao mesmo espaço de nomes do"
" PID especificado (placeholder)\\n': ''}"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP matar solo processo(s) que tenham contexto\n"
"                        (deve preceder outros argumentos)"

msgid "Invalid time format"
msgstr "Formato de hora inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "Namensraum PID inválido"

msgid "Bad regular expression: %s\n"
msgstr "Expresão regular mal formada: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2024 Craig Small\n"

msgid "running"
msgstr "executando"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Planejamento de Processos\n"
"Política: %s\n"
"Cortesia (Nice): %ld\tPrioridade RT (Real-Time Priority): %ld \n"

msgid "Invalid option"
msgstr "Opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all resalta o processo atual e seus antecessores\n"
" -H PID, --highlight-pid=PID\n"
"                      destaca este processo e seus antecessores\n"
" -l, --long          não corte as linhas longas"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID     iniciar este PID; valor padrão é 1 (init)\n"
"USUARIO mostra apenas árvores de processos cujas raízes são processos deste usuário."

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Não há usuário com o nome 'Es'."

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
