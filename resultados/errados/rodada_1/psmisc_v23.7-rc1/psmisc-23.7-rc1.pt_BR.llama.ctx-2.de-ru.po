msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'command': '-e,--exact', 'description': 'trebora exata para muito longos "
"nomes'}, {'command': '-I,--ignore-case', 'description': 'não diferencia "
"entre maiúsculas e minúsculas nos nomes dos processos'}, {'command': '-g,--"
"process-group', 'description': 'abre comutação de grupo em vez de um único "
"processo'}, {'command': '-y,--younger-than', 'description': 'termina os "
"processos mais novos que a data especificada'}, {'command': '-o,--older-"
"than', 'description': 'termina os processos mais antigos que a data "
"especificada'}, {'command': '-i,--interactive', 'description': 'pedir "
"confirmação ao usuário antes de terminar o processo(es)'}, {'command': '-l,"
"--list', 'description': 'lista todos os nomes conhecidos dos sinais'}, "
"{'command': '-q,--quiet', 'description': 'não exibe mensagens de aviso ou "
"erro'}, {'command': '-r,--regexp', 'description': 'considera NAME como um "
"expressão regular expandida'}, {'command': '-s,--signal SIGNAL', "
"'description': 'envia o sinal especificado em vez de SIGTERM'}, {'command': "
"'-u,--user USER', 'description': 'termina apenas os processos do usuário "
"especificado'}, {'command': '-v,--verbose', 'description': 'envia uma "
"notificação se o sinal foi enviado com êxito'}, {'command': '-V,--version', "
"'description': 'exibe a versão do utilitário killall'}, {'command': '-w,--"
"wait', 'description': 'esperar o término dos processos antes de sair'}, "
"{'command': '-n,--ns PID', 'description': 'considera apenas os processos que"
" pertencem ao mesmo namespace do PID especificado'}]"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP apenas processos com contexto, para interromper\n"
"                        (deve ser especificado antes de outros argumentos)"

