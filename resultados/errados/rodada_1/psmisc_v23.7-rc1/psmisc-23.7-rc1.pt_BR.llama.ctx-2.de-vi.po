msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não foi encontrado."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer um argumento."

msgid "Invalid namespace name"
msgstr "Namensraum inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'command': '-e,--exact', 'description': 'gêne aceitação para nomes muito "
"longos'}, {'command': '-I,--ignore-case', 'description': 'não distingue "
"entre maiúsculas e minúsculas ao procurar por tên implícitos em um nome de "
"processo.'}, {'command': '-g,--process-group', 'description': 'abrevia o "
"término dos processos pertencentes à mesma grupo de processamento, além do "
"próprio'}, {'command': '-y,--younger-than', 'description': 'interrompe os "
"processos que foram iniciados após a data e hora especificadas.'}, "
"{'command': '-o,--older-than', 'description': 'interrompe os processos que "
"foram iniciados antes da data e hora especificadas.'}, {'command': '-i,--"
"interactive', 'description': 'pedir confirmação ao usuário antes de "
"interromper um processo'}, {'command': '-l,--list', 'description': 'lista "
"todos os nomes conhecidos dos sinais que podem ser enviados a um "
"processo.'}, {'command': '-q,--quiet', 'description': 'não exibir mensagens "
"de aviso ou erro'}, {'command': '-r,--regexp', 'description': 'nome é um "
"expressão regular expandida para busca por processos.'}, {'command': '-s,--"
"signal SIGNAL', 'description': 'envia o sinal especificado em vez do padrão "
"SIGTERM'}, {'command': '-u,--user USER', 'description': 'interrompe apenas "
"os processos que estão executando sob o usuário especificado.'}, {'command':"
" '-v,--verbose', 'description': 'exibe uma mensagem de log após a conclusão "
"bem-sucedida da interrupção do sinal'}, {'command': '-V,--version', "
"'description': 'imprime o número da versão atual desse comando.'}, "
"{'command': '-w,--wait', 'description': 'esperar que os processos terminem "
"antes de sair'}, {'command': '-n,--ns PID', 'description': 'interrompe "
"apenas aqueles processos cujo nome do espaço residencial é o mesmo ou está "
"no mesmo namespace daquele especificado pelo ID do processo.'}]"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP apenas processos com contexto (deve anteceder outros "
"argumentos) \n"

msgid "Invalid time format"
msgstr "Formato de tempo inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "PID inválido para o espaço de nomes especificado."

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

