msgid "%s: Unknown file type; file ignored"
msgstr "%s : tipo de ficheiro desconhecido; ficheiro ignorado."

msgid "%s: file changed as we read it"
msgstr "%s: o arquivo foi alterado enquanto estava sendo lido."

msgid "%s: time stamp %s is %s s in the future"
msgstr "%s : a marca de tempo %s está %s segundos no futuro."

msgid "%s: skipping existing file"
msgstr "%s : arquivo existente ignorado"

msgid "Extracting contiguous files as regular files"
msgstr "Extraindo arquivos contínuos como arquivos regulares"

msgid "Unexpected long name header"
msgstr "Cabeçola de nomes largos inesperados"

msgid "Current %s is newer or same age"
msgstr "O atual do %s é mais recente ou da mesma data."

