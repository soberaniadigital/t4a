msgstr "ACCIÓN"

msgid "send verbose output to FILE"
msgstr "envie a saída detalhada para o arquivo"

msgid "show valid ranges for snapshot-file fields"
msgstr "exibe os intervalos válidos para os campos do arquivo de instantânea"

msgid "show file or archive names after transformation"
msgstr "apresenta os nomes dos arquivos ou diretórios após a transformação"

