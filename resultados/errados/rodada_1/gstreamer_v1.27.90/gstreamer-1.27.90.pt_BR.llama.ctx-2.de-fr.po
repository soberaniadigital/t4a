msgid "Print the GStreamer version"
msgstr "A versão de GStreamer deve ser exibida"

msgid ""
"Default debug level from 1 (only error) to 9 (anything) or 0 for no output"
msgstr ""
"Nível de diagnóstico por erro padrão, de 1 (erros apenas) a 9 (tudo "
"incluindo falhas não detectadas), ou 0 para nenhuma saída."

msgid "Disable debugging"
msgstr "Desabilitar a diagnose de erro"

msgid "Colon-separated paths containing plugins"
msgstr ""
"Por meio de dois pontos, separados por espaços em branco, são indicadas as "
"caminhos para os plugins."

msgid "Disable spawning a helper process while scanning the registry"
msgstr "Desabilitar o processo auxiliar ao ler a Registry."

msgid "Internal GStreamer error: event problem."
msgstr "Erro interno do GStreamer : problema de evento."

msgid "Internal GStreamer error: caps problem."
msgstr "Erro interno do GStreamer : problema de capacidades."

msgid "Internal GStreamer error: tag problem."
msgstr "Erro interno do GStreamer: problema de marcação."

msgid "Your GStreamer installation is missing a plug-in."
msgstr "Sua instalação de GStreamer fica com um plugin ausente."

msgid "GStreamer error: clock problem."
msgstr "Erro GStreamer: problema de relógio."

msgid "GStreamer encountered a general supporting library error."
msgstr ""
"Erro do GStreamer da Internet: Problema com a biblioteca de suporte. Por "
"favor, envie um relatório de erro."

msgid "Could not initialize supporting library."
msgstr "A biblioteca de suporte não pôde ser inicializada."

msgid "Could not close supporting library."
msgstr "A biblioteca de suporte não pôde ser fechada."

msgid "Encoding error."
msgstr "Erro de codificação."

msgid "Resource not found."
msgstr "Recursos não encontrados."

msgid "Could not open resource for writing."
msgstr "A fonte não pôde ser aberta para escrita."

msgid "Could not perform seek on resource."
msgstr "Não foi possível executar o processo de pesquisa na recurso."

msgid "Could not synchronize on resource."
msgstr "A fonte não pôde ser sincronizada."

msgid "Could not get/set settings from/on resource."
msgstr "As configurações não podem ser lidas ou gravadas na recurso."

msgid "Element doesn't implement handling of this stream. Please file a bug."
msgstr ""
"O Elemento não consegue processar este fluxo de dados. Por favor, envie um "
"relatório de erro."

msgid "Could not determine type of stream."
msgstr "A natureza do fluxo de dados não pôde ser determinada."

msgid "There is no codec present that can handle the stream's type."
msgstr ""
"Não há nenhum codec disponível que possa processar esse tipo de fluxo de "
"dados."

msgid "Could not multiplex stream."
msgstr "O fluxo de dados não pôde ser multiplexado."

msgid ""
"The stream is encrypted and can't be decrypted because no suitable key has "
"been supplied."
msgstr ""
"O fluxo de dados está criptografado, mas não pode ser descriptografado "
"porque nenhum chave adequada está disponível."

msgid "No error message for domain %s."
msgstr "Não há mensagem de erro para o domínio %s."

msgid "Selected clock cannot be used in pipeline."
msgstr "O sinal selecionado não pode ser utilizado na linha."

msgid "title sortname"
msgstr "Nome para Ordenar do Título"

msgid "album containing this data"
msgstr "Album que contém esses dados"

msgid "The artist of the entire album, as it should be displayed"
msgstr "O artista do álbum inteiro, como ele deve ser exibido"

msgid "The artist of the entire album, as it should be sorted"
msgstr "O artista do álbum inteiro, como ele deve ser classificado"

msgid "comment"
msgstr "Comentário"

msgid "extended comment"
msgstr "Comentário ampliado"

msgid "track count"
msgstr "número de títulos"

msgid "count of tracks inside collection this track belongs to"
msgstr "Número de títulos na coleção, à qual pertence este item"

msgid "disc count"
msgstr "Número de discos"

msgid "count of discs inside collection this disc belongs to"
msgstr "Número de discos na coleção à qual pertence esta placa"

msgid "short text describing the content of the data"
msgstr "Uma breve descrição do conteúdo"

msgid "version"
msgstr "Versão"

msgid "International Standard Recording Code - see http://www.ifpi.org/isrc/"
msgstr "Código Internacional de Gravação - consulte http://www.ifpi.org/isrc/"

msgid "copyright notice of the data"
msgstr ""
"Agradecimento pela utilização dos dados. Por favor, siga as diretrizes de "
"uso e cite o copyright adequadamente."

msgid "URI to the copyright notice of the data"
msgstr "URI para a declaração de direitos autorais dos dados"

msgid "contact information"
msgstr "Informações de contato"

msgid "license"
msgstr "Licença"

msgid "license of data"
msgstr "Licença dos dados"

msgid "license uri"
msgstr "URI de licença"

msgid "performer"
msgstr "ator"

msgid "person(s) performing"
msgstr "A pessoa(s) que interpreta o/os personagens"

msgid "codec"
msgstr "Codificador/Decodificador"

msgid "codec the data is stored in"
msgstr "formato de dados, no qual os dados estão armazenados"

msgid "container format"
msgstr "Formato do contêiner"

msgid "encoder"
msgstr "Codificador"

msgid "serial number of track"
msgstr "número de série do título"

msgid "track gain in dB"
msgstr "nível de título em dB"

msgid "album gain in dB"
msgstr "Pegel dos álbuns em dB"

msgid "peak of the album"
msgstr "Pico do álbum"

msgid "language code for this stream, conforming to ISO-639-1 or ISO-639-2"
msgstr ""
"Código linguístico para este fluxo de energia, conforme a norma ISO-639-1 ou"
" ISO-639-2"

msgid "file attached to this stream"
msgstr "Ficheiro anexado a este fluxo de dados"

msgid "comma separated keywords describing the content"
msgstr "palavras-chave separadas por vírgula que descrevem o conteúdo"

msgid ""
"geo longitude location of where the media has been recorded or produced in "
"degrees according to WGS84 (zero at the prime meridian in Greenwich/UK,  "
"negative values for western longitudes)"
msgstr ""
"geográfico grau de longitude do local em graus conforme WGS84 (0 para o "
"meridiano principal por Greenwich/Reino Unido, valores negativos para os "
"grades leste)"

msgid "geo location movement direction"
msgstr "Rota Geográfica de Movimento"

msgid "geo location capture direction"
msgstr "Geografische Aufzeichnungsrichtung"

msgid "show name"
msgstr "mostrar o nome"

msgid "show sortname"
msgstr "Nome do emissor para o processamento de dados"

msgid "lyrics"
msgstr "Liedtext"

msgid "grouping"
msgstr "agrupar"

msgid "device manufacturer"
msgstr "Fabricante de dispositivos eletrônicos"

msgid "device model"
msgstr "Modelo de dispositivo"

msgid "Application used to create the media"
msgstr "Aplicação utilizada para criar este meio digital"

msgid "Arbitrary application data to be serialized into the media"
msgstr "Dados arbitrários de aplicação para serialização no meio"

msgid "interpreted-by"
msgstr "interpretado por"

msgid "Midi note number of the audio track."
msgstr "Midi-Notenzahl da Tonspur."

msgid ", "
msgstr ", "

msgid "No URI handler for the %s protocol found"
msgstr "Nenhum handler de endereço foi encontrado para o protocolo %s."

msgid "link has no sink [source=%s@%p]"
msgstr "Conexão sem destino [sink=%s@%p]"

msgid "Element \"%s\" is not a GstPreset"
msgstr "O elemento »%s« não é um GstPreset."

msgid "could not link %s to %s, %s can't handle caps %s"
msgstr ""
"%s não pode ser associado a %s, pois o %s não suporta as capacidades %s."

msgid "could not link %s to %s"
msgstr "%s não pode ser associado a %s"

msgid "no sink element for URI \"%s\""
msgstr "Não há elemento de entrada para URI '\\%s'."

msgid "no source element for URI \"%s\""
msgstr "Não há elemento de origem para URI 'de'"

msgid "Internal data flow problem."
msgstr "Problema interno no fluxo de dados."

msgid "Internal data flow error."
msgstr "Erro interno no fluxo de dados."

msgid "Internal clock error."
msgstr "Erro de Tempo Interno."

msgid "Caps Change Mode"
msgstr "Modo de alteração das capacidades"

msgid "Error while writing to download file."
msgstr "Erro ao escrever na pasta de download."

msgid "Could not open file \"%s\" for writing."
msgstr "A pasta de trabalho »%s« não pode ser aberta para escrita."

msgid "Error while seeking in file \"%s\"."
msgstr "Erro ao pesquisar os dados '###'."

msgid "File \"%s\" is a socket."
msgstr "A pasta de dados \"%s\" é um soquete."

msgid "caps"
msgstr "Habilidades"

msgid "minimum"
msgstr "mínimo"

msgid "force caps"
msgstr "forçar as capacidades"

msgid "Stream contains no data."
msgstr "O fluxo de dados não contém nenhum dado."

msgid "writable"
msgstr "escritório disponível"

msgid "changeable only in NULL, READY or PAUSED state"
msgstr "alterável apenas em estado NULL, REALIZADO ou PAUSA"

msgid "Print all elements"
msgstr "todos os elementos"

msgid "Print list of blacklisted files"
msgstr "Listagem de arquivos na lista negra"

msgid "List the plugin contents"
msgstr "Liste os conteúdos do plugin."

msgid ""
"A slashes ('/') separated list of types of elements (also known as klass) to"
" list. (unordered)"
msgstr ""
"Uma lista de tipos de elementos separados por barras inclinadas '/' (também "
"conhecida como 'klass'), que deve ser listada sem ordem algébrica."

msgid ""
"When checking if an element or plugin exists, also check that its version is"
" at least the version specified"
msgstr ""
"Verificem se um elemento ou plugin está presente durante a verificação, além"
" disso, confirme que sua versão é igual ou superior à indicada."

msgid "Could not load plugin file: %s\n"
msgstr ""
"Ao tentar carregar a arquivo de extensão do plugin, foi encontrada uma "
"falha. Arquivo não identificado ou inexistente."

msgid "Index statistics"
msgstr "Estatísticas de índice"

msgid "Got EOS from element \"%s\".\n"
msgstr "EOS foi recebido do elemento 'DE'."

msgid "FOUND TAG      : found by pad \"%s:%s\".\n"
msgstr "KENNZEICHEN GEFUNDEN: Encontrado por Padding »%s:%s«."

msgid "FOUND TAG\n"
msgstr "Fundo KENNZEICHEN"

msgid "FOUND TOC      : found by element \"%s\".\n"
msgstr "TOC GEFUNDEN: Encontrado pelo elemento »%s«."

msgid "WARNING: from element %s: %s\n"
msgstr "AVISO: Do elemento %s: %s\n"

msgid "Prerolled, waiting for buffering to finish...\n"
msgstr "Vorgelaufen, aguarde o fim do carregamento intermediário …"

msgid "Redistribute latency...\n"
msgstr "Redistribuição de latência …"

msgid "Interrupt while waiting for EOS - stopping pipeline...\n"
msgstr "Interrupção durante o espera por EOS - parada da linha de trabalho..."

msgid ""
"Do not output status information for the specified property if verbose "
"output is enabled (can be used multiple times)"
msgstr ""
"Não será exibida nenhuma informação da propriedade especificada se o modo de"
" saída detalhada estiver ativado (pode ser utilizado várias vezes)."

msgid "PROGRAM-NAME"
msgstr "NOM_PROPRIETÉ"

msgid "WARNING: erroneous pipeline: %s\n"
msgstr "AVISO : Leitura de linha com erro: %s"

msgid "ERROR: the 'pipeline' element wasn't found.\n"
msgstr "ERRO: O elemento »Roda de Transmissão» não foi encontrado."

msgid "Failed to set pipeline to PAUSED.\n"
msgstr "O encaminhamento para o modo PAUSIERT falhou."
