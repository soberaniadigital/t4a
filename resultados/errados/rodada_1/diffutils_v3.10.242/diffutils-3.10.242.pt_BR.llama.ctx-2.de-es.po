msgid "invalid argument %s for %s"
msgstr "argumento %s inválido para %s"

msgid "Valid arguments are:"
msgstr "Os argumentos válidos são:"

msgid "character special file"
msgstr "arquivo especial de caracteres especiais"

msgid "multiplexed block special file"
msgstr "ficheiro especial com blocos multiplexados"

msgid "port"
msgstr "porta"

msgid "stack overflow"
msgstr "desbordamento de pilha"

msgid "Try '%s --help' for more information."
msgstr "Tente '%s --help' para mais informações."

msgid "%s: option '%s%s' requires an argument\n"
msgstr "%s: a opção '%s%s' não permite argumento.\"\n"

msgid "%s: invalid option -- '%c'\n"
msgstr "%s: a opção -- '%c' é inválida"

msgid "'"
msgstr "»"

msgid "Success"
msgstr "Conseguiu."

msgid "Premature end of regular expression"
msgstr "Fim prematuro da expressão regular"

msgid "Unmatched ) or \\)"
msgstr "ou) desemparelhado"

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s. \n"

msgid "Written by %s, %s, and %s.\n"
msgstr ""
"Escrito por %s, %s e %s. \n"
"\n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s, %s e %s. \n"

msgid "General help using GNU software: <%s>\n"
msgstr "Ajuda geral sobre o uso de software GNU: <%s>"

msgid "unknown stream"
msgstr "fluxo desconhecido"

msgid "invalid --ignore-initial value %s"
msgstr "valor --ignore-initial inválido '%s'"

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=%d\n"
"      Escape the first %d bytes of input."

msgid "    --help                 display this help and exit"
msgstr "    --help                 Muestra esta ajuda e termina."

msgid "-v, --version              output version information and exit"
msgstr ""
"-v --versão               Mostrar o nome e a versão do software, depois "
"encerrar."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"Os parâmetros opcionais SAUT1 e SAUT2 indicam o número de bytes que se "
"escavam no início de cada arquivo (zero por padrão)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos obrigatórios para as opções longas são também necessários para"
" as opções curtas."

msgid "extra operand %s"
msgstr "operando extra '%s'"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s são distintos: byte %<PRIuMAX>, linha %<PRIuMAX>"

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: Fin de arquivo (EOF) em %s que está vazio."

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: Fin de arquivo (EOF) em %s após o byte %<PRIuMAX>"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Len Tower"
msgstr "Len Tower"

msgid "invalid tabsize %s"
msgstr "tamanho de tabulação %s inválido"

msgid "conflicting tabsize options"
msgstr "opções de tamanho de tabulação conflitantes"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   Indica somente se os arquivos são diferentes "
"ou não."

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     Gere um arquivo 'diff' no formato RCS."

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NÚM               limita a saída à no máximo NÚM colunas "
"impressas (130 por padrão)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             mostra apenas nas colunas esquerda as linhas "
"comuns"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=%s   Mostre a linha mais recente que corresponda ao"
" padrão %s."

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Estenda os tabuladores em espaços na saída."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=N              Os tabuiais de espaçamento são separados por N "
"(8 por padrão) colunas"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            Não siga links simbólicos."

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     Descarta diferenças entre maiúsculas e "
"minúsculas ao comparar os nomes de arquivos."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      descarta mudanças devidas à expansão de "
"tabs."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space     descarta espaços em branco ao final da "
"linha."

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines        descarta os alterações em linhas que estejam"
" completamente vazias."

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      Trata todos os arquivos como textos"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         elimina os retornos de carro finais na "
"entrada"

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser soit « antigo », « novo » ou « sem alterações ». GTYP é como "
"LTYPE ou 'mudado'."

msgid "    --help               display this help and exit"
msgstr "    --help               Mostra esta ajuda e termina a execução."

msgid "-v, --version            output version information and exit"
msgstr "-v --versao            exibe o nome e a versão do software e termina."

msgid "conflicting %s option value %s"
msgstr "o valor '%s' da opção %s é conflitante."

msgid "conflicting output style options"
msgstr "As opções de estilo de saída apresentam conflitos."

msgid "invalid color %s"
msgstr "cor da cor %s inválida"

msgid "-D option not supported with directories"
msgstr "a opção -D não pode ser usada com diretórios"

msgid "cannot compare '-' to a directory"
msgstr "não pode comparar '-' com um diretório"

msgid "'-' specified for more than one input file"
msgstr "para mais de um arquivo de entrada, use '--' como opção."

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          como -e, mas somente mostra os alterações que se"
" sobrepõem."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr ""
"-i                          Adiciona as ordens 'w' e 'q' aos scripts ed"

msgid "-a, --text                  treat all files as text"
msgstr "-a, --text                    Trata todos os arquivos como textos"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAMA utiliza PROGRAMA para comparar os arquivos."

msgid "%s: diff failed: "
msgstr "%s: diff falhou: "

msgid "invalid diff format; invalid change separator"
msgstr "formato de diff inválido; separador de cambio inválido."

msgid "invalid diff format; incomplete last line"
msgstr "formato de diff inválido; última linha incompleta."

msgid "internal error: invalid diff type passed to output"
msgstr "erro interno: tipo de diff inválido passado à saída"

msgid "%s: recursive directory loop"
msgstr "%s: bucle de directorio recursivo"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=ARQUIVO         Interactuar interativamente, enviando o "
"resultado para ARQUIVO."

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignora espaços em branco no final da linha"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    Descarta as diferenças na quantidade de espaço "
"em branco no arquivo\n"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     Ignora as alterações cujas linhas são todas em "
"branco."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      Suponha arquivos grandes e muitos pequenos "
"alterações dispersas."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAMA      Utilizar o PROGRAMA para comparar os "
"arquivos."

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar esta ajuda e finalizar."

msgid "-v, --version                output version information and exit"
msgstr ""
"-v --versão                 Mostrar o nome e a versão do software e "
"encerrar."

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Fusão côte a côte das diferenças entre os arquivos %s e %s."

msgid "cannot interactively merge standard input"
msgstr "não pode ser misturada interativamente com a entrada padrão."

msgid "both files to be compared are directories"
msgstr "Os dois arquivos a serem comparados são diretórios."
