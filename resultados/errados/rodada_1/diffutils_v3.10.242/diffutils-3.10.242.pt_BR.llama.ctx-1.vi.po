msgid "invalid argument %s for %s"
msgstr "argumento %s inválido para %s"

msgid "Valid arguments are:"
msgstr "Os argumentos válidos são:"

msgid "character special file"
msgstr "ficheiro especial caracteres"

msgid "multiplexed block special file"
msgstr "ficheiro especial com blocos multiplexados"

msgid "port"
msgstr "porta"

msgid "stack overflow"
msgstr "desbordeamento da pilha"

msgid "Try '%s --help' for more information."
msgstr "Utilize o comando “%s --help” para obter mais informações."

msgid "%s: option '%s%s' requires an argument\n"
msgstr "%s: a opção \"%s%s\" requer um argumento\n"

msgid "%s: invalid option -- '%c'\n"
msgstr "%s: a opção -- “%c” é inválida"

msgid "'"
msgstr "»"

msgid "Success"
msgstr "Sucesso"

msgid "Premature end of regular expression"
msgstr "Fim prématuramente da expressão regular"

msgid "Unmatched ) or \\)"
msgstr "Chão ou \") sem vis-à-vis\""

msgid "Written by %s and %s.\n"
msgstr "Écrit par %s et %s.\n"

msgid "Written by %s, %s, and %s.\n"
msgstr ""
"Técnico de Localização e Objetivo especializado em ambientes GNU/Linux, CLI "
"utilizados. Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr ""
"Técnico de Localização e Objetivo especializado em ambientes GNU/Linux, CLI "
"utilizados. Tradução específica para texto strings (msgid) do inglês para o "
"português brasileiro (pt-BR), conforme necessário para .po arquivos."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, and %s.\n"
msgstr ""
"Técnico de Localização e Objetivo especializado em ambientes GNU/Linux, CLI "
"utilizadores. Tradução específica para texto strings (msgid) do inglês para "
"o português brasileiro (pt-BR), conforme necessário para .po arquivos."

msgid "General help using GNU software: <%s>\n"
msgstr ""
"Ajuda geral sobre o uso dos softwares GNU: <https://www.gnu.org/gethelp/>"

msgid "unknown stream"
msgstr "fluxo desconhecido"

msgid "invalid --ignore-initial value %s"
msgstr "valor inválido para --ignore-initial `%s'"

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=%<PRIuMAX>      Escamoter les %d prime bytes des "
"entrées"

msgid "    --help                 display this help and exit"
msgstr "    --help                 hiêln thîs trôp giûy ròi thoát"

msgid "-v, --version              output version information and exit"
msgstr ""
"-v, --version               Exibe o nome e a versão do software e termina "
"após"

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"Os parâmetros opcionais SAUT1 e SAUT2 indicam o número de bytes a serem "
"escapados ao início de cada arquivo (zero por padrão)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os parâmetros necessários para as opções longas também são necessários para "
"as opções curtas."

msgid "extra operand %s"
msgstr "opção suplementar %s"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s são diferentes: byte %<PRIuMAX>, linha %<PRIuMAX>"

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: Encontrei o fim do arquivo (EOF) no campo %s que está vazio\n"

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: Encontrei o fim do arquivo (EOF) no %s após byte %<PRIdMAX>"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Len Tower"
msgstr "Torre de Len"

msgid "invalid tabsize %s"
msgstr "tamanho de tabulação %s inválido"

msgid "conflicting tabsize options"
msgstr "opções conflitantes de tamanho da tabulação com '%s' e '%d'"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   Indique somente se os arquivos diferem (diff)"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     gera um arquivo 'diff' no formato RCS"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=S%d                Limite a saída à no máximo S%<PRIuMAX> "
"colunas impressas (130 por padrão)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             Mostrar apenas as linhas duplicadas na coluna "
"esquerda da tabela"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   Mostre a linha mais recente associada ao RE"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Estenda os tabuleiros em espaços na saída"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=N              As tabulações de espaço são a cada N (8 por "
"padrão) colunas"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não segui o link simbólico"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     Ignore a diferença de maiúsculas e "
"minúsculas ao comparar nomes de arquivos"

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   Ignora as alterações relacionadas à expansão "
"das tabulações"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignora os espaços em branco finais da "
"linha"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines        Ignorar alterações em que todas as linhas "
"são brancas"

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      xử lý mọi tập tin là văn bản thường"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar caracteres de retorno de linha no "
"final da entrada\n"

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser \"antigo\", \"novo\", ou \"sem alteração\". GTYP é LTYPE ou "
"\"alterado\"."

msgid "    --help               display this help and exit"
msgstr "    --help               exibir esta ajuda e encerrar a execução"

msgid "-v, --version            output version information and exit"
msgstr ""
"-v --versao             apresentar o nome e a versão do software, depois "
"sair."

msgid "conflicting %s option value %s"
msgstr "valor conflictuoso do parâmetro '%s' com o valor '%s'"

msgid "conflicting output style options"
msgstr "múltiplas opções de estilo de saída conflituosas"

msgid "invalid color %s"
msgstr "cor da cor %s inválida"

msgid "-D option not supported with directories"
msgstr "a opção -D não trata os diretórios"

msgid "cannot compare '-' to a directory"
msgstr "não pode comparar o sinal negativo (-) com um diretório"

msgid "'-' specified for more than one input file"
msgstr "opção para mais de um arquivo de entrada -}"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          similar ao -e, mas apenas considera as "
"alterações que se sobrepõem às outras."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr ""
"-i                          Adicionar as comandas « w » e « q » ao script de"
" edição (ed)"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                    Trata todos os arquivos como textos padrão"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROG              Utilizar o PROGramme para comparar os "
"arquivos"

msgid "%s: diff failed: "
msgstr "%s: falha ao executar 'diff': "

msgid "invalid diff format; invalid change separator"
msgstr "formato de 'diff' inválido; separador de alteração inválido"

msgid "invalid diff format; incomplete last line"
msgstr "formato de 'diff' inválido; última linha incompleta."

msgid "internal error: invalid diff type passed to output"
msgstr "erro interno : tipo de \"diff\" inválido fornecido na saída"

msgid "%s: recursive directory loop"
msgstr "%s: bucle recursivo no diretório"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=FICHIER         Executar interativamente, com saída para "
"FICHIER"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignora os espaços em branco finais da "
"linha"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    Ignora as alterações no espaçamento entre "
"palavras\n"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     Ignora linhas em branco ao processar "
"alterações\n"

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      Suponha grandes arquivos e muitos pequenos "
"alterações espalhados"

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROG      Utilizar o PROGramme para comparar os arquivos"

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar esta ajuda e sair"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v, --version                Affirme o nome e a versão do software para você"
" e termine."

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Fusão côte a côte das diferenças dos arquivos."

msgid "cannot interactively merge standard input"
msgstr ""
"não podem interagir com o dado padrão de forma tão construtiva como antes"

msgid "both files to be compared are directories"
msgstr "Os dois arquivos a serem comparados são diretórios"
