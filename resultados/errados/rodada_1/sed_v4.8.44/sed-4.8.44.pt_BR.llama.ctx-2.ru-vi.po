msgid "unbalanced ["
msgstr "thiếu dấu ngoặc vuông mở ["

msgid "unfinished \\ escape"
msgstr "chave não concluída da sequência de escape \""

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "O caráter de comparação não é permitido."

msgid "Unmatched \\{"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid content of \\{\\}"
msgstr "“{}” contém conteúdo inválido."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\")” lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há mais regularidade para a linha anterior."

msgid "Written by %s.\n"
msgstr "Escreva por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrevam por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrevam por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escreva por %s, %s e %s. Eles são os autores da nossa aplicação."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Viết bởi %s, %s, %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Viết bởi %s, %s, %s, %s, %s, %s, %s e %s."

msgid "%s home page: <%s>\n"
msgstr "Trâng chú  %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos e/r/w interrompidos no modo de segurança do disco"

msgid "option `e' not supported"
msgstr "não há suporte ao parâmetro \"e\""

msgid "`e' command not supported"
msgstr "não há suporte para a comando “e”"

msgid "no input files"
msgstr "não há arquivos de entrada disponítable para ler."

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência inválida \\%d para a opção RHS «s»"

msgid "regex input buffer length larger than INT_MAX"
msgstr "comprimento do buffer de entrada regex maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed aqui foi traduzido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr ""
"O programa sed aqui foi traduzido, porém não contém suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
"  -n, --quiet, --silent\n"
"trocar para o modo silencioso ou sem saída de texto ao executar a operação automática do script."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 theo lienhoto de links simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU0] \n"
"                 modificar arquivo no local (cria cópia se HẬU0 for definido) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 coi các táp tin là riêng với nhau, chứ không phải đơn,\n"
"                 luồng liên tục."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox thực hiện no modo sandbox (tắt lệnh e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao instalar o modo de execução binário em “%s”"

msgid "read error on %s: %s"
msgstr "lẽio de leitura no %s: %s"
