msgid "unbalanced ["
msgstr "falha na verificação de equilíbrio do ângulo ["

msgid "unfinished \\ escape"
msgstr "chave não fechada \""

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível encontrar o código de erro"

msgid "Invalid collation character"
msgstr "Caracter não aceito para comparação"

msgid "Unmatched \\{"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid content of \\{\\}"
msgstr "Contém conteúdo inválido"

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc não par pairal entre `)’ ou ‘\\)’ lone di"

msgid "No previous regular expression"
msgstr ""
"Não há mais regularidade para acompanhar o progresso anteriormente "
"registrado."

msgid "Written by %s.\n"
msgstr "Escrita por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrita por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrita por %s, %s, %s, %s, %s, %s, %s e %s. \n"

msgid "%s home page: <%s>\n"
msgstr "Página principal de %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở «{» lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando `y` não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos e/r/w interrompidos no modo de segurança da caixa"

msgid "option `e' not supported"
msgstr "o parâmetro 'e' não é suportado"

msgid "`e' command not supported"
msgstr "a opção 'e' não é suportada"

msgid "no input files"
msgstr "não há arquivos de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência inválida \\%d para a RHS da instrução \"s\""

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"comprimento do buffer de entrada para expressão regular maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed aqui foi traduzido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste script não possui suporte ao SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
"  -n, --quiet, --silent\n"
"trocar para o modo de operação em loop automático com distância do padrão molda"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguindo sinais simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[HÁU_TÔ], --in-place[=HÁU_TÔ] \n"
"                 modificar arquivos no local (cria uma cópia, se o sufixo HÁU_TÔ for aplicado) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"  -s, --separate\n"
"                 separar arquivos individuais para cada um deles, e não como uma única sequência contínua."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 trabalhar em modo sandbox (desligar comandos e/w)\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "erro ao instalar o modo binário de compatibilidade para \"%s\""

msgid "read error on %s: %s"
msgstr "lỗi đọc trên %s: %s"
