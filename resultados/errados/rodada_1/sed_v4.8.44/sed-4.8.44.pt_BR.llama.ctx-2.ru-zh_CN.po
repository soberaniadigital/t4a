msgid "unbalanced ["
msgstr "não correspondente ["

msgid "unfinished \\ escape"
msgstr "sequência de escape não concluída"

msgid "? at start of expression"
msgstr "? no começo da expressão?"

msgid "+ at start of expression"
msgstr "+ no começo da expressão"

msgid "regular expression too big"
msgstr "expressão regular excessivamente grande"

msgid "no syntax specified"
msgstr "sem sintaxe especificada"

msgid "Invalid collation character"
msgstr "Caractere de agrupamento inválido"

msgid "Unmatched \\{"
msgstr "caracter não correspondente \\{\\}"

msgid "Invalid content of \\{\\}"
msgstr "Contenuto inválido em \\{\\}"

msgid "Premature end of regular expression"
msgstr "fim prematuro de uma expressão regular"

msgid "Regular expression too big"
msgstr "Ex Expressão regular muito grande"

msgid "Unmatched ) or \\)"
msgstr "ou ) não combinado"

msgid "No previous regular expression"
msgstr "Não há expressões regulares anteriores."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s, %s, %s e %s. \n"

msgid "%s home page: <%s>\n"
msgstr "%s de página inicial: <%s>"

msgid "unmatched `{'"
msgstr ""
"não é encontrada a correspondência para o símbolo de fechamento \"{}\" não "
"associado."

msgid "extra characters after command"
msgstr "caracteres desnecessários após a comando"

msgid "unterminated `y' command"
msgstr "comando `y` não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr ""
"As operações de leitura/escrita são desabilitadas no modo 'bacia de areia'."

msgid "option `e' not supported"
msgstr "a opção «e» não é suportada"

msgid "`e' command not supported"
msgstr "a comando «e» não é suportado"

msgid "no input files"
msgstr "não há arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\\%d inválida no membro direito da comando \"s\""

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"A tamanho do buffer de entrada da expressão regular é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "Este programa foi compilado para suportar SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed foi compilado sem suporte de SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"                 suprimir a escrita automática do espaço de motivos"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguir links simbólicos durante o processamento"

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 editar os arquivos em seu lugar (faz uma cópia se o SUFFIXE for especificado) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 opera no modo sandbox (desabilita as comandas e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "impossível de passar em modo binário sobre \"%s\""

msgid "read error on %s: %s"
msgstr "erro de leitura no %s: %s"
