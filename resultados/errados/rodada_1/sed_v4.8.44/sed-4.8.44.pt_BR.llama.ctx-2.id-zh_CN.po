msgid "%s home page: <%s>\n"
msgstr "%s 的主页：<%s>"

msgid "unmatched `{'"
msgstr "não há correspondência para '{{' não associada"

msgid "extra characters after command"
msgstr "caracteres desnecessários após a comando"

msgid "unterminated `y' command"
msgstr "comando ‘y’ não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "As operações de leitura/escrita são desabilitadas no balde de areia."

msgid "option `e' not supported"
msgstr "opção 'e' não é suportada."

msgid "`e' command not supported"
msgstr "a comando 'e' não é suportado"

msgid "no input files"
msgstr "não há ficheiro de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\\%d inválida no membro direito da comando \"s\""

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"A tamanho do buffer de entrada da expressão regular é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "Este programa foi compilado com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed foi compilado sem suporte de SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"supomover o modo de impressão automática do espaço dos padrões."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 Seguir sinais simbólicos durante o processamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 editar os arquivos em seu lugar (faz uma cópia de segurança se o SUFFIXE for fornecido) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de um único fluxo contínuo. "
"Para obter mais informações sobre esta opção, digite '--help'."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 opera em modo sandbox (desabilita as comandas e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "impossível de passar em modo binário sobre \"%s\""

msgid "read error on %s: %s"
msgstr "erro de leitura no arquivo %s: %s"
