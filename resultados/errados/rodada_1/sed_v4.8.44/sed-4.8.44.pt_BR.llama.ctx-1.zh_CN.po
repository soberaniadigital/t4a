msgid "unbalanced ["
msgstr "falha na verificação de alinhamento ortogonal ["

msgid "unfinished \\ escape"
msgstr "não foi possível encerrar a sequência de escape \""

msgid "? at start of expression"
msgstr "O biúchi não é válido."

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biuiuc chinh quy qua lomg"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "O carácter não é aceito para coleta legalmente"

msgid "Unmatched \\{"
msgstr "não foi possível encontrar o par (\"{}\")."

msgid "Invalid content of \\{\\}"
msgstr "“{}” contém conteúdo inválido."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\\)” lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há expressões regulares no caminho principal."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrita por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, e outros. \n"

msgid "%s home page: <%s>\n"
msgstr "%s de administrador: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando “y” não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos de e/r/w foram desabilitados no modo seguro do contêiner"

msgid "option `e' not supported"
msgstr "não há suporte para a opção ‘e’"

msgid "`e' command not supported"
msgstr "não há suporte para o comando 'e'"

msgid "no input files"
msgstr "não há nenhum arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "o comando '%d' não é válido para o lado direito da instrução 's'"

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"comprimento do buffer de entrada longo para regex excede o valor máximo "
"INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed neste caso foi traduzido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed deste código não inclui suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
"  -n, --quiet, --silent\n"
"trocar para o modo de operação em loop automático sem mensagens na distância do ponto final."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 Direcionar alterações diretamente no arquivo, seguindo sinais de ligação simbólica."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[HÁU_TÔ], --in-place[=HÁU_TÔ] \n"
"                 modificar diretamente o arquivo no local (criar backup se extensão for especificada) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                    Tratamento dos arquivos como separados e independentes uns dos outros, não como um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 Executar em ambiente sandbox (desligar comandos e/r/w)."

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo binário em `%s'"

msgid "read error on %s: %s"
msgstr "lỗi đọc trên %s: %s"
