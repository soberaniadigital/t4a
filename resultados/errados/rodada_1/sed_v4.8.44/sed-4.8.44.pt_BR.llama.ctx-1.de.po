msgid "unbalanced ["
msgstr "falha na verificação de ângulo retângulo fechado ["

msgid "unfinished \\ escape"
msgstr "não foi possível encerrar a sequência de escape \""

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "O biossímolso de cadeia não é válido."

msgid "regular expression too big"
msgstr "o biúchi está muito grande para ser um regular expressão"

msgid "no syntax specified"
msgstr "não foi possível verificar a sintaxe do código"

msgid "Invalid collation character"
msgstr "Caracter '%s' não é um operador de comparação válido."

msgid "Unmatched \\{"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid content of \\{\\}"
msgstr "O conteúdo dentro de {} é inválido."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm."

msgid "Regular expression too big"
msgstr "O biúchi é muito grande para ser processado"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\\)” lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há um padrão regular principal para a frente do caminho."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, e outros autores. \n"

msgid "%s home page: <%s>\n"
msgstr "Trang chủ %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở \"{\" lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos de E/R e/w desabilitados no modo seguro do sandbox"

msgid "option `e' not supported"
msgstr "não há suporte ao selecionar a letra 'e'"

msgid "`e' command not supported"
msgstr "não há suporte para o comando 'e'"

msgid "no input files"
msgstr "não há arquivos de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência inválida \\%d no lado direito (»RHS«) do comando \"s\""

msgid "regex input buffer length larger than INT_MAX"
msgstr "Comprimento do bônus de regex maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed aqui foi traduzido e contém suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed desta versão não oferece suporte ao SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
"  -n, --quiet, --silent\n"
"tornar o buffer de trabalho silencioso para operações automáticas. \n"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 folgt símbolos de ligação quando utilizado com -i."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HáU_Tanto], --in-place[=HáU_Tanto] \n"
"   altera a ficheira de entrada (cria uma cópia salva no disco, se HáU_Tanto for especificado) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 separa as pastas de dados para que cada uma seja tratada individualmente e não como um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 trabalha no modo sandbox (e/r/w comandos são desabilitados).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir tabela %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo de operação binário para \"%s\""

msgid "read error on %s: %s"
msgstr "Lỗi đọc trên %s: %s"
