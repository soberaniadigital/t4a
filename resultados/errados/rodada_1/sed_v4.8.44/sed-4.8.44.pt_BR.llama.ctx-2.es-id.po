msgstr "[ descompensado}"

msgid "unfinished \\ escape"
msgstr ""
"sequência de escape \n"
" não terminada"

msgid "? at start of expression"
msgstr "? ao princípio da expressão?"

msgid "+ at start of expression"
msgstr "+ al inicio de la expresión"

msgid "regular expression too big"
msgstr "expresão regular demasiado grande"

msgid "no syntax specified"
msgstr "não há sintaxe especificada"

msgid "Invalid collation character"
msgstr "Caráctere de reorganização inválido"

msgid "Unmatched \\{"
msgstr "{ sin pareja}"

msgid "Invalid content of \\{\\}"
msgstr "Contenido inválido de \\{\\}"

msgid "Premature end of regular expression"
msgstr "Fim prematuro de uma expressão regular"

msgid "Regular expression too big"
msgstr "Ex Expressão regular excessivamente grande"

msgid "Unmatched ) or \\)"
msgstr ") ou ) sin pareja"

msgid "No previous regular expression"
msgstr "Não há uma expressão regular previamente definida."

msgid "Written by %s.\n"
msgstr "Escrito por %s. \n"

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s. \n"

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e y %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrito por %s, %s, %s, \n"
"%s, %s, %s, %s,\n"
" e y %s. \n"

msgid "%s home page: <%s>\n"
msgstr "%s página inicial de <%s>"

msgid "unmatched `{'"
msgstr "{ 'sin pareja'}"

msgid "extra characters after command"
msgstr "caracteres desnecessários após a comando"

msgid "unterminated `y' command"
msgstr "comando 'y' não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr ""
"As operações de leitura/escrita estão desabilitadas no modo 'bac a areia'."

msgid "option `e' not supported"
msgstr "a opção 'e' não é suportada."

msgid "`e' command not supported"
msgstr "a comando 'e' não é suportado"

msgid "no input files"
msgstr "não há arquivos de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\\%d inválida no lado direito da instrução `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"a tamanho do buffer de entrada da expressão regular é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "Este programa foi compilado para suportar SELinux."

msgid "This sed program was built without SELinux support."
msgstr "Este programa sed está compilado sem suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"supõe a eliminação da escrita automática do espaço de padrões."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"siga os links simbólicos durante o processamento no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 edita ficheros em seu lugar (crie um backup se o SUFFIXE for dado) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os ficheros como separados em vez de um único fluxo, longo e "
"continuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 opera em modo sandbox (desabilita as ordens e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "não foi possível passar em modo binário no arquivo %s"

msgid "read error on %s: %s"
msgstr "erro de leitura no arquivo %s: %s"
