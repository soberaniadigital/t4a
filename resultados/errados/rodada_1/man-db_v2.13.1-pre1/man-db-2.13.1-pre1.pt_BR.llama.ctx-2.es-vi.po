msgid "warning: %s: ignoring bogus filename"
msgstr "cảnh báo: %s: se encerra o nome inválido do arquivo de texto"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém que use a função 'setuid' \"%s\""

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr "Caminho de dados %s corrompido; reconstrua com 'mandb -- create'."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cảnh báo: %s é a versão %s, necessita de %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN] (Manuscript)"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão tem o valor definido como %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr "coloque o DREAM_PATH para navegar pelos links de diretório do manual"

msgid "man command failed with exit status %d"
msgstr "lêm hãm fallada com trạng thái thoát %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória do índice %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o armazenamento de memória temporária %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"A actualização do banco de dados temporário para a rota '%s/%s' está em "
"andamento. Por favor, espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tarefa de limpeza dos dados antigos da base de dados em %s..."

msgid "look for pages case-insensitively (default)"
msgstr "não há diferença de capitalização ao procurar (padrão)"

msgid "look for pages case-sensitively"
msgstr "phân biệt chữ HOA/thường khi tìm"

msgid "FILE..."
msgstr "TẾ_TRANSFIERE…"

msgid "parse as man page"
msgstr "análise de página man bonita"

msgid "parse as cat page"
msgstr "análise de página cat"

msgid "%s: incompatible options"
msgstr "%s: cossenos não são compatíveis entre si"

msgid "reset all options to their default values"
msgstr ""
"adicione novamente todos os valores padrão para as configurações "
"selecionadas."

msgid "Main modes of operation:"
msgstr "Modos principais de operação:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "o catman é utilizado para redesenhar as páginas do site antigo."

msgid "Finding manual pages:"
msgstr "Em busca de guias do manual:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "empregue %s para definir o layout da página"

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "OPÇÃO_INVÁLIDA"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizando groff e exibindo através de gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utiliza o groff e impede que ele crie ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual trângulo de ajuda deseja?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de usuário para %s na seção %s"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"lệnh \"mandb\" (sistema de dados direcionador) encontrou erro com o estado "
"de saída %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"erro interno do sistema operacional: tipo de entrada %d fora da faixa "
"aceita."

msgid " Manual page "
msgstr "Trâng de diretrizes"

msgid "must specify an output encoding"
msgstr "é necessário especificar uma codificação de saída para o arquivo"

msgid "can't write to standard output"
msgstr "não é possível escrever por saída padrão"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN] (Man Path)"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua o aviso 'giả'."

msgid "don't purge obsolete entries from the dbs"
msgstr "não faça upload de mensagens antigas para o banco de dados."

msgid "FILENAME"
msgstr "TÊN_TẬP_TIN"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar os guias de manuais sob %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso: não há diretivas 'MANDB_MAP' no %s, será utilizada a sua rota de "
"saída (manpath)."

msgid "No databases created."
msgstr "Não foi possível criar a base de dados."

msgid "warning: $MANPATH set, inserting %s"
msgstr "cão báfio: típaro de $MANPATH (diretório de busca), adicionando %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "cão báfio: típaro de $MANPATH (diretório de busca), saindo %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso: não há diretório de arquivos %s obrigatório"

msgid "warning: %s does not begin with %s"
msgstr "cão báfio: %s não começa com %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Ao verificar o diretório, encontramos arquivos cat desordenados sob %s…"

msgid "do not trim output to terminal width"
msgstr ""
"não faça alterações no dispositivo final sem a devida análise e planejamento"
" para garantir o uso adequado da largura do terminal."

msgid "warning: %s contains a pointer loop"
msgstr "cão de guarda: %s contém um bucle de puntero (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: nenhum agradável encontrado. (sem nada adequado)"

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: cargas solicitadas .so anidadas profundamente ou recursivamente"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: cảnh báo: yêu cầu '.lf' có chứa ký tự dòng mới nên bỏ qua"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
