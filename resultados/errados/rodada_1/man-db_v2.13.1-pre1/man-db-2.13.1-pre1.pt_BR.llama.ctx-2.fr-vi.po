msgid "warning: %s: ignoring bogus filename"
msgstr "cão báfio: %s: saindo do nome de arquivo errado, ignorado"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém que possa usar a função 'setuid' \"%s\""

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de ficheiro %s está corrompido; reexecute o comando 'mandb -- "
"create' para criar um novo."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cão báfio: %s é a versão %s, necessita de %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN] (Base de donneios do homem)"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"configuração do caminho de pesquisa para os manuals da linha de comando "
"chamado LINUX_PATH"

msgid "man command failed with exit status %d"
msgstr ""
"lêm hãy tentar novamente, pois o comando 'man' falhou devido ao código de "
"saída %d."

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória temporária do arquivo %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de memória %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"A atualização do cache de memória para o caminho '%s/%s' está em andamento. "
"Por favor, espere…"

msgid "Purging old database entries in %s...\n"
msgstr "Ao tarefa de limpeza dos dados antigos no %s…"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há diferença de tratamento entre as letras maiúsculas e minúsculas ao "
"procurar por páginas (padrão)"

msgid "look for pages case-sensitively"
msgstr "phân biệt chữ HOA/thường khi tìm"

msgid "FILE..."
msgstr "TẾ_TRÊS…"

msgid "parse as man page"
msgstr "análise de documento limpo para orientação manual do usuário."

msgid "parse as cat page"
msgstr "análise de padrões no catálogo digital"

msgid "%s: incompatible options"
msgstr "%s: cossenos de opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr "adicione novamente todos os valores padrão das opções"

msgid "Main modes of operation:"
msgstr "Modos operacionais principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"utilizado por catman para reformatar as páginas antigas do site de gatos"

msgid "Finding manual pages:"
msgstr "Em busca de guias de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para definir o layout da página"

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "RESOLUÇÃO_DE_PROBLEMA"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e forceie para que ele crie ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual guia de usuário você deseja acessar?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de usuário para %s na seção %s"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"lệnh \"mandb\" (sistema de dados direcionado) encontrou erro com o código %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"erro de nível interno: o tipo candidato %d está fora do alcance da linha "
"%<PRIuMAX>."

msgid " Manual page "
msgstr "Trâng de diretrizes"

msgid "must specify an output encoding"
msgstr ""
"é necessário indicar o código de saída para a tabela de resultados ser "
"gerada corretamente."

msgid "can't write to standard output"
msgstr "não é possível escrever para a saída padrão"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN] (Manual)"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, remova a barreira de aviso 'giá'"

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova informações antigas da base de dados."

msgid "FILENAME"
msgstr "TÊN_TẬP_TIN"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas do manual sob %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso: não há chave de diretório 'MANDB_MAP' no %s, portanto será utilizado "
"o caminho especificado pelo usuário."

msgid "No databases created."
msgstr "Não foi possível criar a base de dados."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"cão báfio: agrupamento do caminho $MANPATH (diretório de busca), atualmente "
"inscrevendo %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr ""
"cão báfio: agrupamento do caminho $MANPATH (diretório de busca), atualmente "
"em %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cão báfio: não há pasta de arquivo %s requerida"

msgid "warning: %s does not begin with %s"
msgstr "cão bágua: %s não começa por %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Ao verificar o diretório, encontramos rapidamente a pasta 'cat' sob %s…"

msgid "do not trim output to terminal width"
msgstr "não faça a exportação para uma largura uniforme do dispositivo final"

msgid "warning: %s contains a pointer loop"
msgstr "cão de guarda: %s contém um vórtice constrói (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr ""
"%s: nenhum agradável encontrado. Clique em 'OK' para continuar ou na opção "
"'Cancelar' se preferir não prosseguir."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: requetes .so imbriquées trop profondément ou récursivement"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: cảnh báo: yêu cầu '.lf' có chứa ký tự dòng mới nên bỏ qua"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
