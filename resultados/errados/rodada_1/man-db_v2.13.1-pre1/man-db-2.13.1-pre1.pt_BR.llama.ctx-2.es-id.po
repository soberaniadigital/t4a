msgid "warning: %s: ignoring bogus filename"
msgstr "peringatamento: %s: está ignorando o nome de um arquivo falsificado"

msgid "the setuid man user \"%s\" does not exist"
msgstr "Não há ninguém com a capacidade de usar o modo 'setuid' \"%s\"."

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s ter corrompido; construa novamente utilizando o comando "
"'mandb -- create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr "peringatan: %s adalah versi %s, mengharapkan %s\n"

msgid "[MAN DATABASE]"
msgstr "[ID DO SITE DE DADOS DA MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão possui o valor %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"coloca o DẦN_DƯỜNG para a direção do caminho de pesquisa que leva aos guias "
"da referência manual em DIREÇÃO"

msgid "man command failed with exit status %d"
msgstr "comando \"man\" falhou ao sair com status %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar a memória de cache do índice %s"

msgid "can't create index cache %s"
msgstr "não é possível criar a memória de cache do índice %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de índices para caminho '%s/%s'. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação cargas de informações antigas na base de dados no %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há discriminação de maiúsculas e minúsculas para o termo HOA/thường ao "
"realizar uma pesquisa padrão."

msgid "look for pages case-sensitively"
msgstr "falha na busca devido a diferenças nas maiúsculas e minúsculas."

msgid "FILE..."
msgstr "ID_TIN..."

msgid "parse as man page"
msgstr "análise positiva do layout da página man"

msgid "parse as cat page"
msgstr "análise de página do catálogo"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"reinstale todos os valores padrão para as configurações definidas "
"anteriormente."

msgid "Main modes of operation:"
msgstr "Modo operacional principal:"

msgid "equivalent to whatis"
msgstr "tão semelhante ao whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"o catman utilizou o comando '%s' para reformular os artigos cat antigos."

msgid "Finding manual pages:"
msgstr "Estou procurando o guia de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "Use o %s para definir a estrutura da página."

msgid "use %s with selected device"
msgstr "utilize o %s com a ferramenta que foi escolhida"

msgid "RESOLUTION"
msgstr "ID_DETALHAMENTO"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique pressão nele para gerar ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual trângulo de controle você deseja?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guias de estilo para %s na seção %s\n"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s para edição"

msgid "mandb command failed with exit status %d"
msgstr ""
"falha ao executar o comando 'mandb' (gerenciador de base de dados) no estado"
" de saída %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"erro interno do sistema operacional: tipo candidato %d fora dos limites "
"permitidos (fora da faixa de valores)"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário especificar a codificação de saída do arquivo"

msgid "can't write to standard output"
msgstr "não é possível gravar no fluxo padrão de saída."

msgid "CODE[:...]"
msgstr "CÓDE[:...]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN] (ID)"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, trunca a barreira de aviso 'falso'"

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não remova entradas antigas da base de dados do sistema operacional "
"localizador e orientador para navegação em sistemas Linux com CLI."

msgid "FILENAME"
msgstr "ID_NOMBREFICHERO"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de manual sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"peringatança: não há diretório de mapa (MANDB_MAP) no %s, utilizando a rota "
"do usuário."

msgid "No databases created."
msgstr "Não há uma base de dados criada ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr "aviso de erro: $MANPATH estabelecida, inserindo %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "peringatamento: $MANPATH configurado, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso de cancelamento: diretório %s não encontrado"

msgid "warning: %s does not begin with %s"
msgstr "peringatamento: %s não iniciou com %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Fazendo verificação no cat terceiro abaixo %s...\n"

msgid "do not trim output to terminal width"
msgstr ""
"não faça o export do sinal para a largura completa da tela de dispositivo "
"final"

msgid "warning: %s contains a pointer loop"
msgstr "cảnh báo: %s contém um vórtice de ponteiro (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: permissões .so conflitantes excessivamente complexas ou recursivas\n"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: nova linha em permissão .lf, se ignorar"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
