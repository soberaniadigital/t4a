msgid "warning: %s: ignoring bogus filename"
msgstr "aviso: %s: o nome do arquivo foi ignorado devido a ser inválido"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não existe um usuário para configurar o programa 'setuid' do %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s danificado; recomece com a instrução 'mandb -- create'."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "aviso: %s é a versão %s, requer %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão tem o valor definido como %s%s."

msgid "can't open %s for reading"
msgstr "não foi possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"Adicione o caminho de pesquisa para as páginas de ajuda na variável PATH."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou ao sair com código de estado %d"

msgid "can't update index cache %s"
msgstr "não foi possível atualizar o cache de memória do local %s"

msgid "can't create index cache %s"
msgstr "não foi possível criar um cache de memória para o livro %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória do índice para caminho `%s/%s'. Por "
"favor, espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao processar os arquivos de log antigos na pasta %s..."

msgid "look for pages case-insensitively (default)"
msgstr ""
"não faz distinciação entre maiúsculas e minúsculas ao procurar (padrão)"

msgid "look for pages case-sensitively"
msgstr "falta de consideração ao registro durante a pesquisa"

msgid "FILE..."
msgstr "Título do arquivo..."

msgid "parse as man page"
msgstr "analisar a página de manequim com detalhes"

msgid "parse as cat page"
msgstr "analisar o padrão da página cat"

msgid "%s: incompatible options"
msgstr "%s: cossenários de opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr ""
"redefinir todos os valores padrão para as configurações definidas "
"manualmente."

msgid "Main modes of operation:"
msgstr "modos de operação principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "Utilizado o catman para reformular as páginas do gato antigas."

msgid "Finding manual pages:"
msgstr "Em busca de guias de ajuda:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para formatar a página"

msgid "use %s with selected device"
msgstr ""
"utilize o %s com a ferramenta selecionada para uso em dispositivos "
"específicos."

msgid "RESOLUTION"
msgstr "Solução de Problemas"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizando groff e exibindo através de gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e impeça que ele crie ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual guia de ajuda você precisa?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de trânsito para %s no menu %s."

msgid "can't open temporary file %s"
msgstr "não foi possível abrir o arquivo temporário %s para edição"

msgid "mandb command failed with exit status %d"
msgstr ""
"lệnh 'mandb' (comando de gerenciamento do banco de dados) encontrou um erro "
"ao sair com estado %d"

msgid "internal error: candidate type %d out of range"
msgstr "erro de nível inferior: tipo de candidato %d está fora do escopo"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação da tabela de saída para o programa"

msgid "can't write to standard output"
msgstr "não foi possível armazenar no padrão de saída"

msgid "CODE[:...]"
msgstr "Código de codificação[:...]"

msgid "[MANPATH]"
msgstr "[MANPATH]"

msgid "work quietly, except for 'bogus' warning"
msgstr ""
"chute im, exclua avisos 'fictícios' e continue a execução sem interrupções"

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova mensagens antigas do banco de dados"

msgid "FILENAME"
msgstr "Nome do Arquivo"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de ajuda sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há a diretiva 'MANDB_MAP' no arquivo '%s', portanto, será"
" utilizado o caminho do manual que você especificou."

msgid "No databases created."
msgstr "Não há bases de dados criadas."

msgid "warning: $MANPATH set, inserting %s"
msgstr "aviso de segurança: encontrada a variável $MANPATH, inserindo %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "aviso de segurança: encontrado o caminho $MANPATH, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso de erro: não há diretório obrigatório %s"

msgid "warning: %s does not begin with %s"
msgstr "aviso: a linha %s não começa com o caractere '%c'"

msgid "Checking for stray cats under %s...\n"
msgstr "Fazendo verificação de cat em %s...\n"

msgid "do not trim output to terminal width"
msgstr "não faça upload de dados para o tamanho do display da máquina final"

msgid "warning: %s contains a pointer loop"
msgstr "cão de alerta: %s contém um vórtice (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado para você."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: các requisições .so lõu nhau quá sâu hoặt bị đệ quy."

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: a linha nova em .lf requisitada, ignorada\n"

msgid "compatibility switch (ignored)"
msgstr "opções de compatibilidade para o objetivo do software (ignoradas)"
