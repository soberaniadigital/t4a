msgid "warning: %s: ignoring bogus filename"
msgstr "cảnh báo: %s: é ignorado o nome inválido do arquivo"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém que possa usar a função 'setuid' '%s'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s danificado; realize a reconstrução utilizando o comando "
"'mandb -- create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cảnh báo: %s é a versão %s, necessita de %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN] (Manual de Formatos)"

msgid "The man database defaults to %s%s."
msgstr "Công trình dữ liệu chính có giá trị mặc định là %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr "coloca o caminho de pesquisa para navegar entre as páginas de ajuda"

msgid "man command failed with exit status %d"
msgstr ""
"lệnh 'man' não teve sucesso ao sair do estado de escape (código de saída %d)"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória temporária do arquivo %s"

msgid "can't create index cache %s"
msgstr "não é possível criar um cache temporário de memória para o livro %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"A atualização do cache de memória temporária para o caminho `%s/%s` está em "
"andamento. Por favor, espere…"

msgid "Purging old database entries in %s...\n"
msgstr ""
"Ao processar os arquivos de log antigos no %s, pode haver erros que precisam"
" ser tratados."

msgid "look for pages case-insensitively (default)"
msgstr "não é comum ignorar o caso da letra HOA ao procurar (padrão)"

msgid "look for pages case-sensitively"
msgstr "phân biệt chữ HOA/thường khi tìm"

msgid "FILE..."
msgstr "TẾ_TRÊS…"

msgid "parse as man page"
msgstr "análise de página bem feita para interface do usuário manual"

msgid "parse as cat page"
msgstr "análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"adicionar novamente todos os valores padrão para as configurações "
"selecionadas"

msgid "Main modes of operation:"
msgstr "Modos de operação principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "o catman é utilizado para reformular as páginas do cat antigas"

msgid "Finding manual pages:"
msgstr "Em busca de guias de referência:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para definir o layout da página"

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "RESOLUÇÃO_DE_PROBLEMAS"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizando groff e exibindo através de gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e pressione a tecla para gerar ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual guia de ajuda você precisa?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de opções para %s no menu %s\n"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s para edição"

msgid "mandb command failed with exit status %d"
msgstr ""
"lệnh \"mandb\" (sistema de dados direcionado) encontrou erro com o estado "
"salvo como %d"

msgid "internal error: candidate type %d out of range"
msgstr "lỗi nội bộ: kiểu ứng cử %d nằm ngoài phạm vi."

msgid " Manual page "
msgstr "Trâng de direção"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação da tabela de saída do programa."

msgid "can't write to standard output"
msgstr "não é possível escrever no fluxo padrão de saída"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua aviso 'falso'"

msgid "don't purge obsolete entries from the dbs"
msgstr "não tire informações antigas do banco de dados."

msgid "FILENAME"
msgstr "TÊN_TẬP_TIN"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar os painéis de diretrizes em %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso: não há a diretiva 'MANDB_MAP' no %s, portanto será utilizado seu "
"caminho de saída manual."

msgid "No databases created."
msgstr "Não há base de dados criada."

msgid "warning: $MANPATH set, inserting %s"
msgstr "cảnh báo: tập hợp '$MANPATH' (đường dẫn hướng dẫn), đang chèn %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr ""
"cão báfio: agrupamento do caminho $MANPATH (diretório de busca), sendo "
"removido %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cão báfio: não há diretório de arquivos obrigatório %s"

msgid "warning: %s does not begin with %s"
msgstr "cảnh báo: %s không bắt đầu bằng %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Ao verificar o cat em %s, encontramos resultados rápidos..."

msgid "do not trim output to terminal width"
msgstr ""
"não remova o xenofílico de saída para a largura completa do dispositivo "
"final"

msgid "warning: %s contains a pointer loop"
msgstr "cảnh báo: %s contém um ciclo de referência (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr ""
"%s: nenhum item adequado encontrado. Clique em 'OK' para continuar ou na "
"opção 'Cancelar' se preferir não prosseguir."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: các yêu cầu '.so' lồng nhau quá sâu hoặc bị đệ quy."

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr ""
"%s:%d: cálculo de localização para o novo ponto %<PRIuMAX> concluído. Ponto "
"atualizado no arquivo .lf."

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
