msgid "warning: %s: ignoring bogus filename"
msgstr "cão de guarda: %s: o nome do arquivo inválido será ignorado"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não existe um usuário com privilégio \"setuid\" \"%s\""

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Sistema de dados %s danificado; execute o comando 'mandb -- create' para "
"recriá-lo."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cảnh báo: %s là phiên bản %s, cần %s\n"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN] - [HANDBUCHDATENBANK]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "o arquivo %s não pode ser aberto para leitura."

msgid "set search path for manual pages to PATH"
msgstr ""
"Defina o caminho de navegação para localizar as páginas guias do manual."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou com status de saída %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória do log %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de memória para a lista %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de índices para a rota `%s/%s'. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação các mục tin cơ sở dữ liệu khác trong %s…"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não é permitido discriminar entre maiúsculas e minúsculas ao procurar por "
"HOA/thường (padrão)"

msgid "look for pages case-sensitively"
msgstr "faltando ao seu respeito, HOA/thường khi tìm"

msgid "FILE..."
msgstr "TARDE_TRABALHADO..."

msgid "parse as man page"
msgstr "análise de página man atualizada"

msgid "parse as cat page"
msgstr "análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: opções incompatíveis"

msgid "reset all options to their default values"
msgstr "redefinir todos os valores padrão para as configurações selecionadas."

msgid "Main modes of operation:"
msgstr "Modos principais de operação:"

msgid "equivalent to whatis"
msgstr "substituto para 'whatis'"

msgid "used by catman to reformat out of date cat pages"
msgstr "o catman foi utilizado para reformular as páginas cat antigas"

msgid "Finding manual pages:"
msgstr "Encontrando as páginas de diretrizes:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "%s para formatar a página."

msgid "use %s with selected device"
msgstr "%s utilizado com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "DEFEZA A PARADISEIA GERAL"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e epbuco para gerar ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual caminho de ajuda deseja?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de linha para %s no capítulo %s disponível."

msgid "can't open temporary file %s"
msgstr "não é possível abrir a pasta temporária %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"Erro ao executar o comando 'mandb' (gerenciador de dados) com status de "
"saída %d."

msgid "internal error: candidate type %d out of range"
msgstr "erro de nível interno: tipo candidato %d fora do intervalo permitido"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação de saída para o arquivo"

msgid "can't write to standard output"
msgstr "não é possível escrever por saída padrão"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[CAMINHO_DO_MANUSCRITO]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua aviso 'erro' e continue trabalhando."

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não é permitido sair do local de armazenamento dos dados sem remover "
"entradas antigas das caixas de entrada"

msgid "FILENAME"
msgstr "NOMBREFICHERO_TINA"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de ajuda sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há diretivas 'MANDB_MAP' no arquivo %s, portanto será "
"utilizado o caminho do manual (manpath) para orientação."

msgid "No databases created."
msgstr "Não há nenhuma base de dados criada ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"cão de guarda: tápia hóspede '$MANPATH' (diretório caminho), adicionando %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "cão de guarda: tápacho $MANPATH (diretório caminho), %s será ignorado"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso de erro: o diretório %s não existe"

msgid "warning: %s does not begin with %s"
msgstr "cão bágua: %s não começa com %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Fazendo uma verificação no diretório %s para arquivos 'cat' ausentes..."

msgid "do not trim output to terminal width"
msgstr "não é permitido exportar para a largura completa do dispositivo final"

msgid "warning: %s contains a pointer loop"
msgstr "cão de guarda: %s contém um vínculo circular (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: cargas .so simultâneas são muito profundamente aninhadas ou "
"recursivas\n"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr ""
"%s:%d: Aviso: Linha de aviso em solicitação '.lf': a linha foi adicionada e "
"será ignorada."

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
