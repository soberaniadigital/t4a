msgstr "Berkas %s dan %s identik\n"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opções não compatíveis"

msgid "'-' specified for more than one input file"
msgstr "'--' especifica mais de um arquivo de entrada"

msgid "read failed"
msgstr "falha na leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exiba todas as alterações e conflitos no "
"documento\n"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"--ed                    excluir script ed que contém alterações de OLDFILE "
"para YOURFILE e salvar no MYFILE\n"

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap          seperati como -e mas apit conflitos na caixa de "
"entrada/saída"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             seperti -e, tapi hanya melibatkan perubahan yang"
" tidak bertindih"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          seperati como -e, mas somente conterá alterações"
" que tenham sobreposição"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          seperti -x, tapi apit konflik dalam kurung"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          imbuhkan perintah 'w' e 'q' ke skrip ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"--merge                 Descarte o arquivo realmente concatenado, de acordo "
"com -A se nenhuma outra opção for especificada."

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                    Aplique a todos os arquivos como texto para "
"processamento\n"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     apagar retorno de carro no final da entrada"

