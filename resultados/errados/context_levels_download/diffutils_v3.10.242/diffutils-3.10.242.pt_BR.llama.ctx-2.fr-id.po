msgstr "Subdirektori sama: %s dan %s\n"

msgid "Only in %s: %s\n"
msgstr "Hanya dalam %s: %s\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr "A berkas %s adalah %s sementara berkas %s adalah %s\n"

