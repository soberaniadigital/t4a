msgstr ""
"-E, --ignore-tab-expansion   abaixar alterações decorrentes da expansão das "
"tabulações\n"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignorar espaços em branco no final da "
"linha\n"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    Ignore os alterações no espaçamento entre "
"palavras"

