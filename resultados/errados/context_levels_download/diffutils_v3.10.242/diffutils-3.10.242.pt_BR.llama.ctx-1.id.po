msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed: Ubata lal gunakan keduanya versi, dekorasikan dengan header. \n"
" eb: Ubat lal gunakan keduanya versi. \n"
" el atau e1: Edit lalu gunakan versinikri. \n"
" er atau e2: Edit lalu gunakan versionorangka. \n"
" e: Edit versinya baru. \n"
" l  atau e1: Gunaka versinikri. \n"
" r  atau e2: Gunaka versionorangka. \n"
" s: Sertukatnya linur bersama diam-diam. \n"
" v: Sertukatnya linur bersama verbose. \n"
" q: Keluar."

