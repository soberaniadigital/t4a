msgid "-b, --print-bytes          print differing bytes"
msgstr "-b, --print-bytes          tampilque bytes que sao diferentes."

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=SKIP         leva SKIP byte awal dali kedua masukan"

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:%d SKIP2:%<PRIuMAX> bytes at the beginning of "
"FILE1 and FILE2\n"

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose              exibe cada byte e todos os valores diferentes de "
"bytes que possui o arquivo."

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr ""
"-n, --bytes=LIMIT          bandar o maior número de bytes possíveis LIMIT "
"byte"

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s, --quiet, --silent      cegue todas as saídas normais\n"

msgid "    --help                 display this help and exit"
msgstr "    --help                 Mostrar ajuda para este comando e sair."

msgid "-v, --version              output version information and exit"
msgstr "-v, --version              Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "Penggunaan: %s [PILIHAN]... BERKAS1 [BERKAS2 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandingkan dua berkas byte per byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 dan SKIP2 adoram ser o número de bytes que devem ser pulados no início"
" de cada arquivo (valor padrão é zero)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"O argumento '%s' deve ser opção de longa duração, além da breve. Abreviações"
" não são permitidas."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Nilai SKIP dapat sering diikuti oleh suffiks perkalian berikut:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, dan seterusnya untuk T, P, E, Z, Y."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se o arquivo for '-' ou não existir, ler a entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"Status de saída é 0 se o input for igual, 1 se diferente e 2 se houver erro."

msgid "invalid --bytes value %s"
msgstr "nilai %s --byte não é válido"

msgid "missing operand after %s"
msgstr "não há operando após %s"

msgid "extra operand %s"
msgstr "operando extra %s"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s berbeda: byte %<PRIdMAX>, linha %<PRIdMAX>"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX> is %3o %s %3o %s\n"
msgstr "%s %s berbeda: byte %<PRIdMAX>, baris %<PRIdMAX> adalah %3o %s %3o %s"

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF pada %s que está vazio"

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF pada %s setelah byte %<PRIdMAX>"

