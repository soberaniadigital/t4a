msgstr ""
"-3, --easy-only             semelhante ao -e, mas apenas envolve alterações "
"que não sejam interdependentes"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          seperta -e, mas somente com alterações que "
"conectem (se sobrepõem)"

