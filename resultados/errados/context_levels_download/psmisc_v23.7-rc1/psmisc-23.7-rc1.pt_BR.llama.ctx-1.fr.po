msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"           killall -l, --list\n"
"       killall -V, --version\n"
" \n"
"--exact          requer uma concordância porfeita dos nomes muito longos\n"
"--ignore-case      pesquisa ignorando a diferença de maiúsculas e minúsculas\n"
"--process-group    termina o grupo associado ao programa em vez do próprio processo\n"
"--younger-than     termina os programas criados antes da hora HORA_GIAN\n"
"--older-than       termina os programas criados depois da hora HORA_GIAN\n"
"--interactive      solicita confirmação prévia ao término dos processos\n"
"--list             lista todos os nomes de sinal conhecidos\n"
"--quiet            não exibe as notificações adicionais (_im_\n"
"--regexp           interpreta NOM como uma expressão regular estendida\n"
"--signal SIGNAL    envia esse sinal ao invés do padrão SIGTERM\n"
"--user UTILISATEUR termina apenas os programas utilizados por este usuário específico\n"
"--verbose          notifica se o sinal foi enviado com sucesso\n"
"--version         exibe informações sobre a versão do programa\n"
"--wait             aguarda que os processos terminem antes de continuar\n"
"--ns PID           atua nos processos pertencentes ao mesmo espaço nome/PID especificado"

