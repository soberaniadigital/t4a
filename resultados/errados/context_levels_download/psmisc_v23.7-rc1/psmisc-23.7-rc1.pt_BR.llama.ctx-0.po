msgid ""
"Usage: pidof [ -eg ] NAME...\n"
"       pidof -V\n"
"\n"
"    -e      require exact match for very long names;\n"
"            skip if the command line is unavailable\n"
"    -g      show process group ID instead of process ID\n"
"    -V      display version information\n"
"\n"
msgstr ""
"Cách de uso:\n"
"\n"
"pidof [-e]\n"
"       pidof -V\n"
"\n"
"-e      necessita da execução em um processo _exato_ com nomes muito longos (com a extensão .exe)\n"
"                    se não houver fluxo de dados disponível para o programa.\n"
"-g      mostra ID do grupo que contém o processo\n"
"-V      exibe informações detalhadas sobre o estado atual da execução"

