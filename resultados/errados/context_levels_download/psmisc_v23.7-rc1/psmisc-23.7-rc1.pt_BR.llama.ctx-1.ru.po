msgid ""
"\n"
"Display a tree of processes.\n"
"\n"
msgstr "Exibe o diagrama de fluxo do processo."

msgid ""
"  -a, --arguments     show command line arguments\n"
"  -A, --ascii         use ASCII line drawing characters\n"
"  -c, --compact-not   don't compact identical subtrees\n"
msgstr ""
"[{'option': '-a, --arguments', 'description': 'mostrar argumentos da linha "
"de comando'}, {'option': '-A, --ascii', 'description': 'utilizar caracteres "
"ASCII para desenhar a linha'}, {'option': '-c, --compact-not', "
"'description': 'não comprimir o mesmo subárbusto ao longo da linha de "
"comando'}]"

msgid ""
"  -C, --color=TYPE    color process by attribute\n"
