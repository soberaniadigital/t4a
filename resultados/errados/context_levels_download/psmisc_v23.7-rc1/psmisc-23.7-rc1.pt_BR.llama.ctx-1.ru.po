"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
"[{'command': '-h, --highlight-all', 'description': \"Substitua 'RU' por uma "
"descrição adequada em português.\"}, {'command': '-H PID, --highlight-"
"pid=PID', 'description': 'Preserve the command and description as is for "
"consistency with previous translations. Ensure proper formatting in "
"Portuguese syntax.'}, {'command': '-l, --long', 'description': \"Substitua "
"'RU' por uma descrição adequada em português e maintain the formal tone and "
"terminology used previously.\"}]"

msgid ""
"  -n, --numeric-sort  sort output by PID\n"
"  -N TYPE, --ns-sort=TYPE\n"
"                      sort output by this namespace type\n"
"                              (cgroup, ipc, mnt, net, pid, time, user, uts)\n"
