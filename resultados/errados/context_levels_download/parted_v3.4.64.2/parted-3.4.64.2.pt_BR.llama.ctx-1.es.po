msgstr "Fim?"

msgid ""
"You requested a partition from %s to %s (sectors %llu..%llu).\n"
"The closest location we can manage is %s to %s (sectors %llu..%llu).%s"
msgstr ""
"Pediu uma partição de %s a %s (sectores %llu..%llu). A localização mais "
