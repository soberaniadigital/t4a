msgstr "Modelo: %s (%s)"

msgid "Disk %s: %s\n"
msgstr "Disco %s: %s\n"

msgid "Sector size (logical/physical): %lldB/%lldB\n"
msgstr "Tamanho do setor (lógico/físico): %<PRIuMAX>B/%<PRIuMAX>B"

msgid "Partition Table: %s\n"
msgstr "Tabla de particiones: %s"

msgid "Disk Flags: %s\n"
