"\n"
"Error: SEGV_MAPERR (Address not mapped to object)\n"
msgstr "Erro SEGV_MAPERR (Direção não atribuída ao objeto)"

msgid ""
"\n"
"Error: SEGV_ACCERR (Invalid permissions for mapped object)\n"
msgstr "Erro SEGV_ACCERR (Permissões inválidas para objeto assegurado)"

msgid ""
"\n"
"Error: A general SIGSEGV signal was encountered.\n"
msgstr "Erro encontrado: uma sinal de SIGSEGV geral."

msgid ""
