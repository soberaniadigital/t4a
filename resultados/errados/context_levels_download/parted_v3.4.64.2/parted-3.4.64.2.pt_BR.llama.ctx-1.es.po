msgid ""
"\n"
"Is this still acceptable to you?"
msgstr "Esta ainda é aceitável para você?"

msgid ""
"The resulting partition is not properly aligned for best performance: %s"
msgstr ""
"A partição resultante não está corretamente alinhada para o melhor "
"desempeño: %s"

