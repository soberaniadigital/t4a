msgstr "selecionar"

msgid "select DEVICE                            choose the device to edit"
msgstr "selecione o dispositivo para edição"

msgid "disk_set"
msgstr "set de disco"

msgid ""
"disk_set FLAG STATE                      change the FLAG on selected device"
msgstr "o estado da BANDERA no dispositivo selecionado foi alterado."

msgid "disk_toggle"
msgstr "ativar/desativar o disco"

msgid ""
"disk_toggle [FLAG]                       toggle the state of FLAG on "
"selected device"
msgstr "alterna o estado de BANDERA no dispositivo selecionado."

