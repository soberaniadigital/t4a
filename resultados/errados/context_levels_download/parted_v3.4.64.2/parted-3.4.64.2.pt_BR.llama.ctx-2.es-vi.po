msgid "Try `%s --help' for more information.\n"
msgstr "Tente `%s --help' para mais informações."

msgid "Usage: %s [OPTION] [DEVICE]...\n"
msgstr "Modo de uso: %s [OPÇÃO] [DISPOSITIVOS]...\n"

msgid ""
"Inform the operating system about partition table changes.\n"
"\n"
"  -d, --dry-run    do not actually inform the operating system\n"
"  -s, --summary    print a summary of contents\n"
"  -h, --help       display this help and exit\n"
"  -v, --version    output version information and exit\n"
msgstr ""
"Informa ao sistema operacional sobre alterações na tabela de particionamento. \n"
"\n"
" -d, --dry-run    executa um teste (sem efeito real) \n"
" -s, --summary    exibe uma visão geral do conteúdo \n"
" -h, --help       mostra esta mensagem de ajuda e encerra o programa \n"
" -v, --version    apresenta informações sobre a versão atual e termina o programa"

msgid ""
"\n"
"When no DEVICE is given, probe all partitions.\n"
msgstr "Quando não se fornecer um dispositivo, examina todas as partições."

msgid ""
"\n"
"Report bugs to <%s>.\n"
msgstr "Comunicar erros a <%s>."

msgid "Unable to open %s."
msgstr "Não é possível abrir %s."

msgid "Unable to probe store."
msgstr "Não é possível sondear o armazenamento."

msgid ""
"WARNING: the kernel failed to re-read the partition table on %s (%s).  As a "
"result, it may not reflect all of your changes until after reboot."
msgstr ""
"ADVERTENCIA: o kernel não conseguiu ler novamente a tabela de partições em "
"%s (%s). Por isso, pode haver alterações que ainda não foram refletidas até "
"após um reinício."

msgid ""
"Warning: unable to open %s (%s). As a result, it may not reflect all of your"
" changes until after reboot."
msgstr ""
"Advertencia: não foi possível abrir %s (%s). Por isso, pode haver alterações"
" que ainda não foram refletidas até após um reinício."

msgid ""
"Warning: failed to make translator go away on %s (%s). As a result, it may "
"not reflect all of your changes until after reboot."
msgstr ""
"Advertencia: não foi possível remover o tradutor em %s (%s). Por isso, pode "
"haver alterações que ainda não são refletidas até após um reinício."

msgid "%s trying to sync %s to disk"
msgstr "%s tentando sincronizar %s no disco"

msgid "Could not stat device %s - %s."
msgstr "Não é possível executar o comando `stat' sobre o dispositivo %s - %s."

msgid "Unable to determine the dm type of %s."
msgstr "Não é possível determinar o tipo de dm de %s."

msgid ""
"Could not determine sector size for %s: %s.\n"
"Using the default sector size (%lld)."
msgstr ""
"Não foi possível determinar o tamanho do setor para %s: %s. Portanto, "
"utiliza-se por omissão o tamanho de sector (%lld)."

msgid ""
"Could not determine physical sector size for %s.\n"
"Using the logical sector size (%lld)."
msgstr ""
"Não foi possível determinar o tamanho do setor físico para %s. Utiliza-se, "
"em vez disso, o tamanho do sector lógico (%lld)."

msgid "Unable to determine the size of %s (%s)."
msgstr "Não é possível determinar o tamanho do arquivo %s (%s)."

msgid "Generic IDE"
msgstr "IDE genérico"

msgid "Could not get identity of device %s - %s"
msgstr "Não é possível obter a identidade do dispositivo %s - %s"

msgid ""
"Device %s has multiple (%d) logical sectors per physical sector.\n"
"GNU Parted supports this EXPERIMENTALLY for some special disk label/file system combinations, e.g. GPT and ext2/3.\n"
"Please consult the web site for up-to-date information."
msgstr ""
"O dispositivo %s possui vários (%d) setores lógicos por cada sector físico. "
"GNU Parted implementa isso de forma EXPERIMENTAL para algumas combinains "
"especiais de etiquetagem do disco/sistema de arquivos, como GPT e ext2/3. "
"Por favor consulte o site web para informações atualizadas."

msgid "Error initialising SCSI device %s - %s"
msgstr "Erro ao iniciar o dispositivo SCSI %s - %s"

msgid ""
"The device %s is so small that it cannot possibly store a file system or "
"partition table.  Perhaps you selected the wrong device?"
msgstr ""
"O dispositivo %s é tão pequeno que não pode conter um sistema de arquivos ou"
" tabulação de particionamento. Talvez ele tenha selecionado o dispositivo "
"erroneamente?"

msgid ""
"Unable to determine geometry of file/device %s.  You should not use Parted "
"unless you REALLY know what you're doing!"
msgstr ""
"Não é possível determinar a geometria do ficheiro/dispositivo %s. Não deve "
"utilizar Parted sem que realmente saiba o que está fazendo!"

