msgid "Could not read title information for DVD."
msgstr "Não foi possível obter a informação do título para o DVD."

msgid "Failed to open DVD device '%s'."
msgstr "Não foi possível abrir o dispositivo de DVD \"%s\"."

msgid "Failed to set PGC based seeking."
msgstr "Não foi possível configurar a pesquisa baseada em PGC."

msgid ""
"Could not read DVD. This may be because the DVD is encrypted and a DVD "
"decryption library is not installed."
msgstr ""
"Não foi possível ler o DVD. Isso pode ser devido ao fato de que o DVD está "
"criptografado e a biblioteca necessária para descriptografá-lo não foi "
"instalada."

msgid "Could not read DVD."
msgstr "não foi possível ler o DVD."

msgid "This file contains no playable streams."
msgstr "Este arquivo contém fluxo não reproduzível."

msgid "Could not open sndfile stream for reading."
msgstr "Não foi possível abrir e ler o fluxo sndfile."

msgid "Generated file has a larger preroll time than its streams duration"
msgstr ""
"A seção de previsão do arquivo gerado ultrapassa o seu próprio comprimento "
"de fluxo."

msgid "Missing element '%s' - check your GStreamer installation."
msgstr ""
"Falta o componente '%s' - por favor, verifique sua instalação do GStreamer."

msgid "File location is set to NULL, please set it to a valid filename"
msgstr ""
"A localização do arquivo é NULL, por favor defina um nome de arquivo válido."

msgid "Digitalzoom element couldn't be created"
msgstr "não foi possível criar o componente Digitalzoom"

msgid "Subpicture format was not configured before data flow"
msgstr "O formato de subimagem não foi configurado antes do fluxo de dados."

