msgid "Not enough memory."
msgstr "Não há memória suficiente."

msgid "Setting a value for this tag is unsupported!"
msgstr "Não há suporte para a criação de um valor para esta marca!"

msgid "Too few components specified (need %d, found %d)\n"
msgstr ""
"Chamado para indicar que há menos componentes do que o necessário (%d "
"requeridos, %d encontrados)."

msgid "Numeric value expected\n"
msgstr "É necessário um valor numérico."

msgid "Internal error. Please contact <%s>."
msgstr "Erro interno. Por favor, entre em contato com <%s>."

msgid "Not yet implemented!"
msgstr "Não foi possível concluir a operação!"

msgid "Warning; Too many components specified!"
msgstr "Aviso: há muito poucos componentes especificados!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr "Existe muito dado EXIF (%i byte). O máximo é %i byte."

msgid "Could not write '%s' (%s)."
msgstr "Não foi possível gravar '%s' (%s)."

msgid "Wrote file '%s'."
msgstr "Foi feito treino na tabela '%s'."

msgid "EXIF entry '%s' "
msgstr "Mục tin EXIF »%s« "

msgid "(0x%x, '%s') "
msgstr "(0x%x, '%s') "

msgid "exists in IFD '%s':\n"
msgstr "existiu em IFD »%s«:"

msgid "Adding entry..."
msgstr "Adiciona módulo..."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr "IFD \"%s\" não contém nenhuma marcação '%s'!"

msgid "Could not open '%s' (%s)!"
msgstr "Não foi possível abrir '%s' (%s)!"

msgid "Could not determine size of '%s' (%s)."
msgstr "Não foi possível determinar o tamanho do arquivo %s (%s)."

msgid "Could not read '%s' (%s)."
msgstr "Não foi possível ler '%s' (%s)."

msgid "IFD '%s' does not contain tag '%s'."
msgstr "IFD \"%s\" não contém a marcação '%s'."

msgid "'%s' does not contain tag '%s'."
msgstr ""
"'%s' não contém a etiqueta '%s'. A marcação é necessária para identificar o "
"elemento."

msgid "'%s' does not contain a thumbnail!"
msgstr "Se '%s' não conter imagens de referência!"

msgid "Could not open '%s' for writing (%s)!"
msgstr "Não foi possível abrir '%s' para escrever (%s)!"

msgid "EXIF tags in '%s':"
msgstr "Trilhas EXIF na »%s«:"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr ""
"Não há informações sobre o formato ou a presença de uma anotação do "
"fabricante."

msgid "MakerNote does not contain any value.\n"
msgstr "MakerNote não contém valor."

msgid "MakerNote contains %i value:\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Unknown Tag"
msgstr "Marcação desconhecida"

msgid "Unknown value"
msgstr "Valor desconhecido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thẻ EXIF trong »%s« (thứ tự byte %d):"

msgid "Tag"
msgstr ""
"marcação do termo 'thẻ' para o português brasileiro, considerando as "
"traduções anteriores e aderindo às regras de formalidade técnica."

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "Os dados EXIF contêm uma imagem de referência (%i bytes)."

msgid "ThumbnailSize\t%i\n"
msgstr "Kích cỡ ảnh mẫu %i"

msgid "Display software version"
msgstr "Hiện thị phiên bản phần mềm"

msgid "Show IDs instead of tag names"
msgstr "Hiêni nhân mã số thay cho tên tiến hình anh"

msgid "Select tag"
msgstr "Escolha a etiqueta"

msgid "tag"
msgstr "etiqueta"

msgid "Select IFD"
msgstr "Selecionar IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Listagem de todas as marcas EXIF disponíveis."

msgid "Show contents of tag MakerNote"
msgstr "Contenido da nota do fabricante mostrar"

msgid "Remove tag or ifd"
msgstr "Remova a marcação ou o IFD."

msgid "Show description of tag"
msgstr "Esta é a descrição atual da marca"

msgid "Extract thumbnail"
msgstr "Truncar imagem pequena"

msgid "Remove thumbnail"
msgstr "remover miniatura do arquivo"

msgid "Insert FILE as thumbnail"
msgstr "Colar a imagem de exemplo na área do texto"

msgid "FILE"
msgstr "TARDE TINDA"

msgid "Do not fix existing tags in files"
msgstr "Não corrija alterações já existentes no documento"

msgid "Write data to FILE"
msgstr "Digite dados no TXT_FILE"

msgid "Value of tag"
msgstr "Valor da marcação"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Caso não haja dados EXIF, eles serão gerados automaticamente."

msgid "Output in a machine-readable (tab delimited) format"
msgstr "Xuất ra một định dạng cho máy đọc được (định giới bằng khoảng tab)"

msgid "Width of output"
msgstr "largura de saída do processo de conclusão horizontal"

msgid "WIDTH"
msgstr "Rua"

msgid "Output in a XML format"
msgstr "Saída em um formato XML"

msgid "Show debugging messages"
msgstr "Atualização de mensagens do erro"

msgid "Help options:"
msgstr "Opções de auxílio:"

msgid "Show this help message"
msgstr "Olá! Estou aqui para ajudar. Como posso atender às suas necessidades?"

msgid "Display brief usage message"
msgstr "Aviso curto de assistência necessária"

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD fornecido não é válido. Os IFDs permitidos são '0', '1', 'EXIF', "
"'GPS' e 'Interoperability'. Para obter mais informações, tente `%s --help'"

msgid "Invalid tag '%s'!"
msgstr "Etiqueta '%s' não é válida!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar uma etiqueta!"

msgid "You need to specify an IFD!"
msgstr "É necessário que você especifique um IFD!"

msgid "Tag '%s' "
msgstr "Marcação »%s« "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Chame o comando `--create-exif' para criar metadados EXIF no arquivo de "
"entrada."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "O arquivo '%s' não pode ser lido ou está vazio de dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O XML não é utilizado para notas do autor no software MakeNote."

msgid "Data does not follow JPEG specification."
msgstr "Os dados não seguem a especificação JPEG."
