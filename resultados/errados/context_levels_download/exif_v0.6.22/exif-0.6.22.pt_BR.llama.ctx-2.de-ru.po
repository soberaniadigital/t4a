msgstr "Os dados EXIF contêm uma imagem de referência (%i bytes)."

msgid "ThumbnailSize\t%i\n"
msgstr "Kích cỡ ảnh mẫu %i"

msgid "Display software version"
msgstr "Hipervisor de software apresenta a versão atualizada."

msgid "Show IDs instead of tag names"
msgstr "Exibir o número de identificação em vez do nome da marcação."

msgid "Select tag"
msgstr "Escolha a etiqueta"

msgid "tag"
msgstr "etiqueta"

msgid "Select IFD"
msgstr "Escolha IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Listagem de todos os marcadores EXIF"

msgid "Show contents of tag MakerNote"
msgstr "Contenido da anotação do fabricante mostrar"

msgid "Remove tag or ifd"
msgstr "Remova a marcação ou IFD"

msgid "Show description of tag"
msgstr "Esta é a descrição atual da marca"

