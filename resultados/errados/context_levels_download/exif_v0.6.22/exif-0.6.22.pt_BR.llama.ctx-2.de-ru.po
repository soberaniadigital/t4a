msgstr "Esta mensagem de assistência requer atenção imediata."

msgid "Display brief usage message"
msgstr "Aviso de assistência curta exibido."

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"IFD não é aceito '%s'. Os IFD válidos são '0', '1', 'EXIF', 'GPS' e "
"'Interoperability'."

msgid "Invalid tag '%s'!"
msgstr "Marking '%s' is not allowed!"

msgid "You need to specify a tag!"
msgstr "Você precisa marcar uma etiqueta!"

msgid "You need to specify an IFD!"
msgstr "Você precisa especificar um IFD!"

msgid "Tag '%s' "
msgstr "Marcação »%s« "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Chame o comando `--create-exif' para criar metadados EXIF no arquivo de "
"entrada."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s não pode ser lido ou ele não contém dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O XML não é utilizado para notas de Maker Notes."

msgid "Data does not follow JPEG specification."
msgstr "Os dados não seguem a especificação JPEG."
