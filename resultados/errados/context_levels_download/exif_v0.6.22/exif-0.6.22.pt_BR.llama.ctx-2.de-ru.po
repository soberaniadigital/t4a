msgstr "Não foi possível abrir '%s' para gravar (%s)!"

msgid "EXIF tags in '%s':"
msgstr "Exif tags em »%s«:"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr "Não há informações sobre o formato ou não existe nota do fabricante."

msgid "MakerNote does not contain any value.\n"
msgstr "MakerNote não contém nenhum valor."

msgid "MakerNote contains %i value:\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Unknown Tag"
msgstr "Marcação desconhecida"

msgid "Unknown value"
msgstr "Valor desconhecido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thẻ EXIF trong »%s« (thứ tự byte %d):"

msgid "Tag"
msgstr "marcação"

msgid "Value"
msgstr "Valor"

