msgid "Not enough memory."
msgstr "Não há bônus de memória suficiente."

msgid "Setting a value for this tag is unsupported!"
msgstr "Não há suporte para a função de criar um valor para este token!"

msgid "Too few components specified (need %d, found %d)\n"
msgstr ""
"Chamado para indicar que o número de elementos (%d, %d) excede a quantidade "
"alocada."

msgid "Numeric value expected\n"
msgstr "Cada campo deve conter um valor numérico."

msgid "Internal error. Please contact <%s>."
msgstr "Erro de baixo nível. Por favor, conecte-se ao <%s>."

msgid "Not yet implemented!"
msgstr "Ação ainda não foi concluída!"

msgid "Warning; Too many components specified!"
msgstr "Aviso de baixa informação disponível para o componente!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr "Existem muitos dados EXIF (%i byte). Para permitir %i byte."

msgid "Could not write '%s' (%s)."
msgstr "Não é possível salvar no arquivo %s (%d)."

msgid "Wrote file '%s'."
msgstr "Fez treino no arquivo '%s'."

msgid "EXIF entry '%s' "
msgstr "Mục tin EXIF '%s'"

msgid "(0x%x, '%s') "
msgstr "(0x%x, '%s') "

msgid "exists in IFD '%s':\n"
msgstr "está presente no IFD \"%s\":"

msgid "Adding entry..."
msgstr "Adicione o item..."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr "Se o arquivo %s não contém nenhum sinal de terminação (EOF)!"

msgid "Could not open '%s' (%s)!"
msgstr "Não é possível abrir o arquivo %s (%s)!"

msgid "Could not determine size of '%s' (%s)."
msgstr "Não é possível determinar o tamanho do arquivo %s (%s)."

msgid "Could not read '%s' (%s)."
msgstr "Não é possível ler o arquivo %s (%s)."

msgid "IFD '%s' does not contain tag '%s'."
msgstr "Se o arquivo IFD '%s' não contiver a chave '%s', falha."

msgid "'%s' does not contain tag '%s'."
msgstr "%s"

msgid "'%s' does not contain a thumbnail!"
msgstr "Se o IFD '%s' não contém imagens de referência!"

msgid "Could not open '%s' for writing (%s)!"
msgstr "Não é possível abrir o arquivo %s para gravação!"

msgid "EXIF tags in '%s':"
msgstr "Thêm EXIF para o arquivo %s:"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr "Não há informações sobre o tamanho ou a presença de um makernote."

msgid "MakerNote does not contain any value.\n"
msgstr "O Makernote não possui valor."

msgid "MakerNote contains %i value:\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Unknown Tag"
msgstr "Não é possível identificar o símbolo de interrupção (Esc) do teclado."

msgid "Unknown value"
msgstr "Valor baixo ou insuficiente para a operação desejada."

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thê EXIF dentro de \"%s\" (thêu tự byte %s):"

msgid "Tag"
msgstr "Thema"

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "O dado EXIF contém uma imagem de referência (%i byte)."

msgid "ThumbnailSize\t%i\n"
msgstr "Clique para visualizar o exemplo de imagem %i."

msgid "Display software version"
msgstr "Desenvolvimento de Software em Português (Pt-BR)"

msgid "Show IDs instead of tag names"
msgstr ""
"Olá! Seja bem-vindo ao seu novo sistema de gestão financeira. Para verificar"
" o status do seu documento, digite 'ver sms %s'."

msgid "Select tag"
msgstr "Escolha a opção"

msgid "tag"
msgstr "a folha de cálculo do Excel"

msgid "Select IFD"
msgstr "Escolha IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Lista de todos os atributos EXIF disponíveis."

msgid "Show contents of tag MakerNote"
msgstr "O presente documento é o Termo de Ajuste do Makernote."

msgid "Remove tag or ifd"
msgstr "Borrando a linha ou IFD (IFDS)"

msgid "Show description of tag"
msgstr "Esta é a descrição atual do termo"

msgid "Extract thumbnail"
msgstr "Truncamento de imagem insuficiente."

msgid "Remove thumbnail"
msgstr "Remover imagem pequena"

msgid "Insert FILE as thumbnail"
msgstr "Exibir imagem de exemplo para TEXTPOOL"

msgid "FILE"
msgstr "Tá no caminho para a solução do problema"

msgid "Do not fix existing tags in files"
msgstr "Não faça alterações em uma nota já existente no arquivo."

msgid "Write data to FILE"
msgstr "GHI DÚLUI LÍQUIDO E OUVIDA NO TEXTO DO ARQUIVOLUME"

msgid "Value of tag"
msgstr "Valor do termo contratual (valor da dívida)"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Dados EXIF presentes se houver, caso contrário"

msgid "Output in a machine-readable (tab delimited) format"
msgstr "Xeque um padrão para máquina de leitura (formato por faixa tab)}"

msgid "Width of output"
msgstr "Chiado de largura para saída do pacote"

msgid "WIDTH"
msgstr "Rua"

msgid "Output in a XML format"
msgstr "Saída em formato XML"

msgid "Show debugging messages"
msgstr "Erro de entrada/saída"

msgid "Help options:"
msgstr "Escolha de ajuda:"

msgid "Show this help message"
msgstr "Olá! Estou aqui para ajudá-lo nesta tarefa."

msgid "Display brief usage message"
msgstr "Olá! Seja bem-vindo ao nosso serviço de assistência técnica."

msgid "[OPTION...] file"
msgstr "[TÚU_CHÓE...] tabela"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD não for hora legal '%s', as opções válidas são:\n"
" • 0\n"
" • 1\n"
" • EXIF\n"
" • GPS\n"
" • Túmulo de interoperabilidade"

msgid "Invalid tag '%s'!"
msgstr "Thẻ không hợp lệ '%s'!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar um número!"

msgid "You need to specify an IFD!"
msgstr "É necessário informar um IFD!"

msgid "Tag '%s' "
msgstr "Thẻ \"%s\""

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Chame o comando --create-exif para criar um arquivo de metadados EXIF."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s não pode ler ou conter dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O uso de um padrão XML não é recomendado para o software Make Notes."

msgid "Data does not follow JPEG specification."
msgstr "Dados não seguem o padrão JPEG."
