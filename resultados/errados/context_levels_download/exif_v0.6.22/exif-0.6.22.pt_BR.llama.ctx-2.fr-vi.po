msgid "Not enough memory."
msgstr "Não há blocos de memória suficientes."

msgid "Setting a value for this tag is unsupported!"
msgstr "Não há suporte para atribuir um valor a este descriptor!"

msgid "Too few components specified (need %d, found %d)\n"
msgstr ""
"Chamamento para ajuste excessivo de componentes (%d necessários, %d "
"identificados)"

msgid "Numeric value expected\n"
msgstr "Cần một giá trị bằng số"

msgid "Internal error. Please contact <%s>."
msgstr "Lỗi nội bộ. Hãy liên lạc với <%s>."

msgid "Not yet implemented!"
msgstr "Não foi possível concluir a operação!"

msgid "Warning; Too many components specified!"
msgstr "CANAL DE RENDA: pouco de informação especificada no componente!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr ""
"Excepcional quantidade de dados EXIF (%i byte). Permite apenas %i byte."

msgid "Could not write '%s' (%s)."
msgstr "Não é possível gravar '%s' (%s)."

msgid "Wrote file '%s'."
msgstr "Giti para o arquivo \"%s\"."

msgid "EXIF entry '%s' "
msgstr "Mục tin EXIF \"%s\""

msgid "(0x%x, '%s') "
msgstr "(0x%x, '%s') "

msgid "exists in IFD '%s':\n"
msgstr "está presente no IFD \"%s\":"

msgid "Adding entry..."
msgstr "Adicione o item..."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr "IFD \"%s\" não contém nenhum sinal de falha para o termo '%s'!"

msgid "Could not open '%s' (%s)!"
msgstr "Não é possível abrir \"%s\" (%s)!"

msgid "Could not determine size of '%s' (%s)."
msgstr "Não é possível determinar o tamanho do arquivo '%s' (%s)."

msgid "Could not read '%s' (%s)."
msgstr "Não é possível ler o arquivo %s (%s)."

msgid "IFD '%s' does not contain tag '%s'."
msgstr "Se o IFD \"%s\" não contém a etiqueta \"%s\"."

msgid "'%s' does not contain tag '%s'."
msgstr "%s"

msgid "'%s' does not contain a thumbnail!"
msgstr "IFD \"%s\" não possui imagens de modelo exibidas!"

msgid "Could not open '%s' for writing (%s)!"
msgstr "Không thêm nenhum arquivo %s%d para gravação!"

msgid "EXIF tags in '%s':"
msgstr "Thêm thể EXIF trong \"%s\":"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr ""
"Não é possível determinar o formato ou não há informações no MakerNote."

msgid "MakerNote does not contain any value.\n"
msgstr "MakerNote não contém valor."

msgid "MakerNote contains %i value:\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Unknown Tag"
msgstr "Não é possível identificar o sinal (Thẻ)"

msgid "Unknown value"
msgstr "Valor desconhecido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thẻ EXIF trong \"%s\" (thứ tự byte %d):"

msgid "Tag"
msgstr "Thẻ"

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "As dados EXIF contêm uma imagem de modelo (%i byte)."

msgid "ThumbnailSize\t%i\n"
msgstr "Kích cỡ ảnh mẫu\t%i"

msgid "Display software version"
msgstr "Filtragem de vídeo"

msgid "Show IDs instead of tag names"
msgstr ""
"Olá! Seja bem vindo ao nosso sistema. Para ver o seu número de "
"identificação, você pode digitar 'Hiển thị mã số'."

msgid "Select tag"
msgstr "Selecione o sinal"

msgid "tag"
msgstr "thẻ"

msgid "Select IFD"
msgstr "Chose IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Liste todos os marcadores EXIF"

msgid "Show contents of tag MakerNote"
msgstr "Contenido atual do marcação MakerNote"

msgid "Remove tag or ifd"
msgstr "Borra o sinal ou IFD"

msgid "Show description of tag"
msgstr "Esta é a descrição atual do marcador."

msgid "Extract thumbnail"
msgstr "Trincheir de imagem pequena"

msgid "Remove thumbnail"
msgstr "Remova a miniatura do arquivo"

msgid "Insert FILE as thumbnail"
msgstr "Inscreva o arquivo como imagem de modelo."

msgid "FILE"
msgstr "TÁ PENSANDO?"

msgid "Do not fix existing tags in files"
msgstr "Não faça alterações em marcadores já existentes no arquivo"

msgid "Write data to FILE"
msgstr "Ghi dữ liệu vào TẬP TIN"

msgid "Value of tag"
msgstr "Valor do sinal"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Táo dữ liệu EXIF nếu không có."

msgid "Output in a machine-readable (tab delimited) format"
msgstr "Saída em um padrão legível para computador (delimitado por espaços)"

msgid "Width of output"
msgstr "largura da saída de produto finalizado"

msgid "WIDTH"
msgstr "RỘNG"

msgid "Output in a XML format"
msgstr "Saída em formato XML"

msgid "Show debugging messages"
msgstr "Hiện thông tin gỡ lỗi"

msgid "Help options:"
msgstr "Escolha ajuda:"

msgid "Show this help message"
msgstr "Olá! Estou aqui para ajudar."

msgid "Display brief usage message"
msgstr "Olá! Aqui está uma breve nota de uso."

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"IFD não é hora lê %s. Os IFD válidos são: \n"
" • 0\n"
" • 1\n"
" • EXIF\n"
" • GPS\n"
" • Interoperabilidade"

msgid "Invalid tag '%s'!"
msgstr "Thẻ không hợp lệ \"%s\"!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar um marcador!"

msgid "You need to specify an IFD!"
msgstr "Você precisa especificar um IFD!"

msgid "Tag '%s' "
msgstr "Thẻ \"%s\" "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Chia em disco ou --create-exif para adicionar metadados EXIF ao arquivo."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s"

msgid "XML format is not available for Maker Notes"
msgstr "O formato XML não está disponível para notas do criador."

msgid "Data does not follow JPEG specification."
msgstr "Os dados não seguem a especificação JPEG."
