msgstr "Chèn TẾP TIN dãng ảnh mẫu"

msgid "FILE"
msgstr "IDENTIFICADOR DE USUÁRIO"

msgid "Do not fix existing tags in files"
msgstr "Não faça alterações no texto que já contém a etiqueta"

msgid "Write data to FILE"
msgstr "Ghi dữ liệu vào TẬP TIN"

msgid "Value of tag"
msgstr "Valor do token"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Táo dữ liệu EXIF nếu không có."

msgid "Output in a machine-readable (tab delimited) format"
msgstr "Xuanda um padrão para máquina de leitura (nível tab)}"

msgid "Width of output"
msgstr "Chiêu longitudinal de saída"

msgid "WIDTH"
msgstr "RỘNG"

msgid "Output in a XML format"
msgstr "XUARTE A OBJETIVO DE EXPORTAR EM DADOS XML"

msgid "Show debugging messages"
msgstr "Hiện thông tin gỡ lỗi"

msgid "Help options:"
msgstr "Opções de ajuda:"

msgid "Show this help message"
msgstr "Olá! Estou aqui para ajudar."

msgid "Display brief usage message"
msgstr "Olá! Seja bem vindo(a)."

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"IFD '%s' não é válido. IFD válidos são '0', '1', 'EXIF', 'GPS' e "
"'Interoperability'. Para obter mais informações, tente `%s --help'"

msgid "Invalid tag '%s'!"
msgstr "Thẻ không hợp lệ '%s'!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar um tag!"

msgid "You need to specify an IFD!"
msgstr "É preciso definir um IFD!"

msgid "Tag '%s' "
msgstr "Thẻ \"%s\" "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr "Chia em disco ou --create-exif para adicionar metadados EXIF."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s"

msgid "XML format is not available for Maker Notes"
msgstr "O formato XML não está disponível para o Notas do Makers."

msgid "Data does not follow JPEG specification."
msgstr "Dados não seguem o padrão JPEG."
