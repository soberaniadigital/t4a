msgid "Unknown format or nonexistent MakerNote.\n"
msgstr ""
"Não é possível determinar o tamanho do arquivo ou se há informações de "
"MakerNote."

msgid "MakerNote does not contain any value.\n"
msgstr "MakerNote não contém valor."

msgid "MakerNote contains %i value:\n"
msgstr "ID"

msgid "Unknown Tag"
msgstr "Sem identificação (sem ID)"

msgid "Unknown value"
msgstr "Valor mínimo permitido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thẻ EXIF trong \"%s\" (thứ tự byte \"%s\"):"

msgid "Tag"
msgstr "Thẻ"

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "Dados EXIF contêm uma imagem de modelo (%i byte)."

msgid "ThumbnailSize\t%i\n"
msgstr "Kích cỡ ảnh mẫu %i"

