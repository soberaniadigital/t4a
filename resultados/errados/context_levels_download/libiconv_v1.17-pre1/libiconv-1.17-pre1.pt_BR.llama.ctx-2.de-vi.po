msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr ""
"CÓDIGO FORMATO DE UFERMA: iconv [-c] [-s] [-f codificação_entrada] [-t "
"codificação_saída] [arquivo(s) …]"

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente ‘%s --help’ para obter mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr ""
"CÓDIGO DE USE: %s [OPÇÕES...] [-f ENCODAMENTO] [-t ENCODEMENTO] "
"[ARQUIVOS_DE_ENTRADA...]\n"

msgid "or:    %s -l\n"
msgstr "hoje ou terça-feira -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converta o texto de uma codificação para outra."

msgid "Options controlling the input and output format:\n"
msgstr ""
"Các tùy chọn điều khiển định dạng nhập vào và xuất ra:\n"
"\n"
"'VI': 'Vídeo', \n"
"'DE': 'Diapositiva', \n"
"'DI': 'Imagem em quadrado'\n"

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              Entrada em código"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              Saída em codificação de caracteres."

msgid "Options controlling conversion problems:\n"
msgstr ""
"Opções de controle para a conversão de caracteres: \n"
"\t'VI': Opção que permite converter uma sequência específica. Utilize-a quando necessário.\n"
"\t'DE': Dica sobre como lidar com problemas relacionados à convergência dos dados."

msgid "  -c                          discard unconvertible characters\n"
msgstr ""
" -c                           Ignorar caracteres que não podem ser "
"convertidos"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr "--unicode-subst=SUBSTITUIÇÃO_DE_CHUỖI_UNICO"

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=FORMATSTRING    Substitui bytes que não podem ser convertidos"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=CHUỖI_ĐỊNH_DẠNG\n"
"                              substitui caracteres róticos que não podem ser convertidos."

msgid "Options controlling error output:\n"
msgstr ""
"Các tùy chọn de controle para a saída dos erros: \n"
"\t'VI': Opção que gera mensagens detalhadas sobre os erros. Utilize-a quando necessário.\n"
"\t'DE': Esta opção permite especificar o formato da mensagem de erro, como JSON ou texto simples. Para obter mais informações, digite 'VI --help'."

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
"  -s, --silent                Não exibir mensagens relacionadas aos erros de"
" conversão\n"

msgid "Informative output:\n"
msgstr "Xuất thông tin:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   lista das codificações suportadas"

msgid "  --help                      display this help and exit\n"
msgstr "  --help                      mostra esta ajuda e termina a execução\n"

msgid "  --version                   output version information and exit\n"
msgstr "--versao                    Mostrar versão e sair\n"

msgid ""
"Report bugs in the bug tracker at <%s>\n"
"or by email to <%s>.\n"
msgstr ""
"Por favor, envie relatório de erro para o sistema de rastreamento do bug em "
"<%s> ou por e-mail para <%s>. Além disso, envia atualizações dos mesmos para"
" a lista de correio da internacionalização no Google Groups "
"(i18n-zh@googlegroups.com)."

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+ ou posterior: Licença Código Fonte GNU Versão 3 <%s> \n"
"Este software é livre para que você o modifique e reenvie. Nenhuma garantia externa está presente, dentro dos limites legais permitidos.\n"

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr ""
"Đối số %s: neste localizador, não é permitido o uso de formatos com "
"variáveis."

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr ""
"Đối số %s: neste localizador, não é permitido o uso de formatos com precisão"
" variável."

msgid "%s argument: A format directive with a size is not allowed here."
msgstr "Đối số %s: ở đây không cho phép chỉ thị định dạng có kích cỡ."

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s 参数: 字符串在命令中部终止。"

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr "%s 参数: 字符‘%c’不是有效的转义符。"

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"O parâmetro '%s': caractere final não é um sinal de terminação válido para o"
" formato."

msgid ""
"%s argument: The format string consumes more than one argument: %u argument."
msgstr ""

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não foi possível converter o byte para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"não foi possível converter as substituições Unicode para a codificação alvo:"
" %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr ""
"não foi possível converter os bytes para uma string aninhada com largura: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"não é possível converter caracteres de largura variável para a codificação "
"alvo: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr "não foi possível converter os bytes para a codificação alvo: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%d:%d: nenhuma conversão possível."

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: dây kiểu ký tự hay dịch chưa hoàn thành"

msgid "%s:%u:%u"
msgstr "%s:%u:%u"

msgid "%s: I/O error"
msgstr "%s: Erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "não há suporte para conversão a partir de %s"

msgid "conversion to %s unsupported"
msgstr "não é suportado o processamento para %s"

msgid "conversion from %s to %s unsupported"
msgstr "não há suporte para converter de %s para %s."

msgid "try '%s -l' to get the list of supported encodings"
msgstr ""
"Tente usar ‘%s -l’ para obter a lista de todas as codificações suportadas."

msgid "(stdin)"
msgstr "(Entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "Erro de entrada/saída"

msgid "Report bugs to <bug-gnu-libiconv@gnu.org>.\n"
msgstr ""
"请向 <%s> 报告软件错误。\n"
"请向 <i18n-zh@googlegroups.com> 报告翻译错误。\n"
