msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr ""
"Utilização do iconv: -c, --convert all characters; -s, --skip errors; -f "
"in_encoding [input encoding]; -t out_encoding [output encoding] "
"[arquivo(s)]."

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente ‘%s --help’ para obter mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr "Utilização: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"

msgid "or:    %s -l\n"
msgstr "ou:    %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converte o texto de uma codificação para outra."

msgid "Options controlling the input and output format:\n"
msgstr ""
"Opções de controle para formatos de entrada e saída: \n"
"\t'--input-format=<FORMAT>'\tFormato do input. Por exemplo, 'json'.\n"
"\t'--output-format=<FORMAT>' \tFormat output. Exemplo: 'xml'."

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                               Entrada em codificação"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                               saída de codificação"

msgid "Options controlling conversion problems:\n"
msgstr ""
"Opções de controle para conversão de caracteres: \n"
"\t'--convert_to': converte o arquivo em um formato específico. Por exemplo, '--convert_to=txt' irá converter um arquivo PDF em texto simples.\n"
"\t'--preserve_formatting': preserva a formatação original do documento durante a conversão. Isso é útil para manter o layout da página como estava no origem, por exemplo: '--convert_to=html --preserve_formatting'. \n"
"\t'--encoding': especifica o tipo de codificação utilizado pelo arquivo original (por exemplo, UTF-8 ou ISO-8859-1). Por padrão, a conversão assume que o arquivo está em 'UTF-8', mas se você tiver um documento com outra codificação, é importante especificar isso para evitar erros de interpretação. Exemplo: '--encoding=ISO-8859-1'. \n"
"\t'--output_dir': define o diretório onde os arquivos convertidos serão salvos (por exemplo, '/home/user/converted'). Se você não especificar um caminho de saída diferente do padrão ('./'), a conversão irá criar novos arquivos no mesmo diretório que o original. Exemplo: '--output_dir=/home/user/converted'. \n"
"\t'--batch': permite converter múltiplos documentos de uma vez só, utilizando um único comando e sem a necessidade de repetir as opções para cada arquivo (por exemplo, converte todos os PDFs em texto no diretório atual). Exemplo: 'pdftotext -r --batch *.pdf'. \n"
"\t'--help': mostra uma lista completa das opções disponís e como utilizá-las. Por padrão, o comando irá mostrar apenas as opções mais importantes para iniciar a conversão (por exemplo: '--convert_to=txt'). Exemplo: 'pdftotext --help'."

msgid "  -c                          discard unconvertible characters\n"
msgstr " -c                           ignorar caracteres não convertíveis"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"--unicode-subst=STRING_FORMAT\n"
"                              Substituição para caracteres Unicode que não podem ser convertidos."

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=FORMATSTRING    Substituição para bytes que não podem ser "
"convertidos"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=STRING_FORMAT\n"
"                              substituição para caracteres não convertíveis em largura de palavra."

msgid "Options controlling error output:\n"
msgstr "Opções de controle para erros de saída: 'RU'"

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
"  -s, --silent                 não exibir mensagens relacionadas a erros de "
"conversão\n"

msgid "Informative output:\n"
msgstr "Informações de saída:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   lista de codificações suportadas"

msgid "  --help                      display this help and exit\n"
msgstr " --help                       Mostrar esta ajuda e sair\n"

msgid "  --version                   output version information and exit\n"
msgstr ""
"--versao                       Mostrar informações sobre a versão e sair\n"

msgid ""
"Report bugs in the bug tracker at <%s>\n"
"or by email to <%s>.\n"
msgstr ""
"Por favor, envie relatórios de erros para o sistema de rastreamento do bug "
"<%s> ou por e-mail a <%s>. Além disso, envia os relatórios em português ao "
"seguir este link: <i18n-zh@googlegroups.com>"

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior <%s> \n"
"Este software é livre. Você pode modificá-lo e recompô-lo para publicação.\n"
"Nenhum acordo legal fora do que a lei permite."

msgid "Written by %s.\n"
msgstr "Autor(es): %s. \n"

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr "%s 参数: 在此处不允许用可变长度的命令格式。"

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr "%s 参数: 在此处不允许用可变精度的命令格式。"

msgid "%s argument: A format directive with a size is not allowed here."
msgstr "%s 参数: 此处不允许用含大小的命令格式。"

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s argumento: a string ends at the middle of the directive."

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr ""
"%s argumento: o caractere '\\x%c' não é um especificador de escape válido."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"%s argument: Caracter, utilizado para encerrar a diretiva de formatação "
"inválido."

msgid ""
"%s argument: The format string consumes more than one argument: %u argument."
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não é possível converter os bytes para Unicode: %s"

