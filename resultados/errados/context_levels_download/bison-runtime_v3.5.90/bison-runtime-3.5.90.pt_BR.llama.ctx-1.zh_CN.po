msgid "syntax error: cannot back up"
msgstr "erro de sintaxe: não é possível reverter para a estação de segurança"

msgid "syntax is ambiguous"
msgstr "a sintaxe ainda não está clara"

msgid "syntax error"
msgstr "erro de sintaxe"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s anômia"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s anômia, precisa %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr ""
"erro de sintaxe, %s anômia, precisa executar o comando 'g++ -fsyntax-check' "
"ou verificar novamente."

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr ""
"erro de sintaxe, %s anômia, precisa executar %s ou %s para corrigir o "
"problema\n"

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de sintaxe, %s anônimo ou inválido, precisa executar o comando '%c' "
"para continuar a operação manualmente."

msgid "memory exhausted"
msgstr "memória esgotada"
