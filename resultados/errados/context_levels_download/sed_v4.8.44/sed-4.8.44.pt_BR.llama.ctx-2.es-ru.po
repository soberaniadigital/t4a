msgid ""
"  -R, --regexp-perl\n"
"                 use Perl 5's regular expressions syntax in the script.\n"
msgstr ""
"  -R, --regexp-perl\n"
"                 utiliza a sintaxe das expressões regulares de Perl 5 no script."

msgid "%s: option '--%s' doesn't allow an argument\n"
