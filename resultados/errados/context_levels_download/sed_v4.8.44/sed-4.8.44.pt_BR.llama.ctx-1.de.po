msgid ""
"Usage: %s [OPTION]... {script-only-if-no-other-script} [input-file]...\n"
"\n"
msgstr ""
"Aufruf: %s [OPTION] … {Skript-falls-kein-anderes-Skript} [Eingabedatei] …\n"

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
"--quiet, --silent\n"
"                 impedir a escrita automática no buffer de trabalho."

msgid ""
"      --debug\n"
"                 annotate program execution\n"
msgstr ""
"      --debug\n"
"                 anotar a execução do programa"

msgid ""
"  -e script, --expression=script\n"
"                 add the script to the commands to be executed\n"
msgstr ""
"  -e script, --expression=script\n"
"                 adicionar o script às comandas para executar."

msgid ""
"  -f script-file, --file=script-file\n"
"                 add the contents of script-file to the commands to be executed\n"
msgstr ""
" -f fichier-script, --file=fichier-script\n"
" Adicionar o conteúdo da ficheiro-script às comandas a serem executadas."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 siga links simbólicos durante o processamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"                 editar os arquivos em seu lugar (faz uma cópia de segurança se o SUFFIXE for especificado) \n"

msgid ""
"  -b, --binary\n"
"                 open files in binary mode (CR+LFs are not processed specially)\n"
msgstr ""
"  -b, --binary\n"
"                 abre arquivos em modo binário (CR+LF não são processados especialmente).\n"

msgid ""
"  -l N, --line-length=N\n"
"                 specify the desired line-wrap length for the `l' command\n"
msgstr ""
"  -l N, --line-length=N\n"
"                 especifica a longitud da quebra de linha desejada para o comando \"l\"."

msgid ""
"  --posix\n"
"                 disable all GNU extensions.\n"
msgstr ""
"--posix\n"
"de ativa todas as extensões GNU. (Note that this is the opposite of what `--posix` does in English, which disables all GNU extensions.)"

msgid ""
"  -E, -r, --regexp-extended\n"
"                 use extended regular expressions in the script\n"
"                 (for portability use POSIX -E).\n"
msgstr ""
" -E, -r, --extended-regexp\n"
"                 utilize a sintaxe de expressões regulares estendidas no script.\n"
"                 (use E para portabilidade)."

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de uma única fonte longa e "
"contínua.\n"

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 trabalha no modo sandbox (desativa as comandas e/r/w).\n"

msgid ""
"  -u, --unbuffered\n"
"                 load minimal amounts of data from the input files and flush\n"
"                 the output buffers more often\n"
msgstr ""
"  -u, --unbuffered\n"
"                 carrega apenas as quantidades mínimas de dados dos arquivos de entrada e escreve os buffers da saída com mais frequência no disco."

msgid ""
"  -z, --null-data\n"
"                 separate lines by NUL characters\n"
msgstr ""
"  -z, --null-data\n"
"                 separa linhas com caractere NUL"

msgid "      --help     display this help and exit\n"
msgstr "      --help     mostra esta ajuda e encerra o programa."

msgid "      --version  output version information and exit\n"
msgstr ""
"      --version mostra as informações de versão do software e termina o "
"programa."

msgid ""
"\n"
"If no -e, --expression, -f, or --file option is given, then the first\n"
"non-option argument is taken as the sed script to interpret.  All\n"
"remaining arguments are names of input files; if no input files are\n"
"specified, then the standard input is read.\n"
"\n"
msgstr ""
"Se nenhuma das opções -e, --expression, -f ou --file forem especificadas, o "
"primeiro argumento que não é uma opção será considerado como um script sed "
"para interpretação. Todos os outros argumentos seguirão sendo tratados como "
"nomes de arquivos de entrada; caso nenhum desses seja indicado, a entrada "
"padrão será lida."

