msgid "integer"
msgstr "número inteiro"

msgid "main configuration file"
msgstr "arquivo de configuração principal"

msgid "location of main configuration file"
msgstr "Localização da arquivo de configuração principal"

msgid "location of language data files"
msgstr "Localização dos arquivos de dados linguísticos"

msgid "location of the main word list"
msgstr "Nome da lista de palavras principais"

msgid "encoding to expect data to be in"
msgstr "codificação, na qual os dados são esperados para estar em"

msgid "add or removes a filter"
msgstr "adiciona ou remove um filtro"

msgid "path(s) aspell looks for filters"
msgstr "Pfad(e) onde aspell procura filtros."

msgid "extra dictionaries to use"
msgstr "zusätzliche dicionárias externos para uso"

msgid "ignore words <= n chars"
msgstr "ignorar palavras com <= n caracteres"

msgid "ignore commands to store replacement pairs"
msgstr "ignoriere comandos, substituição de pares para armazenar"

msgid "prefix directory"
msgstr "diretório de prefixo"

msgid "replacements list file name"
msgstr "Nome do Arquivo de Lista de Substituição"

msgid "maximum number that can be strung together"
msgstr "quantidade máxima de palavras compostas que podem ser juntadas"

msgid "minimal length of interior words"
msgstr "comprimento mínimo das palavras internas"

msgid "set the prefix based on executable location"
msgstr "Definir prefixo baseado no nome do programa"

msgid "no longer used"
msgstr "não é mais utilizado"

msgid "use replacement tables, override sug-mode default"
msgstr "utilize tabelas de substituição em vez do modo sug-mode padrão"

msgid "characters to insert when a word is split"
msgstr "quando um palavra for dividida, inscrever caracteres adicionais"

msgid "indicator for affix flags in word lists -- CURRENTLY IGNORED"
msgstr ""
"Indicador para flags de terminação em listas de palavras -- EM STATUS ATIVO "
"E NO FUNCIONAMENTO NORMAL"

msgid "use affix compression when creating dictionaries"
msgstr "Comprimir endonas ao gerar dicionários."

msgid "remove invalid affix flags"
msgstr "remover flags de terminação inválida"

msgid "partially expand affixes for better suggestions"
msgstr ""
"Para melhores sugestões, parte do apêndice para termos relacionados foi "
"expandida."

msgid "skip invalid words"
msgstr "palavras inválidas ignoradas"

msgid "create missing root/affix combinations"
msgstr "Criar combinações de palavras que carecem da terminação raiz/afixo"

msgid "suggest possible replacements"
msgstr "sugeridos substitutos possíveis"

msgid "The Unicode code point U+%04X is unsupported."
msgstr "O Unicode caracter na posição U+%04X não é suportado."

msgid "Invalid UTF-8 sequence at position %ld."
msgstr "Sequência UTF-8 inválida na posição %ld."

msgid "The file \"%file:1\" can not be opened"
msgstr "A ficheiro \"%file:1\" não pode ser aberto"

msgid "The file \"%file:1\" can not be opened for writing."
msgstr "A ficheiro \"%file:1\" não pode ser aberto para escrita."

msgid "The key \"%key:1\" is not an integer."
msgstr "O chave \"%key:1\" não é um número inteiro."

msgid "The key \"%key:1\" is not a list."
msgstr "O chave \"%key:1\" não é uma lista."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"reset-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por um "
"'reset-'."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by an "
"\"enable-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por um "
"'enable-'."

msgid "The language \"%lang:1\" is not known."
msgstr "A linguagem \"%lang:1\" é desconhecida."

msgid "Expected language \"%lang:1\" but got \"%prev:2\"."
msgstr "Linguagem esperada é '%lang:1', mas recebida foi '%prev:2'."

msgid "The word \"%word:1\" is invalid."
msgstr "O termo '\\%word:1' é inválido."

msgid "The affix flag '%aff:1' is invalid for word \"%word:2\"."
msgstr ""
"O uso do termo de finalização '%aff:1' para o sufixo da palavra '%word:2' é "
"inválido."

msgid "The affix flag '%aff:1' can not be applied to word \"%word:2\"."
msgstr "O termo 'affix %aff:1' não pode ser aplicado ao termo '%word:2'."

msgid "dlopen returned \"%return:1\"."
msgstr "falha ao abrir módulo com dlopen: \"%return:1\"."

msgid "The filter \"%filter:1\" does not exist."
msgstr "O filtro \"%filter:1\" não existe."

msgid "Aspell version does not match filter's requirement."
msgstr "Versão Aspell não corresponde aos requisitos do filtro."

msgid "Filter option already exists."
msgstr "A opção de filtragem já existe."

msgid "Unknown mode description key \"%key:1\"."
msgstr ""
"Modul descrevendo o padrão de operação `%key:1` não possui chave conhecida."

msgid "\"%mode:1\": no range for magic search given for magic \"%magic:2\"."
msgstr ""
"»%mode:1«: Não há um intervalo definido para a busca mágica de '%magic:2'."

msgid "\"%mode:1\": no magic expression available for magic \"%magic:2\"."
msgstr "»%mode:1«: Não há expressões mágicas disponíveis para »%magic:2«."

msgid "Error: %s\n"
msgstr "Erro: %s\n"

msgid "Error: "
msgstr "Erro: "

msgid "enter Email mode."
msgstr "Ao entrar no modo de e-mail."

msgid "Invalid Option: %s"
msgstr "Opção inválida: %s"

msgid "Time to load word list: "
msgstr "Tempo para carregar a lista de palavras:"

msgid "Only one file name may be specified."
msgstr "Só é permitido um nome de arquivo."

msgid "Invalid keymapping: %s"
msgstr "Ungültige Tastaturbelegung: %s"

msgid "Could not open the file \"%s\" for writing. File not saved."
msgstr ""
"Não foi possível abrir a pasta de arquivo '%s' para escrita. Arquivo não "
"salvo."

msgid "Replace"
msgstr "substituir"

msgid "Abort"
msgstr "Cancelar"

msgid "Are you sure you want to abort (y/n)? "
msgstr "Está certo que deseja interromper (j/n)?"

msgid "Yy"
msgstr "Jj"

msgid "Sorry that is an invalid choice!"
msgstr "Desculpe, mas esta é uma escolha inválida!"

msgid "Sorry \"create/merge personal\" is currently unimplemented.\n"
msgstr ""
"Desculpe, a funcionalidade de criação/união da lista pessoal ainda não foi "
"implementada."

msgid "\"%s\" is not a valid flag for the \"munch-list\" command."
msgstr "“%s” não é uma opção válida para o comando 'munch-list'."

msgid "Usage: aspell [options] <command>"
msgstr "Aufruf: aspell [Opções] <Comando>"

msgid "  help             display a detailed help message"
msgstr "Este é um texto de ajuda detalhado para o uso do software."

msgid "  [dump] config    dumps the current configuration to stdout"
msgstr "Gibt die aktuelle Konfiguration auf der Standardausgabe aus"

msgid "  munch            generate possible root words and affixes"
msgstr "gera possíveis palavras base e terminações"

msgid "  expand [1-4]     expands affix flags"
msgstr "expandir [1-4] Endungskennzeichen"

msgid "  munch-list [simple] [single|multi] [keep]"
msgstr "munch-list [simples] [único|mais de um] [manter]"

msgid "Enter"
msgstr "Pressione Enter"

msgid "Accept Changes"
msgstr "aceitar as alterações"

msgid "Backspace"
msgstr "Löschtaste"

msgid "Delete the previous character"
msgstr "Remover o caractere anterior"

msgid "Control-B"
msgstr "Ctrl+B"

msgid "Right"
msgstr "direita"

msgid "Control-F"
msgstr "Ctrl+F"

msgid "End"
msgstr "Fim"

msgid "Delete"
msgstr "remover"

msgid "Control-K"
msgstr "Ctrl-K"

msgid "Abort This Operation"
msgstr "Cancelar esta operação"

msgid "Warning: %s Skipping word.\n"
msgstr "Aviso: »%s«: Pule a palavra."

msgid "one of ultra, fast, normal, slow, or bad-spellers"
msgstr "um dos seguidos de ultra, fast, normal, slow ou bad-spellers."

msgid "a string of 'o','O','p',or 'P'"
msgstr "'o', 'O', 'p' ou 'P' constituem uma cadeia de caracteres."

msgid "HTML attributes to always check"
msgstr "o atributo HTML que sempre deve ser verificado"

msgid "filter for dealing with generic SGML/XML documents"
msgstr "um filtro, destinado a tratar documentos SGML/XML genéricos."

msgid "SGML attributes to always check"
msgstr "O SGML-Attribute sempre deve ser verificado."

msgid "check TeX comments"
msgstr "verificação de comentários em TeX"

msgid "filter to skip URL like constructs"
msgstr "filtro, para passar por URLs semelhantes"

msgid "mode for skipping quoted text in email messages"
msgstr "Modus para passar por cima de um texto citado em emails."

msgid "mode to disable all filters"
msgstr "Modo para desabilitar todos os filtros."

msgid "mode for checking Nroff documents"
msgstr "Modus para verificar o padrão de um documento nroff."
