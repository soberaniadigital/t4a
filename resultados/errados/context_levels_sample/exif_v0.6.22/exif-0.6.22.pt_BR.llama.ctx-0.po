msgid "Warning; Too many components specified!"
msgstr "Aviso: Foram especificadas muitas componentes!"

msgid "Could not write '%s' (%s)."
msgstr "O arquivo '%s' não pôde ser escrito (erro de %s)."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr ""
"Se o arquivo IFD »%s« não contém a marcação de extensão do formato '%s'!"

msgid "Could not determine size of '%s' (%s)."
msgstr "A medida de \"%s\" não pôde ser determinada (%s)."

msgid "'%s' does not contain tag '%s'."
msgstr "O texto \"%s\" não contém a marcação '»%s«'."

msgid "'%s' does not contain a thumbnail!"
msgstr "Olá! O arquivo %s não contém nenhuma pré-visualização!"

msgid "MakerNote does not contain any value.\n"
msgstr "Anotação do fabricante não contém valor."

msgid "Value"
msgstr "valor"

msgid "Show IDs instead of tag names"
msgstr "Exibir kennungen (IDs) em vez de nomes das marcações."

msgid "tag"
msgstr "Marcação"

msgid "List all EXIF tags"
msgstr "Listagem de todas as marcações EXIF do arquivo"

msgid "Output in a XML format"
msgstr "Saída em um formato XML."

msgid "You need to specify a tag!"
msgstr "Por favor, forneçam uma marcação!"
