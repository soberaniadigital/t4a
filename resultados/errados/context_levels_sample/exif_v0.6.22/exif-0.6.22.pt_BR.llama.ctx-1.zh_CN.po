msgid "Warning; Too many components specified!"
msgstr "Aviso: Foram especificadas mais componentes do que o permitido!"

msgid "Could not write '%s' (%s)."
msgstr "Não foi possível escrever na string \"%s\" (%s)."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr ""
"Olá! Seja bem vindo ao nosso sistema de localização. Por favor, informe o "
"nome do arquivo que você deseja processar para continuar."

msgid "Could not determine size of '%s' (%s)."
msgstr "A medida de \"%s\" não pôde ser determinada (%s)."

msgid "'%s' does not contain tag '%s'."
msgstr "\"%s\" não contém a marcação \"%s\"."

msgid "'%s' does not contain a thumbnail!"
msgstr "»%s« não contém nenhuma pré-visualização!"

msgid "MakerNote does not contain any value.\n"
msgstr "Anotação do fabricante não contém nenhum valor."

msgid "Value"
msgstr "valor"

msgid "Show IDs instead of tag names"
msgstr "Exibir kennungen (IDs) em vez de nomes das marcas antonomiais"

msgid "tag"
msgstr "Marcação"

msgid "List all EXIF tags"
msgstr "Listar todas as marcações EXIF"

msgid "Output in a XML format"
msgstr "Saída em um formato XML."

msgid "You need to specify a tag!"
msgstr "Por favor, indique uma marcação!"
