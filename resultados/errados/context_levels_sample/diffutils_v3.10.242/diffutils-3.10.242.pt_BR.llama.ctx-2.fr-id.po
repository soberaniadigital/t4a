msgid "invalid argument %s for %s"
msgstr "argumento %s inválido para %s"

msgid "Valid arguments are:"
msgstr "Os argumentos válidos são:"

msgid "character special file"
msgstr "ficheiro especial de caracteres"

msgid "multiplexed block special file"
msgstr "ficheiro especial com blocos multiplexados"

msgid "port"
msgstr "porta"

msgid "stack overflow"
msgstr "desbordeamento de pilha"

msgid "Try '%s --help' for more information."
msgstr "Utilize 'utilizando %s --help' para obter mais informações."

msgid "%s: option '%s%s' requires an argument\n"
msgstr "%s: a opção '%s%s' requer argumento\n"

msgid "%s: invalid option -- '%c'\n"
msgstr "%s: a opção -- '%c' não é válida"

msgid "'"
msgstr " »"

msgid "Success"
msgstr "Succès"

msgid "Premature end of regular expression"
msgstr "Fim prematuro da expressão regular"

msgid "Unmatched ) or \\)"
msgstr ") ou ) sem vis-à-vis"

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s. \n"

msgid "Written by %s, %s, and %s.\n"
msgstr ""
"Escrito por %s, %s e %s. \n"
"\n"
"(C) Copyright (c) [Year] by the authors."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr ""
"Escrito por %s, %s, %s\n"
"%s, %s e %s.\n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, and %s.\n"
msgstr ""
"Escrito por %s, %s, %s\n"
"%s, %s, %s e %s.\n"

msgid "General help using GNU software: <%s>\n"
msgstr "Ajuda geral sobre o uso dos softwares GNU: <%s>"

msgid "unknown stream"
msgstr "fluxo desconhecido"

msgid "invalid --ignore-initial value %s"
msgstr "valor %s para --ignore-initial inválido"

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=N      Descartar os N primeiros bytes das entradas"

msgid "    --help                 display this help and exit"
msgstr "    --help                  Mostrar esta ajuda e sair"

msgid "-v, --version              output version information and exit"
msgstr ""
"-v, --version               Mostrar o nome e a versão do software e depois "
"sair."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"Os parâmetros opcionais SAUT1 e SAUT2 indicam o número de bytes a escapar no"
" início de cada arquivo (zero por padrão)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os parâmetros necessários para as opções longas também são necessários para "
"as opções curtas."

msgid "extra operand %s"
msgstr "opérande adicional %s"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s são diferentes: octeto %<PRIdMAX>, linha %<PRIdMAX>"

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF no final do arquivo (EOF) em %s que está vazio"

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF no final do arquivo (EOF) em %s após o byte %<PRIdMAX>"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Len Tower"
msgstr "Torre de Len"

msgid "invalid tabsize %s"
msgstr "tamanho de tabulação %s inválido"

msgid "conflicting tabsize options"
msgstr "opções conflitantes de tamanho de tabulação"

msgid "-q, --brief                   report only when files differ"
msgstr "-q, --brief                   Indicar apenas se os arquivos diferem"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     Gera um arquivo 'diff' no formato RCS."

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=N                Limite a saída em no máximo N colunas impressas"
" (130 por padrão)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column            Mostrar apenas as linhas idênticas na coluna "
"esquerda"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   Mostrar a linha mais recente correspondente ao"
" RE"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Estenda os tabuleiros em espaços na saída"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=N              Balões de tabulação estão a cada N (8 por "
"padrão) colunas."

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            Não siga links simbólicos"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case   Ignorar a diferença de maiúsculas e minúsculas"
" na comparação dos nomes de arquivos."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   Ignorar alterações relacionadas à expansão das "
"tabulações"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignora os espaços em branco finais da "
"linha"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     Ignorar alterações em quaisquer linhas que "
"estejam todas em branco"

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                    Tratar todos os arquivos como textos"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr       Eliminar os retornos de carro da entrada"

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'old', 'new' ou 'unchanged'. GTYP recebe uma das opções de "
"LTYPE, ou seja, 'changed'."

msgid "    --help               display this help and exit"
msgstr "    --help               exibir esta ajuda e sair"

msgid "-v, --version            output version information and exit"
msgstr "-v, --version            exibir o nome e a versão do software e sair"

msgid "conflicting %s option value %s"
msgstr "valor %2$s conflitante da opção %1$s"

msgid "conflicting output style options"
msgstr "opções de estilo de saída conflituosas"

msgid "invalid color %s"
msgstr "cor da cor %s inválida"

msgid "-D option not supported with directories"
msgstr "A opção -D não trata os diretórios."

msgid "cannot compare '-' to a directory"
msgstr "não pode comparar '-' com um diretório"

msgid "'-' specified for more than one input file"
msgstr ""
"Fourneau para mais de um arquivo de entrada - '}' fourneau para mais do que "
"um ficheiro de entrada"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only    Com como -e mas inclui as alterações que se sobrepõem"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr ""
"-i                            Adicionar as comandas 'w' e 'q' ao script 'ed'"

msgid "-a, --text                  treat all files as text"
msgstr "-a, --text                    Tratar todos os arquivos como textos"

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROG              Utilizar o PROGramme para comparar os "
"arquivos"

msgid "%s: diff failed: "
msgstr "%s: falha ao executar 'diff': "

msgid "invalid diff format; invalid change separator"
msgstr "formato de « diff » inválido; separador de alteração inválido"

msgid "invalid diff format; incomplete last line"
msgstr "formato de « diff » inválido; última linha incompleta"

msgid "internal error: invalid diff type passed to output"
msgstr "erro interno : tipo de \"diff\" inválido fornecido na saída"

msgid "%s: recursive directory loop"
msgstr "%s: loop recursivo no diretório"

msgid "Thomas Lord"
msgstr "Senhor Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=FICHIER         Interagir interativamente, com saída para "
"FICHIER"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignora os espaços em branco finais da "
"linha"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    Ignorar mudanças no espaçamento das linhas de "
"texto"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     Ignorar alterações em que todas as linhas são "
"brancas"

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      Supõe de grandes arquivos e muitos pequenos "
"alterações esparramados."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROG      Utilizar o PROGramme para comparar os arquivos"

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar esta ajuda e sair"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v, --version                Mostrar o nome e a versão do software e sair"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Fusão lateral das diferenças entre os arquivos."

msgid "cannot interactively merge standard input"
msgstr "não podem mesclar a entrada padrão interativamente"

msgid "both files to be compared are directories"
msgstr "Os dois arquivos a serem comparados são diretórios"
