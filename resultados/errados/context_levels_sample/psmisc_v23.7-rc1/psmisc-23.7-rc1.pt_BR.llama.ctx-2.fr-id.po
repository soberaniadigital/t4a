msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção do espaço de nomes requer um argumento."

msgid "Invalid namespace name"
msgstr "Namensraum inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"--exact          requer uma concordância exata para nomes muito longos (%<PRIuMAX>)\n"
"-I,--ignore-case    faz a comparação sem diferenciar maiúsculas e minúsculas (-e) ou ignorando as casas altas/baixas (-i)\n"
"-g,--process-group  termina o grupo associado ao programa em vez do processo individual (%s)\n"
"-y,--younger-than   encerra programas criados antes de uma determinada data e hora específsca (%<PRIuMAX>)\n"
"-o,--older-than     encerra programas criados depois daquela mesma data e hora\n"
"-i,--interactive    solicita confirmação do usuário antes de prosseguir com a terminação dos processos (-q para silencioso, -v para verbose)\n"
"-l,--list           lista todos os nomes conhecidos de sinais (%s)\n"
"-q,--quiet          sem mensagens ou avisos\n"
"-r,--regexp         interpreta o nome como um padrão regular estendido (-u para usuário específico, -v para verbose output)\n"
"-s,--signal SIGNAL    envia este sinal em vez de SIGTERM (%d)\n"
"-u,--user USER      termina apenas os processos executados pelo usuário especificado\n"
"-v,--verbose        notifica se o sinal foi enviado com sucesso (-V para versão do programa, -w para esperar que os programas terminem antes de sair)\n"
"-w,--wait           aguarda a conclusão dos processos ativos (%s)\n"
"-n,--ns PID         considera apenas aqueles processos pertencentes ao mesmo espaço nominal que o PID especificado\n"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP encerre apenas os processos que possuem contexto "
"(mandatório antes de outros argumentos)\n"

msgid "Invalid time format"
msgstr "Fechamento não permitido para este arquivo."

msgid "Cannot find user %s\n"
msgstr "Utilizador %s não pode ser encontrado"

msgid "Invalid namespace PID"
msgstr "PID inválido para o espaço de nomes"

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2donde Small Craig\n"

msgid "running"
msgstr "o processo está em execução."

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Política de Orçamento de Recursos (R)T\n"
" Política de Alocação de Tempo (Nice): %s \t Prioridade R/T: %ld \t Courtoisie: %ld \n"

msgid "Invalid option"
msgstr "opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all mettere em destaque o processo atual e seus antecessores\n"
" -H PID, --highlight-pid=PID\n"
"                      mete este processo e seus antecessores em evidência\n"
" -l, --long          não corte linhas longas"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID    iniciar com este PID; o valor padrão é 1 (init)\n"
"USER   exiba apenas árvores de processos que tenham raízes em processos deste usuário"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Não há nenhum usuário com esse nome: %s"

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
