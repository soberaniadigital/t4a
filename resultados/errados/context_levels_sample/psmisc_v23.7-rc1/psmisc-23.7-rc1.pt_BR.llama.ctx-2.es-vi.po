msgid "Specified filename %s does not exist.\n"
msgstr "O nome do arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer argumento."

msgid "Invalid namespace name"
msgstr "Nome inválido para espaço de nomes"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'command': '-e,--exact', 'description': 'yêu cầu khớp chính xác với mọi "
"tên rất dài'}, {'command': '-I,--ignore-case', 'description': 'không phân "
"biệt HOA/thường khi khớp tên tiến trình'}, {'command': '-g,--process-group',"
" 'description': 'buộc kết thúc nhóm tiến trình thay thế tiến trình'}, "
"{'command': '-y,--younger-than', 'description': 'buộc kết thúc mỗi tiến "
"trình mới hơn THỖI_GIAN'}, {'command': '-o,--older-than', 'description': "
"'buộc kết thúc mỗi tiến trình cũ hơn THỖI_GIAN'}, {'command': '-i,--"
"interactive', 'description': 'xin xác nhận trước khi buộc kết thúc'}, "
"{'command': '-l,--list', 'description': 'liệt kê mọi tên tín hiệu đã biết'},"
" {'command': '-q,--quiet', 'description': 'không hiển thị lời than phiền "
"(_im_)'}, {'command': '-r,--regexp', 'description': 'giải thích TÊN là biểu "
"thức chính quy mở rộng'}, {'command': '-s,--signal SIGNAL', 'description': "
"'gửi tín hiệu này gọi đến các tiến trình, thay thế cho SIGTERM'}, "
"{'command': '-u,--user USUARIO', 'description': 'buộc kết thúc chỉ những "
"tiến trình đang chạy dưới tư cách người dùng'}, {'command': '-v,--verbose', "
"'description': 'thông báo khi đã gửi tín hiệu thành công'}, {'command': '-V,"
"--version', 'description': 'hiện thông tin phiên bản của chương trình'}, "
"{'command': '-w,--wait', 'description': 'đợi tiến trình kết thúc'}, "
"{'command': '-n,--ns PID', 'description': 'khớp mẫu tiết trình cái mà thuộc "
"về cùng một không gian tên'}]"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP interrompa processos que possuem contexto (deve "
"anteceder a outros argumentos)"

msgid "Invalid time format"
msgstr "Formato de hora no válido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "Namensraum PID inválido"

msgid "Bad regular expression: %s\n"
msgstr "Expresão regular mal formada: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2donde Small, Craig\n"

msgid "running"
msgstr "executando"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Política de Gerenciamento do Processo\n"
"  Política: %s\n"
"Cortesia RT (Prioridade Real Time):   %ld \t Prioridade da Linha Rozhskiy:%ld\n"

msgid "Invalid option"
msgstr "opção inválida -- '%s'"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all resalta o processo atual e seus antecessores\n"
" -H PID, --highlight-pid=PID\n"
"                      destaca este processo e seus antecessores\n"
" -l, --long          não corte as linhas longas"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID     empezar con esta PID; valor por defecto es 1 (init)\n"
"USUARIO muestra solo árboles que tienen raíces en los procesos de este usuario."

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s\n"

msgid "No such user name: %s\n"
msgstr "Não há nenhum usuário com o nome 'Es'."

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar"
