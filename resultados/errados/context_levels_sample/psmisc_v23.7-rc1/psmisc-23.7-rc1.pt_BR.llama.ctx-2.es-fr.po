msgid "Specified filename %s does not exist.\n"
msgstr "O nome do arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço de nomes requer argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço de nomes inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"--exact          requer uma concordância exata para nomes muito longos\n"
"-I,--ignore-case    pesquisa ignorando diferenças entre maiúsculas e minúsculas\n"
"-g,--process-group  termina o grupo de processos associado ao programa em vez do próprio programa\n"
"-y,--younger-than   termina os programas criados após a HORA especificada\n"
"-o,--older-than     termina os programas criados antes da HORA especificada\n"
"-i,--interactive    solicita confirmação do usuário antes de terminar o programa\n"
"-l,--list           lista todos os nomes conhecidos dos sinais\n"
"-q,--quiet          não exibe notificações ou aviso\n"
"-r,--regexp         interpreta NOM como uma expressão regular estendida\n"
"-s,--signal SIGNAL   envia este sinal em vez de enviar o SIGTERM padrão\n"
"-u,--user USUARIO  termina apenas os processos que são executados pelo usuário especificado\n"
"-v,--verbose        exibe uma mensagem indicando se a comunicação foi bem sucedida após ter enviado o sinal\n"
"-V,--version          mostra informações sobre a versão do programa\n"
"-w,--wait           aguarda que os programas terminem suas tarefas antes de sair\n"
"-n,--ns PID         termina apenas aqueles processos no mesmo espaço de nomes que o PID especificado"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP interrompa apenas processos que possuem contexto (deve"
" anteceder outros argumentos)"

msgid "Invalid time format"
msgstr "Formato de hora inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "PID de espaço de nomes inválido"

msgid "Bad regular expression: %s\n"
msgstr "Expresão regular mal formada: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2024 Craig Small\n"

msgid "running"
msgstr "executando"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Política de Gerenciamento do Processo\n"
"  Política: %s\n"
"Cortesia RT (Prioridade Real Time):   %ld \n"
"%s"

msgid "Invalid option"
msgstr "opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
"ES\n"
"{\"highlight_all\": true, \"highlight_pid\": null}\n"
"{\"long\": false}\n"
"{\"help\": \"Tente `%s --help' para mais informações.\"}"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID     iniciar este PID; valor padrão é 1 (init)\n"
"USUARIO mostra apenas árvores com raízes em processos desse usuário"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s\n"

msgid "No such user name: %s\n"
msgstr "Não há usuário com esse nome de usuário: %s"

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
