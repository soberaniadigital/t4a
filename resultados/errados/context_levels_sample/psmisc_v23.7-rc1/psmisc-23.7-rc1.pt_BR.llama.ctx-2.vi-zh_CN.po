msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço nomeado requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço de nomes inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'original_text': '-e,--exact', 'translated_text': '-e, --exact'}, "
"{'original_text': '-I,--ignore-case', 'translated_text': '-i, --ignore-"
"case'}, {'original_text': '-g,--process-group', 'translated_text': '-g, "
"--process-group'}, {'original_text': '-y,--younger-than', 'translated_text':"
" '-y, --menor que [TIME]'}, {'original_text': '-o,--older-than', "
"'translated_text': '-o, --maior que [TIME]'}, {'original_text': '-i,--"
"interactive', 'translated_text': '-i, --interativo'}, {'original_text': '-l,"
"--list', 'translated_text': '-l, --lista'}, {'original_text': '-q,--quiet', "
"'translated_text': '-q, em silêncio'}, {'original_text': '-r,--regexp', "
"'translated_text': '-r, --expressão regular'}, {'original_text': '-s,--"
"signal SIGNAL', 'translated_text': '-s, enviar sinal [SIGNAL]'}, "
"{'original_text': '-u,--user USER', 'translated_text': '-u, --usuário'}, "
"{'original_text': '-v,--verbose', 'translated_text': '-v, em detalhes'}, "
"{'original_text': '-V,--version', 'translated_text': '-V, --versão'}, "
"{'original_text': '-w,--wait', 'translated_text': '-w, esperar a terminação "
"dos processos'}, {'original_text': '-n,--ns PID', 'translated_text': '-n, "
"com base no namespace do ID de Processo (PID)'}]"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP nur Prozesse que possuem contexto (mandatório antes de"
" outros argumentos)\n"

msgid "Invalid time format"
msgstr "Formato de tempo inválido"

msgid "Cannot find user %s\n"
msgstr "Não foi possível encontrar o usuário %s."

msgid "Invalid namespace PID"
msgstr "PID inválido para o espaço de nomes especificado."

msgid "Bad regular expression: %s\n"
msgstr "Biểu thức regular não é válido: %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Privilégio (C) 2009–2024 Craig Small"

msgid "running"
msgstr "o programa está rodando"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Política de agendamento\n"
"   Chave:\t%s\n"
"Máximo nível de prioridade RT: %ld\t\tReal-time Priority: %ld \n"

msgid "Invalid option"
msgstr "opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all tô sáng tiến trình hiện tại và con cháu của nó\n"
"-H PID, --highlight-pid=PID\n"
"                      tô sáng tiến trình này và các con cháu của nó\n"
"-l, --long          đừng cắt ngắn các dòng dài"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID    iniciar a partir deste PID; valor padrão é 1 (init)\n"
"NÚMERO_USUARIO   apenas mostrar árvores de processos cujas raízes são os processos desse usuário"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Não há usuário com o nome '{}'."

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
