msgid "Specified filename %s does not exist.\n"
msgstr "Nome do arquivo %s não foi encontrado."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço nomeado requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço de nomes inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"{'-e,--exact          membutuhkan pencocokan tepat unt0\\n      killall -l, "
"--list\\n      killall -V, --version': 'membutuhkan coincidência exata para "
"nomes muito longos', '-I,--ignore-case   pencocokan nama proses tidak "
"memperhatikan besar huruf\\n      killall -l, --list\\n      killall -V, "
"--version': 'ignorando diferenças entre maiúsculas e minúsculas nos nomes "
"dos processos', '-g,--process-group  hentikan proses grup daripada proses\\n"
"      killall -l, --list\\n      killall -V, --version': 'matar o grupo de "
"processos em vez do único processo', '-y,--younger-than   hentikan proses "
"lebih muda dari WAKTU\\n      killall -l, --list\\n      killall -V, "
"--version': 'matar os processos mais jovens que o tempo especificado', '-o,"
"--older-than     hentikan proses lebih tua dari WAKTU\\n      killall -l, "
"--list\\n      killall -V, --version': 'matar os processos mais velhos do "
"que o tempo especificado', '-i,--interactive   tanya untuk konfirmasi "
"sebelum menghentikan\\n      killall -l, --list\\n      killall -V, "
"--version': 'pedir confirmação ao usuário antes de matar os processos', '-l,"
"--list           daftar seluruh nama sinyal yang diketahui\\n      killall "
"-l, --list\\n      killall -V, --version': 'lista todos os sinais "
"conhecendo-se o nome do mesmo', '-q,--quiet          jangan tampilkan "
"komlainin\\n      killall -l, --list\\n      killall -V, --version': 'sem "
"mensagens de erro ou aviso serão apresentadas ao usuário', '-r,--regexp"
"         interpretasikan NAMA sebagai sebuah ekstensi ekpresi regular\\n"
"      killall -l, --list\\n      killall -V, --version': 'interpretar o nome"
" do processo como um padrão de expressão regular', '-s,--signal SINYAL  "
"kirim sinyal ini daripada SIGTERM\\n      killall -l, --list\\n      killall"
" -V, --version': 'enviar sinal especificado em vez do padrão de terminação',"
" '-u,--user USER       hentikan hanya proses yang berjalan sebagai "
"PENGGUNA\\n      killall -l, --list\\n      killall -V, --version': 'matar "
"apenas os processos que estão em uso pelo usu0', '-v,--verbose        "
"laporkan jika sinyal telah secara sukses dikirimkan\\n      killall -l, "
"--list\\n      killall -V, --version': 'registrar se o sinal foi enviado com"
" êxito ao usuário', '-V,--version        tampilkan informasi versi\\n      "
"killall -l, --list\\n      killall -V, --version': 'mostrar a versão do "
"utilitário de controle de processos'}"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
" -Z,--context REGEXP somente encerra processos que tenham contexto "
"(mandatório antes de outros argumentos)\n"

msgid "Invalid time format"
msgstr "Formato de tempo inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "ID de processo não válido para o espaço de nomes especificado."

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

