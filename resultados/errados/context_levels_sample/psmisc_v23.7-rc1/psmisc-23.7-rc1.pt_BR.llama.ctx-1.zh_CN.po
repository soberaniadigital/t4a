"\n"
msgstr "Copyright (C) 2009–2024 Craig Small\n"

msgid "running"
msgstr "o processo está rodando"

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
