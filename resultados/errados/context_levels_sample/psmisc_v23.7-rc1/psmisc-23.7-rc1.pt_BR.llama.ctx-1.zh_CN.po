msgid "Invalid option"
msgstr "opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all \n"
"                        destaque todos os processos atuais e seus antecessores\n"
" -H PID, --highlight-pid=PID\n"
"                        destacar o processo com ID específico e seus antecessores\n"
" -l, --long\n"
"                         sem cortar as linhas longas"

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID     iniciar com esta PID; valor padrão é 1 (init)\n"
"NÚMERO    mostrar apenas árvores de processos que têm raízes em processos deste usuário"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Nenhum usuário com o nome '\\"

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
