msgid "Specified filename %s does not exist.\n"
msgstr "Nome de arquivo %s não foi encontrado."

msgid "Namespace option requires an argument."
msgstr "A opção de espaço nomeado requer um argumento."

msgid "Invalid namespace name"
msgstr "Nome do espaço de nomes inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"[{'command': '-e,--exact', 'description': 'obrigatório para nomes longos "
"exatamente corresponderem'}, {'command': '-I,--ignore-case', 'description': "
"'ignora diferenças entre maiúsculas e minúsculas na comparação de processo "
"nome'}, {'command': '-g,--process-group', 'description': 'mata o grupo de "
"processos em vez do único processo'}, {'command': '-y,--younger-than', "
"'description': 'matar os processos que foram iniciados após a hora "
"especificada'}, {'command': '-o,--older-than', 'description': 'matar os "
"processos que foram iniciados antes da hora especificada'}, {'command': '-i,"
"--interactive', 'description': 'pedir confirmação ao usuário antes de matar "
"o processo'}, {'command': '-l,--list', 'description': 'lista todos os nomes "
"dos sinais disponítables para uso com este comando'}, {'command': '-q,--"
"quiet', 'description': 'não exibe mensagens de erro ou aviso ao usuário'}, "
"{'command': '-r,--regexp', 'description': 'considera o nome do processo como"
" um padrão regular para busca eficiente'}, {'command': '-s,--signal SIGNAL',"
" 'description': 'envia sinal especificado ao processo em vez de SIGTERM por "
"padrão'}, {'command': '-u,--user USER', 'description': 'mata apenas os "
"processos que pertencem a usuário especificado'}, {'command': '-v,--"
"verbose', 'description': 'exibe mensagem de confirmação após o sinal ter "
"sido enviado com êxito ao processo'}, {'command': '-V,--version', "
"'description': 'imprime a versão do utilitário killall'}, {'command': '-w,--"
"wait', 'description': 'esperar até que o processo termine antes de sair'}, "
"{'command': '-n,--ns PID', 'description': 'considera apenas os processos com"
" nomes no mesmo espaço de nomes do PID especificado'}]"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP apenas encerre processos com contexto específico\n"
"                        (deve ser utilizado antes de outros argumentos)"

msgid "Invalid time format"
msgstr "Formato de tempo inválido"

msgid "Cannot find user %s\n"
msgstr "O usuário %s não pode ser encontrado."

msgid "Invalid namespace PID"
msgstr "Nenhuma PID de nome espaço é válida."

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida: %s"

