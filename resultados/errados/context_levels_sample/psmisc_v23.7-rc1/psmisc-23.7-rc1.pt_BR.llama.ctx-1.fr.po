msgid "Specified filename %s does not exist.\n"
msgstr "O nome do arquivo %s não existe."

msgid "Namespace option requires an argument."
msgstr "A opção do espaço de nomes requer um argumento."

msgid "Invalid namespace name"
msgstr "Namensraum inválido"

msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"      -e,--exact          requer uma concordância perfeita para nomes muito longos\n"
"      -I,--ignore-case     pesquisa ignorando a diferença entre maiúsculas e minúsculas\n"
"      -g,--process-group    termina o grupo associado ao programa em vez do próprio processo\n"
"      -y,--younger-than   termina os programas criados antes da hora especificada\n"
"      -o,--older-than     termina os programas criados depois da hora especificada\n"
"      -i,--interactive    solicita confirmação do usuário antes de terminar o processo\n"
"      -l,--list           lista todos os nomes conhecidos dos sinais\n"
"      -q,--quiet          não exibe notificações ou erros\n"
"      -r,--regexp         interpreta NOM como uma expressão regular estendida\n"
"      -s,--signal SIGNAL   envia esse sinal em vez de SIGTERM\n"
"      -u,--user USER     termina apenas os programas utilizados por usuário especificado\n"
"      -v,--verbose        notifica se o sinal foi enviado com sucesso\n"
"      -V,--version       exibe as informações sobre a versão\n"
"      -w,--wait           aguarda que os processos terminem\n"
"      -n,--ns PID         termina apenas aqueles pertencentes ao mesmo espaço de nomes do PID especificado"

msgid ""
"  -Z,--context REGEXP kill only process(es) having context\n"
"                      (must precede other arguments)\n"
msgstr ""
"  -Z,--context REGEXP pare apenas os processos com contexto\n"
"                        (deve vir antes de outros argumentos)"

msgid "Invalid time format"
msgstr "Fechamento não permitido para este arquivo."

msgid "Cannot find user %s\n"
msgstr "Utilizador %s não pode ser encontrado"

msgid "Invalid namespace PID"
msgstr "PID inválido de espaço de nomes"

msgid "Bad regular expression: %s\n"
msgstr "Expressão regular inválida : %s"

msgid ""
"Copyright (C) 2009-2024 Craig Small\n"
"\n"
msgstr "Copyright (C) 2009–2024 Craig Small\n"

msgid "running"
msgstr "o processamento está em execução."

msgid ""
"Scheduling\n"
"  Policy: %s\n"
"  Nice:   %ld \t\t RT Priority: %ld %s\n"
msgstr ""
"Política de Orçamento para Processos\n"
" Política: %s\n"
" Consideração Cortês: %ld \tPrioridade Real Time (RT): %ld %s"

msgid "Invalid option"
msgstr "opção inválida"

msgid ""
"  -h, --highlight-all highlight current process and its ancestors\n"
"  -H PID, --highlight-pid=PID\n"
"                      highlight this process and its ancestors\n"
"  -l, --long          don't truncate long lines\n"
msgstr ""
" -h, --highlight-all mete em destaque o processo atual e seus antecessores \n"
" -H PID, --highlight-pid=PID\n"
"                      mete em destaque esse processo específico e seus predecessores com base no seu identificador de Process ID (PID) \n"
" -l, --long          não corte as linhas longas "

msgid ""
"\n"
"  PID    start at this PID; default is 1 (init)\n"
"  USER   show only trees rooted at processes of this user\n"
"\n"
msgstr ""
"PID    iniciar com este PID; o valor padrão é 1 (init)\n"
"USER   mostrar apenas os subárbores que contêm processos desse usuário"

msgid "pstree (PSmisc) %s\n"
msgstr "pstree (PSmisc) %s"

msgid "No such user name: %s\n"
msgstr "Não há nenhum usuário com o nome '\\"

msgid "Press return to close\n"
msgstr "Pressione Enter para fechar."
