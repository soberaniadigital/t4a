msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "? at start of expression"
msgstr "O biquíntem não é uma expressão válida."

msgid "+ at start of expression"
msgstr "O biquíntem não é uma expressão válida."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "caractere de agrupamento inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contém conteúdo inválido."

msgid "Premature end of regular expression"
msgstr "Biểu thức regular expression expira prematuramente."

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\")” lẻ đôi"

msgid "No previous regular expression"
msgstr "Não há expressões regulares antes deste ponto."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s, %s, %s e %s."

msgid "%s home page: <%s>\n"
msgstr "%s da página principal do site %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” lẻ đôi"

msgid "extra characters after command"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unterminated `y' command"
msgstr "comando “y” não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr ""
"Os comandos e/r/w estão desabilitados no modo de segurança do sandbox."

msgid "option `e' not supported"
msgstr "Não há suporte para a opção ‘e’."

msgid "`e' command not supported"
msgstr "não é suportado o comando ‘e’"

msgid "no input files"
msgstr "não há arquivo de entrada disponível"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "A referência \\\"%d\\\" no lado direito da instrução `s` não é válida."

msgid "regex input buffer length larger than INT_MAX"
msgstr "a tamanho do buffer de entrada regex é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed neste código possui suporte ao SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste momento não contém suporte ao SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"deixe o modo de impressão automática desabilitado para a busca em curso."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguir links simbólicos durante o processamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"chave -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 modifica o arquivo no local (cria uma cópia se um sufixo for especificado)"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                    Tratamento dos arquivos como independentes uns dos outros em vez de um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 Executar em modo sandbox (desligar e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo binário em “%s”"

msgid "read error on %s: %s"
msgstr "erro de leitura no %s: %s"
