msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "código não finalizado \""

msgid "? at start of expression"
msgstr "Biêu teorema não é válido."

msgid "+ at start of expression"
msgstr "Biêu teorema não é válido."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "caracter '%s' não é aceito para comparação."

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contém conteúdo inválido."

msgid "Premature end of regular expression"
msgstr "Obiamente o fechamento do biquete regular não é prematuro."

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc não par pairwise ou \")\n"

msgid "No previous regular expression"
msgstr "Não há mais expressões regulares para analisar."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrevido por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrevido por %s, %s e %s. Eles desenvolveram o programa em conjunto com a "
"equipe de %d."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Autores da aplicação — %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrevido por %s, %s, %s, %s, %s, %s, %s e %s."

msgid "%s home page: <%s>\n"
msgstr "Página principal do usuário %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở \"{\" lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos e/r/w interrompidos no modo de segurança da sandbox"

msgid "option `e' not supported"
msgstr "parâmetro «e» não é suportado."

msgid "`e' command not supported"
msgstr "comando «e» não é suportado."

msgid "no input files"
msgstr "não há arquivos de entrada disponíveis"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência inválida \\\"%d\\\" para a RHS do comando \"s\""

msgid "regex input buffer length larger than INT_MAX"
msgstr "A longitud do buffer de entrada regex é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr ""
"O programa sed neste trecho foi desenvolvido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste código não possui suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"trocar para o modo silencioso ou sem saída de texto ao executar a operação."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguindo sinais simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 alterar arquivos no local (cria uma cópia se HẬU_TỐ for utilizado)\n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 considerar arquivos separadamente, e não como uma única longa fonte contínua."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox thêm em modo sandbox (desligar comandos e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir modo binário de dois níveis para \"%s\""

msgid "read error on %s: %s"
msgstr "falha na leitura no %s: %s"
