msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "sequência não concluída \""

msgid "? at start of expression"
msgstr "Biêu teorema chinês não é válido."

msgid "+ at start of expression"
msgstr "Biêu teorema chinês não é válido."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "caractere de comparação inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contém conteúdo inválido em \\\"{}\\\"."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc rấdương"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc não pariado (“)” ou “\\) lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há mais expressões regulares anteriores."

msgid "Written by %s.\n"
msgstr "Escrita por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrevido por %s, %s e %s. E a opção '%c' não é válida.\n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Autores da aplicação — %s, %s, %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escreve por %s, %s, %s, %s, %s, %s, %s e %s."

msgid "%s home page: <%s>\n"
msgstr "Página de usuário %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở \"{\" lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "As operações de leitura/escrita estão desligadas no modo seguro."

msgid "option `e' not supported"
msgstr "opção \"e\" não é suportada."

msgid "`e' command not supported"
msgstr "A opção 'e' não é suportada."

msgid "no input files"
msgstr "não há arquivos de entrada disponíveis"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%d\\\" inválida no membro direito da instrução `s`."

msgid "regex input buffer length larger than INT_MAX"
msgstr "A longidade do buffer de entrada regex maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed aqui apresentado contém suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed aqui foi compilado sem suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"trocar para o modo silencioso do programa automaticamente ao detectar a falta de conexão com um soquete remoto."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguindo sinais simbólicos durante o tratamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 modificar arquivos no local (cria uma cópia se o HẬU_TỐ for especificado)"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 considerar arquivos como separados em vez de um fluxo longo e contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox thêm em modo sandbox (desligar comandos e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo binário em “%s”"

msgid "read error on %s: %s"
msgstr "erro de leitura no %s: %s"
