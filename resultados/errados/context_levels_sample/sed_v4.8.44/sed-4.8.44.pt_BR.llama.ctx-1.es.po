msgid "unbalanced ["
msgstr ""
"falha na verificação da linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "falha na análise/analisando a sintaxe especificada."

msgid "Invalid collation character"
msgstr "carácter de ordenamento inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contenido inválido de \\\"\\{\\\"\"}."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\")"

msgid "No previous regular expression"
msgstr "Não há uma expressão regular prévia para avaliar."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e y %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr ""
"Escrito por %s, %s, %s, \n"
"%s, %s e %s. \n"
"\n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Viết bởi %s, %s, %s,\n"
"%s, %s, %s, %s\n"
"và %s.\n"

msgid "%s home page: <%s>\n"
msgstr "%s página inicial: <%s>"

msgid "unmatched `{'"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "extra characters after command"
msgstr "caracteres extras após a ordem"

msgid "unterminated `y' command"
msgstr "lênhei `y` não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "As operações de leitura/escrita estão desativadas no modo 'sandbox'."

msgid "option `e' not supported"
msgstr "não há suporte para a opção `e'"

msgid "`e' command not supported"
msgstr "não há suporte para a ordem `e`"

msgid "no input files"
msgstr "não há arquivos de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "falha na referência \\\"%d\\\" no lado direito da instrução `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"a longitud do buffer de entrada da expressão regular é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "Este programa sed está construído com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "Este programa sed está construído sem suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n,--quiet, --silent\n"
"troca o modo de operação para silencioso e não exibe mensagens ao longo da execução do programa."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 siga os links simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"chama o comando 'sed' para editar arquivos no local (cria um backup se "
"houver extensão de script) [HẬU_TỐ]"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considera os arquivos como separados em vez de um único fluxo, longo e "
"contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 operar no modo sandbox (desligar as ordens e/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falhou ao definir o modo binário em '%s'"

msgid "read error on %s: %s"
msgstr "erro ao ler do %s: %s"
