msgid "unbalanced ["
msgstr "[ não correspondente]"

msgid "unfinished \\ escape"
msgstr "sequência de escape não concluída"

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biuiuc chính quyu quá lớn"

msgid "no syntax specified"
msgstr ""
"não foi possível encontrar o código de erro específico para a sintaxe não "
"fornecida."

msgid "Invalid collation character"
msgstr "Caractere de agrupamento inválido"

msgid "Unmatched \\{"
msgstr "não foi possível encontrar o par de chaves '{'"

msgid "Invalid content of \\{\\}"
msgstr "Contém dados inválidos."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm"

msgid "Regular expression too big"
msgstr "Biuiuc chính quyu quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng \")\" hay \")\" non apparié."

msgid "No previous regular expression"
msgstr "Não há uma expressão regular principal para a frente"

msgid "Written by %s.\n"
msgstr "Écrit par %s."

msgid "Written by %s and %s.\n"
msgstr "É escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Écrit por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Écrit par %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Écrit por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, e outros autores. \n"

msgid "%s home page: <%s>\n"
msgstr "Trâng chủ %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở « { » non appariée"

msgid "extra characters after command"
msgstr "caracteres desnecessários após a comando"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr ""
"códigos de operação e/r/w foram desligados no ambiente seguro para testes"

msgid "option `e' not supported"
msgstr "a opção 'e' não é suportada."

msgid "`e' command not supported"
msgstr "não há suporte para a comando 'e'"

msgid "no input files"
msgstr "não há ficheiro de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%d\". Inválida no membro direito da instrução \"s\"."

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"o comprimento do buffer de entrada da expressão regular é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed a sido compilado para suportar SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed a sido compilado sem suporte ao SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"troca o modo de operação para silencioso e não exibe mensagens ao usuário."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguir links simbólicos durante o tratamento"

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HOTO_TÓ], --in-place[=HOTO_TÓ] \n"
"                 editar os arquivos no local (faz uma cópia de segurança se o HOTO_TÓ for aplicado) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"  -s, --separate\n"
"                considerar os arquivos como separados em vez de um fluxo long e contínuo. \n"

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 opera em modo sandbox (desativa as comandas e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao colocar o sistema em modo binário no dispositivo \"%s\""

msgid "read error on %s: %s"
msgstr "lỗi đọc trên %s: %s"
