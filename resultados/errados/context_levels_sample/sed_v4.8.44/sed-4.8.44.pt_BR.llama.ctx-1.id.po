msgid "unbalanced ["
msgstr "[ ID não equilibrado"

msgid "unfinished \\ escape"
msgstr "não foi possível escapar o caractere de escape na string \""

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biuiuc chính quyu khuyaquá lớn"

msgid "no syntax specified"
msgstr ""
"não foi possível encontrar o caminho para a ferramenta de linha de comando"

msgid "Invalid collation character"
msgstr "O caractere de identificação não é válido."

msgid "Unmatched \\{"
msgstr "\\{ sem par\tanca"

msgid "Invalid content of \\{\\}"
msgstr "{\\\"\\"

msgid "Premature end of regular expression"
msgstr "Biêu từng quy kết thúc quá sớm."

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\\)” lẻ đôi"

msgid "No previous regular expression"
msgstr ""
"Não há uma expressão regular padrão anteriormente definida para "
"identificação."

msgid "Written by %s.\n"
msgstr "Ditulis oleo por %s."

msgid "Written by %s and %s.\n"
msgstr "Ditulis oleo por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrita por %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrita por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrita por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, %d, %d, %<PRIuMAX>, %<PRIuMAX>, e %s. \n"

msgid "%s home page: <%s>\n"
msgstr "Trâng principal %s: <%s>"

msgid "unmatched `{'"
msgstr "{ '{' sem parênteses \n"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando 'y' não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos de operação e/r/w interrompidos no modo seguro do sandbox"

msgid "option `e' not supported"
msgstr "opção 'e' não é suportada"

msgid "`e' command not supported"
msgstr "a pergunta 'e' não é suportada"

msgid "no input files"
msgstr "não há nenhum arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referensi tid de %d na linha direita da instrução 's' não é válido."

msgid "regex input buffer length larger than INT_MAX"
msgstr "comprimento do panjang penyangga masukan regex maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed é um tradução com suporte SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste código foi desenvolvido sem suporte ao SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
"  -n, --quiet, --silent\n"
"teca penampilan otomatis dari pola ruang para hóquei no gelo"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 o seguir links simbólicos durante a manipulação no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"  -i[HÁBITANTE], --in-place[=HÁBITANTE] \n"
"                 modifica blocos no local (cria backup se HÁBITANTE for aplicado) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"  -s, --separate\n"
"                 anggap berkas-berkas sebagai terpisah daripada sebagai\n"
"                 sebuah stream tunggal panjang berkelanjutan."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 operar em modo sandbox (desligar comandos e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo binário em '%s'"

msgid "read error on %s: %s"
msgstr "lỗi đọc trên %s: %s"
