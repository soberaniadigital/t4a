msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "falha na conclusão da sequência de escape \""

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "Caracter de identidade não é válido."

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "O conjunto \\\"\\{\\\" não é válido."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc prematur"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\")"

msgid "No previous regular expression"
msgstr "Não há expressões regulares prévias."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrevei por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrevido por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrevido por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrevido por %s, %s, %s, \n"
"%d, %d, %d, %d,\n"
" e %s. \n"

msgid "%s home page: <%s>\n"
msgstr "Trang chủ %s: <%s>"

msgid "unmatched `{'"
msgstr "{ without pairing braces (brackets) '{' }"

msgid "extra characters after command"
msgstr "caracter adicional após o comando"

msgid "unterminated `y' command"
msgstr "comando 'y' não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr ""
"códigos de operação e/r/w interrompidos no modo seguro para evitar acesso "
"não autorizado."

msgid "option `e' not supported"
msgstr "opção 'e' não é suportada."

msgid "`e' command not supported"
msgstr "permitido não é suportado para a tecla 'e'."

msgid "no input files"
msgstr "não há arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência não é válida §=%d no lado direito (»RHS«) do comando 's'."

msgid "regex input buffer length larger than INT_MAX"
msgstr "comprimento do bônus de regex superior ao INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr ""
"O programa sed neste código foi desenvolvido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste código não possui suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"teca a interface de usuário automática sem saída ao vivo. \n"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 o seguir links simbólicos ao realizar a operação no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 altera o conteúdo da pasta de origem (cria uma cópia se HẬU_TỐ for especificado) "

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 separar berkas-berkas khusus untuk setiap tipe data dan tidak menghitungkan sebagai satu stream yang panjang. "

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox operando no modo sandbox (desligar comandos e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir berkas %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo de divisão binária em '%s'."

msgid "read error on %s: %s"
msgstr "lỗi đọc trên %s: %s"
