msgid "unbalanced ["
msgstr "falta de equilíbrio ["

msgid "unfinished \\ escape"
msgstr "código não finalizado \\\""

msgid "? at start of expression"
msgstr "Biêu từng quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biêu teorema chinês não é válido."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr ""
"não foi possível encontrar o caminho para a pasta de trabalho especificada."

msgid "Invalid collation character"
msgstr "caractere colação não é permitido."

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contém conteúdo inválido."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc prematuramente."

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr ""
"Có dấu ngoặc não parêntesis ou ponto e vírgula sem sinal de igualdade."

msgid "No previous regular expression"
msgstr "Não há mais expressões regulares anteriores."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Esta mensagem foi criada por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrito por %s, %s e %s. Eles também desenvolveram o soquete de "
"entrada/saída padrão."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrevido por %s, %s, %s, %s, %s, %s, %s e %s. \n"

msgid "%s home page: <%s>\n"
msgstr "Página de usuário %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở ‘{’ lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando 'y' não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos e/r/w interrompidos no modo de segurança do sandbox."

msgid "option `e' not supported"
msgstr "parâmetro «e» não é suportado."

msgid "`e' command not supported"
msgstr "a opção 'e' não é suportada."

msgid "no input files"
msgstr "não há arquivos de entrada disponíveis"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência não é uma referência válida §<%d> na RHS da instrução 's'."

msgid "regex input buffer length larger than INT_MAX"
msgstr "A longitud do buffer de entrada regex maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed está disponibilizado com suporte SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed é construído sem suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"trocar para o modo silencioso do programa."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguindo sinais simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 modificar arquivos no local (cria uma cópia se HẬU_TỐ for definido) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 considerar ficheiros separadamente, e não como um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox thực hiện trong chế độ sandbox (tắt lệnh e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao instalar o modo binário em “%s”"

msgid "read error on %s: %s"
msgstr "falha na leitura do arquivo %s: %s"
