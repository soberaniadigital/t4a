msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "não foi possível encerrar a sequência de escape Escape"

msgid "? at start of expression"
msgstr ""
"O biquíntus é um conceito que não pode ser expresso em uma única fórmula "
"matemática."

msgid "+ at start of expression"
msgstr ""
"O biquíntus é um conceito que não pode ser expresso em uma única linha de "
"código."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "falta de sintaxe especificada para o comando."

msgid "Invalid collation character"
msgstr "Caracter de comparação inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contenido inválido de \\\"\\{\\\"\"}."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm"

msgid "Regular expression too big"
msgstr ""
"Otimização de expressão regular é muito grande para ser executada em tempo "
"real."

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\\) lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há um expressão regular anterior definida."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrito por %s, %s, %s, \n"
"%d, %<PRIuMAX>, %s e %s. \n"
"e %s."

msgid "%s home page: <%s>\n"
msgstr "Página inicial de %s: <%s>"

msgid "unmatched `{'"
msgstr "não é par, {}"

msgid "extra characters after command"
msgstr "adicionar caracteres após o comando"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "Os comandos e/r/w estão desabilitados no modo de sandbox."

msgid "option `e' not supported"
msgstr "A opção 'e' não é suportada."

msgid "`e' command not supported"
msgstr "não há suporte para a orden `e'"

msgid "no input files"
msgstr "não há arquivos de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%d\\\" inválida no lado direito da instrução `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr "A longitud do bônus de entrada regex é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr ""
"O programa sed neste versão foi desenvolvido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste versão não possui suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"tolerar falta de saída do buffer de trabalho. \n"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 siga os enlaces simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 altera o conteúdo da ficheiro de entrada (cria um backup se HẬU_TỐ for especificado) "

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 considera os arquivos como separados em vez de uma única fonte contínua."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"opera no modo sandbox (as ordens de entrada/saída e escrita são "
"desabilitadas)."

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir a pasta %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falhou ao definir o modo de execução binário em '%s'."

msgid "read error on %s: %s"
msgstr "erro de leitura em %s: %s"
