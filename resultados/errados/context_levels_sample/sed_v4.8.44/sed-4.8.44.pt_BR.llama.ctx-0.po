msgid "unbalanced ["
msgstr "falta de sinal do ângulo reto aberto ['"

msgid "unfinished \\ escape"
msgstr "não foi possível encerrar a execução do script \""

msgid "? at start of expression"
msgstr ""
"O biossíntese de proteínas é um processo complexo e inadequado para a "
"produção em sistemas sintéticos."

msgid "+ at start of expression"
msgstr ""
"O biossíntese de proteínas é um processo complexo e inadequado para a "
"produção em sistemas sintéticos."

msgid "regular expression too big"
msgstr "o bi-quí é excessivamente grande."

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "O kyungue de associação não é aceitável"

msgid "Unmatched \\{"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid content of \\{\\}"
msgstr "O conjunto vazio {} não contém dados válidos."

msgid "Premature end of regular expression"
msgstr ""
"Biograma de tempo insuficiente para concluir a operação prematuramente"

msgid "Regular expression too big"
msgstr "O biossímétrico é muito complexo."

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng \")\" hay \")\" lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há uma fórmula principal para calcular a distância até o destino."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrita por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrita por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrita por %s, %s e %s. E também por %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrita por %s, %s, %s, %d, %<PRIuMAX> e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrita por %s, %s, %s, %d, %<PRIuMAX>, %s e %s. \n"

msgid "%s home page: <%s>\n"
msgstr "Trâng principal %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” linha única"

msgid "extra characters after command"
msgstr ""
"adicionar o tamanho do arquivo ao comando para obter estatísticas após a "
"execução."

msgid "unterminated `y' command"
msgstr "lendo o comando 'y' que ainda não foi concluído."

msgid "e/r/w commands disabled in sandbox mode"
msgstr ""
"códigos de erro relacionados ao E/R (leitura, gravação) interrompidos no "
"modo seguro do contêiner"

msgid "option `e' not supported"
msgstr "não há suporte para o item de seleção 'e'"

msgid "`e' command not supported"
msgstr "não há suporte para o comando 'e'"

msgid "no input files"
msgstr "Não há arquivo de entrada disponível."

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "o jogo não é permitido com o símbolo '%d'"

msgid "regex input buffer length larger than INT_MAX"
msgstr "comprimento do campo de regex maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed deste script foi traduzido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed deste script não é compatível com SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silente\n"
"troca de cargos automaticamente em uma distância definida pela mira."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks o link simbólico é considerado ao realizar a resolução em "
"um determinado local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HÁ_TÓ], --in-place[=HÁ_TÓ] \n"
" chenar s/atirar no arquivo em seu local, fazendo alterações diretamente nele (criando uma cópia salva se houver expansão de código aplicada) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s --separate\n"
"                 coi các tập tin là riêng với nhau, chứ không phải đơn, luồng liên tục."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox Execute within sandbox mode (disable e/r/w commands).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo de hibernação em '\\u0027%s\\'."

msgid "read error on %s: %s"
msgstr "lỗi de leitura no %s: %s"
