msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "não foi possível encerrar a sequência de escape \""

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "O valor do parâmetro '%s' não é válido."

msgid "Unmatched \\{"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid content of \\{\\}"
msgstr "“{}” não contém dados válidos."

msgid "Premature end of regular expression"
msgstr "O biquete de tempo para a conclusão é muito curto."

msgid "Regular expression too big"
msgstr "O biquini é muito grande."

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “)\" lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há nenhum padrão regular anterior para avaliar."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrevido por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrevido por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrevido por %s, %s e %s. Eles trabalham juntos para desenvolver o sistema "
"de arquivos."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrevido por %s, %s, %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Viết bởi %s, %s, %s, \n"
"%d, %<PRIuMAX>, %s e %s\n"
"và %s."

msgid "%s home page: <%s>\n"
msgstr "Trâng chúrio %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” lẻ đôi"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando não concluído 'y'"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "các lệnh e/r/w bị tắt ở chế độ hộp an toàn"

msgid "option `e' not supported"
msgstr "Não há suporte ao selecionar a opção 'e'."

msgid "`e' command not supported"
msgstr "não há suporte para o comando “e”"

msgid "no input files"
msgstr "não há arquivos de entrada disponíveis"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "tham chiếu không hợp lệ “%d” bên phải lệnh “s”"

msgid "regex input buffer length larger than INT_MAX"
msgstr "comprimento do bônus de regex superior ao INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed aqui foi traduzido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed desta versão não contém suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"trocar o modo de operação para um fluxo em loop sem saída. \n"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 o --seguir símbolos de ligação pequenos quando utilizando a opção -i."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 alteração no arquivo de entrada (arquivo de backup será criado, se HẬU_TỐ for especificado) "

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 coi các táp tin là riêng với nhau, chứ không phải đơn,\n"
"                 luồng liên tục."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox thực hiện no modo sandbox (tắt lệnh e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "gặp lỗi khi đặt chế độ nhị phân trên “%s”"

msgid "read error on %s: %s"
msgstr "lẽio de leitura em %s: %s"
