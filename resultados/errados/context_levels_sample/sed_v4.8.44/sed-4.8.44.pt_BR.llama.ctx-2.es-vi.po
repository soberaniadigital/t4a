"%s, %s, and %s.\n"
msgstr ""
"Escrevido por %s, %s, %s, \n"
"%s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Viết bởi %s, %s, %s, \n"
"%d, %<PRIuMAX>, %s e %s\n"
"và %s."

msgid "%s home page: <%s>\n"
msgstr "Trâng chúrio %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” lẻ đôi"

msgid "extra characters after command"
msgstr "caracteres extras após a ordem"

msgid "unterminated `y' command"
msgstr "lêmnage `y` não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "Os comandos e/r/w estão desativados no modo de segurança do sandbox."

msgid "option `e' not supported"
msgstr "não há suporte para a opção 'e'"

msgid "`e' command not supported"
msgstr "não há suporte para a orden `e'"

msgid "no input files"
msgstr "não há arquivos de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%d\\\" inválida no lado direito da instrução `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"comprimento do buffer de entrada da expressão regular é maior que INT_MAX"

