msgid "unbalanced ["
msgstr "falta de equilíbrio ["

msgid "unfinished \\ escape"
msgstr "falha na saída de dados para o soquete 'ID' não foi concluída."

msgid "? at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biểu thức chính quy demasiado grande"

msgid "no syntax specified"
msgstr "falta de sintaxe especificada"

msgid "Invalid collation character"
msgstr "Caracter de ordem não é válido."

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "O conjunto \\\"\\{\\\" não é válido."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc prematur"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy terlalu besar"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\")"

msgid "No previous regular expression"
msgstr "Não há uma expressão regular padrão anterior."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrevei por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrevido por %s, %s, %s e dan %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrevido por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrevido por %s, %s, %s, \n"
"%d, %d, %d, %d, \n"
"%<PRIuMAX>, e\n"
"dan %s."

msgid "%s home page: <%s>\n"
msgstr "Trang chủ %s: <%s>"

msgid "unmatched `{'"
msgstr "{ without pairing braces }"

msgid "extra characters after command"
msgstr "caracteres extras após o comando"

msgid "unterminated `y' command"
msgstr "comando 'y' não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "códigos de operação e/r/w são desabilitados no modo seguro."

msgid "option `e' not supported"
msgstr "não há suporte para a opção 'e'"

msgid "`e' command not supported"
msgstr "a opção 'e' não é suportada."

msgid "no input files"
msgstr "não há arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%s\\\" não é válida no lado direito da instrução `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"A longitud do buffer de entrada da expressão regular é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa atualizado está construído com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa atual não possui suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"troque o modo de operação para tátil automático do espaço de patrones."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 o seguir links simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 modifica blocos de texto no local (cria um backup se HẬU_TỐ for definido) "

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 considera os arquivos como separados em vez de um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox operar no modo sandbox (desabilitar comandos e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falhou ao definir o modo binário em '%s'"

msgid "read error on %s: %s"
msgstr "lỗi đọc trên %s: %s"
