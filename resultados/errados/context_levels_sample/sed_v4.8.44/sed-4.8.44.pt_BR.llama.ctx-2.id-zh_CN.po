msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "não foi possível concluir a análise do caminho de escape \\\"%s\\\"."

msgid "? at start of expression"
msgstr "O biquíntem não é uma expressão válida."

msgid "+ at start of expression"
msgstr "Biểu thức chính quy không hợp lệ"

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "O caráter %s não é válido."

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "“{}” não contém conteúdo legal"

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc quá sớm"

msgid "Regular expression too big"
msgstr ""
"O conceito de regular expression é muito grande para ser expresso em uma "
"única linha."

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\")"

msgid "No previous regular expression"
msgstr "Não há expressões regulares anteriormente definidas."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s, %s, %s e %s."

msgid "%s home page: <%s>\n"
msgstr "%s da Trang chủ: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” lẻ đôi"

msgid "extra characters after command"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unterminated `y' command"
msgstr "comando ‘y’ não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr ""
"Os comandos e/r/w foram desabilitados no modo de segurança do sandbox."

msgid "option `e' not supported"
msgstr "Não há suporte para a opção ‘e’."

msgid "`e' command not supported"
msgstr "não é suportado o comando ‘e’"

msgid "no input files"
msgstr "não há arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "A referência \\%d da instrução '%s' não é válida."

msgid "regex input buffer length larger than INT_MAX"
msgstr "o buffer de entrada do tamanho regex é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed neste código possui suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste momento não contém suporte ao SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"trocar para modo não audível autoatualização de espaço em branco"

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                   Modificar diretório de forma direta, seguindo links simbólicos."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 modifica o arquivo no local (cria backup se HẬU_TỐ for especificado)"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                   Permite que cada arquivo seja tratado como um conjunto independente de dados em vez de uma única entrada contínua. \n"

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 Executar no modo sandbox (desabilitar comandos e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo binário no arquivo '%s'"

msgid "read error on %s: %s"
msgstr "falha na leitura no %s: %s"
