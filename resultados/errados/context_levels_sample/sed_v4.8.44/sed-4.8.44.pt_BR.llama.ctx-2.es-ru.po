msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "código não finalizado \n"

msgid "? at start of expression"
msgstr "Biêu teorema chinês não é válido."

msgid "+ at start of expression"
msgstr "Biêu teorema chinês não é válido."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "falha na análise de sintaxe: Sintaxe não especificada."

msgid "Invalid collation character"
msgstr "caractere de comparação inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contenido inválido de \\\"\\{\\\"\"}."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc rấdương hết cùng"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc não par pairing ')' ou '\\)' lone bracket"

msgid "No previous regular expression"
msgstr "Não há um padrão regular pré-existente para a linha %<PRIuMAX>."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Autores da aplicação — %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s, %s, %s e %s."

msgid "%s home page: <%s>\n"
msgstr "Página de Início %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở ‘{’ lẻ đôi"

msgid "extra characters after command"
msgstr "caracteres extras após a instrução"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "As operações de leitura/escrita estão desligadas no modo seguro."

msgid "option `e' not supported"
msgstr "parâmetro «e» não é suportado."

msgid "`e' command not supported"
msgstr "A ordem `e` não é suportada."

msgid "no input files"
msgstr "não há arquivos de entrada disponíveis para processamento."

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%s\\\" inválida no lado direito da instrução `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr ""
"A longitud do buffer de entrada para a expressão regular é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed neste script contém suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste script não possui suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"troque o modo de operação para silencioso ou em 'quiet' sem saída ao executar a medição automática do caminho da onda."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguindo os links simbólicos ao processar no local."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
"chave -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 modifica arquivos no local (cria uma cópia se houver um SUFIJO)"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 considerar arquivos como separados em vez de um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox thêm trong chế độ sandbox (tắt lệnh e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha ao definir o modo binário em '%s'"

msgid "read error on %s: %s"
msgstr "falha ao ler do %s: %s"
