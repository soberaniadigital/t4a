msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "código de escape não concluído \""

msgid "? at start of expression"
msgstr "O biquíntus é um conceito que não tem sentido lógico em matemática."

msgid "+ at start of expression"
msgstr ""
"O símbolo de biquíni não é aceito como um operador lógico em linguagens "
"formais."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "Caractere de agrupamento inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contém conteúdo inválido em \\\"{}\\\"."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc toàn các bướng sẽ xảy ra."

msgid "Regular expression too big"
msgstr "O biútan de expressão é excessivamente grande."

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\\) lẻ đôi."

msgid "No previous regular expression"
msgstr "Não há nenhum padrão regular anterior para comparar."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s e %s. Eles também são responsáveis pelo projeto."

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrito por %s, %s, %s, \n"
"%s, %s, %s, %s\n"
" e %s."

msgid "%s home page: <%s>\n"
msgstr "Página inicial de %s: <%s>"

msgid "unmatched `{'"
msgstr "não é par (ímpar)"

msgid "extra characters after command"
msgstr "có ký tự thêm nằm sau lệnh"

msgid "unterminated `y' command"
msgstr "comando não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "Os comandos e/r/w estão desabilitados no modo de sandboxamento."

msgid "option `e' not supported"
msgstr "A opção 'e' não é suportada."

msgid "`e' command not supported"
msgstr "não há suporte para o comando 'e'."

msgid "no input files"
msgstr "não há arquivos de entrada disponíveis para o processamento."

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%d\\\" inválida no membro de direita da instrução \"s\"."

msgid "regex input buffer length larger than INT_MAX"
msgstr "A tamanho do bônus de entrada regex é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr ""
"O programa sed neste versão foi desenvolvido com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed neste versão não possui suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"tolerar silencio automático no buffer de trabalho."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguir símbolos de links durante o processamento"

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"   altera o conteúdo da ficheiro de entrada (cria uma cópia se HẬU_TỐ for especificado) "

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate\n"
"                 considerar os arquivos como separados e não como uma única fonte longa contínua."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 executa no modo sandbox (efeitos e/r/w são desabilitados).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir a pasta %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falha na configuração do modo binário para o dispositivo \"%s\""

msgid "read error on %s: %s"
msgstr "erro de leitura no %s: %s"
