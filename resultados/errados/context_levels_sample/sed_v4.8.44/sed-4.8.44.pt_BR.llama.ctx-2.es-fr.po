msgid "unbalanced ["
msgstr "[ não alinhado"

msgid "unfinished \\ escape"
msgstr "sequência de escape não concluída"

msgid "? at start of expression"
msgstr "Biêu teorema não é válido."

msgid "+ at start of expression"
msgstr "Biêu teorema chinês não é válido."

msgid "regular expression too big"
msgstr "expressão regular excessivamente complexa"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "Caractere de agrupamento inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contém conteúdo inválido de \\\"{}\\\"."

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc rấdương"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” ou “\") não parecido"

msgid "No previous regular expression"
msgstr "Não há uma expressão regular previamente definida."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s."

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr ""
"Escrito por %s, %s, %s, \n"
"%d, %<PRIuMAX>, %s e %s. E aí é o que você deseja fazer?"

msgid "%s home page: <%s>\n"
msgstr "Página inicial de %s: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở `{` não parecida."

msgid "extra characters after command"
msgstr "caracteres extras após a comando"

msgid "unterminated `y' command"
msgstr "comando `y` não concluído"

msgid "e/r/w commands disabled in sandbox mode"
msgstr "As operações de leitura/escrita estão desabilitadas no modo seguro."

msgid "option `e' not supported"
msgstr "A opção \"e\" não é suportada."

msgid "`e' command not supported"
msgstr "não há suporte para a comando `e`"

msgid "no input files"
msgstr "não há arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr "referência \\\"%s\\\" inválida no lado direito da instrução `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr "a tamanho do bônus de entrada regex é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa a seguir foi compilado com suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa atual não contém suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"trocar o modo de operação para que não seja gerado automaticamente a saída do espaço dos padrões."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 seguir links simbólicos durante o tratamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 edita os arquivos no local (cria uma cópia se HẬU_TỐ for definido) \n"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados em vez de um único fluxo, longo e "
"contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr "      --sandbox thực hiện trong chế độ sandbox (tắt lệnh e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não é possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falhou ao definir o modo de execução binário em '%s'"

msgid "read error on %s: %s"
msgstr "erro de leitura no %s: %s"
