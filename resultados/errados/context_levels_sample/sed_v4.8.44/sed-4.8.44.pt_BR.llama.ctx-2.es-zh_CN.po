msgid "unbalanced ["
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unfinished \\ escape"
msgstr "não foi possível concluir a análise do caminho de escape \\"

msgid "? at start of expression"
msgstr "O biquíntificador não é válido."

msgid "+ at start of expression"
msgstr "O biquíntificador não é uma expressão válida."

msgid "regular expression too big"
msgstr "biểu thức chính quy quá lớn"

msgid "no syntax specified"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Invalid collation character"
msgstr "caracter de ordenamento inválido"

msgid "Unmatched \\{"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Invalid content of \\{\\}"
msgstr "Contenido inválido de \\\"{}\\\""

msgid "Premature end of regular expression"
msgstr "Biểu thức chính quy kết thúc rấdương"

msgid "Regular expression too big"
msgstr "Biểu thức chính quy quá lớn"

msgid "Unmatched ) or \\)"
msgstr "Có dấu ngoặc đơn đóng “)” hay “\")"

msgid "No previous regular expression"
msgstr "Não há uma expressão regular prévia."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid "Written by %s and %s.\n"
msgstr "Escrito por %s e %s."

msgid "Written by %s, %s, and %s.\n"
msgstr "Escrito por %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s e %s. \n"

msgid ""
"Written by %s, %s, %s,\n"
"%s, %s, %s, %s,\n"
"and %s.\n"
msgstr "Escrito por %s, %s, %s, %s, %s, %s, %s e %s."

msgid "%s home page: <%s>\n"
msgstr "%s página inicial: <%s>"

msgid "unmatched `{'"
msgstr "có dấu ngoặc móc mở “{” lẻ đôi"

msgid "extra characters after command"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "unterminated `y' command"
msgstr "comando “y” ainda não foi concluído."

msgid "e/r/w commands disabled in sandbox mode"
msgstr "As operações de leitura/escrita estão desabilitadas no modo seguro."

msgid "option `e' not supported"
msgstr "Não há suporte para a opção `e`."

msgid "`e' command not supported"
msgstr "não há suporte para a orden `e'"

msgid "no input files"
msgstr "não há arquivo de entrada"

msgid "invalid reference \\%d on `s' command's RHS"
msgstr ""
"falha na verificação da referência §%d inválida no lado direito da instrução"
" `s'"

msgid "regex input buffer length larger than INT_MAX"
msgstr "a longitud do bônus de entrada regex é maior que INT_MAX"

msgid "Tom Lord"
msgstr "Tom Lord"

msgid "Ken Pizzini"
msgstr "Ken Pizzini"

msgid "Assaf Gordon"
msgstr "Assaf Gordon"

msgid "This sed program was built with SELinux support."
msgstr "O programa sed presente contém suporte para SELinux."

msgid "This sed program was built without SELinux support."
msgstr "O programa sed atual não contém suporte para SELinux."

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n, --quiet, --silent\n"
"trocar para modo de execução silencioso que não imprime mensagens ao longo da busca por caminhos mínimos."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                   seguir links simbólicos ao modificar diretório em tempo de execu endou a hora."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[HẬU_TỐ], --in-place[=HẬU_TỐ] \n"
"                 modifica o arquivo no local (cria um backup se houver extensão de nome especificada)"

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
" -s, --separate considera os arquivos como separados em vez de um único "
"fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 Executar em modo sandbox (desligar e/r/w).\n"

msgid "couldn't open file %s: %s"
msgstr "não foi possível abrir o arquivo %s: %s"

msgid "failed to set binary mode on '%s'"
msgstr "falhou ao definir o modo de interrupção em `%s"

msgid "read error on %s: %s"
msgstr "erro ao ler do %s: %s"
