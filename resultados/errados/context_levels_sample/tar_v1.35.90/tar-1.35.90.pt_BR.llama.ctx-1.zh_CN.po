msgstr "evitar o deslize automático em diretórios"

msgid "patterns match file name start"
msgstr "alinhar o nome do arquivo com base no seu padrão de entrada/saída"

msgid "use wildcards (default for exclusion)"
msgstr "uso do caractere de substituição (padrão para exclusão)"

msgid "wildcards do not match '/'"
msgstr "Jokerzeichen não podem ser combinados com ‘/’"

msgid ""
"The following options were used after non-option arguments.  These options "
"are positional and affect only arguments that follow them.  Please, "
"rearrange them properly."
msgstr ""
"As seguintes opções foram especificadas após argumentos que não são opções. "
"Essas opções são posicionais e têm influência apenas sobre os argumentos "
"subsequentes."

msgid "-C %s has no effect"
msgstr "-C %s sem efeito"

msgid "--%s has no effect"
msgstr "--%s sem efeito"

msgid "%s: file name read contains nul character"
msgstr "%s: o nome do arquivo contém um caractere NULL (NULL)"

