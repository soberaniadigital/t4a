msgstr ""
"Ordem de classificação para pastas: `none`=nenhuma (padrão), `name` ou inode"

msgid "directory sorting order: none (default) or name"
msgstr "Ordem de classificação para pastas: `none`=nenhuma (padrão) ou `name`"

msgid "Handling of extended file attributes:"
msgstr "Tratamento das atributos de arquivo estendidos:"

