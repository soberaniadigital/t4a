"Escrito por %s, %s, %s, \n"
"%d, %s, %s, %s,\n"
"%<PRIuMAX>, %s e outros."

msgid "%s: Warning: Cannot %s"
msgstr "%s : Avertimento : %s falhou"

msgid "%s: Cannot hard link to %s"
msgstr "%s : impossível criar uma ligação física para %s"

msgid "%s: Cannot create symlink to %s"
msgstr "%s : não é possível criar uma associação simbólica para %s."

msgid "stdin"
msgstr "Entrada padrão"

msgid "Invalid seek offset"
msgstr "Valor inválido para posicionamento"

msgid "NUMBER"
msgstr "ZAHL"

msgid "set debug level"
msgstr "nível de depuração definido para %s"

msgid "cannot open %s"
msgstr "impossível abrir %s"

msgid "This does not look like a tar archive"
msgstr "Este não se assemelha a um arquivo de troca (tar) do tipo."

msgid "(pipe)"
msgstr "canal (tubo)"

msgid "Refusing to read archive contents from terminal (missing -f option?)"
msgstr ""
"Refus de ler o conteúdo do arquivo a partir da linha de comando (opção -f "
"ausente?)"

msgid "Archive is compressed. Use %s option"
msgstr "O arquivo está comprimido. Utilize a opção %s."

msgid "Cannot backspace archive file; it may be unreadable without -i"
msgstr ""
"Não é possível reverter o arquivo de backup; ele pode ficar inacessível sem "
"a opção '-i'."

msgid "%s: contains invalid volume number"
msgstr "%s : contém um número de volume inválido."

msgid "WARNING: Archive is incomplete"
msgstr "Avertimento : a pasta de trabalho é inválida."

msgid " ?             Print this list\n"
msgstr "Por favor, forneça a lista desejada."

msgid "No new volume; exiting.\n"
msgstr "Não há novo volume; continue o processamento."

msgid "File name not specified. Try again.\n"
msgstr "Nome do arquivo não especificado. Tente novamente."

msgid ""
"%s is possibly continued on this volume: header contains truncated name"
msgstr "O arquivo '%s' pode conter nomes troncados no cabeçalho."

msgid "%s is the wrong size (%jd != %jd + %jd)"
msgstr "%s tem uma tamanho de entrada incorreto (%d != %d + %<PRIuMAX>)."

msgid ""
"%s: file name too long to be stored in a GNU multivolume header, truncated"
msgstr ""
"%s : nome do arquivo truncado, pois é muito longo para ser armazenado em um "
"cabeçalho GNU multi-volume\n"

msgid "write did not end on a block boundary"
msgstr "A escrita não chegou ao fim em uma limitação de bloco."

msgid "Not linked to %s"
msgstr "Não está associado a %s."

msgid "Device number differs"
msgstr "Números de identificação dos dispositivos são diferentes."

msgid "Verify "
msgstr "Verifique se o arquivo está corrompido."

msgid "Archive contains transformed file names."
msgstr "O arquivo contém nomes de arquivos transformados."

msgid "Verification may fail to locate original files."
msgstr "A verificação pode falhar na localização dos arquivos originais."

msgid "value %s%ju out of %s range %jd..%ju"
msgstr "Valor %s fora da faixa de %s : %s..%s"

msgid "Generating negative octal headers"
msgstr "geração de cabeçalhos octais negativos"

msgid "%s: file name is too long (max %d); not dumped"
msgstr ""
"%s : o nome do arquivo é muito longo (%d máximo); ficheiro não salvado."

msgid "%s: file is on a different filesystem; not dumped"
msgstr ""
"%s : ficheiro está em um sistema de arquivos diferente; ficheiro não "
"armazenado."

msgid "%s: Unknown file type; file ignored"
msgstr "%s : tipo de arquivo desconhecido; arquivo ignorado."

msgid "%s: file changed as we read it"
msgstr "%s : ficheiro modificado durante a leitura."

msgid "%s: time stamp %s is %s s in the future"
msgstr "%s: o horário de marcação %s está localizado %s segundos no futuro."

msgid "%s: skipping existing file"
msgstr "%s : arquivo existente ignorado"

msgid "Extracting contiguous files as regular files"
msgstr "Extraia arquivos contíguos como se fossem regulares."

msgid "Unexpected long name header"
msgstr "Título de cabeçalho com nome longo inesperado"

msgid "Current %s is newer or same age"
msgstr "O atual %s é novo ou tem o mesmo período de vida."

msgid "%s: Directory has been renamed from %s"
msgstr "%s : o diretório foi renomeado desde %s."

msgid "Invalid time stamp"
msgstr "Horário de data inválido"

msgid "Invalid modification time (nanoseconds)"
msgstr "Tempo de modificação inválido (nanosegundos)"

msgid "Invalid inode number"
msgstr "Número de inode inválido"

msgid "Missing record terminator"
msgstr "Falha na conclusão do registro"

msgid "Malformed dumpdir: expected '%c' but found end of data"
msgstr ""
"O diretório de dados para o dump está incorreto, mas fim das informações foi"
" encontrado."

msgid "Malformed dumpdir: 'X' never used"
msgstr ""
"O diretório de dados para o dump do sistema operacional não foi utilizado"

msgid "Cannot create temporary directory using template %s"
msgstr "impossível criar um diretório temporário utilizando o modelo %s"

msgid "%s: directory is on a different device: not purging"
msgstr ""
"%s : o diretório está em um sistema de arquivos diferente, não pode ser "
"excluído."

msgid "Archive octal value %.*s is out of %s range"
msgstr "A valor octal de %.*s está fora do intervalo de %s."

msgid " link to "
msgstr "Ligação a %s"

msgid "--Long Name--\n"
msgstr "--Nome longo--"

msgid "Creating directory:"
msgstr "Crie o diretório:"

msgid "Renaming %s back to %s\n"
msgstr "%s finalmente renomeado para %s"

msgid "get names to extract or create from FILE"
msgstr "Ler desde o ficheiro a lista de nomes para extrair ou criar."

msgid "disable the effect of the previous --null option"
msgstr "efeito da opção --null anteriormente desabilitada."

msgid "unquote input file or member names (default)"
msgstr ""
"Remover a proteção de caracteres dos arquivos de entrada ou nomes de membros"
" (padrão)"

msgid "do not unquote input file or member names"
msgstr ""
"Não é possível remover a proteção de caracteres do arquivo de entrada ou dos"
" nomes dos membros."

msgid "-T reads file names verbatim (no escape or option handling)"
msgstr "-T leia os nomes dos arquivos literalmente (sem espaços ou opções)"

msgid "PATTERN"
msgstr "MOTIFO"

msgid "exclude files, given as a PATTERN"
msgstr "Exclua os arquivos que correspondem ao motivo"

msgid "exclude patterns listed in FILE"
msgstr ""
"Exclua os padrões listados no arquivo %s que não se encaixam nas datas "
"especificadas."

msgid ""
"exclude contents of directories containing CACHEDIR.TAG, except for the tag "
"file itself"
msgstr ""
"Exclua o conteúdo de diretórios que contêm CACHEDIR.TAG, exceto a pasta "
"marcadora em si mesma."

msgid "exclude everything under directories containing CACHEDIR.TAG"
msgstr ""
"todo o conteúdo a ser excluído está localizado em diretórios que contêm "
"CACHEDIR.TAG."

msgid ""
"exclude contents of directories containing FILE, except for FILE itself"
msgstr ""
"Exclua o conteúdo dos diretórios que contêm a pasta %s, exceto para essa "
"própria pasta."

msgid "avoid descending automatically in directories"
msgstr "prevenir o deslize automático em diretórios subordinados"

msgid "patterns match file name start"
msgstr ""
"Os motivos devem corresponder ao nome do arquivo no início da sua "
"designação."

msgid "use wildcards (default for exclusion)"
msgstr "Utilizar caracteres de correspondência (padrão para exclusão)"

msgid "wildcards do not match '/'"
msgstr ""
"O símbolo 'Joker' não corresponde a nenhum caractere de correspondência para"
" o operador '/'."

msgid ""
"The following options were used after non-option arguments.  These options "
"are positional and affect only arguments that follow them.  Please, "
"rearrange them properly."
msgstr ""
"As seguintes opções foram utilizadas após argumentos que não são opções. "
"Essas opções são posicionais e afetam apenas os argumentos subsequentes."

msgid "-C %s has no effect"
msgstr "-C %s não tem efeito"

msgid "--%s has no effect"
msgstr "--%s sem efeito"

msgid "%s: file name read contains nul character"
msgstr "%s : o nome do arquivo contém um caractere nulo"

msgid "Pattern matching characters used in file names"
msgstr ""
"Caracteres de correspondência para padrões utilizados no nome do arquivo."

msgid ""
"Use --wildcards to enable pattern matching, or --no-wildcards to suppress "
"this warning"
msgstr ""
"Utilize o parâmetro `--wildcards` para habilitar a correspondência de "
"padrões ou utilize o parâmetro `--no-wildcards` para suprimir esta "
"advertência."

msgid "%s: Not found in archive"
msgstr "%s : não encontrado no arquivo."

msgid "%s: Required occurrence not found in archive"
msgstr "%s : ocorrência requerida não encontrada no arquivo."

msgid "Archive label mismatch"
msgstr "A identificação do arquivo não está correta."

msgid ""
"GNU 'tar' saves many files together into a single tape or disk archive, and can restore individual files from the archive.\n"
"\n"
"Examples:\n"
"  tar -cf archive.tar foo bar  # Create archive.tar from files foo and bar.\n"
"  tar -tvf archive.tar         # List all files in archive.tar verbosely.\n"
"  tar -xf archive.tar          # Extract all files from archive.tar.\n"
msgstr ""
"O programa GNU `tar` permite armazenar muitas pastas e arquivos em um único "
"arquivo de backup (ou 'arquivo') no disco ou na mídia magnética, como uma "
"unidade USB. Também pode restaurar esses arquivos individualmente a partir "
"do arquivo criptado."

msgid "Main operation mode:"
msgstr "Modo principal de trabalho :"

msgid "extract files from an archive"
msgstr ""
"Extrair arquivos de um arquivo .zip para o diretório %s em linha %d, usando "
"a opção '%c'."

msgid "only append files newer than copy in archive"
msgstr ""
"Adicione apenas arquivos mais recentes do que as cópias presentes no "
"armazenamento de backup."

msgid "Operation modifiers:"
msgstr "Modificações de operação :"

msgid "technique to detect holes"
msgstr "Técnica de detecção de buracos"

msgid "do not check device numbers when creating incremental archives"
msgstr ""
"não é recomendado verificar o número do dispositivo durante a criação de "
"arquivos incrementais"

msgid "check device numbers when creating incremental archives (default)"
msgstr ""
"verificar o número do dispositivo durante a criação de um backup incremental"
" (padrão)"

msgid "overwrite existing files when extracting"
msgstr "sobrescrever arquivos existentes durante a extração"

msgid "overwrite metadata of existing directories when extracting (default)"
msgstr ""
"Fazer backup das metadados dos diretórios existentes ao extrair (padrão)"

msgid "create a subdirectory to avoid having loose files extracted"
msgstr "créer um subdiretório para evitar a perda de arquivos extraídos."

msgid "Handling of file attributes:"
msgstr "Tratamento dos atributos do arquivo :"

msgid "DATE-OR-FILE"
msgstr "DATA-OU-ARQUIVO"

msgid "CHANGES"
msgstr "Alterações"

msgid "force (symbolic) mode CHANGES for added files"
msgstr ""
"Utilize os CHANGEMENTS de modo (simbólicos) para as pastas adicionadas."

msgid ""
"try extracting files with the same ownership as exists in the archive "
"(default for superuser)"
msgstr ""
"tente extrair as pastas com o mesmo proprietário que na archive (padrão para"
" administradores)"

msgid "extract files as yourself (default for ordinary users)"
msgstr "Extrair arquivos do diretório atual (padrão para usuários normais)"

msgid "always use numbers for user/group names"
msgstr ""
"sempre utilizar valores numéricos dos usuários/grupos para identificação"

msgid ""
"apply the user's umask when extracting permissions from the archive (default"
" for ordinary users)"
msgstr ""
"Aplicar o umask do usuário ao extrair as permissões de acesso (por padrão "
"para os utilizadores normais)"

msgid ""
"delay setting modification times and permissions of extracted directories "
"until the end of extraction"
msgstr ""
"No último passo do descompactação, o ajuste das datas de modificação e dos "
"direitos de acesso aos pastas extraídas será feito."

msgid "directory sorting order: none (default), name or inode"
msgstr "Ordem de triagem dos diretórios : nenhum (padrão), nome ou inode\n"

msgid "directory sorting order: none (default) or name"
msgstr "Ordem de triagem para pastas: „none“=nenhuma (padrão) ou “nome”"

msgid "Handling of extended file attributes:"
msgstr "Tratamento dos atributos de arquivos estendidos :"

msgid "specify the exclude pattern for xattr keys"
msgstr "especificar o padrão de exclusão para chaves xattr"

msgid "Enable the SELinux context support"
msgstr "Ativar suporte para contexto SELinux"

msgid "specify drive and density"
msgstr ""
"especificar o leitor e a densidade de gravação/gravura (densidade do disco) "
"para %s."

msgid "archive file is local even if it has a colon"
msgstr ""
"O arquivo de saída está local, mesmo que o nome contenha um ponto e vírgula."

msgid "use given rmt COMMAND instead of rmt"
msgstr "Utilize a comando `rmt` fornecido para remover o arquivo."

msgid "use remote COMMAND instead of rsh"
msgstr "Utilize a COMMANDA distante em vez de rsh."

msgid "create/list/extract multi-volume archive"
msgstr "Criar/Lista e extrai uma pasta de arquivos multiplos volumes"

msgid "use/update the volume number in FILE"
msgstr "Utilize o número de volume na pasta %s para atualização ou uso."

msgid "Device blocking:"
msgstr "Blocos do dispositivo:"

msgid "NUMBER of bytes per record, multiple of 512"
msgstr "Número de bytes por registro, múltiplos de 512"

msgid "ignore zeroed blocks in archive (means EOF)"
msgstr "Ignorar blocos de zeros no arquivo (chamado EOF)"

msgid "reblock as we read (for 4.2BSD pipes)"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid ""
"create archive with volume name TEXT; at list/extract time, use TEXT as a "
"globbing pattern for volume name"
msgstr ""
"Criar o arquivo de log com o nome TEXT; ao listar ou extrair, utilize TEXT "
"como padrão para corresponder aos nomes dos logs."

msgid "Compression options:"
msgstr "Opções de compressão :"

msgid "MEMBER-NAME"
msgstr "Nome do Elemento"

msgid "strip NUMBER leading components from file names on extraction"
msgstr ""
"Remover componentes numéricos no começo dos nomes de arquivos ao extrair"

msgid "display progress messages every NUMBERth record (default 10)"
msgstr ""
"mostrar mensagens de progresso a cada NOMBRE registros (10 por padrão) no "
"conjunto de dados."

msgid "ACTION"
msgstr "Ação"

msgid "send verbose output to FILE"
msgstr "escrever a saída detalhada em %s para o arquivo %d."

msgid "show valid ranges for snapshot-file fields"
msgstr "exibir os intervalos válidos dos campos das pastas de instantâneo"

msgid "show file or archive names after transformation"
msgstr "mostrar os nomes dos arquivos ou de pastas após a transformação."

msgid "set name quoting style; see below for valid STYLE values"
msgstr ""
"Defina o estilo de proteção dos caracteres aplicados aos nomes. Consulte "
"abaixo para valores válidos do STYLE."

msgid "additionally quote characters from STRING"
msgstr "adicionar caracteres adicionais ao ZEICHENKETTE citado."

msgid "Substituting %s for unknown date format %s"
msgstr "Substitua %s pelo formato de data desconhecido %s."

msgid "Valid arguments for the --quoting-style option are:"
msgstr "Os argumentos válidos para a opção '--quoting-style' são:"

msgid "Options '-[0-7][lmh]' not supported by *this* tar"
msgstr "As opções « -[0-7][lmh] » não são suportadas por este tar."

msgid "Invalid tape length"
msgstr "Largura da bandeira inválida"

msgid "More than one threshold date"
msgstr "Existe mais de uma data limite especificada."

msgid "--atime-preserve='system' is not supported on this platform"
msgstr "--atime-preserve='system' não é suportado nesta plataforma."

msgid "invalid --checkpoint value"
msgstr "Ponto de Controle da Leitura %u"

msgid "error parsing %s"
msgstr "erro ao ler o arquivo %s"

msgid "non-option arguments in %s"
msgstr "Argumentos não possuem opções em %s"

msgid "%s: Volume label length exceeds %d bytes"
msgstr ""
"%s : a etiqueta do volume é muito longa (limite máximo %<PRIuMAX> octet)"

msgid "Cannot use multi-volume compressed archives"
msgstr "impossível utilizar arquivos multiplos volumes comprimidos."

msgid "--acls can be used only on POSIX archives"
msgstr "--acls pode ser utilizada apenas com arquivos POSIX."

msgid "--xattrs can be used only on POSIX archives"
msgstr "--xattrs pode ser utilizado apenas com arquivos POSIX."

msgid ""
"Cannot deduce top-level directory name; please set it explicitly with --one-"
"top-level=DIR"
msgstr ""
"Não foi possível deduzir o nome do diretório de maior nível; por favor, "
"especifique explicitamente com --one-top-level=VERZ."

msgid "failed to assert availability of the standard file descriptors"
msgstr ""
"falha na verificação da disponibilidade dos descriptores de arquivo padrão"

msgid "Pattern %s cannot be used"
msgstr "O motivo %s não pode ser utilizado."

msgid "Malformed extended header: missing equal sign"
msgstr "Tipo de cabeçalho estendido incorreto : sinal de igualdade ausente"

msgid "Extended header %s=%s is out of range %jd..%ju"
msgstr "Parte superior expandida %s=%s está fora do intervalo %s..%s."

msgid "Malformed extended header: invalid %s: odd number of values"
msgstr ""
"Tipo de cabeçalho estendido inválido : %s não valida : número impar de "
"valores"

msgid "write"
msgstr "leitura"

msgid "File creation options:"
msgstr "Opções para criação de arquivos :"

msgid "SIZE"
msgstr "GRÖßE"

msgid "Create file of the given SIZE"
msgstr "criar o arquivo com a GRÖße especificada"

msgid "Size of a block for sparse file"
msgstr "Tamanho de um bloco para arquivos dispersos (fragmentados)"

msgid "Generate sparse file. Rest of the command line gives the file map."
msgstr ""
"Gerar um arquivo disperso (com trincas). O restante da linha de comando "
"define a especificação do arquivo."

msgid "Seek to the given offset before writing data"
msgstr "Antes de escrever na posição dada, salte para trás."

msgid "Suppress non-fatal diagnostic messages"
msgstr "Os mensagens de diagnóstico não críticas devem ser ignoradas."

msgid "File statistics options:"
msgstr "Opções de estatísticas do arquivo :"

msgid "Invalid size: %s"
msgstr "Tamanho inválido : %s"

msgid "cannot open `%s'"
msgstr "impossível abrir «%s»"

msgid "cannot seek"
msgstr "não é possível posicionar aqui."

msgid "command failed: %s"
msgstr "falha na execução da comando '%s'"

msgid "cannot remove directory `%s'"
msgstr "impossível remover o diretório \"%s\""

msgid "cannot unlink `%s'"
msgstr "não é possível remover o arquivo \"%s\" (desenxarada)"

msgid "Command failed with status %d\n"
msgstr "O comando falhou com o status de término %d."

msgid "Command terminated on signal %d\n"
msgstr "O comando finalizou no sinal %d\n"

msgid "Command stopped on signal %d\n"
msgstr "O comando parou em resposta ao sinal %d\n"
