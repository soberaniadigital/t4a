msgstr "%s : a opção '%s%s' deve ter um argumento\n"

msgid "%s: option requires an argument -- '%c'\n"
msgstr "%s : a opção -- '%c' precisa de um argumento."

msgid "unable to record current working directory"
msgstr "não é possível registrar o diretório de trabalho atual."

msgid "^[yY]"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

