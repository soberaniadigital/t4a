msgid ""
"Mandatory or optional arguments to long options are also mandatory or "
"optional for any corresponding short options."
msgstr ""
"Os argumentos necessários ou opcionais para as versões longas das opções são"
" igualmente obrigatórios e facultativos, assim como para suas contrapartes "
"curtas."

msgid "Usage:"
msgstr "Aufruf:"

msgid " [OPTION...]"
msgstr " [OPÇÃO...]"

msgid "Report bugs to %s.\n"
msgstr "Ligue para o suporte técnico em %s."

msgid "print program version"
msgstr "Imprimir a versão do programa"

msgid "(PROGRAM ERROR) Option should have been recognized!?"
msgstr "(PROGRAMMFEHLER) A opção deveria ter sido reconhecida!"

msgid "%s: option '%s%s' is ambiguous; possibilities:"
msgstr "%s : a opção « %s%s » é ambígua; escolhas possíveis :"

msgid "%s: unrecognized option '%s%s'\n"
msgstr "%s c: a opção « %s%s » é desconhecida."

