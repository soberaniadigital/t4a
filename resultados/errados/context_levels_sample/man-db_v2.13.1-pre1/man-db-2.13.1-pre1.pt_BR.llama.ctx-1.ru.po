msgid "warning: %s: ignoring bogus filename"
msgstr ""
"aviso de erro: %s: o nome do arquivo foi ignorado devido a ser inválido"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não existe usuário '%s' com a capacidade de 'setuid'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s danificado; reparo com a linha de comando 'mandb -- "
"create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr ""
"aviso de atualização: %s possui versão %s, e é necessário o comando '%c' "
"para prosseguir."

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "não foi possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr "adicione o caminho de pesquisa para navegar entre as páginas de ajuda"

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou ao sair (código de saída %d)"

msgid "can't update index cache %s"
msgstr "não foi possível atualizar o cache de memória do local %s"

msgid "can't create index cache %s"
msgstr "não foi possível criar o cache de memória para a lista %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória do caminho `%s/%s'. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr ""
"Ao atualizar os dados da base de usuários, estamos excluindo as entradas "
"antigas na pasta %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não faz distinciação entre HOA e registro padrão ao procurar (por default)"

msgid "look for pages case-sensitively"
msgstr "falta de respeito ao registro durante a pesquisa"

msgid "FILE..."
msgstr "Título do arquivo..."

msgid "parse as man page"
msgstr "analisar a página de ajuda do manual para obter mais informações."

msgid "parse as cat page"
msgstr "fazer análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: cargas de opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr "redefinir todos os valores padrão para as configurações selecionadas"

msgid "Main modes of operation:"
msgstr "modos de operação principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "Utilizado o catman para reformular as páginas cat antigas."

msgid "Finding manual pages:"
msgstr "Em busca de guias de referência:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para formatar a página"

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "Solução para o problema proposto."

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e faça com que ele gere ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual guia de ajuda você precisa?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de referência para %s no subseção %s\n"

msgid "can't open temporary file %s"
msgstr "não foi possível abrir o arquivo temporário %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"erro ao executar a længe 'mandb' (comando de gerenciamento do banco de "
"dados) com o estado saída %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"Erro de nível interno: tipo do candidato %d está fora dos limites permitidos"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "deve ser indicada a codificação de saída do código"

msgid "can't write to standard output"
msgstr "não foi possível escrever no padrão de saída"

msgid "CODE[:...]"
msgstr "Código de Operação[:...]"

msgid "[MANPATH]"
msgstr "[MAN_CAMINHO]"

msgid "work quietly, except for 'bogus' warning"
msgstr ""
"chute im, exclua avisos 'fictícios' exceto quando necessário para a "
"segurança do sistema."

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova antigas mensagens do banco de dados."

msgid "FILENAME"
msgstr "Nome do Arquivo"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de ajuda em %s...\n"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há a diretiva 'MANDB_MAP' no %s, utilizará o caminho do "
"seu manpath."

msgid "No databases created."
msgstr "Não há bases de dados criadas."

msgid "warning: $MANPATH set, inserting %s"
msgstr "aviso de segurança: encontrada variável $MANPATH, adicionando ao %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "aviso de segurança: encontrado o caminho $MANPATH, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso de erro: o diretório %s obrigatório não existe"

msgid "warning: %s does not begin with %s"
msgstr "aviso de erro: %s não começa com o valor esperado, que é %s."

msgid "Checking for stray cats under %s...\n"
msgstr "Fazendo verificação de catbombas em %s...\n"

msgid "do not trim output to terminal width"
msgstr "não obrigado a cortar o output para caber na largura do terminal"

msgid "warning: %s contains a pointer loop"
msgstr "cão de alerta: %s contém um loop cíclico (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado para este caso."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: các requisições .so lõu nhau quá sâu hoặng bị đệ quy."

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: nova linha em .lf requisitada, ignorada\n"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
