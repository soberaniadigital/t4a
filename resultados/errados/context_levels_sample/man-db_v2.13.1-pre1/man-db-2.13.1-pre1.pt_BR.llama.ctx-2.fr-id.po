msgid "warning: %s: ignoring bogus filename"
msgstr "peringatan: %s: mengabaikan nama berkas palsu"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém utilizando a função 'setuid' do usuário %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s ter sido comprometido; realize a restauração utilizando "
"o comando 'mandb -- create'."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "peringatan: %s a versão %s, espera-se que seja o caso de %s"

msgid "[MAN DATABASE]"
msgstr "[ID DO SITE DE DONNEES PARA O USUÁRIO]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão possui o valor por defeito %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"Coloque o DẦN_DỪNG para a direção do caminho de pesquisa dos links guias."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou ao sair com código %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o local de armazenamento do cache %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de memória para a linha %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória para diretório '%s/%s'. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação cargas de dados antigos na base de %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr "não há discriminação de maiúsculas e minúsculas (padrão)"

msgid "look for pages case-sensitively"
msgstr "falha na busca por termo HOA/thường khi tìm"

msgid "FILE..."
msgstr "ID_TIN..."

msgid "parse as man page"
msgstr "análise de tela limpa como página manual"

msgid "parse as cat page"
msgstr "análise de padrões no catálogo digital do gato"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"adicione novamente todos os valores padrão para as opções selecionadas."

msgid "Main modes of operation:"
msgstr "Modo operacional principal:"

msgid "equivalent to whatis"
msgstr "tão parecido com whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"utilizado olevao pelo catman para reformatar as páginas antigas do site de "
"cães"

msgid "Finding manual pages:"
msgstr "Estou procurando o guia de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize o %s para formatar a página."

msgid "use %s with selected device"
msgstr "utilize %s com o periférico que foi escolhido"

msgid "RESOLUTION"
msgstr "ID_DETALHAMENTO"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique pressão nele para produzir ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual trângulo de diretrizes você precisa?\n"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guias de linha para %s na seção %s"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s para edição"

msgid "mandb command failed with exit status %d"
msgstr ""
"comando 'mandb' (sistema de gerenciamento do banco) falhou ao sair com o "
"código %d"

msgid "internal error: candidate type %d out of range"
msgstr "Erro de nível interno: o tipo candidato %d está fora do alcance"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário especificar o código de saída para a tabela gerada."

msgid "can't write to standard output"
msgstr "não é possível escrever no fluxo padrão de saída."

msgid "CODE[:...]"
msgstr "Código[:...]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN] (ID)"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, trunca a barreira de aviso 'falso'"

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova entradas antigas da base de dados semanas atrasadas."

msgid "FILENAME"
msgstr "ID_DE_FICHIER"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas do manual sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"peringatamento: não há diretório de mapa (MANDB_MAP) no %s, portanto será "
"utilizado o caminho indicação do usuário."

msgid "No databases created."
msgstr "Não há uma base de dados criada ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr "cranberror: táp hợp $MANPATH (dẫn dịch), chênh lệch %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "peringatamento: a tabela $MANPATH está configurada, %s é ignorado."

msgid "warning: mandatory directory %s doesn't exist"
msgstr "peringatamento: diretório obrigatório %s não existe"

msgid "warning: %s does not begin with %s"
msgstr "peringatan: %s não começa por %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Fazendo verificação no cat terceiro abaixo de %s...\n"

msgid "do not trim output to terminal width"
msgstr ""
"não permita a saída de dados para o lado mais amplo da tela do terminal sem "
"redução"

msgid "warning: %s contains a pointer loop"
msgstr "peringatan: %s contém um vórtice de referência (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: permissões .so conflitantes excessivamente complexas ou recursivas\n"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: linha nova na solicitação .lf, ignorada"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
