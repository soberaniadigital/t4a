msgid "warning: %s: ignoring bogus filename"
msgstr "cảnh báo: %s: o nome do arquivo está incorreto e será ignorado."

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém que use a função 'setuid' '%s'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s corrompido; recomece usando o comando 'mandb -- create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cảnh báo: %s là phiên bản %s, cần %s\n"

msgid "[MAN DATABASE]"
msgstr "[Livro de Dados do Man]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"coloque o caminho de navegação _Caminho_Diretor para pesquisar os links "
"guiados."

msgid "man command failed with exit status %d"
msgstr "lêm hãm đã thất bại với trạng thái thoát là %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de índice temporário %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de indexação %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"A atualização do cache de indexação está em andamento para o caminho %s/%s. "
"Por favor, espere…"

msgid "Purging old database entries in %s...\n"
msgstr "Ao tarefa de limpeza, cópia dos dados antigos do banco %s…"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não é permitido discriminar entre maiúsculas e minúsculas ao procurar por "
"HOA/thường (padrão)"

msgid "look for pages case-sensitively"
msgstr "phân biệt chữ HOA/thường khi tìm"

msgid "FILE..."
msgstr "TẾ_TRÊS ..."

msgid "parse as man page"
msgstr "análise de página limpa para o manual do usuário"

msgid "parse as cat page"
msgstr "análise de padrões na imagem cat"

msgid "%s: incompatible options"
msgstr "%s: cossenários de opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr "adicionar novamente todos os valores padrão das opções selecionadas."

msgid "Main modes of operation:"
msgstr "Chave de operação principal:"

msgid "equivalent to whatis"
msgstr "tương đương với whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "o catman é utilizado para reformular as páginas cat antigas"

msgid "Finding manual pages:"
msgstr "Em busca de direções:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "dùng %s para definir o layout da página."

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "DIRIGE_SEGURO"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizar o groff e exibir através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e force a saída ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual interface de ajuda você deseja?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de trânsito para %s no capítulo %s."

msgid "can't open temporary file %s"
msgstr "não é possível abrir a tabela temporária %s para edição"

msgid "mandb command failed with exit status %d"
msgstr ""
"lệnh \"mandb\" (sistema de dados direcionador) encontrou erro com status de "
"saída %d"

msgid "internal error: candidate type %d out of range"
msgstr "lỗi nội bộ: kiểu ứng cử %d nằm ngoài phạm vi."

msgid " Manual page "
msgstr "Trâng hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar uma codificação de saída para o código fonte."

msgid "can't write to standard output"
msgstr "não é possível escrever na saída padrão (STDOUT)"

msgid "CODE[:...]"
msgstr "MÃ[:…}"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chame im, exclua aviso 'giả'."

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova mensagens antigas do banco de dados."

msgid "FILENAME"
msgstr "TÊN_TẬP_TIN"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar os guias de usuário sob %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"cánh bao: không có chỉ thị \"MANDB_MAP\" trong ‘%s’ nên sô pra usar o "
"caminho de ajuda do seu manual."

msgid "No databases created."
msgstr "Não há base de dados criada ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"cão báfio: típaro de $MANPATH (diretório do caminho), atualmente adicionando"
" %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "cão báfio: típaro de $MANPATH (diretório de busca), %s é ignorado"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cão báfio: não há diretório %s requerido"

msgid "warning: %s does not begin with %s"
msgstr "cảnh báo: %s không bắt đầu bằng %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Ainda está verificando se o diretório contém a pasta 'cat' rapidamente "
"abaixo de %s…"

msgid "do not trim output to terminal width"
msgstr "não faça a exportação para o tamanho de janela do terminal"

msgid "warning: %s contains a pointer loop"
msgstr "cảnh báo: %s contém um ciclo de referência constrói (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada que corresponda. Por favor, tente outra opção."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: các yêu cầu '.so' lồng nhau quá sâu hoặc bị đệ quy."

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr ""
"%s:%d: aviso: requisito '.lf' com novo caractere de linha deve ser removido"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
