msgid "warning: %s: ignoring bogus filename"
msgstr "cão de guarda: %s: nome inválido do arquivo, ignorado"

msgid "the setuid man user \"%s\" does not exist"
msgstr ""
"não existe o utilizador com privilégios setuid '%s' para executar programas."

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"A base de dados %s está corrompida; tente novamente com o comando 'mandb -- "
"create'."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cão de guarda: %s é a versão %s, precisa ser atualizada para %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão possui o valor %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"configuração do caminho de pesquisa para diretórios de guias de manuais a "
"DIREÇÃO_DAVN"

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou com %d como código de saída do sistema"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória do log %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de memória para linha %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória para indicar a direção do caminho "
"« %s/%s ». Por favor, espere…"

msgid "Purging old database entries in %s...\n"
msgstr ""
"Ao processar o arquivo %s, estamos excluindo entradas desnecessárias..."

msgid "look for pages case-insensitively (default)"
msgstr ""
"não faz distinção entre maiúsculas e minúsculas ao pesquisar o manual "
"(padrão)"

msgid "look for pages case-sensitively"
msgstr "falha na busca por páginas ao distinguir maiúsculas e minúsculas"

msgid "FILE..."
msgstr "Tá por aí... (contextual placeholder for the actual translated text)"

msgid "parse as man page"
msgstr "análise do texto para fins de orientação manual"

msgid "parse as cat page"
msgstr "análise de página catgrafada"

msgid "%s: incompatible options"
msgstr "%s : opções em conflito entre si"

msgid "reset all options to their default values"
msgstr "reinicie todas as opções para seus valores padrão atuais."

msgid "Main modes of operation:"
msgstr "Modos operacionais principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"utilizado por catman para reformatar as páginas antigas do site de cat"

msgid "Finding manual pages:"
msgstr "Em busca de guias de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para formatar as páginas do trângulo"

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "Solução para o problema"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba com gxditview (X11) : \n"
" -X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e forceie para que ele produza ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual guia de usuário deseja visar?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de usuário para %s na seção %s."

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s"

msgid "mandb command failed with exit status %d"
msgstr "erro ao executar o comando 'mandb' devido à saída de estado %d"

msgid "internal error: candidate type %d out of range"
msgstr "erro de nível inferior : o tipo candidato %d está fora do alcance"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr ""
"é necessário indicar a codificação de saída para o código ser gerado "
"corretamente."

msgid "can't write to standard output"
msgstr "impossível escrever na saída padrão"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[MANPATH]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, desmonte o bloqueio 'giá'"

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova mensagens antigas da fonte de dados."

msgid "FILENAME"
msgstr "Nome do Arquivo"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de ajuda sob %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há a diretiva 'MANDB_MAP' no arquivo %s, portanto será "
"utilizado o caminho do seu manual."

msgid "No databases created."
msgstr "Não há nenhuma base de dados criada."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"cão de guarda: agrupamento do caminho $MANPATH (diretório indicador), "
"atualmente inserido %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "cão de guarda: a variável $MANPATH está configurada, %s é ignorado."

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso de erro: não há diretório necessário %s"

msgid "warning: %s does not begin with %s"
msgstr "cão de guarda: %s não começa a latir antes do alarme soar\n"

msgid "Checking for stray cats under %s...\n"
msgstr "Em busca de arquivos préformatados sem fontes sob %s…"

msgid "do not trim output to terminal width"
msgstr "não reduza o tamanho do display para a largura do terminal"

msgid "warning: %s contains a pointer loop"
msgstr "cão de guarda: %s contém um vórtice (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s : não há nada adequado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: requetes .so imbriquées trop profondément ou récursivement"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: .lf requisição contém novo caractere de linha, ignorado"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
