msgid "warning: %s: ignoring bogus filename"
msgstr "aviso: %s: se ignora o nome inválido do arquivo de texto"

msgid "the setuid man user \"%s\" does not exist"
msgstr ""
"não existe um usuário que possa executar com privilégios de 'setuid' \"%s\"."

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Sistema de dados %s corrompido; reconstrua com o comando 'mandb -- create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr ""
"aviso: a versão %s tem como base o modelo de desenvolvimento do projeto, "
"apesar dos requisitos esperados não serem atendidos. Para obter mais "
"informações sobre as expectativas e suporte técnico disponível para "
"solucionar problemas relacionados à compatibilidade com diferentes modelos, "
"consulte a documentação relevante."

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN] - Base de dados para o sistema do homem."

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão tem o valor %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"Estabeleça a direção de pesquisa para navegar entre as páginas do manual na "
"Rota_Direcao"

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou ao sair do estado de execução %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar a cache de índices %s"

msgid "can't create index cache %s"
msgstr "não é possível criar a cacha de índices %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Ao atualizar a cache de índices para o caminho `%s/%s'. Por favor, espere..."

msgid "Purging old database entries in %s...\n"
msgstr ""
"Tendo em vista atualizar os dados antigos da base de dados no diretório "
"%s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há distinção entre maiúsculas e minúsculas na busca padrão (método "
"definido)"

msgid "look for pages case-sensitively"
msgstr ""
"falta de respeito ao termo 'HOA' ou 'thường', que não é padrão em buscas "
"distintas maiúsculas e minúsculas."

msgid "FILE..."
msgstr "FICHERO_TIN…"

msgid "parse as man page"
msgstr "análise positiva da página man"

msgid "parse as cat page"
msgstr "análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: cópus incompatíveis"

msgid "reset all options to their default values"
msgstr ""
"restabeleça todas as opções de seleção para seus valores padrão definidos"

msgid "Main modes of operation:"
msgstr "Modos principais de operação:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"empleado por catman para reformatear páginas cat antigas e desatualizadas"

msgid "Finding manual pages:"
msgstr "Encontrando páginas do manual:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "emplee %s para formato de páginas"

msgid "use %s with selected device"
msgstr "utilize o %s com dispositivo selecionado"

msgid "RESOLUTION"
msgstr "DETERMINAR_SEU_PROCESSO"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizando groff e exibindo através de gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utiliza o groff e aplica força para gerar ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual página do manual deseja?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de trânsito para %s na seção %s\n"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"erro ao executar o comando 'mandb' (comando de gerenciamento do banco de "
"dados) no estado de saída %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"erro interno do sistema operacional: tipo de candidato %d fora da faixa "
"permitida"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr ""
"é necessário especificar uma codificação de saída para a tabela de "
"resultados"

msgid "can't write to standard output"
msgstr "não é possível escrever por saída padrão"

msgid "CODE[:...]"
msgstr "CÓDIGO[:...]"

msgid "[MANPATH]"
msgstr "[MANPATH]"

msgid "work quietly, except for 'bogus' warning"
msgstr "im executa em silêncio, exceto para avisos 'injustificados'"

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não é permitido sair do banco de dados sem limpar as entradas antigas."

msgid "FILENAME"
msgstr "NOMBREFICHERO_TIN"

msgid "Processing manual pages under %s...\n"
msgstr "Processando as páginas de manual sob %s...\n"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há diretivas 'MANDB_MAP' no %s, portanto será utilizada a"
" rota do manual (manpath)"

msgid "No databases created."
msgstr "Não há bases de dados criadas ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"aviso de configuração concluída: $MANPATH estabelecida, adicionando %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "aviso de erro: $MANPATH configurada, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso: o diretório obrigatório %s não existe"

msgid "warning: %s does not begin with %s"
msgstr "aviso de erro: %s não iniciou com o valor esperado, que é %s."

msgid "Checking for stray cats under %s...\n"
msgstr "Ao verificar, encontramos páginas cat perdidas sob %s..."

msgid "do not trim output to terminal width"
msgstr ""
"não é permitido cortar a saída para o tamanho do terminal de visualização "
"completa."

msgid "warning: %s contains a pointer loop"
msgstr "aviso: a variável %s contém um vórtice de ponteiro (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: requisicao(s) .so aninhada(s) excessivamente profunda ou recursiva\n"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: nova linha em petição .lf, se ignorar"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
