msgid "warning: %s: ignoring bogus filename"
msgstr "cảnh báo: %s: đang bỏ qua tên tập tin giả"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há usuário com permissões 'setuid' %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s bateu; por favor, execute novamente o comando 'mandb -- "
"create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cão de guarda: %s é a versão %s, necessita %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN] (Manual de Instrução)"

msgid "The man database defaults to %s%s."
msgstr "Công trả dữ liệu chính có giá trị mặc định là %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"coloque o caminho de navegação CONTROLE_NAVIGATION para pesquisar os links "
"de diretrizes guia."

msgid "man command failed with exit status %d"
msgstr "lêm hãnh 'man' nên thất bại với trạng thái thoát là %d."

msgid "can't update index cache %s"
msgstr ""
"não é possível fazer alterações no armazenamento temporário de memória do "
"sistema operacional %s"

msgid "can't create index cache %s"
msgstr "não é possível criar um banco de memória temporário para o livro %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"A atualização do banco de memória temporário para o caminho de destino "
"'%s/%s' está em andamento. Por favor, espere…"

msgid "Purging old database entries in %s...\n"
msgstr "Ao atualizar os arquivos de dados antigos no %s…"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há preconceito ao digitar o símbolo HOA/padrão ao procurar (por padrão)"

msgid "look for pages case-sensitively"
msgstr "phân biệt chữ HOA/thường khi tìm kiến hay câu lệnh"

msgid "FILE..."
msgstr "TẾ_PIN…"

msgid "parse as man page"
msgstr "análise de imagem limpa no monitor manuais"

msgid "parse as cat page"
msgstr "análise de padrões no catálogo digital"

msgid "%s: incompatible options"
msgstr "%s: cargas de trabalho não são compatíveis entre si"

msgid "reset all options to their default values"
msgstr "adicione todos os seus ajustes de configuração padrão"

msgid "Main modes of operation:"
msgstr "Chave de ação principal:"

msgid "equivalent to whatis"
msgstr "tương đương với whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"o catman é utilizado para redesenhar as páginas antigas do site de cães"

msgid "Finding manual pages:"
msgstr "Em busca de guias de navegação:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "dùng %s para definir o layout da página."

msgid "use %s with selected device"
msgstr "utilize o %s com a ferramenta selecionada"

msgid "RESOLUTION"
msgstr "DIRIGE_SEU_PERCURSO"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizando groff e exibindo informações por meio do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e execute a instrução ditroff para gerar um troféu"

msgid "What manual page do you want?\n"
msgstr "Qual é o seu comando de navegação desejado?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de navegação para %s no painel %s"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo %s para edição temporária."

msgid "mandb command failed with exit status %d"
msgstr ""
"lêm nenhum erro ao executar o comando 'mandb' (sistema de gerenciamento de "
"dados) em relação à condição de saída normal, que é representada pelo número"
" %d"

msgid "internal error: candidate type %d out of range"
msgstr "lỗi nội bộ: kiểu ứng cử %d nằm ngoài phạm vi."

msgid " Manual page "
msgstr "Trâng de direção"

msgid "must specify an output encoding"
msgstr ""
"é necessário indicar a matriz de saída para o programa ser executado "
"corretamente."

msgid "can't write to standard output"
msgstr "não é possível armazenar em saída padrão"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN] (Assine)"

msgid "work quietly, except for 'bogus' warning"
msgstr "chame im, remova o aviso 'giả'."

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não faça upload de dados antigos para o banco de dados, pois pode causar "
"inconsistências em mensagens armazenadas no cache."

msgid "FILENAME"
msgstr "TÊN_TẬP_TIN"

msgid "Processing manual pages under %s...\n"
msgstr ""
"Ao executar %s, você está atualmente processando os guias de diretrizes "
"abaixo…\n"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"cênho báto:\n"
"Nem haveria chave de navegação para \"MANDB_MAP\" dentro do diretório especificado (\"%s\"). Assim, será utilizada a rota personalizada da sua localização."

msgid "No databases created."
msgstr "Não foi possível criar o banco de dados."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"cão de guarda: tápia do conjunto $MANPATH (diretório de busca), em processo "
"de adição %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr ""
"cão de guarda: tápia do conjunto $MANPATH (diretório de direção), atualmente"
" removendo %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cão de guarda: não há pastas bloqueadas %s"

msgid "warning: %s does not begin with %s"
msgstr ""
"cão de guarda: %s não iniciou o serviço com sucesso, esperando que ele "
"comece bàgaiamente em breve."

msgid "Checking for stray cats under %s...\n"
msgstr "Ainda está verificando o caminho para a pasta %s…"

msgid "do not trim output to terminal width"
msgstr ""
"não faça a exportação de dados para o tamanho padrão do dispositivo final"

msgid "warning: %s contains a pointer loop"
msgstr "cão de alerta: %s contém um vórtice constrói (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada que seja adequado para você."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: cargas de trabalho '.so' simultâneas excessivas ou insuficientes"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr ""
"%s:%d: aviso: requer %.lf que contenha novo caractere de linha para poder "
"ser removido"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
