msgid "warning: %s: ignoring bogus filename"
msgstr "peringatan: %s: mengabaikan nama berkas palsu"

msgid "the setuid man user \"%s\" does not exist"
msgstr "Não há ninguém com acesso de setuid ao usuário %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s ter sido comprometido; por favor, execute o comando "
"'mandb -- create' novamente."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "peringatamento: %s é a versão %s, espera-se que seja o caso de %s"

msgid "[MAN DATABASE]"
msgstr "[MAN ID] DOVA DE DADOS LIEUVES"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão como %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"Coloque o caminho de diretório CONTROLE_PATH para navegar até os guias de "
"orientação."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou ao sair com estado %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória do índice %s"

msgid "can't create index cache %s"
msgstr "não é possível criar um local de armazenamento para memória cache %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória para caminho '%s/%s'. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr ""
"Ao tentação cargas de informações antigas do banco de dados na base de "
"%s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há discriminação entre maiúsculas e minúsculas do termo HOA/thường "
"quando pesquisa (padrão)"

msgid "look for pages case-sensitively"
msgstr "falha na busca de termo com diferenciação maiúsculo/minúsculo"

msgid "FILE..."
msgstr "ID_TIN..."

msgid "parse as man page"
msgstr "análise positiva do layout da página de abertura manual"

msgid "parse as cat page"
msgstr "análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"adicionar novamente todos os valores padrão para as configurações "
"selecionadas."

msgid "Main modes of operation:"
msgstr "Modo operacional principal:"

msgid "equivalent to whatis"
msgstr "igual ao whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"o catman utilizou o comando para reformular os layouts dos artigos antigos "
"do gato"

msgid "Finding manual pages:"
msgstr "Estou procurando o guia de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "Use o %s para formatar a página da interface."

msgid "use %s with selected device"
msgstr "utilize o %s com a ferramenta selecionada"

msgid "RESOLUTION"
msgstr "ID_do_usuário"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique uma força para que ele gere ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual caminho de navegação você deseja?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guias de estilo disponíveis para %s na seção %s."

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s para edição."

msgid "mandb command failed with exit status %d"
msgstr ""
"comando 'mandb' para gerenciamento de dados falhou ao sair com código %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"Erro de nível interno: o tipo candidato %d está fora do alcance atualizado."

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação de saída para o código gerado."

msgid "can't write to standard output"
msgstr "não é possível escrever no padrão de saída"

msgid "CODE[:...]"
msgstr "Código[:...]"

msgid "[MANPATH]"
msgstr "[ID_MAN]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, pule a mensagem 'giả'"

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova mensagens antigas do banco de dados"

msgid "FILENAME"
msgstr "ID_TIN"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar os guias de ajuda sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há diretório 'MANDB_MAP' no %s, utilizando caminho do seu"
" manual."

msgid "No databases created."
msgstr "Não há nenhuma base de dados criada."

msgid "warning: $MANPATH set, inserting %s"
msgstr "cảnh báo: tập hợp \"$MANPATH\" (đường dẫn hướng dẫn), chèn %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "peringunta: $MANPATH atualizado, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "peringunta: diretório %s não encontrado"

msgid "warning: %s does not begin with %s"
msgstr "peringatamento: %s não iniciou com o símbolo '%c'"

msgid "Checking for stray cats under %s...\n"
msgstr "Fazendo verificação, o cat terceiro abaixo de %s...\n"

msgid "do not trim output to terminal width"
msgstr ""
"não faça o export do sinal para a largura total da tela de dispositivo final"

msgid "warning: %s contains a pointer loop"
msgstr "peringatamento: %s contém um ciclo de referência (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr ""
"%s: não há nada que se encaixe. (semelhante a 'não tem nada adequado' ou "
"'ninguém é o certo')"

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: permintaan .so berlapis terlalu dalam atau rekursif"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: linha nova em .lf, ignorada"

msgid "compatibility switch (ignored)"
msgstr "opções de compatibilidade para o objetivo do software (excluídas)"
