msgid "warning: %s: ignoring bogus filename"
msgstr "aviso: %s: o nome do arquivo foi ignorado devido a ser inválido"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não existe um usuário 'setuid' '%s'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s danificado; reestruturar utilizando a linha 'mandb -- "
"create'."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "aviso: %s tem versão %s, é necessário %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão como %s%s."

msgid "can't open %s for reading"
msgstr "não foi possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"Adicione o caminho de pesquisa para diretórios de guias de ajuda na variável"
" DẦN_DẪN."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou ao sair com status %d"

msgid "can't update index cache %s"
msgstr "não foi possível atualizar o cache de memória do local %s"

msgid "can't create index cache %s"
msgstr "não foi possível criar o cache de memória para a lista %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória do caminho `%s/%s`. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação cápsulas de dados antigos na nossa base de dados em %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não é permitido discriminar o caso da letra HOA/comum ao procurar (padrão)"

msgid "look for pages case-sensitively"
msgstr "falta de consideração ao pesquisar com base em HOA/thường."

msgid "FILE..."
msgstr ""
"TÍVEL_TRABALHO... (Please provide the full original text for accurate "
"translation)"

msgid "parse as man page"
msgstr "analisar o layout da página de ajuda manualmente"

msgid "parse as cat page"
msgstr "fazer análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr "redefinir todos os valores padrão para as configurações selecionadas"

msgid "Main modes of operation:"
msgstr "modos de operação principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "utilizado o catman para reformular as páginas cat antigas"

msgid "Finding manual pages:"
msgstr "Em busca de guias de referência:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilizar %s para formatar a página"

msgid "use %s with selected device"
msgstr "utilizar %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "RESOLUÇÃO DE PROBLEMAS"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizar o groff e exibir através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e forceie a criação do ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual é a página de ajuda que você precisa?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de trânsito para %s no menu %s."

msgid "can't open temporary file %s"
msgstr "não foi possível abrir o arquivo temporário %s para edição"

msgid "mandb command failed with exit status %d"
msgstr ""
"Erro ao executar o comando 'mandb' (administração de base de dados) devido à"
" saída do processo %d."

msgid "internal error: candidate type %d out of range"
msgstr "Erro de nível interno: tipo do candidato %d está fora dos limites"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "deve haver uma indicação da codificação de saída do código"

msgid "can't write to standard output"
msgstr "não foi possível gastar no fluxo padrão de saída"

msgid "CODE[:...]"
msgstr "Código de Autenticação[: ...]"

msgid "[MANPATH]"
msgstr "[MANPATH]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua avisos exceto os 'fictícios'"

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não deve parar de sair do local dos dados antigos das notificações "
"desatualizadas."

msgid "FILENAME"
msgstr "Nome do Arquivo"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de ajuda sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há a diretiva 'MANDB_MAP' no %s, portanto será utilizado "
"o caminho do manpath da sua sessão."

msgid "No databases created."
msgstr "As bases de dados ainda não foram criadas."

msgid "warning: $MANPATH set, inserting %s"
msgstr "aviso de segurança: encontrada variável $MANPATH, inserindo em %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr ""
"aviso de segurança: encontrado o caminho do ambiente $MANPATH, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso de erro: não há diretório obrigatório %s"

msgid "warning: %s does not begin with %s"
msgstr "aviso: %s não começa com %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Fazendo verificação de arquivos cat que estão corrompidos sob %s...\n"

msgid "do not trim output to terminal width"
msgstr ""
"não faça upload de conteúdo para a largura completa do dispositivo terminal."

msgid "warning: %s contains a pointer loop"
msgstr "cão de guarda: %s contém um ciclo referencial (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado para este campo."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: các requisições .so lõu nhau quá sâu hoặt bị đệ quy."

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: nova linha em .lf requisitada, ignorada\n"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
