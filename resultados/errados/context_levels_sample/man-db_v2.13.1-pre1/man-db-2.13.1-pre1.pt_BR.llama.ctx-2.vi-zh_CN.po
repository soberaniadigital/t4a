msgid "warning: %s: ignoring bogus filename"
msgstr "cảnh báo: %s: đang bỏ qua tên tập tin giả"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém com acesso de 'setuid' ao arquivo %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s foi corrompido; por favor, execute o comando 'mandb -- "
"create' novamente."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cảnh báo: %s là phiên bản %s, cần %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A fonte de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"coloque o diretório de entrada para navegar pelos links dos guias de "
"pesquisa."

msgid "man command failed with exit status %d"
msgstr "lêm hãnh 'man' như thất bại với trạng thái thoát là %d."

msgid "can't update index cache %s"
msgstr "não é possível atualizar o banco de dados de memória temporária %s"

msgid "can't create index cache %s"
msgstr "não é possível criar um banco de dados temporário para o local %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"A atualização do cache de índice para o caminho %s/%s está em andamento. Por"
" favor, espere…"

msgid "Purging old database entries in %s...\n"
msgstr "Ao processar os arquivos de cache antigos no diretório %s…"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há diferença de tratamento entre maiúsculas e minúsculas do termo "
"HOA/thường ao procurar (padrão)"

msgid "look for pages case-sensitively"
msgstr "phân biệt chữ HOA/thường khi tìm"

msgid "FILE..."
msgstr "TẾ_TRÊS…"

msgid "parse as man page"
msgstr ""
"análise detalhada do manual de instruções para acessar o sistema operacional"
" Linux em um computador desktop comum."

msgid "parse as cat page"
msgstr "análise de padrões catgifs"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"adicionar novamente todos os valores padrão para as configurações "
"selecionadas."

msgid "Main modes of operation:"
msgstr "Chave de operação principal:"

msgid "equivalent to whatis"
msgstr "tão parecido com whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"o catman foi utilizado para redesenhar as páginas antigas do site de gatos."

msgid "Finding manual pages:"
msgstr "Em busca de guias:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilizando %s para definir o layout da página do manual"

msgid "use %s with selected device"
msgstr "utilize o %s com a ferramenta selecionada"

msgid "RESOLUTION"
msgstr "Direção de Apoio ao Cliente"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilizando groff e exibindo através de gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique uma força para que ele gere ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual guia de instruções você precisa?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de uso para %s no capítulo %s."

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo temporário %s para edição"

msgid "mandb command failed with exit status %d"
msgstr ""
"lệnh \"mandb\" (sistema de dados guia) encontrou erro ao sair do estado %d"

msgid "internal error: candidate type %d out of range"
msgstr "erro de nível interno: o tipo %d está fora do alcance normal"

msgid " Manual page "
msgstr "Trâng Hướng Dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação de saída para o código fonte."

msgid "can't write to standard output"
msgstr "não é possível escrever no padrão de saída"

msgid "CODE[:...]"
msgstr "MÃ[:…} (preserve the original formatting and variables)"

msgid "[MANPATH]"
msgstr "[Demonstração do Manual]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua alerta 'bogus' sem sair nenhuma informação"

msgid "don't purge obsolete entries from the dbs"
msgstr "não é permitido excluir mensagens antigas do banco de dados local"

msgid "FILENAME"
msgstr "Nome do Arquivo"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar os guias de ajuda sob %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso: não há o comando específico 'MANDB_MAP' no diretório '%s', portanto, "
"será utilizado seu caminho de ajuda."

msgid "No databases created."
msgstr "Não há nenhuma base de dados criada."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"cão báfio: agrupamento $MANPATH (cadeia de diretório), atualmente "
"adicionando %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr ""
"cão báfio: agrupamento do caminho $MANPATH (diretório de busca), atualmente "
"sendo removido %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cão báfio: não há diretório %s obrigatório"

msgid "warning: %s does not begin with %s"
msgstr "cão bágua: %s não começa com %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Ao verificar se o trângulo está vazio, encontramos a página 'cat' "
"rapidamente abaixo de %s…"

msgid "do not trim output to terminal width"
msgstr ""
"não é permitido exportar para o tamanho de janela do dispositivo final sem "
"ajuste"

msgid "warning: %s contains a pointer loop"
msgstr "cảnh báo: %s contém um ciclo de vetor con (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: nenhum resultado adequado encontrado. %d"

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: cargas (.so) simultâneas excessivas ou formando ciclos"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: cảnh báo: yêu cầu '.lf' có chứa ký tự dòng mới nên bỏ qua"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
