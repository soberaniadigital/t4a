msgid "warning: %s: ignoring bogus filename"
msgstr "cảnh báo: %s: đang bỏ qua tên tập tin giả"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém que use a função 'setuid' '%s'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s corrompido; realize a restauração utilizando o comando "
"'mandb -- create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cảnh báo: %s là phiên bản %s, cần %s\n"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN] (Manual Data Entry)"

msgid "The man database defaults to %s%s."
msgstr "Công thức dữ liệu chính có giá trị mặc định là %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"coloca o caminho de navegação para localizar os guias de orientação em "
"DIR_NAVIGATION"

msgid "man command failed with exit status %d"
msgstr "lêm hãnh 'man' khôt thiệt với trạng thái thoát là %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o índice de memória temporária %s"

msgid "can't create index cache %s"
msgstr ""
"não é possível criar um índice de memória temporária para o arquivo %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"A atualização do cache de memória para o caminho '%s/%s' está em andamento. "
"Por favor, espere…"

msgid "Purging old database entries in %s...\n"
msgstr "Ao tarefa de atualização dos dados antigos da base de dados em %s..."

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há diferença de tratamento para o símbolo HOA/thường ao procurar "
"(padrão)"

msgid "look for pages case-sensitively"
msgstr "phân biệt chữ HOA/thường khi tìm"

msgid "FILE..."
msgstr "TẾ_TRANSFERÊNCIA…"

msgid "parse as man page"
msgstr "análise de imagem limpa no monitor man"

msgid "parse as cat page"
msgstr "análise de padrões no catálogo digital do gato virtual"

msgid "%s: incompatible options"
msgstr "%s: cadeiras de computador não são compatíveis entre si."

msgid "reset all options to their default values"
msgstr ""
"adicione novamente todos os valores padrão para as opções selecionadas."

msgid "Main modes of operation:"
msgstr "Modo operacional principal:"

msgid "equivalent to whatis"
msgstr "tão semelhante ao que é"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"o catman utilizou o comando %s para reformatar os layout dos artigos antigos"
" do gato"

msgid "Finding manual pages:"
msgstr "Em busca de guias de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para definir o layout da página"

msgid "use %s with selected device"
msgstr "utilize o %s com a ferramenta selecionada."

msgid "RESOLUTION"
msgstr "OPÇÃO INVÁLIDA -- '%c'"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique este comando para gerar ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual trângulo de diretrizes você deseja?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de linha para %s na seção %s."

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo %s para leitura temporária."

msgid "mandb command failed with exit status %d"
msgstr ""
"lệnh \"mandb\" (sistema de dados direcionado) enfrentou erro com o estado "
"saída %d"

msgid "internal error: candidate type %d out of range"
msgstr "lỗi nội bộ: kiểu ứng cử %d nằm ngoài phạm vi."

msgid " Manual page "
msgstr "Trâng de direção"

msgid "must specify an output encoding"
msgstr ""
"é necessário indicar claramente a sequência de números e letras no código "
"fonte para que possamos gerar o arquivo resultante."

msgid "can't write to standard output"
msgstr "não é possível gravar no fluxo padrão de saída."

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN] (Caminho do Homem)"

msgid "work quietly, except for 'bogus' warning"
msgstr "chame im, exclua o aviso 'palsu'."

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova entradas obsoletas da base de dados."

msgid "FILENAME"
msgstr "TÊN_TẬP_TIN"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar os guias de procedimento sob %s…"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"clareação de aviso: não há diretório chiapado 'MANDB_MAP' no %s, utilizando "
"o caminho indicado por você."

msgid "No databases created."
msgstr "Não há base de dados criada ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr "cão báfio: táp họp $MANPATH (đường dẫn hướng dẫn), chênh mại %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr ""
"cão báfio: típaro de $MANPATH (diretório de diretivas), atualmente removendo"
" %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cão báfio: não há diretório de arquivos %s requerido"

msgid "warning: %s does not begin with %s"
msgstr "clareira de aviso: %s não iniciou com o valor %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Ainda está verificando o cat terráqueo sob %s…"

msgid "do not trim output to terminal width"
msgstr "não faça o export do sinal para a borda da tela de saída final"

msgid "warning: %s contains a pointer loop"
msgstr "cảnh báo: %s contém um ciclo de referência (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr ""
"%s: nenhum ajuste adequado disponível. Clique em 'OK' para continuar ou na "
"opção 'Cancelar' se preferir não prosseguir."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: permintaan .so berlapis terlalu dalam atau rekursif"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: requisito '.lf' com novo caractere de linha, ignorado"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (bị bỏ qua)"
