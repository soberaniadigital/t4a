msgid "warning: %s: ignoring bogus filename"
msgstr "peringatan: %s: mengabaikan nama berkas palsu"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém com acesso \"setuid\" %s"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s ter sido comprometido; realize a restauração utilizando "
"o comando 'mandb -- create'."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "peringatan: %s adalah versi %s, mengharapkan %s\n"

msgid "[MAN DATABASE]"
msgstr "[MAN BASIS_DATA] ID [HANDBUCHDATENBANK] DE"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"coloque o DẦN_DỪNG para direcionar a pesquisa de páginas guias no PATH"

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou ao sair com status %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar a memória de cache do índice %s"

msgid "can't create index cache %s"
msgstr "não é possível criar um local de armazenamento para memória cache %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória para caminho '%s/%s'. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação cargas de informações antigas do banco de dados %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há discriminação de maiúsculas e minúsculas para o termo HOA/thường ao "
"procurar (padrão)"

msgid "look for pages case-sensitively"
msgstr "falha na busca por HOA/thường khi tìm ID ou DE."

msgid "FILE..."
msgstr "ID_TIN..."

msgid "parse as man page"
msgstr "análise de imagem limpa da página do manual"

msgid "parse as cat page"
msgstr "análise de padrões no catálogo do gato"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"redefinir todos os valores padrão para as configurações definidas pelo "
"usuário."

msgid "Main modes of operation:"
msgstr "Modo operacional principal:"

msgid "equivalent to whatis"
msgstr "tão semelhante ao whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "o catman é utilizado para reformular as páginas cat antigas"

msgid "Finding manual pages:"
msgstr "Estou procurando a página de diretrizes:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize o %s para formatar a página."

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "ID_RESOLUSIÓREAL"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique este comando para gerar ditroff"

msgid "What manual page do you want?\n"
msgstr "Qual é o caminho de navegação que você deseja?\n"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de trânsito para %s na seção %s"

msgid "can't open temporary file %s"
msgstr "não é possível abrir a pasta temporária %s para edição."

msgid "mandb command failed with exit status %d"
msgstr ""
"comando 'mandb' (sistema de gerenciamento do banco) falhou ao encontrar o "
"estado saída %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"Erro de nível interno do sistema operacional: Tipo candidato %d está fora "
"dos limites da área visada."

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário especificar a codificação de saída para o código gerado."

msgid "can't write to standard output"
msgstr "não é possível escrever no fluxo padrão de saída."

msgid "CODE[:...]"
msgstr "Código[:...]"

msgid "[MANPATH]"
msgstr "[ID_MAN]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, trunca a barreira de aviso 'falso'"

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não remova entradas antigas da base de dados para manter registros "
"históricos importantes."

msgid "FILENAME"
msgstr "ID_DE"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de diretrizes sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"peringatamento: não há diretório de mapa 'MANDB_MAP' no %s, portanto será "
"utilizado o caminho indicação do usuário."

msgid "No databases created."
msgstr "Não há base de dados criada ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr "peringatamento: $MANPATH configurado, %s é adicionado"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "peringatamento: $MANPATH configurado, o valor %s será ignorado."

msgid "warning: mandatory directory %s doesn't exist"
msgstr "peringunta: diretório wajib %s não existe"

msgid "warning: %s does not begin with %s"
msgstr "peringatamento: %s não iniciou com o sinal '%s'."

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Fazendo verificação com o termo 'cat' quebrando rapidamente abaixo de "
"%s...\n"

msgid "do not trim output to terminal width"
msgstr "não faça a exportação para o tamanho do terminal padrão."

msgid "warning: %s contains a pointer loop"
msgstr "peringatan: %s contém um ciclo de referência (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada que corresponda. (não tem nada adequado)"

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: permintaan .so berlapis terlalu dalam atau rekursif"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: linha nova em '.lf', ignorada"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
