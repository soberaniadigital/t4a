msgid "warning: %s: ignoring bogus filename"
msgstr "aviso: %s: está removendo o nome incorreto do arquivo"

msgid "the setuid man user \"%s\" does not exist"
msgstr ""
"não há nenhum usuário para executar o programa com permissões setuid '%s'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Sistema de dados %s corrompido; utilize o comando 'mandb -- create' para "
"reestruturá-lo."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "aviso: a versão %s da ferramenta é %s, e esperamos que seja de %s."

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A fonte de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"Defina o caminho de acesso para diretório do manual de busca, permitindo que"
" você encontre os guias de ajuda facilmente."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou, código de saída para o estado de escape é %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o local de armazenamento da memória cache %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de memória para a lista %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr "Atualizando o cache de índices para a rota %s/%s. Aguarde..."

msgid "Purging old database entries in %s...\n"
msgstr "Ajudando a limpar dados antigos na base de dados no %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não faz diferença se o HOA ou a letra 'a' forem maiúsculas ou minúsculas ao "
"procurar este manual (padrão)"

msgid "look for pages case-sensitively"
msgstr ""
"falha na busca devido a diferença de maiúsculas e minúsculas no nome do "
"arquivo HOA/thường"

msgid "FILE..."
msgstr "Título do arquivo..."

msgid "parse as man page"
msgstr "análise de imagem limpa da página manual"

msgid "parse as cat page"
msgstr "análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"redefinir todos os valores padrão para as configurações definidas "
"anteriormente."

msgid "Main modes of operation:"
msgstr ""
"ZH_CN: 主要运行模式：\n"
"ES: Principais modos de operação:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr "Utilizado por catman para redesenhar as páginas cat antigas."

msgid "Finding manual pages:"
msgstr "Em busca de guias de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para formatar o manual do equipamento."

msgid "use %s with selected device"
msgstr "utilize o %s com a ferramenta selecionada"

msgid "RESOLUTION"
msgstr "Resolução de qualidade"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11) conforme as seguintes configurações:\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique força para que ele crie ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual é o manual de destino para você?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de linha para %s na seção %s."

msgid "can't open temporary file %s"
msgstr "não foi possível abrir o arquivo temporário %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"falha ao executar o comando 'mandb' (gerenciamento de dados guia) devido à "
"condição de saída %d."

msgid "internal error: candidate type %d out of range"
msgstr ""
"erro interno do sistema operacional: tipo de entrada %d está fora dos "
"limites aceitáveis"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação de saída para o arquivo .exe"

msgid "can't write to standard output"
msgstr "não é possível escrever por saída padrão"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[MAN PATH]"

msgid "work quietly, except for 'bogus' warning"
msgstr "executar em modo silencioso, exceto para avisos 'falso positivos'"

msgid "don't purge obsolete entries from the dbs"
msgstr "não remova mensagens antigas do banco de dados local"

msgid "FILENAME"
msgstr "Nome do Arquivo"

msgid "Processing manual pages under %s...\n"
msgstr "Em processamento de %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há a diretiva 'MANDB_MAP' no arquivo %s, portanto será "
"utilizada sua rota manual (manpath).\n"

msgid "No databases created."
msgstr "Não há nenhuma base de dados criada."

msgid "warning: $MANPATH set, inserting %s"
msgstr "aviso: $MANPATH configurada, inserindo %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "aviso: $MANPATH configurada, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso: o diretório %s não existe"

msgid "warning: %s does not begin with %s"
msgstr "aviso: %s não começa com %s"

msgid "Checking for stray cats under %s...\n"
msgstr "Fazendo verificação no diretório %s...\n"

msgid "do not trim output to terminal width"
msgstr "não envie saída para a largura do dispositivo finalizado"

msgid "warning: %s contains a pointer loop"
msgstr "aviso: o %s contém um ciclo de ligação (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: nenhum resultado adequado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: cargas .so anidadas exceden la profundidad máxima o forman ciclos "
"recursivos"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr ""
"%s:%d: aviso: requisição .lf contém uma linha nova, por isso será ignorada."

msgid "compatibility switch (ignored)"
msgstr "opções de compatibilidade (ignoradas)"
