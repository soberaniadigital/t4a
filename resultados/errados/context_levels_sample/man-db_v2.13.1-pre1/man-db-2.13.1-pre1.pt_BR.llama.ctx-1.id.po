msgid "warning: %s: ignoring bogus filename"
msgstr "peringatan: %s: mengabaikan nama berkas palsu"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém com o ID de usuário setuid \"%s\""

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Sistema de dados %s comprometido; construa novamente usando o comando 'mandb"
" -- create'"

msgid "warning: %s is version %s, expecting %s\n"
msgstr ""
"peringatamento: %s é a versão %s, espera-se que sejam feitas as alterações "
"necessárias\n"

msgid "[MAN DATABASE]"
msgstr "[MAN BASIS_DATA] ID do usuário."

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão como %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para leitura."

msgid "set search path for manual pages to PATH"
msgstr ""
"Coloque o ID do caminho de pesquisa para navegar pelos links guia no PATH "
"definido."

msgid "man command failed with exit status %d"
msgstr "comando \"man\" falhou ao sair com status %d"

msgid "can't update index cache %s"
msgstr ""
"não é possível atualizar o local de armazenamento do cache da memória %s"

msgid "can't create index cache %s"
msgstr "não é possível criar uma memória de trabalho %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Ao atualizar o local de armazenamento da memória para caminho '%s/%s'. Por "
"favor, espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação cargas de informações antigas do servidor em %s..."

msgid "look for pages case-insensitively (default)"
msgstr ""
"não há discriminação de maiúsculas e minúsculas (HOA/thường) ao procurar por"
" ID\n"

msgid "look for pages case-sensitively"
msgstr "falta de identidade (ID)"

msgid "FILE..."
msgstr "ID do usuário"

msgid "parse as man page"
msgstr "análise de tela limpa para interface gráfica do usuário (GUI)"

msgid "parse as cat page"
msgstr "análise de padrões no catálogo digital do gato"

msgid "%s: incompatible options"
msgstr "%s: các tùy chọn không tương thích với nhau"

msgid "reset all options to their default values"
msgstr ""
"adicione novamente todos os valores padrão para as opções selecionadas."

msgid "Main modes of operation:"
msgstr "Modo operacional principal:"

msgid "equivalent to whatis"
msgstr "igual ao whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"o catman utilizou o comando '%s' para reformatar os artigos antigos do seu "
"blog."

msgid "Finding manual pages:"
msgstr "Estou procurando o guia de usuário:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "Use o %s para definir a estrutura da página."

msgid "use %s with selected device"
msgstr "use o %s com a ferramenta escolhida"

msgid "RESOLUTION"
msgstr "ID do usuário"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e aplique este comando para gerar ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual é o caminho para a página de ajuda que você deseja visitar?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guias de entrada para %s na seção %s\n"

msgid "can't open temporary file %s"
msgstr "não é possível abrir o arquivo %s para leitura temporária."

msgid "mandb command failed with exit status %d"
msgstr ""
"Erro ao executar o comando 'mandb' (gerenciamento de base de dados) no "
"estado de saída %d"

msgid "internal error: candidate type %d out of range"
msgstr "Erro de nível interno: tipo candidato %d está fora do alcance"

msgid " Manual page "
msgstr ""
"Trang hướng dẫn para oportunidades de aprendizado e desenvolvimento "
"profissional."

msgid "must specify an output encoding"
msgstr ""
"é necessário especificar um código de saída para o registro do resultado da "
"execução."

msgid "can't write to standard output"
msgstr "não é possível escrever no fluxo padrão de saída."

msgid "CODE[:...]"
msgstr "Código[:...]"

msgid "[MANPATH]"
msgstr "[ĐƯỜNG_DẪN_MAN] (ID)"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua alerta 'palsu' para prosseguir."

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não remova entradas antigas da base de dados para manter a integridade dos "
"registros históricos."

msgid "FILENAME"
msgstr "ID_DETECTADA"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar os guias de diretrizes sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"peringatamento: não há diretório de mapa 'MANDB_MAP' no %s, utilizando o "
"caminho do usuário."

msgid "No databases created."
msgstr "Não há uma base de dados criada ainda."

msgid "warning: $MANPATH set, inserting %s"
msgstr "cão de guarda: $MANPATH (diretório do PATH), adicionando %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "peringatamento: $MANPATH atualizado, desconsiderando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "peringatamento: diretório wajib %s não tem arquivo"

msgid "warning: %s does not begin with %s"
msgstr "peringatamento: %s não iniciou com o valor %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Fazendo verificação no diretório com o arquivo 'cat', encontramos um erro "
"rapidamente abaixo de %s...\n"

msgid "do not trim output to terminal width"
msgstr ""
"não faça xenofobia ao exportar para a largura máxima do terminal final"

msgid "warning: %s contains a pointer loop"
msgstr "peringatamento: %s contém um ciclo de referência (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada que corresponda. Por favor, tente outra opção."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: permissões negadas para solicitações .so simultâneas ou recursivas"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: linha nova em permissão .lf, ignorada"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thích (diabaikan)"
