msgid "warning: %s: ignoring bogus filename"
msgstr "cão de guarda: %s: o nome do arquivo está incorreto e será ignorado"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não existe um usuário para executar o comando setuid '%s'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Sistema de dados %s danificado; execute o comando 'mandb -- create' para "
"reparo."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "Cairição: %s é a versão %s, esperado foi %s"

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "não é possível abrir %s para ler"

msgid "set search path for manual pages to PATH"
msgstr ""
"Defina o caminho de navegação para localizar as páginas guias do manual."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou com status de saída %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória do índice %s"

msgid "can't create index cache %s"
msgstr "não é possível criar um cache de memória para o log %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória do caminho %s/%s. Por favor, "
"espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação c%C3%A2mpos de dados antigos do banco de dados %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr ""
"não é permitido discriminar entre maiúsculas e minúsculas ao procurar por "
"HOA/thường (padrão)"

msgid "look for pages case-sensitively"
msgstr ""
"faltando ao seu nome, por favor informe o que procura para assistência."

msgid "FILE..."
msgstr "TARGET_FILE..."

msgid "parse as man page"
msgstr "análise de imagem limpa da página do manual"

msgid "parse as cat page"
msgstr "análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr "redefinir todos os valores padrão dos campos selecionados."

msgid "Main modes of operation:"
msgstr "Modos de operação principais:"

msgid "equivalent to whatis"
msgstr "substitui o whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"O catman foi utilizado para reformular as páginas antigas do site Cat."

msgid "Finding manual pages:"
msgstr "Encontrando as páginas de ajuda:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para definir o layout da página"

msgid "use %s with selected device"
msgstr "%s utilizado com o dispositivo selecionado."

msgid "RESOLUTION"
msgstr "Filtragem de qualidade"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"Utilize o groff e exiba com gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e force a criação da saída ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual é a página de ajuda que você deseja visualizar?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de trânsito para %s no capítulo %s."

msgid "can't open temporary file %s"
msgstr "não é possível abrir a pasta temporária %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"Erro ao executar o comando 'mandb' (gerenciamento de dados) enquanto saiu do"
" sistema. Estado final %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"Erro interno do sistema operacional: tipo de voto %d está fora dos limites "
"permitidos."

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação de saída para o arquivo .po."

msgid "can't write to standard output"
msgstr "não é possível escrever no padrão de saída"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[CAMINHO_DO_MANUSCRITO]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, sem emitir aviso 'erro' em caso de falha"

msgid "don't purge obsolete entries from the dbs"
msgstr "não é permitido excluir registros antigos da base de dados"

msgid "FILENAME"
msgstr "NOMÉR_ARQUIVOS"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de ajuda sob %s, ..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há instruções para 'MANDB_MAP' no diretório '%s', "
"portanto, será utilizado o caminho do seu manual."

msgid "No databases created."
msgstr "Não há nenhuma base de dados criada."

msgid "warning: $MANPATH set, inserting %s"
msgstr "CANAL DE ALERTA: o $MANPATH está configurado, %s será adicionado"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "CANAL DE ALERTA: o $MANPATH está configurado, %s será ignorado."

msgid "warning: mandatory directory %s doesn't exist"
msgstr "Cairi: não há diretório %s necessário para o processamento."

msgid "warning: %s does not begin with %s"
msgstr "cão de guarda: %s não começa com a palavra 'guarda'."

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Fazendo uma verificação, as páginas do 'cat' que não contêm arquivos em %s "
"estão sendo procuradas..."

msgid "do not trim output to terminal width"
msgstr ""
"não faça a saída de dados para o tamanho fixo da largura do terminal, mas "
"mantenha as informações completas."

msgid "warning: %s contains a pointer loop"
msgstr "CANALHAO DE ERRO: %s contém um vínculo cíclico (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada que corresponda."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr "%s:%d: các requisições .so lõu nhau quá sâu hoặt bị đệ quy."

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr ""
"%s:%d: Aviso: Linha de comando .lf contém novos caracteres de quebra de "
"linha, ignorados"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
