msgid "warning: %s: ignoring bogus filename"
msgstr "cão de guarda: %s: o nome do arquivo inválido será ignorado"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém utilizando o usuário setuid \"%s\""

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Sistema de dados %s danificado; execute o comando 'mandb -- create' para "
"recriar."

msgid "warning: %s is version %s, expecting %s\n"
msgstr "cão de guarda: %s é a versão %s, esperado foi o uso do comando '%s' \n"

msgid "[MAN DATABASE]"
msgstr "[Livro de Dados da Biblioteca Man]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados principal tem o valor padrão %s%s."

msgid "can't open %s for reading"
msgstr "impossível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"Defina o caminho de pesquisa para navegar entre as páginas guias do manual."

msgid "man command failed with exit status %d"
msgstr "comando 'man' falhou com o status de saída %d"

msgid "can't update index cache %s"
msgstr "não é possível atualizar o cache de memória do log %s"

msgid "can't create index cache %s"
msgstr "não é possível criar o cache de memória para a lista %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória para o caminho do índice '%s/%s'. Por"
" favor, espere..."

msgid "Purging old database entries in %s...\n"
msgstr "Estão sendo excluídos os registros antigos do %s..."

msgid "look for pages case-insensitively (default)"
msgstr ""
"não faz distinção entre maiúsculas e minúsculas ao procurar por HOA/thường "
"(padrão)"

msgid "look for pages case-sensitively"
msgstr "faltando ao seu respeito, HOA/thường khi tìm"

msgid "FILE..."
msgstr "TARGET_FILE..."

msgid "parse as man page"
msgstr "análise de imagem agradável da página do manual"

msgid "parse as cat page"
msgstr "análise de página do catgirl"

msgid "%s: incompatible options"
msgstr "%s: opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr "redefinir todos os valores padrão das opções selecionadas."

msgid "Main modes of operation:"
msgstr "Modos de operação principais:"

msgid "equivalent to whatis"
msgstr "substituto para 'whatis'"

msgid "used by catman to reformat out of date cat pages"
msgstr "Utilizado por catman para reformatar as páginas antigas."

msgid "Finding manual pages:"
msgstr "Encontrando as páginas de ajuda:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para formatar as páginas."

msgid "use %s with selected device"
msgstr "%s utilizado com o dispositivo selecionado."

msgid "RESOLUTION"
msgstr "DE"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba com gxditview (X11) : \n"
" -X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e force a produção da saída ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual caminho de ajuda desejamos?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de usuário para %s no capítulo %s disponível."

msgid "can't open temporary file %s"
msgstr "não é possível abrir a pasta temporária %s"

msgid "mandb command failed with exit status %d"
msgstr ""
"Erro ao executar o comando 'mandb' (comando de gerenciamento do banco de "
"dados) com status de saída %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"erro de nível baixo: o tipo do candidato %d não está dentro dos limites "
"permitidos"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação de saída para o arquivo .xlsx."

msgid "can't write to standard output"
msgstr "não é possível escrever na saída padrão (STDERR)"

msgid "CODE[:...]"
msgstr "MÃ[:…]"

msgid "[MANPATH]"
msgstr "[CAMINHO_DO_MANUSCRITO]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua aviso de erro 'giả'"

msgid "don't purge obsolete entries from the dbs"
msgstr ""
"não exclua os registros antigos da base de dados para evitar problemas com o"
" sistema."

msgid "FILENAME"
msgstr "NOM_DE_FICHIER"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de diretrizes sob %s..."

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso de erro: não há instruções para 'MANDB_MAP' no diretório '%s', "
"portanto, será utilizado o caminho do manual."

msgid "No databases created."
msgstr "Não há nenhuma base de dados criada."

msgid "warning: $MANPATH set, inserting %s"
msgstr ""
"cão de guarda: tápacho $MANPATH (diretório caminho), atualmente, está "
"inserindo %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "cão de guarda: tápacho $MANPATH (diretório caminho), %s será ignorado"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "cãonh báo: không có thư mục bắt buộc %s"

msgid "warning: %s does not begin with %s"
msgstr "cão de guarda: %s não começa a latir com %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Ao procurar por arquivos sem a pasta de trabalho do programa 'cat', "
"encontramos %s...\n"

msgid "do not trim output to terminal width"
msgstr ""
"não é permitido exportar para a largura do dispositivo final sem adaptação à"
" largura da tela"

msgid "warning: %s contains a pointer loop"
msgstr ""
"cão de guarda: %s contém um vínculo circular com o ponteiro (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: cargas .so simultâneas ou conflitantes são muito profundamente "
"aninhadas ou reiterativas\n"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr ""
"%s:%d: Aviso: linha de comando inválida em '.lf' devido a novos caracteres, "
"ignorada."

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
