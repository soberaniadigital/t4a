msgid "warning: %s: ignoring bogus filename"
msgstr "aviso : %s : nome de arquivo inválido, ignorado"

msgid "the setuid man user \"%s\" does not exist"
msgstr "não há ninguém com a capacidade de 'setuid' usada por '%s'"

msgid "Database %s corrupted; rebuild with mandb --create"
msgstr ""
"Caminho de dados %s corrompeu; execute novamente a instrução 'mandb -- "
"create'."

msgid "warning: %s is version %s, expecting %s\n"
msgstr ""
"aviso: %s tem a versão %s, e é necessário o comando de atualização para "
"obter mais informações."

msgid "[MAN DATABASE]"
msgstr "[CƠ SỞ DỮ LIỆU MAN]"

msgid "The man database defaults to %s%s."
msgstr "A base de dados padrão tem o valor por defeito como %s%s."

msgid "can't open %s for reading"
msgstr "não foi possível abrir %s para leitura"

msgid "set search path for manual pages to PATH"
msgstr ""
"configuração do caminho de pesquisa para navegar entre as páginas de ajuda "
"manual"

msgid "man command failed with exit status %d"
msgstr ""
"comando 'man' falhou ao sair do estado de escape com %d como código de saída"

msgid "can't update index cache %s"
msgstr "não foi possível atualizar o cache de memória do local %s"

msgid "can't create index cache %s"
msgstr "não foi possível criar o cache de memória para a lista %s"

msgid "Updating index cache for path `%s/%s'. Wait..."
msgstr ""
"Estamos atualizando o cache de memória para caminho `%s/%s'. Por favor, "
"espere…"

msgid "Purging old database entries in %s...\n"
msgstr "Ao tentação cargas de informações antigas na base de dados %s...\n"

msgid "look for pages case-insensitively (default)"
msgstr "não faz distinção entre maiúsculas e minúsculas ao procurar (padrão)"

msgid "look for pages case-sensitively"
msgstr "falta de consideração ao registrar durante a pesquisa"

msgid "FILE..."
msgstr "TARGET_FILE..."

msgid "parse as man page"
msgstr "analisar o layout da página de ajuda do manual man"

msgid "parse as cat page"
msgstr "fazer análise da página cat"

msgid "%s: incompatible options"
msgstr "%s: opções não compatíveis entre si"

msgid "reset all options to their default values"
msgstr "reinicie todos os valores padrão dos parâmetros selecionados"

msgid "Main modes of operation:"
msgstr "modos de operação principais:"

msgid "equivalent to whatis"
msgstr "equivalente a whatis"

msgid "used by catman to reformat out of date cat pages"
msgstr ""
"utilizado por catman para reformatar as páginas do site Cat já existentes"

msgid "Finding manual pages:"
msgstr "Em busca de guias de ajuda:"

msgid "LIST"
msgstr "DANH_SÁCH"

msgid "use %s to format pages"
msgstr "utilize %s para formatar as páginas."

msgid "use %s with selected device"
msgstr "utilize %s com o dispositivo selecionado"

msgid "RESOLUTION"
msgstr "RESOLUÇÃO DE PROBLEMAS"

msgid ""
"use groff and display through gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"
msgstr ""
"utilize o groff e exiba através do gxditview (X11):\n"
"-X = -TX75, -X100 = -TX100, -X100-12 = -TX100-12"

msgid "use groff and force it to produce ditroff"
msgstr "utilize o groff e pressione para fazê-lo gerar ditroff."

msgid "What manual page do you want?\n"
msgstr "Qual guia de ajuda você precisa?"

msgid "No manual entry for %s in section %s\n"
msgstr "Não há guia de linha para %s no subsector %s\n"

msgid "can't open temporary file %s"
msgstr "não foi possível abrir o arquivo temporário %s para trabalhar"

msgid "mandb command failed with exit status %d"
msgstr ""
"erro ao executar o comando 'mandb' (gerenciamento de dados) devido à saída "
"do estado de escape %d"

msgid "internal error: candidate type %d out of range"
msgstr ""
"erro de nível interno: o tipo do candidato %d não está dentro da faixa "
"permitida"

msgid " Manual page "
msgstr "Trang hướng dẫn"

msgid "must specify an output encoding"
msgstr "é necessário indicar a codificação de saída do arquivo"

msgid "can't write to standard output"
msgstr "não foi possível gastar no fluxo padrão de saída"

msgid "CODE[:...]"
msgstr "Código de Autorização[:...]"

msgid "[MANPATH]"
msgstr "[MAN_CAMINHO]"

msgid "work quietly, except for 'bogus' warning"
msgstr "chute im, exclua aviso 'giả'"

msgid "don't purge obsolete entries from the dbs"
msgstr "não tire informações antigas do banco de dados."

msgid "FILENAME"
msgstr "NOM_DE_ARQUIVO"

msgid "Processing manual pages under %s...\n"
msgstr "Ao processar as páginas de ajuda em %s...\n"

msgid "warning: no MANDB_MAP directives in %s, using your manpath"
msgstr ""
"aviso: não há a diretiva 'MANDB_MAP' no %s, portanto será utilizado o "
"caminho de saída do seu manpath."

msgid "No databases created."
msgstr "As bases de dados ainda não foram criadas."

msgid "warning: $MANPATH set, inserting %s"
msgstr "aviso de segurança: encontrada a variável $MANPATH, insere %s"

msgid "warning: $MANPATH set, ignoring %s"
msgstr "aviso de segurança: encontrado o caminho $MANPATH, ignorando %s"

msgid "warning: mandatory directory %s doesn't exist"
msgstr "aviso : o diretório %s não está disponível para leitura ou gravação."

msgid "warning: %s does not begin with %s"
msgstr "aviso: %s não começa com %s"

msgid "Checking for stray cats under %s...\n"
msgstr ""
"Ao verificar, ocorreu uma falha rápida na execução do comando 'cat' sob "
"%s...\n"

msgid "do not trim output to terminal width"
msgstr "não remova o xen ket xuot cho bằng biê bề rộng của thiết bị cuối."

msgid "warning: %s contains a pointer loop"
msgstr "cão de guarda: %s contém um vínculo circular (pointer loop)"

msgid "%s: nothing appropriate.\n"
msgstr "%s: não há nada adequado para você."

msgid "%s:%d: .so requests nested too deeply or are recursive"
msgstr ""
"%s:%d: các requisições .so imbriquées excessivamente profundamente ou "
"regressivamente"

msgid "%s:%d: warning: newline in .lf request, ignoring"
msgstr "%s:%d: aviso: nova linha em .lf requisição, ignorada"

msgid "compatibility switch (ignored)"
msgstr "các tùy chọn dùng cho mục đích tương thịch (bị bỏ qua)"
