msgid "syntax error: cannot back up"
msgstr ""
"erro de sintaxe : não é possível salvar o estado da estação de segurança"

msgid "syntax is ambiguous"
msgstr ""
"a sintaxe não é clara o suficiente para determinar se há ambiguidade ou não."

msgid "syntax error"
msgstr "erro de sintaxe lỗi cú pháp"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s bólida"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s inesperado, esperava-%<PRIuMAX>%s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "erro de sintaxe, %s inesperado, esperava %s ou %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr "erro de sintaxe, %s inesperado, esperava-se que fosse %s ou %s ou %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr "lỗi cú pháp, gặp %s bất thường, cần %s hoặc %s hoặc %s hay %s"

msgid "memory exhausted"
msgstr "bateria esgotada"
