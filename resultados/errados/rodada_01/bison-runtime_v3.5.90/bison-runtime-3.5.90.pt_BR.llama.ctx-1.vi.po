msgid "syntax error: cannot back up"
msgstr "erro de codificação penal: não é possível armazenar a delegacia"

msgid "syntax is ambiguous"
msgstr "o código não está claro para mim"

msgid "syntax error"
msgstr "erro de código"

msgid "syntax error, unexpected %s"
msgstr "erro de código, gostaria que você fosse %s incomum"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "lỗi cú pháp, gặp %s bất thường, cần %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "lỗi cú pháp, gặp %s bất thường, cần %s hoặc %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr ""
"erro de codificação, gostaria de %s incomum, preciso %s ou %s e/ou %s para "
"corrigir."

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr "lỗi cú pháp, gặp %s bất thường, cần %s hoặt %s hoặt %s hay %s"

msgid "memory exhausted"
msgstr ""
"bem vindo ao terminal do Linux, você pode digitar comandos para interagir "
"com o sistema."
