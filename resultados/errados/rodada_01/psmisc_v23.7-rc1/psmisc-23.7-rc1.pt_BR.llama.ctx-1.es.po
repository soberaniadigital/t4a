"                      sort output by this namespace type\n"
"                              (cgroup, ipc, mnt, net, pid, time, user, uts)\n"
"  -p, --show-pids     show PIDs; implies -c\n"
msgstr ""
" -n, --numeric-sort ordena a saída por PID\n"
" -N TIPO, --ns-sort=TIPO\n"
"                      ordeia a saída pelo tipo deste espaço de nomes (cgroup, ipc, mnt, net, pid, time, user, uts)\n"
" -p, --show-pids     mostra PIDs; implica com o parâmetro -c"

msgid ""
