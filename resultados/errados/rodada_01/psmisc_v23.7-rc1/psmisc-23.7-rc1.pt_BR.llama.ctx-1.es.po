msgid ""
"\n"
"Display a tree of processes.\n"
"\n"
msgstr "Exiba um diagrama de fluxo para os processos."

msgid ""
"  -a, --arguments     show command line arguments\n"
"  -A, --ascii         use ASCII line drawing characters\n"
"  -c, --compact-not   don't compact identical subtrees\n"
msgstr ""
"[{'option': '-a, --arguments', 'description': 'Mostra os argumentos da linha"
" de comandos'}, {'option': '-A, --ascii', 'description': 'Utiliza caracteres"
" ASCII para traçar a linha'}, {'option': '-c, --compact-not', 'description':"
" 'Não compacta subárbores idênticos no tronco do diagrama de árvore'}]"

msgid ""
"  -C, --color=TYPE    color process by attribute\n"
"                      (age)\n"
msgstr "  -C, --color=KIỂU    coloreia processo por atributo (idade)\n"

msgid ""
"  -g, --show-pgids    show process group ids; implies -c\n"
"  -G, --vt100         use VT100 line drawing characters\n"
