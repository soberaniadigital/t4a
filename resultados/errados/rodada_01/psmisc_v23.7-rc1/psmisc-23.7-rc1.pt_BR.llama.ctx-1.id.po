"                   [ -A | -G | -U ] [ PID | USER ]"

msgid ""
"\n"
"Display a tree of processes.\n"
"\n"
msgstr "Mostre o diagrama de fluxo do processo."

msgid ""
"  -a, --arguments     show command line arguments\n"
"  -A, --ascii         use ASCII line drawing characters\n"
"  -c, --compact-not   don't compact identical subtrees\n"
msgstr ""
"[{'option': '-a, --arguments', 'description': 'menampilkan argumen baris "
"perintah'}, {'option': '-A, --ascii', 'description': 'gunakan karakter "
"menggambar garis ASCII'}, {'option': '-c, --compact-not', 'description': "
"'jangan satukan sub pohon identik'}]"

msgid ""
