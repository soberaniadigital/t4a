msgid ""
"       killall -l, --list\n"
"       killall -V, --version\n"
"\n"
"  -e,--exact          require exact match for very long names\n"
"  -I,--ignore-case    case insensitive process name match\n"
"  -g,--process-group  kill process group instead of process\n"
"  -y,--younger-than   kill processes younger than TIME\n"
"  -o,--older-than     kill processes older than TIME\n"
"  -i,--interactive    ask for confirmation before killing\n"
"  -l,--list           list all known signal names\n"
"  -q,--quiet          don't print complaints\n"
"  -r,--regexp         interpret NAME as an extended regular expression\n"
"  -s,--signal SIGNAL  send this signal instead of SIGTERM\n"
"  -u,--user USER      kill only process(es) running as USER\n"
"  -v,--verbose        report if the signal was successfully sent\n"
"  -V,--version        display version information\n"
"  -w,--wait           wait for processes to die\n"
"  -n,--ns PID         match processes that belong to the same namespaces\n"
"                      as PID\n"
msgstr ""
"{'%s': '%s', '-e,--exact': '--exact', '-I,--ignore-case': {'description': "
"'ignorar maiúsculas e minúsculas na comparação de nomes, mas não em outros "
"campos.', 'translation': '--ignore-case'}, '-g,--process-group': "
"{'description': 'kill process group instead of a single one', 'translation':"
" '--process-group'}, '-y,--younger-than': {'description': 'kills processes "
"younger than the given time.', 'translation': '--older-than'}, '-l,--list': "
"{'description': 'List all known signals', 'translation': '--list'}, '-q,--"
"quiet': {'description': 'suppresses the output of messages to stderr.', "
"'translation': '--quiet'}, '-r,--regexp': {'description': 'treat input as a "
"regular expression', 'translation': '--regexp'}, '-s,--signal SIGNAL': "
"{'description': 'send the given signal instead of TERM to terminate "
"processes.', 'translation': '--signal SIGTERM'}, '-u,--user UTILISATEUR': "
"{'description': 'kill only those owned by user', 'translation': '--user "
"USERNAME'}, '-V,--version': {'description': 'display version information and"
" exit.', 'translation': '--version'}, '-w,--wait': {'description': 'Wait for"
" processes to terminate before killing', 'translation': '--wait'}, '-n,--ns "
"PID': {'description': 'kill only the process with a name matching this "
"string.', 'translation': '--pid-name NG_DÙNG'}}"

