msgstr "Privilégio de cópia (C) Trent Waddington, 2007."

msgid ""
"Usage: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <pid> [<fd> ..]\n"
"    -8, --eight-bit-clean        output 8 bit clean streams.\n"
"    -n, --no-headers             don't display read/write from fd headers.\n"
"    -c, --follow                 peek at any new child processes too.\n"
"    -t, --tgid                   peek at all threads where tgid equals <pid>.\n"
"    -d, --duplicates-removed     remove duplicate read/writes from the output.\n"
"    -V, --version                prints version info.\n"
"    -h, --help                   prints this help.\n"
"\n"
"  Press CTRL-C to end output.\n"
msgstr ""
"CÓDIGO DE ACESSO: peekfd [-8] [-n] [-c] [-d] [-V] [-h] <PID> [<fd> ..] \n"
"    -8, --eight-bit-clean       xuất luồng dữ liệu 8 bít. \n"
"    -n, --no-headers           Header para leitura/escrita de fds não mostrar. \n"
"    -c, --follow               Tìm hiếu các tiến trình mới xem nên. \n"
"    -t, --tgid                 Xem tất cả các tiến trình chỗ thể tựa <PID>. \n"
"    -d, --duplicates-removed   Gỡ bỏ đọc/viết lặp ra khỏi kết xuất. \n"
"    -V, --version              Hiển thị thông tin về phiên bản. \n"
"    -h, --help                 Tiếp tục hiển thuyết này."

