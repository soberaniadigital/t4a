msgstr "-f <arquivo>"

msgid "--rcfile=<file>"
msgstr "--rcfile=<arquivo>"

msgid "Use only this file for configuring nano"
msgstr "Utilizar exclusivamente este arquivo para configurar o nano."

msgid "Show cursor in file browser & help text"
msgstr "Mostrar o cursor e texto de ajuda no gerenciador de arquivos"

msgid "Show this help text and exit"
msgstr "Exibir este texto e sair."

msgid "Automatically indent new lines"
msgstr "Autoespaçamento em novas linhas automático"

msgid "Scroll per half-screen, not per line"
msgstr "Deslize por meio do ecrã, não linha a linha"

msgid "Cut from cursor to end of line"
msgstr "cortar desde o cursor até o final da linha"

msgid "Show line numbers in front of the text"
msgstr "Mostrar os números das linhas antes do texto"

msgid "Enable the use of the mouse"
msgstr "Permissão concedida para o uso da mouse."

msgid "Do not read the file (only write it)"
msgstr "Não ler o arquivo (só escrever nele)"

