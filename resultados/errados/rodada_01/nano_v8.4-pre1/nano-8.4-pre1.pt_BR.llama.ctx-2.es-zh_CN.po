msgstr "Definir o diretório de trabalho"

msgid "Preserve XON (^Q) and XOFF (^S) keys"
msgstr "Reservado as teclas XON (^Q) e XOFF (^S)"

msgid "Show a position+portion indicator"
msgstr "Mostrar indicador de posição+troco"

msgid "-r <number>"
msgstr "-r <число>"

msgid "--fill=<number>"
msgstr "--fill=<число>"

msgid "Set width for hard-wrap and justify"
msgstr "Defina a largura para o alinhamento rígido e reordenação de linhas."

msgid "-s <program>"
msgstr "-s <programa>"

msgid "--speller=<program>"
msgstr "--speller=<programa>"

msgid "Use this alternative spell checker"
msgstr "Utilizar esta alternativa de verificação ortográfica"

msgid "Save changes on exit, don't prompt"
msgstr "Não solicitar para salvar as alterações ao sair."

msgid "Save a file by default in Unix format"
msgstr "Por padrão, salvar o arquivo no formato Unix."

msgid "View mode (read-only)"
msgstr "Modo de visualização (apenas leitura)"

msgid "Don't hard-wrap long lines [default]"
msgstr ""
"Não fornecer aqui, pois não é possível traduzir para o idioma desejado."

msgid "Don't show the two help lines"
msgstr "Não mostrar as duas linhas de ajuda abaixo."

msgid "Make Ctrl+Right stop at word ends"
msgstr ""
"Parar ao final das palavras enquanto mantém o Ctrl pressionado e clica para "
"direita."

msgid "List the names of available syntaxes"
msgstr "Enumerar os nomes de sintaxe disponíveis."

msgid "Also try magic to determine syntax"
msgstr "Utilizar magia para determinar sintaxe."

msgid "Accept 'filename:linenumber' notation"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Show some states on the title bar"
msgstr "Mostrar alguns estados na barra do título"

msgid "Show a feedback bar at the bottom"
msgstr "Exibir a linha de feedback neste coluna."

