msgstr "Definir a largura da tabulação para o número de linhas especificado."

msgid "Wipe status bar upon next keystroke"
msgstr "Após o clique, limpe a linha de estado."

msgid "Print version information and exit"
msgstr "Exibir versão e sair."

msgid "Detect word boundaries more accurately"
msgstr "Determinar limites de palavras com maior precisão"

