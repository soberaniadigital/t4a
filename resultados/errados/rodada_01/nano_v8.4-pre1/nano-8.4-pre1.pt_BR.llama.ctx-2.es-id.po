msgid "When soft-wrapping, do it at whitespace"
msgstr "Fazer o ajuste de linha suave apenas em espaços em branco."

msgid "Automatically hard-wrap overlong lines"
msgstr "ajuste estrito de linhas muito longas"

msgid "Constantly show cursor position"
msgstr "Mostrar a posição do cursor constantemente"

msgid "Fix Backspace/Delete confusion problem"
msgstr "Resolver a questão do Retroceso/Supressão"

msgid "Keep the line below the title bar empty"
msgstr "Não ocupue a linha abaixo do cabeçalho da tabela."

