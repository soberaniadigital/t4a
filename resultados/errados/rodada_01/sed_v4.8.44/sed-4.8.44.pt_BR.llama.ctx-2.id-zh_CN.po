msgid ""
"Usage: %s [OPTION]... {script-only-if-no-other-script} [input-file]...\n"
"\n"
msgstr ""
"Utilização: %s [OPÇÕES]... {Script (Se não houver outro script)} [Ficheiro "
"de Entrada]...\n"

msgid ""
"  -n, --quiet, --silent\n"
"                 suppress automatic printing of pattern space\n"
msgstr ""
" -n --quiet, --silent\n"
"supomover o modo de impressão automática do espaço dos padrões."

msgid ""
"      --debug\n"
"                 annotate program execution\n"
msgstr ""
"      --debug\n"
"                 anotar a execução do programa"

msgid ""
"  -e script, --expression=script\n"
"                 add the script to the commands to be executed\n"
msgstr ""
"  -e script, --expression=script\n"
"                 adicionar o script à lista de comandos para serem executados."

msgid ""
"  -f script-file, --file=script-file\n"
"                 add the contents of script-file to the commands to be executed\n"
msgstr ""
"  -f fichier-script, --file=fichier-script\n"
"                 adicionar o conteúdo de fichier-script às listas de comandos a serem executadas."

msgid ""
"  --follow-symlinks\n"
"                 follow symlinks when processing in place\n"
msgstr ""
"--follow-symlinks\n"
"                 Seguir sinais simbólicos durante o processamento."

msgid ""
"  -i[SUFFIX], --in-place[=SUFFIX]\n"
"                 edit files in place (makes backup if SUFFIX supplied)\n"
msgstr ""
" -i[SUFFIXE], --in-place[=SUFFIXE] \n"
"      Editar os arquivos em seu lugar (faz uma cópia de segurança se o SUFFIXE for fornecido) \n"

msgid ""
"  -b, --binary\n"
"                 open files in binary mode (CR+LFs are not processed specially)\n"
msgstr ""
"  -b, --binary\n"
"                 abrir os arquivos no modo binário (CR+LF não são processados especialmente)"

msgid ""
"  -l N, --line-length=N\n"
"                 specify the desired line-wrap length for the `l' command\n"
msgstr ""
"  -l N, --line-length=N\n"
"                especificar a extensão da quebra de linha desejada para o comando 'l'\n"

msgid ""
"  --posix\n"
"                 disable all GNU extensions.\n"
msgstr ""
"ZH_CN\n"
"--posix\n"
"关闭所有 GNU 扩展"

msgid ""
"  -E, -r, --regexp-extended\n"
"                 use extended regular expressions in the script\n"
"                 (for portability use POSIX -E).\n"
msgstr ""
"ZH_CN\n"
"  -E, -r, --regexp-extended\n"
"                 Utilize a sintaxe de expressões regulares estendidas no script.\n"
"                 (use -E para portabilidade)."

msgid ""
"  -s, --separate\n"
"                 consider files as separate rather than as a single,\n"
"                 continuous long stream.\n"
msgstr ""
"considere os arquivos como separados, em vez de um único fluxo contínuo."

msgid ""
"      --sandbox\n"
"                 operate in sandbox mode (disable e/r/w commands).\n"
msgstr ""
"      --sandbox\n"
"                 opera em modo sandbox (desabilita as comandas e/r/w).\n"

msgid ""
"  -u, --unbuffered\n"
"                 load minimal amounts of data from the input files and flush\n"
"                 the output buffers more often\n"
msgstr ""
" -u, --unbuffered\n"
"                 carregar quantidades mínimas de dados dos arquivos de entrada e escrever os buffers de saída com mais frequência no disco."

msgid ""
"  -z, --null-data\n"
"                 separate lines by NUL characters\n"
msgstr ""
"--null-data\n"
"                 separar linhas com caractere NUL"

msgid "      --help     display this help and exit\n"
msgstr "Tente `%s --help' para mais informações.\n"

msgid "      --version  output version information and exit\n"
msgstr "      --version   exibe as informações de versão do software e sai\n"

msgid ""
"\n"
"If no -e, --expression, -f, or --file option is given, then the first\n"
"non-option argument is taken as the sed script to interpret.  All\n"
"remaining arguments are names of input files; if no input files are\n"
"specified, then the standard input is read.\n"
"\n"
msgstr ""
"Se nenhuma das opções -e, --expression, -f ou --file fornecer um argumento, "
"o primeiro que não é uma opção será considerado como o script sed a ser "
"interpretado. Todos os outros argumentos restantes são nomes de arquivos de "
"entrada; caso nenhum seja especificado, a entrada padrão será lida."

