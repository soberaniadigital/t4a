msgid "%s: option '%s%s' doesn't allow an argument\n"
msgstr "%s: para o parâmetro '\\%s%s' não pode haver argumento"

msgid "%s: option '%s%s' requires an argument\n"
msgstr "%s: para o parâmetro '\\%s%s' é necessário um argumento."

msgid "%s: invalid option -- '%c'\n"
msgstr "%s: opção inválida — «%c»"

msgid "%s: option requires an argument -- '%c'\n"
msgstr "%s: para o parâmetro é necessário argumento — «%c»"

msgid "cannot remove %s: %s"
msgstr "não foi possível excluir %s: %s"

msgid "cannot stat %s: %s"
msgstr "não foi possível obter estado (stat) do arquivo %s: %s"

msgid "%s home page: <https://www.gnu.org/software/%s/>\n"
msgstr "Página inicial de %s: <https://www.gnu.org/software/%s/>"

msgid ""
"  -R, --regexp-perl\n"
"                 use Perl 5's regular expressions syntax in the script.\n"
msgstr ""
"  -R, --regexp-perl\n"
"                 utilizar o sintaxe das expressões regulares de Perl 5 no script."

msgid "%s: option '--%s' doesn't allow an argument\n"
msgstr "%s: a opção \"%s\" não permite argumento\n"

msgid "%s: unrecognized option '--%s'\n"
msgstr "%s: opção não reconhecida '--%s'"

msgid "%s: option '-W %s' is ambiguous\n"
msgstr "%s: a opção «-W %s» é ambígua"

msgid "%s: option '-W %s' doesn't allow an argument\n"
msgstr "%s: a opção «-W %s» não permite argumento\n"

msgid "%s: option '-W %s' requires an argument\n"
msgstr "%s: para o parâmetro «-W %s» é necessário um argumento"

msgid "cannot specify modifiers on empty regexp"
msgstr ""
"impossível de especificar modificadores em uma expressão matemática vazia"

