msgstr "múltiplas opções `g` associadas à comando `s`"

msgid "multiple number options to `s' command"
msgstr "múltiplas opções numéricas associadas à comando `s`"

msgid "number option to `s' command may not be zero"
msgstr "o modificador numérico da opção para a comando `s` não pode ser nulo"

