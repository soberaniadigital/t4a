msgstr ""
"%s: aviso: não foi possível alterar o contexto de criação do arquivo padrão "
"para %s: %s"

msgid "%s: warning: failed to get security context of %s: %s"
msgstr ""
"%s: aviso de segurança: não foi possível obter o contexto de segurança %s: "
"%s"

