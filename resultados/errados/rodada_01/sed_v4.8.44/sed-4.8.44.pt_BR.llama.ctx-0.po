msgid ""
"  -R, --regexp-perl\n"
"                 use Perl 5's regular expressions syntax in the script.\n"
msgstr "utilize a sintaxe das expressões regulares do Perl 5 no script."

msgid "%s: option '--%s' doesn't allow an argument\n"
msgstr "%s: a opção « --%s » não permite argumento\n"

msgid "%s: unrecognized option '--%s'\n"
