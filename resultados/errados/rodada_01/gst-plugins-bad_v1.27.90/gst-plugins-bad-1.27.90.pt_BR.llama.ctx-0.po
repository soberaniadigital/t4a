msgid "Could not get settings from frontend device \"%s\"."
msgstr "Não foi possível obter o estado (stat) do arquivo %s."

msgid "Cannot enumerate delivery systems from frontend device \"%s\"."
msgstr ""
"Não foi possível enumerar os sistemas de comunicação a partir do dispositivo"
" terminal \"%s\"."

msgid "Could not open file \"%s\" for reading."
msgstr "Não foi possível abrir o arquivo \"%s\" para leitura."

msgid "Couldn't find channel configuration file"
msgstr "não foi possível encontrar o arquivo de configuração do canal"

msgid "Couldn't load channel configuration file: '%s'"
msgstr "Não foi possível carregar o arquivo de configuração do canal : “%s”"

msgid "Couldn't find details for channel '%s'"
msgstr "não foi possível obter informações detalhadas do canal \"%s\""

msgid "No properties for channel '%s'"
msgstr "o canal `%s' não possui atributos"

msgid "Failed to set properties for channel '%s'"
msgstr "não foi possível configurar o atributo do canal \"%s\""

msgid "Couldn't find channel configuration file: '%s'"
msgstr "não foi possível encontrar o arquivo de configuração do canal : \"%s\""

msgid "Channel configuration file doesn't contain any channels"
msgstr "No canal é especificado no arquivo de configuração do canal."

msgid "failed to draw pattern"
msgstr "não foi possível desenhar o gráfico"

msgid "A GL error occured"
msgstr "ocorreu um erro GL (Graphics Library)"

msgid "format wasn't negotiated before get function"
msgstr ""
"Antes de chamar a função get, o formato adequado ainda não foi determinado."

