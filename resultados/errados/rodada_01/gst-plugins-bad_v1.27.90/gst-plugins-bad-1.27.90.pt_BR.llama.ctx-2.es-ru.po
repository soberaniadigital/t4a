msgid "OpenCV failed to load template image"
msgstr "falha ao carregar modelo de imagem com OpenCV"

msgid "Could not read title information for DVD."
msgstr "não foi possível obter a informação do título para o DVD."

msgid "Failed to open DVD device '%s'."
msgstr "Não foi possível abrir o dispositivo de DVD \"%s\"."

msgid "Failed to set PGC based seeking."
msgstr "Não foi possível configurar a pesquisa baseada no PGC."

msgid ""
"Could not read DVD. This may be because the DVD is encrypted and a DVD "
"decryption library is not installed."
msgstr ""
"Não foi possível ler o DVD. Isso pode acontecer porque o DVD está "
"criptografado e a biblioteca necessária para decodificá-lo não foi "
"instalada."

msgid "Could not read DVD."
msgstr "não foi possível obter estado (stat) do arquivo DVD."

msgid "This file contains no playable streams."
msgstr "Este arquivo contém fluxos que não podem ser reproduzidos."

msgid "Could not open sndfile stream for reading."
msgstr "não foi possível abrir e ler o fluxo sndfile."

msgid "Generated file has a larger preroll time than its streams duration"
msgstr ""
"O preenrollamento do arquivo gerado ultrapassa a duração de seus fluxos."

msgid "Missing element '%s' - check your GStreamer installation."
msgstr ""
"Falta o componente \"%s\" - por favor, verifique a instalação do GStreamer."

msgid "File location is set to NULL, please set it to a valid filename"
msgstr ""
"O local do arquivo é NULL, por favor defina um nome de arquivo válido."

msgid "Digitalzoom element couldn't be created"
msgstr "não foi possível criar o componente Digitalzoom"

msgid "Subpicture format was not configured before data flow"
msgstr ""
"O formato do painel de crianças não foi configurado antes da configuração "
"dos dados fluindo."

msgid "Failed to get fragment URL."
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Couldn't download fragments"
msgstr "falha na conexão com o servidor"

msgid "Internal data stream error."
msgstr "Erro interno de fluxo de dados."

