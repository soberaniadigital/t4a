msgstr "Não foi possível configurar o local de pesquisa baseado em PGC."

msgid ""
"Could not read DVD. This may be because the DVD is encrypted and a DVD "
"decryption library is not installed."
msgstr ""
"Não foi possível ler o DVD. Isso pode ser devido ao fato de que o DVD está "
"criptografado e não há a instalação do software necessário para "
"descriptografá-lo."

msgid "Could not read DVD."
msgstr "Não foi possível ler o DVD."

msgid "This file contains no playable streams."
msgstr "Este arquivo contém um fluxo que não pode ser reproduzido."

msgid "Could not open sndfile stream for reading."
msgstr "Não foi possível abrir e ler o fluxo sndfile."

msgid "Generated file has a larger preroll time than its streams duration"
msgstr ""
"Anexo de previsão do arquivo gerado ultrapassa o seu próprio comprimento da "
"fonte."

msgid "Missing element '%s' - check your GStreamer installation."
msgstr ""
"Falta do componente \"%s\" - Por favor, verifique a instalação de GStreamer."

msgid "File location is set to NULL, please set it to a valid filename"
msgstr ""
"O local do arquivo é NULL, por favor, defina um nome de arquivo válido."

msgid "Digitalzoom element couldn't be created"
msgstr "não foi possível criar o componente Digitalzoom"

msgid "Subpicture format was not configured before data flow"
msgstr ""
"O formato de tela infantil não foi configurado antes do fluxo de dados."

msgid "Failed to get fragment URL."
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "Couldn't download fragments"
