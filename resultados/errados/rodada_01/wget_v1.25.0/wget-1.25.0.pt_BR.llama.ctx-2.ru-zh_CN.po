msgstr "%s: parâmetro inválido — «-n%c»"

msgid "Debugging support not compiled in. Ignoring --debug flag.\n"
msgstr "Assembled without debugging support. The --debug flag is ignored."

msgid ""
"Both --no-clobber and --convert-links were specified, only --convert-links "
"will be used.\n"
msgstr ""
"São indicados imediatamente --no-clobber e --convert-links, mas será "
"utilizado apenas o --convert-links."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"São indicados imediatamente --no-clobber e --convert-file-only, será "
"utilizado apenas o último."

msgid "Can't be verbose and quiet at the same time.\n"
msgstr "Não é possível usar simultaneamente os modos verboso e silencioso."

msgid "Can't timestamp and not clobber old files at the same time.\n"
msgstr ""
"Não é possível utilizar simultaneamente marcadores de tempo e não excluir "
"arquivos antigos."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar simultaneamente --inet4-only e --inet6-only."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é permitido especificar simultaneamente -k ou --convert-file-only e -O, "
"se URLs forem indicadas em quantidade. Além disso, essas opções não podem "
"ser usadas juntamente com as opções -p ou -r."

msgid ""
"WARNING: combining -O with -r or -p will mean that all downloaded content\n"
"will be placed in the single file you specified.\n"
"\n"
msgstr ""
"PRELUDE: combinação do parâmetro -O com o parâmetro -r ou -p indica que "
"todos os dados carregados serão armazenados em um único arquivo. \n"

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"AVISO: trabalhar com marcações de tempo não é possível se o parâmetro -O for"
" especificado. Para mais informações, consulte a documentação."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"O output do WARC não funciona com o parâmetro --no-clobber, esse parâmetro "
"será desabilitado."

msgid ""
"WARC output does not work with timestamping, timestamping will be "
"disabled.\n"
msgstr ""
"O output do WARC não funciona com marcas de tempo, as marcações de tempo "
"serão desligadas."

msgid "WARC output does not work with --spider.\n"
msgstr "O output do WARC não funciona com --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O output do WARC não funciona com --continue ou --start-pos; eles serão "
"desabilitados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório de desligamento; a duplicação WARC não encontrará registros "
"repetidos."

msgid ""
"Compression does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O compressão não funciona com --continue ou --start-pos; eles serão "
"desligados."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente --ask-password e --password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"AVISO: não foi especificado o nome de usuário, mas houve a solicitação "
"--ask-password. Isso geralmente não é necessário."

msgid ""
"Specifying both --start-pos and --continue is not recommended; --continue "
"will be disabled.\n"
msgstr ""
"Não é recomendado especificar simultaneamente --start-pos e --continue; o "
"último será desligado."

msgid "%s: missing URL\n"
msgstr "%s: URL ausente"

msgid "You cannot specify both --post-data and --post-file.\n"
msgstr ""
"Não é permitido especificar --post-data e --post-file simultaneamente."

msgid ""
"You cannot use --post-data or --post-file along with --method. --method "
"expects data through --body-data and --body-file options\n"
msgstr ""
"Não é permitido o uso simultâneo de --post-data ou --post-file com o "
"parâmetro --method. O parâmetro --method pressupõe dados nos parâmetros "
"--body-data e --body-file."

msgid ""
"You must specify a method through --method=HTTPMethod to use with --body-"
"data or --body-file.\n"
msgstr ""
"Para utilizar o --body-data ou o --body-file, é necessário especificar o "
"método de transferência através do parâmetro --method=HTTPMethod."

msgid "You cannot specify both --body-data and --body-file.\n"
msgstr ""
"Não é permitido especificar --body-data e --body-file simultaneamente."

msgid "This version does not have support for IRIs\n"
msgstr "Esta versão não suporta IRI."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"Parâmetro -k ou -r pode ser utilizado somente em conjunto com -O, se o "
"output for produzido para um arquivo normal."

msgid ""
"--convert-links or --convert-file-only can be used together only if "
"outputting to a regular file.\n"
msgstr ""
"Parâmetro --convert-links ou --convert-file-only podem ser usados juntos "
"apenas, se o resultado for produzido em um arquivo normal. \n"

