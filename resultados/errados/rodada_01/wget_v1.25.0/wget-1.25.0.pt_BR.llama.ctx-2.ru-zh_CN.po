msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Falha no expresso%c; use '%<PRIuMAX>'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: Incorrecto; use 'on', 'off' ou 'quiet'."

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. Por favor, verifique novamente."

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor incorreto do byte %s"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Invalido intervalo de tempo %s"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Diâmetro de tempo negativo %s"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso do askpass é necessário uma string ou a variável de ambiente "
"WGET_ASKPASS ou SSH_ASKPASS."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor inválido de %s. Por favor, verifique novamente."

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: Título inválido %s. \n"

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr ""
"%s: %s: O nome do arquivo WARC %s é inválido. Por favor, verifique "
"novamente."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr "%s: %s: Tipo de progresso inválido %s. \n"

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição inválida %s, utilize "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "Codificação %s inválida"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O processo de conversão do %s para o %s não é suportado."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes inválida ou incompleta."

msgid "Unhandled errno %d\n"
msgstr "Código de erro não tratado %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: localidade não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr ""
"Erro ao converter para o caso inferior:\n"
"%d:%s\n"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; registro de log desabilitado."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL]...\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para parâmetros longos e curtos são os mesmos."

msgid "Startup:\n"
msgstr "Iniciar o processo:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version           Mostrar versão do Wget e encerrar a operação\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help              mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o lançamento do aplicativo, entre no modo de"
" fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr "  -e, --execute=%s   executar a comando no estilo de ‘.wgetrc’\n"

msgid "Logging and input file:\n"
msgstr "Jornalização e arquivo de entrada:"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o, --output-file=FILE    salvar mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr "  -a,  --append-output=%s  adicionar mensagens ao final do arquivo %s\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr "  -d,  --debug               mostre muitas informações de depuração"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "  -q,  --quiet               nenhum dado será exibido"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
"  -v,  --verbose             mostrar informações detalhadas (por padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose          отключить вывод подробных сведений (не "
"полностью)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"   --input-metalink=FILE     baixar arquivos, listados no localizado FILE de"
" Metalink\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL            considerar que as URLs do arquivo de entrada "
"(-i -F) são relativas à URL especificada\n"

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=FILE         definir arquivo de configuração\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config           não ler arquivos de configuração"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registrosar causas do rejeitamento de URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             configurar ЧИСЛО tentativas adicionais\n"
"                                 (0 without limit)\n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused       повтори, mesmo que o conexão tenha sido "
"negada\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error     considere erros de host como não críticos e"
" aleatórios."

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS     lista (através de vírgula) erros "
"HTTP,                      causando recomeço\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    salvar documentos no FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              ignorar a carga de arquivos que levariam à sobregravação dos arquivos existentes\n"
"                                 (e suas recriações)"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr "--no-netrc                   não tenta obter dados do .netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                continue a leitura parcialmente carregada "
"do arquivo\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=SEMANO      iniciar a carregamento do arquivo no SEMANO "
"(começando de zero)\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIP            selecionar tipo de indicador de progresso\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress           mostrar o indicador de progresso em "
"qualquer modo detalhado\n"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N, --timestamping            não carregar novamente arquivos que já foram"
" carregados se eles forem mais antigos do que os locais\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"--no-use-server-timestamps    não utilizar a verificação if-modified-since "
"para solicitações no modo de leitura das marcas de tempo do servidor\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--no-use-server-timestamps     não usar o timestamp obtido do servidor para "
"marcar localmente\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         resposta do servidor\n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                     não carregar nenhum arquivo"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=%<PRIuMAX>           configuração de todos os timeouts para"
" o mesmo número de segundos\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSA        lista de servidores DNS solicitados\n"
"                                 (separado por vírgula)"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE  associar o resolver DNS à ADRESSE local "
"(nome do computador ou endereço IP) \n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEC         configuração de tempo limite para busca no "
"DNS em segundos (SEC)"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"--conexao-timeout=СЕК     configuração do tempo limite de conexão em СЕК\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"--read-timeout=СЕК        estabelecimento de tempo limite para leitura em "
"СЕК\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDOS            pausa de segundos entre as chamadas para "
"carregar (apenas se houver mais de uma URL) \n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS       espera de segundos entre tentativas "
"sucessivas para carregar (para mais de um URL) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --random-wait             pausa de 0.5*WAIT...1.5*WAIT segundos entre"
" as carregamentos (quando forem mais do que um URL)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                explicitamente desligue o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓDIGO             definir a quantidade de quota em CÓDIGO"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADDR      vincular ADDR (nome do computador ou "
"endereço IP) local\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr "       --limit-rate=СКОРОСТЬ     ограничить СКОРОСТЬ загрузки\n"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "       --no-dns-cache            desligue o cache de DNS-pedidos"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS  utilizar em nomes de arquivos caracteres, \n"
"                                 aceitos pela OS\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"--ignorar-case             ignorar maiúsculas e minúsculas ao comparar "
"arquivos/pastas\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "--inet4-only              conectar apenas a endereços IPv4\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--ipv6 somente              conectar apenas a endereços IPv6\n"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMESSATIVO conectar-se primeiro aos endereços do "
"família especificado (pode ser IPv6, IPv4 ou nada) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr ""
"       --user=USUÁRIO        definir e ftp- e http-usuários no usuário\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr ""
"       --password=<PASSWORD>         definir ftp e http password para "
"<PASSWORD> \n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password            solicitar senha"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=COMMAND     especificar o gerenciador de mandaços para "
"solicitar nome do usuário e senha. Se a COMMAND não for especificada, será "
"utilizado a variável ambiente WGET_ASKPASS  ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                  desligue a suporte IRI\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como codificação local para "
"IRI\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como codificação remota "
"padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                     apagar arquivo antes de desmontar"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash            deixar arquivos com hashes inválidos "
"(adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=NOME    ordem do NOME metaurl\n"
"                 Metalink application/metalink4+xml\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar dados metadados Metalink a partir "
"do cabeçalho de resposta HTTP\n"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location      localização preferida dos recursos "
"Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                   habilitar o armazenamento de dados "
"metadados em arquivos com extensões adicionais\n"

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories           não criar pastas\n"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        forçadamente criar pastas\n"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr ""
" -nH, --no-host-directories      não cria diretórios no host como em um nó\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories     utilizar o nome do protocolo em pastas\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "  -P,  --directory-prefix=ПРЕФИКС salvar arquivos no ПРЕФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО componentes do catálogo "
"remoto\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr ""
"       --http-user=ПОЛЬЗОВ.    estabelecer usuário http no usuário POЛЬЗОВ"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr ""
"       --http-password=PAROL\n"
"        definir http-senha em PAROL\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"--no-cache              ignorar dados armazenados em cache no servidor."

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=NAME      alterar o nome da página por defeito "
"(geralmente é \"index.html\")\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E, --adjust-extension      salvar documentos HTML/CSS com extensões "
"apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"--ignorar-tamanho         ignorar o campo de cabeçalho 'Content-Length'"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=STRINGA         inserir STRINGA entre cabeçalhos\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TIPO       tipo de compressão: auto, gzip ou none\n"
"                               (por padrão: none)"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          máximo permitido de redirecionamentos para a "
"página\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USUÁRIO.   utilizar USUÁRIO como nome de usuário para "
"proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLHA   utilizar PAROLHA como a senha para o "
"proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           incluir no cabeçalho HTTP do pedido de linha "
"%s\n"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U, --user-agent=AGENT      identificar como AGENT em vez de "
"Wget/VERDADEIRO."

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive    desligue o suporte HTTP keep-alive (conexões "
"persistentes) \n"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies            não utilizar cookies."

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies a partir do FILE antes de "
"iniciar o sessão."

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"--keep-session-cookies  carregar e salvar cookies de sessão (não "
"permanentes)"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=СТРОКА      utilizar método POST; envio de STRING como "
"dados"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILE\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod     utilizar método \"HTTPMethod\" no cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      enviar STRING como dados; \n"
"                               DEVEM ser especificados o parâmetro --method"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envio do conteúdo FILE; \n"
"                               DEVEM ser especificados parâmetros de método."

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   considerar o cabeçalho Content-Disposition ao"
" escolher nomes para arquivos locais (experimental)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"--content-on-error      exibir dados aceitos em caso de erro do servidor\n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"       --auth-no-challenge     enviar informações de autenticação sem esperar pelo primeiro resposta do servidor\n"
"                               Basic HTTP não está aguardando o primeiro retorno do servidor"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR     escolha do protocolo de segurança: auto, "
"SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr "--https-only             apenas por meio de links seguros HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr "--no-check-certificate   não verificar certificado do servidor"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       arquivo de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=TIPO   tipo de certificado do usuário: PEM ou DER."

msgid "       --private-key=FILE          private key file\n"
msgstr "       --private-key=FILE       arquivo de chave privada."

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr "       --private-key-type=TIPO   tipo de chave privada: PEM ou DER."

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr ""
"       --ca-certificate=FILE    arquivo com um conjunto de certificados CA\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=CAT\n"
"        diretório, no qual é armazenado o listagem dos certificados CA."

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          arquivo com um conjunto de CRL\n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES   Arquivo com chave pública (PEM/DER) ou "
"qualquer número de hashes sha256 em formato base64, começando por 'sha256//'"
" e separados por ';', que é usado para verificar o nó resposta"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE        arquivo com dados aleatórios para GERANCIA "
"DE NUMÉRICOS PSEUDÓGRAFADOS (PRNG) SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo o soquete EGD com dados "
"aleatórios."

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=СТРОКА         designar a prioridade da string (GnuTLS) ou "
"lista de chaves (OpenSSL) diretamente. Use com cautela. Este parâmetro "
"substitui o valor do protocolo seguro."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--no-hsts               desligar HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"--hsts-file             caminho para a base de dados HSTS (substitui o valor"
" padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"arquivos binários FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr "       --ftp-user=USUÁRIO ftp instalar usuário em USUÁRIO\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=ПАРОЛЬ   estabelecer ftp-senha em ПАРОЛЬ\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "--no-remove-listing     não remova listagens de arquivo '*.listing'"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"--no-glob                    desligue as macros para nomes de arquivos FTP"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp        desligue o modo \"paciente\" de transferência"
" FTP"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"--preserve-permissions       conservando permissões de arquivos remotos\n"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         при рекурсивному доступу загрузить файлы по "
"ссылкам (не каталоги)\n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"      --ftps-implicit                    utilizar FTPS (porto padrão — 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               reiniciar sessão SSL/TLS, iniciado no"
" canal de gerenciamento, ao abrir o canal de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"--ftps-clear-data-connection    criptografar apenas o canal de controle; "
"dados transmitidos em texto simples\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"       --ftps-fallback-to-ftp          volte para FTP, se o FTPS não for "
"suportado pelo servidor\n"

msgid "WARC options:\n"
msgstr "Parâmetros WARC:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILE          salvar dados de solicitação/resposta em "
"arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr "       --warc-header=STRING      inserir STRING na regra warcinfo\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=ЧИСЛО     максимального размеу файлу WARC равен ЧИСЛУ"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                salvar arquivos indexados CDX\n"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILE         não salvar registros, listados no arquivo "
"CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr ""
"       --no-warc-compression     não utilizar compressão GZIP nos arquivos "
"WARC\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "--no-warc-digests         não calcula digestas SHA1"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr ""
"--no-warc-keep-log        não salvar o arquivo de log nas gravações WARC."

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=CATALOG    localização para arquivos temporários, "
"criados pela procedimento de gravação WARC\n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive          incluir recursão na carregamento\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr ""
"  -l,  --level=ЧИСЛО        profundidade de recursividade (inf e 0 — "
"infinito) \n"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr "--delete-after       apagar arquivos locais após a carregamento\n"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
"  -k,  --converter-links      converte links para locais no HTML ou CSS "
"carregado\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr ""
"       --convert-file-only  converter apenas a parte de arquivo da URL (base"
" do nome) \n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                 ante a escrita do arquivo X, fazer backup em N "
"cópias\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X fazer uma cópia "
"de segurança no formato X_orig\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X fazer uma cópia "
"de backup no formato X.orig\n"

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"  -m,  --mirror             короткий параметр, эквивалентен: \n"
"                            -N -r -l inf --no-remove-listing\n"

msgid ""
"  -p,  --page-requisites           get all images, etc. needed to display "
"HTML page\n"
msgstr ""
"  -p,  --page-requisites    carregar todas as imagens e outros elementos "
"necessários para exibir a página HTML."

msgid ""
"       --strict-comments           turn on strict (SGML) handling of HTML "
"comments\n"
msgstr ""
"       --strict-comments    habilitar tratamento estrito (SGML) de "
"comentários HTML\n"

msgid "Recursive accept/reject:\n"
msgstr ""
"Restrições/Permissões de recursão: \n"
"\"%s\": \"%d\"; \"%<PRIuMAX>\" campos; \"%c\" opção inválida."

