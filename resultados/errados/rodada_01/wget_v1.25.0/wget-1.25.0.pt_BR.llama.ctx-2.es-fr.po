msgstr ""
"%s: O certificado assinado por %s não foi emitido pela Autoridade "
"Certificadora (CA).\n"

msgid "%s: The certificate of %s was signed using an insecure algorithm.\n"
msgstr ""
"%s: Para assinar o certificado %s foi utilizado um algoritmo não seguro. Por"
" favor, use um método de criptografia mais robusto."

msgid "%s: The certificate of %s is not yet activated.\n"
msgstr ""
"%s: o certificado %s ainda não está ativado. (Certificação de %s ainda não "
"foi ativada.)"

