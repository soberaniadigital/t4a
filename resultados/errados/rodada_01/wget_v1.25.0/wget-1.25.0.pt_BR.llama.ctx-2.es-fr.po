"  -A,  --accept=LIST               comma-separated list of accepted "
"extensions\n"
msgstr ""
"  -A,  --accept=LISTE              lista de extensões aceitas, separadas por"
" vírgula\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LISTA              lista de extensões rejeitadas, separadas "
"por vírgulas\n"

msgid "       --accept-regex=REGEX        regex matching accepted URLs\n"
msgstr ""
"       --accept-regex=РЕГВЫР       expressão regular correspondente às URLs "
"aceitas\n"

msgid "       --reject-regex=REGEX        regex matching rejected URLs\n"
msgstr ""
"       --reject-regex=РЕГВЫР       expressão regular correspondente às URLs "
"rejeitadas\n"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr ""
"       --regex-type=ТИП            тип регулярного выражения (posix|pcre) \n"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr "       --regex-type=ТИП            тип регулярного выражения (posix)"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr ""
"  -D,  --domains=LISTA             domínios aceitos, separados por vírgula\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr ""
"       --exclude-domains=LISTA     domínios rejeitados, separados por "
"vírgulas\n"

msgid ""
"       --follow-ftp                follow FTP links from HTML documents\n"
msgstr "--follow-ftp                seguir os links FTP dos documentos HTML"

msgid ""
"       --follow-tags=LIST          comma-separated list of followed HTML "
"tags\n"
msgstr ""
"       --follow-tags=LISTA         lista de tags HTML a seguir, separadas "
"por vírgula\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignore-tags=LISTA         lista de tags HTML ignorados, separados "
"por vírgula\n"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"  -H,  --span-hosts                seguir links externos em modo recursivo\n"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr "  -L,  --relative                  ne siga apenas os links relativos\n"

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr "  -I,  --include-directories=LISTA DE DIRETÓRIOS PERMITIDOS\n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"--trust-server-names             utilizar o nome indicado pelo sufixo de URL redirecionante\n"
"        como último componente."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclude-directories=%s\n"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr " -np --no-parent                 não subir no diretório pai\n"

