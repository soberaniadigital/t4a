msgstr "ОШИБКА: falha ao abrir certificado %s: (%d)."

msgid "Loaded CA certificate '%s'\n"
msgstr ""
"Certificado de Autoridade Certificadora (CA) '\\u00ab%s\\u00bb' carregado."

