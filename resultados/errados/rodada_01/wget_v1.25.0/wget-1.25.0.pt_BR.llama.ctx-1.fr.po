msgstr "não é possível abrir o arquivo de cookies %s : %s"

msgid "Error writing to %s: %s\n"
msgstr "Erro de escrita no arquivo %s : %s"

msgid "Error closing %s: %s\n"
msgstr "Erro de fechamento para %s : %s"

msgid "Unsupported listing type, trying Unix listing parser.\n"
msgstr ""
"Não é suportado o formato de lista, tentaríamos analisá-lo com um anotador "
"de listas do tipo Unix."

msgid "Index of /%s on %s:%d"
msgstr "Índice de /%s na linha %d do arquivo %s"

msgid "time unknown       "
msgstr "o tempo é desconhecido     "

