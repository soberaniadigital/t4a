msgstr "Arquivo        "

msgid "Directory   "
msgstr "Catalogo     "

msgid "Link        "
msgstr "Ligação"

msgid "Not sure    "
msgstr "Incerto   "

msgid " (%s bytes)"
msgstr "(%s bytes)"

msgid "Length: %s"
msgstr "Tamanho (byte): %s"

msgid ", %s (%s) remaining"
msgstr ", %s (%s) restante"

msgid ", %s remaining"
msgstr ", %s restante"

msgid " (unauthoritative)\n"
msgstr "não é uma marca certificada (non certifiée)"

msgid "Could not initialize SSL. It will be disabled.\n"
msgstr "Não é possível inicializar o SSL. Será desligado."

msgid "Logging in as %s ... "
msgstr "Executa a entrada sob o nome %s… "

msgid "Error in server response, closing control connection.\n"
msgstr "Erro na resposta do servidor, o controle de conexão é encerrado."

msgid "Error in server greeting.\n"
msgstr "Erro na mensagem de boas-vindas do servidor."

msgid "Write failed, closing control connection.\n"
msgstr "Erro de escrita, conexão de controle encerrada."

msgid "The server refuses login.\n"
msgstr "O servidor negou a autenticação do usuário."

msgid "Login incorrect.\n"
msgstr "Usuário ou senha inválido."

msgid "Logged in!\n"
msgstr "Entrada bem sucedida na sistema!"

msgid "Server did not accept the 'PBSZ 0' command.\n"
msgstr "O servidor não aceitou a comando 'PBSZ 0'."

msgid "Server did not accept the 'PROT %c' command.\n"
msgstr "O servidor não aceitou a comando 'PROT %c'."

msgid "Server error, can't determine system type.\n"
msgstr "Erro do servidor, impossível determinar o tipo de sistema."

msgid "done.    "
msgstr "pronto."

msgid "done.\n"
msgstr "pronto."

msgid "Unknown type `%c', closing control connection.\n"
msgstr "Tipo de conexão desconhecido \"%c\". Fermando a conexão controladora."

msgid "done.  "
msgstr "pronto."

msgid "==> CWD not needed.\n"
msgstr "==> Diretório de trabalho não é necessário."

msgid "Logically impossible section reached in getftp()"
msgstr "Ao chamar getftp(), foi alcançada uma seção lógica inviável."

msgid ""
"cwd_count: %d\n"
"cwd_start: %d\n"
"cwd_end: %d\n"
msgstr ""
"contador_cwd : %d\n"
"início_cwd : %d\n"
"fim_cwd : %d\n"

msgid ""
"No such directory %s.\n"
"\n"
msgstr "Não existe tal diretório: %s."

msgid "==> CWD not required.\n"
msgstr "==> Diretório não é necessário."

msgid "File has already been retrieved.\n"
msgstr "Arquivo já carregado."

msgid "Cannot initiate PASV transfer.\n"
msgstr "Não é possível iniciar a transferência PASV."

msgid "Cannot parse PASV response.\n"
msgstr "Erro na análise da resposta PASV."

msgid "couldn't connect to %s port %d: %s\n"
msgstr "não foi possível estabelecer a conexão com %s no porto %d: %s"

msgid "Bind error (%s).\n"
msgstr "Erro de ligação (%s)."

msgid "Invalid PORT.\n"
msgstr "Porto inválido."

msgid ""
"\n"
"REST failed, starting from scratch.\n"
msgstr "Erro REST, reinício desde o começo."

msgid "File %s exists.\n"
msgstr "O arquivo %s existe."

msgid "No such file %s.\n"
msgstr "Não há tal arquivo: %s."

msgid ""
"No such file %s.\n"
"\n"
msgstr "Não há tal arquivo: %s."

msgid ""
"No such file or directory %s.\n"
"\n"
msgstr "Não há tal arquivo ou diretório %s. \n"

msgid "%s has sprung into existence.\n"
msgstr "%s se tornou realidade."

msgid "%s: %s, closing control connection.\n"
msgstr ""
"%s : a conexão de controle foi encerrada. Fica na esperança que você possa "
"reabrir o soquete para continuar."

msgid "%s (%s) - Data connection: %s; "
msgstr "%s (%s) — Conexão de transferência de dados : %s ; "

msgid "Control connection closed.\n"
msgstr "Conexão de controle encerrada."

msgid "Data transfer aborted.\n"
msgstr "Transferência de dados interrompida."

msgid "File %s already there; not retrieving.\n"
msgstr "Arquivo %s já existe; não é carregado."

msgid "(try:%2d)"
msgstr "(tentativa :%2d)"

msgid ""
"%s (%s) - written to stdout %s[%s]\n"
"\n"
msgstr "%s (%s) — enviado para a saída padrão %s[%s]"

msgid ""
"%s (%s) - %s saved [%s]\n"
"\n"
msgstr "%s (%s) - %s salvo [%s]"

msgid "Removing %s.\n"
msgstr "Destruição de %s."

msgid "Using %s as listing tmp file.\n"
msgstr "Utilização de %s como arquivo temporário para listagem. \n"

msgid "Removed %s.\n"
msgstr "O arquivo %s foi removido."

msgid "Recursion depth %d exceeded max. depth %d.\n"
msgstr ""
"nível de recursividade %d ultrapassou o nível máximo permitido, que é %d."

msgid "Remote file no newer than local file %s -- not retrieving.\n"
msgstr ""
"O arquivo remoto não é mais recente que o arquivo local %s — nenhuma carga. "
"\n"

msgid ""
"Remote file is newer than local file %s -- retrieving.\n"
"\n"
msgstr "O arquivo remoto do %s — carregamento."

msgid ""
"The sizes do not match (local %s) -- retrieving.\n"
"\n"
msgstr "Os tamanhos não concordam (%s localmente) — carregamento."

msgid "Invalid name of the symlink, skipping.\n"
msgstr "Nome inválido de símbolo de link, ignorado."

msgid ""
"Already have correct symlink %s -> %s\n"
"\n"
msgstr "Lien simbólico %s -> %s já existe e está correto."

msgid "Creating symlink %s -> %s\n"
msgstr "Criando a ligação simbólica %s -> %s"

msgid "Symlinks not supported, skipping symlink %s.\n"
msgstr "Liens simbólicos não são suportados, referência %s ignorada."

msgid "Skipping directory %s.\n"
msgstr "O diretório %s foi ignorado."

msgid "%s: unknown/unsupported file type.\n"
msgstr ""
"%s : tipo de ficheiro desconhecido ou não suportado. Por favor, verifique se"
" o arquivo é do formato correto."

msgid "Failed to set permissions for %s.\n"
msgstr "Não foi possível definir as permissões para %s."

msgid "%s: corrupt time-stamp.\n"
msgstr "%s : horodatagem corrompida."

msgid "Will not retrieve dirs since depth is %d (max %d).\n"
msgstr ""
"Os catálogos não serão carregados, pois a profundidade é de %d (máximo %d)."

msgid "Not descending to %s as it is excluded/not-included.\n"
msgstr ""
"Acesso ao diretório \"%s\" não é possível, pois ele está excluído ou não "
"incluso."

msgid "Rejecting %s.\n"
msgstr "Rejeitado. %s."

msgid "Rejecting %s (Invalid Entry).\n"
msgstr "Rejeitado %s (entrada inválida)."

msgid "%s is excluded/not-included through regex.\n"
msgstr "«%s» excluído/excluída de acordo com o padrão regular."

msgid "Error matching %s against %s: %s\n"
msgstr "Erro — %s não corresponde a %s : %s"

msgid "No matches on pattern %s.\n"
msgstr "Não há concordância para o padrão %s."

msgid "Wrote HTML-ized index to %s [%s].\n"
msgstr "Índice em formato HTML gravado no arquivo \"%s\" [%s]."

msgid "Wrote HTML-ized index to %s.\n"
msgstr "Índice em formato HTML gravado no arquivo \"%s\"."

msgid "ERROR: Cannot open directory %s.\n"
msgstr "ERRO : não foi possível abrir o diretório %s. \n"

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ОШИБКА: falha ao abrir o certificado %s: (%d)."

msgid "Loaded CA certificate '%s'\n"
msgstr "O certificado do CA «%s» foi carregado com sucesso."

msgid "ERROR: Failed to load CRL file '%s': (%d)\n"
msgstr ""
"ERRO: Falha ao carregar o arquivo de lista de revocações do certificado "
"«%s»: (%d)"

msgid "Loaded CRL file '%s'\n"
msgstr "CRL-ficheiro carregado de certificados revogados 'nome_do_crl'."

msgid "ERROR: GnuTLS requires the key and the cert to be of the same type.\n"
msgstr "ERRO : GnuTLS requer que a chave e o certificado sejam do mesmo tipo."

msgid "Your GnuTLS version is too old to support TLS 1.3\n"
msgstr ""
"A versão do GnuTLS que você está utilizando é muito antiga para suportar o "
"TLS 1.3."

msgid "GnuTLS: unimplemented 'secure-protocol' option value %u\n"
msgstr ""
"GnuTLS : valor %u para o parâmetro 'secure-protocol' não está implementado"

msgid "Please report this issue to bug-wget@gnu.org\n"
msgstr "Comunique-se sobre esta falha para <bug-wget@gnu.org>"

msgid "GnuTLS: unimplemented 'secure-protocol' option value %d\n"
msgstr ""
"GnuTLS : valor %d para o parâmetro 'secure-protocol' não está implementado"

msgid ""
"GnuTLS: Cannot set prio string directly. Falling back to default priority.\n"
msgstr ""
"GnuTLS : impossível definir diretamente a cadeia de prioridade. A prioridade"
" padrão será utilizada."

msgid "ERROR"
msgstr "ОШИБКА"

msgid "WARNING"
msgstr "Pré-aviso"

msgid "%s: No certificate presented by %s.\n"
msgstr "%s : não há certificado apresentado por %s."

msgid "%s: The certificate of %s is not trusted.\n"
msgstr "%s : o certificado de %s não é confiável. Aceito."

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr ""
"%s : o certificado de %s não é emitido por um autor conhecido. Por favor, "
"verifique novamente a fonte do seu certificado."

msgid "%s: The certificate of %s has been revoked.\n"
msgstr "%s : o certificado para %s foi revogado."

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr ""
"%s : o certificado assinado por %s não foi emitido pela Autoridade "
"Certificadora (CA)."

msgid "%s: The certificate of %s was signed using an insecure algorithm.\n"
msgstr ""
"%s : para assinar o certificado %s foi utilizado um algoritmo não seguro."

msgid "%s: The certificate of %s is not yet activated.\n"
msgstr ""
"%s : o certificado de %s ainda não foi ativado. (Certificação desativada)."

msgid "%s: The certificate of %s has expired.\n"
msgstr ""
"%s : o certificado de %s expirou. (O prazo do certificado de %s chegou ao "
"fim.)"

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro de inicialização do certificado X.509 : %s"

msgid "No certificate found\n"
msgstr "Certificado não encontrado"

msgid "Error parsing certificate: %s\n"
msgstr "Erro de análise do certificado : %s"

msgid "The certificate has not yet been activated\n"
msgstr "O certificado ainda não está ativado."

msgid "The certificate has expired\n"
msgstr "O certificado expirou seu período de validade"

msgid "The certificate's owner does not match hostname %s\n"
msgstr ""
"O proprietário do certificado não corresponde ao nome de hospedeiro %s"

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública não corresponde à chave pública fixa!"

msgid "Certificate must be X.509\n"
msgstr "O certificado deve corresponder ao padrão X.509"

msgid "Error in handling the address list.\n"
msgstr "Erro ao processar a lista de endereços."

msgid "Unknown host"
msgstr "nó desconhecido"

msgid "Temporary failure in name resolution"
msgstr "Erro temporário ao resolver o nome do arquivo"

msgid "Unknown error"
msgstr "Erro desconhecido"

msgid "Resolving %s... "
msgstr "Ressolvendo %s… "

msgid "failed: No IPv4/IPv6 addresses for host.\n"
msgstr "falha : para o servidor não há endereço IPv4/IPv6. \n"

msgid "failed: timed out.\n"
msgstr "falha de execução : tempo limite excedido."

msgid "%s: Cannot resolve incomplete link %s.\n"
msgstr ""
"%s : impossível resolver o link incompleto %s. Por favor, verifique se a URL"
" está correta e tente novamente."

msgid "%s: Invalid URL %s: %s\n"
msgstr "%s : URL %s inválido : %s"

msgid "Failed writing HTTP request: %s.\n"
msgstr "Erro de escrita da requisição HTTP : %s. \n"

msgid "No headers, assuming HTTP/0.9"
msgstr "Não há cabeçalhos, HTTP/0.9 presumido."

msgid ""
"File %s already there; not retrieving.\n"
"\n"
msgstr "Arquivo %s já existe — não é carregado."

msgid "gmtime failed. This is probably a bug.\n"
msgstr "Ошибка gmtime. Provável falha por defeito.\n"

msgid ""
"Cannot convert timestamp to http format. Falling back to time 0 as last "
"modification time.\n"
msgstr ""
"Não é possível converter a marcação de tempo para o formato HTTP. Retornamos"
" ao horário zero como do último momento da alteração."

msgid "BODY data file %s missing: %s\n"
msgstr "Ficheiro de dados BODY %s faltante : %s"

msgid "Reusing existing connection to [%s]:%d.\n"
msgstr "Réutilização da conexão existente com [%s]:%d. \n"

msgid "Reusing existing connection to %s:%d.\n"
msgstr "Réutilização da conexão existente com %s:%d. \n"

msgid "Failed reading proxy response: %s\n"
msgstr "Falha na leitura da resposta do proxy : %s"

msgid "%s ERROR %d: %s.\n"
msgstr ""
"%s ERRO %d: %s. (Original context was 'FR' -> '%s erreur %d: %s.' in "
"Portuguese)"

msgid "Malformed status line"
msgstr "Não é uma linha de estado completa"

msgid "Proxy tunneling failed: %s"
msgstr "Erro de túnel do proxy : %s"

msgid "Unknown authentication scheme.\n"
msgstr "Esquema de autenticação desconhecido."

msgid "Authentication selected: %s\n"
msgstr "Autenticação selecionada : %s"

msgid "Saving to: %s\n"
msgstr "Salvar em: %s\n"

msgid ""
"When downloading signature:\n"
"%s: %s.\n"
msgstr ""
"Durante o download da assinatura: \n"
"%s : %s. \n"

msgid "Unable to read signature content from temporary file. Skipping.\n"
msgstr ""
"Não é possível ler o conteúdo da assinatura a partir do arquivo temporário. "
"Ignorado."

msgid "Could not create temporary file. Skipping signature download.\n"
msgstr ""
"Não foi possível criar o arquivo temporário. Ocorreu um erro ao tentar "
"baixar a assinatura."

msgid "Invalid pri value. Assuming %d.\n"
msgstr "Valor pri inválido. Supomos %d."

msgid ""
"Could not find acceptable digest for Metalink resources.\n"
"Ignoring them.\n"
msgstr ""
"Não é possível encontrar uma função hash (digest) adequada para os recursos "
"Metalink. Ignoraremos."

msgid "Disabling SSL due to encountered errors.\n"
msgstr "Desativação do SSL devido a erros detectados."

msgid "%s request sent, awaiting response... "
msgstr "requête %s enviada, esperando a resposta… "

msgid "No data received.\n"
msgstr "Não foram recebidos dados."

msgid "Read error (%s) in headers.\n"
msgstr "Erro de leitura (%s) nos cabeçalhos."

msgid "(no description)"
msgstr "(sem descrição)"

msgid "Location: %s%s\n"
msgstr "Emplacamento : %s%s\n"

msgid "unspecified"
msgstr "não há dados"

msgid " [following]"
msgstr "[avançar]"

msgid ""
"File %s not modified on server. Omitting download.\n"
"\n"
msgstr "O arquivo %s no servidor não foi alterado. O download é permitido."

msgid ""
"Server ignored If-Modified-Since header for file %s.\n"
"You might want to add --no-if-modified-since option.\n"
"\n"
msgstr ""
"O servidor ignorou o cabeçalho If-Modified-Since para o arquivo %s. Tente "
"adicionar a opção --no-if-modified-since."

msgid ""
"\n"
"    The file is already fully retrieved; nothing to do.\n"
"\n"
msgstr "Arquivo já totalmente carregado; nada a fazer."

msgid "Length: "
msgstr "Comprimento : "

msgid "ignored"
msgstr "ignorado"

msgid "Warning: wildcards not supported in HTTP.\n"
msgstr "Aviso: as máscaras de URL (*) não são suportadas no HTTP."

msgid "Spider mode enabled. Check if remote file exists.\n"
msgstr "Modo de trabalho ativado. Verificando a existência do arquivo remoto."

msgid "Cannot write to %s (%s).\n"
msgstr "Не foi possível escrever no %s (%s)."

msgid "Required attribute missing from Header received.\n"
msgstr "O atributo obrigatório está ausente no cabeçalho aceito."

msgid "Username/Password Authentication Failed.\n"
msgstr "Erro de autenticação do usuário/senha."

msgid "Cannot write to WARC file.\n"
msgstr "Не foi possível escrever no arquivo WARC."

msgid "Cannot write to temporary WARC file.\n"
msgstr "Не foi possível gravar no arquivo WARC temporário."

msgid "Unable to establish SSL connection.\n"
msgstr "Não é possível estabelecer uma conexão SSL."

msgid "Cannot unlink %s (%s).\n"
msgstr "Не foi possível excluir o link %s (%s)."

msgid "ERROR: Redirection (%d) without location.\n"
msgstr "ERRO: redirecionamento (%d) sem endereço especificado."

msgid ""
"Could not find Metalink data in HTTP response. Downloading file using HTTP "
"GET.\n"
msgstr ""
"Não é possível encontrar os dados Metalink na resposta HTTP. O arquivo será "
"baixado utilizando o método GET HTTP."

msgid "Metalink headers found. Switching to Metalink mode.\n"
msgstr "Encontrados os cabeçalhos Metalink. Avançamos para o modo Metalink."

msgid "Remote file does not exist -- broken link!!!\n"
msgstr "Arquivo remoto não existe — referência inválida."

msgid "Last-modified header missing -- time-stamps turned off.\n"
msgstr "falha na verificação da última modificação do arquivo\n"

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr ""
"Não é permitido um cabeçalho inválido de 'last modified' — horários "
"ignorados."

msgid ""
"Server file no newer than local file %s -- not retrieving.\n"
"\n"
msgstr ""
"O arquivo no servidor não é mais recente que o arquivo local %s — nenhuma "
"transferência. \n"

msgid "The sizes do not match (local %s) -- retrieving.\n"
msgstr ""
"Os tamanhos dos arquivos não correspondem (%s localmente) — carregamento. \n"

msgid "Remote file is newer, retrieving.\n"
msgstr "O arquivo remoto é mais recente, carregando."

msgid ""
"Remote file exists and could contain links to other resources -- retrieving.\n"
"\n"
msgstr ""
"Arquivo remoto existente e pode conter referências a outros recursos — "
"carregamento em andamento."

msgid ""
"Remote file exists but does not contain any link -- not retrieving.\n"
"\n"
msgstr ""
"O arquivo remoto existe, mas não contém nenhuma referência — não é "
"carregado."

msgid ""
"Remote file exists and could contain further links,\n"
"but recursion is disabled -- not retrieving.\n"
"\n"
msgstr ""
"O arquivo remoto existe e pode conter links adicionais, mas o modo de "
"recursão está desabilitado — não é carregado."

msgid ""
"Remote file exists.\n"
"\n"
msgstr "O arquivo remoto existe."

msgid "%s URL: %s %2d %s\n"
msgstr "%s URL: %s %2d %s\n"

msgid ""
"%s (%s) - written to stdout %s[%s/%s]\n"
"\n"
msgstr "%s (%s) — envio versão para saída padrão %s[%s/%s]"

msgid ""
"%s (%s) - %s saved [%s/%s]\n"
"\n"
msgstr "%s (%s) — %s salvo [%s/%s]"

msgid "%s (%s) - Connection closed at byte %s. "
msgstr "%s (%s) — Fechamento da conexão com o socket %s. "

msgid "%s (%s) - Read error at byte %s (%s)."
msgstr "%s (%s) — Falha na leitura no byte %<PRIuMAX> (posição %d)."

msgid "%s (%s) - Read error at byte %s/%s (%s). "
msgstr "%s (%s) — Erro de leitura no byte %s/%s (%s). "

msgid "Unsupported quality of protection '%s'.\n"
msgstr "Atributo de segurança não suportado \"%s\"."

msgid "Unsupported algorithm '%s'.\n"
msgstr "Algoritmo \"%s\" não é suportado."

msgid ""
"%s: WGETRC points to %s, which couldn't be accessed because of error: %s.\n"
msgstr ""
"%s : WGETRC indica que %s não está acessível devido à erro : %s. Por favor, "
"verifique as permissões do sistema e certifique-se de que o arquivo esteja "
"presente no diretório especificado."

msgid "%s: Cannot read %s (%s).\n"
msgstr "%s : impossível ler %s (%s)."

msgid "%s: Error in %s at line %d.\n"
msgstr "%s: Ошибка в %s в строке %d.\n"

msgid "%s: Syntax error in %s at line %d.\n"
msgstr "%s : erro de sintaxe no %s na linha %d. \n"

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s : comando desconhecido %s na linha %<PRIuMAX> da coluna %d. \n"

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro de processamento do arquivo sistema wgetrc (variável d'ambiente SYSTEM_WGETRC). Por favor, verifique \n"
"\t\"%s\", ou indique um outro arquivo com --config."

msgid ""
"Parsing system wgetrc file failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro de processamento do arquivo sistema wgetrc. Por favor, verifique o "
"seguinte caminho ou indique um outro com --config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s : aviso : o wgetrc do sistema e de usuário indicam para %s. Por favor, "
"verifique as configurações em ambos os arquivos."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s : comando --execute %s inválido"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s : %s : valor lógico %s incorreto ; utilize 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s : %s : %s incorreto; utilizez 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s : %s : número %s inválido."

msgid "%s: %s must only be used once\n"
msgstr "%s : a opção %s ne pode ser utilizada mais do que uma vez\n"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s : %s : valor d’octeto %s incorreto"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s : %s : período de tempo %s incorreto"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s : %s : período de tempo negativo %s"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso de askpass é necessário uma string ou a ativação da variável "
"ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s : %s : valor %s inválido."

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s : %s : cabeçalho %s incorreto."

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s : %s : en-tête WARC %s incorreto."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr "%s : %s : tipo de progressão %s incorreto."

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s : %s : restrição de uso inválida, utilize "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "A codificação %s é inválida"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão de %s para %s não é suportada."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência multioctet não completa ou inválida."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8 : configuração de localidade não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "erro idn_encode (%d): %s\n"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d : %s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s : %s ; desativação de registro. (Desligamento da captura de logs.)"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização : %s [PARAMETRO]… [URL]…\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para as opções no formato longo também são "
"necessários para as opções em formato curto."

msgid "Startup:\n"
msgstr "Démarrage :"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version                   Mostrar a versão do Wget e encerrar o "
"trabalho\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      Mostrar a ajuda deste aplicativo\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para entrar no modo de"
" fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr ""
"  -e, --execute=COMMANDE   executar uma comando no estilo '.\n"
"wgetrc'\n"

msgid "Logging and input file:\n"
msgstr "Jornalização e ficheiro de entrada : \n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrevendo mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr "  -a,  --append-output=%s     adicionar mensagens ao final do FICHIER\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                     mostrar uma grande quantidade de "
"informações de depuração\n"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr ""
"  -q,  --quiet                     executar em modo silencioso (sem saída)"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
"--verbose, --v\n"
"    Execute em modo detalhado (modo padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose          desligar o modo verboso, sem ser silencioso\n"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE\n"
"    carregar URLs do arquivo local ou externo."

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE\n"
"         baixar arquivos listados no FILE Metalink local"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL                   considerar os links HTML do arquivo de "
"entrada (-i -F) como relativos à URL especificada."

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=%s         definir arquivo de configuração %s\n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                 não ler nenhum arquivo de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registrar as razões para rejeição de URL no "
"FILE\n"

msgid "Download:\n"
msgstr "Telecargação:\n"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=CÓDIGO              definir o CÓDIGO de tentativas (0 indica "
"a ausência de limite)"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused         réessayer mesmo se a conexão for "
"recusada\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error     припускано, considerando erros de host como"
" não críticos e aleatórios\n"

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS    lista de erros HTTP para reexecutar, "
"separados por vírgula\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    salvar documentos no FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"--no-clobber              -n, --sem cobrar                    ignorar as atualizações que levariam à substituição de arquivos existentes\n"
"(e suas recriações)"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr ""
"       --no-netrc                  não tentar obter dados do arquivo "
".netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                   para continuar o carregamento de um "
"arquivo parcialmente baixado\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=POSICÃO        iniciar o download a partir da POSICÃO "
"(considerado como zero) \n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr "       --progress=ТИП            выбрать тип индикатора выполнения\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress             mostrar a barra de progresso em qualquer "
"modo detalhado\n"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N, --timestamping              não reticarcar arquivos além da última "
"versão localmente disponível\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"--no-use-server-timestamps    não utilizar a condição if-modified-since para"
" solicitações em modo timestamping."

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--no-use-server-timestamps     não usar a marca de tempo local, recebida do "
"servidor\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         exibir a resposta do servidor\n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                    ne fazer nenhuma carga"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         definir todos os valores de tempo "
"esperados como igual ao número especificado em segundos\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSES      lista de servidores DNS a serem "
"consultados (separada por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE  vincular o resolver DNS à ADRESSE (nome "
"de host ou endereço IP) do computador local\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SEC         definir o tempo de espera para a resolução "
"DNS em segundos\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"--connect-timeout=SEC     definir o tempo de espera para conexão em SEC\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"--read-timeout=SEC\n"
"    Definir o tempo limite de espera para leitura em segundos."

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEGUNDAS              atenção entre as tentativas em segundos\n"
"                                   (utilizada se mais de uma URL forem solicitadas)"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDAS        espera de 1 a SEGUNDAS segundos entre as "
"tentativas seguintes (utilizada se mais do que uma URL forem solicitadas)"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"--random-wait             pausa aleatória de 0.5*WAIT...1.5*WAIT segundos "
"entre as tentativas (utilizada quando mais de uma URL forem carregadas)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                  desligar o proxy diretamente"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓDIGO              definir a quota de transferência em "
"CÓDIGO"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRESSE      ligar localmente (nome de hospede ou "
"endereço IP) \n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr "       --limit-rate=TAUX           limitar a TAUX de transferência"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "--no-dns-cache              desligar a cache de consultas DNS"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS    utilizar em nomes de arquivos caracteres "
"aceitáveis pelo sistema operacional\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             ignorar a diferença de maiúsculas e "
"minúsculas para correspondência dos arquivos ou diretórios\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "--inet4-only              conectar apenas a endereços IPv4\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only              conectar apenas a adresses IPv6\n"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar-se preferencialmente aos endereços do\n"
"                        SEMEISSTVO (IPv6, IPv4 ou nenhum)\n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr "       --user=USUÁRIO          definir o USUÁRIO para FTP e HTTP\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr "       --password=PAROLI         definir o PAROLI para FTP e HTTP\n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password              solicitar senhas"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=COMMAND      especifique o acreditador para as "
"solicitações de login e senha. Se nenhuma COMMAND for especificada, será "
"utilizado a variável ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                    desligar a suporte aos IRIs\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como codificação local для "
"IRI\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como codificação remota "
"distante КДР por padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "       --unlink                    remover o arquivo antes de apagar"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash              conserve os arquivos de soma de contraste"
" incorretos (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr "       --metalink-index=NOMBRE    Metalink application/metalink4+xml\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar as metadados Metalink a partir do "
"cabeçalho de resposta HTTP"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location        localização preferida dos recursos "
"Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                   habilitar o armazenamento de metadados em "
"atributos de arquivo estendidos\n"

msgid "Directories:\n"
msgstr "Répertoires :"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories           não criar catálogos"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        forçar a criação de diretórios"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr "  -nH, --no-host-directories       não cria diretórios no host\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories      utilizar diretórios com o nome do "
"protocolo\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr ""
"  -P,  --directory-prefix=ПРЕФИКС  salvar arquivos no diretório PRЭФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО componentes de catálogo\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=POLIZOVATEL     definir o utilizador HTTP"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "       --http-password=ПАРОЛЬ  estabelecer http-senha em ПАРОЛЬ\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"--no-cache                      negar dados armazenados em cache do servidor"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr "       --default-page=ÍMÊ"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E, --ajustar extensão      salvar documentos HTML/CSS com suas "
"respectivas extensões\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"       --ignore-length             ignorar o campo de cabeçalho 'Content-"
"Length'"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "--header=%s\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TYPE       tipo de compressão: auto, gzip ou none\n"
"                               (por padrão: none)"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          máximo permitido de redirecionamentos para a "
"página\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USERNAME   definir USERNAME como nome de usuário para "
"proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROL\n"
"                               definir o PAROL como a senha do servidor mandatoiro."

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           inclua o cabeçalho 'Referer: URL' na "
"solicitação HTTP\n"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-en-têtes no arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENT      identificar como AGENT e não Wget/VERSÃO\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive        desligue o HTTP keep-alive (conexões "
"persistentes)"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                não utilizar cookies"

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE      carregar cookies do FILE antes de iniciar o "
"jogo\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      carregar e salvar cookies de sessão (não "
"permanentes) \n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING utilizar a método POST para enviar STRING como "
"dados\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILE\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod     utilizar o método \"HTTPMethod\" no "
"cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=STRING          envio da STRING como dados; \n"
"                               O --method deve ser definido\n"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FICHIER         envio do conteúdo da FICHIER. \n"
"                                     --method deve ser definido\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   respeitar o cabeçalho Content-Disposition\n"
"                               ao escolher nomes para arquivos locais (experimental)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"--content-on-error      exibir o conteúdo recebido após erros do servidor\n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"       --auth-no-challenge     enviar informações de autenticação HTTP "
"básico sem esperar por primeiro resposta do servidor\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR        escolha um protocolo de segurança PR "
"entre auto, SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr "       --https-only             indo apenas por links HTTPS seguros"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr "--no-check-certificate      não validar o certificado do servidor\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       ficheiro de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=ТИП   тип сертификата пользователя: PEM або DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr "       --private-key=FILE      arquivo de chave privada\n"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr "       --private-key-type=ТИП   тип секретного ключа: PEM або DER\n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr ""
"       --ca-certificate=FILE    arquivo com uma coleção de certificados CA\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=КАТ       catálogo, no qual está armazenado a lista de"
" hashes dos certificados das autoridades de certificação"

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr ""
"       --crl-file=FILE          arquivo de lista de revocações de "
"certificado"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES  ficheiro de chave pública (PEM/DER), ou "
"qualquer número de hash sha256 codificado em base64 iniciando com 'sha256//'"
" e separados por ';', para verificação das pares\n"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE      arquivo de dados aleatórios para inicializar "
"a geração de números pseudoaleatórios SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo de socket EGD com dados aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=СТРОКА         Designar STR como prioridade (GnuTLS) ou a lista de cipher STR (OpenSSL) diretamente. \n"
"                                Use com cautela. Essa opção substitui o valor do parâmetro --secure-protocol. \n"
"                                O formato e sintaxe da STR dependem do motor SSL/TLS utilizado."

msgid "HSTS options:\n"
msgstr ""
"Parâmetros HSTS : \n"
"\t%s - %d segundos; \n"
"\t%<PRIuMAX> campos de entrada e saída padrão; \n"
"\t%s - 'Strict-Transport-Security' (HSTS) para garantir a comunicação HTTPS em todas as solicitações futuras."

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                  desligar HSTS\n"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho da base de dados HSTS (sobe o valor "
"padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP : \n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"ficheiros binaires FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr "       --ftp-user=USERNAME      definir o USERNAME FTP\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=ПАРОЛЬ   definir a senha FTP em ПАРОЛЬ\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "--no-remove-listing         não remova as listagens (.listing)"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"--no-glob                   desligar as macros para nomes de arquivos FTP"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp            desligar o modo de transferência "
"passivo\n"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"--preserve-permissions      manter os direitos de acesso aos arquivos "
"remotos"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         em modo recursivo, carregar arquivos ligados "
"a símbolos (não catálogos) \n"

msgid "FTPS options:\n"
msgstr ""
"Parâmetros FTPS : \n"
"\t%s - Hostname ou IP do servidor (exemplo: ftp.example.com)\n"
"\t%d - Porta usada pelo serviço de transferência seguro (por exemplo, 990 para o SFTP e 21 para o FTP tradicional)\n"
"\t%s - Senha ou autenticação baseada em certificados necessária para acessar o servidor remoto\n"
"\t%<PRIuMAX> - Número máximo de campos permitidos por linha no arquivo de configuração do FTPS (por exemplo, 10)\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                 utilizar implicitamente FTPS (porta "
"padrão é o número 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               reinicie o sessão SSL/TLS iniciada no"
" canal de controle, ao abrir a conexão de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"       --ftps-clear-data-connection    chifrar apenas o canal de controle; "
"Todas as informações serão em texto simples\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"       --ftps-fallback-to-ftp          reverter para FTP se o FTPS não "
"estiver suportado pelo servidor alvo\n"

msgid "WARC options:\n"
msgstr ""
"Parâmetros WARC : \n"
"\t%s - Caminho para o arquivo de entrada (input file path). O caminho deve ser especificado em formato absoluto. Por exemplo, '/home/user/documents/warcfile.warc'. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%d - Número máximo de linhas para ler do arquivo WARC (maximum number of lines to read from the .warc file). O valor padrão deve ser 10. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%<PRIuMAX> - Número máximo de campos por linha (maximum number of fields per line). O valor padrão deve ser 10. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de saída WARC (output file path to .warc). O caminho deve ser especificado em formato absoluto. Por exemplo, '/home/user/documents/processed_warcfile.warc'. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%d - Número máximo de linhas para escrever no arquivo WARC (maximum number of lines to write into the .warc file). O valor padrão deve ser 10. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de log (log file path). Por exemplo, '/var/logs/warc_processing.log'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de saída (output file path). Por exemplo, '/var/logs/processed_warcfile.txt'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de entrada (input file path). Por exemplo, '/var/logs/warc_file.txt'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de saída (output file path). Por exemplo, '/var/logs/processed_warcfile.txt'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de entrada (input file path). Por exemplo, '/var/logs/warc_file.txt'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de saída (output file path). Por exemplo, '/var/logs/processed_warcfile.txt'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de entrada (input file path). Por exemplo, '/var/logs/warc_file.txt'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de saída (output file path). Por exemplo, '/var/logs/processed_warcfile.txt'. O caminho deve ser especificado em formato absoluto. Se a variável não for definida ou estiver vazia, um erro é gerado e o processamento falhará.\n"
"\t%s - Caminho para o arquivo de entrada (input file path). Por exemplo, '/var end of document"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILE          salvar dados de solicitação e resposta em "
"arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr "--warc-header=STRINGA inscrever STRINGA no registro warcinfo"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=%<PRIuMAX>      definir o tamanho máximo de arquivos "
"WARC como %<PRIuMAX>"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                 escrever os arquivos de índice CDX\n"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILE        não salvar registros repetidos do arquivo "
"CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr "       --no-warc-compression     não comprimir arquivos WARC com GZIP\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "--no-warc-digests           não calcula os hashes SHA1"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr "--no-warc-keep-log          não salvar log em registro WARC"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=CATALOG    localização para arquivos temporários "
"criados pela escrita WARC\n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive          включение рекурсивной загрузки\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr ""
"  -l,  --level=CÓDIGO        profundidade máxima de recursão (inf ou 0 para "
"infinito) \n"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr ""
"       --delete-after              apagar arquivos locais após a "
"transferência de dados"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
"  -k,  --convert-links      transformar links em locais nos arquivos HTML ou"
" CSS carregados\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr ""
"       --convert-file-only         converte apenas a parte do arquivo da URL"
" (parte chamada basename) \n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                 antes de escrever o arquivo X, fazer backup em N"
" cópias e manter no máximo N\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X fazer uma cópia "
"em formato X_orig\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X fazer uma cópia "
"de backup no formato X.orig\n"

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"  -m,  --mirror                    raccoursi de -N -r -l inf --no-remove-"
"listing\n"

msgid ""
"  -p,  --page-requisites           get all images, etc. needed to display "
"HTML page\n"
msgstr ""
"  -p,  --page-requisites           obter todas as imagens e outros elementos"
" necessários para exibir a página HTML\n"

msgid ""
"       --strict-comments           turn on strict (SGML) handling of HTML "
"comments\n"
msgstr ""
"       --strict-comments    habilitar o tratamento rigoroso (SGML) de "
"comentários HTML\n"

msgid "Recursive accept/reject:\n"
msgstr ""
"Permissões/proibições recursivas : \n"
"\t%s - Permitir acesso ao diretório e aos arquivos dentro dele. %d - Número máximo permitido de níveis de profundidade para o recurso.\n"
"\t%<PRIuMAX> - O tamanho do buffer utilizado durante as verificações recursivas."

msgid ""
"  -A,  --accept=LIST               comma-separated list of accepted "
"extensions\n"
msgstr ""
"  -A,  --accept=LISTE              lista de extensões aceitas, separadas por"
" vírgula\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LISTA              lista de extensões rejeitadas, separadas "
"por vírgulas\n"

msgid "       --accept-regex=REGEX        regex matching accepted URLs\n"
msgstr ""
"       --accept-regex=РЕГВЫР       регулярное выражение для разрешённых URL"

msgid "       --reject-regex=REGEX        regex matching rejected URLs\n"
msgstr ""
"       --reject-regex=РЕГВЫР       expressão regular correspondente às URLs "
"rejeitadas\n"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr ""
"       --regex-type=ТИП            тип регулярного выражения (posix|pcre) \n"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr "       --regex-type=ТИП            тип регулярного выражения (posix) \n"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr ""
"  -D,  --domains=LISTA             domínios aceitos, separados por vírgula\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr ""
"       --exclude-domains=LISTA     domínios rejeitados, separados por "
"vírgulas\n"

msgid ""
"       --follow-ftp                follow FTP links from HTML documents\n"
msgstr ""
"       --follow-ftp                seguir links FTP nos documentos HTML\n"

msgid ""
"       --follow-tags=LIST          comma-separated list of followed HTML "
"tags\n"
msgstr ""
"       --follow-tags=LISTA         lista de tags HTML a seguir, separadas "
"por vírgula\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignore-tags=LISTA         lista de tags HTML ignorados, separados "
"por vírgula\n"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"  -H,  --span-hosts                visita outros nós durante a recursão \n"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr ""
"  -L,  --relative                  ne seguir apenas por links relativos"

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr "  -I,  --include-directories=LISTA_DE_DIRETORIOS_PERMITIDOS\n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"--trust-server-names             utilizar o nome indicado pelo sufixo do URL"
" de redirecionamento\n"

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclui-diretórios=%s\n"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr "  -np, --no-parent                 não subir no diretório pai\n"

msgid ""
"Email bug reports, questions, discussions to <bug-wget@gnu.org>\n"
"and/or open issues at https://savannah.gnu.org/bugs/?func=additem&group=wget.\n"
msgstr ""
"Envie relatórios de bugs, perguntas e sugestões para <bug-wget@gnu.org> ou "
"abra uma questão no https://savannah.gnu.org/bugs/?func=additem&group=wget."

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, programa para a transferência de arquivos pela rede sem interação do usuário. \n"
"\n"

msgid "Password for user %s: "
msgstr "Senha para o usuário %s : "

msgid "Password: "
msgstr "Mot de passe : "

msgid "Cannot create pipe\n"
msgstr "Не foi possível criar o soquete."

msgid "Error initializing spawn file actions for use-askpass: %d\n"
msgstr ""
"Erro de inicialização do objeto ação de arquivo spawn para use-askpass : %d"

msgid "Error setting spawn file actions for use-askpass: %d\n"
msgstr "Erro ao configurar as ações de arquivo para use-askpass : %d"

msgid "Error reading response from command \"%s %s\": %s\n"
msgstr "Erro de leitura da resposta para a comando \"%s %s\": %s"

msgid "Username for '%s%s': "
msgstr "Nome de usuário para \"%s%s\": "

msgid "Password for '%s%s@%s': "
msgstr "Mot de passe para o utilizador \"%s%s@%s\": "

msgid "Wgetrc: "
msgstr "Wgetrc : "

msgid "Locale: "
msgstr "Parametros regionais : "

msgid "Compile: "
msgstr "Compilação : "

msgid "Link: "
msgstr "Lien : \"%s\""

msgid ""
"GNU Wget %s built on %s.\n"
"\n"
msgstr "GNU Wget %s para %s. \n"

msgid "    %s (env)\n"
msgstr "    %s (ambiente) \n"

msgid "    %s (user)\n"
msgstr "    %s (usuário) \n"

msgid "    %s (system)\n"
msgstr "    %s (sistema) \n"

