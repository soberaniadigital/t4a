msgid ""
"\n"
"Originally written by Hrvoje Niksic <hniksic@xemacs.org>.\n"
msgstr "Écrítua originalmente por Hrvoje Niksic <hniksic@xemacs.org>."

msgid "Please send bug reports and questions to <bug-wget@gnu.org>.\n"
msgstr "Em caso de erros ou dúvidas, envie mensagens para <bug-wget@gnu.org>."

msgid "Memory allocation problem\n"
msgstr "Problema de alocação de memória"

msgid "Exiting due to error in %s\n"
msgstr "Ocorreu uma falha em %s, o que obriga a sair."

msgid "Try `%s --help' for more options.\n"
msgstr ""
"Para obter mais informações, utilize a comando '\\u00ab %s --help \\u00bb'."

msgid "%s: illegal option -- `-n%c'\n"
msgstr "%s : opção inválida — « -n%c »"

msgid "Debugging support not compiled in. Ignoring --debug flag.\n"
msgstr "Assembled without debugging support. The --debug flag is ignored."

msgid ""
"Both --no-clobber and --convert-links were specified, only --convert-links "
"will be used.\n"
msgstr ""
"Указаны сразу --no-clobber і --convert-links, буде використовуватися apenas "
"--convert-links."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"Указаны сразу --no-clobber e --convert-file-only, utilizará apenas "
"--convert-file-only."

msgid "Can't be verbose and quiet at the same time.\n"
msgstr "Não é possível usar ao mesmo tempo o modo verbose e silencioso."

msgid "Can't timestamp and not clobber old files at the same time.\n"
msgstr ""
"Não é possível utilizar as datas temporárias e não exaurir arquivos antigos "
"ao mesmo tempo."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar --inet4-only e --inet6-only ao mesmo tempo."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Не é possível indicar simultaneamente -k ou --convert-file-only e -O, se "
"URLs múltiplas forem especificadas, ou em combinação com -p ou -r. Consulte "
"o manual para mais detalhes."

msgid ""
"WARNING: combining -O with -r or -p will mean that all downloaded content\n"
"will be placed in the single file you specified.\n"
"\n"
msgstr ""
"PRECISÃO: ao combinar o parâmetro -O com os parâmetros -r ou -p, indica que "
"todos os dados carregados serão armazenados em um único arquivo. \n"

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"ATENÇÃO: o horodatador não funciona se combinado com o parâmetro -O. "
"Consulte o manual para mais detalhes."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com o parâmetro --no-clobber, que será desabilitado."

msgid ""
"WARC output does not work with timestamping, timestamping will be "
"disabled.\n"
msgstr "Saída WARC não funciona com o horodatagem, que será desligada."

msgid "WARC output does not work with --spider.\n"
msgstr "Saída WARC não funciona com --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"Saída WARC não funciona com --continue ou --start-pos; eles serão "
"desligados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório desconectado; a função de eliminação dupla WARC não encontrará "
"registros repetidos."

msgid ""
"Compression does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"A compressão não funciona com --continue ou --start-pos; eles serão "
"desligados."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr "Não é possível indicar simultaneamente --ask-password e --password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
