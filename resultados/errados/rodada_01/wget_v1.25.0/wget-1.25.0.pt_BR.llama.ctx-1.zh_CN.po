msgstr ""
"%s: Aviso: os arquivos wgetrc do sistema e do usuário indicam para %s. Por "
"favor, revise as configurações em ambos."

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando --execute inválido %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Falha no valor lógico do switch %s; use 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: Inválido '%s'; utilize 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. \n"

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor de byte inválido %d\n"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Tempo de intervalo inválido %s"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso do askpass é necessário uma string ou a variável de ambiente "
"WGET_ASKPASS ou SSH_ASKPASS."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor inválido de %s. Por favor, verifique novamente."

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: Título inválido do arquivo %s. \n"

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s: %s: Não é um cabeçalho WARC válido %s."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr ""
"%s: %s: Tipo de progresso inválido %s. Por favor, verifique a configuração "
"do seu programa."

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição inválida %s, usuário deve utilizar "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "A codificação %s é inválida."

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O processo de conversão do %s para o %s não é suportado."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes inválida ou incompleta."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: locale não definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no codificador idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d:%s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O E/S padrão está redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr ""
"%s: a opção '%s' foi desabilitada. Ao utilizar esta função, o registro de "
"log será interrompido."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL]...\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções longas permanecem obrigatórios mesmo "
"quando se usam opções curtas."

msgid "Startup:\n"
msgstr "Iniciar:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version                    Mostrar versão do Wget e encerrar a "
"execução\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h, --help                       Mostrar esta ajuda\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa, inicie no modo de "
"fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr "  -e, --execute=%s   executar a comando no estilo de “.wgetrc”\n"

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrever mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr "  -a,  --append-output=%s do seguinte arquivo\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                      Mostrar informações de depuração "
"extensivas\n"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr ""
"  -q,  --quiet                      modo silencioso (sem saída de "
"informações)"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "  -v,  --verbose                    Verbose (default)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose                Desligue o relatório detalhado para "
"reduzir a quantidade de informações exibidas (sem entrar em modo silencioso)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=тип    единицы измерения пропускной способности\n"
"                             определить тип. тип может быть равно битам\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo <ARQUIVO> \n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos, listados no local Metalink"
" FILE <arquivo> \n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL                   considerar que as ligações do arquivo de"
" entrada HTML são relativas à URL especificada\n"

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=%s         especificar o arquivo de configuração\n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                    não ler arquivos de configuração"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registrem os motivos de rejeição das URLs em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             configurar o número de tentativas (0 para "
"sem limite) \n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused          mesmo se ocorrer falha na conexão, é "
"recomendado tentar novamente."

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error        considerar erros de host como não "
"críticos e aleatórios"

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS     Lista (separada por vírgula) de erros"
" HTTP, que causam recomeço\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=FILE    salvar documentos no FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              não fazer uploads que levariam à "
"substituição de arquivos já existentes\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr ""
"       --no-netrc                   Não tente obter dados do arquivo "
".netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
" -c, --continue                   continuar a leitura de um arquivo "
"parcialmente baixado\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=POSIÇÃO_INICIAL           iniciar a carregamento do "
"conteúdo da posição inicial (considerado como zero)\n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=Tipo            escolher tipo de indicador de progresso\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress             mostrar o indicador de progresso em "
"qualquer modo detalhado\n"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping            não carregue novamente arquivos sem "
"marcação de data e hora, apenas se eles forem mais recentes do que os "
"locais\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"--no-use-server-timestamps    não utilizar a condição if-modified-since para"
" solicitações no modo que considera marcas de tempo do servidor."

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--no-use-server-timestamps   Não usar o timestamp obtido do servidor para "
"marcar este arquivo localmente"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response         Resposta do servidor\n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                    Não baixar nenhum arquivo"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         configuração de todos os timeouts para o "
"número SEGUNDOS especificado\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSA\n"
"         Especifique o(s) servidor(es) DNS desejado(s)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESS   vincular o resolver DNS ao endereço "
"especificado (nome do computador ou IP local) \n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"       --dns-timeout=SECS         configuração do timeout para busca no DNS "
"em SECS segundos\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"       --connect-timeout=SEC     configuração do tempo limite de conexão em "
"SEC segundos\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"       --read-timeout=SEC        configuração do tempo limite de leitura em "
"segundos\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEGUNDOS               pausa de segundos entre as solicitações"
" para carregar mais de um URL\n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS      espera de reenvio entre tentativas de "
"carregamento (quando há mais do que um URL) por SEGUNDOS segundos\n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"--random-wait             pausa aleatória de 0.5*WAIT...1.5*WAIT segundos "
"entre as cargas (quando carregar mais do que 1 URL)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                   Desligue o proxy explicitamente"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=CÓDIGO             definir a quantidade de quota em CÓDIGO "
"bytes\n"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADDRRESS      vincular ADRESS (nome do computador ou "
"IP) local\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED            limitar a SPEED de transferência para "
"evitar sobrecarga do servidor"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "--no-dns-cache             Desligue o cache DNS"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=SYSTEM utilizar em nomes de arquivos "
"caracteres, permitidos no sistema\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"--ignorar-maiúsculas/minúsculas         ignorar maiúsculas e minúsculas ao "
"comparar arquivos ou diretórios."

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr ""
"  -4,  --inet4-only                    conectar apenas a endereços IPv4\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--inet6-only                 conectar apenas a endereços IPv6\n"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar primeiro aos endereços do família"
" especificada (pode ser IPv6, IPv4 ou nenhum) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr ""
"       --user=USUÁRIO                   Configurar o usuário ftp e http para"
" <USUÁRIO> \n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr ""
"       --password=<PASSWORD>         definir ftp e http com a mesma senha "
"<PASSWORD> \n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "--pedir-senha             pedir a senha"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=COMMAND     especificar o gerenciador de mandas para "
"solicitar nome do usuário e senha. Se a COMMAND não for especificada, será "
"utilizado a variável ambiente WGET_ASKPASS  ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                     Desligue o suporte ao IRI\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como codificação local para "
"IRI\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como codificação remota "
"padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                     Remover arquivo antes de desmontar"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash              mantendo arquivos com hashes de controle "
"incorretos (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=%s    Metalink application/metalink4+xml metaurl\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar meta dados Metalink a partir do "
"cabeçalho de resposta HTTP\n"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location        Metalink localização preferida dos "
"recursos"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                      Em arquivos com extensões de atributos, "
"armazenar metadados\n"

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories             não criar pastas\n"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        принудительно создавать каталоги"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr " -nH, --no-host-directories        Não cria diretórios no host\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories       utilizar o nome do protocolo nas "
"pastas\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "  -P,  --directory-prefix=ПРЕФИКС/../\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО componentes de um catálogo "
"remoto\n"

msgid "HTTP options:\n"
msgstr ""
"HTTP 选项：\n"
"%s: %<PRIuMAX> 字段，请求头中必须提供。\n"
"%d: %<PRIuMAX> 字段，请求头中可选的。\n"
"%s: %d 字段，请求头中必须提供的非数值字段。"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=USUÁRIO_HTTP\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr ""
"       --http-password=<PASSWORD>         definir http-senha para <PASSWORD>"
" \n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr ""
"--no-cache                   Não utilizar dados armazenados no servidor."

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=PAISÃO_PADRINA          alterar nome da página por "
"defeito (geralmente é \"index.html\")\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E, --ajustar-extensão           salvar documentos HTML/CSS com extensões "
"apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"--ignorar-tamanho              ignorar o campo de cabeçalho 'Content-Length'"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=STRING          inserir STRING entre cabeçalhos\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TIPO       tipo de compressão: auto, gzip ou none\n"
"                               (por padrão: none)"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          максимально допустимое число перенаправлений "
"на страницу\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USUÁRIO_PROXY   utilizar USUÁRIO_PROXY como nome de "
"usuário para proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PASSWORD   utilizar PASSWORD como a senha para o "
"proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL               Incluir no cabeçalho HTTP do pedido o "
"'Referer: URL'"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENT      identificar como AGENT em vez de Wget/VERSO."

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"--no-http-keep-alive     Desligue o HTTP keep-alive (conexões persistentes)"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                Não utilizar cookies."

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE   carregar cookies a partir de FILE antes do "
"jogo\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão."

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr "        --keep-session-cookies        读取并保存会话 (非永久) cookies。\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING utilizar método POST; envio de STRING como dados."

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILEA\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod     utilizar método \"HTTPMethod\" no cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=STRING           Enviar STRING como dados; \n"
"                               DEVE SER INICIADO com o parâmetro --method\n"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envio do conteúdo de FILE; \n"
"                               DEVE SER INDICADO o parâmetro --method\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   permitir Content-Disposition заголовок при выборе имен файлов локальных\n"
"                               (EXPERIMENTAL)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"       --content-on-error      ao ocorrer erro no servidor, exiba os dados "
"recebidos."

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"--auth-no-challenge         Enviar informações de autenticação sem esperar "
"pelo primeiro reconhecimento do servidor no protocolo HTTP básico."

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR         Selecione o protocolo de segurança: "
"auto, SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr ""
"       --https-only                   apenas por meio de links seguros HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr ""
"--no-check-certificate        Não verificar o certificado do servidor."

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE      Arquivo de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=ТИП   тип сертификата пользователя: PEM або DER."

msgid "       --private-key=FILE          private key file\n"
msgstr ""
"       --private-key=FILE\n"
"        Arquivo de chave privada.\n"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr "       --private-key-type=TYPE   tipo de chave privada: PEM ou DER.\n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr ""
"       --ca-certificate=FILE    arquivo com um conjunto de certificados CA\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=КАТ       каталог, em que é armazenado o hash do "
"certificado CA."

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          arquivo com um conjunto de CRL\n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES   Para verificação do nó, utilize o "
"arquivo com chave pública (PEM/DER) ou qualquer número de hashes sha256 em "
"base64, começando por 'sha256//' e separados por ';'"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE        arquivo com dados aleatórios para "
"inicialização do pseudo-gerador de números aleatórios SSL (PRNG)\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo o soquete EGD com dados "
"aleatórios."

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=СТРОКА         приоритети зробити строку (GnuTLS) або "
"список шифрів (OpenSSL) непосредственно. Будучого використання будь "
"ласкаavel. Значення цього параметра замінить значення --secure-protocol. "
"Формат та синтаксис строки завидуємося від використанняado лише библиотеки "
"SSL/TLS. "

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                    Desabilitar HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho para a base de dados HSTS "
"(sobreescreve o valor padrão)\n"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf                  utilizar o formato Stream_LF para todos "
"os arquivos binários FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr ""
"       --ftp-user=USUÁRIO ftp para definir o nome de usuário do FTP como "
"<USUÁRIO>.\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr ""
"       --ftp-password=<PASSWORD>   definir a senha do ftp como <PASSWORD> \n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "       --no-remove-listing         Não remova arquivos ‘.listing’\n"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"--no-glob                    Desligue a expansão de múltiplos arquivos FTP "
"usando padrões globais\n"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp             Desligue o modo 'passivo' de "
"transferência FTP"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr "--preserve-permissions      保留远程文件的权限"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         durante a recusa, carregar arquivos por meio "
"de links (excluindo diretórios)\n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                  utilizar FTPS (porto padrão — 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"        --ftps-resume-ssl               reiniciar sessão SSL/TLS iniciada no"
" canal de controle, ao abrir o canal de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"       --ftps-clear-data-connection     apenas criptografa o canal de "
"controle; dados transmitidos em texto simples\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"       --ftps-fallback-to-ftp           volte para FTP, se o servidor não "
"suportar FTPS\n"

msgid "WARC options:\n"
msgstr "Parâmetros WARC:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILE_NAME           salvar dados de solicitação/resposta "
"em um arquivo .warc.gz\n"

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr ""
"       --warc-header=STRINGA         inserir STRINGA no início da cópia "
"WARCinfo\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=%<PRIuMAX>     максимального размера файлов WARC "
"равен ЧИСЛУ\n"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr ""
"       --warc-cdx                   escrever em arquivos CDX indexados"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILENAME          Não salvar registros listados no "
"arquivo CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr ""
"       --no-warc-compression        Não utilizar compressão GZIP nos "
"arquivos WARC\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "--no-warc-digests            Não calcule SHA1 de sumário"

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr "--no-warc-keep-log           Não salvar arquivo de log no WARC"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=DIREÇÃO         Diretório de arquivos temporários "
"utilizado pelo WARC escrevendo processo\n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:\n"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive          especificação de carregamento recursivo\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr ""
"  -l,  --level=ЧИСЛО        глубина рекурсивного поиска (inf или 0 — "
"бесконечность, 0 — неограниченное количество)"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr ""
"       --delete-after               Após a conclusão da transferência, "
"remover arquivos locais\n"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
"  -k, --convert-links      transformar links locais em HTML ou CSS "
"carregados\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr ""
"       --convert-file-only          apenas a conversão da parte de arquivo "
"do URL (geralmente chamada de 'nome base' ou basename) \n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                   antes de escrever no arquivo X, fazer rotação "
"em N cópias do arquivo\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
" -K, --backup-converted   antes de converter o arquivo X fazer uma cópia de "
"backup no formato X_orig."

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
" -K, --backup-converted   antes de converter o arquivo X fazer uma cópia de "
"backup no formato X.orig."

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"  -m,  --mirror                    -N -r -l inf --no-remove-listing 的缩写形式。\n"

