msgstr "       --follow-tags=LISTA           separada por vírgula\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignore-tags=LISTA           lista separada por vírgula de tags HTML"
" para ser ignoradas\n"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"  -H,  --span-hosts                    visitando hosts ao longo da "
"recursão\n"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr "  -L,  --relative                   Siga apenas por links relativos\n"

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr "  -I,  --include-directories=LISTA DE CATALOGAS ACEITAS\n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"--trust-server-names utilizar o nome, indicado no URL de redirecionamento "
"final. Usar como último componente do caminho local."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--exclui-diretórios=LISTA DE CATALOGOS EXCLUIDOS\n"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr "  -np, --no-parent                 Não subirá em diretório pai\n"

