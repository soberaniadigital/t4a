msgstr "Не foi possível gravar no arquivo temporário WARC."

msgid "Unable to establish SSL connection.\n"
msgstr "Не foi possível estabelecer conexão SSL."

msgid "Cannot unlink %s (%s).\n"
msgstr "Невозможно удалити %s (%s)."

msgid "ERROR: Redirection (%d) without location.\n"
msgstr "ОШИБКА: перенаправление (%d) без указания адреса."

msgid ""
"Could not find Metalink data in HTTP response. Downloading file using HTTP "
"GET.\n"
msgstr ""
"Не foi possível encontrar dados Metalink na resposta HTTP. O arquivo está "
"sendo baixado utilizando o método GET HTTP."

msgid "Metalink headers found. Switching to Metalink mode.\n"
msgstr "Encontrados os cabeçalhos Metalink. Ainda estamos no modo Metalink."

msgid "Remote file does not exist -- broken link!!!\n"
msgstr "Arquivo remoto não existe -- enlace inválido!"

msgid "Last-modified header missing -- time-stamps turned off.\n"
msgstr ""
"Oculto o cabeçalho 'Last-modified' -- marcadores de tempo desativados."

msgid "Last-modified header invalid -- time-stamp ignored.\n"
msgstr ""
"Заголовок 'Last-modified' -- marca de tempo ignorada. Ainda é possível "
"utilizar o cabeçalho 'Last-accessed', que indica a última vez em que um "
"arquivo foi lido."

msgid ""
"Server file no newer than local file %s -- not retrieving.\n"
"\n"
msgstr ""
"Ficheiro no servidor não é mais recente do que o ficheiro local %s — não "
"será carregado."

msgid "The sizes do not match (local %s) -- retrieving.\n"
msgstr "Размерes dos arquivos não concordam (local %s) - sendo carregado."

msgid "Remote file is newer, retrieving.\n"
msgstr "Arquivo remoto mais recente, sendo carregado."

msgid ""
"Remote file exists and could contain links to other resources -- retrieving.\n"
"\n"
msgstr ""
"Arquivo remoto existente e capaz de conter links para outros recursos - "
"carregando."

msgid ""
"Remote file exists but does not contain any link -- not retrieving.\n"
"\n"
msgstr "Arquivo remoto existente, porém não contém links — não será baixado."

msgid ""
"Remote file exists and could contain further links,\n"
"but recursion is disabled -- not retrieving.\n"
"\n"
msgstr ""
"Arquivo remoto existente e pode conter links adicionais, porém a recorrência"
" está desabilitada -- não é carregado."

msgid ""
"Remote file exists.\n"
"\n"
msgstr "Arquivo remoto existente."

msgid "%s URL: %s %2d %s\n"
msgstr "%s URL: %s %2d %s\n"

msgid ""
"%s (%s) - written to stdout %s[%s/%s]\n"
"\n"
msgstr "%s (%s) - gravado no stdout %s[%s/%s]"

msgid ""
"%s (%s) - %s saved [%s/%s]\n"
"\n"
msgstr "%s (%s) — đã lưu %s [%s/%s]"

