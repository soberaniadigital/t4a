msgstr "%s: Erro no %s na linha %d."

msgid "%s: Syntax error in %s at line %d.\n"
msgstr "%s: Erro de sintaxe no %s na linha %d. \n"

msgid "%s: Unknown command %s in %s at line %d.\n"
msgstr "%s: Comando desconhecido %s na linha %d."

msgid ""
"Parsing system wgetrc file (env SYSTEM_WGETRC) failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo de configuração do sistema wgetrc (env "
"SYSTEM_WGETRC). Tente verificar “%s”, ou especifique outro arquivo usando "
"--config.\n"

msgid ""
"Parsing system wgetrc file failed.  Please check\n"
"'%s',\n"
"or specify a different file using --config.\n"
msgstr ""
"Erro ao processar o arquivo de configuração wgetrc. Por favor, verifique "
"'\\u041e\\u0442\\u043a\\u0446\\u0435 \\u043f\\u0438\\u043c\\u0435\\u0442%s',"
" ou especifique outro arquivo usando --config."

msgid "%s: Warning: Both system and user wgetrc point to %s.\n"
msgstr ""
"%s: Coração de alerta: Ambos os arquivos wgetrc do sistema e do usuário "
"apontam para %s. Para obter mais informações, tente 'wget --help'.\n"

msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Expressão lógica inválida %s; utilize `on' ou `off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: %s không hợp lệ; dùng “on” (bật), “off” (tắt) hay “quiet”.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %d."

msgid "%s: %s must only be used once\n"
msgstr "%s: %s deve ser utilizado apenas uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor byte incorreto para o campo %s\n"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Khoảng thời gian %s sai."

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Chu kỳ thời gian âm %s. \n"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para o uso de askpass é necessário uma string ou variável ambiente "
"WGET_ASKPASS ou SSH_ASKPASS. configurada."

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor %s inválido. (Não é um valor válido.)"

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: Неверный заголовок %s.\n"

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr "%s: %s: O título WARC não é válido %s. \n"

msgid "%s: %s: Invalid progress type %s.\n"
msgstr ""
"%s: %s: Tipo de progresso %s inválido. Por favor, verifique seu código para "
"garantir que o tipo correto seja utilizado."

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição de uso do comando '%c' não permitida, utilize "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "Codificação %s inválida"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O conversor de %s para %s não está suportado"

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência multibyte incompleta ou inválida."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado de %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: local não está configurada"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no codificador idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "falha na conversão para letras minúsculas: %d: %s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; desligando a captura de logs. (logging is disabled)."

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "CÓDIGO DE UTILIZAÇÃO: %s [PARÂMETRO]... [URL]..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para os parâmetros longos também são obrigatórios"
" para os parâmetros curtos."

msgid "Startup:\n"
msgstr "Khởi động:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr ""
"  -V,  --version                   Mostrar a versão do Wget e encerrar o "
"trabalho."

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help              Mostrar esta ajuda."

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do processamento iniciar no modo "
"de fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr "  -e,  --execute=COMMAND   executar uma instrução no estilo `.wgetrc`\n"

msgid "Logging and input file:\n"
msgstr "Jornalização e ficheiros de registo e entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrever mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=%s     adicionar mensagens ao final do arquivo %s\n"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                     exibir uma grande quantidade de "
"informações para depuração."

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "im lặng (không kết xuất ra màn hình)."

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr ""
"  -v,  --verbose                   habilitar a saída detalhada (por padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose          Desligue o modo detalhado sem deixar de "
"imprimir informações parciais (sem ser silencioso)"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=ТИП    единицы измерения пропускной способности\n"
"                             определить ТИПОМ. ТИП может быть равно bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos listados no FILE Metalink "
"local\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considera que o arquivo de entrada é HTML."

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL            considerar que as ligações do arquivo de "
"entrada (-i -F) são relativas à URL especificada\n"

msgid "       --config=FILE               specify config file to use\n"
msgstr ""
"       --config=%s         especifique o arquivo de configuração a ser "
"utilizado\n"

msgid "       --no-config                 do not read any config file\n"
msgstr ""
"       --no-config                      não ler ficheiros de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registra as razões para rejeição de URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             definir ЧИСЛО tentativas (0 = sem limite)\n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused         tentar novamente mesmo que a conexão seja"
" negada."

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error     considera erros de host como não críticos e"
" aleatórios, os transitórios em vez dos fatais."

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"       --retry-on-http-error=ERROS    lista separada por vírgula de erros "
"HTTP para reintenta\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr ""
"  -O,  --output-document=FILE    escrever documentos neste arquivo FILE\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              ignora as cargas que levariam à "
"sobreescrita de arquivos já existentes\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr "       --no-netrc                  não tentar obter dados do .netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                  continue a transferência parcial de um "
"arquivo em processo."

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=СМЕЩЕНИЯ      iniciar a transferência de dados desde a "
"posição da região (considerada como zero) \n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIPO            escolher tipo de indicador de progresso."

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress           mostrar o indicador de progresso em "
"qualquer modo de detalhamento"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping              não carrega arquivos repetidos, apenas se"
" forem mais novos que os locais."

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"       --no-use-server-timestamps    não utilizar a verificação if-modified-"
"since para solicitações no modo de contagem de marcação do tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"       --no-use-server-timestamps   não usar marcação de tempo local para o "
"arquivo, baseado no horário do servidor. \n"

msgid "  -S,  --server-response           print server response\n"
msgstr ""
"  -S,  --server-response         Resposta do servidor para solicitações de "
"cliente. \n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                    nenhum download para carregar."

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEKUNDOS         definir todos os valores de tempo igual ao"
" número SEKUNDOS. \n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSES      lista de servidores DNS a serem "
"consultados (separados por vírgula)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE_DNS  vincular o endereço DNS ao ADRESSE "
"especificada (nome do computador ou IP) localmente\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr "--dns-timeout=СЕК  instalação do timeout para busca no DNS em СЕК\n"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"--connect-timeout=СЕК     configuração do tempo de espera para conexão com o"
" soquete em СЕК."

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=СЕК  define a temporização de leitura em СЕК."

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w,  --wait=SEGUNDOS            pausa de tantos SEGUNDOS entre as "
"tentativas de carregamento (aplicável se mais do que uma URL forem baixadas)"
" \n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEKUNDOS       pausa de 1..SEKUNDOS entre tentativas "
"repetidas de carregamento (quando mais do que uma URL for baixada) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --random-wait             pausa de 0.5*WAIT...1.5*WAIT segundos entre"
" as cargas (quando mais do que uma URL for carregada)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                  explicitamente desconecta o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=ЧИСЛО             establecer a quantia da quota de upload em "
"ЧИСЛО\n"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADRESS\n"
"                                 local host computer\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED     limitar a SPEED de transferência para este "
"endereço."

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr ""
"       --no-dns-cache              desligue o cache DNS para consultas. \n"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS    limitar caracteres no nome do arquivo a "
"aqueles aceitos pela OS\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             não levar em consideração o caso da letra "
"ao comparar arquivos e/ou pastas\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "  -4,  --inet4-only              conectar apenas a endereços IPv4. \n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr ""
"chave -6, --inet6-only                conectar apenas a endereços IPv6."

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar primeiro aos endereços do grupo "
"especificado (pode ser IPv6, IPv4 ou nenhum) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr ""
"       --user=POLIZOTEUEL            instalar e ftp- e http-usuário para o "
"POLIZOTEUEL\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr ""
"       --password=ПАРОЛЬ         установить ftp- и http-пароль в ПАРОЛЬ\n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "       --ask-password              solicitar senhas. \n"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=CHAMAR          especificar o manejador de senhas para "
"solicitar nome do usuário e senha. Se nenhuma chamada for definida, será "
"utilizado a variável ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "       --no-iri                    desligue o suporte IRI."

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=BẢNG-MẦU      utilizar BẢNG-MẦU como a codificação "
"local para IRI. \n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como codificação remota por "
"padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr ""
"       --unlink                    apagar arquivo antes de sobrescrever."

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash              mantenha os arquivos com hashes de "
"verificação incorretos (adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=NOME        NOME na ordem Metalink "
"aplicação/metalink4+xml metaurl\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http      utilizar dados de Metalink HTTP usando "
"cabeçalhos da resposta"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location      localização preferida para os recursos "
"Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                    ativar o armazenamento de metadados nos "
"extensores dos arquivos virtuais\n"

msgid "Directories:\n"
msgstr "Catálogos:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories            não criar pastas."

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr "--force-directories        принудительно создавать каталоги"

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr "  -nH, --no-host-directories      não cria diretórios no host."

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories      utilizar o nome do protocolo nos "
"diretórios."

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "  -P,  --directory-prefix=ПРЕФИКС  salvar arquivos no ПРЕФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО componentes de catálogo "
"remoto\n"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "       --http-user=ПОЛЬЗОВ.       辨别 http-пользователя в ПОЛЬЗОВАТЕЛЬ\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "       --http-password=ПАРОЛЬ  установить http-пароль в ПАРОЛЬ\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "       --no-cache              ignorar dados cacheados do servidor\n"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=ÍMÊN      alterar o nome da página por defeito "
"(geralmente é \"index.html\")\n"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E,  --adjust-extension      salvar documentos HTML/CSS com as extensões "
"apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"       --ignore-length             ignorar o campo `Content-Length' nas "
"cabeceras\n"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=%s              inserir STRING entre os cabeçalhos. \n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TIPO         escolha do método de compressão entre "
"auto, gzip e none. (por padrão: none)\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          максимально допустимое число перенаправлений "
"на страницу\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=POLZOV.   utilizar POLZOV como nome de usuário para "
"proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLI    utilizar PAROLI como senha para o proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           inclui no pedido HTTP o cabeçalho 'Referer: "
"URL'."

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGENTE       utilizar este đại diện para substituir "
"Wget/VERSIÓN. \n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"       --no-http-keep-alive        desligue o HTTP keep-alive (conexões "
"persistentes) \n"

msgid "       --no-cookies                don't use cookies\n"
msgstr "       --no-cookies                sem usar cookies."

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies a partir do FILE antes de "
"iniciar o trabalho."

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      salvar e carregar cookies de sessão (não "
"permanentes)\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=СТРОКА      використовувати метод POST; enviar СТРОКИ "
"como дані. \n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio do conteúdo da "
"FILEA\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod         utilizar método \"HTTPMethod\" no "
"cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      отправка СТРОКИ в качестве данных; \n"
"                               ДЕЛИ ВЯЖНО БУДЕТ ĐЕジТЕР --method"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envóvel o conteúdo do FILE; \n"
"                               DEVE ser usado o parâmetro --method."

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   considerar o cabeçalho Content-Disposition\n"
"                               ao escolher nomes para arquivos locais (EXPERIMENTAL)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"       --content-on-error      exibe os dados recebidos em caso de erro do "
"servidor. \n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"       --auth-no-challenge     enviar informações sobre autenticação HTTP "
"Basic sem esperar pelo desafio do servidor\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR        escolha do protocolo de segurança, uma "
"das opções disponítable são auto, SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, "
"TLSv1_3 ou PFS."

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr ""
"       --https-only             transfetando apenas por conexões seguras "
"HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr ""
"       --no-check-certificate      não verificar o certificado do servidor "
"virtual\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "       --certificate=FILE       ficheiro de certificado do usuário\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=TIPO   tipo de certificado do usuário: PEM ou "
"DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr "       --private-key=FILE       ficheiro de chave privada\n"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr ""
"       --private-key-type=TIPO   tipo de chave privada secreta: PEM ou DER. "
"\n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr "       --ca-certificate=FILE    ficheiro com a agrupamento de CAs\n"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"       --ca-directory=КАТ       thư mục chứa danh sách mã băm của CA. (Note:"
" 'КАТ' is a placeholder for the actual directory path and should be replaced"
" with the appropriate value.)"

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          arquivo com o conjunto de CRLs\n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES  Arquivo de chave pública (PEM/DER), o "
"qual pode conter um ou mais hashes sha256 codificados como base64, "
"precedidos por 'sha256//' e separados por ';', para verificar contra a "
"entrada"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr ""
"       --random-file=FILE       ficheiro com dados aleatórios para gerar a "
"PRNG SSL."

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"       --egd-file=FILE          arquivo, definindo soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=СТРОКА         назначить строку приоритета (GnuTLS) или "
"список шифров (OpenSSL) непосредственно. Использовать осторожно. Данный "
"параметр заменяет значение --secure-protocol. Формат и синтаксис строки "
"зависят от используемой библиотеки SSL/TLS. \n"

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "       --no-hsts                   desligue HSTS\n"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"       --hsts-file             caminho da base de dados HSTS (substituir o "
"valor padrão)"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"arquivos binários FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr ""
"       --ftp-user=POLZOWATEL        utilizar POLZOWATEL nesta instância para"
" autenticar no FTP\n"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "       --ftp-password=ПАРОЛЬ   установить ftp-пароль в ПАРОЛЬ\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr ""
"       --no-remove-listing         não remova a lista de arquivos "
"“.listing”\n"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"       --no-glob                   desligue o globbing para nomes de "
"arquivos FTP."

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"       --no-passive-ftp            desligue o modo 'pasivo' de "
"transferência\n"

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"--preserve-permissions      preserva permissões de acesso aos arquivos "
"remotos."

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"       --retr-symlinks         quando recursiva, carregar arquivos por links"
" (não catálogos) \n"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"       --ftps-implicit                 utilizar FTPS implicitamente (porta "
"padrão é a 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"       --ftps-resume-ssl               reanuda a sessão SSL/TLS iniciada no "
"canal de controle, ao abrir o canal de dados\n"

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"       --ftps-clear-data-connection    apenas criptografa o canal de "
"controle; os dados não são criptografados\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"       --ftps-fallback-to-ftp          retorna ao FTP, se o FTPS não estiver"
" disponível no servidor\n"

msgid "WARC options:\n"
msgstr "Parâmetros WARC:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"       --warc-file=FILENAME          salvar dados dos pedidos e respostas em"
" um arquivo .warc.gz."

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr ""
"       --warc-header=STRING        inserta STRING no cabeçalho warcinfo\n"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=ЧИСЛО     максимального размеу файлів WARC равен "
"ЧИСЛУ"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "       --warc-cdx                  salvar arquivos indexados CDX."

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILENAME        não salvar registros listados no arquivo"
" CDX neste caso."

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr ""
"       --no-warc-compression      não comprime arquivos WARC com GZIP."

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr "       --no-warc-digests           não calcula resumos SHA1."

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr ""
"       --no-warc-keep-log        não salvar o arquivo de log nas entradas "
"WARC."

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"       --warc-tempdir=CATALOG    localização para arquivos temporários, "
"criados pela ferramenta de gravação WARC. \n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "  -r,  --recursive          включение рекурсивной загрузки"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr ""
"  -l,  --level=ЧИСЛО        глубина рекурсивної (inf або 0 - неогративно) \n"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr ""
"       --delete-after              apaga arquivos locais após a "
"transferência concluída. \n"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
"  -k,  --convert-links      transformar links em locais no HTML ou CSS carregado\n"
"                            para localizações dentro do diretório de destino.\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr ""
"       --convert-file-only         chamecer somente a parte do arquivo de "
"uma URL (geralmente conhecida como o basename) \n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                      antes de escrever o arquivo X, rota até um máximo N de cópias. \n"
"\t(Respeitando os backups é uma boa prática para evitar a perda do seu trabalho.)"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X, fazer uma cópia "
"em formato X_orig. \n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
"  -K,  --backup-converted   antes de converter o arquivo X, fazer uma cópia "
"de backup no formato X.orig\n"

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"  -m,  --mirror             Короткий параметр, equivalente ao \n"
"                            “-N -r -l inf --no-remove-listing”.\n"

msgid ""
"  -p,  --page-requisites           get all images, etc. needed to display "
"HTML page\n"
msgstr ""
"  -p,  --page-requisites    carregar todas as imagens e outros elementos "
"necessários para a exibição da página HTML."

msgid ""
"       --strict-comments           turn on strict (SGML) handling of HTML "
"comments\n"
msgstr ""
"       --strict-comments           ative o tratamento rigoroso (SGML) dos "
"comentários no HTML. \n"

msgid "Recursive accept/reject:\n"
msgstr ""
"Permissões/proibições para recursão: \n"
"\n"
"'Chápar nhận/từ chối recursivamente (ES): Se o arquivo for encontrado, ele será processado. Caso contrário, uma mensagem de erro será exibida.\n"
"\n"
"'Acepta/rechaza recursivamente (VI): A permissão para acessar e trabalhar com um determinado caminho ou diretório é concedida se o arquivo for encontrado. Caso contrário, uma mensagem de erro será exibida.\n"
"\n"
"'Chấp nhận/từ chối đệ quy (VI): Se um bloco estiver definido para aceitar ou rejeitar recursivamente a entrada do usuário, ele fará o mesmo. Caso contrário, uma mensagem de erro será exibida.\n"
"\n"
"'Acepta/rechaza recursivamente (VI): A permissão para trabalhar com um determinado caminho ou diretório é concedida se o arquivo for encontrado. Caso contrário, uma mensagem de erro será exibida."

msgid ""
"  -A,  --accept=LIST               comma-separated list of accepted "
"extensions\n"
msgstr ""
"  -A,  --accept=LIST\n"
"                                     Để mở rộng danh sách phần đuôi của bạn. Lựa chọn trong tìm kiếm vào.\n"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr ""
"  -R,  --reject=LIST                 lista separada por vírgulas de "
"extensões rechazadas\n"

msgid "       --accept-regex=REGEX        regex matching accepted URLs\n"
msgstr ""
"       --accept-regex=РЕГВЫР       регулярное выражение для разрешённых URL"

msgid "       --reject-regex=REGEX        regex matching rejected URLs\n"
msgstr ""
"       --reject-regex=РЕГВЫР       регулярное выражение для запрещённых URL"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr "       --regex-type=TIPO_REGEX           tipo de regex (posix|pcre) \n"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr ""
"       --regex-type=TIPO            tipo de biểu thức regular (posix) \n"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr ""
"  -D,  --domains=СПИСОК            списки разрешённых доменов, через "
"запятую\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr ""
"       --exclude-domains=СПИСОК    список запрещённых доменів, через "
"запятую\n"

msgid ""
"       --follow-ftp                follow FTP links from HTML documents\n"
msgstr ""
"       --follow-ftp                theo lien ket FTP tao link document HTML"

msgid ""
"       --follow-tags=LIST          comma-separated list of followed HTML "
"tags\n"
msgstr ""
"       --follow-tags=LIST          lista separada por vírgula de etiquetas "
"HTML a seguir\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignore-tags=LIST          lista separada por vírgula de etiquetas "
"HTML a ignorar\n"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"  -H,  --span-hosts                já visita máquinas externas durante a "
"recursão\n"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr "  -L,  --relative                  chame apenas links relativos"

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr "  -I,  --include-directories=СПИСОК список разрешённых каталогов\n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"  --trust-server-names             utilizar o nome, indicado no URL de "
"redirecionamento final\n"

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "  -X,  --exclude-directories=%s\n"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr "  -np, --no-parent                 não subir no diretório pai\n"

msgid ""
"Email bug reports, questions, discussions to <bug-wget@gnu.org>\n"
"and/or open issues at https://savannah.gnu.org/bugs/?func=additem&group=wget.\n"
msgstr ""
"Envie mensagens sobre erros, perguntas e sugestões para <bug-wget@gnu.org> \n"
