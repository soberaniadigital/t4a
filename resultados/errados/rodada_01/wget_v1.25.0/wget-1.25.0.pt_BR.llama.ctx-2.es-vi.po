msgstr ""
"Símbolos de ligação não são suportados, a ligação simbólica %s é ignorada."

msgid "Skipping directory %s.\n"
msgstr "Borra o diretório %s."

msgid "%s: unknown/unsupported file type.\n"
msgstr ""
"%s: tipo de arquivo desconhecido/não suportado. (unknown file type not "
"supported)"

msgid "Failed to set permissions for %s.\n"
msgstr "Não foi possível definir permissões para %s."

msgid "%s: corrupt time-stamp.\n"
msgstr ""
"%s: marca de data/tempo corrupta. (dado que a linha %<PRIuMAX> possui "
"%<PRIuMAX> campos, esperando %<PRIuMAX>)"

msgid "Will not retrieve dirs since depth is %d (max %d).\n"
msgstr ""
"Categorias não serão carregadas, devido à profundidade atingir %d (máximo de"
" %d)."

msgid "Not descending to %s as it is excluded/not-included.\n"
msgstr ""
"Acesso ao diretório \"%s\" não é permitido, pois ele está excluído/no-"
"incluso."

msgid "Rejecting %s.\n"
msgstr "Từ chối %s."

msgid "Rejecting %s (Invalid Entry).\n"
msgstr "O elemento %s é inválido (elemento incorreto)."

msgid "%s is excluded/not-included through regex.\n"
msgstr ""
"%s bị loại trừ hoặt không được bao gồm thông qua biểu thức. (regex "
"exclusion)"

msgid "Error matching %s against %s: %s\n"
msgstr "Lỗi khớp %s với %s: %s"

msgid "No matches on pattern %s.\n"
msgstr "Não há nada que se ajuste ao padrão %s."

msgid "Wrote HTML-ized index to %s [%s].\n"
msgstr "Índice no formato HTML foi escrito em %s [%s]."

msgid "Wrote HTML-ized index to %s.\n"
msgstr "Índice em formato HTML gravado no arquivo \"%s\"."

msgid "ERROR: Cannot open directory %s.\n"
msgstr "ОШИБКА: não foi possível abrir o diretório %s."

msgid "ERROR: Failed to open cert %s: (%d).\n"
msgstr "ОШИБКА: Erro ao abrir certificado %s: (%d).\n"

msgid "Loaded CA certificate '%s'\n"
msgstr "Certificado CA carregado com o nome \"%s\""

