"Could not find acceptable digest for Metalink resources.\n"
"Ignoring them.\n"
msgstr ""
"Немогла-ся encontrar хэш-сумму (digest) apropriada para os recursos "
"Metalink. Ignorando."

msgid "Disabling SSL due to encountered errors.\n"
msgstr "O SSL foi desabilitado devido às falhas encontradas."

msgid "%s request sent, awaiting response... "
msgstr "Petição %s enviada, esperando resposta... "

