msgstr "Ficheiro CRL carregado “%s”"

msgid "ERROR: GnuTLS requires the key and the cert to be of the same type.\n"
msgstr ""
"ERRO: Para GnuTLS é necessário o par chave/certificado de um único tipo."

msgid "Your GnuTLS version is too old to support TLS 1.3\n"
msgstr ""
"A versão do GnuTLS que você está utilizando é muito antiga para suportar o "
"TLS 1.3."

msgid "GnuTLS: unimplemented 'secure-protocol' option value %u\n"
msgstr "GnuTLS: valor do parâmetro \"secure-protocol\" não está implementado %u"

msgid "Please report this issue to bug-wget@gnu.org\n"
msgstr ""
"Comunique-se sobre esta falha por meio do endereço de correio <bug-"
"wget@gnu.org>."

msgid "GnuTLS: unimplemented 'secure-protocol' option value %d\n"
msgstr ""
"GnuTLS: valor %d do parâmetro 'secure-protocol' não está implementado."

msgid ""
"GnuTLS: Cannot set prio string directly. Falling back to default priority.\n"
msgstr ""
"GnuTLS: não é possível definir a string de prioridade diretamente. "
"Retornamos ao padrão de prioridade por implicação."

msgid "ERROR"
msgstr "ОШИБКА"

msgid "WARNING"
msgstr "PREDÚPRAZDENÍE"

msgid "%s: No certificate presented by %s.\n"
msgstr ""
"%s: Não há certificado apresentado por %s. (No original, 'VI' and '%s' were "
"placeholders for the user input.)"

msgid "%s: The certificate of %s is not trusted.\n"
msgstr ""
"%s: Não há confiança no certificado para %s. A autenticidade do certificado "
"não pode ser verificada."

msgid "%s: The certificate of %s doesn't have a known issuer.\n"
msgstr ""
"%s: Não foi possível identificar o emissor do certificado %s. Por favor, "
"verifique novamente ou informe ao suporte técnico."

msgid "%s: The certificate of %s has been revoked.\n"
msgstr "%s: Certificado para %s revogado. (certidão de %s cancelado)."

msgid "%s: The certificate signer of %s was not a CA.\n"
msgstr "%s: O certificado assinado por %s não foi encontrado no UC."

msgid "%s: The certificate of %s was signed using an insecure algorithm.\n"
msgstr ""
"%s: Para assinar o certificado %s foi utilizado um algoritmo de criptografia"
" não seguro. Por favor, use um método mais confiável para garantir a "
"integridade do seu documento."

msgid "%s: The certificate of %s is not yet activated.\n"
msgstr ""
"%s: Certificado %s ainda não está ativado. (Certificate still not "
"activated.)"

msgid "%s: The certificate of %s has expired.\n"
msgstr ""
"%s: O certificado de %s expirou. A data limite do mesmo é agora passada."

msgid "Error initializing X509 certificate: %s\n"
msgstr "Erro na inicialização do certificado X509: %s"

