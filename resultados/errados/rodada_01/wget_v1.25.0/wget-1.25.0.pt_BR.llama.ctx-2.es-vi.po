msgstr "O proprietário do certificado não corresponde ao nome da máquina %s"

msgid "The public key does not match pinned public key!\n"
msgstr "Chave pública não corresponde à chave encadeada!"

msgid "Certificate must be X.509\n"
msgstr "O certificado deve ser X.509"

msgid "Error in handling the address list.\n"
msgstr ""
"Erro ao processar a lista de endereços. Lembre-se, se você encontrar "
"problemas com listas de endereços no futuro, consulte o manual do usuário."

msgid "Unknown host"
msgstr "nó desconhecido"

msgid "Temporary failure in name resolution"
