msgid "%s: Certificate verification error for %s: %s\n"
msgstr "%s: Ошибка проверки сертификата для %s: %s\n"

msgid "%s (%s) - Connection closed at byte %s/%s. "
msgstr "%s (%s) - Соединение закрыто, позиция %s/%s. "
