msgstr "Autenticidade escolhida: %s"

msgid "Saving to: %s\n"
msgstr "Gravar no: %s\n"

msgid ""
"When downloading signature:\n"
"%s: %s.\n"
msgstr "Durante o download da assinatura: %s: %s."

