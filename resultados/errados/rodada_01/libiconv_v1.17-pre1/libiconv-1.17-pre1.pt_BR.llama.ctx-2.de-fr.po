msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr ""
"Utilização: iconv [-c] [-s] [-f codificação_entrada] [-t codificação_saida] "
"[arquivo ...]"

msgid "or:    iconv -l"
msgstr "ou: iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente '%s --help' para mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr "Uso: %s [OPÇÃO...] [-f ENCODING] [-t ENCODING] [ARQUIVO_DE...]\n"

msgid "or:    %s -l\n"
msgstr "ou:    %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converta o texto de um código para outro código."

msgid "Options controlling the input and output format:\n"
msgstr "Opções para controlar o formato de entrada e saída:\n"

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
" -f ENCODING, --from-code=ENCODING\n"
"                           Codificação de entrada"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              codificação de saída"

msgid "Options controlling conversion problems:\n"
msgstr ""
"Opções para controlar a conversão de caracteres: \n"
"\t'%s': Converta todos os caracteres em maiúsculas; \n"
"\t'%d': Limite o número máximo de caracteres convertidos por linha à quantidade especificada pelo usuário. Se houver mais, eles serão truncados sem perder a última parte da entrada.\n"

msgid "  -c                          discard unconvertible characters\n"
msgstr " -c                           esquecer caracteres não convertíveis"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"--unicode-subst=FORMATSTRING\n"
"                              Substituição para caracteres Unicode não convertíveis."

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=FORMATSTRING    Substituição para bytes não convertíveis em "
"caracteres"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=FORMATSTRING\n"
"                              Substituição para caracteres largos não convertíveis."

msgid "Options controlling error output:\n"
msgstr "控制错误输出的选项:\n"

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
" -s, --silent                 não exibir mensagens relacionadas aos erros de"
" conversão\n"

msgid "Informative output:\n"
msgstr "Informações de saída:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   lista as codificações suportadas"

msgid "  --help                      display this help and exit\n"
msgstr ""
" --help                       Mostra este mensagem de ajuda e termina o "
"programa."

msgid "  --version                   output version information and exit\n"
msgstr "--versao                    Mostrar informações de versão e sair\n"

msgid ""
"Report bugs in the bug tracker at <%s>\n"
"or by email to <%s>.\n"
msgstr ""
"Por favor, envie o relatório de erro para o sistema de rastreamento do bug "
"<%s> ou por e-mail para <%s>. Para reportar problemas com a tradução, "
"escreva ao <traduc@traduc.org>."

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL versão 3 ou posterior <%s> \n"
"Este software é livre: você pode modificá-lo e redistribuí-lo. \n"
"Não há garantias, dentro dos limites legais permitidos."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr ""
"%s argumento: Uma diretiva de format com largura variável não é permitida "
"aqui."

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr ""
"%s argumento: Uma diretiva de formato com precisão fixa não é permitida "
"aqui."

msgid "%s argument: A format directive with a size is not allowed here."
msgstr ""
"%s argumento: Uma diretiva de formato que inclui tamanho não é permitida "
"aqui."

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s argumento: a string termina no meio de uma instrução."

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr ""
"%s argumento: o caractere '\\%c' não é um especificador de conversão válido."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"%s argumento: O caractere que termina o formato não é um especificador de "
"conversão válido."

msgid ""
"%s argument: The format string consumes more than one argument: %u argument."
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não pode converter os bytes de substituição para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"não pode converter as substituições Unicode para o código de saída "
"especificado: %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr ""
"não pode converter os bytes de substituição em uma string aninhada: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"não pode converter os caracteres anchos de substituição no codificador "
"desejado: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr ""
"não pode converter os bytes de substituição para o código de saída "
"especificado: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%u:%u: não pode converter."

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: caractere incompleto ou sequência de deslocamento"

msgid "%s:%u:%u"
msgstr "%s:%u:%u"

msgid "%s: I/O error"
msgstr "%s: erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "a conversão a partir de %s não é suportada."

msgid "conversion to %s unsupported"
msgstr "a conversão para %s não é suportada."

msgid "conversion from %s to %s unsupported"
msgstr "conversão de %s para %s não é suportada."

msgid "try '%s -l' to get the list of supported encodings"
msgstr "Tente usar '\\%s -l' para obter a lista de codificações suportadas."

msgid "(stdin)"
msgstr "(entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "erro de entrada/saída"

msgid "Report bugs to <bug-gnu-libiconv@gnu.org>.\n"
msgstr "Por favor, relata os erros de software para <%s>.\n"
