msgid "Usage: iconv [-c] [-s] [-f fromcode] [-t tocode] [file ...]"
msgstr "Modo de uso: iconv [-c] [-s] [-f desde] [-t até] [arquivo ...]"

msgid "or:    iconv -l"
msgstr ""
"ou:\n"
"iconv -l"

msgid "Try '%s --help' for more information.\n"
msgstr "Tente `%s --help' para mais informações."

msgid "Usage: %s [OPTION...] [-f ENCODING] [-t ENCODING] [INPUTFILE...]\n"
msgstr ""
"Modo de uso: %s [Opção...] [-f ENCODING] [-t ENCODING] [FicheiroEntrada...]"

msgid "or:    %s -l\n"
msgstr "ou seja: %s -l\n"

msgid "Converts text from one encoding to another encoding.\n"
msgstr "Converta o texto de uma codificação para outra."

msgid "Options controlling the input and output format:\n"
msgstr ""
"Opciones para controlar el formato de entrada y salida:\n"
"\t--espacio (%s): %d espaços por linha.\n"
"\t--tabulação (%s): tabulador em vez do caractere padrão."

msgid ""
"  -f ENCODING, --from-code=ENCODING\n"
"                              the encoding of the input\n"
msgstr ""
"  -f ENCODING, --from-code=ENCODING\n"
"                               Codificação de entrada"

msgid ""
"  -t ENCODING, --to-code=ENCODING\n"
"                              the encoding of the output\n"
msgstr ""
"  -t ENCODING, --to-code=ENCODING\n"
"                               Codificação de saída"

msgid "Options controlling conversion problems:\n"
msgstr ""
"Opciones para controlar los problemas de conversión:\n"
"\t--especializadas %s (conversor especializado)\n"
"\t--verbose %d (verboso, detalhado)\n"

msgid "  -c                          discard unconvertible characters\n"
msgstr " -c                          descarta caracteres não convertíveis"

msgid ""
"  --unicode-subst=FORMATSTRING\n"
"                              substitution for unconvertible Unicode characters\n"
msgstr ""
"--unicode-subst=CADENADEFORMATO\n"
"                              substituição para os caracteres Unicode não convertíveis"

msgid "  --byte-subst=FORMATSTRING   substitution for unconvertible bytes\n"
msgstr ""
"--byte-subst=CADENADEFORMATO sustituição para os bytes não convertíveis\n"

msgid ""
"  --widechar-subst=FORMATSTRING\n"
"                              substitution for unconvertible wide characters\n"
msgstr ""
"--widechar-subst=CADENADEFORMATO\n"
"                              substituição para caracteres anchos não convertíveis"

msgid "Options controlling error output:\n"
msgstr ""
"Opciones para controlar la salida de errores:\n"
"\t--verbose (mostrar detalles)\n"
"\t--logto FILENAME (guardar logs en el archivo especificado)\n"
"\t--quiet (reducir verbosidad, mostrar solo mensajes críticos)\n"

msgid ""
"  -s, --silent                suppress error messages about conversion "
"problems\n"
msgstr ""
" -s, --silent                 não exibir mensagens relacionadas a erros de "
"conversão"

msgid "Informative output:\n"
msgstr "Salida informativa:"

msgid "  -l, --list                  list the supported encodings\n"
msgstr "  -l, --list                   lista das codificações admitidas"

msgid "  --help                      display this help and exit\n"
msgstr " --help                       mostra esta ajuda e sai\n"

msgid "  --version                   output version information and exit\n"
msgstr "--versao                    Mostra a versão e sai\n"

msgid ""
"Report bugs in the bug tracker at <%s>\n"
"or by email to <%s>.\n"
msgstr ""
"Por favor, envie o relatório de erro para a ferramenta de rastreamento do "
"bug <%s> ou por e-mail para <%s>. Além disso, envia os relatórios de "
"tradução incorretos para o email da lista internacional em chinês "
"(i18n-zh@googlegroups.com)."

msgid ""
"License GPLv3+: GNU GPL version 3 or later <%s>\n"
"This is free software: you are free to change and redistribute it.\n"
"There is NO WARRANTY, to the extent permitted by law.\n"
msgstr ""
"Licença GPLv3+: GNU GPL Versão 3 ou posterior <http://gnu.org/licenses/gpl.html> \n"
"Este software é livre: você pode modificá-lo e redistribuí-lo sob essa licença.\n"
"Nenhuma garantia, além do que a lei permite."

msgid "Written by %s.\n"
msgstr "Escrito por %s."

msgid ""
"%s argument: A format directive with a variable width is not allowed here."
msgstr ""
"argumento %s: Não é permitido um especificador de formato com largura "
"variável."

msgid ""
"%s argument: A format directive with a variable precision is not allowed "
"here."
msgstr ""
"%s argumento: Não é permitido um especificador de formato com precisão "
"variável."

msgid "%s argument: A format directive with a size is not allowed here."
msgstr ""
"argumento %s: Não é permitido um especificador de formato com tamanho."

msgid "%s argument: The string ends in the middle of a directive."
msgstr "%s argumento: a string termina no meio de um especificador."

msgid "%s argument: The character '%c' is not a valid conversion specifier."
msgstr ""
"%s argumento: O carácter '%c' não é um especificador de conversão válido."

msgid ""
"%s argument: The character that terminates the format directive is not a "
"valid conversion specifier."
msgstr ""
"%s argumento: O carácter que termina a diretiva de formato não é um "
"especificador válido de conversão."

msgid ""
"%s argument: The format string consumes more than one argument: %u argument."
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "cannot convert byte substitution to Unicode: %s"
msgstr "não é possível converter as substituições de bytes para Unicode: %s"

msgid "cannot convert unicode substitution to target encoding: %s"
msgstr ""
"não é possível converter os caracteres unicode para a codificação alvo: %s"

msgid "cannot convert byte substitution to wide string: %s"
msgstr "não é possível converter os bytes para uma string aninhada: %s"

msgid "cannot convert widechar substitution to target encoding: %s"
msgstr ""
"não é possível converter o caractere ancho para a codificação alvo: %s"

msgid "cannot convert byte substitution to target encoding: %s"
msgstr "não foi possível converter os bytes para a codificação alvo: %s"

msgid "%s:%u:%u: cannot convert"
msgstr "%s:%d:%d: não é possível converter"

msgid "%s:%u:%u: incomplete character or shift sequence"
msgstr "%s:%d:%d: carácter o secuencia de desplazamiento incompleta"

msgid "%s:%u:%u"
msgstr "%s:%d:%d"

msgid "%s: I/O error"
msgstr "%s: erro de entrada/saída"

msgid "conversion from %s unsupported"
msgstr "não é admitido a conversão de %s"

msgid "conversion to %s unsupported"
msgstr "não é suportado a conversão para %s"

msgid "conversion from %s to %s unsupported"
msgstr "não é admitido a conversão de %s para %s"

msgid "try '%s -l' to get the list of supported encodings"
msgstr "Tente usar ‘%s -l’ para obter a lista de codificações suportadas."

msgid "(stdin)"
msgstr "(entrada padrão)"

msgid "%s"
msgstr "%s"

msgid "I/O error"
msgstr "erro de entrada/saída"

msgid "Report bugs to <bug-gnu-libiconv@gnu.org>.\n"
msgstr ""
"{'original_text': ['请向 <%s> 报告软件错误。', '请向 <i18n-zh@googlegroups.com> "
"报告翻译错误。'], 'translated_text': ['Comunicar erros de software a <bug-gnu-"
"libiconv@gnu.org>.', 'Comunicar erros de tradução para o grupo i18n-zh do "
"Google Groups.']}"
