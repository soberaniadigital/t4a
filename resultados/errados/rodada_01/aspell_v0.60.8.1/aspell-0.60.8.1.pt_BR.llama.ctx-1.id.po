msgstr "O termo 'Kata %word:1' não é válido."

msgid "The affix flag '%aff:1' is invalid for word \"%word:2\"."
msgstr ""
"O prefixo de terminação 'affix %aff:1' não é válido para o sufixo '%word:2'."

msgid "The affix flag '%aff:1' can not be applied to word \"%word:2\"."
msgstr ""
"O prefixo de terminação 'affix %aff:1' não pode ser aplicado ao termo "
"'%word:2'."

msgid "not a version number"
msgstr "Esta não é uma versão da nossa aplicação."

