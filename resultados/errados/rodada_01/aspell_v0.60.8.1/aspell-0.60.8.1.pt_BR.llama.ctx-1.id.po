msgstr "arquivos de configuração pessoal"

msgid "personal dictionary file name"
msgstr "Nome do meu dicionário pessoal"

msgid "prefix directory"
msgstr "diretório de prefixo"

msgid "replacements list file name"
msgstr "Nome do arquivo para substituição"

msgid "consider run-together words legal"
msgstr "aceitar palavras compostas"

msgid "maximum number that can be strung together"
msgstr "quantidade máxima de palavras compostas"

