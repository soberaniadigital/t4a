msgstr "# Padrão: "

msgid ""
"\n"
"#######################################################################\n"
"#\n"
"# Filter: %s\n"
"#   %s\n"
"#\n"
"# configured as follows:\n"
"\n"
msgstr ""
"Filtro: %s\n"
"%s\n"
"\n"
"Configurado da seguinte forma:\n"

msgid "ASPELL_CONF env var"
msgstr "ASPELL_CONF Umgebungsvariable"

msgid "main configuration file"
msgstr "arquivo de configuração principal"

msgid "location of main configuration file"
msgstr "Nome da principal arquivo de configuração"

msgid "location of language data files"
msgstr "Localização dos arquivos de dados linguísticos"

msgid "create dictionary aliases"
msgstr "criar alias para dicionário de palavras"

msgid "location of the main word list"
msgstr "Nome da lista principal de palavras"

msgid "encoding to expect data to be in"
msgstr "Codificação, na qual os dados são esperados para serem codificados"

msgid "add or removes a filter"
msgstr "adiciona ou remove um filtro"

msgid "path(s) aspell looks for filters"
msgstr "Os caminhos em que aspell procura filtros"

msgid "filter mode"
msgstr "Modo de filtragem"

msgid "extra dictionaries to use"
msgstr "zusätzliche utilizáveis dicionários"

msgid "files with list of extra words to accept"
msgstr "Arquivos com listas adicionais de palavras"

msgid "location for personal files"
msgstr "Nome para arquivos pessoais"

msgid "ignore words <= n chars"
msgstr "ignoriere Wörter mit <= n Zeichen"

msgid "ignore accents when checking words -- CURRENTLY IGNORED"
msgstr ""
"Ao verificar, ignore os acentos - atualmente em execução sem interrupções."

msgid "ignore case when checking words"
msgstr "ignoriere diferença de maiúsculas e minúsculas ao verificar"

msgid "ignore commands to store replacement pairs"
msgstr "ignoriere comandos, opções de substituição para armazenar"

msgid "extra information for the word list"
msgstr "informações adicionais para a lista de palavras"

msgid "keyboard definition to use for typo analysis"
msgstr "Definição de Teclado para análise de erros táteis"

msgid "language code"
msgstr "Código de linguagem"

msgid "deprecated, use lang instead"
msgstr "obsoleto, usem 'lang' em vez disso."

msgid "location of local language data files"
msgstr "Localização dos arquivos de dados linguísticos locais"

msgid "base name of the main dictionary to use"
msgstr "Nome do principal dicionário de nomes"

msgid "set module name"
msgstr "Nome do módulo definir"

msgid "search order for modules"
msgstr "Ordem de execução para módulos"

msgid "enable Unicode normalization"
msgstr "Ativar normalização Unicodenormalizada"

msgid "Unicode normalization required for current lang"
msgstr "A normalização Unicodenormalizada é necessária para a língua atual."

msgid "Unicode normalization form: none, nfd, nfc, comp"
msgstr ""
"Forma de normalização Unicode para o português brasileiro:\n"
"one, nfd, nfc, comp"

msgid "avoid lossy conversions when normalization"
msgstr ""
"Evite conversões não reversíveis ao normalizar para prevenir perda de dados."

msgid "personal configuration file"
msgstr "arquivos de configuração pessoal"

msgid "personal dictionary file name"
msgstr "Nome do seu dicionário pessoal"

msgid "prefix directory"
msgstr "diretório de prefixo"

msgid "replacements list file name"
msgstr "Nome do arquivo de substituição"

msgid "consider run-together words legal"
msgstr "aceitar palavras compostas"

msgid "maximum number that can be strung together"
msgstr "número máximo de palavras compostas"

msgid "minimal length of interior words"
msgstr "comprimento mínimo das palavras internas"

msgid "consider camel case words legal"
msgstr "aceitar palavras em CamelCase como válidas"

msgid "save replacement pairs on save all"
msgstr "salvar tudo, incluindo pares de substituição"

msgid "set the prefix based on executable location"
msgstr "Definir prefixo baseado no nome do programa"

msgid "size of the word list"
msgstr "tamanho da lista de palavras"

msgid "no longer used"
msgstr "não é mais utilizado"

msgid "suggestion mode"
msgstr "Modo de sugestão"

msgid "use typo analysis, override sug-mode default"
msgstr ""
"Realizar análise de erros ortográficos em vez do modo sugerido padrão."

msgid "use replacement tables, override sug-mode default"
msgstr "Utilize tabelas de substituição em vez do modo sugestivo padrão."

msgid "characters to insert when a word is split"
msgstr "quando um palavra for dividida, inscrever caracteres adicionais"

msgid "use personal, replacement & session dictionaries"
msgstr "use personal, replacement and session word dictionaries"

msgid "search path for word list information files"
msgstr "caminho para arquivos de informações sobre listagens de palavras"

msgid "enable warnings"
msgstr "ative as avisas"

msgid "indicator for affix flags in word lists -- CURRENTLY IGNORED"
msgstr ""
"Indicador para flags de terminação em listas de palavras - Atualmente sem "
"efeito"

msgid "use affix compression when creating dictionaries"
msgstr "Comprimir terminações ao gerar dicionários."

msgid "remove invalid affix flags"
msgstr "remover flags inválidos de terminação"

msgid "attempts to clean words so that they are valid"
msgstr "limpar palavras para que sejam válidas"

msgid "compute soundslike on demand rather than storing"
msgstr "calcula o klang fonético quando necessário, em vez de armazená-lo"

msgid "partially expand affixes for better suggestions"
msgstr ""
"Para melhores sugestões, parte do apêndice para palavras de abertura foi "
"expandida."

msgid "skip invalid words"
msgstr "palavras inválidas serão puladas"

msgid "check if affix flags are valid"
msgstr "Verificar se os flags de termino são válidos."

msgid "check if words are valid"
msgstr "Verificar se as palavras são válidas."

msgid "create a backup file by appending \".bak\""
msgstr "Criar backup com extensão '.bak' adicionada"

msgid "use byte offsets instead of character offsets"
msgstr "utilizar offsets de bytes em vez de offsets de caracteres"

msgid "create missing root/affix combinations"
msgstr ""
"Erigem combinações de palavras sem a terminação derivada do radical ou da "
"morfologia"

msgid "keymapping for check mode: \"aspell\" or \"ispell\""
msgstr "Taxa de erro para modo de teste: 'aspell' ou 'ispell'"

msgid "reverse the order of the suggest list"
msgstr "Reihenfolge der Vorschlagsliste umdrehen"

msgid "suggest possible replacements"
msgstr "sugerências de substituições possíveis"

msgid "time load time and suggest time in pipe mode"
msgstr "tempo de carregamento e tempo para sugerir no modo Pipe (pipeline)"

msgid ""
"This could also mean that the file \"%s\" could not be opened for reading or"
" does not exist."
msgstr ""
"Isso também pode significar que o arquivo \"%s\" não conseguiu ser aberto "
"para leitura ou ele não existe."

msgid "The Unicode code point U+%04X is unsupported."
msgstr "O Unicode caracter na posição U+%04X não é suportado."

msgid "Invalid UTF-8 sequence at position %ld."
msgstr "Sequência UTF-8 inválida na posição %ld."

msgid "Operation Not Supported: %what:1"
msgstr "Operação não suportada: %what:1"

msgid "The method \"%what:1\" is unimplemented in \"%where:2\"."
msgstr "A metodã \"%what:1\" nao foi implementada no local “%where:2”."

msgid "%file:1:"
msgstr "%file:1:"

msgid "The file \"%file:1\" can not be opened"
msgstr "A ficheiro \"%file:1\" não pode ser aberto"

msgid "The file \"%file:1\" can not be opened for reading."
msgstr "A ficheiro \"%file:1\" não pode ser aberto para leitura."

msgid "The file \"%file:1\" can not be opened for writing."
msgstr "A ferramenta de localização do guia não está presente no sistema."

msgid "The file name \"%file:1\" is invalid."
msgstr "O nome do arquivo '\\%file:1' é inválido."

msgid "The file \"%file:1\" is not in the proper format."
msgstr "A ficheiro \"%file:1\" não possui o formato correto."

msgid "The directory \"%dir:1\" can not be opened for reading."
msgstr "O diretório \"%dir:1\" não pode ser aberto para leitura."

msgid "The key \"%key:1\" is unknown."
msgstr "O chaveiro \"%key:1\" é desconhecida."

msgid "The value for option \"%key:1\" can not be changed."
msgstr "O valor da opção '\\%key:1' não pode ser alterado."

msgid "The key \"%key:1\" is not %accepted:2 and is thus invalid."
msgstr "O chave \"%key:1\" não pode %accepted:2, portanto é inválida."

msgid ""
"The value \"%value:2\" is not %accepted:3 and is thus invalid for the key "
"\"%key:1\"."
msgstr ""
"O valor \"%value:2\" não é aceito como %accepted:3, portanto o campo "
"'%key:1' está inválido."

msgid "The key \"%key:1\" is not a string."
msgstr "O chave \"%key:1\" não é uma cadeia de caracteres."

msgid "The key \"%key:1\" is not an integer."
msgstr "O chave \"%key:1\" não é um número inteiro."

msgid "The key \"%key:1\" is not a boolean."
msgstr "O chave \"%key:1\" não é um valor de verdade."

msgid "The key \"%key:1\" is not a list."
msgstr "O chave \"%key:1\" não é uma lista."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"reset-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por 'reset-'."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by an "
"\"enable-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por "
"'enable-'."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by a \"dont-\""
" or \"disable-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por 'dont-' "
"ou 'disable-'."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"clear-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por 'clear-'."

msgid "The language \"%lang:1\" is not known."
msgstr "A linguagem \"%lang:1\" é desconhecida."

msgid "The soundslike \"%sl:2\" is not known."
msgstr "O som do termo '%sl:2' não é conhecido."

msgid "The language \"%lang:1\" is not supported."
msgstr "A linguagem \"%lang:1\" não é suportada."

msgid "No word lists can be found for the language \"%lang:1\"."
msgstr "Não é possível encontrar listagens de palavras para a língua \"%lang:1\"."

msgid "Expected language \"%lang:1\" but got \"%prev:2\"."
msgstr ""
"A linguagem esperada é '%lang:1', mas recebida foi '%prev:2'. Esse erro "
"indica que a configuração do usuário não está alinhada com as expectativas."

msgid "Affix '%aff:1' is corrupt."
msgstr "Último afixo '%aff:1' está danificado."

msgid "The condition \"%cond:1\" is invalid."
msgstr "A condição \"%cond:1\" é inválida."

msgid ""
"The condition \"%cond:1\" does not guarantee that \"%strip:2\" can always be"
" stripped."
msgstr ""
"A condição \"%cond:1\" não garante que a operação de remoção da parte "
"'%strip:2' seja sempre possível."

msgid ""
"The file \"%file:1\" is not in the proper format. Expected the file to be in"
" \"%exp:2\" not \"%got:3\"."
msgstr ""
"A ficheira '\\%file:1' não possui o formato correto. Deveria ser encontrada "
"na '\\%exp:2', e não em '\\%got:3'."

msgid "The encoding \"%encod:1\" is not known."
msgstr "A codificação '\"%encod:1\"' não é conhecida."

msgid "The encoding \"%encod:1\" is not supported."
msgstr "A codificação '\\%encod:1' não é suportada."

msgid "The conversion from \"%encod:1\" to \"%encod2:2\" is not supported."
msgstr "A conversão de '»%encod:1«' para '»%encod:2«' não é suportada."

msgid "The string \"%str:1\" is invalid."
msgstr "A cadeia de caracteres \"%str:1\" é inválida."

msgid "The word \"%word:1\" is invalid."
msgstr "O termo \"%word:1\" é inválido."

msgid "The affix flag '%aff:1' is invalid for word \"%word:2\"."
msgstr ""
"O uso do termo de conclusão '\\%aff:1' para o sujeito '%word:2' é inválido."

msgid "The affix flag '%aff:1' can not be applied to word \"%word:2\"."
msgstr "O fim de sinal '%aff:1' não pode ser aplicado ao termo '%word:2'."

msgid "not a version number"
msgstr "Esta não é uma versão deste software."

msgid "dlopen returned \"%return:1\"."
msgstr "falha ao abrir módulo com dlopen. Erro de volta '%return:1'."

msgid "The file \"%filter:1\" does not contain any filters."
msgstr "A ficheiro %filter:1 não contém nenhum filtro."

msgid "The filter \"%filter:1\" does not exist."
msgstr "O filtro \"%filter:1\" não existe."

msgid "Confused by version control."
msgstr "confuso pela versão controle."

msgid "Aspell version does not match filter's requirement."
msgstr "A versão Aspell não atende às necessidades do filtro."

msgid "Filter option already exists."
msgstr "A opção de filtragem já existe."

msgid "Use option modifiers only within named option."
msgstr "Utilize modificadores de opções apenas dentro das opções nomeadas."

msgid "Option modifier unknown."
msgstr "Modificador desconhecido."

msgid "Error setting filter description."
msgstr "Erro ao definir a descrição do filtro."

msgid "Empty option specifier."
msgstr "Descrição inválida para opção vazia."

msgid "Option \"%option:1\" possibly specified prior to filter."
msgstr "A opção »%option:1« pode ter sido especificada antes do filtro."

msgid "Unknown mode description key \"%key:1\"."
msgstr "Chave de descrição do modo desconhecida \"%key:1\"."

msgid "Expecting \"%modekey:1\" key."
msgstr "Chave esperada: \"%modekey:1\"."

msgid "Version specifier missing key: \"aspell\"."
msgstr "Falta a versão do aspell."

msgid "Aspell version does not match mode's requirement."
msgstr "A versão Aspell não atende aos requisitos do filtro."

msgid "Missing magic mode expression."
msgstr "Oração sem Magic Mode expressão faltante."

msgid "Empty extension at char %char:1."
msgstr "A extensão à direita do caractere %char:1 está vazia."

msgid "\"%mode:1\" error"
msgstr "Erro \"%mode:1\""

msgid "Unknown mode: \"%mode:1\"."
msgstr "Modo desconhecido: »%mode:1«."

msgid "\"%mode:1\" error while extend Aspell modes. (out of memory?)"
msgstr ""
"Erro ao expandir a opção do modo '%mode:1' no Aspell. (Insuficiência de "
"memória?)"

msgid "\"%mode:1\": no start for magic search given for magic \"%magic:2\"."
msgstr "»%mode:1«: Não há começo para a busca mágica de »%magic:2«."

msgid "\"%mode:1\": no range for magic search given for magic \"%magic:2\"."
msgstr ""
"»%mode:1«: Não há um intervalo especificado para a busca mágica de "
"»%magic:2«."

msgid "\"%mode:1\": no magic expression available for magic \"%magic:2\"."
msgstr "»%mode:1«: Não há expressões mágicas disponíveis para \"%magic:2\"."

msgid ""
"\"%mode:1\": Magic \"%magic:2\": bad regular expression after location "
"specifier; regexp reports: \"%regerr:3\"."
msgstr ""
"»%mode:1«: Magia »%magic:2«: Expressão regular inválida após a localização; "
"regexp retorna: »%regerr:3«."

msgid "\"%expression:1\" is not a valid regular expression."
msgstr "“%expression:1” não é um expressão regular válida."

msgid "Unhandled Error: "
msgstr "Erro não tratado de manipulação do objeto localizador:"

msgid "Error: %s\n"
msgstr "Erro: %s"

msgid "Error: "
msgstr "Erro: "

msgid "enter Email mode."
msgstr "Ao entrar no modo de e-mail."

msgid "enter HTML mode."
msgstr "Ao entrar no modo HTML."

msgid "enter TeX mode."
msgstr "Avançar para o modo TeX."

msgid "enter Nroff mode."
msgstr "Ao entrar no modo nroff."

msgid "enter Markdown mode."
msgstr "Avançar para o modo Markdown."

msgid "Invalid Option: %s"
msgstr "Opção inválida: %s"

msgid "'%s' does not take any parameters."
msgstr "A opção '%s' não aceita nenhum parâmetro."

msgid "You must specify a parameter for \"%s\"."
msgstr "Você deve especificar um parâmetro para \"%s\"."

msgid "You must specify an action"
msgstr "Sua ação deve ser especificada."

msgid "Unknown Action: %s"
msgstr "Ação desconhecida: %s"

msgid "Error: You must specify at least %d parameters for \"%s\".\n"
msgstr ""
"Erro: Você deve especificar pelo menos %d parâmetros para "
"'\\u00ab%s\\u00bb'."

msgid "Invalid Input"
msgstr "Entrada inválida"

msgid "WARNING: Unable to enter Nroff mode: %s\n"
msgstr "AVISO: Não é possível alternar para o modo nroff: %s"

msgid "Time to load word list: "
msgstr "Tempo para carregar a lista de palavras:"

msgid "Suggestion Time: %f\n"
msgstr "Tempo de sugestão: %f"

msgid "You must specify a file name."
msgstr "Sua vez, você deve especificar um nome de arquivo."

msgid "Only one file name may be specified."
msgstr "Pode haver apenas um nome de arquivo especificado."

msgid "Could not open the file \"%s\" for reading"
msgstr "Não foi possível abrir a pasta de arquivo '%s' para leitura."

msgid "Invalid keymapping: %s"
msgstr "Ungültige Tastaturbelegung: %s"

msgid "\"%s\" is not a regular file"
msgstr "“%s” não é uma arquivo normal"

msgid "Could not open the file \"%s\" for writing. File not saved."
msgstr ""
"Não foi possível abrir a pasta de arquivo '%s' para gravação. Arquivo não "
"salvo."

msgid "Ignore"
msgstr "ignorar"

msgid "Ignore all"
msgstr "Ignorar todas as alterações"

msgid "Replace"
msgstr "substituir"

msgid "Replace all"
msgstr "todos os elementos devem ser substituídos"

msgid "Add"
msgstr "Adicionar"

msgid "Add Lower"
msgstr "adicionar em letras minúsculas"

msgid "Abort"
msgstr "Cancelar"

msgid "Exit"
msgstr "Sair"

msgid "Are you sure you want to abort (y/n)? "
msgstr "Está certo que deseja encerrar (j/n)?"

msgid "Yy"
msgstr "Jj"

msgid "With: "
msgstr "Mit:"

msgid "Sorry that is an invalid choice!"
msgstr "Desculpe, esta é uma escolha inválida!"

msgid "Can't merge a master word list yet. Sorry."
msgstr "Desculpe, mas não é possível unir uma lista de palavras-chave."

msgid "Sorry \"create/merge personal\" is currently unimplemented.\n"
msgstr ""
"Desculpe, a funcionalidade para criar/unir sua lista pessoal ainda não foi "
"implementada."

msgid "Sorry I won't overwrite \"%s\""
msgstr "Desculpe, mas eu não vou sobrescrever \"%s\""

msgid "Sorry \"create/merge repl\" is currently unimplemented.\n"
msgstr "Desculpe, a lista de substituição ainda não foi implementada."

msgid "\"%s\" is not a valid flag for the \"munch-list\" command."
msgstr "«%s» não é uma opção válida para o comando 'munch-list'."

msgid "Usage: aspell [options] <command>"
msgstr "FÓLIO: aspell [Opções] <Comando>"

msgid "<command> is one of:"
msgstr "<Befehl> ist eins von:"

msgid "  -?|usage         display a brief usage message"
msgstr " -?|usage          Mostrar mensagem de uso breve e clara."

msgid "  help             display a detailed help message"
msgstr "mostrar um texto de ajuda detalhado"

msgid "  -c|check <file>  spellchecks a file"
msgstr " -c|check <arquivo> Verificação de ortografia em arquivo"

msgid "  -a|pipe          \"ispell -a\" compatibility mode"
msgstr "  -a|pipe          Modo de compatibilidade para \"ispell -a\""

msgid "  [dump] config    dumps the current configuration to stdout"
msgstr "Gerar dump da configuração atual para a saída padrão."

msgid "  config <key>     prints the current value of an option"
msgstr "config <key>     Gere o valor atual de uma opção"

msgid "  [dump] dicts | filters | modes"
msgstr " [dump] dicionários | filtros | modos"

msgid "    lists available dictionaries / filters / filter modes"
msgstr ""
"    Lista os seguintes recursos disponíveis para dicionários, filtros e modos de aplicação dos mesmos:\n"
"\n"
"Dicionário/Vetor Palavras - %s\n"
"Filtro por Campo - %d\n"
"Modo Filtro (Padrão) - %<PRIuMAX>\n"

msgid "[options] is any of the following:"
msgstr "[opções] qualquer uma das seguintes:"

msgid ""
"  list             produce a list of misspelled words from standard input"
msgstr ""
"Liste de palavras com erros ortográficos provenientes da entrada padrão."

msgid ""
"  soundslike       returns the sounds like equivalent for each word entered"
msgstr "soundslike       Retorna o som aproximado de cada palavra digitada"

msgid "  munch            generate possible root words and affixes"
msgstr "geração de possíveis raízes e terminações de palavras"

msgid "  expand [1-4]     expands affix flags"
msgstr "expandir [1-4]     σímbolo de terminação expandir"

msgid ""
"  clean [strict]   cleans a word list so that every line is a valid word"
msgstr ""
"limpar [estrito]   Lista de palavras, para que cada linha seja uma palavra "
"válida."

msgid "  filter           filters input as if it was being spellchecked"
msgstr ""
"filtro           filtrar a entrada como se fosse verificada ortograficamente"

msgid "  -v|version       prints a version line"
msgstr " -v|versão        Imprime uma linha com informações de versão"

msgid "  munch-list [simple] [single|multi] [keep]"
msgstr "munch-list [simples] [único|mais de um] [manter]"

msgid "    reduce the size of a word list via affix compression"
msgstr "reduzir o tamanho de uma lista de palavras com compressão por sufixo"

msgid "  conv <from> <to> [<norm-form>]"
msgstr "conv <von> <nach> [<Normalform>]"

msgid "    converts from one encoding to another"
msgstr "Conversão de uma codificação para outra."

msgid "  norm (<norm-map> | <from> <norm-map> <to>) [<norm-form>]"
msgstr ""
"norm (<norm-map> | <origem> <norm-map> <destino>) [<forma-normalizada>]"

msgid "    perform Unicode normalization"
msgstr "Ativar normalização Unicodenormalizada"

msgid "  dump|create|merge master|personal|repl [<name>]"
msgstr "dumpar|criar|mesclar master|personal|repl [<nome>]"

msgid ""
"    dumps, creates or merges a master, personal, or replacement dictionary."
msgstr ""
"Lista principal (master), lista pessoal (personal) ou lista de substituição "
"(replacement)-"

msgid ""
"  <norm-form>      normalization form to use, either none, internal, or "
"strict"
msgstr ""
"Para utilizar a normalização, escolha entre nenhuma (none), interna "
"(internal) ou estrita (strict)."

msgid ""
"\n"
"Aspell %s.  Copyright 2000-2023 by Kevin Atkinson.\n"
"\n"
msgstr "Aspell %s. Copyright 2000–2023 Kevin Atkinson."

msgid ""
"Available Dictionaries:\n"
"    Dictionaries can be selected directly via the \"-d\" or \"master\"\n"
"    option.  They can also be selected indirectly via the \"lang\",\n"
"    \"variety\", and \"size\" options.\n"
msgstr ""
"Livros de palavras disponíveis: Você pode escolher livros diretamente com a "
"opção '-d' ou 'master'. Outras maneiras incluem as opções '-lang', "
"'-variety' e '-size'."

msgid ""
"Available Filters (and associated options):\n"
"    Filters can be added or removed via the \"filter\" option.\n"
msgstr "Filtros disponíveis (e opções relacionadas):"

msgid ""
"\n"
"  %s filter: %s\n"
msgstr "%s filtros:%s\n"

msgid ""
"Available Filter Modes:\n"
"    Filter Modes are reconfigured combinations of filters optimized for\n"
"    files of a specific type. A mode is selected via the \"mode\" option.\n"
"    This will happen implicitly if Aspell is able to identify the file\n"
"    type from the extension, and possibility the contents, of the file.\n"
msgstr ""
"Modos de filtragem disponíveis: \n"
"    Os modos de filtro são combinações diferentes dos filtros que foram otimizados para tipos específicos de arquivos. Você pode definir o modo desejado usando a opção 'mode'. Se Aspell não tiver informações suficientes, ele tentará identificar automaticamente o tipo correto do arquivo e seu modo correspondente com base no nome da extensão e possivelmente em seu conteúdo. \n"

msgid "Error: Stdin not a terminal."
msgstr "Erro: Entrada padrão não é um terminal."

msgid "Enter"
msgstr "Pressione Enter"

msgid "Accept Changes"
msgstr "aceitar as alterações"

msgid "Backspace"
msgstr "Löschtaste"

msgid "Control-H"
msgstr "Ctrl-H"

msgid "Delete the previous character"
msgstr "Remover o caractere anterior"

msgid "Left"
msgstr "links"

msgid "Control-B"
msgstr "Ctrl+B"

msgid "Move Back one space"
msgstr "Mover um espaço para a esquerda"

msgid "Right"
msgstr "direita"

msgid "Control-F"
msgstr "Ctrl+F"

msgid "Move Forward one space"
msgstr "mover um caractere para a direita"

msgid "Home"
msgstr "Pos1"

msgid "Control-A"
msgstr "Ctrl+A"

msgid "Move to the beginning of the line"
msgstr "Movendo para o início da linha"

msgid "End"
msgstr "Fim"

msgid "Control-E"
msgstr "Ctrl+E"

msgid "Move to the end of the line"
msgstr "Zum Zeilenende"

msgid "Delete"
msgstr "remover"

msgid "Control-D"
msgstr "Ctrl+D"

msgid "Delete the next character"
msgstr "Remover o próximo caractere"

msgid "Control-K"
msgstr "Ctrl-K"

msgid "Kill all characters to the EOL"
msgstr "Remover todos os caracteres até o final da linha."

msgid "Control-C"
msgstr "Interrupção por tecla Ctrl (Ctrl+C)"

msgid "Abort This Operation"
msgstr "Cancelar esta ação"

msgid "This is probably because: "
msgstr "Provável razão para isso:"

msgid "The required field \"name\" is missing."
msgstr "O campo necessário 'nome' está ausente."

msgid "Empty string."
msgstr "Cadeia vazia."

msgid "The character '%s' (U+%02X) may not appear at the beginning of a word."
msgstr "O caractere '\\%s' (U+%02X) não deve aparecer no início de uma palavra."

msgid ""
"The character '%s' (U+%02X) must be followed by an alphabetic character."
msgstr ""
"Após o caractere '\\u%02X' (U+%02X) deve seguir um caractere alfabético."

msgid "Does not contain any alphabetic characters."
msgstr "Não contém nenhuma letra."

msgid "The character '%s' (U+%02X) may not appear in the middle of a word."
msgstr "O caractere '\\%s' (U+%02X) não deve aparecer no meio de uma palavra."

msgid ""
"The character '\\r' (U+0D) may not appear at the end of a word. This "
"probably means means that the file is using MS-DOS EOL instead of Unix EOL."
msgstr ""
"O caractere '\\r' (U+0D) não deve aparecer no final de uma palavra. Isso "
"pode estar relacionado ao fato de que a arquivo utiliza o termino de linha "
"do MS-DOS em vez do Unix."

msgid "The character '%s' (U+%02X) may not appear at the end of a word."
msgstr "O caractere '\\%s' (U+%02X) não pode estar no final de uma palavra."

msgid "Warning: Removing invalid affix '%s' from word %s.\n"
msgstr "Aviso: Remova a terminação inválida '%s' do palavra '%s'."

msgid "Warning: Removing inapplicable affix '%s' from word %s.\n"
msgstr ""
"Aviso: Não remova a extensão de terminação '%s' do palavra '%s'. Anexe "
"apenas as partes que sejam aplicáveis."

msgid "Warning: %s Skipping string.\n"
msgstr "Aviso: »%s«: Pule a sequência de caracteres."

msgid "The total length is larger than 240 characters."
msgstr "O termo é geralmente mais longo do que 240 caracteres."

msgid "Warning: %s Skipping word.\n"
msgstr "Aviso: »%s«: Pule a palavra."

msgid "Possibly incorrect count."
msgstr "Possível número inválido."

msgid "Incompatible hash function."
msgstr "FUNÇÃO DE HASH NÃO COMPATÍVEL"

msgid "Wrong endian order."
msgstr "Ordem de bytes inválida."

msgid "Wrong soundslike."
msgstr "Falho no fluxo sonoro."

msgid "Wrong soundslike version."
msgstr ""
"Falha no reconhecimento de palavras por falta de correspondência sonora "
"adequada."

msgid "Affix flags found in word but no affix file given."
msgstr ""
"Encontrados sinais de terminação no texto, mas não há um arquivo com as "
"palavras terminadas."

msgid ""
"The total word length, with soundslike data, is larger than 240 characters."
msgstr ""
"A soma da extensão do termo, incluindo dados de sonoridade semelhante ao "
"som, é maior que 240 caracteres."

msgid "There must be at least one \"add\" line."
msgstr "É necessário que haja pelo menos uma linha de 'adicionar'."

msgid "one of ultra, fast, normal, slow, or bad-spellers"
msgstr ""
"um dos seguintes termos em inglês para avaliar o tipo de letração ou "
"digitação é 'ultra', que indica uma escrita rápida e sem erros; 'fast', "
"também conhecido como 'rápido' no Brasil, refere-se à velocidade da "
"digitação sem comprometer a precisão; 'normal' sugere um ritmo de digitação "
"comum e confiável; 'slow' implica em uma digitação mais lenta que pode ser "
"intencional ou devido ao desempenho do teclado; por fim, há termos como "
"'bad-spellers', mas no contexto brasileiro, preferimos usar a expressão "
"'erros de ortografia'."

msgid "is not one of the allowed types"
msgstr "não é de nenhum dos tipos permitidos."

msgid "The personal word list is unavailable."
msgstr "A lista de palavras pessoais não está disponível."

msgid "The session word list is unavailable."
msgstr "A lista de palavras da sessão não está disponível."

msgid "The main word list is unavailable."
msgstr "A principal lista de palavras não está disponível."

msgid "a string of 'o','O','p',or 'P'"
msgstr "'o', 'O', 'p' ou 'P' constituem uma cadeia de caracteres."

msgid "experimental filter for hiding delimited contexts"
msgstr ""
"Experimental Filter, to hide limited sections for concealment purposes."

msgid "context delimiters (separated by spaces)"
msgstr "Context Separator (separated by spaces)"

msgid "swaps visible and invisible text"
msgstr "Texto visível e texto não visível trocados"

msgid "filter for skipping quoted text in email messages"
msgstr "Filtro para passar por cima do texto citado em emails."

msgid "email quote characters"
msgstr "Caracteres de citação para e-mail"

msgid "num chars that can appear before the quote char"
msgstr "Número máximo de caracteres que podem aparecer antes do sinal '}"

msgid "filter for dealing with HTML documents"
msgstr "um filtro para tratar documentos HTML"

msgid "HTML attributes to always check"
msgstr "os atributos HTML que sempre são verificados."

msgid "HTML tags to always skip the contents of"
msgstr "HTML Tags Whose Content Is Always Skipped Over"

msgid "filter for Markdown/CommonMark documents"
msgstr "um filtro para tratar documentos em Markdown/CommonMark"

msgid "skip link labels in link reference definitions"
msgstr ""
"Ignorar as descrições de ligação em definições de referência ligada às "
"conexões"

msgid "support tags that span multiple lines outside of HTML blocks"
msgstr "soporta tags multiplos de linhas fora dos blocos HTML"

msgid "HTML tags that start an HTML block that allows blank lines"
msgstr ""
"Tags HTML que iniciam um bloco de código HTML, permitindo linhas em branco"

msgid "HTML tags that start an HTML block that ends with a blank line"
msgstr ""
"Tags HTML que iniciam um bloco de código HTML, concluído por uma linha em "
"branco"

msgid "filter for dealing with Nroff documents"
msgstr "um filtro para tratar documentos Nroff"

msgid "filter for dealing with generic SGML/XML documents"
msgstr "filtro, para tratar documentos SGML/XML genéricos"

msgid "SGML attributes to always check"
msgstr "os atributos SGML sempre devem ser verificados."

msgid "SGML tags to always skip the contents of"
msgstr "Os elementos SGML, cujo conteúdo é sempre ignorado"

msgid "filter for dealing with TeX/LaTeX documents"
msgstr "um filtro para reconhecer comandos TeX/LaTeX."

msgid "check TeX comments"
msgstr "verificação de comentários em TeX"

msgid "TeX commands"
msgstr "Comandos TeX"

msgid "filter for dealing with Texinfo documents"
msgstr "um filtro para Texinfo documentos"

msgid "Texinfo commands to ignore the parameters of"
msgstr "Comandos Texinfo cujos parâmetros são ignorados."

msgid "Texinfo environments to ignore"
msgstr "Ambientes Texinfo a serem ignorados"

msgid "filter to skip URL like constructs"
msgstr "filtro para pular construções semelhantes a URL"

msgid "mode for checking C++ comments and string literals"
msgstr "Modus para verificar comentários C++ e literais de string."

msgid "mode to check any lines starting with a #"
msgstr "Modus para verificar todas as linhas que começam com '##'."

msgid "mode for skipping quoted text in email messages"
msgstr "Modus para ignorar referências citadas em emails"

msgid "mode for checking HTML documents"
msgstr "Modus para verificar o padrão de um documento HTML."

msgid "mode for checking Markdown/CommonMark documents"
msgstr "Modus para verificação de documentos Markdown/CommonMark"

msgid "mode to disable all filters"
msgstr "Modus para desativar todos os filtros."

msgid "mode for checking Nroff documents"
msgstr "Modus para verificar documentos Nroff"

msgid "mode for checking Perl comments and string literals"
msgstr "Modus para verificar comentários Perl e literais de cadeia textual."

msgid "mode for checking generic SGML/XML documents"
msgstr "Modus para verificar documentos SGML/XML genéricos."

msgid "mode for checking TeX/LaTeX documents"
msgstr "Regime de filtragem para documentos TeX/LaTeX"

msgid "mode for checking Texinfo documents"
msgstr "Modus para verificar documentos Texinfo."

msgid "mode to skip URL like constructs (default mode)"
msgstr "Modus para pular construções semelhantes a URLs (modo padrão)"

msgid "edit distance to use, override sug-mode default"
msgstr "Defina a distância e substitua o valor padrão de sug-mode"

msgid "Sorry \"filter\" is currently unimplemented.\n"
msgstr "Sorry, »filter« ist noch nicht implementiert.\n"
