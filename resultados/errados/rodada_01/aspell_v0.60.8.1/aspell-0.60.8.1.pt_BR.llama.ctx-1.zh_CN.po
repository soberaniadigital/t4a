msgstr "O termo de conclusão '%aff:1' foi danificado."

msgid "The condition \"%cond:1\" is invalid."
msgstr "A condição '\\%cond:1' é inválida."

msgid ""
"The condition \"%cond:1\" does not guarantee that \"%strip:2\" can always be"
" stripped."
msgstr ""
"A condição \"%cond:1\" não garante que a parte \"%strip:2\" sempre possa ser"
" separada."

msgid ""
"The file \"%file:1\" is not in the proper format. Expected the file to be in"
" \"%exp:2\" not \"%got:3\"."
msgstr ""
"A ficheiro \"%file:1\" não possui o formato correto. Deveria ser no arquivo "
