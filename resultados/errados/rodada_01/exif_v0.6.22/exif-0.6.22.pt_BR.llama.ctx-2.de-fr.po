msgid "Not enough memory."
msgstr "Não há memória suficiente."

msgid "Setting a value for this tag is unsupported!"
msgstr "Não há suporte para a criação de um valor para esta marca!"

msgid "Too few components specified (need %d, found %d)\n"
msgstr ""
"Chamado para indicar quantidade insuficiente de partes (%d necessitadas, %d "
"identificadas)"

msgid "Numeric value expected\n"
msgstr "É necessário um valor numérico igual a uma variável."

msgid "Internal error. Please contact <%s>."
msgstr "Erro de nível inferior. Por favor, entre em contato com <%s>."

msgid "Not yet implemented!"
msgstr "Não foi possível concluir a operação!"

msgid "Warning; Too many components specified!"
msgstr "Aviso: insuficiente número de componentes especificados!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr "Existe muito dado EXIF (%i byte). O máximo é %i byte."

msgid "Could not write '%s' (%s)."
msgstr "Não foi possível escrever \"%s\" (%s)."

msgid "Wrote file '%s'."
msgstr "Foi feito o treino da tabela '%s'."

msgid "EXIF entry '%s' "
msgstr "Mục tin EXIF »%s« "

msgid "(0x%x, '%s') "
msgstr "(0x%x, '%s') "

msgid "exists in IFD '%s':\n"
msgstr "existiu no IFD »%s«:"

msgid "Adding entry..."
msgstr "Adicionar item..."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr "IFD \"%s\" não contém nenhuma marcação de '%s'!"

msgid "Could not open '%s' (%s)!"
msgstr "Não foi possível abrir \"%s\" (%s)!"

msgid "Could not determine size of '%s' (%s)."
msgstr "Não foi possível determinar o tamanho do arquivo %s (%d)."

msgid "Could not read '%s' (%s)."
msgstr "Não foi possível ler o arquivo %s (%s)."

msgid "IFD '%s' does not contain tag '%s'."
msgstr "IFD \"%s\" não contém nenhuma marcação de linha '%s'."

msgid "'%s' does not contain tag '%s'."
msgstr "O arquivo '%s' não contém a marcação de linha '%s'."

msgid "'%s' does not contain a thumbnail!"
msgstr "Se não houver imagens de exemplo em \"%s\", aviso!"

msgid "Could not open '%s' for writing (%s)!"
msgstr "Não foi possível abrir \"%s\" para escrever (%s)!"

msgid "EXIF tags in '%s':"
msgstr "Trilhas EXIF na imagem %s:"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr ""
"Não há informações sobre o formato ou não existe a anotação do fabricante."

msgid "MakerNote does not contain any value.\n"
msgstr "MakerNote não contém valor."

msgid "MakerNote contains %i value:\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Unknown Tag"
msgstr "Marcação desconhecida"

msgid "Unknown value"
msgstr "Valor desconhecido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "Thê EXIF dentro de »%s« (ordem dos bytes bytea %s):"

msgid "Tag"
msgstr "marcação"

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "Os dados EXIF contêm uma imagem de exemplo (%i bytes)."

msgid "ThumbnailSize\t%i\n"
msgstr "Kích cỡ ảnh mẫu %i"

msgid "Display software version"
msgstr "Hipervisor de software em análise"

msgid "Show IDs instead of tag names"
msgstr "Hiêniân sử dụng mã cá thật cho tên trong khuôn luận."

msgid "Select tag"
msgstr "Escolha o símbolo de cancelamento"

msgid "tag"
msgstr "etiqueta"

msgid "Select IFD"
msgstr "Escolha IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Liste todos os marcadores EXIF."

msgid "Show contents of tag MakerNote"
msgstr "Contenido da nota do fabricante mostrar"

msgid "Remove tag or ifd"
msgstr "Remova a marcação ou o IFD."

msgid "Show description of tag"
msgstr "Esta é a descrição atual do marcador."

msgid "Extract thumbnail"
msgstr "Truncar a imagem pequena."

msgid "Remove thumbnail"
msgstr "remover a miniatura do arquivo"

msgid "Insert FILE as thumbnail"
msgstr "Coloque o arquivo de exemplo como imagem em animação."

msgid "FILE"
msgstr "TARDE TINDA"

msgid "Do not fix existing tags in files"
msgstr "Não corrija marcações existentes em arquivos"

msgid "Write data to FILE"
msgstr "Digite dados no T_P_TIN"

msgid "Value of tag"
msgstr "Valor da marcação do sinal"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Criar dados EXIF se eles não existirem."

msgid "Output in a machine-readable (tab delimited) format"
msgstr ""
"Saiba o seguinte padrão para máquinas que lêem arquivos (separados por tabulação):\n"
"DE: '%s'\n"
"FR: 'In un format lisible par une machine, séparé par des tabulations.'"

msgid "Width of output"
msgstr "Chiêu róng kết xuất"

msgid "WIDTH"
msgstr "largura do rio"

msgid "Output in a XML format"
msgstr "Saída em formato XML"

msgid "Show debugging messages"
msgstr "Atualização de mensagens do erro"

msgid "Help options:"
msgstr "opções de auxílio:"

msgid "Show this help message"
msgstr "Olá! Estou aqui para ajudar."

msgid "Display brief usage message"
msgstr "Olá! Aqui está a assistência rápida."

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"IFD não é aceito. Os IFDs válidos são '0', '1', 'EXIF', 'GPS' e "
"'Interoperability'. Para obter mais informações, tente usar a opção --help."

msgid "Invalid tag '%s'!"
msgstr "Marqueiro \"%s\" inválido!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar um sinal!"

msgid "You need to specify an IFD!"
msgstr "Você precisa especificar um IFD!"

msgid "Tag '%s' "
msgstr "Marcação »%s« "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Digite o nome do arquivo de entrada ou --create-exif para criar metadados "
"EXIF."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s não pode ser lido ou não contém dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O XML não é suportado para notas do Makers Notes."

msgid "Data does not follow JPEG specification."
msgstr "Os dados não seguem a especificação JPEG."
