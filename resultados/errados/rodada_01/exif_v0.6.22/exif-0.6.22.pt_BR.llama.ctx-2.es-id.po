msgstr "Chame um teto de proteção para o arquivo ou --create-exif."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "'%s' é ilegível ou não contém dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O formato XML não está disponível para Notas do Autor/Maker Notes"

msgid "Data does not follow JPEG specification."
msgstr "O dado não cumpre a especificação JPEG."
