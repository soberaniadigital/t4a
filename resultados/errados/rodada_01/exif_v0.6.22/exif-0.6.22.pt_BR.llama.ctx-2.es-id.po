msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD '%s' não for válido. Os IFD válidos são '0', '1', 'EXIF', 'GPS', e "
"'Tiógrafia Interoperativa'."

msgid "Invalid tag '%s'!"
msgstr "Thẻ không hợp lệ '%s'!"

msgid "You need to specify a tag!"
msgstr "É necessário especificar uma etiqueta!"

msgid "You need to specify an IFD!"
msgstr "É necessário especificar um IFD!"

msgid "Tag '%s' "
msgstr "Etiqueta '%s' "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

