msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] tập_tin"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD fornecido não é válido. Os IFDs válidos são '0', '1', 'EXIF', 'GPS'"
" e 'Interoperability'. Para obter mais informações, tente `%s --help'"

msgid "Invalid tag '%s'!"
msgstr "Marking '%s' is not allowed!"

msgid "You need to specify a tag!"
msgstr "Você precisa especificar um identificador!"

msgid "You need to specify an IFD!"
msgstr "Você precisa especificar um IFD!"

msgid "Tag '%s' "
msgstr "Marcação »%s« "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

