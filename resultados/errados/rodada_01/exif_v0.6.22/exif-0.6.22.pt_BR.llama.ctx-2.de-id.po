msgstr "Chame o teto de vídeo ou --create-exif para criar metadados EXIF."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "%s não pode ser lido ou está vazio de dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O XML não é um formato disponível para Anotações do Maker Notes."

msgid "Data does not follow JPEG specification."
msgstr "Dados não seguem a especificação JPEG."
