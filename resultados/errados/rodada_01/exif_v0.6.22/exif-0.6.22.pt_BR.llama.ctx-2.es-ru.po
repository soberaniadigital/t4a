msgid "Not enough memory."
msgstr "Não há blocos de memória suficientes."

msgid "Setting a value for this tag is unsupported!"
msgstr "Não há suporte para atribuir um valor a esta etiqueta!"

msgid "Too few components specified (need %d, found %d)\n"
msgstr ""
"Chamado para indicar um número insuficiente de componentes (%d necessários, "
"%d encontrados).\n"

msgid "Numeric value expected\n"
msgstr "É necessário um valor numérico."

msgid "Internal error. Please contact <%s>."
msgstr "Erro interno. Por favor, confronte com <%s>."

msgid "Not yet implemented!"
msgstr "Não foi possível concluir a operação!"

msgid "Warning; Too many components specified!"
msgstr "Atenção: se houver insuficiente número de componentes!"

msgid "Too much EXIF data (%i bytes). Only %i bytes are allowed."
msgstr "Demasiados dados EXIF (%i byte). Chão se admitir %i byte."

msgid "Could not write '%s' (%s)."
msgstr "Não foi possível escrever '%s' (%s)."

msgid "Wrote file '%s'."
msgstr "Fez treino no arquivo '%s'."

msgid "EXIF entry '%s' "
msgstr "Mục tin EXIF '%s' "

msgid "(0x%x, '%s') "
msgstr "(0x%x, '%s') "

msgid "exists in IFD '%s':\n"
msgstr "existe em IFD '%s':"

msgid "Adding entry..."
msgstr "Adicionando item..."

msgid "IFD '%s' does not contain a tag '%s'!"
msgstr "IFD '%s' não contém uma etiqueta '%s'!"

msgid "Could not open '%s' (%s)!"
msgstr "Não foi possível abrir '%s' (%s)!"

msgid "Could not determine size of '%s' (%s)."
msgstr "Não foi possível determinar o tamanho do arquivo '%s' (%s)."

msgid "Could not read '%s' (%s)."
msgstr "Não foi possível ler '%s' (%s)."

msgid "IFD '%s' does not contain tag '%s'."
msgstr "IFD '%s' não contém a etiqueta '%s'."

msgid "'%s' does not contain tag '%s'."
msgstr "'%s' não contém a etiqueta '%s'."

msgid "'%s' does not contain a thumbnail!"
msgstr "Se '%s' não conter miniatura de imagem!"

msgid "Could not open '%s' for writing (%s)!"
msgstr ""
"Não foi possível abrir '%s' para gravação (%s)! Espero que você tenha "
"entendido a mensagem."

msgid "EXIF tags in '%s':"
msgstr "Thêm ES ou RU em '%s':"

msgid "Unknown format or nonexistent MakerNote.\n"
msgstr "Não foi possível determinar o formato ou não há nota do autor."

msgid "MakerNote does not contain any value.\n"
msgstr "NotaMaker sem valor."

msgid "MakerNote contains %i value:\n"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Unknown Tag"
msgstr "etiqueta desconhecida"

msgid "Unknown value"
msgstr "Valor desconhecido"

msgid "EXIF tags in '%s' ('%s' byte order):"
msgstr "ETIQUETAS EXIF em '%s' (ordem de bytes '%s'):"

msgid "Tag"
msgstr "etiqueta"

msgid "Value"
msgstr "Valor"

msgid "EXIF data contains a thumbnail (%i bytes)."
msgstr "Os dados EXIF contêm uma miniatura (%i bytes)."

msgid "ThumbnailSize\t%i\n"
msgstr "TamanhoMiniatura %i"

msgid "Display software version"
msgstr "Hífen a versão do software"

msgid "Show IDs instead of tag names"
msgstr ""
"Olá! Seja bem vindo ao nosso sistema. Para ver o número de identificação do "
"seu dispositivo em vez da etiqueta, por favor digite 'show id'."

msgid "Select tag"
msgstr "Selecionar etiqueta"

msgid "tag"
msgstr "etiqueta"

msgid "Select IFD"
msgstr "Selecionar IFD"

msgid "IFD"
msgstr "IFD"

msgid "List all EXIF tags"
msgstr "Lista de todas as tags EXIF"

msgid "Show contents of tag MakerNote"
msgstr "Contenido da etiqueta MakerNote"

msgid "Remove tag or ifd"
msgstr "Eliminar etiqueta o 'ifd' ou IFD"

msgid "Show description of tag"
msgstr "Descrição atual da etiqueta"

msgid "Extract thumbnail"
msgstr "Extrair miniatura"

msgid "Remove thumbnail"
msgstr "Remover miniatura"

msgid "Insert FILE as thumbnail"
msgstr "Inserir arquivo como miniatura de exemplo"

msgid "FILE"
msgstr "Ficheiro aberto para edição."

msgid "Do not fix existing tags in files"
msgstr "Não corrija etiquetas existentes nos arquivos."

msgid "Write data to FILE"
msgstr "Ghi dữ liệu vào TẬP TIN"

msgid "Value of tag"
msgstr "Valor da etiqueta do elemento"

msgid "STRING"
msgstr "CHUỖI"

msgid "Create EXIF data if not existing"
msgstr "Criar dados EXIF se não existirem."

msgid "Output in a machine-readable (tab delimited) format"
msgstr "Xuất ra một định dạng cho máy đọc được (định giới bằng khoảng tab)"

msgid "Width of output"
msgstr "largura da saída finalizada"

msgid "WIDTH"
msgstr "RỘNG"

msgid "Output in a XML format"
msgstr "Saída em formato XML"

msgid "Show debugging messages"
msgstr "Atualização de mensagens de erro"

msgid "Help options:"
msgstr "Escolha a ajuda:"

msgid "Show this help message"
msgstr ""
"Olá! Se precisar de ajuda, por favor entre em contato com o suporte técnico."

msgid "Display brief usage message"
msgstr "Olá! Estou aqui para ajudar."

msgid "[OPTION...] file"
msgstr "[TÙY_CHỌN...] ficheiro"

msgid ""
"Invalid IFD '%s'. Valid IFDs are '0', '1', 'EXIF', 'GPS', and "
"'Interoperability'."
msgstr ""
"Se o IFD '%s' não for válido. Os valores de IFD aceitáveis são '0', '1', "
"'EXIF', 'GPS' e 'Interoperability'."

msgid "Invalid tag '%s'!"
msgstr "Tela '%s' inválida!"

msgid "You need to specify a tag!"
msgstr "É necessário especificar uma etiqueta!"

msgid "You need to specify an IFD!"
msgstr "É necessário especificar um IFD!"

msgid "Tag '%s' "
msgstr "Etiqueta '%s' "

msgid "(0x%04x, '%s'): "
msgstr "(0x%04x, '%s'): "

msgid "Specify input file or --create-exif"
msgstr ""
"Chame um teto de proteção para o arquivo ou use a opção --create-exif."

msgid "'%s' is not readable or does not contain EXIF data!"
msgstr "'%s' é ilegível ou não contém dados EXIF!"

msgid "XML format is not available for Maker Notes"
msgstr "O formato XML não está disponível para Notas do Autor."

msgid "Data does not follow JPEG specification."
msgstr "O dado não cumpre a especificação JPEG."
