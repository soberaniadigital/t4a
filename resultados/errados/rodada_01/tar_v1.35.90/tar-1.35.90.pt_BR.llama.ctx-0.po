msgid "display progress messages every NUMBERth record (default 10)"
msgstr ""
"exibe mensagens de progresso a cada NÚMERO-ésimo registro (por omissão 10)"

msgid "ACTION"
msgstr "Ação"

msgid "execute ACTION on each checkpoint"
msgstr "execute ACCIÓN em cada ponto de verificação."

msgid "print a message if not all links are dumped"
msgstr "mostra um mensagem se todos os links não forem clicados"

msgid "SIGNAL"
msgstr "SIGNO"

msgid ""
"print total bytes after processing the archive; with an argument - print "
"total bytes when this SIGNAL is delivered; Allowed signals are: SIGHUP, "
"SIGQUIT, SIGINT, SIGUSR1 and SIGUSR2; the names without SIG prefix are also "
"accepted"
msgstr ""
"mostra os bytes totais após processar o arquivo; com um argumento - mostra "
"os bytes totais quando recebe esta sinalização; permitem-se as seguintes "
"sinais de mensagem: SIGHUP, SIGQUIT, SIGINT, SIGUSR1 e SIGUSR2; também "
"aceitam nomes sem o prefixo 'SIG'."

msgid "print file modification times in UTC"
msgstr "exibe as datas e horas de modificação dos arquivos em UTC."

msgid "print file time to its full resolution"
msgstr "exibe a data do arquivo com maior resolução possível."

msgid "send verbose output to FILE"
msgstr "envia a saída detalhada para o arquivo"

msgid "show block number within archive with each message"
msgstr "exibe o número do bloco no arquivo com cada mensagem."

msgid "show tar defaults"
msgstr "exibe os valores padrão do tar"

msgid "show valid ranges for snapshot-file fields"
msgstr "exibe os intervalos válidos para os campos do arquivo de instantânea"

msgid ""
"when listing or extracting, list each directory that does not match search "
"criteria"
msgstr ""
"quando se lista ou extrai, lista cada diretório que não coincide com o "
"critério de busca"

msgid "show file or archive names after transformation"
msgstr "exibe os nomes dos arquivos após a transformação."

msgid "STYLE"
msgstr "estilo"

msgid "set name quoting style; see below for valid STYLE values"
msgstr ""
"estabeleça o estilo de cita dos nomes; veja abaixo os valores ESTILO "
"válidos."

msgid "additionally quote characters from STRING"
msgstr "entrecomilhas os caracteres de CADENA também."

msgid "disable quoting for characters from STRING"
msgstr "sem aspas nos caracteres da CADENA"

msgid "ask for confirmation for every action"
msgstr "pede confirmação para cada ação"

msgid "verbosely list files processed"
msgstr "lista os arquivos processados detalhadamente"

msgid "KEYWORD"
msgstr "Palavrinha da Chave"

msgid "warning control"
msgstr "control de aviso"

msgid "Compatibility options:"
msgstr "Opciones de compatibilidade:"

