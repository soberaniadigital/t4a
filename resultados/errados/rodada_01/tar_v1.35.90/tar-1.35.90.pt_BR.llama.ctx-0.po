msgid "incorrect mask (near `%s')"
msgstr "máscara incorreta (cerca de `%s')"

msgid "Unknown field `%s'"
msgstr "Campo desconhecido `%s'"

msgid "cannot set time on `%s'"
msgstr "não é possível estabelecer a data para o arquivo %s"

msgid "cannot truncate `%s'"
msgstr "não é possível truncar o arquivo %s"

msgid "command failed: %s"
msgstr "falha na orden: %s"

msgid "cannot stat `%s'"
msgstr "não foi possível obter estado (stat) do arquivo %s"

msgid "cannot remove directory `%s'"
msgstr "não é possível excluir o diretório %s"

msgid "cannot unlink `%s'"
msgstr "não é possível desconectar o %s"

msgid "Command exited successfully\n"
msgstr "A ordem foi concluída com sucesso."

msgid "Command failed with status %d\n"
msgstr "A ordem falhou com o estado %d."

msgid "Command terminated on signal %d\n"
msgstr "A ordem foi encerrada com a sinalização %d"

msgid "Command stopped on signal %d\n"
msgstr "A ordem foi interrompida com a sinalização %d"

msgid "Command dumped core\n"
msgstr "A ordem explodiu um núcleo"

msgid "Command terminated\n"
msgstr "A ordem foi concluída."

msgid "--stat requires file names"
msgstr "--stat necessita nomes de arquivos."

msgid "--set-times requires file names"
msgstr "--set-times necessita nomes de arquivos"

msgid "%s: Warning: Read error at byte %jd, while reading %zu byte"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "Cannot connect to %s: resolve failed"
msgstr ""
"Não é possível se conectar ao %s: falha na resolução do nome de domínio"

msgid "%s: File shrank by %s byte; padding with zeros"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "--checkpoint value is not an integer"
msgstr "O valor de --checkpoint não é um número inteiro."

msgid "Generated keyword/value pair is too long (keyword=%s, length=%s)"
msgstr ""
"O par chave/valor gerado é excessivamente longo (chave=%s, comprimento=%s)"

msgid "%s: file is the archive; not dumped"
msgstr "%s: o arquivo é próprio; não se pode copiar para outro lugar"

msgid "%s: File shrank by %s byte"
msgstr ""
"falha na verificação: a linha %<PRIuMAX> possui %<PRIuMAX> campos (esperado "
"%<PRIuMAX>)"

msgid "%s home page: <https://www.gnu.org/software/%s/>\n"
msgstr "Página de opções do %s: <https://www.gnu.org/software/%s/>"

msgid "OPTION"
msgstr "opção"

msgid "%.*s: ARGP_HELP_FMT parameter must be positive"
msgstr "%.*s: O parâmetro ARGP_HELP_FMT deve ser positivo"

