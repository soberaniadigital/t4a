msgstr "Opções de execução síncrona :"

msgid "N"
msgstr "N"

msgid ""
"Execute ARGS. Trigger checkpoints every Nth record (default 1). Useful with "
"--checkpoint and one of --cut, --append, --touch, --unlink"
msgstr ""
"Execute ARGS. Executes checkpoints every Nth record (default is 1). Useful "
"with --checkpoint and one of the following options - --cut, --append, "
"--touch or --unlink."

