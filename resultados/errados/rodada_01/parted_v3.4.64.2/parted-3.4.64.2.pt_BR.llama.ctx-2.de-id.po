msgstr ""
"tamanho da partição de %jd seções excede o máximo especificado na tabela de "
"particionamento %s do sistema operacional, que é definido em %jd."

msgid ""
"starting sector number, %jd exceeds the %s-partition-table-imposed maximum "
"of %jd"
msgstr ""
"O número de sector inicial, %jd excede o máximo especificado na tabela de "
"particionamento %s do sistema operacional DE/ID."

msgid "%s : Bad checksum on block %llu of type %s."
msgstr ""
"%s : Falha na verificação de soma de comprovação no bloco %llu do tipo %s."

msgid "%s : Didn't find rdb block, should never happen."
msgstr ""
"%s : Não foi possível encontrar o bloco rdb. Isso não deveria acontecer."

msgid "%s : Loop detected at block %d."
msgstr "%s : Bucle detectado no bloco %d."

msgid "%s : The %s list seems bad at block %s."
msgstr "%s : A lista %s parece estar com falhas no bloco %s."

