msgid ""
"START and END are disk locations, such as 4GB or 10%.  Negative values count"
" from the end of the disk.  For example, -1s specifies exactly the last "
"sector.\n"
msgstr ""
"INICIO e FIM são locais no disco, como por exemplo 4GB ou 10%. Valores "
"negativos contam a partir do final da unidade. Por exemplo, -1s especifica "
"precisamente o último setor."

msgid ""
"END is disk location, such as 4GB or 10%.  Negative value counts from the "
"end of the disk.  For example, -1s specifies exactly the last sector.\n"
msgstr ""
"FIN é uma localização em um disco, como 4GB ou 10%. Valores negativos contam"
" a partir do final da unidade. Por exemplo, -1s especifica precisamente o "
"último setor."

msgid "STATE is one of: on, off\n"
msgstr "ESTATO é um dos seguintes estados: ligado, desligado\n"

msgid "DEVICE is usually /dev/hda or /dev/sda\n"
msgstr "DISPOSITIVO é normalmente /dev/hda ou /dev/sda"

