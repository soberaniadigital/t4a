msgstr "Sólo as particções primárias podem ser partições de troca."

msgid "Only logical partitions can be a boot file."
msgstr "Sólo as partições lógicas podem ser um ficheiro de arranque."

msgid ""
"failed to set dvh partition name to %s:\n"
