msgstr "falha na abertura do dispositivo"

msgid "seeking on device failed"
msgstr "falha na busca no dispositivo"

msgid "writing to device failed"
msgstr "falha na escritura ao dispositivo"

msgid "reading from device failed"
msgstr "falha na leitura do dispositivo"

