msgstr "Tentando ler o ficheiro HFS com CNID %X após a conclusão do ficheiro."

msgid "Could not find sector %lli of HFS file with CNID %X."
msgstr "Não foi possível encontrar o setor %lli do fichê HFS com CNID %X."

msgid "Trying to write HFS file with CNID %X behind EOF."
msgstr ""
"Tentando escrever o ficheiro HFS com CNID %X após a conclusão do ficheiro."

msgid "Could not update the extent cache for HFS+ file with CNID %X."
msgstr ""
"Não foi possível atualizar o cache de extensões do arquivo HFS+ com CNID %X."

msgid "Trying to read HFS+ file with CNID %X behind EOF."
msgstr "Tentando ler o arquivo HFS+ com CNID %X após a conclusão do arquivo."

msgid "Could not find sector %lli of HFS+ file with CNID %X."
msgstr "Não foi possível encontrar o setor %lli do fichê HFS+ com CNID %X."

msgid "Trying to write HFS+ file with CNID %X behind EOF."
msgstr ""
"Tentando escrever o ficheiro HFS+ com CNID %X após a conclusão do ficheiro."

msgid "Sorry, HFS cannot be resized that way yet."
msgstr ""
