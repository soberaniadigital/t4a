msgstr "selecionar"

msgid "select DEVICE                            choose the device to edit"
msgstr "selecione o dispositivo a editar"

msgid "disk_set"
msgstr "seleção de disco"

msgid ""
"disk_set FLAG STATE                      change the FLAG on selected device"
msgstr "o estado do dispositivo selecionado mudou a bandeira para %s."

msgid "disk_toggle"
msgstr "disque_togougluar"

