msgstr "Espaço Livre"

msgid ""
"A %s %s partition was found at %s -> %s.  Do you want to add it to the "
"partition table?"
msgstr ""
"Foi encontrada uma partição %s %s no dispositivo de armazenamento em "
"/dev/sdXY -> %s. Você quer adicioná-la à tabela de partições?"

msgid "searching for file systems"
msgstr "buscando os sistemas de arquivos"

msgid "The resize command has been removed in parted 3.0"
msgstr "A ordem de redimensionamento foi removida no parted 3.0"

msgid ""
"Shrinking a partition can cause data loss, are you sure you want to "
"continue?"
msgstr ""
"Contrair uma partição pode provocar perda de dados, você realmente deseja "
"continuar?"

msgid "New device?"
msgstr "Novo dispositivo?"

msgid "alignment type(min/opt)"
msgstr "tipo de alinhamento (min/opt)"

