msgstr "Modelo: %s (%s) \n"

msgid "Disk %s: %s\n"
msgstr "Disco %s: %s\n"

msgid "Sector size (logical/physical): %lldB/%lldB\n"
msgstr "Tamanho do sector (lógico/físico): %lldB/%lldB"

msgid "Partition Table: %s\n"
msgstr "Tabulação de particípios: %s"

