msgstr "Número"

msgid "Start"
msgstr "Início"

msgid "End"
msgstr "Fim"

msgid "Size"
msgstr "tamanho"

msgid "Type"
msgstr "Tipo"

msgid "File system"
msgstr "Sistema de arquivos"

msgid "Name"
msgstr "Nome"

