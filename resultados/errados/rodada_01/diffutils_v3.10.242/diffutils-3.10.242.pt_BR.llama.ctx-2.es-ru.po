msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "Dávid Heiz (David Hayes)"

msgid "Richard Stallman"
msgstr "Richard Stallman (Richard Stallman)"

msgid "Len Tower"
msgstr "Len Tower"

msgid "invalid context length %s"
msgstr "a longitud de contexto %s não é válida"

msgid "pagination not supported on this host"
msgstr "o paginamento não é suportado neste host."

msgid "too many file label options"
msgstr "existe muito mais opções de rótulo para arquivos do que o necessário."

msgid "invalid width %s"
msgstr "largura não permitida '%s'"

msgid "conflicting width options"
msgstr "opções de largura conflitantes"

msgid "invalid horizon length %s"
msgstr "o número de linhas horizontais %s não é válido"

msgid "invalid tabsize %s"
msgstr "largura tabulação %s não é válida"

msgid "conflicting tabsize options"
msgstr "opções de tabsize conflitantes"

msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan."

msgid "    --normal                  output a normal diff (the default)"
msgstr ""
"    --normal                  exibir diferenças em formato padrão (básico)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   saída somente quando arquivos diferentes são "
"processados."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical-files  relatar quando duas pastas contêm arquivos "
"idênticos"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C %d, --context[=%d]   exibe %d (pelo padrão 3) linhas do contexto "
"copiado."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U %s, --unified[=%s]   exibe %<PRIuMAX> (padrão 3) linhas do contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      exibir como um script ed"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     keluaran RCS diferença (diff)"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            mostra em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W,--width=NUM           liberar o máximo de NUM (valor padrão é 130) "
"colunas para impressão"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             exibir apenas a coluna esquerda das linhas "
"comuns"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não exibe linhas comuns"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         mostra em qual função C está cada alteração\n"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   Mostrar a linha de função mais recente que "
"corresponda à RE."

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             utilizar LABEL em vez do nome de arquivo e da marca de tempo (w/e) \n"
"                        (pode ser repetido)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr "-t, --expand-tabs             ekspansi tab ke spasi dalam keluaran"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab             fazer com que os caracteres da linha se "
"alinhem horizontalmente, adicionando um caractere de tabulação no início "
"dessas linhas."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty\n"
"                        não insira espaços ou tabulação antes de uma linha vazia."

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr "-l, --paginate          direcionar a saída para 'pr' para paginarla"

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive         ´mente comparando subdiretórios recursivamente."

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não içar símbolos"

msgid "-N, --new-file                  treat absent files as empty"
msgstr "-N, --new-file          trata arquivos que não existam como vazios"

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   tratar o primeiro arquivo não existente como"
" vazio"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     desconsidere diferenças entre maiúsculas e "
"minúsculas ao comparar os nomes dos arquivos."

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  considerar pequeno e grande ao comparar o "
"nome do arquivo."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               excluir arquivos que correspondam ao PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         excluir arquivos que correspondam a um "
"padrão definido no FILE"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        comece com FILE ao comparar diretórios\n"

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1   comparar FILE1 com todos os operandos; \n"
"                        FILE1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2     comparar todos os operandos com FILE2; \n"
"                        FILE2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case       desconsiderar diferenças entre letras maiúsculas e "
"minúsculas no conteúdo do arquivo."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      desconsidere alterações devidas a expansões "
"de tabs."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space     abaixa os caracteres em branco no final da "
"linha"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       desconsidere as diferenças no número de "
"espaços em branco."

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space          descarta todos os espaços em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        abaixa as alterações em linhas vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE\n"
"        Ignore changes in lines that match the regular expression RE."

msgid "-a, --text                      treat all files as text"
msgstr ""
"-a, --text                      considerar todos os arquivos como texto"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar o retorno de carro no final da "
"entrada\n"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                    ler e escrever dados no modo binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NAME                ekskluzifikan berkat yang tergabung dengan "
"diff '#ifdef NAME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatar grupos de entrada GTYPE com o "
"formato GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          formatar todas as linhas de entrada no "
"formato LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT\n"
"        Formatar as linhas de entrada LTYPE em conformidade com o formato LFMT."

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Opsi format inicial oferece controle fino sobre o resultado de "
"diferenciação, generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'antigo', 'novo' ou 'sem alterações'. O valor de GTYPE é "
"LTYPE ou 'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode conter (só):\n"
"    %< linhas do arquivo1\n"
"    %> linhas do arquivo2\n"
"    %= linhas comuns aos arquivos1 e arquivo2\n"
"    %[-][largura][.[precisão]]{doxX}LETRA  especificação printf para LETRA\n"
"      As LETRAs podem ser como seguidas para grupos novos (em minúsculas para grupos antigos):\n"
"        F número da primeira linha\n"
"        L número da última linha\n"
"        N número de linhas = L-F+1\n"
"        E F-1\n"
"        M L+1\n"
"    %(A=B?T:E)  se A for igual a B então T, caso contrário E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"GFMT ou LFMT podem conter: \n"
"    %% \n"
"    %c'C'\tumor um caractere C\n"
"    %c'^'\tcaracter com código octal OOO (representando o símbolo ')\n"
"    C\tumor o carácter C"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal           tenta encontrar o conjunto de alterações mínimo do "
"Keras"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM mantém NUM linhas de prefícios e sufixos comuns\n"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files supõe que os arquivos sejam grandes e haja muitos "
"pequenos e dispersos alterações"

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=QUANDO]     saída em cor; QUANDO pode ser 'sempre', 'sem "
"necessidade' ou 'automático'; sem especificação, usa-se automaticamente."

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE   paleta de cores utilizada quando o --color está "
"ativo; PALETTE é uma lista separada por dois pontos das capacidades "
"terminfo."

msgid "    --help               display this help and exit"
msgstr "    --help              Mostrar ajuda desta interface e sair."

msgid "-v, --version            output version information and exit"
msgstr "-v, --version            Mostrar informações sobre a versão e sair."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr "FILES é 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Seja --from-file ou --to-file definidos, não há limites para arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se um arquivo for definido como '-', lê a entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Utilização: %s [OPÇÃO]... BÉCAS"

msgid "Compare FILES line by line."
msgstr "Bandando FILE barras por barras."

