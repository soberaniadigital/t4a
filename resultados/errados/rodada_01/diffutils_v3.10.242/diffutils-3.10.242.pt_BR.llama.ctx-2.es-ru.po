msgid "-b, --print-bytes          print differing bytes"
msgstr "-b, --print-bytes       exibe os bytes distintos."

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=%s  pulverizar os primeiros %s bytes de entrada inicial"
" das duas entradas"

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:SKIP2 \n"
"        pulando os primeiros SKIP1 bytes do arquivo FILE1\n"
"        e dos primeiros SKIP2 bytes do arquivo FILE2"

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose              imprime bytes e seus valores para fins de "
"depuração\n"

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr "-n, --bytes=%s          bandar como máximo %d byte"

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "--quiet, --silent      não exibir mensagens normais"

msgid "    --help                 display this help and exit"
msgstr "    --help              Mostrar esta ajuda e sair"

msgid "-v, --version              output version information and exit"
msgstr "-v, --version              Mostrar informações sobre a versão e sair."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "Utilização: %s [PILIHAN]... BERKAS1 [BERKAS2 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandingkan dua berkas byte per byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 e SKIP2 representam o número de bytes que devem ser pulados no início "
"de cada arquivo (valor padrão é zero)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos obrigatórios para opções longas também são obrigatórios para "
"as opções curtas."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Os valores SKIP podem ser multiplicados pelos seguintes sufixos de tamanho:\n"
"KB 1000, KB 1024, MB 1.000.000, MB 1.048.576,\n"
"GB 1.000.000.000, GB 1.073.741.824 e assim por diante para TB, PB, EB, ZB, YB."

msgid "If a FILE is '-' or missing, read standard input."
msgstr ""
"Se um arquivo for definido como '-' ou não ser definido, lê a entrada "
"padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"O status de saída é 0 se as entradas forem idênticas, 1 caso contrário e 2 "
"em caso de falha."

msgid "invalid --bytes value %s"
msgstr "valor --bytes inválido '%s'"

msgid "missing operand after %s"
msgstr "não há operando após '%s'"

msgid "extra operand %s"
msgstr "operando extra '%s'"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s diferem em byte %<PRIdMAX>, linhas %<PRIdMAX>"

