msgstr ""
"%s %s diferem: byte %<PRIdMAX>, linha %<PRIdMAX> é de %3o bits e %3o bytes."

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF em %s, que está vazio"

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF em %s após byte %<PRIdMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "cmp: EOF em %s após byte %<PRIdMAX>, linha %<PRIdMAX>"

