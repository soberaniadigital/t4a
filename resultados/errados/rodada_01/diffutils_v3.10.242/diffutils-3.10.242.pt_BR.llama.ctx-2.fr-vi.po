msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                  sair com o diff padrão (por defeito)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   chiapar apenas quando os arquivos são "
"diferentes."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr "-s, --report-identical-files  báo cáo khi có hai tập tin bằng nhau"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C NUM, --context[=NUM]   keluarkan NUM (baku 3) baris dari konteks yang"
" disalin"

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U SỐ, --unified[=SỐ]     xuất ra SỐ (mặc định là 3) dòng của ngữ cảnh"

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      excluir um script de edição (script)"

msgid "-n, --rcs                     output an RCS format diff"
msgstr ""
"-n, --rcs                     gera diferenças no formato RCS para keluaran "
"dalam format diff\n"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            Visualização em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NUM               keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             kết xuất chỉ cột bên trái của các dòng chung"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não exibir linhas idênticas"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         hiển thị cái mà từng hàm C thay đổi ở trong "
"đó."

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   Mostrar a linha de função mais recente "
"correspondente à RE"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pakai LABEL bukan nama berkas dan stempel waktu\n"
"                                (dapat diulang)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             mở rộng ký tự tab ra ký tự espaçamento quando "
"a saída é gerada."

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab             sábem preencher o tab antes do atual para "
"alinhar os tabs\n"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak\n"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty    cegah spazi e tab antes de linhas vazias na "
"saída do programa."

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                transfira dados de saída para 'pr' para "
"paginar."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 sincronizar subdiretórios de forma recursiva"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não aceitar links simbólicos"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N --novo-arquivo                    considerar o arquivo vazio se não "
"houver conteúdo"

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   anggap berkas pertama yang tidak ada sebagai"
" kosong"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     bỏ qua chữ HOA/thường khi so sánh các tên "
"tập tin"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  pertimbangkan besar kecil saat membandingkan"
" nama berkas"

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr "-x, --exclude=PAT               tanpa berkas yang cocok dengan PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         minta que berkat yang cocok dengan pola "
"dalam FILE"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        mulai dende com FILE ketika membandungkan "
"diretório e comparando nhiều thư mục."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1           bandar o FILE1 com todos os operandes; \n"
"                                   FILE1 pode ser um diretório ou outro arquivo"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2             bandar sempre os operandos com FILE2; \n"
"                                  FILE2 pode ser um diretório ou outro arquivo"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               não diferenciar maiúsculas e minúsculas no "
"conteúdo dos arquivos"

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr "-E, --ignore-tab-expansion      bỏ qua mọi thay đổi do mở rộng tab."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr "-Z, --ignore-trailing-space     bỏ qua tất cả dấu cách ở cuối dòng."

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       bỏ qua thay đổi gây ra bởi nhóm dấu cách."

msgid "-w, --ignore-all-space          ignore all white space"
msgstr ""
"-w, --ignore-all-space          abaixa tudo o que é espaço em branco "
"(espaços)"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        bỏ qua thay đổi do dòng trống"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore as para linhas que concordam com a "
"expressão regular RE."

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      xử lý mọi tập tin là văn bản thường"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar o retorno de carro no final da "
"entrada (dòng)\n"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                     Leia e escreva dados em binário\n"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=TÊN                 kết xuất tập tin đã trộn với khác biệt "
"“#ifdef TÊN”"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   format grup masukan GTYPE dengan GFMT "

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT           format semua baris masukan denga LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr "    --LTYPE-line-format=LFMT    định dạng cổ tiếp LTYPE với LFMT"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Opsi format inicial oferece controle fino sobre a saída de diff e generaliza"
" -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'antigo', 'novo' ou 'sem alteração'. GTYPE é LTYPE ou "
"'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode conter o seguinte : \n"
"    %< linhas do FILE1\n"
"    %> linhas do FILE2\n"
"    %= linhas comuns entre FILE1 e FILE2\n"
"    %[-][LARGEUR][.[PREC]]{doxX}LETRO  a especificação de LETRAS é idêntica à notação printf() \n"
"      onde os códigos possísive para as letras são em maiúsculas para o novo grupo, e minúsculas para o antigo grupo: \n"
"        F número da primeira linha\n"
"        L número da última linha\n"
"        N total de linhas = L-F+1\n"
"        E (F - 1)\n"
"        M (L + 1)    %(A=B?T:E) se A for igual a B então T, caso contrário E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"GFMT ou LFMT podem conter : \n"
"%%\n"
"%c'C'\tcaractere único C\n"
"%c'^'\tcaracter com cadeia octal ^^^\n"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal            cópia do conjunto de dados para um novo diretório e"
" limpeza dos arquivos temporários."

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM   guarde NUM linhas que tenham prefijos e sufixos "
"comuns"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files  assume that large and numerous small changes are "
"dispersed"

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=WHEN]       cor da saída; WHEN pode ser 'sempre', 'jamais' ou 'automático' (padrão);\n"
"                           --color sem argumento é equivalente a --color='automático'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    cromas utilizadas quando --color está ativo; "
"PALETTE é um conjunto de capacidades terminfo separados por virgula"

msgid "    --help               display this help and exit"
msgstr "    --help               exiba ajuda deste e saia"

msgid "-v, --version            output version information and exit"
msgstr ""
"-v, --version            mostra o nome e a versão do software e sai da "
"utilidade."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES adalah “FILE1 FILE2” ou “DIR1 DIR2” ou “DIR FICHIER” ou “FICHIER DIR”."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Seja utilizado o --from-file (de um arquivo) ou --to-file (para salvar em um"
" arquivo), sem limite para os arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o arquivo T_IN for '-', ler de entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Cách dùng: %s [OPTION]... CÁC_TIN"

msgid "Compare FILES line by line."
msgstr "Bandar FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr "valor %2s oci%1$s conflitante"

msgid "conflicting output style options"
msgstr ""
"conflicto de opções do gaya keluaran com níveis diferentes de formato para "
"saída padrão e alternativo"

msgid "invalid color %s"
msgstr "cor da %s não é válida"

msgid "-D option not supported with directories"
msgstr "A opção -D não é suportada para diretórios."

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios sama: %s e %s\n"

msgid "Only in %s: %s\n"
msgstr "Chinês apenas dentro de %s: %s\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr "O arquivo '%s' é um %s enquanto o diretório '%s' é um %s. \n"

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o sinal de menos (-) com um diretório"

msgid "Files %s and %s are identical\n"
msgstr "As pastas %s e %s são idênticas"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opções não compatíveis"

msgid "'-' specified for more than one input file"
msgstr "Disponibiliza '-' para mais de um arquivo de entrada."

msgid "read failed"
msgstr "falha na leitura"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exibir todas as alterações e conflitos no "
"arquivo de transferência"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"--ed                    excluir script ed que contém alterações de OLDFILE "
"para YOURFILE e depois inseriria no MYFILE."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --show-overlap          seperti -e, tapi apit konflik dalam kurung"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             semelhante a -e, mas apenas envolve alterações "
"que não se recupõem"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          semelhante ao -e, mas somente considera as "
"alterações que se sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          Comum como -x, porém pode causar conflitos de "
"abertura e fechamento em uma única linha."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          nóximo de comandos 'w' e 'q' ao script ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                 keluarkan berkas tergabung yang sebenarnya, "
"sesuai dengan -A bila tidak diberikan opsi lain\n"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                    Trata todos os arquivos como texto padrão\n"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     apagar o retorno de carro no final da entrada"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab           Tente criar uma tabulação reta adicionando um \n"
"                                espaço em branco antes de cada tabulador."

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM  utilizar PROGRAM para comparar as pastas"

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L,--label=LABEL           pakai LABEL sebagai pengganti nama berkas\n"
"                                (dapat diulang sampai dengan tiga kali)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  exiba ajuda deste e saia"

msgid "-v, --version               output version information and exit"
msgstr ""
"-v, --version                 Afirmar o nome e a versão do software para "
"obter informações detalhadas sobre ele antes de sair."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Pemakaian: %s [OPTION]... TẬP_TIN_CŨ MYFILE OLDFILE YOURFILE\n"

msgid "Compare three files line by line."
msgstr "Bandingkan tiga berkas baris per baris."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída por defeito é uma representação mais ou menos lisível para"
" um humano dos alterações. As opções -e, -E, -x, -X (e as correspondentes "
"longas) provocam a escrita de um script ed em vez da saída por padrão. "
"Finalmente, a opção -m (--merge) solicita que diff3 realize uma fusão "
"internamente e envie o arquivo resultante. Para entradas incomuns, isso é "
"mais robusto do que usar ed."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do keluaran é 0 se tudo correu bem, 1 em caso de conflito e 2 "
"quando houve algum erro."

msgid "internal error: screwup in format of diff blocks"
msgstr "erro interno de sintaxe: mistura dentro do formato dos blocos 'diff'."

msgid "%s: diff failed: "
msgstr "%s: falha ao executar 'diff' :"

msgid "internal error: invalid diff type in process_diff"
msgstr ""
"Erro interno: tipo de 'diff' inválido no process_diff (xorar diferentes)"

msgid "invalid diff format; invalid change separator"
msgstr "DIFFIMOS NÃO É VÁLIDO; SEPARADOR DE CHAMADA NAO É VALIDO"

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença não é válido; a última linha está incompleta."

msgid "subsidiary program %s could not be invoked"
msgstr "programa subsidiário %s não pode ser chamado"

msgid "invalid diff format; incorrect leading line chars"
msgstr "format diff tidak valid; karakter leading line tidak tepat"

msgid "internal error: invalid diff type passed to output"
msgstr "Erro interno : tipo de 'diff' inválido fornecido como saída"

msgid "input file shrank"
msgstr "o arquivo de entrada se encurtou"

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar o nome do arquivo %s e %s"

msgid "%s: recursive directory loop"
msgstr "%s: loop direto no repertório recursivo"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=FILE            Execute interactively, send output to FILE."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr ""
"-i, --ignore-case            ignorar maiúsculas e minúsculas semelhantes"

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr "-E, --ignore-tab-expansion   bỏ qua mọi thay đổi do mở rộng tab"

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space abaixo de cada linha restante espaços em branco"

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    bỏ qua thay đổi gây ra bởi nhóm dấu cách."

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space       bỏ qua tất cả dấu cách"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr "-B, --ignore-blank-lines     bỏ qua thay đổi do dòng trống\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore as para linhas que concordam com a "
"expressão regular RE."

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      apagar o retorno de carro no final da entrada "
"(carriage return)"

msgid "-a, --text                   treat all files as text"
msgstr "-a, --text                   perlakukan semua berkas sebagai teks"

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            Keeps only the left column of identical "
"horizontal lines."

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines  não exibir linhas semelhantes"

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs            khai triển ký tự tab ke spasi dalam output\n"

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                cópia do conjunto de dados para um novo "
"diretório e substituição dos arquivos originais com cópias modificadas."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      assume that large files with small scattered "
"changes are being processed."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr ""
"    --diff-program=PROGRAM   utilizar PROGRAM para comparar as pastas "
"(directórios)"

msgid "    --help                   display this help and exit"
msgstr "    --help                   exiba ajuda deste e saia"

msgid "-v, --version                output version information and exit"
msgstr ""
"-v, --version                Mostrar o nome e a versão do software e sair."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Cách dùng: %s [OPTION]... TÍPIO1 TÍPIO2\n"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Fusão de diferenças entre o arquivo %s e o arquivo %s."

msgid "cannot interactively merge standard input"
msgstr "não é possível combinar a entrada padrão de forma interativa"

msgid "both files to be compared are directories"
msgstr "as duas pastas que estão sendo comparadas são diretórios"

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed: Siga e utilize as duas versões, cada uma com seu próprio cabeçalho. \n"
" eb: Siga e utilize as duas versões. \n"
" el ou e1: Siga e utilize a versão de esquerda. \n"
" er ou e2: Siga e utilize a versão de direita. \n"
" e: Abandone ambas as versões para criar uma nova. \n"
" l ou 1: Utilize a versão de esquerda. \n"
" r ou 2: Utilize a versão de direita. \n"
" s: Inclua linhas idênticas sem gerir explicitamente o output. \n"
" v: Inclua e exporte linhas idênticas com detalhes explícitos. \n"
" q: Sair."

msgid "unrecognized prefix: %s"
msgstr "prefíxo não reconhecido: %s"

msgid "unparsable value for --palette"
msgstr "valor não pode ser analisado para --palette"
