msgstr "MOT-CLEF... (continuação da tradução necessária)"

msgid "The --regex option is enabled by default."
msgstr "Opção --regex habilitada por padrão."

msgid "print verbose warning messages"
msgstr "exibindo mensagens de aviso extensivas"

msgid "interpret each keyword as a regex"
msgstr "interpretar cada palavra-chave como uma expressão regular"

