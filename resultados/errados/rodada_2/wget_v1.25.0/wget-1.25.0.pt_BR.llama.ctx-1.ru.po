msgstr "PREDUEPRAZDENICIE"

msgid "%s: No certificate presented by %s.\n"
msgstr ""
"%s: Não há certificado, apresentado por %s. Para obter mais informações "
"sobre como criar um novo ou importar um existente, consulte a documentação "
"do sistema."

msgid "%s: The certificate of %s is not trusted.\n"
msgstr ""
"%s: Não há confiança no certificado para %s. Por favor, verifique se o seu "
"certificado é válido e atualizado."

