"FINISHED --%s--\n"
"Total wall clock time: %s\n"
"Downloaded: %d files, %s in %s (%s)\n"
msgstr ""
"ZAVERSHENO --%s--\n"
"Observado no tempo: %s\n"
"Carregados: %d arquivos, %s em %s (%s)"

msgid "Download quota of %s EXCEEDED!\n"
msgstr "OBSOLETE LIMITATION OVERRUN (%s)!"

msgid "-O not supported for metalink download. Ignoring.\n"
msgstr "O parâmetro '-O' não é suportado ao baixar metalink. É ignorado."

msgid "[--trust-server-names %s, --directory-prefix=%s]\n"
msgstr "[--trust-server-names %s, --directory-prefix=%s]"

msgid "Planned metalink file: %s\n"
msgstr "Planiando arquivo metalink: %s"

msgid "Secured metalink file: %s\n"
msgstr "Arquivo metalink seguro: %s"

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Ignoramos o arquivo metalink. Nome de entrada inseguro."

msgid "Processing metaurl %s...\n"
msgstr "Tratamento de URL metadados %s…"

msgid "Rejecting metaurl file %s. Unsafe name.\n"
msgstr "Ignoramos o arquivo metaurl %s. Nome inseguro."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro de download %s. Ignorando metaurl."

msgid "Unable to parse metaurl file %s.\n"
msgstr "Não foi possível processar o arquivo metaurl %s."

msgid "Metaurls processing returned with error.\n"
