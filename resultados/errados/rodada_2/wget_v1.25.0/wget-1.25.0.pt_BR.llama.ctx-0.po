msgstr "%s: parâmetro inválido — «-n%c»"

msgid "Debugging support not compiled in. Ignoring --debug flag.\n"
msgstr "Assembled without debugging support. The --debug flag is ignored."

msgid ""
"Both --no-clobber and --convert-links were specified, only --convert-links "
"will be used.\n"
msgstr ""
"Serão utilizadas somente as opções --convert-links, pois são especificadas "
"junto com --no-clobber."

msgid ""
"Both --no-clobber and --convert-file-only were specified, only --convert-"
"file-only will be used.\n"
msgstr ""
"São especificados imediatamente --no-clobber e --convert-file-only, será "
"utilizado apenas o --convert-file-only."

msgid "Can't be verbose and quiet at the same time.\n"
msgstr ""
"Não é possível utilizar simultaneamente os modos verboso e silencioso."

msgid "Can't timestamp and not clobber old files at the same time.\n"
msgstr ""
"Não é possível utilizar simultaneamente marcadores temporários e não exaurir"
" arquivos antigos."

msgid "Cannot specify both --inet4-only and --inet6-only.\n"
msgstr ""
"Não é possível especificar e --inet4-only, e --inet6-only simultaneamente."

msgid ""
"Cannot specify both -k or --convert-file-only and -O if multiple URLs are given, or in combination\n"
"with -p or -r. See the manual for details.\n"
"\n"
msgstr ""
"Não é permitido especificar simultaneamente -k ou --convert-file-only e -O, "
"se forem indicados vários URLs, ou em combinação com parâmetros -p ou -r. "
"Detalhes estão disponíveis na documentação."

msgid ""
"WARNING: combining -O with -r or -p will mean that all downloaded content\n"
"will be placed in the single file you specified.\n"
"\n"
msgstr ""
"PRECARDAÇÃO: combinação do parâmetro -O com o -r ou -p indica que todos os "
"dados carregados serão colocados em um único arquivo."

msgid ""
"WARNING: timestamping does nothing in combination with -O. See the manual\n"
"for details.\n"
"\n"
msgstr ""
"PRELUNAR: trabalhar com marcações de tempo não está funcionando, se houver o"
" parâmetro -O. Detalhes podem ser vistos no manual."

msgid ""
"WARC output does not work with --no-clobber, --no-clobber will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com o parâmetro --no-clobber, esse parâmetro será"
" desabilitado."

msgid ""
"WARC output does not work with timestamping, timestamping will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com marcas de tempo, as marcações de tempo serão "
"desligadas."

msgid "WARC output does not work with --spider.\n"
msgstr "O output WARC não funciona com o --spider."

msgid ""
"WARC output does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O output WARC não funciona com --continue ou --start-pos; eles serão "
"desabilitados."

msgid ""
"Digests are disabled; WARC deduplication will not find duplicate records.\n"
msgstr ""
"Relatório de desligamento; a duplicação WARC não encontrará registros "
"repetidos."

msgid ""
"Compression does not work with --continue or --start-pos, they will be "
"disabled.\n"
msgstr ""
"O comprimento não funciona com --continue ou --posInicial; eles serão "
"desabilitados."

msgid "Cannot specify both --ask-password and --password.\n"
msgstr ""
"Não é possível especificar simultaneamente --ask-password e --password."

msgid ""
"WARNING: No username set with --ask-password. This is usually not what you "
"want.\n"
msgstr ""
"PRECARDAÇÃO: não foi especificado o nome do usuário, mas há a opção --ask-"
"password. Normalmente, isso não é necessário."

msgid ""
"Specifying both --start-pos and --continue is not recommended; --continue "
"will be disabled.\n"
msgstr ""
"Não recomendamos a utilização simultânea de --start-pos e --continue; o "
"último será desabilitado."

msgid "%s: missing URL\n"
msgstr "%s: URL não encontrada\n"

msgid "You cannot specify both --post-data and --post-file.\n"
msgstr ""
"Não é permitido especificar --post-data e --post-file simultaneamente."

msgid ""
"You cannot use --post-data or --post-file along with --method. --method "
"expects data through --body-data and --body-file options\n"
msgstr ""
"Não é permitido o uso simultâneo de --post-data ou --post-file com --method."
" O parâmetro --method implica que os dados devem estar nos campos --body-"
"data e --body-file."

msgid ""
"You must specify a method through --method=HTTPMethod to use with --body-"
"data or --body-file.\n"
msgstr ""
"Para utilizar o parâmetro --body-data ou --body-file, é necessário "
"especificar o método de comunicação através do parâmetro "
"--method=HTTPMethod."

msgid "You cannot specify both --body-data and --body-file.\n"
msgstr ""
"Não é permitido especificar --body-data e --body-file simultaneamente."

msgid "This version does not have support for IRIs\n"
msgstr "Esta versão não suporta IRI."

msgid ""
"-k or -r can be used together with -O only if outputting to a regular "
"file.\n"
msgstr ""
"O parâmetro -k ou -r pode ser utilizado somente em conjunto com o -O, se a "
"saída for produzida em um arquivo normal. \n"

msgid ""
"--convert-links or --convert-file-only can be used together only if "
"outputting to a regular file.\n"
msgstr ""
"O parâmetro --converter-links ou --converter-file-only pode ser utilizado "
"simultaneamente apenas se o resultado for produzido em um arquivo normal. \n"

msgid "Failed to init libcares\n"
msgstr "Erro de inicialização do libcares"

msgid "Failed to init c-ares channel\n"
msgstr "Erro de inicialização do canal c-ares"

msgid "Failed to parse IP address '%s'\n"
msgstr "falha na análise do endereço IP \"%s\""

msgid "Failed to set DNS server(s) '%s' (%d)\n"
msgstr ""
"Não foi possível atribuir o(s) servidor(es) DNS para a entrada de dados "
"especificada (%d)."

msgid "No URLs found in %s.\n"
msgstr "URLs não encontradas no arquivo %s."

msgid "Unable to parse metalink file %s.\n"
msgstr "Não foi possível processar o arquivo metalink %s."

msgid "Could not download all resources from %s.\n"
msgstr "Não é possível baixar todos os recursos do %s."

msgid ""
"FINISHED --%s--\n"
"Total wall clock time: %s\n"
"Downloaded: %d files, %s in %s (%s)\n"
msgstr ""
"ZARGESTEU --%s--\n"
"Obrigado pelo seu tempo de espera.\n"
"Tempo total: %s minutos e %d segundos (%<PRIuMAX>)\n"
"Arquivos carregados: %d arquivos em %s horas, com um tamanho médio por arquivo de %s bytes\n"

msgid "Download quota of %s EXCEEDED!\n"
msgstr "Obrigado, mas você não pode continuar a carregar (%s)!"

msgid "-O not supported for metalink download. Ignoring.\n"
msgstr "O parâmetro -O não é suportado ao baixar metalink. É ignorado."

msgid "[--trust-server-names %s, --directory-prefix=%s]\n"
msgstr "[--trust-server-names %s, --directory-prefix=%s]"

msgid "Planned metalink file: %s\n"
msgstr "O arquivo de referência metalink planejado é %s"

msgid "Secured metalink file: %s\n"
msgstr "Arquivo seguro metalink: %s"

msgid "Rejecting metalink file. Unsafe name.\n"
msgstr "Ocultando o arquivo metalink. Nome de entrada inseguro."

msgid "Processing metaurl %s...\n"
msgstr "Tratamento de metadados %s...\n"

