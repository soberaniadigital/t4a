msgstr "Ocultando o arquivo metaurl %s. Nome inseguro."

msgid "Failed to download %s. Skipping metaurl.\n"
msgstr "Erro de download do arquivo %s. Ignoramos metaurl."

msgid "Unable to parse metaurl file %s.\n"
msgstr "Não foi possível processar o arquivo metaurl %s."

msgid "Metaurls processing returned with error.\n"
msgstr "A análise do metaupload retornou um erro."

msgid "Resource type %s not supported, ignoring...\n"
msgstr "Tipo de recurso %s não é suportado, ignorado…"

msgid "Could not open downloaded file.\n"
msgstr "Não foi possível abrir o arquivo baixado."

msgid "Computing size for %s\n"
msgstr "Calcula-se o tamanho do arquivo %s"

msgid "File size not declared. Skipping check.\n"
msgstr "O tamanho do arquivo não foi declarado. A verificação é ignorada."

msgid "Could not get downloaded file's size.\n"
msgstr "não foi possível obter o tamanho do arquivo salvo."

msgid "Size mismatch for file %s.\n"
msgstr "O tamanho do arquivo %s não é compatível."

msgid "Size matches.\n"
msgstr "O tamanho é igual."

msgid "Computing checksum for %s\n"
msgstr "Calcula-se a soma de verificação %s"

