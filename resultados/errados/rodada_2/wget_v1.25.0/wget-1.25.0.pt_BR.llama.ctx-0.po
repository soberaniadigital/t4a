msgstr ""
"Não é possível abrir o arquivo baixado para verificação de assinatura. Para "
"obter mais informações, tente 'verificar-assinatura --help'."

msgid "GPGME data_new_from_mem: %s\n"
msgstr "data_new_from_mem: %s\n"

msgid "GPGME op_verify: %s\n"
msgstr "op_verificar do GPGME: %s"

msgid "GPGME op_verify_result: NULL\n"
msgstr "Resultado da verificação do GPGME: NULL"

msgid "Signature validation succeeded.\n"
msgstr "A assinatura está correta."

msgid "Invalid signature. Rejecting resource.\n"
msgstr "A assinatura é inválida. Descartamos o fonte."

msgid "Data matches signature, but signature is not trusted.\n"
msgstr ""
"Os dados estão assinados corretamente, mas não há confiança na assinatura."

msgid "No checksums found.\n"
msgstr "As contas de caixa não foram encontradas."

msgid "Failed to download %s. Skipping resource.\n"
