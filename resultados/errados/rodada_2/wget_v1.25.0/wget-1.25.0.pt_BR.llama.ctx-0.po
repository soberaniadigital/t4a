msgid ""
"\n"
"Originally written by Hrvoje Niksic <hniksic@xemacs.org>.\n"
msgstr "Autor original da versão: Hrvoje Niksic <hniksic@xemacs.org>."

msgid "Please send bug reports and questions to <bug-wget@gnu.org>.\n"
msgstr ""
"Para enviar mensagens sobre erros e perguntas, envie para <bug-"
