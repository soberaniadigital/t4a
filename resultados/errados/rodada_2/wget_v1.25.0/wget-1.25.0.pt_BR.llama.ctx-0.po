msgid "%s: Invalid --execute command %s\n"
msgstr "%s: Comando inválido --execute %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Expressão lógica inválida; use 'on' ou 'off'.\n"

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: Erro; use 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr ""
"%s: %s: Número inválido. Por favor, verifique seu input e tente novamente."

msgid "%s: %s must only be used once\n"
msgstr "%s: a variável %s deve ser utilizada apenas uma vez."

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor incorreto para o byte %s"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Valor de tempo inválido\n"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: O intervalo de tempo é negativo\n"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"Para uso de askpass, é necessário uma linha de comando ou variável de "
"ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "%s: %s: Invalid value %s.\n"
msgstr ""
"%s: %s: Valor inválido para o campo %s. Por favor, verifique novamente."

msgid "%s: %s: Invalid header %s.\n"
msgstr ""
"%s: Campo %d: Título inválido. O campo deve conter apenas letras e espaços "
"em branco."

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr ""
"%s: Campo de título WARC %d inválido. A caminho do arquivo, o campo 'Título'"
" não foi encontrado ou está vazio."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr "%s: %s: Tipo de progresso inválido '%s'.\n"

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição não permitida '%s', utilize "
"[unix|vms|windows],[minúsculas|maiúsculas],[sem controle],[ASCII]."

msgid "Encoding %s isn't valid\n"
msgstr "Codificação inválida %s\n"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "O conversor de %s para %s não é suportado."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes inválida ou incompleta."

msgid "Unhandled errno %d\n"
msgstr "Erro de código não tratado %d\n"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: local não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no encoder IDN (%d): %s\n"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para o caso de letras minúsculas: %d:%s\n"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "O fluxo de saída é redirecionado para %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: a opção %s foi desabilitada. (Desligamento do registro.)\n"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Utilização: %s [PARAMETRO]... [URL]...\n"

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para parâmetros longos são obrigatórios e para os"
" curtos também. Para mais informações, tente 'comando --help'."

msgid "Startup:\n"
msgstr "Iniciando o processo...\n"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr " -V,--versão           Mostrar versão do Wget e encerrar a operação \n"

msgid "  -h,  --help                      print this help\n"
msgstr "--help\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr "-b --background, após o término do programa, vá para o modo de fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr ""
"  -e, --execute=%s\n"
"Executar a comando especificado no estilo de configuração do wgetrc."

msgid "Logging and input file:\n"
msgstr "Registro e arquivo de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr ""
" -o, --output-file=FILE\n"
"    Escrever mensagens no FILE."

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"--append-output=arquivo\n"
"dopor favor, adicione mensagens ao final do arquivo."

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr "--debug\n"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "--wdebug              Mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "--quiet\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "-v, --verbose Mostrar informações detalhadas (padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr "-nv --sem verbos\n"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=UNITO    unidades de medida da velocidade do sinal\n"
"                             determinar UNIDADEM. A unidade pode ser igual a bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
" -i, --input-file=FILE     carregar URLs de acordo com o arquivo local ou "
"externo\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"--input-metalink=FILE\n"
"    baixar arquivos listados no FILE Metalink local."

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr "-F, --force-html         considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"--base=URL\n"
"                     considerar que as ligações do arquivo de entrada (-i -F) são relativas à URL especificada."

msgid "       --config=FILE               specify config file to use\n"
msgstr "--config=FILE\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config           não ler arquivos de configuração\n"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registros das razões para o rejeito de URL em "
"FILE\n"

msgid "Download:\n"
msgstr "Carregamento em progresso."

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"--tries=ЧИСЛО             definir QUANTIDADE de tentativas (0 sem limite)\n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"--retry-connrefused\n"
"Tente novamente, mesmo que o servidor tenha recusado a conexão."

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"--retry-on-host-error     considerar erros de host não críticos, "
"aleatórios\n"

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr ""
"--retry-on-http-error=ERROS HTTP, list (separated by comma) of errors that "
"cause a retry."

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr ""
" -O, --output-document=FILE\n"
"    Escrever documentos no FILE."

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"--no-clobber, --sem-overwrite\n"
"                    Ignora a cópia de arquivos que levariam à substituição ou sobreposição com arquivos existentes."

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr "--não-netrc                   não tentar obter dados do .netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"--continue --continuação\n"
"                        Continue a carregar parcialmente um arquivo que já foi carregado em partes."

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"--start-pos=SEMANA_INICIAL\n"
"iniciar a carregamento da semana inicial (considerado como 0)"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr "--progress=TIP\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"--show-progress Mostrar o indicador de progresso em qualquer modo detalhado."

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"--timestamping\n"
"                    --data_lastest, apenas se não for mais recente do que os locais."

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"--no-use-server-timestamps    não utilizar a verificação de modificação "
"desde para solicitações no modo que considera marcas de tempo do servidor\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"--sem uso de timestamps locais     não habilitar timestamp local, obtido do "
"servidor\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "--server-response         resposta do servidor\n"

msgid "       --spider                    don't download anything\n"
msgstr "--spider                   Não carregar nada"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"--timeout=SEGUNDOS         configuração de todos os tempos limite igual ao "
"número SEGUNDO\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"--dns-servers=ADRESSA\n"
"                 --dns-servers=Аедимо Ческоне\n"
"                 (через запятую)\n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"--bind-dns-address=ADRESSE\n"
"    Associar o endereço DNS ao ADRESSE do computador local (nome ou IP)"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"--dns-timeout=SEC instalação do timeout de pesquisa DNS em segundos (SEC)"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"--conexao_timeout=SEC\n"
"Configuração do tempo limite de conexão em segundos."

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr "--read-timeout=SEC instalação do timeout de leitura em SEC\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"--wait=SEGUNDOS            pausa em segundos entre as chamadas\n"
"                 (quando carregar mais de um URL)"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS       pausa de %d segundos entre tentativas "
"sucessivas de carregamento (quando há mais de um URL a ser baixado) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"--espera aleatória              pausa de 0.5*WAIT...1.5*WAIT segundos entre "
"as cargas (quando carregar mais do que um URL)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr "--no-proxy                explicitamente desligue o proxy"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"--quota=ЧИСЛО             -Q,  --quota=ЧИСЛО             установить величину"
" квоты загрузки в ЧИСЛО"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"--bind-address=ADRESSE\n"
"                      vincular ADRESSE (nome do computador ou endereço IP) local"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=LIMITE_RATE     limitar a velocidade de transferência "
"das chamadas para uma certa taxa (LIMITE_RATE)"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr "--no-dns-cache            Desligue o cache de DNS-pedidos"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS utilizar em nomes de arquivos caracteres, \n"
"                    aceitos pela OS\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"--ignorar-caso         ignorar maiúsculas e minúsculas ao comparar arquivos "
"ou pastas\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "--inet4-only              conectar apenas a endereços IPv4\n"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "--ipv6 somente\n"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"--prefer-family=SEMEISSTVO conectar primeiro aos endereços do sistema "
"familiar (pode ser IPv6, IPv4 ou nenhum) para garantir a compatibilidade com"
" dispositivos semelhantes."

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr "--user=USUÁRIO       instale e ftp- e http- usuário em USUÁRIO\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr ""
"--password=PARAOL\n"
"    para configurar o ftp e http com a mesma senha PARAOL."

msgid "       --ask-password              prompt for passwords\n"
msgstr "--pedir-senha            pedir senhas"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=CMD     especificar o manipulador de pedidos para "
"solicitar nome do usuário e senha. Se a CMD não for especificada, será "
"utilizado a variável ambiente WGET_ASKPASS ou SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "--no-iri                  desligar a suporte para IRI\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr "--local-encoding=KDR utilizar KDR como codificação local para URI\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr "--remote-encoding=KDR utilizar KDR como codificação remota padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "--unlink                     remover arquivo antes de apagar\n"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"--keep-badhash            deixar arquivos com hashes de controle incorretos "
"(adicionando .badhash)"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"--metalink-index=NUMERO\n"
"        Metalink application/metalink4+xml\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"--metalink-over-http utilizar meta dados Metalink a partir do cabeçalho de "
"resposta HTTP."

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr "--localização preferida dos recursos Metalink"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"--xattr                   habilitar armazenamento de dados metadados em "
"arquivos extensos com atributos adicionais\n"

msgid "Directories:\n"
msgstr "Categorias:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "--nd --no-directories           não cria catálogos"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr ""
"-x, --force-directories: pressione para criar os diretórios necessários "
"obrigatoriamente."

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr "-nH,--no-host-directories      não cria diretórios no host\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr "--protocol-directories utilizar o nome do protocolo nas pastas\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "--prefixar diretório=PREFIXO/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"--cut-dirs=CÓMOLAS\n"
"                    ignorar CÓMOLAS componentes removidos do catálogo"

msgid "HTTP options:\n"
msgstr "Parâmetros HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "--http-user=USUÁRIO HTTP\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "--http-password=PARAOLH\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "--sem-cache             ignorar dados armazenados no servidor\n"

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"--default-page=NOME_PAGE\n"
"Para alterar o nome da página por defeito (geralmente 'index.html'), utilize a opção --default-page com seu valor desejado."

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"--ajustar extensão\n"
"                   salvar documentos HTML/CSS com os respectivos"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"--ignorar-comprimento         ignorar o campo de cabeçalho 'Content-Length'"

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr ""
"--header=%s\n"
"de inserir uma linha entre os cabeçalhos."

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TYPE\n"
"         tipo de compressão: auto, gzip ou none\n"
"         (por padrão: none)"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"--max-redirect          máximo permitido de redirecionamentos para a página\n"
"                               na paginação da URL."

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"--proxy-user=USUÁRIO.   configurar o USUÁRIO como nome de usuário para proxy"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"--proxy-password=PROXÍA\n"
"                   definir PROXÍA como a senha do proxy."

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"--referer=URL\n"
"incluir no cabeçalho HTTP do pedido \"Referer: URL\""

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "--salvar-cabeçalhos          salvar HTTP-cabeçalhos em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
" -U, --user-agent=AGENT      identificar como AGENT em vez de Wget/VERSO\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"--no-http-keep-alive    desligar o suporte HTTP (conexões persistentes)"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--não-uso-cookies"

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"--load-cookies=arquivo\n"
"Carregue cookies do arquivo 'arquivo' antes de iniciar o jogo."

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr ""
"--save-cookies=arquivo\n"
"Salvar cookies no arquivo após sessão."

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr "--keep-session-cookies (permanentes)\n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"--post-data=STRINGA utilizar método POST; envio de STRINGA como dados."

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"--post-file=arquivo\n"
"usar método POST; envio do conteúdo da arquiv\\u00e1ria."

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod     utilizar método \"HTTPMethod\" no cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"--body-data=STRINGA\n"
"de enviar STRINGA como dados; DEVE SER especificado o parâmetro --method."

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        envio do conteúdo de FILE; \n"
"                               DEVE SER OBRIGADO especificar o parâmetro --method."

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"--content-disposition   considerar o cabeçalho Content-Disposition ao "
"escolher os nomes para arquivos locais (Exemplificativo)"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"--content-on-error      exibir dados aceitos em caso de erro do servidor\n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"--auth-no-challenge enviar informações sobre autenticação\n"
"Basic HTTP sem esperar pelo primeiro resposta do servidor"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Parâmetros HTTPS (SSL/TLS):\n"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=SSLv3     escolha do protocolo de segurança: auto, "
"SSLv2, SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr "--https-only             apenas por meio de links seguros HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr "--não verificar certificado do servidor"

msgid "       --certificate=FILE          client certificate file\n"
msgstr "--certificado=ARQUIVO\n"

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=TIPO   tipo de certificado do usuário: PEM ou "
"DER\n"

msgid "       --private-key=FILE          private key file\n"
msgstr "--private-key=FILE       arquivo de chave privada\n"

msgid "       --private-key-type=TYPE     private key type, PEM or DER\n"
msgstr "--private-key-type=TIPO   tipo de chave privada: PEM ou DER\n"

msgid "       --ca-certificate=FILE       file with the bundle of CAs\n"
msgstr "--ca-certificate=FILE    arquivo com conjunto de CA"

msgid ""
"       --ca-directory=DIR          directory where hash list of CAs is "
"stored\n"
msgstr ""
"--ca-directory=КАТ\n"
"catologo, no qual é armazenado o lista de CA."

msgid "       --crl-file=FILE             file with bundle of CRLs\n"
msgstr "       --crl-file=FILE          arquivo com lista de CRL\n"

msgid ""
"       --pinnedpubkey=FILE/HASHES  Public key (PEM/DER) file, or any number\n"
"                                   of base64 encoded sha256 hashes preceded by\n"
"                                   'sha256//' and separated by ';', to verify\n"
"                                   peer against\n"
msgstr ""
"       --pinnedpubkey=FILE/HASHES Faixa de hashes sha256 em base64, "
"começando com 'sha256//' e separados por ';', que é usada para verificar o "
"nó responder"

msgid ""
"       --random-file=FILE          file with random data for seeding the SSL"
" PRNG\n"
msgstr "--random-file=FILE       arquivo com dados aleatórios para RNG SSL\n"

msgid ""
"       --egd-file=FILE             file naming the EGD socket with random "
"data\n"
msgstr ""
"--egd-file=FILE          arquivo, definindo soquete EGD com dados "
"aleatórios\n"

msgid ""
"       --ciphers=STR           Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly.\n"
"                                   Use with care. This option overrides --secure-protocol.\n"
"                                   The format and syntax of this string depend on the specific SSL/TLS engine.\n"
msgstr ""
"       --ciphers=%s         definir prioridade da cifra (GnuTLS) ou lista de"
" criptos (OpenSSL) diretamente. Utilize com cuidado. Este parâmetro "
"substitui o valor do protocolo seguro."

msgid "HSTS options:\n"
msgstr "Parâmetros HSTS:\n"

msgid "       --no-hsts                   disable HSTS\n"
msgstr "--no-hsts             desligar HSTS"

msgid ""
"       --hsts-file                 path of HSTS database (will override "
"default)\n"
msgstr ""
"--hsts-file             caminho para a base de dados HSTS (substitui o valor"
" padrão)"

msgid "FTP options:\n"
msgstr "Parâmetros FTP:\n"

msgid ""
"       --ftp-stmlf                 use Stream_LF format for all binary FTP "
"files\n"
msgstr ""
"       --ftp-stmlf             utilizar o formato Stream_LF para todos os "
"arquivos binários FTP\n"

msgid "       --ftp-user=USER             set ftp user to USER\n"
msgstr "--ftp-user=POLZOWATEL JÁ INSTALADO FTP USUARIO POLZOWATEL"

msgid "       --ftp-password=PASS         set ftp password to PASS\n"
msgstr "--ftp-password=PARAOL\n"

msgid "       --no-remove-listing         don't remove '.listing' files\n"
msgstr "--não remova a lista de arquivos '*.listing'"

msgid "       --no-glob                   turn off FTP file name globbing\n"
msgstr ""
"--no-glob                 desligar as máscaras para nomes de arquivos FTP\n"

msgid "       --no-passive-ftp            disable the \"passive\" transfer mode\n"
msgstr ""
"--no-passive-ftp\n"
"Desligue o modo 'passivo' do FTP."

msgid "       --preserve-permissions      preserve remote file permissions\n"
msgstr ""
"--preserve-permissions: manter os direitos de acesso aos arquivos remotos\n"

msgid ""
"       --retr-symlinks             when recursing, get linked-to files (not "
"dir)\n"
msgstr ""
"--retr-symlinks         --recurso recursivo carregar arquivos por links (não"
" catálogos)"

msgid "FTPS options:\n"
msgstr "Parâmetros FTPS:\n"

msgid ""
"       --ftps-implicit                 use implicit FTPS (default port is "
"990)\n"
msgstr ""
"--ftps-implícito                 utilizar FTPS de forma implícita (porta "
"padrão é o 990)"

msgid ""
"       --ftps-resume-ssl               resume the SSL/TLS session started in the control connection when\n"
"                                         opening a data connection\n"
msgstr ""
"--ftps-resume-ssl             reiniciar sessão SSL/TLS iniciada no canal de "
"controle, ao abrir o canal de dados."

msgid ""
"       --ftps-clear-data-connection    cipher the control channel only; all "
"the data will be in plaintext\n"
msgstr ""
"--ftps-clear-data-connection    --canal de controle criptografado; dados não"
" são criptografados\n"

msgid ""
"       --ftps-fallback-to-ftp          fall back to FTP if FTPS is not "
"supported in the target server\n"
msgstr ""
"--ftps-fallback-to-ftp          retornar ao FTP, se o FTPS não for suportado"
" pelo servidor."

msgid "WARC options:\n"
msgstr "Parâmetros WARC:\n"

msgid ""
"       --warc-file=FILENAME        save request/response data to a .warc.gz "
"file\n"
msgstr ""
"--warc-file=FILE\n"
"    Escrever dados de solicitação/resposta em arquivo .warc.gz."

msgid ""
"       --warc-header=STRING        insert STRING into the warcinfo record\n"
msgstr ""
"--warc-header=STRINGA\n"
"inserir STRINGA na cópia warcinfo"

msgid ""
"       --warc-max-size=NUMBER      set maximum size of WARC files to "
"NUMBER\n"
msgstr ""
"       --warc-max-size=CÓDIGO     o tamanho máximo dos arquivos WARC é "
"CÉLU\n"

msgid "       --warc-cdx                  write CDX index files\n"
msgstr "--warc-cdx                salvar arquivos indexados CDX\n"

msgid ""
"       --warc-dedup=FILENAME       do not store records listed in this CDX "
"file\n"
msgstr ""
"       --warc-dedup=FILE         não salvar registros, listados no arquivo "
"CDX\n"

msgid ""
"       --no-warc-compression       do not compress WARC files with GZIP\n"
msgstr "       --no-warc-compression     não comprimir arquivos WARC com GZIP\n"

msgid "       --no-warc-digests           do not calculate SHA1 digests\n"
msgstr ""
"--no-warc-digests\n"
"Não calcula digestas SHA1."

msgid ""
"       --no-warc-keep-log          do not store the log file in a WARC "
"record\n"
msgstr "--não-salvar-arquivo-de-registro em arquivos WARC"

msgid ""
"       --warc-tempdir=DIRECTORY    location for temporary files created by the\n"
"                                     WARC writer\n"
msgstr ""
"--warc-tempdir=CATALOGO    localização para arquivos temporários, criados "
"pela procedimento de gravação WARC\n"

msgid "Recursive download:\n"
msgstr "Carregamento recursivo:\n"

msgid "  -r,  --recursive                 specify recursive download\n"
msgstr "-r --recursivo\n"

msgid ""
"  -l,  --level=NUMBER              maximum recursion depth (inf or 0 for "
"infinite)\n"
msgstr " -l --level=%s\n"

msgid ""
"       --delete-after              delete files locally after downloading "
"them\n"
msgstr "--delete-after: apagar arquivos locais após a carregamento\n"

msgid ""
"  -k,  --convert-links             make links in downloaded HTML or CSS point to\n"
"                                     local files\n"
msgstr ""
" -k, --converter de links      converte os links para locais no HTML ou CSS "
"carregado\n"

msgid ""
"       --convert-file-only         convert the file part of the URLs only "
"(usually known as the basename)\n"
msgstr "--converter apenas de parte do arquivo da URL (parte base do nome)\n"

msgid ""
"       --backups=N                 before writing file X, rotate up to N "
"backup files\n"
msgstr ""
"--backups=N                   antes de escrever o arquivo X, fazer backup em N\n"
"        rotação dos backups"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X_orig\n"
msgstr ""
" -K, --backup-converted antes de converter o arquivo X fazer backup em "
"formato X_orig\n"

msgid ""
"  -K,  --backup-converted          before converting file X, back up as "
"X.orig\n"
msgstr ""
" -K, --backup-converted antes de converter o arquivo X fazer backup em "
"formato X.orig"

msgid ""
"  -m,  --mirror                    shortcut for -N -r -l inf --no-remove-"
"listing\n"
msgstr ""
"-m, --mirror             curto parâmetro equivalente ao -N -r -l inf --no-"
"remove-listing"

msgid ""
"  -p,  --page-requisites           get all images, etc. needed to display "
"HTML page\n"
msgstr ""
"--pagina-requisitos\n"
"    Carregue todas as imagens e outros elementos necessários para a exibição da página HTML."

msgid ""
"       --strict-comments           turn on strict (SGML) handling of HTML "
"comments\n"
msgstr ""
"--strict-comments    incluir tratamento estrito (SGML) de comentários HTML\n"

msgid "Recursive accept/reject:\n"
msgstr ""
"Permissões/proibições para a recursão: \n"
"\"%s\": \"A permissão negada. Para obter mais informações, tente '\\u0394 --help'.\"; \"%d\": \"O arquivo %<PRIuMAX> não pode ser lido.\"; \"%c\": \"Opção inválida: '%c'\"}"

msgid ""
"  -A,  --accept=LIST               comma-separated list of accepted "
"extensions\n"
msgstr "--aceitar=LISTA DE EXTENSIONS PERMITIDAS, separadas por vírgula"

msgid ""
"  -R,  --reject=LIST               comma-separated list of rejected "
"extensions\n"
msgstr "--rejeição=LISTA_DE_EXTENSÕES, separadas por vírgula. \n"

msgid "       --accept-regex=REGEX        regex matching accepted URLs\n"
msgstr ""
"--accept-regex=РЕГВЫР\n"
"    регулярное выражение для разрешённых URL"

msgid "       --reject-regex=REGEX        regex matching rejected URLs\n"
msgstr ""
"       --reject-regex=РЕГВЫР       expressão regular para URLs proibidas\n"

msgid "       --regex-type=TYPE           regex type (posix|pcre)\n"
msgstr ""
"       --regex-type=TIPO            tipo de expressão regular (posix|pcre)"

msgid "       --regex-type=TYPE           regex type (posix)\n"
msgstr "       --regex-type=TIPO            tipo de expressão regular (posix)"

msgid ""
"  -D,  --domains=LIST              comma-separated list of accepted "
"domains\n"
msgstr "-D, --domains=LISTA_DE_DOMÍNIO\n"

msgid ""
"       --exclude-domains=LIST      comma-separated list of rejected "
"domains\n"
msgstr "--exclude-domains=LISTA_DE_DOMÍNIO_EXCLUÍDO, \n"

msgid ""
"       --follow-ftp                follow FTP links from HTML documents\n"
msgstr "--follow-ftp                 Segue por links FTP em documentos HTML\n"

msgid ""
"       --follow-tags=LIST          comma-separated list of followed HTML "
"tags\n"
msgstr "       --follow-tags=LISTA DE TEGS HTML, separados por vírgula\n"

msgid ""
"       --ignore-tags=LIST          comma-separated list of ignored HTML "
"tags\n"
msgstr ""
"       --ignorar-tags=LISTA        lista de tags HTML ignoradas, através da "
"vírgula\n"

msgid "  -H,  --span-hosts                go to foreign hosts when recursive\n"
msgstr ""
"--span-hosts                -H,  --spans hosts                   visita "
"outros nós durante a recursão"

msgid "  -L,  --relative                  follow relative links only\n"
msgstr "--relativo                   Segue apenas por links relativas."

msgid "  -I,  --include-directories=LIST  list of allowed directories\n"
msgstr ""
" -I, --include-directories=CAMINHO_DE_DIRETORIO s/lista de diretórios "
"permitidos\n"

msgid ""
"       --trust-server-names        use the name specified by the redirection\n"
"                                     URL's last component\n"
msgstr ""
"--trust-server-names utilizar o nome, indicado no URL de redirecionamento, "
"como último componente."

msgid "  -X,  --exclude-directories=LIST  list of excluded directories\n"
msgstr "--excluir-diretórios=%s"

msgid ""
"  -np, --no-parent                 don't ascend to the parent directory\n"
msgstr "--no-parent, --não subir no diretório pai\n"

msgid ""
"Email bug reports, questions, discussions to <bug-wget@gnu.org>\n"
"and/or open issues at https://savannah.gnu.org/bugs/?func=additem&group=wget.\n"
msgstr ""
"Envie mensagens sobre erros, perguntas e sugestões para <bug-wget@gnu.org> "
"ou abra a questão no site "
"https://savannah.gnu.org/bugs/?func=additem&group=wget."

msgid "GNU Wget %s, a non-interactive network retriever.\n"
msgstr ""
"GNU Wget %s, programa para download de arquivos da internet em modo "
"autônomo."

