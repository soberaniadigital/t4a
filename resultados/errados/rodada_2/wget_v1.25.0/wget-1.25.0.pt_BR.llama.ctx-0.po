msgstr "%s (ambiente)"

msgid "    %s (user)\n"
msgstr "Usuário (%s)"

msgid "    %s (system)\n"
msgstr "Sistema (sistema)"

msgid "Copyright (C) %s Free Software Foundation, Inc.\n"
msgstr "Copyright (C) %s Free Software Foundation, Inc."

