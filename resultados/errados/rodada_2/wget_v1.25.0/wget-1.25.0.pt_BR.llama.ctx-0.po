msgid "ERROR: GnuTLS requires the key and the cert to be of the same type.\n"
msgstr ""
"ERRO: Para GnuTLS é necessário um par de chave e certificado do mesmo tipo."

msgid "Your GnuTLS version is too old to support TLS 1.3\n"
msgstr "A versão do GnuTLS antiga é insuficiente para suportar o TLS 1.3."

