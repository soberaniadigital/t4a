msgstr "%s: Comando --execute inválido %s\n"

msgid "%s: %s: Invalid boolean %s; use `on' or `off'.\n"
msgstr "%s: %s: Logical expression invalid; use 'on' or 'off'."

msgid "%s: %s: Invalid %s; use `on', `off' or `quiet'.\n"
msgstr "%s: %s: %s inválido; utilize 'on', 'off' ou 'quiet'.\n"

msgid "%s: %s: Invalid number %s.\n"
msgstr "%s: %s: Número inválido %s. (Não é um número válido)"

msgid "%s: %s must only be used once\n"
msgstr "%s: %s somente pode ser utilizado uma vez"

msgid "%s: %s: Invalid byte value %s\n"
msgstr "%s: %s: Valor byte inválido %d\n"

msgid "%s: %s: Invalid time period %s\n"
msgstr "%s: %s: Período de tempo não válido %s"

msgid "%s: %s: Negative time period %s\n"
msgstr "%s: %s: Período de tempo negativo %s\n"

msgid ""
"use-askpass requires a string or either environment variable WGET_ASKPASS or"
" SSH_ASKPASS to be set.\n"
msgstr ""
"use-askpass necessita uma string ou variável de ambiente WGET_ASKPASS ou "
"SSH_ASKPASS para autenticar. \n"

msgid "%s: %s: Invalid value %s.\n"
msgstr "%s: %s: Valor não é válido %s. (ID: %d)"

msgid "%s: %s: Invalid header %s.\n"
msgstr "%s: %s: Header inválido %s. (Header invalid %s.)"

msgid "%s: %s: Invalid WARC header %s.\n"
msgstr ""
"%s: %s: O WARC Header é inválido %s. Por favor, verifique novamente o "
"formato do seu arquivo."

msgid "%s: %s: Invalid progress type %s.\n"
msgstr "%s: %s: Tipo de progresso inválido %s. \n"

msgid ""
"%s: %s: Invalid restriction %s,\n"
"    use [unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii].\n"
msgstr ""
"%s: %s: Restrição não permitida %s, utilize "
"[unix|vms|windows],[lowercase|uppercase],[nocontrol],[ascii]."

msgid "Encoding %s isn't valid\n"
msgstr "Pengkodean %s tidak valid"

msgid "Conversion from %s to %s isn't supported\n"
msgstr "A conversão do %s para o %s não é suportada."

msgid "Incomplete or invalid multibyte sequence encountered\n"
msgstr "Encontrada uma sequência de bytes multibyte incompleta ou inválida."

msgid "Unhandled errno %d\n"
msgstr "Erro não tratado %d"

msgid "locale_to_utf8: locale is unset\n"
msgstr "locale_to_utf8: local não está definida"

msgid "idn_encode failed (%d): %s\n"
msgstr "falha no idn_encode (%d): %s"

msgid "Failed to convert to lower: %d: %s\n"
msgstr "Erro ao converter para letras minúsculas: %d:%s"

msgid ""
"\n"
"Redirecting output to %s.\n"
msgstr "Mengalihkan keluaran ke %s."

msgid "%s: %s; disabling logging.\n"
msgstr "%s: %s; desligando a captura de logs. \n"

msgid "Usage: %s [OPTION]... [URL]...\n"
msgstr "Penggunaan: %s [OPSI]... [URL]..."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
"\n"
msgstr ""
"Os argumentos obrigatórios para opções de longo alcance também são "
"necessários para as opções de curto alcance."

msgid "Startup:\n"
msgstr "Início do processo:"

msgid ""
"  -V,  --version                   display the version of Wget and exit\n"
msgstr "  -V,  --version                   mostre a versão do Wget e saia\n"

msgid "  -h,  --help                      print this help\n"
msgstr "  -h,  --help                      mostre a ajuda deste comando\n"

msgid "  -b,  --background                go to background after startup\n"
msgstr ""
"  -b,  --background        após o término do programa para entrar no modo de"
" fundo."

msgid "  -e,  --execute=COMMAND           execute a `.wgetrc'-style command\n"
msgstr ""
"  -e,  --execute=COMMAND           executar uma instrução no estilo de "
"‘.wgetrc’\n"

msgid "Logging and input file:\n"
msgstr "Jogando com Berkas e arquivo de entrada:\n"

msgid "  -o,  --output-file=FILE          log messages to FILE\n"
msgstr "  -o,  --output-file=FILE    escrever mensagens no FILE\n"

msgid "  -a,  --append-output=FILE        append messages to FILE\n"
msgstr ""
"  -a,  --append-output=%s\n"
"dopirizar mensagens no final do arquivo %s"

msgid "  -d,  --debug                     print lots of debugging information\n"
msgstr ""
"  -d,  --debug                     mostre muitas informações de depuração\n"

msgid "       --wdebug                    print Watt-32 debug output\n"
msgstr "       --wdebug              mostrar informações de depuração Watt-32\n"

msgid "  -q,  --quiet                     quiet (no output)\n"
msgstr "senyap (tidak ada keluaran) ou modo silencioso\n"

msgid "  -v,  --verbose                   be verbose (this is the default)\n"
msgstr "--verbose                   mostrar informações detalhadas (padrão)"

msgid ""
"  -nv, --no-verbose                turn off verboseness, without being "
"quiet\n"
msgstr ""
"  -nv, --no-verbose                desligue o relatório detalhado, sem "
"entrar em modo silencioso\n"

msgid ""
"       --report-speed=TYPE         output bandwidth as TYPE.  TYPE can be "
"bits\n"
msgstr ""
"       --report-speed=UNIDADES_METRICAS    determinar UNIDADEM. UNIDADE pode"
" ser bits\n"

msgid ""
"  -i,  --input-file=FILE           download URLs found in local or external "
"FILE\n"
msgstr ""
"  -i,  --input-file=FILE     carregue URLs de acordo com o conteúdo local ou"
" externo do FILE\n"

msgid ""
"       --input-metalink=FILE       download files covered in local Metalink "
"FILE\n"
msgstr ""
"       --input-metalink=FILE     baixar arquivos listados no FILE Metalink "
"local\n"

msgid "  -F,  --force-html                treat input file as HTML\n"
msgstr ""
"  -F,  --force-html          considerar que o arquivo de entrada é HTML\n"

msgid ""
"  -B,  --base=URL                  resolves HTML input-file links (-i -F)\n"
"                                     relative to URL\n"
msgstr ""
"  -B,  --base=URL                  mengurai tautan berkas masukan HTML (-i "
"-F) relatif ke URL. \n"

msgid "       --config=FILE               specify config file to use\n"
msgstr "       --config=%s         definir arquivo de configuração\n"

msgid "       --no-config                 do not read any config file\n"
msgstr "--no-config           não ler arquivos de configuração"

msgid ""
"       --rejected-log=FILE         log reasons for URL rejection to FILE\n"
msgstr ""
"       --rejected-log=FILE   registar as razões para a exclusão da URL no "
"FILE\n"

msgid "Download:\n"
msgstr "Download:"

msgid ""
"  -t,  --tries=NUMBER              set number of retries to NUMBER (0 "
"unlimits)\n"
msgstr ""
"  -t,  --tries=ЧИСЛО             configurar o número de tentativas (0 para "
"sem limite)\n"

msgid "       --retry-connrefused         retry even if connection is refused\n"
msgstr ""
"       --retry-connrefused         tentar novamente mesmo que a conexão seja"
" negada\n"

msgid ""
"       --retry-on-host-error       consider host errors as non-fatal, "
"transient errors\n"
msgstr ""
"       --retry-on-host-error     considera erros de host como falhas não "
"críticas e aleatórias\n"

msgid ""
"       --retry-on-http-error=ERRORS    comma-separated list of HTTP errors "
"to retry\n"
msgstr "       --retry-on-http-error=ERROS de HTTP, solicitando novamente\n"

msgid "  -O,  --output-document=FILE      write documents to FILE\n"
msgstr "  -O,  --output-document=%s    escrever documentos no arquivo %s\n"

msgid ""
"  -nc, --no-clobber                skip downloads that would download to\n"
"                                     existing files (overwriting them)\n"
msgstr ""
"  -nc, --no-clobber              evitar a cópia de arquivos que levariam à substituição dos existentes\n"
"                                     (e suas recriações)\n"

msgid ""
"       --no-netrc                  don't try to obtain credentials from "
".netrc\n"
msgstr ""
"       --no-netrc                  não tente obter dados do arquivo .netrc\n"

msgid ""
"  -c,  --continue                  resume getting a partially-downloaded "
"file\n"
msgstr ""
"  -c,  --continue                  continuar a leitura de um arquivo "
"parcialmente carregado\n"

msgid ""
"       --start-pos=OFFSET          start downloading from zero-based "
"position OFFSET\n"
msgstr ""
"       --start-pos=SEMANO_INICIAL           iniciar a carga do arquivo desde"
" o início (considerando como zero) \n"

msgid "       --progress=TYPE             select progress gauge type\n"
msgstr ""
"       --progress=TIPO             escolha tipo indicador de progresso\n"

msgid ""
"       --show-progress             display the progress bar in any verbosity"
" mode\n"
msgstr ""
"       --show-progress             mostre o indicador de progresso em "
"qualquer modo detalhado"

msgid ""
"  -N,  --timestamping              don't re-retrieve files unless newer than\n"
"                                     local\n"
msgstr ""
"  -N,  --timestamping              não levar em conta blocos de dados que já"
" foram carregados se eles forem mais antigos do que os locais\n"

msgid ""
"       --no-if-modified-since      don't use conditional if-modified-since get\n"
"                                     requests in timestamping mode\n"
msgstr ""
"       --no-use-server-timestamps    não utilizar a verificação if-modified-"
"since para solicitações no modo que considera marcas de tempo\n"

msgid ""
"       --no-use-server-timestamps  don't set the local file's timestamp by\n"
"                                     the one on the server\n"
msgstr ""
"       --no-use-server-timestamps   não usar o timestamp localizado obtido "
"do servidor\n"

msgid "  -S,  --server-response           print server response\n"
msgstr "  -S,  --server-response           resposta do servidor\n"

msgid "       --spider                    don't download anything\n"
msgstr "       --spider                    não carregar nada"

msgid "  -T,  --timeout=SECONDS           set all timeout values to SECONDS\n"
msgstr ""
"  -T,  --timeout=SEGUNDOS         fixar todos os valores de tempo igual ao "
"número SEGUNDOS\n"

msgid ""
"       --dns-servers=ADDRESSES     list of DNS servers to query (comma "
"separated)\n"
msgstr ""
"       --dns-servers=ADRESSA        daftar server DNS para consulta "
"(separado por ponto e com) \n"

msgid ""
"       --bind-dns-address=ADDRESS  bind DNS resolver to ADDRESS (hostname or"
" IP) on local host\n"
msgstr ""
"       --bind-dns-address=ADRESSE  vincular o resolver DNS à ADRESSE (nome "
"do computador ou endereço IP) local\n"

msgid "       --dns-timeout=SECS          set the DNS lookup timeout to SECS\n"
msgstr ""
"--dns-timeout=SEC         atuação do timeout para pesquisa DNS no SECOND"

msgid "       --connect-timeout=SECS      set the connect timeout to SECS\n"
msgstr ""
"       --connect-timeout=SEK     configuração do tempo de espera para "
"conexão em SEK segundos\n"

msgid "       --read-timeout=SECS         set the read timeout to SECS\n"
msgstr ""
"       --read-timeout=SEC        instalação do timeout de leitura em "
"segundos\n"

msgid ""
"  -w,  --wait=SECONDS              wait SECONDS between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"  -w, --wait=SEGUNDOS            pausa de uma segundos entre as chamadas "
"para obter URLs (aplica-se quando mais do que um URL for obtido) \n"

msgid ""
"       --waitretry=SECONDS         wait 1..SECONDS between retries of a retrieval\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --waitretry=SEGUNDOS       espera de 1..SEGUNDOS entre tentativas "
"repetidas para acessar (aplicável quando mais de um URL forem baixados) \n"

msgid ""
"       --random-wait               wait from 0.5*WAIT...1.5*WAIT secs between retrievals\n"
"                                     (applies if more then 1 URL is to be retrieved)\n"
msgstr ""
"       --random-wait             pausa de 0,5*WAIT...1,5*WAIT segundos entre"
" as operações (quando mais do que um URL for carregado)"

msgid "       --no-proxy                  explicitly turn off proxy\n"
msgstr ""
"--no-proxy                   Não permitir o uso de proxy explicitamente\n"

msgid "  -Q,  --quota=NUMBER              set retrieval quota to NUMBER\n"
msgstr ""
"  -Q,  --quota=%s              estabelecer a quantidade de quota em %s "
"unidades"

msgid ""
"       --bind-address=ADDRESS      bind to ADDRESS (hostname or IP) on local"
" host\n"
msgstr ""
"       --bind-address=ADDRRESS      vincular ADRESS (nome do computador ou "
"IP) local\n"

msgid "       --limit-rate=RATE           limit download rate to RATE\n"
msgstr ""
"       --limit-rate=SPEED           limitar a velocidade de transferência "
"para SPEED\n"

msgid "       --no-dns-cache              disable caching DNS lookups\n"
msgstr ""
"       --no-dns-cache              desligue o cache DNS para consultas"

msgid ""
"       --restrict-file-names=OS    restrict chars in file names to ones OS "
"allows\n"
msgstr ""
"       --restrict-file-names=OS    restringir caracteres no nome do arquivo "
"para aqueles aceitos pela OS\n"

msgid ""
"       --ignore-case               ignore case when matching "
"files/directories\n"
msgstr ""
"       --ignore-case             ignorar diferenças de maiúsculas e "
"minúsculas ao comparar arquivos/diretórios\n"

msgid "  -4,  --inet4-only                connect only to IPv4 addresses\n"
msgstr "hanya menghubungi ke alamat IPv4 saja"

msgid "  -6,  --inet6-only                connect only to IPv6 addresses\n"
msgstr "hanya menghubungi ke alamat IPv6 saja"

msgid ""
"       --prefer-family=FAMILY      connect first to addresses of specified family,\n"
"                                     one of IPv6, IPv4, or none\n"
msgstr ""
"       --prefer-family=SEMEISSTVO conectar primeiro aos endereços da família"
" especificada (pode ser IPv6, IPv4 ou nenhum) \n"

msgid "       --user=USER                 set both ftp and http user to USER\n"
msgstr ""
"       --user=USUÁRIO       instale e ftp- e http-usuário para USUÁRIO\n"

msgid ""
"       --password=PASS             set both ftp and http password to PASS\n"
msgstr "       --password=PAROL          definir ftp e http com PAROL\n"

msgid "       --ask-password              prompt for passwords\n"
msgstr "--ask-password              solicitar senha"

msgid ""
"       --use-askpass=COMMAND       specify credential handler for requesting \n"
"                                     username and password.  If no COMMAND is \n"
"                                     specified the WGET_ASKPASS or the SSH_ASKPASS \n"
"                                     environment variable is used.\n"
msgstr ""
"       --use-askpass=COMMAND      especifique o maneira de lidar com "
"credenciais para solicitar nome do usuário e senha. Se não houver uma "
"instrução definida, será utilizado a variável ambiente WGET_ASKPASS ou "
"SSH_ASKPASS."

msgid "       --no-iri                    turn off IRI support\n"
msgstr "--no-iri                    desativar suporte ao IRI\n"

msgid ""
"       --local-encoding=ENC        use ENC as the local encoding for IRIs\n"
msgstr ""
"       --local-encoding=КДР      utilizar КДР como padrão de codificação "
"local para IRI\n"

msgid ""
"       --remote-encoding=ENC       use ENC as the default remote encoding\n"
msgstr ""
"       --remote-encoding=КДР     utilizar КДР como ponteiro de codificação remota\n"
"                                por padrão\n"

msgid "       --unlink                    remove file before clobber\n"
msgstr "       --unlink                    apagar arquivo antes de clobberar"

msgid ""
"       --keep-badhash              keep files with checksum mismatch (append"
" .badhash)\n"
msgstr ""
"       --keep-badhash            manter arquivos com checksums incorretas "
"(adicionando .badhash) \n"

msgid ""
"       --metalink-index=NUMBER     Metalink application/metalink4+xml "
"metaurl ordinal NUMBER\n"
msgstr ""
"       --metalink-index=NUMERO    ordem numérica metaurl\n"
"                 Metalink application/metalink4+xml\n"

msgid ""
"       --metalink-over-http        use Metalink metadata from HTTP response "
"headers\n"
msgstr ""
"       --metalink-over-http        utilizar metadata Metalink do cabeçalho "
"de resposta HTTP\n"

msgid ""
"       --preferred-location        preferred location for Metalink "
"resources\n"
msgstr ""
"       --preferred-location        localização preferida para acesso aos "
"recursos Metalink\n"

msgid ""
"       --xattr                     turn on storage of metadata in extended "
"file attributes\n"
msgstr ""
"       --xattr                     habilitar armazenamento de dados "
"metadados nos atributos extensos do arquivo."

msgid "Directories:\n"
msgstr "Diretórios:\n"

msgid "  -nd, --no-directories            don't create directories\n"
msgstr "  -nd, --no-directories           não criar diretórios\n"

msgid "  -x,  --force-directories         force creation of directories\n"
msgstr ""
"--force-directories        paksa pembuatkan direktori diretórios, mesmo que "
"nenhum arquivo esteja presente."

msgid "  -nH, --no-host-directories       don't create host directories\n"
msgstr "jangada de diretórios do host\n"

msgid "       --protocol-directories      use protocol name in directories\n"
msgstr ""
"       --protocol-directories      utilizar o nome do protocolo nos "
"diretórios\n"

msgid "  -P,  --directory-prefix=PREFIX   save files to PREFIX/..\n"
msgstr "  -P,  --directory-prefix=ПРЕФИКС   salvar arquivos no ПРЕФИКС/..\n"

msgid ""
"       --cut-dirs=NUMBER           ignore NUMBER remote directory "
"components\n"
msgstr ""
"       --cut-dirs=ЧИСЛО           ignorar ЧИСЛО componentes de catálogo "
"remoto\n"

msgid "HTTP options:\n"
msgstr "Opsi HTTP:\n"

msgid "       --http-user=USER            set http user to USER\n"
msgstr "--http-user=POLIZOVATEL\n"

msgid "       --http-password=PASS        set http password to PASS\n"
msgstr "       --http-password=PAROL\n"

msgid "       --no-cache                  disallow server-cached data\n"
msgstr "--no-cache                   Não usar dados armazenados no servidor."

msgid ""
"       --default-page=NAME         change the default page name (normally\n"
"                                     this is 'index.html'.)\n"
msgstr ""
"       --default-page=%s      alterar o nome da página por defeito "
"(geralmente é \"index.html\")"

msgid ""
"  -E,  --adjust-extension          save HTML/CSS documents with proper "
"extensions\n"
msgstr ""
"  -E,  --adjust-extension          salvar documentos HTML/CSS com extensões "
"apropriadas\n"

msgid ""
"       --ignore-length             ignore 'Content-Length' header field\n"
msgstr ""
"--ignore-length             abaixo do cabeçalho 'Content-Length' seja "
"ignorado."

msgid "       --header=STRING             insert STRING among the headers\n"
msgstr "       --header=STRING             inserir STRING entre cabeçalhos\n"

msgid ""
"       --compression=TYPE          choose compression, one of auto, gzip and"
" none. (default: none)\n"
msgstr ""
"       --compression=TYPE       escolha de compressão: auto, gzip ou nenhum "
"(por padrão: nenhum).\n"

msgid ""
"       --max-redirect              maximum redirections allowed per page\n"
msgstr ""
"       --max-redirect          máximo permitido de redirecionamentos para a "
"página\n"

msgid "       --proxy-user=USER           set USER as proxy username\n"
msgstr ""
"       --proxy-user=USER.   utilizar USER como nome de usuário para proxy\n"

msgid "       --proxy-password=PASS       set PASS as proxy password\n"
msgstr ""
"       --proxy-password=PAROLLE   instale PAROLLE como senha para proxy\n"

msgid ""
"       --referer=URL               include 'Referer: URL' header in HTTP "
"request\n"
msgstr ""
"       --referer=URL           incluir no cabeçalho HTTP do pedido o campo "
"'Referer: URL' \n"

msgid "       --save-headers              save the HTTP headers to file\n"
msgstr "       --save-headers          salvar HTTP-заголовки em arquivo\n"

msgid ""
"  -U,  --user-agent=AGENT          identify as AGENT instead of "
"Wget/VERSION\n"
msgstr ""
"  -U,  --user-agent=AGEN           identificar se mesmo como AGEN ao invés "
"de Wget/VERSÃO\n"

msgid ""
"       --no-http-keep-alive        disable HTTP keep-alive (persistent "
"connections)\n"
msgstr ""
"--no-http-keep-alive    desligue o HTTP keep-alive (sincronização "
"persistente)\n"

msgid "       --no-cookies                don't use cookies\n"
msgstr "--no-cookies                não utilizar cookie"

msgid ""
"       --load-cookies=FILE         load cookies from FILE before session\n"
msgstr ""
"       --load-cookies=FILE     carregar cookies a partir de FILE antes do "
"jogo\n"

msgid "       --save-cookies=FILE         save cookies to FILE after session\n"
msgstr "       --save-cookies=FILE     salvar cookies no FILE após sessão\n"

msgid ""
"       --keep-session-cookies      load and save session (non-permanent) "
"cookies\n"
msgstr ""
"       --keep-session-cookies      salvar e manter cookies de sessão (non-"
"permanentes) \n"

msgid ""
"       --post-data=STRING          use the POST method; send STRING as the "
"data\n"
msgstr ""
"       --post-data=STRING          utilizar método POST; envio de STRING "
"como dados\n"

msgid ""
"       --post-file=FILE            use the POST method; send contents of "
"FILE\n"
msgstr ""
"       --post-file=FILE        utilizar método POST; envio de conteúdo da "
"FILEA\n"

msgid ""
"       --method=HTTPMethod         use method \"HTTPMethod\" in the "
"request\n"
msgstr ""
"       --method=HTTPMethod         utilizar método \"HTTPMethod\" no "
"cabeçalho\n"

msgid ""
"       --body-data=STRING          send STRING as data. --method MUST be "
"set\n"
msgstr ""
"       --body-data=СТРОКА      завантаження СТРОКИ для enviôncia; \n"
"                               ДОЛЖЕН бути указан параметр --method\n"

msgid ""
"       --body-file=FILE            send contents of FILE. --method MUST be "
"set\n"
msgstr ""
"       --body-file=FILE        criação de conteúdo FILE; --method HARUS "
"diatur\n"

msgid ""
"       --content-disposition       honor the Content-Disposition header when\n"
"                                     choosing local file names (EXPERIMENTAL)\n"
msgstr ""
"       --content-disposition   принимати заголовок Content-Disposition при "
"вибір імені для локальних файлів (експериментарний)\n"

msgid ""
"       --content-on-error          output the received content on server "
"errors\n"
msgstr ""
"       --content-on-error      exibir dados aceitos ao enfrentar erros do "
"servidor\n"

msgid ""
"       --auth-no-challenge         send Basic HTTP authentication information\n"
"                                     without first waiting for the server's\n"
"                                     challenge\n"
msgstr ""
"       --auth-no-challenge         enviar informações de autenticação do "
"padrão HTTP basic sem esperar por resposta inicial do servidor\n"

msgid "HTTPS (SSL/TLS) options:\n"
msgstr "Opciones HTTPS (SSL/TLS):"

msgid ""
"       --secure-protocol=PR        choose secure protocol, one of auto, SSLv2,\n"
"                                     SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 and PFS\n"
msgstr ""
"       --secure-protocol=PR        escolha do protocolo seguro: auto, SSLv2,"
" SSLv3, TLSv1, TLSv1_1, TLSv1_2, TLSv1_3 ou PFS\n"

msgid "       --https-only                only follow secure HTTPS links\n"
msgstr "--https-only             apenas por HTTPS"

msgid ""
"       --no-check-certificate      don't validate the server's certificate\n"
msgstr ""
"       --no-check-certificate      não validar certificado do servidor\n"

msgid "       --certificate=FILE          client certificate file\n"
msgstr ""
"       --certificate=FILE          armazenamento de certificado do usuário "
"em um arquivo."

msgid "       --certificate-type=TYPE     client certificate type, PEM or DER\n"
msgstr ""
"       --certificate-type=TYPE     tipo de certificado do cliente, PEM ou "
"DER."

msgid "       --private-key=FILE          private key file\n"
msgstr "       --private-key=FILE          ficheiro chave privada\n"

