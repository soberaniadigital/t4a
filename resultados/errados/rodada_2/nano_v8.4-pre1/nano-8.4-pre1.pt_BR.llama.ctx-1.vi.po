msgid "Cannot limit permissions on %s: %s"
msgstr "Não é possível limitar a autoridade sobre %s: %s."

msgid "Key is invalid in view mode"
msgstr "Нельзя использовать эту клавишу в этом режиме просмотра"

msgid "This function is disabled in restricted mode"
msgstr "A função atual está desabilitada no modo de restrições"

msgid "To suspend, type ^T^Z"
msgstr "Para interromper o processo, digite ^T^Z."

msgid "No file name"
msgstr "Não há nome para o arquivo."

msgid "Save modified buffer? "
msgstr "Deseja salvar o buffer modificado? "

