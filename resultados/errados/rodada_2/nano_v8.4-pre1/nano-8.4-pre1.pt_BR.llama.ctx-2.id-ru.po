msgid "Show a position+portion indicator"
msgstr "Mostrar o indicador de posição+parte"

msgid "-r <number>"
msgstr "-r <число>"

msgid "--fill=<number>"
msgstr "--fill=<число>"

msgid "Set width for hard-wrap and justify"
