msgid "Save changes on exit, don't prompt"
msgstr "Simpan perubahan saat keluar, jangan tanya."

msgid "Save a file by default in Unix format"
msgstr "Por padrão, salvar o arquivo no formato Unix."

msgid "View mode (read-only)"
msgstr "Режим de leitura (somente lendo)"

msgid "Don't hard-wrap long lines [default]"
msgstr "Não deve ser possível transpor linhas longas [padrão]"

msgid "Don't show the two help lines"
msgstr "Não mostre duas linhas de ajuda abaixo."

msgid "Make Ctrl+Right stop at word ends"
msgstr ""
"Parar de digitar à medida que se aproxima do final da palavra, enquanto o "
"Ctrl está pressionado em conjunto com a direita"

msgid "List the names of available syntaxes"
msgstr "Cantumkan nama-nama sintaks yang tersedia."

msgid "Also try magic to determine syntax"
msgstr "Utilize magia para determinar sintaxe."

