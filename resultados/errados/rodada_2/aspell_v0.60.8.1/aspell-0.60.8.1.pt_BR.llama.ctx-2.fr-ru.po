msgstr "A operação não é suportada : %what:1"

msgid "The method \"%what:1\" is unimplemented in \"%where:2\"."
msgstr "A método \"%what:1\" não está implementado no local \"%where:2\"."

msgid "%file:1:"
msgstr "%file:1:"

msgid "The file \"%file:1\" can not be opened"
msgstr "Não foi possível abrir a pasta de arquivo \"%file:1\"."

