msgstr "O termo \"%word:1\" é inválido."

msgid "The affix flag '%aff:1' is invalid for word \"%word:2\"."
msgstr "O símbolo de terminação '%aff:1' é inválido para o termo '%word:2'."

msgid "The affix flag '%aff:1' can not be applied to word \"%word:2\"."
msgstr ""
"O fanion de terminação '%aff:1' não pode ser aplicado ao palavra '%word:2'."

msgid "not a version number"
msgstr "Esta não é uma versão da ferramenta."

msgid "dlopen returned \"%return:1\"."
msgstr "dlopen retornou «%return:1»."

