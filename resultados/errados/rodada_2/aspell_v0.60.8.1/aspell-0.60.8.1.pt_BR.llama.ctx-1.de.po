msgstr ""
"O chave \"%key:1\" não pode conter parâmetros se for precedida por 'reset-'."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by an "
"\"enable-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros se for precedida por "
"'enable-'."

