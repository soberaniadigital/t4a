msgstr ""
"O chave \"%key:1\" não pode conter parâmetros se for precedida por 'não "
"permitir' ou 'desabilitar'."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"clear-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros se for precedida por 'clear-'."

