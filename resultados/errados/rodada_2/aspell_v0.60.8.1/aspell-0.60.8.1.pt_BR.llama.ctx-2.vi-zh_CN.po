"\n"
msgstr ""
"Bloco de filtragem: %s\n"
"%s\n"
"\n"
"Configurado da seguinte forma:"

msgid "ASPELL_CONF env var"
msgstr "ASPELL_CONF Umgebungsvariable"

msgid "main configuration file"
msgstr "arquivo de configuração principal"

msgid "location of main configuration file"
msgstr "Nome da principal arquivo de configuração"

msgid "location of language data files"
msgstr "Nome dos arquivos de dados linguísticos"

msgid "create dictionary aliases"
msgstr "criar aliases de palavras do dicionário"

msgid "location of the main word list"
msgstr "Lista das palavras principais do texto em português."

msgid "encoding to expect data to be in"
msgstr "Codificação, na qual os dados são esperados para serem codificados."

msgid "add or removes a filter"
msgstr "adiciona ou remove um filtro"

msgid "path(s) aspell looks for filters"
msgstr "Os caminhos em que o aspell procura filtros."

msgid "filter mode"
msgstr "Modo de filtragem"

msgid "extra dictionaries to use"
msgstr "zusätzliche tabelas de tradução"

msgid "files with list of extra words to accept"
msgstr "Arquivos com listas de palavras adicionais aceitáveis para datas"

msgid "location for personal files"
msgstr "Nome para arquivos pessoais"

msgid "ignore words <= n chars"
msgstr "ignorar palavras com <= n caracteres"

msgid "ignore accents when checking words -- CURRENTLY IGNORED"
msgstr "ignoriere Akzente beim Überprüfen -- MOMENTAN WIRKUNGSLOS"

msgid "ignore case when checking words"
msgstr "ignorando maiúsculas e minúsculas ao verificar"

msgid "ignore commands to store replacement pairs"
msgstr ""
"ignoriere comandos, substituição de pares para armazenar salva em memória"

msgid "extra information for the word list"
msgstr "informações adicionais para a lista de palavras"

msgid "keyboard definition to use for typo analysis"
msgstr "Definição de Teclado para análise de erros de digitação"

msgid "language code"
msgstr "Código de linguagem"

msgid "deprecated, use lang instead"
msgstr "opção obsoleto, por favor use 'lang' em seu lugar."

msgid "location of local language data files"
msgstr "Nome dos arquivos de dados linguísticos locais"

msgid "base name of the main dictionary to use"
msgstr "Nome do principal dicionário de palavras"

msgid "set module name"
msgstr "Nome do módulo configurar"

msgid "search order for modules"
msgstr "Sequência de Ordem para Modulos"

msgid "enable Unicode normalization"
msgstr "Ativar normalização Unicode padrão"

msgid "Unicode normalization required for current lang"
msgstr "A normalização Unicode para a língua atual é necessária."

msgid "Unicode normalization form: none, nfd, nfc, comp"
msgstr ""
"Forma de normalização Unicode para caracteres únicos: none, nfd, nfc, comp"

msgid "avoid lossy conversions when normalization"
msgstr ""
"Evite conversões não reversíveis ao normalizar para prevenir perda de dados."

msgid "personal configuration file"
msgstr "arquivos de configuração pessoal"

msgid "personal dictionary file name"
msgstr "Nome do seu dicionário pessoal"

msgid "prefix directory"
msgstr "Pasta raiz"

msgid "replacements list file name"
msgstr "Nome do arquivo de substituição"

msgid "consider run-together words legal"
msgstr "aceitam palavras compostas"

msgid "maximum number that can be strung together"
msgstr "quantidade máxima de palavras compostas"

msgid "minimal length of interior words"
msgstr "comprimento mínimo das palavras internas"

msgid "consider camel case words legal"
msgstr "Wörter in CamelCase als gültig akzeptieren"

msgid "save replacement pairs on save all"
msgstr ""
"salvar todos os dados e também as combinações de substituição salvas "
"simultaneamente"

msgid "set the prefix based on executable location"
msgstr "Definir prefixo baseado no nome do programa"

msgid "size of the word list"
msgstr "tamanho da lista de palavras"

msgid "no longer used"
msgstr "Não é mais utilizado"

msgid "suggestion mode"
msgstr "Modo de sugestão"

msgid "use typo analysis, override sug-mode default"
msgstr ""
"Realizar análise de erros tipográficos em vez do modo sugerido padrão."

msgid "use replacement tables, override sug-mode default"
msgstr "utilize tabelas de substituição em vez do modo sugestivo padrão"

msgid "characters to insert when a word is split"
msgstr "quando um termo é dividido, inscrever caracteres adicionais"

msgid "use personal, replacement & session dictionaries"
msgstr "use personal, replacement and session wordbooks"

msgid "search path for word list information files"
msgstr ""
"Pasta de arquivos com informações sobre listagens de palavras para pesquisa "
"do caminho desejado."

msgid "enable warnings"
msgstr "ativação das alertas"

msgid "indicator for affix flags in word lists -- CURRENTLY IGNORED"
msgstr ""
"Indicador para flags de terminação em listas de palavras -- EM STATUS ACTIVE"
" NOW"

msgid "use affix compression when creating dictionaries"
msgstr "Comprimir endereços ao gerar dicionários"

msgid "remove invalid affix flags"
msgstr "remover flags de terminação inválida"

msgid "attempts to clean words so that they are valid"
msgstr "palavras a serem limpas para que sejam válidas"

msgid "compute soundslike on demand rather than storing"
msgstr "Calcular o Wortklang em caso de necessidade, ao invés de armazená-lo."

msgid "partially expand affixes for better suggestions"
msgstr ""
"Parte dos sufixos para melhores recomendações foram expandidos parcialmente."

msgid "skip invalid words"
msgstr "palavras inválidas ignoradas"

msgid "check if affix flags are valid"
msgstr "Verificar se os flags de terminação são válidos."

msgid "check if words are valid"
msgstr "Verificar se as palavras são válidas."

msgid "create a backup file by appending \".bak\""
msgstr "Criar backup com extensão '.bak' para a versão atualizada."

msgid "use byte offsets instead of character offsets"
msgstr "Use byte offsets instead of character offsets."

msgid "create missing root/affix combinations"
msgstr "erigem combinações de palavras sem a terminação ou raiz adequadas"

msgid "keymapping for check mode: \"aspell\" or \"ispell\""
msgstr "Taxa de erro para modo de teste: 'aspell' ou 'ispell'"

msgid "reverse the order of the suggest list"
msgstr "Reihenfolge der Vorschlagsliste umdrehen"

msgid "suggest possible replacements"
msgstr "sugeridas substituições"

msgid "time load time and suggest time in pipe mode"
msgstr ""
"tempo de carregamento e tempo para sugerir no modo Pipe (calculando o tempo "
"necessário para a transferência do buffer)"

msgid ""
"This could also mean that the file \"%s\" could not be opened for reading or"
" does not exist."
msgstr ""
"Isso também poderia significar que a pasta de trabalho \"%s\" não pôde ser "
"aberta para leitura ou simplesmente não existe."

msgid "The Unicode code point U+%04X is unsupported."
msgstr "O caractere Unicode na posição U+%04X não é suportado."

msgid "Invalid UTF-8 sequence at position %ld."
msgstr "Sequência UTF-8 inválida na posição %ld."

msgid "Operation Not Supported: %what:1"
msgstr "Operação não suportada: %what:1"

msgid "The method \"%what:1\" is unimplemented in \"%where:2\"."
msgstr ""
"A metodologia chamada \"%what:1\" não foi implementada no local especificado"
" como '%where:2'."

msgid "%file:1:"
msgstr "%file:1:"

msgid "The file \"%file:1\" can not be opened"
msgstr "A ficheiro \"%file:1\" não pode ser aberto."

msgid "The file \"%file:1\" can not be opened for reading."
msgstr "A ficheiro \"%file:1\" não pode ser aberto para leitura."

msgid "The file \"%file:1\" can not be opened for writing."
msgstr "A ficheiro \"%file:1\" não pode ser aberto para escrita."

msgid "The file name \"%file:1\" is invalid."
msgstr "O nome do arquivo '\\%file:1' é inválido."

msgid "The file \"%file:1\" is not in the proper format."
msgstr "A ficheiro \"%file:1\" não possui o formato correto."

msgid "The directory \"%dir:1\" can not be opened for reading."
msgstr "Não é possível abrir o diretório \"%dir:1\" para leitura."

msgid "The key \"%key:1\" is unknown."
msgstr "O chaveiro \"%key:1\" é desconhecida."

msgid "The value for option \"%key:1\" can not be changed."
msgstr "O valor da opção '\\%key:1' não pode ser alterado."

msgid "The key \"%key:1\" is not %accepted:2 and is thus invalid."
msgstr "O chave \"%key:1\" não pode %accepted:2, portanto é inválida."

msgid ""
"The value \"%value:2\" is not %accepted:3 and is thus invalid for the key "
"\"%key:1\"."
msgstr ""
"O valor \"%value:2\" não é aceito como %accepted:3, portanto o campo "
"\"%key:1\" está inválido."

msgid "The key \"%key:1\" is not a string."
msgstr "O chave \"%key:1\" não é uma cadeia de caracteres."

msgid "The key \"%key:1\" is not an integer."
msgstr "O chave \"%key:1\" não é um número inteiro."

msgid "The key \"%key:1\" is not a boolean."
msgstr "O chave \"%key:1\" não é um valor de verdade."

msgid "The key \"%key:1\" is not a list."
msgstr "O chave \"%key:1\" não é uma lista."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"reset-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por 'reset-'."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by an "
"\"enable-\"."
msgstr ""
"O chave \"%key:1\" não pode conter parâmetros quando precedida por "
"\"enable-\"."

msgid ""
"The key \"%key:1\" does not take any parameters when prefixed by a \"dont-\""
" or \"disable-\"."
msgstr ""
"Olá! Aqui está a tradução para o seu texto em português brasileiro. Por "
"favor, revise e envie sua mensagem de confirmação."

msgid "The key \"%key:1\" does not take any parameters when prefixed by a \"clear-\"."
msgstr ""
"Der Schlüssel »%key:1« kann keine Parameter haben, wenn ein »clear-« "
"vorangestellt ist."

msgid "The language \"%lang:1\" is not known."
msgstr "A linguagem \"%lang:1\" é desconhecida."

msgid "The soundslike \"%sl:2\" is not known."
msgstr "O som do termo '%sl:2' não é conhecido."

msgid "The language \"%lang:1\" is not supported."
msgstr "A linguagem \"%lang:1\" não é suportada."

msgid "No word lists can be found for the language \"%lang:1\"."
msgstr "Não é possível encontrar listagens de palavras para a língua \"%lang:1\"."

msgid "Expected language \"%lang:1\" but got \"%prev:2\"."
msgstr ""
"A linguagem esperada é '%lang:1', mas recebemos '%prev:2'. Esse erro indica "
"que a configuração anterior foi aplicada."

msgid "Affix '%aff:1' is corrupt."
msgstr "O termo de conclusão '\\%aff:1' foi danificado."

msgid "The condition \"%cond:1\" is invalid."
msgstr "A condição \"%cond:1\" é inválida."

msgid ""
"The condition \"%cond:1\" does not guarantee that \"%strip:2\" can always be"
" stripped."
msgstr ""
"A condição \"%cond:1\" não garante que a operação de remoção da parte final,"
" representada por \"%strip:2\", seja sempre possível."

msgid ""
"The file \"%file:1\" is not in the proper format. Expected the file to be in"
" \"%exp:2\" not \"%got:3\"."
msgstr ""
"A ficheiro %file:1% não possui o formato correto. Deveria estar no ficheiro "
"%exp:2%, e não em %got:3%."

msgid "The encoding \"%encod:1\" is not known."
msgstr "A codificação '�%encod:1��' não é conhecida."

msgid "The encoding \"%encod:1\" is not supported."
msgstr "A codificação '\\%encod:1' não é suportada."

msgid "The conversion from \"%encod:1\" to \"%encod2:2\" is not supported."
msgstr "A conversão de »%encod:1« para »%encod:2« não é suportada."

msgid "The string \"%str:1\" is invalid."
msgstr "A cadeia de caracteres '\"%str:1\"' é inválida."

msgid "The word \"%word:1\" is invalid."
msgstr "O termo \"%word:1\" é inválido."

msgid "The affix flag '%aff:1' is invalid for word \"%word:2\"."
msgstr ""
"O cópia affix (thêm vào) ‘%aff:1’ không hợp lệ đối với o termo “%word:2”."

msgid "The affix flag '%aff:1' can not be applied to word \"%word:2\"."
msgstr ""
"O cógido de terminação '%aff:1' não pode ser aplicado ao termo "
"'term%word:2'."

msgid "not a version number"
msgstr "Esta não é uma versão numérica."

msgid "dlopen returned \"%return:1\"."
msgstr "falha ao abrir biblioteca com `dlopen`: retorno de erro '1'."

msgid "The file \"%filter:1\" does not contain any filters."
msgstr "A ficheiro '\\%filter:1' não contém nenhum filtro."

msgid "The filter \"%filter:1\" does not exist."
msgstr "O filtro \"%filter:1\" não existe."

msgid "Confused by version control."
msgstr "Confuso pela versão de controle."

msgid "Aspell version does not match filter's requirement."
msgstr "Aspell versão não corresponde aos requisitos do filtro."

msgid "Filter option already exists."
msgstr "A opção de filtragem já existe."

msgid "Use option modifiers only within named option."
msgstr "Utilize modificadores de opções somente dentro das opções nomeadas."

msgid "Option modifier unknown."
msgstr "Opção modificadora desconhecida."

msgid "Error setting filter description."
msgstr "Erro ao definir a descrição do filtro."

msgid "Empty option specifier."
msgstr "Opção sem especificação."

msgid "Option \"%option:1\" possibly specified prior to filter."
msgstr "A opção »%option:1« pode ter sido especificada antes do filtro."

msgid "Unknown mode description key \"%key:1\"."
msgstr "Chave de descrição do modo desconhecido \"%key:1\"."

msgid "Expecting \"%modekey:1\" key."
msgstr "Chave esperada para o modo de operação \"%modekey:1\"."

msgid "Version specifier missing key: \"aspell\"."
msgstr "Falha na versão do aspell. Versão necessária não encontrada."

msgid "Aspell version does not match mode's requirement."
msgstr "Aspell versão não atende aos requisitos do filtro."

msgid "Missing magic mode expression."
msgstr "Oração do modo mágico faltante."

msgid "Empty extension at char %char:1."
msgstr "A extensão após o caractere %char:1 é vazia."

msgid "\"%mode:1\" error"
msgstr "Erro «%mode:1»"

msgid "Unknown mode: \"%mode:1\"."
msgstr "Modo desconhecido: »%mode:1«."

msgid "\"%mode:1\" error while extend Aspell modes. (out of memory?)"
msgstr ""
"Erro ao expandir a opção Aspell no modo '%mode:1'. (Por falta de memória?)"

msgid "\"%mode:1\": no start for magic search given for magic \"%magic:2\"."
msgstr "»%mode:1«: Não há começo para a busca mágica de '»%magic:2«'."

msgid "\"%mode:1\": no range for magic search given for magic \"%magic:2\"."
msgstr "»%mode:1«: Não há região definida para a busca mágica de »%magic:2«."

msgid "\"%mode:1\": no magic expression available for magic \"%magic:2\"."
msgstr "«%mode:1»: nenhum expressão mágica disponível para «%magic:2»."

msgid ""
"\"%mode:1\": Magic \"%magic:2\": bad regular expression after location "
"specifier; regexp reports: \"%regerr:3\"."
msgstr ""
"»%mode:1«: Magia »%magic:2«: Expressão regular inválida após a localização; "
"regexp diz isso: »%regerr:3«."

msgid "\"%expression:1\" is not a valid regular expression."
msgstr "«%expression:1» não é um expressão regular válida."

msgid "Unhandled Error: "
msgstr "Erro não processável:"

