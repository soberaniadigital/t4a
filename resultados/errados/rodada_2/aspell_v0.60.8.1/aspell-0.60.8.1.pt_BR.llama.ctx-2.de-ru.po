msgstr ""
"»%mode:1«: Não há região para pesquisa de magic, definida para magic "
"'%magic:2'."

msgid "\"%mode:1\": no magic expression available for magic \"%magic:2\"."
msgstr "»%mode:1«: Não há expressões mágicas disponíveis para %magic:2."

msgid ""
"\"%mode:1\": Magic \"%magic:2\": bad regular expression after location "
