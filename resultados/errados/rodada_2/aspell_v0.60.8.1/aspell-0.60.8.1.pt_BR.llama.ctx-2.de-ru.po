msgstr "A metodologia \"%what:1\" não está implementada na localização \"%where:2\"."

msgid "%file:1:"
msgstr "%file:1:"

msgid "The file \"%file:1\" can not be opened"
msgstr "A ficheiro \"%file:1\" não pode ser aberto"

