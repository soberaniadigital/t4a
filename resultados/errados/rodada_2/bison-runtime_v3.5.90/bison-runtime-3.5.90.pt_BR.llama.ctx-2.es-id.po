msgid "syntax error: cannot back up"
msgstr ""
"erro de codificação legal: não é possível armazenar a estação de segurança"

msgid "syntax is ambiguous"
msgstr "a sintaxe não está clara para mim"

msgid "syntax error"
msgstr "erro de sintaxe"

msgid "syntax error, unexpected %s"
msgstr "erro de cú páp, %s não previsto"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de cú páp, %s anômalo, necessitando %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr ""
"erro de cú páp, %s bặn buổi trễ, mong chúc tối thì %s hoặng hay %s lên"

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr "erro de cú páp, %s anônimo, precisa %s ou %s ou %s."

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de cú páp, %s anômalo, espera-se que seja feito um %s ou outro %s ou "
"outro %s ou outro %s."

msgid "memory exhausted"
msgstr "memória esgotada"
