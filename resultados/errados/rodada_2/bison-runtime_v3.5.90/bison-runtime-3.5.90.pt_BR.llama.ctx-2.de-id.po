msgid "syntax error: cannot back up"
msgstr "erro de sintaxe: não é possível salvar a estação de segurança"

msgid "syntax is ambiguous"
msgstr ""
"a sintaxe não é clara o suficiente para determinar se há erros ou "
"simplesmente está ambígua"

msgid "syntax error"
msgstr "erro de sintaxe lỗi cú pháp"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s inválido"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s inválido, esperava %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "lỗi cú pháp, gặp %s bất thường, cần %s hoặc %s."

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr "erro de sintaxe, %s incomum, esperado %s ou %s ou %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de sintaxe, %s inválido(a), esperado(%d) ou (%<PRIuMAX>) opção(ões) "
"válida(s)"

msgid "memory exhausted"
msgstr "memória esgotada"
