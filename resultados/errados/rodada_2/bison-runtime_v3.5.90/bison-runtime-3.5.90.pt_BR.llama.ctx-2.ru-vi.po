msgid "syntax error: cannot back up"
msgstr ""
"erro de sintaxe: não é possível armazenar uma cópia segura da estação de "
"bombeiros"

msgid "syntax is ambiguous"
msgstr "cú pháp chưa rõ ràng"

msgid "syntax error"
msgstr "erro de sintaxe"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s não previsto"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s não prevista, espera-se que seja uma solução"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "erro de sintaxe, gặp %s inesperado, espera-se %s ou %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr ""
"erro de sintaxe, gặp %s incomum, espera-se que seja um erro ou uma entrada "
"inválida, caso contrário, informe o motivo."

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de sintaxe, gên %s inesperado, espera-se que seja um dos seguintes "
"opcionalmente: 'abrir', 'fechar' ou '%d vezes o comando padrão'\n"

msgid "memory exhausted"
msgstr "bateria esgotada"
