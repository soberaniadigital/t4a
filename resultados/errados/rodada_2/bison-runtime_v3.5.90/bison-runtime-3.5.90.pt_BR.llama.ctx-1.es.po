msgid "syntax error: cannot back up"
msgstr "erro de sintaxe: não pode armazenar a estação de segurança"

msgid "syntax is ambiguous"
msgstr "a sintaxe não está clara"

msgid "syntax error"
msgstr "erro de sintaxe"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s inesperado"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s inesperado, se esperava %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr ""
"erro de sintaxe, %s bólida, foi esperado que ocorresse um erro ou uma "
"exceção"

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr "erro de sintaxe, %s inesperado, esperávamos o %s ou %s ou %s."

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr ""
"erro de sintaxe, %s inesperado, esperávamos que ocorresse um dos seguintes "
"casos: uma opção inválida -- '%c' ou 'unable to stat file %s'"

msgid "memory exhausted"
msgstr "memória esgotada"
