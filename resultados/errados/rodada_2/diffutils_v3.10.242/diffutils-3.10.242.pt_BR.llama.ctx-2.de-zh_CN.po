msgstr "falha na leitura"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all               Todos os alterações exibidos, conflitos em ( )"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    exibe o script ed que inclui as alterações da "
"data OLDFILE para YOURDATEI e coloca em MYFILE\n"

