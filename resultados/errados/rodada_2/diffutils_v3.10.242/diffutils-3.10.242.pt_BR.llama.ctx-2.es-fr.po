msgstr "conflicto de opções tabsize"

msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                  produzir diferença normal (padrão)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   Indicar apenas se as diferenças entre os "
"arquivos são diferentes (caso contrário)"

msgid "-s, --report-identical-files  report when two files are the same"
msgstr "-s, --report-identical_files  Indicar se duas pastas são idênticas\n"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c NUM --context[=NUM]   excluir NUM (3 por padrão) linhas do contexto "
"copiado."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u NUM --unified[=NUM]   exclui NUM (padrão 3) linhas do contexto unificado."

msgid "-e, --ed                      output an ed script"
msgstr ""
"-e, --ed                      excluir um script para edição (editor de "
"texto)"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     gerar um arquivo 'diff' no formato RCS"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            Mostra em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM               limite a saída à no máximo NUM colunas "
"impressas (130 por padrão)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             mostra apenas a coluna esquerda as linhas "
"comuns\n"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   Não exiba linhas duplicadas."

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         Mostrar em qual função C ocorre cada "
"alteração\n"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   Mostrar a linha mais recente que corresponda "
"ao RE"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label ETIQUETA             utilizar ETIQUETA ao invés do nome de fichê e da marca de tempo (conforme o horário) \n"
"                                (pode ser repetido)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Expanda os tabulações em espaços na saída."

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab             Alinhe os tabuladores adicionando um tab na "
"frente deles."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty\n"
"Cegar espaços e tabulações antes de linhas vazias."

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                Relayer a saída para 'pr' para paginarla."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 membandaçendo subdiretorios de forma "
"recursiva"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não siga links simbólicos"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                Trata os arquivos que não existam como vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   anggap berkas pertama yang tidak ada sebagai"
" kosong"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     desconsiderar diferenças entre maiúsculas e "
"minúsculas ao comparar os nomes de arquivos."

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case Tenir em conta da diferença entre maiúsculas "
"e minúsculas ao comparar os nomes dos arquivos."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               excluir arquivos que correspondam ao padrão "
"PATron\n"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FICHIER   Exclua os arquivos cujos nomes concordam com "
"aqueles contidos no FICHIER."

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        comece a comparar diretórios iniciando pelo "
"FILE quando as comparações de pastas são feitas."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FICHIER1     Comparar FICHIER1 com todas as operandes. \n"
"                                  FICHIER1 pode ser um diretório ou outro arquivo"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FICHIER2       Comparar todas as opções com FICHIER2. \n"
"                                  FICHIER2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               desconsidere diferenças entre letras "
"maiúsculas e minúsculas no conteúdo dos arquivos."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      Ignore os alterações decorrentes da expansão"
" das tabulações."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space       Ignorar espaços em branco à final da linha"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       Ignore os alterações no número de espaços em"
" branco."

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space          descarta todos os espaços em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines        abaixa as alterações em que todas as linhas "
"são vazias"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore as changes lines that match the "
"regular expression RE."

msgid "-a, --text                      treat all files as text"
msgstr ""
"-a, --text                      Aplique a conversão de todos os arquivos "
"para texto"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr       Elimina os retornos de carro finais da entrada"

msgid "    --binary                    read and write data in binary mode"
msgstr ""
"    --binary                      leia e escreva os dados em modo binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NAME                keluarkan berkas yang tergabung dengan diff "
"'#ifdef NAME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatar grupos de entrada GTYPE com o "
"formato GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT       Formate todas as linhas de entrada no formato "
"LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT   Formatear linhas de entrada LTYPE com LFMT"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"As opções de formato fornecidas oferecem controle fino sobre a saída "
"diferencial e generalizam -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'antigo', 'novo' ou 'sem alterações'. GTYPE assume uma das "
"opções de LTYPE, ou seja, 'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT (somente) pode conter : \n"
"    %< para marcar as linhas do FIJIO1\n"
"    %> para marcar as linhas do FIJIO2\n"
"    %= para marcar as linhas comuns entre o FIJIO1 e o FIJIO2\n"
"    %[-][ANCHO][.[PRECISÃO]]{doxX}LETRA  especificação printf para LETRA\n"
"      As LETRAS podem ser como seguidas para grupos novos (em minúsculas para grupos antigos):\n"
"        F  número da primeira linha\n"
"        L  número da última linha\n"
"        N  número de linhas = L-F+1\n"
"        E  F-1\n"
"        M  L+1    %(A=B?T:E)  se A for igual a B então T caso contrário E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"Tanto GFMT quanto LFMT podem conter : \n"
"    %%\n"
"    %c'C'\t o caractere C (ele mesmo)\n"
"    %c'^'\t o carácter com código octal \\u005e\\n"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal            busca assiduamente o conjunto de diferenças mais "
"pequeno em Keras."

