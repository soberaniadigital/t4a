msgstr "O chave \"%key:1\" não é %accepted:2 e, portanto, está inválida."

msgid ""
"The value \"%value:2\" is not %accepted:3 and is thus invalid for the key "
"\"%key:1\"."
msgstr ""
"O valor \"%value:2\" não é %accepted:3 e, portanto, está incompatível para o"
" chave \"%key:1\"."

