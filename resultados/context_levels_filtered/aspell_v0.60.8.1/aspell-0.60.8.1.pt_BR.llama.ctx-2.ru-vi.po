msgstr "O método \"%what:1\" não está implementado em \"%where:2\"."

msgid "%file:1:"
msgstr "%file:1:"

msgid "The file \"%file:1\" can not be opened"
msgstr "A pasta de arquivo \"%file:1\" não pode ser aberta."

