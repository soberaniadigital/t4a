msgstr "Versão Aspell não atende aos requisitos do filtro."

msgid "Filter option already exists."
msgstr "Opção de filtragem já existe."

msgid "Use option modifiers only within named option."
msgstr ""
"Utilize os modificadores de opções somente dentro das opções nomeadas."

msgid "Option modifier unknown."
msgstr "Modificador de opção desconhecido."

msgid "Error setting filter description."
msgstr "Erro ao definir a descrição do filtro."

msgid "Empty option specifier."
msgstr "Oculto ou inválido selecionador de opção."

msgid "Option \"%option:1\" possibly specified prior to filter."
msgstr ""
"É possível que a opção \"%option:1\" tenha sido especificada antes do "
"filtro."

