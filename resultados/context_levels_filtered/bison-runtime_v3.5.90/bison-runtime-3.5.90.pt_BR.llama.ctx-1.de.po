msgid "syntax error: cannot back up"
msgstr "Erro de sintaxe: não é possível sair da estação segurança"

msgid "syntax is ambiguous"
msgstr "a sintaxe não é clara o suficiente para ser interpretada"

msgid "syntax error"
msgstr "erro de sintaxe"

msgid "syntax error, unexpected %s"
msgstr "erro de sintaxe, %s incomum"

msgid "syntax error, unexpected %s, expecting %s"
msgstr "erro de sintaxe, %s bizarro, esperava %s"

msgid "syntax error, unexpected %s, expecting %s or %s"
msgstr "erro de sintaxe, %s extraordinário, esperava %s ou %s"

msgid "syntax error, unexpected %s, expecting %s or %s or %s"
msgstr ""
"erro de sintaxe, %s inválido ou inesperado, esperava-se que fosse uma opção "
"válida e/ou um argumento\n"

msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr "erro de sintaxe, encontrou %s anônimo, esperava %s ou %s ou %s ou %s"

msgid "memory exhausted"
msgstr "o armazenamento está esgotado"
