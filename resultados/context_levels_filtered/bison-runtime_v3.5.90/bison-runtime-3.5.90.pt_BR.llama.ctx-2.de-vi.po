msgid "syntax error, unexpected %s, expecting %s or %s or %s or %s"
msgstr "lỗi cú pháp, gặp %s bất thường, cần %s hoặt %s hoặc %s hay %s"

msgid "memory exhausted"
msgstr "memória cheia"
