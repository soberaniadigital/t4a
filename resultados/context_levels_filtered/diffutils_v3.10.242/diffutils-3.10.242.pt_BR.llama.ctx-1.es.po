msgstr "Paul Eggert"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Richard Stallman"
msgstr "Richard Stallman"

msgid "Len Tower"
msgstr "Len Tower ES"

msgid "invalid context length %s"
msgstr "longitude de contexto inválida '%s'"

msgid "pagination not supported on this host"
msgstr "paginasi não é suportada neste host."

msgid "too many file label options"
msgstr "demasiadas opções de etiqueta de arquivo"

msgid "invalid width %s"
msgstr "ancho inválido '%s'"

msgid "conflicting width options"
msgstr "opções de ancho conflitantes"

msgid "invalid horizon length %s"
msgstr "a longitude do horizonte '%s' não é válida"

msgid "invalid tabsize %s"
msgstr "tamanho do campo '%s' não é válido"

msgid "conflicting tabsize options"
msgstr "conflicto de opções tabsize"

msgid "--from-file and --to-file both specified"
msgstr "se ha especificado tanto --from-file como --to-file"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                  produz um diff normal (padrão)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief                   indica apenas se os arquivos são diferentes ou"
" não."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical-files notifica quando dois arquivos são idênticos."

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C NUM, --context[=NUM]   exibe NUM (por omissão 3) linhas de contexto "
"da entrada."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   exibe NÚM (padrão 3) linhas de contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      produz um script ed\n"

msgid "-n, --rcs                     output an RCS format diff"
msgstr ""
"-n, --rcs                     gera diferenças no formato RCS para keluaran"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            mostra em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W,--width=NUM               Mostra como máximo NUM colunas de impressão "
"(por omissão, 130)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             mostra apenas a coluna esquerda as linhas "
"comuns"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não exibe linhas comuns"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         menciona em qual função C cada alteração está "
"localizada"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=%s   mostra a linha mais recente que encaixa com %s"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label ETIQUETA          utilize a etiqueta em vez do nome do arquivo e"
" da marca de tempo (se pode repetir)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             expande os tabuladores para espaços na saída"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab             faz com que os tabuladores se alinhem "
"retilirmente na frente do próprio tab\n"

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak\n"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty    suprime espaços ou tabs antes de uma linha "
"vazia"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                passeie a saída por 'pr' para paginarla."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 membanda junto os subdiretórios de forma "
"recursiva"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            não sigam os links simbólicos"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                    trata os arquivos que não existam como "
"vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   trata os arquivos originais que não existem "
"como vazios"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     descarta as diferenças entre maiúsculas e "
"minúsculas ao comparar os nomes dos arquivos"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case considera distintas maiúsculas e minúsculas "
"ao comparar os nomes dos arquivos."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               excluir os arquivos que coincidam com PAT."

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=ARQUIVO      exclui os arquivos que coincidam com alguma "
"expressão regular de ARQUIVO"

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=ARQUIVO     inicia comparando diretórios com o arquivo "
"ARQUIVO especificado."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=ARQUIVO1        compara ARQUIVO1 com todos os operandos; \n"
"                                  ARQUIVO1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=ARQUIVO2          compara todos os operandos com ARQUIVO2; \n"
"                                  ARQUIVO2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               descarta as diferenças entre letras "
"maiúsculas e minúsculas no conteúdo dos arquivos."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      descarta mudanças devidas a expansões de "
"tabs"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space     descarta espaço em branco ao final de "
"linha\n"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       descarta as diferenças no número de espaços "
"em branco\n"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space          descarta todos os espaços em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines        descarta os alterações em linhas "
"completamente vazias\n"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE\n"
"Descarta as linhas que coincidam com RE."

msgid "-a, --text                      treat all files as text"
msgstr ""
"-a, --text                      trata todos os arquivos como de tipo texto"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         elimina os retornos de carro finais na "
"entrada"

msgid "    --binary                    read and write data in binary mode"
msgstr ""
"    --binary                    leia e escreva os dados no modo binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NOMBRE              gera um arquivo combinado que mostra as "
"diferenças com '#ifdef NOMBRE'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatando grupos de entrada GTYPE com o "
"formato GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          formatar todas as linhas de entrada com LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT    formatar as linhas de entrada LTYPE com "
"LFMT\n"

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"As opções de formato fornecem um controle fino sobre o resultado do diff, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE é 'antigo', 'novo' ou 'sem mudanças'. GTYPE é como LTYPE, ou seja, "
"'cambiado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT (solamente) pode conter: \n"
"    %< linhas do ARCHIVO1\n"
"    %> linhas do ARCHIVO2\n"
"    %= linhas comuns a ARCHIVO1 e ARCHIVO2\n"
"    %[-][ANCHO][.[PRECISIÃN]]{doxX}LETRA  especificação printf para LETRA \n"
"      As LETRAs podem ser como seguidas para grupos novos (em minúsculas para grupos antigos):\n"
"        F número da primeira linha\n"
"        L número da última linha\n"
"        N número de linhas = L-F+1\n"
"        E F-1\n"
"        M L+1"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"Tanto GFMT quanto LFMT podem conter: \n"
"%%\n"
"%c'C'\tcaractere C (um caractere)\n"
"%c'^'\tcaracter com código octal \\u005e\\u005e\\u005e (trio de zeros)\\nC    o mesmo que antes\n"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal            busca por pequenos grupos de mudanças no Keras."

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM mantém NUM linhas de prefíxos e sufixos comuns\n"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files supõe que os arquivos são grandes e as alterações "
"são numerosas, pequenas e dispersas."

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=QUANDO]     coloreia a saída; QUANDO é 'sempre', 'nunca' ou 'auto';\n"
"                           --color por si só significa --color='auto'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE     os cromados que são utilizados quando --color está"
" ativo; PALETTE é uma lista de capacidades terminfo separadas por dois "
"pontos"

msgid "    --help               display this help and exit"
msgstr "    --help               mostra esta ajuda e termina a execução"

msgid "-v, --version            output version information and exit"
msgstr "-v, --version            mostra a versão e sai da utilidade\n"

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"ARQUIVOS podem ser 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr "Bila --from-file ou --to-file diri, não há limites para arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se um arquivo for '-', lê a entrada padrão."

