msgstr "As duas pastas que devem ser comparadas são diretórios."

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"[{'ed': 'Edita y usa ambas versões, cada una decorada con una cabecera.', "
"'eb': 'Edita y usa ambas versões.', 'el atau e1': 'Edita y usa la versión "
"izquierda.', 'er atau e2': 'Edita y usa la versión derecha.'}, {'e': 'Edita "
"uma nova versão.', 'l  atau e1': 'Usa a versão esquerda.', 'r  atau e2': "
"'Usa a versão direita.'}, {'s': 'Inclui linhas comuns silenciosamente.', "
"'v': 'Inclui linhas comuns verbosamente.'}, {'q': 'Sair.'}]"

msgid "unrecognized prefix: %s"
msgstr "prefíxo não reconhecido: %s"

