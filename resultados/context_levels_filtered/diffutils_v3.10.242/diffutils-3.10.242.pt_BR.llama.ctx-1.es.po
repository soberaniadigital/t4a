msgstr "-D opção não suportada com diretórios."

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdiretórios comuns: %s e %s"

msgid "Only in %s: %s\n"
msgstr "Sólo en %s: %s\n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr ""
"O arquivo %s é um ES enquanto que o %s é um outro tipo de básico para "
"armazenamento temporário."

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Os símbolos '%s' e '%s' são distintos entre si."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o sinal de menos '-' com um diretório"

msgid "Files %s and %s are identical\n"
msgstr "As pastas %s e %s são idênticas"

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opções não compatíveis"

msgid "'-' specified for more than one input file"
msgstr "ES"

msgid "read failed"
msgstr "falha na leitura"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exibe todos os alterações e encerra conflitos "
"entre parênteses\n"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    exibe um `script' ed incorporando as alterações "
"entre o ARCHIVO-ANTIGUO e TU-ARCHIVO para MI-ARCHIVO."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E, --mostrar sobreposicao          como -e, mas encerrando os conflitos "
"entre parênteses\n"

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             como -e, mas apenas incorpora os alterações que "
"não se sobrepõem."

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          como -e, mas só mostra os alterações que se "
"sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          como -x, mas envolve conflitos entre "
"parênteses\n"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr ""
"-i                          adiciona as ordens 'w' e 'q' aos scripts ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                 exibe o arquivo combinado conforme -A se não for"
" especificada nenhuma outra opção\n"

msgid "-a, --text                  treat all files as text"
msgstr ""
"-a, --text                    trata todos os arquivos como de tipo texto"

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr     elimina os retornos de carro finais na entrada"

