msgstr "Paul Eggert"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Richard Stallman"
msgstr "Richard Stallman"

msgid "Len Tower"
msgstr "Torre de Len"

msgid "invalid context length %s"
msgstr "a longitud de contexto %s não é válida"

msgid "pagination not supported on this host"
msgstr "paginasi não é suportada neste sistema."

msgid "too many file label options"
msgstr "demasiadas opções de etiqueta de arquivo foram especificadas."

msgid "invalid width %s"
msgstr "largura '%s' não é válida"

msgid "conflicting width options"
msgstr "opções de latitudes conflitantes"

msgid "invalid horizon length %s"
msgstr "a panjang horizonte %s não é válido"

msgid "invalid tabsize %s"
msgstr "largura tabular %s não é válida"

msgid "conflicting tabsize options"
msgstr "opções de tabulação com tamanho %<PRIuMAX> conflitantes."

msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan."

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                      exibir diff normal (padrão)"

msgid "-q, --brief                   report only when files differ"
msgstr "-q, --brief                   laporkan hanya ketika berkas berbeda."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical_files    Notificar quando duas pastas são idênticas."

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c NUM --context=NUM   exibe NUM (por omissão 3) linhas do contexto copiado."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   ZAHL linhas do contexto unificado serão "
"excluídas (valor padrão: 3)."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      excluir um script ed."

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     keluaran RCS em diferença (diff)"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            mostra em duas colunas."

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NUM               mude o tamanho máximo de colunas para NUM "
"(padrão 130)"

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             exibe apenas a coluna esquerda das linhas "
"comuns\n"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines     Não exiba linhas comuns."

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         menitkan di qual função C cada alteração é "
"feita."

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE     Mostra a linha atual que corresponde ao "
"padrão RE."

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pakai LABEL bukan nama berkas dan stempel waktu\n"
"                                (dapat diulang)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs             Expande os tabuladores para espaços na saída."

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --initial-tab             Cria uma tabulação reta com um espaço antes do"
" primeiro tabulador."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty      Leia letras ou tabulações antes de uma linha"
" vazia na saída."

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l, --paginate                   Envia a saída para 'pr' para paginar."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 membanda os subdiretórios de forma "
"recursiva."

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference            Não siga os links simbólicos."

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file                    Trata arquivos não existentes como vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   anggap berkas pertama yang tidak ada sebagai"
" kosong."

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-name-case     Ignore diferenças entre maiúsculas e "
"minúsculas ao comparar os nomes dos arquivos."

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  considere diferenças entre maiúsculas e "
"minúsculas ao comparar os nomes dos arquivos."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               excluir arquivos que correspondam a PAT."

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=ARQUIVO        Exclui os arquivos que correspondam a "
"algum padrão no ARQUIVO."

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        comece com FILE ao comparar diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1           bandar FILE1 para todos os operandos; \n"
"                                  FILE1 pode ser um diretório."

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=ARQUIVO2             comparar todos os operandos com ARQUIVO2; \n"
"                                  ARQUIVO2 pode ser um diretório."

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               Ignorar diferenças entre letras maiúsculas e"
" minúsculas no conteúdo dos arquivos."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      ignorem obras devido a expansões de tabs\n"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space     abaixa espaços em branco ao final da linha."

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       Ignore changes in the quantity of white "
"space."

msgid "-w, --ignore-all-space          ignore all white space"
msgstr ""
"-w, --ignore-all-space          Ignorar espaços em branco na leitura do "
"arquivo."

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        ignorar alterações em linhas vazias."

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignore changes in lines that match the "
"pattern RE."

msgid "-a, --text                      treat all files as text"
msgstr ""
"-a, --text                      Aplica-se a todas as pastas como texto."

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar retorno de carro no final da linha ao"
" inserir."

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                    leia e escreva dados no modo binário."

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NAME                Genera um arquivo combinado que inclui a "
"diferença '#ifdef NAME'."

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatar o grupo de entrada GTYPE com GFMT."

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr ""
"    --line-format=LFMT          Formate todas as linhas de entrada no "
"formato LFMT."

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT    formatar linhas de entrada LTYPE com LFMT."

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"As opções de formato fornecem controle fino sobre o resultado do diff, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'antigo', 'novo' ou 'sem alterações'. GTYPE é LTYPE ou "
"'alterado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode (apenas) conter as seguints informações:\n"
"    %< linhas da DATEI1.\n"
"    %> linhas da DATEI2.\n"
"    %= linhas comuns à DATEI1 e a DATEI2.\n"
"    %[-][LARGO][.[PRECISÃO]]{doxX}LETRA  especificação printf para LETRA\n"
"      As seguintes letras podem ser usadas como seguidas para novos grupos (em minúsculas para antigos):\n"
"        F número da primeira linha.\n"
"        L número da última linha.\n"
"        N quantidade de linhas = L-F+1.\n"
"        E F-1.\n"
"        M L+1."

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"LFMT pode (apenas) conter as seguintes informações:\n"
"    %L conteúdo da linha.\n"
"    %l conteúdo da linha, sem caracteres de nova linha no final.\n"
"    %[-][ANCHO][.[PRECISÃO]]{doxX}n especificação em estilo printf para o número da linha de entrada."

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"Tanto GFMT quanto LFMT podem conter: \n"
"%%\n"
"%c'C'\tcaractere único C\n"
"%c'^'\tcaracter com o código octal \\u005eO\n"
"C\tthe character 'C' (and other characters represent themselves)"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal             Intensificar na busca por uma pequena quantidade "
"de alterações."

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM  NUM linhas com prefíxo e sufixo padrão\n"
"            mantêm."

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files   Supõe que grandes arquivos com muitas pequenas e "
"dispersas alterações sejam processados."

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=WHEN]       warnai keluaran; WHEN adalah 'semua', 'tidak' atau 'auto';\n"
"                           --color polos berarti --color='auto'"

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    as bem como utilizadas quando o --color está ativo;"
" PALETTE é uma lista de capacidades terminfo separadas por dois pontos"

msgid "    --help               display this help and exit"
msgstr "    --help                 Mostrar ajuda atual e sair."

msgid "-v, --version            output version information and exit"
msgstr "-v, --version            Mostrar versão e sair."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES podem ser 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr ""
"Seja --from-file ou --to-file especificado, não há limites para arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o arquivo for '-', ler da entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Aufruf: %s [OPTION]... BERKAS"

msgid "Compare FILES line by line."
msgstr "Bandar FILE baris per baris."

msgid "conflicting %s option value %s"
msgstr "valor '%s' da opção %s é conflitante"

msgid "conflicting output style options"
msgstr "opções conflitantes para o estilo de saída do jogo."

msgid "invalid color %s"
msgstr "cor %s não válida"

msgid "-D option not supported with directories"
msgstr "A opção -D não é suportada em diretórios."

msgid "Common subdirectories: %s and %s\n"
msgstr ""
"Subdiretórios sama: %s e %s. \n"
"\t(Gemeinsame Unterverzeichnisse)"

msgid "Only in %s: %s\n"
msgstr "Nur em %s: %s."

msgid "File %s is a %s while file %s is a %s\n"
msgstr "O arquivo %s é um %s, enquanto o arquivo %s é um %s."

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "A simbolica conexão %s -> %s e %s -> %s apresenta diferenças."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar '-' com um diretório."

msgid "Files %s and %s are identical\n"
msgstr "Berkas %s dan %s identik."

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opção não compatível"

msgid "'-' specified for more than one input file"
msgstr "O sinal '-' indica que mais de uma pasta de entrada foi especificada."

msgid "read failed"
msgstr "falha na leitura."

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exibe todas as alterações e conflitos entre "
"parênteses."

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    exibe o script ed que inclui alterações da "
"OLDFILE para YOURFILE em MYFILE."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr "-E --show-overlap           Wie -e, mas com conflitos em parênteses."

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only              como -e, mas apenas incorpora as alterações que"
" não se sobrepõem."

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          como -e, mas apenas integração de alterações que"
" se sobrepõem."

msgid "-X                          like -x, but bracket conflicts"
msgstr "-X                          como -x, mas com conflitos em colchetes."

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr ""
"-i                          imbuhkan perintah 'w' dan 'q' ke skrip ed."

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"-m, --merge                   Exibe a pasta de arquivo realmente combinada, "
"conforme -A, se nenhuma outra opção for especificada."

msgid "-a, --text                  treat all files as text"
msgstr "-a, --text                   Aplica-se a todas as pastas como texto."

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      Elimina os retornos de carro no final da linha "
"na entrada\n"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --tabularize initial tab   \n"
"    Initiate a horizontal indentation by inserting tabs before the first character."

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM  utilizar PROGRAM para comparar as pastas."

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L, --label=LABEL            LABEL em vez do nome de arquivo utilizar "
"(possível repetir até três vezes)"

msgid "    --help                  display this help and exit"
msgstr "    --help                   Mostrar esta ajuda e sair."

msgid "-v, --version               output version information and exit"
msgstr ""
"-v --versao               exibe informações de versão e termina a execução."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Emprego: %s [OPÇÃO]... MEUARQUIVO ANTIGUOARQUIVO SEUARQUIVO\n"

msgid "Compare three files line by line."
msgstr "Bandingkan tiga berkas baris per baris."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída é uma representação mais ou menos legível dos alterações. "
"As opções -e, -E, -x e -X (além das suas correspondentes versões longas) "
"geram um script ed em vez do resultado predeterminado. Por fim, a opção "
"--merge faz com que diff3 combine as mudanças internamente e exiba o arquivo"
" combinado realmente existente. Para entradas incomuns, isso é mais robusto "
"do que usar ed."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"O status do resultado é 0 se tudo correu bem, 1 caso houver conflito e 2 em "
"caso de falha."

msgid "internal error: screwup in format of diff blocks"
msgstr ""
"Erro interno de execução do programa: falha na análise dos blocos diff."

msgid "%s: diff failed: "
msgstr "%s: diff falhou: "

msgid "internal error: invalid diff type in process_diff"
msgstr "Erro interno: tipo de diferença não é válido no process_diff."

msgid "invalid diff format; invalid change separator"
msgstr "formato de diferença inválido; separador de alterações inválido."

msgid "invalid diff format; incomplete last line"
msgstr "formato de diferença inválido; linha final incompleta."

msgid "subsidiary program %s could not be invoked"
msgstr "programa subsidiário %s não pode ser chamado."

msgid "invalid diff format; incorrect leading line chars"
msgstr ""
"formato de diferença inválido; caracteres não corretos no início da linha."

msgid "internal error: invalid diff type passed to output"
msgstr "Erro interno: tipo de diff inválido passado à saída."

msgid "input file shrank"
msgstr "o arquivo de entrada diminuiu inesperadamente."

msgid "cannot compare file names %s and %s"
msgstr "Os nomes de arquivo %s e %s não podem ser comparados."

msgid "%s: recursive directory loop"
msgstr "%s: Loop de diretório recursivo"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o --output=FILE            operar de forma interativa, enviando a saída "
"para FILE."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr ""
"-i, --ignore-case            Não distingue entre maiúsculas e minúsculas."

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   ignora as alterações devidas à expansão de "
"tabs."

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space abaixo de cada linha ignorar espaços em branco "
"ao final."

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    Ignore changes in the amount of white space."

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space       abaixa todos os espaços em branco."

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr ""
"-B, --ignore-blank-lines     ignorar alterações em que todas as linhas são "
"vazias."

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Ignorar alterações em todas as linhas que "
"correspondam ao padrão RE."

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      Remove return carriage at the end of input "
"lines."

msgid "-a, --text                   treat all files as text"
msgstr "-a, --text                   Aplica-se a todas as pastas como texto."

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              Kelihatan NUM (130) kolom cetak. Maximum width "
"per line."

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            Nur linke Spalte der gemeinsamen Zeilen "
"ausgeben."

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines  Não exiba linhas comuns."

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs            Tabuleiros em espaços no lugar dos tabs na "
"saída."

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                Intensiv após uma pequena quantidade de "
"alterações procurar."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      Supõe que grandes arquivos possuem muitos "
"pequenos e dispersos alterações."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM   utilize PROGRAM para comparar as pastas."

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar ajuda deste e encerrar."

msgid "-v, --version                output version information and exit"
msgstr "-v, --version                Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Aufruf: %s [OPTION]... DATEI1 DATEI2\n"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Conjunto diferenciado de FILE1 e FILE2."

msgid "cannot interactively merge standard input"
msgstr "não é possível juntar a entrada padrão de forma interativa."

msgid "both files to be compared are directories"
msgstr "As duas pastas que estão sendo comparadas são diretórios."

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed: Editie, depois utilize ambas versões decoradas com cabeçalho.eb: Editie "
"e utilizar as duas versões decoradas.el ou e1: Edite a versão esquerda.er ou"
" e2: Edite a versão direita.e: Crie uma nova versão.l 1: Utilize a versão "
"esquerda.r 2: Utilize a versão direita.s: Inclua linhas comuns sem "
"interrupção.v: Inclua linhas comuns de forma detalhada.q: Sair."

msgid "unrecognized prefix: %s"
msgstr "Prefíxo desconhecido: %s"

msgid "unparsable value for --palette"
msgstr "valor não pode ser interpretado para --palette"
