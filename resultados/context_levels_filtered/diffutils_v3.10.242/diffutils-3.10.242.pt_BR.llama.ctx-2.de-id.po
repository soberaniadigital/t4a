msgstr "Paul Eggert"

msgid "Mike Haertel"
msgstr "Mike Haertel"

msgid "David Hayes"
msgstr "David Hayes"

msgid "Richard Stallman"
msgstr "Richard Stallman"

msgid "Len Tower"
msgstr "Len Tower"

msgid "invalid context length %s"
msgstr "a panjang do contexto %s não é válido"

msgid "pagination not supported on this host"
msgstr "paginasi não é suportada neste host."

msgid "too many file label options"
msgstr "existe muito mais opções de rótulo do que é necessário."

msgid "invalid width %s"
msgstr "o valor '%s' para o campo 'ID' não é válido."

msgid "conflicting width options"
msgstr "opções de largura conflitantes"

msgid "invalid horizon length %s"
msgstr "a medida do horizonte %s não é válida"

msgid "invalid tabsize %s"
msgstr "ukuran tab %s não é válido"

msgid "conflicting tabsize options"
msgstr "conflicto de opções tabsize."

msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file keduanya disebutkan"

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal                  exibir diff normal (básico)"

msgid "-q, --brief                   report only when files differ"
msgstr "-q, --brief                   laporkan hanya ketika berkas berbeda\n"

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical_files   relatar quando duas pastas são idênticas."

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C NUM, --context[=NUM]   keluarkan NUM (baku 3) baris dari konteks yang"
" disalin."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U NUM, --unified[=NUM]   excluir %d (baku 3) linhas do contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr "-e, --ed                      excluir um script ed."

msgid "-n, --rcs                     output an RCS format diff"
msgstr ""
"-n, --rcs                     keluaran RCS em diferença de versão do sistema"
" (diff)"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side            keluaran dalam dua kolom"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NUM               keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column             apenas exibe a coluna esquerda das linhas que "
"são idênticas."

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não mostre linhas comuns."

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function         menitkan di dentro da função C para onde cada "
"perda de dados irá"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE   mostra a linha de função que corresponde ao "
"padrão RE\n"

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             pakai LABEL bukan nama berkas dan stempel waktu\n"
"                                (dapat diulang)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr "-t, --expand-tabs             ekspansi tab ke spasi dalam keluaran"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab             criar tabulação reta com inserção de tabs na "
"frente do tabulador."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty    cegah espaços ou tabuladores antes de linhas "
"em branco na saída."

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr ""
"-l --paginate                   Forneça sorte para 'pr' ao serem gerados os "
"resultados."

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive                 membandação recursiva de subdiretórios."

msgid "    --no-dereference            don't follow symbolic links"
msgstr ""
"    --no-dereference            Não siga simbolicamente as referências."

msgid "-N, --new-file                  treat absent files as empty"
msgstr "-N, --new-file                   Não aceitar arquivos vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   adiciona o primeiro arquivo sem conteúdo "
"como vazio."

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignora-nome-do-arquivo-de-letras     ignore diferenças entre "
"maiúsculas e minúsculas ao comparar o nome do arquivo."

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case  pertimbangque grandes pequenos ao comparar "
"nomes de arquivos."

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr ""
"-x, --exclude=PAT               sem arquivos que correspondam ao padrão PAT."

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         exclua as pastas que se encaixam nos padrões"
" do arquivo FILE."

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        comece com FILE ao comparar diretórios."

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1           bandar FILE1 para todos os operandos; \n"
"                                  FILE1 pode ser um diretório."

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2             bandar todos os operandos com FILE2; \n"
"                                  FILE2 pode ser um diretório."

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case               abaixa diferenças entre letras maiúsculas e "
"minúsculas no conteúdo do arquivo."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      abaixa as alterações decorrentes da expansão"
" do tabulador."

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space     Ignorar espaços em branco no final da linha."

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       abaixa as alterações no número de espaços em"
" branco."

msgid "-w, --ignore-all-space          ignore all white space"
msgstr ""
"-W, --ignore-all-space          abaixa sem todas as espaçamentos em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr "-B, --ignore-blank-lines        abaixa as alterações em linhas vazias"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Abaixo das linhas que se adequam ao padrão RE"
" serão ignoradas."

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      perlacupe todas as blocas como texto."

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr         apagar retorno de carro no final da linha ao"
" inserir."

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary                    baca dan tulis data dalam mode biner."

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NAME                ekskluzifikan berkas yang tergabung dengan "
"diff '#ifdef NAME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr ""
"    --GTYPE-group-format=GFMT   formatar grupo de entrada GTYPE com o "
"formato GFMT"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr "    --line-format=LFMT          format semua baris masukan denga LFMT\n"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT    formatar linhas com LFMT para entrada do "
"tipo LTYPE."

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Opsi format inicial oferece controle suave sobre a diferença de saída, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"LTYPE pode ser 'antigo', 'novo' ou 'inalterado'. GTYPE é LTYPE ou "
"'modificado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode conter as seguints informações:\n"
"    %< baris de FILE1\n"
"    %> baris de FILE2\n"
"    %= linhas que pertencem tanto a FILE1 quanto a FILE2\n"
"    %[-][BREITE][.[PRÄZ]]{doxX}LINHA  especificação printf-style para LINHA, conforme as regras:\n"
"      As seguintes letras representam novos grupos e seus respectivos caracteres minúsculos antigos: F - primeira linha numeração\n"
"                                L - última linha numeração\n"
"                                N - número total de linhas = L-F+1\n"
"                                E - (F)-1\n"
"                                M - L+1\n"
"    %(A=B?T:E)  Se A for igual a B, então T, caso contrário E."

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"LFMT pode conter as seguintes informações:\n"
"    %L contém uma linha.\n"
"    %l contém uma linha, sem o início de nova linha ao final.\n"
"    %[-][BREITE][.[PRÉC]]{doxX}n  especificador printf para a numeração das linhas."

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"GFMT ou LFMT podem conter: \n"
"%%\n"
"%c'C'\n"
"de caracter único C\n"
"%c'^'\n"
"de caractere com código octal \\u005eO"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal             Intensificação para busca de pequenas alterações "
"no conjunto."

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr "    --horizon-lines=NUM  pertângem NUM barras prefixo e sufixo comuns\n"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files   Assumem grandes arquivos com muitas pequenas "
"alterações dispersas."

msgid ""
"    --color[=WHEN]       color output; WHEN is 'never', 'always', or 'auto';\n"
"                           plain --color means --color='auto'"
msgstr ""
"    --color[=WHEN]       keluaran warnai; Quando é 'sempre', 'jamais' ou 'automático';\n"
"                           --color polos significa `--color='automático'\""

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
"                           a colon-separated list of terminfo capabilities"
msgstr ""
"    --palette=PALETTE    cor de fundo que é utilizada quando o --color está "
"ativo; PALETTE é uma lista separada por dois pontos, consistindo em "
"capacidades terminfo."

msgid "    --help               display this help and exit"
msgstr "    --help                 mostrar ajuda deste e encerrar."

msgid "-v, --version            output version information and exit"
msgstr "-v, --version            Mostrar informações de versão e sair."

msgid "FILES are 'FILE1 FILE2' or 'DIR1 DIR2' or 'DIR FILE' or 'FILE DIR'."
msgstr ""
"FILES adalah 'FILE1 FILE2' ou 'DIR1 DIR2' ou 'DIR FILE' ou 'FILE DIR'."

msgid ""
"If --from-file or --to-file is given, there are no restrictions on FILE(s)."
msgstr "Bila --from-file ou --to-file diri, não há limites para arquivos."

msgid "If a FILE is '-', read standard input."
msgstr "Se o arquivo for '-', ler de entrada padrão."

msgid "Usage: %s [OPTION]... FILES\n"
msgstr "Penggunaan: %s [OPTION]... BERKAS"

msgid "Compare FILES line by line."
msgstr "Bandar FILE baris por linha."

msgid "conflicting %s option value %s"
msgstr "Valor inválido para a opção %1s, conflito com o valor padrão."

msgid "conflicting output style options"
msgstr "Conflicto de opções para o estilo do resultado."

msgid "invalid color %s"
msgstr "A cor %s não é válida"

msgid "-D option not supported with directories"
msgstr "-D option not supported by directories (directories)"

msgid "Common subdirectories: %s and %s\n"
msgstr "Subdirektori sama: %s dan %s."

msgid "Only in %s: %s\n"
msgstr "Hanya dalam %s: %s. \n"

msgid "File %s is a %s while file %s is a %s\n"
msgstr "Berkas %s adalah %d sementara berkas %s adalah %<PRIuMAX>."

msgid "Symbolic links %s -> %s and %s -> %s differ\n"
msgstr "Taut simbolis %s -> %s dan %s -> %s berbeda."

msgid "cannot compare '-' to a directory"
msgstr "não é possível comparar o caractere '-' com diretório."

msgid "Files %s and %s are identical\n"
msgstr "Berkas %s dan %s identik."

msgid "Randy Smith"
msgstr "Randy Smith"

msgid "incompatible options"
msgstr "opção não compatível."

msgid "'-' specified for more than one input file"
msgstr "'--' especifica mais de uma blocos de entrada para o programa."

msgid "read failed"
msgstr "falha na leitura do arquivo."

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all              exiba todas as alterações e conflitos no termo "
"de curtida (conflict in the courier)"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                    excluir script ed que contém alterações de "
"OLDFILE para YOURFILE em MYFILE."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr ""
"-E --mostrar-superposicao          semelhante ao -e, mas apit conflito na "
"caixa de entrada."

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr ""
"-3, --easy-only             semelhante a -e, mas apenas envolve alterações "
"que não se sobrepõem"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only          se semelhante a -e, mas apenas conter alterações"
" que tenham sobreposição."

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                          seperti -x, tapi apit konflik dalam kurung"

msgid "-i                          append 'w' and 'q' commands to ed scripts"
msgstr "-i                          imbuhkan perintah 'w' dan 'q' ke skrip ed"

msgid ""
"-m, --merge                 output actual merged file, according to\n"
"                                -A if no other options are given"
msgstr ""
"--merge                   Mergida de arquivos reais, conforme -A sem opções "
"alternativas."

msgid "-a, --text                  treat all files as text"
msgstr "-a, --text                   Aplique a todos os arquivos como texto."

msgid "    --strip-trailing-cr     strip trailing carriage return on input"
msgstr "    --strip-trailing-cr     apagar retorno de linha no final do input\n"

msgid "-T, --initial-tab           make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab            Inicie uma linha tabulada reta com "
"preenchimento à frente do primeiro caractere de tabulação."

msgid "    --diff-program=PROGRAM  use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM  utilize PROGRAM para comparar arquivos\n"

msgid ""
"-L, --label=LABEL           use LABEL instead of file name\n"
"                                (can be repeated up to three times)"
msgstr ""
"-L,--label=LABEL           pakai LABEL sebagai pengganti nama berkas\n"
"                                (dapat diulang sampai dengan tiga kali)"

msgid "    --help                  display this help and exit"
msgstr "    --help                  Mostrar ajuda deste assistente e sair."

msgid "-v, --version               output version information and exit"
msgstr "-v, --version               Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... MYFILE OLDFILE YOURFILE\n"
msgstr "Pemakaian: %s [OPTION]... MYFILE OLDFILE YOURFILE"

msgid "Compare three files line by line."
msgstr "Bandicote três blocos de linhas por linha."

msgid ""
"\n"
"The default output format is a somewhat human-readable representation of\n"
"the changes.\n"
"\n"
"The -e, -E, -x, -X (and corresponding long) options cause an ed script\n"
"to be output instead of the default.\n"
"\n"
"Finally, the -m (--merge) option causes diff3 to do the merge internally\n"
"and output the actual merged file.  For unusual input, this is more\n"
"robust than using ed.\n"
msgstr ""
"O padrão de saída do keluaran baku é uma representação das alterações que "
"pode ser lida por humanos. As opções -e, -E, -x e -X (além de suas versões "
"mais longas relacionadas) fazem com que um script ed seja emitido como "
"substituto do padrão. Finalmente, a escolha da opção -m (--merge) resulta em"
" diff3 realizar uma fusão internamente das alterações e gerar realmente a "
"fonte combinada."

msgid "Exit status is 0 if successful, 1 if conflicts, 2 if trouble."
msgstr ""
"Status keluaran adalah 0 se caso de sucesso, 1 no caso de conflito e 2 para "
"o caso do programa ter problemas."

msgid "internal error: screwup in format of diff blocks"
msgstr "Erro interno de sintaxe: format para bloco diff está desordenado."

msgid "%s: diff failed: "
msgstr "%s: diferença não foi possível concluir: "

msgid "internal error: invalid diff type in process_diff"
msgstr "Erro interno de tipo difícil em process_diff: tipe diff não é válido."

msgid "invalid diff format; invalid change separator"
msgstr ""
"O formato de diferença (format diff) não é válido; o separador de alterações"
" (separator perubahio) também não é válido."

msgid "invalid diff format; incomplete last line"
msgstr ""
"formato de diferença entre arquivos não é válido; a linha final está "
"incompleta."

msgid "subsidiary program %s could not be invoked"
msgstr "program subsider %s não pode ser chamado."

msgid "invalid diff format; incorrect leading line chars"
msgstr ""
"formato de diferença não é válido; caractere líder na linha não está "
"correto."

msgid "internal error: invalid diff type passed to output"
msgstr "Erro interno de tipo inválido inserido na saída"

msgid "input file shrank"
msgstr "o arquivo de entrada se contraiu involuntariamente."

msgid "cannot compare file names %s and %s"
msgstr "não é possível comparar o nome do arquivo %s e %s."

msgid "%s: recursive directory loop"
msgstr "%s: loop direto recursivo em diretório"

msgid "Thomas Lord"
msgstr "Thomas Lord"

msgid ""
"-o, --output=FILE            operate interactively, sending output to FILE"
msgstr ""
"-o, --output=FILE            operar de forma interativa, enviar saída para "
"FILE."

msgid ""
"-i, --ignore-case            consider upper- and lower-case to be the same"
msgstr ""
"-i, --ignore-case            ignora diferenças entre maiúsculas e "
"minúsculas."

msgid "-E, --ignore-tab-expansion   ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion   abaixa as alterações decorrentes da expansão do"
" tabulador."

msgid "-Z, --ignore-trailing-space  ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space abaixo de cada linha ignorar espaços em branco "
"ao final."

msgid ""
"-b, --ignore-space-change    ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change    ignorar alterações na quantidade de espaços em "
"branco."

msgid "-W, --ignore-all-space       ignore all white space"
msgstr "-W, --ignore-all-space       abaixar todas as white spaces\n"

msgid "-B, --ignore-blank-lines     ignore changes whose lines are all blank"
msgstr "-B,--ignore-blank-lines     abaixar as alterações em linhas vazias."

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes all whose lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE Abaixo das linhas que correspondem ao padrão "
"RE serão ignoradas."

msgid "    --strip-trailing-cr      strip trailing carriage return on input"
msgstr ""
"    --strip-trailing-cr      apagar retorno de linha no final do input."

msgid "-a, --text                   treat all files as text"
msgstr "-a, --text                   perlacupe todas as blocs como texto."

msgid ""
"-w, --width=NUM              output at most NUM (default 130) print columns"
msgstr ""
"-w, --width=NUM              kelihatan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"-l, --left-column            output only the left column of common lines"
msgstr ""
"-l, --left-column            hanya tampilkan kolom kiri baris yang sama"

msgid "-s, --suppress-common-lines  do not output common lines"
msgstr "-s, --suppress-common-lines Não exiba linhas comuns."

msgid "-t, --expand-tabs            expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs            Ekspansione do tabulador para espaços na saída."

msgid ""
"    --tabsize=NUM            tab stops at every NUM (default 8) print "
"columns"
msgstr ""
"    --tabsize=NUM            tab stop adalah setiap NUM (baku 8) kolom cetak"

msgid "-d, --minimal                try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal                usaçao keras para procurar conjuntos de "
"alterações mínimas."

msgid ""
"-H, --speed-large-files      assume large files, many scattered small "
"changes"
msgstr ""
"-H, --speed-large-files      assume large files with many small changes "
"dispersed."

msgid "    --diff-program=PROGRAM   use PROGRAM to compare files"
msgstr "    --diff-program=PROGRAM   utilize PROGRAM para comparar arquivos\n"

msgid "    --help                   display this help and exit"
msgstr "    --help                   Mostrar ajuda deste assistente e sair."

msgid "-v, --version                output version information and exit"
msgstr "-v, --version                Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... FILE1 FILE2\n"
msgstr "Pemakaian: %s [OPTION]... FILE1 FILE2\n"

msgid "Side-by-side merge of differences between FILE1 and FILE2."
msgstr "Penggabungan bersisian dari perbedaan antara FILE1 dan FILE2."

msgid "cannot interactively merge standard input"
msgstr "não é possível juntar a entrada padrão de forma interativa."

msgid "both files to be compared are directories"
msgstr "As duas pastas que estão sendo comparadas são diretórios."

msgid ""
"ed:\tEdit then use both versions, each decorated with a header.\n"
"eb:\tEdit then use both versions.\n"
"el or e1:\tEdit then use the left version.\n"
"er or e2:\tEdit then use the right version.\n"
"e:\tDiscard both versions then edit a new one.\n"
"l or 1:\tUse the left version.\n"
"r or 2:\tUse the right version.\n"
"s:\tSilently include common lines.\n"
"v:\tVerbosely include common lines.\n"
"q:\tQuit.\n"
msgstr ""
"ed: Ubique e utilize ambas as versões, cada uma decorada com um cabeçalho. \n"
" eb: Utilize ambas as versões.\n"
" el ou e1: Edite utilizando a versão esquerda.\n"
" er ou e2: Edite utilizando a versão direita.\n"
" e: Rejeitando ambas as versões atuais, crie uma nova para editar. \n"
" l  ou e1: Utilize a versão esquerda.\n"
" r  ou e2: Utilize a versão direita.\n"
" s: Aceite linha por linha sem interrupção diametral (diam-diam).\n"
" v: Aceite linha por linha com informações detalhadas (verbose). \n"
" q: Sair."

msgid "unrecognized prefix: %s"
msgstr "prefiks tidak dikenal: %s"

msgid "unparsable value for --palette"
msgstr "valor que não pode ser calculado para --palette"
