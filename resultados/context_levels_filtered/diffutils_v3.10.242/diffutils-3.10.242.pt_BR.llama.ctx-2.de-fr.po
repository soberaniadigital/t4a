msgid "-b, --print-bytes          print differing bytes"
msgstr "-b, --print-bytes      Exibir bytes diferentes."

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=SKIP         leva SKIP bytes iniciais dos dados de "
"entrada à fora."

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:SKIP2 \n"
"                         Ignore os primeiros SKIP1 bytes de FILE1 e os primeiros SKIP2 bytes de FILE2."

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose          Exibe os números de bytes e as valores dos bytes que "
"diferem."

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr "-n, --bytes=LIMIT      Comparar ao máximo LIMIT bytes."

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s, --quiet, --silent       Suprimir todas as exibições normais."

msgid "    --help                 display this help and exit"
msgstr "    --help                 Mostrar ajuda deste e sair."

msgid "-v, --version              output version information and exit"
msgstr "-v, --version              Mostrar informações de versão e sair."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "Uso: %s [OPÇÃO]... ARQUIVO1 [ARQUIVO2 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandar dua berkas byte per byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 e SKIP2 são o número de bytes que devem ser pulados no início de cada "
"arquivo (valor padrão é zero)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos necessários para as opções longas também são obrigatórios para"
" as opções curtas."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Os valores de SKIP devem ser acompanhados pelos seguintes sufixos multiplicativos, conforme indicado abaixo:\n"
"KB 1000\n"
"K 1024\n"
"MB 1.000.000\n"
"M 1.048.576\n"
"GB 1.000.000.000\n"
"G 1.073.741.824 e assim por diante para T, P, E, Z, Y."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se o arquivo for '-' ou não existir, lê a entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"O status de saída é 0 se as entradas forem idênticas, 1 caso contrário e 2 "
"em caso de erro."

