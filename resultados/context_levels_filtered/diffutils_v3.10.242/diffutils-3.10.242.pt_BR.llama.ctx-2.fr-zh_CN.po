msgid "-b, --print-bytes          print differing bytes"
msgstr "-b, --print-bytes           Mostrar os bytes que diferem"

msgid "-i, --ignore-initial=SKIP         skip first SKIP bytes of both inputs"
msgstr ""
"-i, --ignore-initial=SKIP         lewati SKIP byte awal dari kedua masukan"

msgid ""
"-i, --ignore-initial=SKIP1:SKIP2  skip first SKIP1 bytes of FILE1 and\n"
"                                      first SKIP2 bytes of FILE2"
msgstr ""
"-i, --ignore-initial=SKIP1:SKIP2  desconsiderar SKIP1 byte no início do "
"arquivo FILE1 e dos SKIP2 bytes no início do arquivo FILE2."

msgid ""
"-l, --verbose              output byte numbers and differing byte values"
msgstr ""
"-l, --verbose               Exibir todos os bytes e seus valores diferentes."

msgid "-n, --bytes=LIMIT          compare at most LIMIT bytes"
msgstr "-n, --bytes=LIMITE          bandar ao mais limite LIMITE bytes"

msgid "-s, --quiet, --silent      suppress all normal output"
msgstr "-s, --quiet, --silent       Cegue o fluxo normal de saída."

msgid "    --help                 display this help and exit"
msgstr "    --help                 Mostrar ajuda e sair"

msgid "-v, --version              output version information and exit"
msgstr "-v, --version               Mostrar versão e sair do programa."

msgid "Usage: %s [OPTION]... FILE1 [FILE2 [SKIP1 [SKIP2]]]\n"
msgstr "Utilização: %s [PILIHAN]... BERKAS1 [BERKAS2 [SKIP1 [SKIP2]]]"

msgid "Compare two files byte by byte."
msgstr "Bandingkan dua berkas byte per byte."

msgid ""
"The optional SKIP1 and SKIP2 specify the number of bytes to skip\n"
"at the beginning of each file (zero by default)."
msgstr ""
"SKIP1 dan SKIP2 adalah jumlah byte yang harus dilewati di awal setiap berkas"
" (nilai baku adalah nol)."

msgid ""
"Mandatory arguments to long options are mandatory for short options too.\n"
msgstr ""
"Os argumentos obrigatórios para as opções longas também são necessários para"
" as opções curtas."

msgid ""
"SKIP values may be followed by the following multiplicative suffixes:\n"
"kB 1000, K 1024, MB 1,000,000, M 1,048,576,\n"
"GB 1,000,000,000, G 1,073,741,824, and so on for T, P, E, Z, Y."
msgstr ""
"Valores de SKIP podem ser seguidos por um dos sufixos multiplicadores a seguir:\n"
"kB=1000, K=1024, MB=1.000.000, M=1.048.576,\n"
"GB=1.000.000.000, G=1.073.741.824, e assim por diante para T, P, E, Z, Y."

msgid "If a FILE is '-' or missing, read standard input."
msgstr "Se um arquivo for '-' ou não existir, ler da entrada padrão."

msgid "Exit status is 0 if inputs are the same, 1 if different, 2 if trouble."
msgstr ""
"O status de saída é 0 se as entradas forem idênticas, 1 se diferirem e 2 em "
"caso de erro."

msgid "invalid --bytes value %s"
msgstr "valor '%s' --byte inválido"

msgid "missing operand after %s"
msgstr "operando ausente após %s"

msgid "extra operand %s"
msgstr "operando extra %s"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "%s %s são diferentes: byte %<PRIdMAX>, linha %<PRIdMAX>"

msgid "%s %s differ: byte %<PRIdMAX>, line %<PRIdMAX> is %3o %s %3o %s\n"
msgstr "%s %s diferem: byte %<PRIdMAX>, linha %<PRIdMAX> é %3o %s, %3o %s"

msgid "cmp: EOF on %s which is empty\n"
msgstr "cmp: EOF encontrado em %s que está vazio"

msgid "cmp: EOF on %s after byte %<PRIdMAX>\n"
msgstr "cmp: EOF na %s após o byte %<PRIdMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, line %<PRIdMAX>\n"
msgstr "cmp: EOF na pilha %s após byte %<PRIdMAX>, linha %<PRIdMAX>"

msgid "cmp: EOF on %s after byte %<PRIdMAX>, in line %<PRIdMAX>\n"
msgstr "cmp: EOF na %s após o byte %<PRIdMAX>, em linha %<PRIdMAX>"

