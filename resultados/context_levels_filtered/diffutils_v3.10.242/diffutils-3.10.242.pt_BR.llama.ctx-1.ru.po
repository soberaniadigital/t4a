msgstr "- dispesifikasikan lebih dari satu berkas masukan"

msgid "read failed"
msgstr "falha na leitura do arquivo"

msgid "-A, --show-all              output all changes, bracketing conflicts"
msgstr ""
"-A, --show-all          exibir todas as alterações e conflitos no "
"documento\n"

msgid ""
"-e, --ed                    output ed script incorporating changes\n"
"                                from OLDFILE to YOURFILE into MYFILE"
msgstr ""
"-e, --ed                exibe o script ed que contém alterações do OLDFILE "
"para YOURFILE e coloca no MYFILE."

msgid "-E, --show-overlap          like -e, but bracket conflicts"
msgstr "-E, --show-overlap      como -e mais conflitos em parênteses."

msgid ""
"-3, --easy-only             like -e, but incorporate only nonoverlapping "
"changes"
msgstr "-3, --easy-only         como -e, mas apenas não sobreponha mudanças"

msgid ""
"-x, --overlap-only          like -e, but incorporate only overlapping "
"changes"
msgstr ""
"-x, --overlap-only      como -e, mas apenas as alterações que se sobrepõem"

msgid "-X                          like -x, but bracket conflicts"
msgstr ""
"-X                      como -x, mas com conflitos de API dentro das chaves"

