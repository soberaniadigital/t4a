msgstr ""
"    --color[=QUALIDADE]     cor de exibição; QUALIDADE pode ser 'sem', "
"'sócrono' ou 'automático'; sem especificar usa-se o valor automático."

msgid ""
"    --palette=PALETTE    the colors to use when --color is active; PALETTE is\n"
