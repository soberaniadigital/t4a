msgstr "Dávid Hays (David Hayes)"

msgid "Richard Stallman"
msgstr "Richard Stallman (Richard Stallman)"

msgid "Len Tower"
msgstr "Len Tower (Len Taower)"

msgid "invalid context length %s"
msgstr "a dificuldade de interpretar o contexto %s é inválida"

msgid "pagination not supported on this host"
msgstr "o paginamento não é suportado neste host"

msgid "too many file label options"
msgstr "ter muito mais opções de rótulo para arquivos"

msgid "invalid width %s"
msgstr "a largura %s não é válida"

msgid "conflicting width options"
msgstr "opções de largura conflitantes"

msgid "invalid horizon length %s"
msgstr "o número de linhas do horizonte %s não é válido"

msgid "invalid tabsize %s"
msgstr "A largura do tabulador %s não é válida"

msgid "conflicting tabsize options"
msgstr "conflicting options for tab size"

msgid "--from-file and --to-file both specified"
msgstr "--from-file dan --to-file precisam ser especificados como opções."

msgid "    --normal                  output a normal diff (the default)"
msgstr "    --normal            exibir diferenças em formato padrão (básico)"

msgid "-q, --brief                   report only when files differ"
msgstr ""
"-q, --brief             apresentar somente quando os arquivos são "
"diferentes."

msgid "-s, --report-identical-files  report when two files are the same"
msgstr ""
"-s, --report-identical-files  relatar quando dois arquivos são idênticos"

msgid ""
"-c, -C NUM, --context[=NUM]   output NUM (default 3) lines of copied context"
msgstr ""
"-c, -C %s, --context[=%s] exibir por %d (padrão 3) linhas do contexto "
"copiado."

msgid ""
"-u, -U NUM, --unified[=NUM]   output NUM (default 3) lines of unified "
"context"
msgstr ""
"-u, -U %s, --unified[=%s] exibir por %s (padrão 3) linhas do contexto "
"unificado."

msgid "-e, --ed                      output an ed script"
msgstr ""
"-e, --ed                      exibir como um script de edição (editor)"

msgid "-n, --rcs                     output an RCS format diff"
msgstr "-n, --rcs                     keluaran RCS diff\n"

msgid "-y, --side-by-side            output in two columns"
msgstr "-y, --side-by-side      exibir em duas colunas"

msgid ""
"-W, --width=NUM               output at most NUM (default 130) print columns"
msgstr ""
"-W, --width=NUM               keluarkan paling banyak NUM (baku 130) kolom "
"cetak."

msgid ""
"    --left-column             output only the left column of common lines"
msgstr ""
"    --left-column       exibir apenas a coluna esquerda das linhas comuns"

msgid "    --suppress-common-lines   do not output common lines"
msgstr "    --suppress-common-lines   não exibir linhas comuns"

msgid "-p, --show-c-function         show which C function each change is in"
msgstr ""
"-p, --show-c-function   exibir em qual função C está localizado cada um dos "
"alterações"

msgid "-F, --show-function-line=RE   show the most recent line matching RE"
msgstr ""
"-F, --show-function-line=RE\n"
"        Mostrar a linha de função mais recente que corresponde à RE."

msgid ""
"    --label LABEL             use LABEL instead of file name and timestamp\n"
"                                (can be repeated)"
msgstr ""
"    --label LABEL             utilizar LABEL em vez de nome do arquivo e da data/hora\n"
"                        (possível repetição)"

msgid "-t, --expand-tabs             expand tabs to spaces in output"
msgstr ""
"-t, --expand-tabs       expandindo tabuletas em espaços ao gerar saída"

msgid "-T, --initial-tab             make tabs line up by prepending a tab"
msgstr ""
"-T, --inicial-tab       alinhar linhas adicionando tabulação no início da "
"primeira coluna."

msgid ""
"    --tabsize=NUM             tab stops every NUM (default 8) print columns"
msgstr ""
"    --tabsize=NUM             tab stop adalah setiap NUM (baku 8) kolom "
"cetak"

msgid ""
"    --suppress-blank-empty    suppress space or tab before empty output "
"lines"
msgstr ""
"    --suppress-blank-empty\n"
"                        não incentive espaços ou tabulações antes de imprimir linhas em branco"

msgid "-l, --paginate                pass output through 'pr' to paginate it"
msgstr "-l, --paginate          direcionar a saída para 'pr' para paginação"

msgid ""
"-r, --recursive                 recursively compare any subdirectories found"
msgstr ""
"-r, --recursive         recursivamente comparando subdiretórios e arquivos"

msgid "    --no-dereference            don't follow symbolic links"
msgstr "    --no-dereference    não deve seguir símbolos de referência"

msgid "-N, --new-file                  treat absent files as empty"
msgstr ""
"-N, --new-file          considerar arquivos não existentes como vazios."

msgid "    --unidirectional-new-file   treat absent first files as empty"
msgstr ""
"    --unidirectional-new-file   tratar o primeiro arquivo não existente como"
" vazio"

msgid "    --ignore-file-name-case     ignore case when comparing file names"
msgstr ""
"    --ignore-file-case     desconsidere o caso das palavras em nomes de "
"arquivos"

msgid ""
"    --no-ignore-file-name-case  consider case when comparing file names"
msgstr ""
"    --no-ignore-file-name-case\n"
"                        considerar pequeno/grande ao comparar o nome do arquivo"

msgid "-x, --exclude=PAT               exclude files that match PAT"
msgstr "-x, --exclude=PAT               tanpa berkas yang cocok dengan PAT"

msgid ""
"-X, --exclude-from=FILE         exclude files that match any pattern in FILE"
msgstr ""
"-X, --exclude-from=FILE         excluir arquivos cujos nomes coincidam com "
"qualquer padrão listado no FILE."

msgid ""
"-S, --starting-file=FILE        start with FILE when comparing directories"
msgstr ""
"-S, --starting-file=FILE        começa com FILE ao comparar diretórios\n"

msgid ""
"    --from-file=FILE1           compare FILE1 to all operands;\n"
"                                  FILE1 can be a directory"
msgstr ""
"    --from-file=FILE1   comparar FILE1 com todos os operandos; \n"
"                        FILE1 pode ser um diretório"

msgid ""
"    --to-file=FILE2             compare all operands to FILE2;\n"
"                                  FILE2 can be a directory"
msgstr ""
"    --to-file=FILE2     comparar todos os operandos com FILE2; \n"
"                        FILE2 pode ser um diretório"

msgid ""
"-i, --ignore-case               ignore case differences in file contents"
msgstr ""
"-i, --ignore-case       ignorar diferenças entre letras maiúsculas e "
"minúsculas no conteúdo do arquivo."

msgid "-E, --ignore-tab-expansion      ignore changes due to tab expansion"
msgstr ""
"-E, --ignore-tab-expansion      ignorar alterações causadas pela expansão da"
" tabulação\n"

msgid "-Z, --ignore-trailing-space     ignore white space at line end"
msgstr ""
"-Z, --ignore-trailing-space    abaixa os espaços em branco no final da linha"

msgid ""
"-b, --ignore-space-change       ignore changes in the amount of white space"
msgstr ""
"-b, --ignore-space-change       ignorar alterações no número de espaços em "
"branco\n"

msgid "-w, --ignore-all-space          ignore all white space"
msgstr "-w, --ignore-all-space  ignorar todos os espaços em branco"

msgid ""
"-B, --ignore-blank-lines        ignore changes where lines are all blank"
msgstr ""
"-B, --ignore-blank-lines        ignorar alterações no número de linhas em "
"branco"

msgid ""
"-I, --ignore-matching-lines=RE  ignore changes where all lines match RE"
msgstr ""
"-I, --ignore-matching-lines=RE\n"
"        Ignorar alterações em linhas que correspondam ao RE"

msgid "-a, --text                      treat all files as text"
msgstr "-a, --text                      aplica todos os arquivos como texto"

msgid ""
"    --strip-trailing-cr         strip trailing carriage return on input"
msgstr "    --strip-trailing-cr apagar o retorno de carro da entrada final"

msgid "    --binary                    read and write data in binary mode"
msgstr "    --binary            escrever e ler arquivos no modo binário"

msgid ""
"-D, --ifdef=NAME                output merged file with '#ifdef NAME' diffs"
msgstr ""
"-D, --ifdef=NAME         ignorar o conteúdo do arquivo com a inclusão "
"'#ifdef NAME'"

msgid "    --GTYPE-group-format=GFMT   format GTYPE input groups with GFMT"
msgstr "    --GTYPE-group-format=GFMT   format grup masukan GTYPE dengan GFMT\n"

msgid "    --line-format=LFMT          format all input lines with LFMT"
msgstr "    --line-format=LFMT  formatar todas as linhas de entrada em LFMT"

msgid "    --LTYPE-line-format=LFMT    format LTYPE input lines with LFMT"
msgstr ""
"    --LTYPE-line-format=LFMT\n"
"                        Formatar as linhas de entrada do tipo LTYPE em conformidade com o formato LFMT."

msgid ""
"  These format options provide fine-grained control over the output\n"
"    of diff, generalizing -D/--ifdef."
msgstr ""
"Opsi format inicial oferece controle fino sobre o diferencial diff, "
"generalizando -D/--ifdef."

msgid "  LTYPE is 'old', 'new', or 'unchanged'.  GTYPE is LTYPE or 'changed'."
msgstr ""
"O LTYPE pode ser 'antigo', 'novo' ou 'inalterado'. O GTYPE é o mesmo que o "
"LTYPE, a menos que seja 'modificado'."

msgid ""
"  GFMT (only) may contain:\n"
"    %<  lines from FILE1\n"
"    %>  lines from FILE2\n"
"    %=  lines common to FILE1 and FILE2\n"
"    %[-][WIDTH][.[PREC]]{doxX}LETTER  printf-style spec for LETTER\n"
"      LETTERs are as follows for new group, lower case for old group:\n"
"        F  first line number\n"
"        L  last line number\n"
"        N  number of lines = L-F+1\n"
"        E  F-1\n"
"        M  L+1\n"
"    %(A=B?T:E)  if A equals B then T else E"
msgstr ""
"GFMT pode conter (só):\n"
"    %<  linhas do arquivo FILE1\n"
"    %>  linhas do arquivo FILE2\n"
"    %=  linhas comuns aos arquivos FILE1 e FILE2\n"
"    %[-][LARANJA][.[DECIMAL]]{doxX}LETRA  formato para LETRAS em estilo printf, a seguir: \n"
"        F  primeira letra do grupo (novos) - 'F'\n"
"        L  última letra do grupo (novos) - 'L'\n"
"        N  número de linhas = L-F+1\n"
"        E  antecessora da primeira letra do grupo (antigos) - F-1\n"
"        M  sucessora da última letra do grupo (antigos) - L+1\n"
"    %(A=B?T:E)  se A for igual a B, então T, caso contrário E"

msgid ""
"  LFMT (only) may contain:\n"
"    %L  contents of line\n"
"    %l  contents of line, excluding any trailing newline\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec for input line number"
msgstr ""
"  LFMT dapat berisi:\n"
"    %L  isi baris\n"
"    %l  isi baris, tanpa baris baru\n"
"    %[-][WIDTH][.[PREC]]{doxX}n  printf-style spec untuk nomor baris masukan"

msgid ""
"  Both GFMT and LFMT may contain:\n"
"    %%  %\n"
"    %c'C'  the single character C\n"
"    %c'\\OOO'  the character with octal code OOO\n"
"    C    the character C (other characters represent themselves)"
msgstr ""
"GFMT ou LFMT podem conter: \n"
"%%\n"
"%c'C'\tumor um caractere C (caracteres, representando a si mesmos)\n"
"%c'^'\tumor com o código octal 128\n"

msgid "-d, --minimal            try hard to find a smaller set of changes"
msgstr ""
"-d, --minimal           tenta encontrar o conjunto de alterações mínimos "
"mais pequeno possível para Keras"

msgid ""
"    --horizon-lines=NUM  keep NUM lines of the common prefix and suffix"
msgstr ""
"    --horizon-lines=NUM mantendo NUM linhas antes e depois das distintas\n"

msgid ""
"    --speed-large-files  assume large files and many scattered small changes"
msgstr ""
"    --speed-large-files assume that large and numerous small changes are "
"dispersed in the files"

msgid ""
