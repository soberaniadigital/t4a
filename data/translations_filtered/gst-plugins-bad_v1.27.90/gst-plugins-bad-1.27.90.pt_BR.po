msgstr "O dispositivo \"%s\" não existe."

#: sys/dvb/gstdvbsrc.c:1648
#, c-format
msgid "Could not open frontend device \"%s\"."
msgstr "Não foi possível abrir o dispositivo de interface \"%s\"."

